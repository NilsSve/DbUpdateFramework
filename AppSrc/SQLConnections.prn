96014>>>>>>>    // finds the target seed value in the updatecolumn. If we autoseed and there is a
96014>>>>>>>    // seed value (psSeedValue), attempt to find GE that value, else move to first row
96014>>>>>>>    // Suitable for augmentation
96014>>>>>>>    Procedure OnSeedData
96016>>>>>>>        Integer iUpdateColumn iSortColumn
96016>>>>>>>        Boolean bSeed bAuto
96016>>>>>>>        String sValue
96016>>>>>>>        Handle hoCol
96016>>>>>>>
96016>>>>>>>        Get piUpdateColumn to iUpdateColumn
96017>>>>>>>        Get psSeedValue to sValue
96018>>>>>>>        Get pbAutoSeed to bSeed
96019>>>>>>>        Get piSortColumn to iSortColumn
96020>>>>>>>        Get pbAutoOrdering to bAuto
96021>>>>>>>        // if not yet sorted and this is auto ordering we will
96021>>>>>>>        // sort the data for the search column. We do this to make the
96021>>>>>>>        // column search GE logic work properly. 
96021>>>>>>>        If (bSeed and bAuto and iUpdateColumn<>-1 and iSortColumn<>iUpdateColumn) Begin
96023>>>>>>>            Get ColumnObject iUpdateColumn to hoCol
96024>>>>>>>            Send SortGridByColumn hoCol False
96025>>>>>>>        End
96025>>>>>>>>
96025>>>>>>>
96025>>>>>>>        If (bSeed and sValue<>"" and iUpdateColumn<>-1) Begin
96027>>>>>>>            Send RequestFindColumnValue iUpdateColumn sValue True 0  
96028>>>>>>>        End
96028>>>>>>>>
96028>>>>>>>        Else Begin
96029>>>>>>>            Send MovetoFirstRow
96030>>>>>>>        End
96030>>>>>>>>
96030>>>>>>>
96030>>>>>>>    End_Function
