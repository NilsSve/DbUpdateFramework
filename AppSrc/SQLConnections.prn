89057>>>    // Removes all driver identifications (e.g. "MSSQLDRV;MyTable" or "MyTable.MSSQLDRV"
89057>>>    // from the passed filelist.
89057>>>    // Returns the number of tables affected.
89057>>>    Function SqlUtilFilelistRemoveDriverInfo String sFilelist Returns Integer
89059>>>        String sCurrentFileList sRootName sDisplayName sLogicalName sVal
89059>>>        Integer iRetval
89059>>>        Handle hTable
89059>>>        
89059>>>        // We first save the current filelist as the passed filelist name
89059>>>        // may come from another workspace, to restore it when we're ready.
89059>>>        Get_Attribute DF_FILELIST_NAME to sCurrentFileList
89062>>>        Set_Attribute DF_FILELIST_NAME to sFilelist
89065>>>        Move 0 to hTable
89066>>>        Move 0 to iRetval
89067>>>        
89067>>>        Repeat
89067>>>>
89067>>>            Get_Attribute DF_FILE_NEXT_USED of hTable to hTable
89070>>>            If (hTable <> 0) Begin
89072>>>                Get_Attribute DF_FILE_ROOT_NAME    of hTable to sRootName
89075>>>                Get_Attribute DF_FILE_DISPLAY_NAME of hTable to sDisplayName
89078>>>                Get_Attribute DF_FILE_LOGICAL_NAME of hTable to sLogicalName
89081>>>                Move (Uppercase(sRootName)) to sVal
89082>>>                If (sVal contains MSSQLDRV_ID or sVal contains DB2_DRV_ID or sVal contains ODBC_DRV_ID) Begin
89084>>>                    // Prefixes:
89084>>>                    Move (Replace((MSSQLDRV_ID + ":"), sRootName, "")) to sRootName
89085>>>                    Move (Replace((DB2_DRV_ID  + ":"), sRootName, "")) to sRootName
89086>>>                    Move (Replace((ODBC_DRV_ID + ":"), sRootName, "")) to sRootName
89087>>>                    // Suffixes:
89087>>>                    Move (Replace(("." + MSSQLDRV_ID), sRootName, "")) to sRootName
89088>>>                    Move (Replace(("." + DB2_DRV_ID),  sRootName, "")) to sRootName
89089>>>                    Move (Replace(("." + ODBC_DRV_ID), sRootName, "")) to sRootName
89090>>>                    
89090>>>                    // Change Filelist entry:
89090>>>                    Set_Attribute DF_FILE_ROOT_NAME of hTable          to sRootName
89093>>>
89093>>>                    Move (Lowercase(sDisplayName)) to sVal
89094>>>                    If (sVal contains "dbo.") Begin
89096>>>                        Move (Replace("dbo.", sDisplayName, ""))       to sDisplayName
89097>>>                        
89097>>>                        // Change Filelist entry:
89097>>>                        Set_Attribute DF_FILE_DISPLAY_NAME of hTable   to sDisplayName
89100>>>                    End
89100>>>>
89100>>>                    Increment iRetval
89101>>>                End
89101>>>>
89101>>>            End
89101>>>>
89101>>>        Until (hTable = 0)
89103>>>        
89103>>>        Set_Attribute DF_FILELIST_NAME to sCurrentFileList
89106>>>        
89106>>>        Function_Return iRetval
89107>>>    End_Function
