80112>>>Function vMakeTempFile Returns String
#REM AMBIGUOUS METHODS ON .DESKTOP. ARE .NOT. RECOMMENDED (OBSOLETE TECHNIQUE)
80114>>>    Integer iRetval
80114>>>    String  sTempPath sTempFileName sPrefixString
80114>>>    Pointer lpTempPath lpTempFileName lpPrefixString
80114>>>
80114>>>    Move (Repeat (Character (0), 255)) To sTempPath
80115>>>    GetAddress Of sTempPath To lpTempPath
80116>>>    Move (vWin32_GetTempPath (255, lpTempPath)) To iRetVal
80117>>>
80117>>>    If (sTempPath = "") Begin
80119>>>       Get_Current_Directory To sTempPath
80120>>>    End
80120>>>>
80120>>>    Move (pad(sTempPath,vMax_Path-14)) To sTempPath // *WvA: 28-04-2005 Quote from msdn: The string cannot be longer than MAX_PATH-14 characters.
80121>>>    Move (Repeat (Character (0), 255)) To sTempFileName
80122>>>    GetAddress Of sTempFileName To lpTempFileName
80123>>>    Move ("tmp"+character(0)) To sPrefixString // **WvA: 28-04-2005 Added a null
80124>>>    GetAddress Of sPrefixString To lpPrefixString
80125>>>    GetAddress Of sTempPath To lpTempPath
80126>>>    Move (vWin32_GetTempFileName (lpTempPath, lpPrefixString, 0, lpTempFileName)) To iRetval
80127>>>    If (iRetval = 0) Begin  // **WvA: 28-04-2005 Changed condition, the api call returns 0 if an error occurs
80129>>>        Move "" To sTempFileName
80130>>>    End
