88435>>>    // Enumerate SQL Servers. 
88435>>>    // Pass a driver id. Returns a string array.                     
88435>>>    // The iDataSourceType (iDatSrcType) parameter is optional and is for the ODBC driver only.
88435>>>    // Note: Returns servers for MSSQLDRV; else data-sources on the machine.
88435>>>    Function SqlUtilEnumerateServers String sDriverID Integer iDatSrcType Returns String[]
88437>>>        String[] sReturnArray
88438>>>        Handle hoSQLHandler
88438>>>        String sServer
88438>>>        Integer iCount iNumItems iDataSourceType
88438>>>        Boolean bOK
88438>>>        
88438>>>        If (num_arguments > 1) Begin
88440>>>            Move iDatSrcType to iDataSourceType
88441>>>        End                                    
88441>>>>
88441>>>        
88441>>>        Case Begin
88441>>>            Case (sDriverID = MSSQLDRV_ID) 
88443>>>                Get phoMSSQLHandler to hoSQLHandler
88444>>>                    Get EnumerateServersLocal of hoSQLHandler to iNumItems
88445>>>                    If (iNumItems = 0) Begin
88447>>>                        Get EnumerateServers of hoSQLHandler to iNumItems
88448>>>                    End            
88448>>>>
88448>>>                For iCount from 0 to (iNumItems - 1)
88454>>>>
88454>>>                    Get String_Value of hoSQLHandler item iCount to sServer
88455>>>                    Move (Trim(sServer)) to sReturnArray[iCount]
88456>>>                Loop
88457>>>>
88457>>>                Case Break 
88458>>>    
88458>>>            Case (sDriverID = DB2_DRV_ID) 
88461>>>                Get phoDB2SQLHandler to hoSQLHandler
88462>>>                Send SeedDataSources of hoSQLHandler          
88463>>>                Move 0 to iCount
88464>>>                Repeat
88464>>>>
88464>>>                    Get DataSources of hoSQLHandler to sServer
88465>>>                    If (sServer <> "") Begin   
88467>>>                        Move (Replace(",", sServer, "")) to sServer
88468>>>                        Move sServer to sReturnArray[iCount]
88469>>>                    End
88469>>>>
88469>>>                    Increment iCount    
88470>>>                Until (sServer = "")
88472>>>                Case Break
88473>>>    
88473>>>            Case (sDriverID = ODBC_DRV_ID) 
88476>>>                Get phoODBCSQLHandler to hoSQLHandler
88477>>>                Set DataSourceType of hoSQLHandler to iDataSourceType       
88478>>>                Move 0 to iCount
88479>>>                Repeat
88479>>>>
88479>>>                    Get DataSources of hoSQLHandler to sServer
88480>>>                    If (sServer <> "") Begin   
88482>>>                        Move (Replace(",", sServer, ", ")) to sServer
88483>>>                        Move sServer to sReturnArray[iCount]
88484>>>                    End
88484>>>>
88484>>>                    Increment iCount    
88485>>>                Until (sServer = "")
88487>>>                Case Break    
88488>>>            
88488>>>            Case (sDriverID = SQLFLEX)  
88491>>>                Get _MertechEnumerateSQLFlexServers to sReturnArray
88492>>>                Case Break
88493>>>            
88493>>>            Case (sDriverID = ORAFLEX)          
88496>>>                Get _MertechEnumerateORAFLEXServers to sReturnArray
88497>>>                Case Break
88498>>>            
88498>>>            // There appearantly is no way to enumerate servers for this backend.
88498>>>            Case (sDriverID = MDSPgSQL)
88501>>>                Move "localhost" to sReturnArray[0]
88502>>>                Case Break
88503>>>            
88503>>>            // There appearantly is no way to enumerate servers for this backend.
88503>>>            Case (sDriverID = MDSMySQL)
88506>>>                Move "localhost" to sReturnArray[0]
88507>>>                Case Break
88508>>>            
88508>>>            Case Else
88508>>>                Error DFERR_PROGRAM "Unsupported DriverID passed to SqlUtilEnumerateServers function"
88509>>>>
88509>>>        Case End
88509>>>
88509>>>        Function_Return sReturnArray
88510>>>    End_Function
88511>>>    
88511>>>    // Returns all databases as a string array for the passed driver id.
88511>>>    Function SqlUtilEnumerateDatabases String sDriverID Returns String[]
88513>>>        String[] sReturnArray                                                    
88514>>>        String sUserID sPassword 
88514>>>        Boolean bOK
88514>>>        
88514>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
88515>>>        If (bOK = False) Begin
88517>>>            Function_Return sReturnArray
88518>>>        End    
88518>>>>
88518>>>        
88518>>>        Case Begin
88518>>>            Case (sDriverID = MSSQLDRV_ID)
88520>>>                Get _SqlDatabasesArrayMSSQL to sReturnArray
88521>>>                Case Break                                                            
88522>>>            Case (sDriverID = DB2_DRV_ID)
88525>>>                Get _SqlDatabasesArrayDB2 to sReturnArray
88526>>>                Case Break
88527>>>
88527>>>            // Enumeration of ODBC databases should be irrelevant as the database
88527>>>            // should have been specified when the ODBC source was setup with the ODBC manager.
88527>>>            Case (sDriverID = ODBC_DRV_ID)
88530>>>                Case Break
88531>>>
88531>>>            Case (sDriverID = SQLFLEX)
88534>>>                Get SqlProcedureArrayMertech "sp_databases" "" to sReturnArray
88535>>>                Case Break
88536>>>
88536>>>            Case (sDriverID = MDSPgSQL)
88539>>>                Get SqlEnumerateEsqlMertech "SELECT datname FROM pg_database" to sReturnArray
88540>>>                Case Break
88541>>>                 
88541>>>            Case (sDriverID = MDSMySQL)
88544>>>                Get SqlEnumerateEsqlMertech "show databases" to sReturnArray
88545>>>                Case Break 
88546>>>            
88546>>>            Case (sDriverID = ORAFLEX)  
88549>>>                Get SqlEnumerateEsqlMertech "SELECT NAME FROM v$database" to sReturnArray
88550>>>                Case Break
88551>>>
88551>>>            Case Else
88551>>>                Error DFERR_PROGRAM "Unsupported DriverID passed to SqlUtilEnumerateDatabases function"
88552>>>>
88552>>>        Case End  
88552>>>        
88552>>>        Function_Return sReturnArray
88553>>>    End_Function
88554>>>    
88554>>>    // Returns all table spaces as a string array for the passed driver id.
88554>>>    Function SqlUtilEnumerateTableSpaces String sDriverID Returns String[]
88556>>>        String[] sReturnArray                                                    
88557>>>        String sServer sUserID sPassword 
88557>>>        Boolean bOK
88557>>>        
88557>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
88558>>>        If (bOK = False) Begin
88560>>>            Function_Return sReturnArray
88561>>>        End    
88561>>>>
88561>>>        
88561>>>        Case Begin
88561>>>            Case (sDriverID = DB2_DRV_ID)
88563>>>                Get SqlEnumerateEsqlDAW "select tablespace_name from dba_tablespaces" 1 to sReturnArray
88564>>>                Case Break
88565>>>
88565>>>            Case (sDriverID = MDSPgSQL)
88568>>>                Get SqlEnumerateEsqlMertech "SELECT spcname FROM pg_tablespace" 1 to sReturnArray
88569>>>                Case Break
88570>>>
88570>>>            Case (sDriverID = ORAFLEX)  
88573>>>                Get SqlEnumerateEsqlMertech "SELECT TABLESPACE_NAME FROM USER_TABLESPACES" 1 to sReturnArray
88574>>>                Case Break 
88575>>>
88575>>>            Case Else     
88575>>>                Error DFERR_PROGRAM "Unsupported driver passed to SqlUtilEnumerateTableSpaces function."
88576>>>>
88576>>>                Case Break
88577>>>        Case End  
88577>>>        
88577>>>        Function_Return sReturnArray
88578>>>    End_Function
88579>>>    
88579>>>    // Returns all schemas as a string array for the passed driver id.
88579>>>    Function SqlUtilEnumerateSchemas String sDriverID Returns String[]
88581>>>        String[] sReturnArray                                                    
88582>>>        Boolean bOK
88582>>>        
88582>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
88583>>>        If (bOK = False) Begin
88585>>>            Function_Return sReturnArray
88586>>>        End    
88586>>>>
88586>>>        
88586>>>        Case Begin
88586>>>            Case (sDriverID = DB2_DRV_ID)
88588>>>                Get SqlEnumerateEsqlDAW "select schemaname from syscat.schemata" 1 to sReturnArray
88589>>>                Case Break
88590>>>
88590>>>            Case (sDriverID = MDSPgSQL)                                   
88593>>>                Get SqlEnumerateEsqlMertech "select schema_name from information_schema.schemata" 1 to sReturnArray
88594>>>                Case Break
88595>>>
88595>>>            Case (sDriverID = ORAFLEX)  
88598>>>                Get SqlEnumerateEsqlMertech "SELECT username from dba_users WHERE default_tablespace not in ('SYSTEM','SYSAUX')" 1 to sReturnArray
88599>>>                Case Break 
88600>>>
88600>>>            Case Else     
88600>>>                Error DFERR_PROGRAM "Unsupported driver passed to SqlUtilEnumerateSchemas function."
88601>>>>
88601>>>                Case Break
88602>>>        Case End  
88602>>>        
88602>>>        Function_Return sReturnArray
88603>>>    End_Function
88604>>>    
88604>>>    // Returns a string array with all tables for the current database.
88604>>>    Function SqlUtilEnumerateTables String sDriverID Returns String[]
88606>>>        String[] sReturnArray sArray
88608>>>        String sServer sDatabase sConnectionString sSelect sSchema     
88608>>>        Integer iSize iCount
88608>>>        Boolean bOK
88608>>>
88608>>>        If (sDriverID = DATAFLEX_ID) Begin
88610>>>            Function_Return sArray        
88611>>>        End                       
88611>>>>
88611>>>        
88611>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
88612>>>        If (bOK = False) Begin
88614>>>            Function_Return sReturnArray
88615>>>        End    
88615>>>>
88615>>>        
88615>>>        Get psConnectionString to sConnectionString
88616>>>        Get psDatabase to sDatabase                               
88617>>>        Get psSchema   to sSchema                                                                              
88618>>>                                                                                                              
88618>>>        Case Begin
88618>>>            Case (sDriverID = MSSQLDRV_ID)
88620>>>                Get _SqlTableArrayDAW to sReturnArray
88621>>>                Case Break                                                            
88622>>>            
88622>>>            Case (sDriverID = DB2_DRV_ID)
88625>>>                Get _SqlTableArrayDAW to sReturnArray
88626>>>                Case Break
88627>>>            
88627>>>            Case (sDriverID = ODBC_DRV_ID)
88630>>>                Get _SqlTableArrayDAW to sReturnArray
88631>>>                Case Break
88632>>>            
88632>>>            Case (sDriverID = SQLFLEX)
88635>>>                Move ("SELECT TABLE_NAME FROM" * sDatabase + ".INFORMATION_SCHEMA.TABLES WHERE TABLE_TYPE != 'VIEW'") to sSelect
88636>>>                Get SqlEnumerateEsqlMertech sSelect to sReturnArray
88637>>>                Case Break
88638>>>            
88638>>>            Case (sDriverID = MDSMySQL)                                   
88641>>>                Move ("SELECT TABLE_NAME from INFORMATION_SCHEMA.TABLES where TABLE_SCHEMA = '" + sDatabase + "' and TABLE_TYPE = 'BASE TABLE' order by TABLE_NAME") to sSelect
88642>>>                Get SqlEnumerateEsqlMertech sSelect to sReturnArray
88643>>>                Case Break
88644>>>            
88644>>>            Case (sDriverID = MDSPgSQL)                                          
88647>>>                Move "select tablename, schemaname from pg_catalog.pg_tables order by tablename"  to sSelect
88648>>>                Get SqlEnumerateEsqlMertech sSelect "" to sReturnArray
88649>>>                Case Break            
88650>>>            
88650>>>            Case (sDriverID = ORAFLEX)                                          
88653>>>                Move "SELECT table_name from user_tables" to sSelect  
88654>>>                Get SqlEnumerateEsqlMertech sSelect to sArray
88655>>>                Move (SizeOfArray(sArray)) to iSize
88656>>>                Decrement iSize
88657>>>                For iCount from 0 to iSize
88663>>>>
88663>>>                    If (not(sArray[iCount] contains "$")) Begin
88665>>>                        Move sArray[iCount] to sReturnArray[SizeOfArray(sReturnArray)]
88666>>>                    End
88666>>>>
88666>>>                Loop
88667>>>>
88667>>>                Case Break            
88668>>>
88668>>>            Case Else     
88668>>>                Error DFERR_PROGRAM "Unsupported driver passed to SqlUtilEnumerateTables function."
88669>>>>
88669>>>                Case Break
88670>>>        Case End
88670>>>        
88670>>>        Function_Return sReturnArray
88671>>>    End_Function
88672>>>    
88672>>>    // Returns a string array with all table columns/fields for the passed table handle and driver id.
88672>>>    Function SqlUtilEnumerateColumns String sDriverID String sTableName Returns String[]
88674>>>        String[] sReturnArray                                          
88675>>>        String sServer sConnectionString sSelect sSchema
88675>>>        Boolean bOK
88675>>>        
88675>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
88676>>>        If (bOK = False) Begin
88678>>>            Error DFERR_PROGRAM ("Unsupported driver. A list of table columns could not be retrieved for:" * sDriverID + ".")
88679>>>>
88679>>>            Function_Return sReturnArray
88680>>>        End   
88680>>>>
88680>>>       
88680>>>        Get psConnectionString to sConnectionString  
88681>>>        Get psSchema to sSchema
88682>>>        
88682>>>        Case Begin
88682>>>            Case (sDriverID = MSSQLDRV_ID)    
88684>>>                Move ("select name from sys.columns where [object_id] = object_id('dbo." + sTableName + "')") to sSelect
88685>>>                Get SqlEnumerateEsqlDAW sSelect 1 to sReturnArray
88686>>>                Case Break
88687>>>
88687>>>            Case (sDriverID = DB2_DRV_ID) 
88690>>>                Move ("SELECT colname from syscat.columns WHERE tabschema = '" + sSchema + "'" * "AND tabname = '" + sTableName + "'") to sSelect  
88691>>>                Get SqlEnumerateEsqlDAW sSelect 1 to sReturnArray
88692>>>                Case Break
88693>>>
88693>>>            Case (sDriverID = SQLFLEX)
88696>>>                Move ("select name from sys.columns where [object_id] = object_id('dbo." + sTableName + "')") to sSelect
88697>>>                Get SqlEnumerateEsqlMertech sSelect 1 to sReturnArray
88698>>>                Case Break
88699>>>            
88699>>>            Case (sDriverID = MDSMySQL) 
88702>>>                Move ("SHOW COLUMNS FROM" * sTableName) to sSelect
88703>>>                Get SqlEnumerateEsqlMertech sSelect 1 to sReturnArray
88704>>>                Case Break
88705>>>            
88705>>>            Case (sDriverID = MDSPgSQL) 
88708>>>                Move ("select column_name, data_type, character_maximum_length from INFORMATION_SCHEMA.COLUMNS where table_name = '" +sTableName + "'") to sSelect
88709>>>                Get SqlEnumerateEsqlMertech sSelect 1 to sReturnArray
88710>>>                Case Break            
88711>>>            
88711>>>            Case (sDriverID = ORAFLEX) 
88714>>>                Move ("SELECT column_name from user_tab_cols WHERE table_name = '" + sTableName + "'") to sSelect
88715>>>                Get SqlEnumerateEsqlMertech sSelect 1 to sReturnArray
