84558>>>>>>>>>>>    Function SQLFileConnect Integer iFileNum Returns Integer
84560>>>>>>>>>>>        Boolean bIsOpen
84560>>>>>>>>>>>        String sDriver sServer
84560>>>>>>>>>>>        tCLIHandleMap[] maps
84560>>>>>>>>>>>        tCLIHandleMap[] maps
84561>>>>>>>>>>>        tCLIHandleMap conn
84561>>>>>>>>>>>        tCLIHandleMap conn
84561>>>>>>>>>>>
84561>>>>>>>>>>>        Get_Attribute DF_FILE_OPENED of iFileNum to bIsOpen
84564>>>>>>>>>>>        If (bIsOpen) Begin
84566>>>>>>>>>>>            //*** Fill the driver id, assume longest is 255 characters
84566>>>>>>>>>>>            Move (Repeat(' ', 255)) to sDriver
84567>>>>>>>>>>>            Move (Repeat(' ', 255)) to sServer
84568>>>>>>>>>>>            Get_Attribute DF_FILE_DRIVER of iFileNum to sDriver
84571>>>>>>>>>>>            Get_Attribute DF_FILE_SERVER_NAME of iFileNum to sServer
84574>>>>>>>>>>>
84574>>>>>>>>>>>            Indicate Err False
84575>>>>>>>>>>>            
84575>>>>>>>>>>>            Get ptCLIHandleMaps to maps
84576>>>>>>>>>>>            Move sDriver to conn.sDriver
84577>>>>>>>>>>>            Move sServer to conn.sConnect
84578>>>>>>>>>>>    
84578>>>>>>>>>>>            If (SizeOfArray(maps) > 0) Move (maps[(SizeOfArray(maps)-1)].iHdbc+1) to conn.iHdbc
84581>>>>>>>>>>>            Else Move 1 to conn.iHdbc
84583>>>>>>>>>>>            
84583>>>>>>>>>>>            Set CurrentConnection to sDriver sServer 
84584>>>>>>>>>>>            If (not(Err)) Begin
84586>>>>>>>>>>>                Move conn to maps[(SizeOfArray(maps))]
84587>>>>>>>>>>>                Set ptCLIHandleMaps to maps
84588>>>>>>>>>>>                Set ptCLIHandleMap to conn
84589>>>>>>>>>>>            End
84589>>>>>>>>>>>>
84589>>>>>>>>>>>
84589>>>>>>>>>>>            Send StoreHandleInfo conn.iHdbc conn.sDriver
84590>>>>>>>>>>>            Set piBindFile to iFileNum
84591>>>>>>>>>>>        End
84591>>>>>>>>>>>>
84591>>>>>>>>>>>        Else Error 4099 "File Not Open"
84593>>>>>>>>>>>
84593>>>>>>>>>>>        //*** Return success status
84593>>>>>>>>>>>        Function_Return (not(Err))
84594>>>>>>>>>>>    End_Function
