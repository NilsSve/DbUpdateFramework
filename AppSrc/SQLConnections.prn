86651>>>    Function DriverIndex String sDriverID Returns Integer
86653>>>        String  sCurrentDriver
86653>>>        Integer iNumberOfDrivers iDriver iCount iRetval
86653>>>        
86653>>>        Move 0 to iDriver
86654>>>        Get_Attribute DF_NUMBER_DRIVERS to iNumberOfDrivers
86657>>>        For iCount from 1 to iNumberOfDrivers
86663>>>>
86663>>>            Get_Attribute DF_DRIVER_NAME of iCount to sCurrentDriver
86666>>>            If ( Uppercase(sCurrentDriver) = Uppercase(sDriverID) ) Begin
86668>>>                Function_Return iCount
86669>>>            End
86669>>>>
86669>>>        Loop
86670>>>>
86670>>>        
86670>>>        // If driver not previously loaded; attempt to do so now.
86670>>>        If (iDriver = 0) Begin
86672>>>            Move 0 to LastErr
86673>>>            Load_Driver sDriverID   
86674>>>            // If driver could not be loaded.
86674>>>            If (LastErr = 4255) Begin
86676>>>                Move 0 to iCount
86677>>>            End
86677>>>>
86677>>>            Function_Return iCount
86678>>>        End
86678>>>>
86678>>>        Function_Return 0
86679>>>    End_Function
86680>>>        
86680>>>    // This will update connection settings of the cCLIHandler object with that passed struct values.
86680>>>    Procedure UpdateConnectionString tSQLConnection SQLConnection
86682>>>        String sRetval sDriverID sConnectionID sConnectionString sServer sDatabase sUserID sPassword
86682>>>        Boolean bTrusted bSilent  
86682>>>        Integer iConnOptions
86682>>>        
86682>>>        Move SQLConnection.sDriverID     to sDriverID
86683>>>        Move SQLConnection.sConnectionID to sConnectionID
86684>>>        Move SQLConnection.sServer       to sServer
86685>>>        Move SQLConnection.sDatabase     to sDatabase
86686>>>        Move SQLConnection.bTrusted      to bTrusted
86687>>>        Move SQLConnection.sUserID       to sUserID
86688>>>        Move SQLConnection.sPassword     to sPassword  
86689>>>        Move SQLConnection.bSilentLogin  to bSilent
86690>>>        
86690>>>        // Note that this message will first delete the current ConnectionID if it exists; which is needed by the cCLIHandler logic.
86690>>>        Send CreateSQLConnection sDriverID sConnectionID sServer sDatabase bTrusted sUserID sPassword bSilent
86691>>>        
86691>>>    End_Procedure
86692>>>
86692>>>    // Called when the object is constructed.
86692>>>    // It will check the psDriverID for a ConnectionID and save it
86692>>>    // as psConnectionID property. It is later used whenever a login to
86692>>>    // the database is needed.
86692>>>    Procedure AutoSetConnectionID
86694>>>        String sConnectionID sValue sDriverID sConnectionString
86694>>>        Integer iDriver iNumConn iConn iConnOptions iRetval
86694>>>        Handle hoCLI                 
86694>>>        Boolean bOK bSilent bMertechDriver
86694>>>        
86694>>>        Get pbSilentLogin      to bSilent
86695>>>        Get psConnectionID     to sConnectionID                            
86696>>>        Get psConnectionString to sConnectionString
86697>>>        // Get the driver Connection ID string & set the psConnectionString property.
86697>>>        Get psDriverID to sDriverID
86698>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
86699>>>        If (bOK = False) Begin
86701>>>            Procedure_Return              
86702>>>        End                 
86702>>>>
86702>>>        
86702>>>        // Mertech drivers can't use connection ID's.
86702>>>        Get IsMertechDriver sDriverID to bMertechDriver    
86703>>>        If (bMertechDriver = True) Begin         
86705>>>            // This ensures that the correct Server & Database attributes are set both for 
86705>>>            // embedded SQL calls and "normal" database commands like e.g. "Open".
86705>>>            Get _MertechSQLManagerHandle to hoCLI
86706>>>            Procedure_Return
86707>>>        End
86707>>>>
86707>>>        
86707>>>        Get DriverIndex sDriverID          to iDriver
86708>>>        // If driver not loaded; load it.
86708>>>        If (iDriver = 0) Begin
86710>>>            Load_Driver sDriverID
86711>>>            Get DriverIndex sDriverID      to iDriver
86712>>>        End                      
86712>>>>
86712>>>        // This shouldn't be possible; unless the driver.dll file is missing or something...
86712>>>        If (iDriver = 0) Begin
86714>>>            Error DFERR_PROGRAM ("The database driver could not be loaded! Connection to database failed." * sDriverID)
86715>>>>
86715>>>            Procedure_Return
86716>>>        End
86716>>>>
86716>>>
86716>>>        Get Create (RefClass(cCLIHandler)) to hoCLI
86717>>>        Set psDriverID of hoCLI            to sDriverID   
86718>>>        // Delete the connection first; in case it exists
86718>>>        Get DeleteConnectionID of hoCLI sConnectionID -1 to iRetval
86719>>>        Get CreateConnectionID of hoCLI sConnectionID sConnectionString bSilent to iRetval
86720>>>
86720>>>        Send Destroy of hoCLI 
86721>>>    End_Procedure
86722>>>
86722>>>    // Returns the handle of the Mertech SQL handler.
86722>>>    // It also ensures that the correct Server & Database attributes are set both for 
86722>>>    // embedded SQL calls and "normal" database commands like e.g. "Open".  
86722>>>    // Note: This does _not_ return a proper CLI handler handle as it is not in this class.
86722>>>    //       So the return value is of no use! But we don't need the handle for this class.
86722>>>    Function _MertechSQLManagerHandle Returns Handle
86724>>>        Handle hoSQLHandler
86724>>>        String sDriverID sServer sDatabase
86724>>>        
86724>>>        Move 0 to hoSQLHandler
86725>>>        Get psDriverID to sDriverID       
86726>>>        Get psServer   to sServer
86727>>>        Get psDatabase to sDatabase
86728>>>        // This command is used to set the server to be used when opening tables   
86728>>>        SET_CURRENT_SQL_SERVER to sServer  
86747>>>>
86747>>>        // This command is used to specify which server to use for embedded SQL statements,
86747>>>        // but it has been constructed rather studidly as only constants and not variables
86747>>>        // are allowed...
86747>>>        If (sDriverID = MDSPgSQL) Begin
86749>>>            SET_CURRENT_SQL_SERVER_CONNECTION of MDSPgSQL to sServer
86765>>>        End
86765>>>>
86765>>>        If (sDriverID = MDSMySQL) Begin
86767>>>            SET_CURRENT_SQL_SERVER_CONNECTION of MDSMySQL to sServer
86783>>>        End
86783>>>>
86783>>>        If (sDriverID = ORAFLEX) Begin
86785>>>            SET_CURRENT_SQL_SERVER_CONNECTION of ORAFLEX to sServer
86801>>>        End
86801>>>>
86801>>>        If (sDriverID = SQLFLEX) Begin
86803>>>            SET_CURRENT_SQL_SERVER_CONNECTION of SQLFLEX to sServer
86819>>>        End
86819>>>>
86819>>>        
86819>>>        // This command is used to specify which database is used for embedded SQL statements.
86819>>>        SQL_USE_DATABASE sDatabase
86833>>>>
86833>>>        SET_DATABASE_NAME to sDatabase
86847>>>>
86847>>>        
86847>>>        // Can't have this here because the property is defined for the cDbUpdateFunctionLibrary class,
86847>>>        // which object may or may not have been created at this point. So don't use the return
86847>>>        // value for this function!
86847>>>        //Get phoSQLManagerMT to hoSQLHandler  
86847>>>        
86847>>>        Function_Return hoSQLHandler
86848>>>    End_Function
86849>>>    
86849>>>    Function _SqlCheckCurrentDriver String sDriverID Returns Boolean
86851>>>        Boolean bOK bMertechDriver
86851>>>        
86851>>>        Get IsDAWSQLDriver sDriverID to bOK
86852>>>
86852>>>        If (bOK = False) Begin
86854>>>            Get IsMertechDriver sDriverID to bOK
86855>>>        End                                     
86855>>>>
86855>>>
86855>>>        If (bOK = False) Begin        
86857>>>            Get IsMertechDriver sDriverID to bMertechDriver
86858>>>            If (bMertechDriver = True) Begin
86860>>>                Error DFERR_PROGRAM "Driver needs to be one of MSSQLDRV_ID, DB2_DRV_ID, ODBC_DRV_ID, SQLFLEX, ORAFLEX, MDSPgSQL or MDSMYSQL"
86861>>>>
86861>>>            End
86861>>>>
86861>>>            Else Begin
86862>>>                Error DFERR_PROGRAM "Driver needs to be one of MSSQLDRV_ID, DB2_DRV_ID or ODBC_DRV_ID"
86863>>>>
86863>>>            End
86863>>>>
86863>>>            Function_Return False
86864>>>        End
86864>>>>
86864>>>        
86864>>>        Function_Return True
86865>>>    End_Function
86866>>>            
86866>>>    Function IsDAWSQLDriver String sDriverID Returns Boolean
86868>>>        Boolean bOK
86868>>>        Move (sDriverID = MSSQLDRV_ID or sDriverID = DB2_DRV_ID or sDriverID = ODBC_DRV_ID) to bOK
86869>>>        Function_Return bOK
86870>>>    End_Function
86871>>>
86871>>>    Function IsMertechDriver String sDriverID Returns Boolean
86873>>>        Boolean bOK   
86873>>>        Move False to bOK
86874>>>            Move (sDriverID = SQLFLEX or sDriverID = ORAFLEX or sDriverID = MDSPgSQL or sDriverID = MDSMYSQL) to bOK
86875>>>        Function_Return bOK
86876>>>    End_Function
86877>>>
86877>>>    Function ConstructConnectionString String sDriverID String sServer String sDatabase Boolean bTrusted String sUserID String sPassword Returns String
86879>>>        Handle hoIniFile
86879>>>        String sConnect 
86879>>>        
86879>>>        Get phoSQLConnectionIniFile to hoIniFile
86880>>>        Get ConstructConnectionString of hoIniFile sDriverID sServer sDatabase bTrusted sUserID sPassword to sConnect
86881>>>        
86881>>>        Function_Return sConnect
86882>>>    End_Function
86883>>>
86883>>>    // Sample sConnString: "SERVER=(local)\SQLEXPRESS;UID=dbuser;PWD=secret;DATABASE=OrderEntry;, 0"
86883>>>    // Pass a complete driver connection string
86883>>>    // Returns the following as a struct:
86883>>>    //   sServer, sDatabase, sUser, sPassword & True if Trusted_Connection is used.
86883>>>    // Finally also returns a boolean TRUE if trusted_connection=yes, else false is returned. 
86883>>>    //
86883>>>    Function DeComposeConnectionString String sDriverID String sConnectionString Returns tSQLConnection
86885>>>        tSQLConnection SQLConnection
86885>>>        tSQLConnection SQLConnection
86885>>>        String sValue sConnectionID sServer sDatabase sUserID sPassword
86885>>>        Boolean bTrusted bSilent bOK
86885>>>        Integer iPos
86885>>>        
86885>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
86886>>>        If (bOK = False) Begin
86888>>>            Function_Return SQLConnection
86889>>>        End
86889>>>>
86889>>>        
86889>>>        Move False to bTrusted  
86890>>>        Move False to bSilent         
86891>>>
86891>>>        Case Begin
86891>>>            Case (sDriverID = MSSQLDRV_ID) 
86893>>>                Get ParseKeyWord sConnectionString (CS_SQLIniServerKeyword + "=")   to sServer
86894>>>                Get ParseKeyWord sConnectionString (CS_SQLIniDatabaseKeyword + "=") to sDatabase
86895>>>                Get ParseKeyWord sConnectionString (CS_SQLIniTrustedKeyword + "=")  to sValue
86896>>>                Move (If(Uppercase(sValue) = "YES", True, False))                   to bTrusted
86897>>>                If (bTrusted = False) Begin
86899>>>                    Get ParseKeyWord sConnectionString (CS_SQLIniUIDKeyword + "=")  to sUserID
86900>>>                    Get ParseKeyWord sConnectionString (CS_SQLIniPWDKeyword + "=")  to sPassword
86901>>>                End
86901>>>>
86901>>>                Case Break
86902>>>                                     
86902>>>            Case (sDriverID = ODBC_DRV_ID)
86905>>>                Get ParseKeyWord sConnectionString (CS_SQLIniDSNKeyword + "=")      to sServer
86906>>>                Get ParseKeyWord sConnectionString (CS_SQLIniTrustedKeyword + "=")  to sValue
86907>>>                Move (If(Uppercase(sValue) = "YES", True, False))                   to bTrusted
86908>>>                If (bTrusted = False) Begin
86910>>>                    Get ParseKeyWord sConnectionString (CS_SQLIniUIDKeyword + "=")  to sUserID
86911>>>                    Get ParseKeyWord sConnectionString (CS_SQLIniPWDKeyword + "=")  to sPassword
86912>>>                End
86912>>>>
86912>>>                Case Break
86913>>>                 
86913>>>            Case (sDriverID = DB2_DRV_ID)
86916>>>                Get ParseKeyWord sConnectionString (CS_SQLIniDSNKeyword + "=")      to sServer
86917>>>                Get ParseKeyWord sConnectionString (CS_SQLIniUIDKeyword + "=")      to sUserID
86918>>>                Get ParseKeyWord sConnectionString (CS_SQLIniPWDKeyword + "=")      to sPassword
86919>>>                Case Break
86920>>>                 
86920>>>            Case (sDriverID = SQLFLEX) 
86923>>>                Get ParseKeyWord sConnectionString (CS_SQLIniServerKeyword + "=")   to sServer
86924>>>                Get ParseKeyWord sConnectionString (CS_SQLIniTrustedKeyword + "=")  to sValue
86925>>>                Move (If(Uppercase(sValue) = "YES", True, False))                   to bTrusted
86926>>>                If (bTrusted = False) Begin
86928>>>                    Get ParseKeyWord sConnectionString (CS_SQLIniUIDKeyword + "=")  to sUserID
86929>>>                    Get ParseKeyWord sConnectionString (CS_SQLIniPWDKeyword + "=")  to sPassword
86930>>>                End
86930>>>>
86930>>>                Case Break
86931>>>                                     
86931>>>            Case (sDriverID = ORAFLEX)
86934>>>                Get ParseKeyWord sConnectionString (CS_SQLIniDSNKeyword + "=")      to sServer
86935>>>                Get ParseKeyWord sConnectionString (CS_SQLIniDatabaseKeyword + "=") to sDatabase
86936>>>                If (sDatabase <> "" and (not(sServer contains "/"))) Begin
86938>>>                    Move (sServer + "/" + sDatabase)                                to sServer
86939>>>                End
86939>>>>
86939>>>                Get ParseKeyWord sConnectionString (CS_SQLIniUIDKeyword + "=")      to sUserID
86940>>>                Get ParseKeyWord sConnectionString (CS_SQLIniPWDKeyword + "=")      to sPassword
86941>>>                Case Break
86942>>>            
86942>>>            Case (sDriverID = MDSPgSQL)
86945>>>                Get ParseKeyWord sConnectionString (CS_SQLIniDSNKeyword + "=")      to sServer
86946>>>                Get ParseKeyWord sConnectionString (CS_SQLIniDatabaseKeyword + "=") to sDatabase
86947>>>                Get ParseKeyWord sConnectionString (CS_SQLIniUIDKeyword + "=")      to sUserID
86948>>>                Get ParseKeyWord sConnectionString (CS_SQLIniPWDKeyword + "=")      to sPassword
86949>>>                Case Break
86950>>>            
86950>>>            Case (sDriverID = MDSMySQL)
86953>>>                Get ParseKeyWord sConnectionString (CS_SQLIniDSNKeyword + "=")      to sServer
86954>>>                Get ParseKeyWord sConnectionString (CS_SQLIniDatabaseKeyword + "=") to sDatabase
86955>>>                Get ParseKeyWord sConnectionString (CS_SQLIniUIDKeyword + "=")      to sUserID
86956>>>                Get ParseKeyWord sConnectionString (CS_SQLIniPWDKeyword + "=")      to sPassword
86957>>>                Case Break
86958>>>            
86958>>>            Case (sDriverID = DATAFLEX_ID)    // Dummy stub.
86961>>>                Break
86962>>>        Case End
86962>>>        
86962>>>        Get ParseKeyWord sConnectionString (Uppercase(CS_SQLConnectionIDText))  to sConnectionID
86963>>>        
86963>>>        // bSilent?
86963>>>        Move (Pos(",0", sConnectionString))                                     to iPos
86964>>>        If (iPos = 0) Begin
86966>>>            Move (Pos(",1", sConnectionString))                                 to iPos
86967>>>        End        
86967>>>>
86967>>>        If (iPos = 0) Move "0"                                                  to sValue
86970>>>        Else Move (Mid(sConnectionString, 1, (iPos +1)))                        to sValue
86972>>>        Move (If(sValue = 1, True, False))                                      to bSilent
86973>>>
86973>>>        Move (Trim(sDriverID))                                                  to SQLConnection.sDriverID
86974>>>        Move (Trim(sConnectionID))                                              to SQLConnection.sConnectionID
86975>>>        Move (Trim(sConnectionString))                                          to SQLConnection.sConnectionString    
86976>>>        Move (Trim(sServer))                                                    to SQLConnection.sServer
86977>>>        Move (Trim(sDatabase))                                                  to SQLConnection.sDatabase
86978>>>        Move bTrusted                                                           to SQLConnection.bTrusted
86979>>>        Move (Trim(sUserID))                                                    to SQLConnection.sUserID
86980>>>        Move (Trim(sPassword))                                                  to SQLConnection.sPassword
86981>>>        Move bSilent                                                            to SQLConnection.bSilentLogin
86982>>>        
86982>>>        Function_Return SQLConnection
