89565>>>    // Backs up an SQL database to a folder of choice. If no path is passed the SQL default backup folder
89565>>>    // will be used.
89565>>>    Function SqlUtilBackupDatabaseToDisk String sDatabase String sBackupName String sPath Boolean bShowProg Returns Boolean
89567>>>        Boolean bOK bExists bShowProgress      
89567>>>        String sStatement sDriverID 
89567>>>        tSQLScriptArray SQLScriptArray SQLScriptArrayPercentReady
89567>>>        tSQLScriptArray SQLScriptArray SQLScriptArrayPercentReady
89567>>>        Integer iDbType
89567>>>        
89567>>>        If (sDatabase = "") Begin
89569>>>            Error DFERR_PROGRAM "The database name was not passed as a parameter to the 'SqlUtilBackupDatabaseToDisk' function"
89570>>>>
89570>>>            Function_Return False
89571>>>        End
89571>>>>
89571>>>        If (sBackupName = "") Begin
89573>>>            Error DFERR_PROGRAM "The database backup name was not passed as a parameter to the 'SqlUtilBackupDatabaseToDisk' function"
89574>>>>
89574>>>            Function_Return False
89575>>>        End
89575>>>>
89575>>>            
89575>>>        // Create backup-folder if it doesn't exist
89575>>>        Get vFolderExists sPath to bExists
89576>>>        If (bExists = False) Begin
89578>>>            Get vCreateDirectory sPath to bOK
89579>>>            If (bOK = False) Begin
89581>>>                Error DFERR_PROGRAM ("Could not create database backup folder:" * sPath)
89582>>>>
89582>>>                Function_Return False
89583>>>            End
89583>>>>
89583>>>        End                     
89583>>>>
89583>>>        // Make sure the path ends with a back-slash
89583>>>        If (sPath <> "") Begin
89585>>>            Get vFolderFormat sPath to sPath
89586>>>        End
89586>>>>
89586>>>        
89586>>>        Get psDriverID to sDriverID  
89587>>>        Get piDbType   to iDbType        
89588>>>        If (num_arguments > 3) Begin
89590>>>            Move bShowProg to bShowProgress
89591>>>        End
89591>>>>
89591>>>        
89591>>>        Case Begin
89591>>>            Case (iDbType = EN_DbTypeMSSQL)
89593>>>                SQLIncludeScriptFile ..\Scripts\BackupMSSQLDatabase.sql as BackupMSSQLDatabase.sql
89593>>>                SQLIncludeScriptFile ..\Scripts\GetPercentageBackupCompletionMSSQL.sql as GetPercentageBackupCompletionMSSQL.sql
89593>>>                Get SqlUtilReadResource of ghoDbUpdateFunctionLibrary "BackupMSSQLDatabase.sql" sDriverID False to SQLScriptArray
89594>>>                Get SqlUtilReadResource of ghoDbUpdateFunctionLibrary "GetPercentageBackupCompletionMSSQL.sql" sDriverID False to SQLScriptArrayPercentReady
89595>>>                
89595>>>                Move SQLScriptArray.sSQLScriptArray[0] to sStatement
89596>>>                Move (Replaces("DATABASE_NAME_XXX", sStatement, sDatabase))   to sStatement
89597>>>                Move (Replaces("BACKUP_PATH_XXX",   sStatement, sPath))       to sStatement
89598>>>                Move (Replaces("BACKUP_NAME_XXX",   sStatement, sBackupName)) to sStatement
89599>>>                Move sStatement to SQLScriptArray.sSQLScriptArray[0]    
89600>>>                Get SqlUtilExecuteEmbeddedScript of ghoDbUpdateFunctionLibrary SQLScriptArray sDriverID False "" bShowProgress to bOK
89601>>>                Case Break
89602>>>            Case Else
89602>>>                Send Info_Box ("The SqlUtilBackupDatabaseToDisk function is currently not implemented for the driver:" * sDriverID + ". It would be great if you could spend a couple of minutes and add a little ESQL code snippet to make it work for that driver! Thanks for helping out.")
89603>>>        Case End
89603>>>        
89603>>>        Function_Return bOK    
89604>>>    End_Function
89605>>>
89605>>>    // Reads a resource that has been embedded by the compiler and writes it to disk.
89605>>>    // Pass the memory resource file reference and the filename to be created,
89605>>>    // including full path.
89605>>>    Procedure SqlUtilCreateFileFromMemory String sMemFileName String sFileName
89607>>>        String sText
89607>>>        Integer iCh iSize iArgSize  
89607>>>        
89607>>>        Move ("Resource:" + sMemFileName) to sMemFileName
89608>>>        Get Seq_Open_Input_Channel sMemFileName to iCh
89609>>>            Get_Channel_Size iCh to iSize
89610>>>            Get_Argument_Size to iArgSize
89611>>>            If (iSize > iArgSize) Begin
89613>>>                Set_Argument_Size iSize
89614>>>>
89614>>>            End
89614>>>>
89614>>>            Read_Block channel iCh sText iSize
89616>>>        Send Seq_Close_Channel iCh
89617>>>    
89617>>>        Get Seq_Open_Output_Channel sFileName to iCh
89618>>>            Write channel iCh sText
89620>>>        Send Seq_Close_Channel iCh
89621>>>    
89621>>>        If (iSize <> iArgSize) Begin
89623>>>            Set_Argument_Size iArgSize
89624>>>>
89624>>>        End
89624>>>>
89624>>>    
89624>>>        // Wait for file to be written to disk.
89624>>>        Sleep 2
89625>>>    End_Procedure 
89626>>>    
89626>>>    // L„s f”rst .int fil och spara alla FIELD_INDEX + FIELD_NUMBER + FIELD_RELATED_FILE + FIELD_RELATED_FIELD i en struct array,
89626>>>    // INDEX_NUMBER + INDEX_NAME (string)
89626>>>    // samt spara undan .int "header rader" s† de kan skrivas ut senare.
89626>>>    // Check if index exists:    
89626>>>    //IF EXISTS (
89626>>>    //   SELECT 'X'
89626>>>    //   from sysindexes
89626>>>    //   WHERE id = (SELECT OBJECT_ID('accounts'))
89626>>>    //     and name = 'idx_acct_no'
89626>>>    //)          
89626>>>    //
89626>>>    // Helper function to create a SQL statement like;
89626>>>    // "SELECT * FROM SYS.INDEXES WHERE NAME = MyIndexName AND OBJECT_ID = OBJECT_ID([MySchmaName].[MyTableName])"
89626>>>    // Used for checking if an index exists.
89626>>>    Function _SqlQueryIfIndexExists String sSchemaName String sTableName String sIndexName Returns String
89628>>>        String sRetval sSelect sFrom sSysIndexes sWhere sObjectID sAnd sName
89628>>>        
89628>>>        Get _SqlFindKeyWord CI_SQLSelect to sSelect
89629>>>        Get _SqlFindKeyWord CI_SQLFrom to sFrom
89630>>>        Get _SqlFindKeyWord CI_SQLSysIndexes to sSysIndexes
89631>>>        Get _SqlFindKeyWord CI_SQLWhere to sWhere
89632>>>        Get _SqlFindKeyWord CI_SQLObjectID to sObjectID
89633>>>        Get _SqlFindKeyWord CI_SQLAND to sAnd
89634>>>        Get _SqlFindKeyWord CI_SQLName to sName
89635>>>        
89635>>>        Move (sSelect * String("*") * sFrom * sSysIndexes * sWhere * sName * "=" * sIndexName * sAnd * sObjectID * "=([" + sSchemaName + "].[" + sTableName + "])") to sRetval
89636>>>        
89636>>>        Function_Return sRetval
89637>>>    End_Function  
