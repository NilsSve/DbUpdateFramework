81359>>>>>>>>>>>>>
81359>>>>>>>>>>>>>    Integer MertechInc_FileNumber      //Replaces _SAVEFILENUMBER# and FILENUMBER
81359>>>>>>>>>>>>>    Integer MertechInc_iArg            //Replaces _LLONG#
81359>>>>>>>>>>>>>    Integer MertechInc_iCallBack       //Replaces _CALLBACK#
81359>>>>>>>>>>>>>    Integer MertechInc_iCount          //General loop limit integer
81359>>>>>>>>>>>>>    Integer MertechInc_iDecSep         //Holds the decimal seperator
81359>>>>>>>>>>>>>    Integer MertechInc_iFunction       //Replaces _FID#    ??? check is this is need when tidy is complete
81359>>>>>>>>>>>>>    Integer MertechInc_iLoop           //General loop integer
81359>>>>>>>>>>>>>    Integer Mertech_iMySQLParam        //Replaces _ALL_PAR_POS#
81359>>>>>>>>>>>>>    Integer MertechInc_iParamCount     //Replaces _NPAR#
81359>>>>>>>>>>>>>    Integer MertechInc_iRet            //Replaces _RET#
81359>>>>>>>>>>>>>    Integer MertechInc_iSaveCount      //Replaces _NPOS#
81359>>>>>>>>>>>>>    Integer MertechInc_iWork           //General work integer
81359>>>>>>>>>>>>>    Integer MertechInc_iWork2
81359>>>>>>>>>>>>>
81359>>>>>>>>>>>>>    String MertechInc_Blank            //Replaces _BLANK#
81359>>>>>>>>>>>>>    String MertechInc_DriverName       //Replaces _DRIVERNAME#
81359>>>>>>>>>>>>>    String MertechInc_sArg1 255        //Replaces _ARG1#
81359>>>>>>>>>>>>>    String MertechInc_sArg2 255        //Replaces _ARG2#
81359>>>>>>>>>>>>>    String MertechInc_sWork 255        //General work string
81359>>>>>>>>>>>>>
81359>>>>>>>>>>>>>    String MertechInc_CurrentDriver    //Keep the current driver name
81359>>>>>>>>>>>>>    //Global string are created pre-filled with spaces. We need an empty string
81359>>>>>>>>>>>>>    Move "" to MertechInc_Blank
81360>>>>>>>>>>>>>    Move "" to MertechInc_CurrentDriver
81361>>>>>>>>>>>>>
81361>>>>>>>>>>>>>
