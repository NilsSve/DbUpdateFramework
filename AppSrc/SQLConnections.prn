89781>>>    Function _SqlTableArrayDAW Returns String[]
89783>>>        String[] sReturnArray   
89784>>>        String sTable sTableType sSchema sDefSchema sComment sTableKeyWord sSysKeyWord
89784>>>        Handle hoSQLHandler
89784>>>        Integer iCount iSize iItem
89784>>>        Boolean bOK   
89784>>>        tSQLConnection SQLConnection
89784>>>        tSQLConnection SQLConnection
89784>>>        
89784>>>        Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
89785>>>        If (SQLConnection.sConnectionString = "") Begin
89787>>>            Function_Return sReturnArray
89788>>>        End 
89788>>>>
89788>>>        
89788>>>        Move SQLConnection.sSchema      to sDefSchema
89789>>>        Move (Uppercase(sDefSchema))    to sDefSchema
89790>>>        Get _SqlFindKeyWord CI_SQLTable to sTableKeyWord
89791>>>        Get _SqlFindKeyWord CI_SQLSys   to sSysKeyWord
89792>>>
89792>>>        Get phoCLIHandler to hoSQLHandler             
89793>>>        Set psDriverID    of hoSQLHandler to SQLConnection.sDriverID
89794>>>        Send Delete_Data  of hoSQLHandler
89795>>>
89795>>>        Send Ignore_Error of Error_Object_Id CLIERR_LOGIN_UNSUCCESSFUL
89796>>>        Get EnumerateTables of hoSQLHandler SQLConnection.sConnectionString to iSize 
89797>>>        Move False to Err
89798>>>        Decrement iSize
89799>>>
89799>>>        For iCount from 0 to iSize
89805>>>>
89805>>>            Get TableName    of hoSQLHandler iCount to sTable
89806>>>            Get TableType    of hoSQLHandler iCount to sTableType 
89807>>>            Get SchemaName   of hoSQLHandler iCount to sSchema
89808>>>            Get TableComment of hoSQLHandler iCount to sComment
89809>>>            Move (Trim(sTable)) to sTable
89810>>>            If (SQLConnection.sDriverID = DB2_DRV_ID) Begin
89812>>>                Move (sTable <> "" and Uppercase(sTableType) = sTableKeyWord and Uppercase(sSchema) = sDefSchema) to bOK
89813>>>            End
89813>>>>
89813>>>            Else Begin
89814>>>                Move (sTable <> "" and Uppercase(sTableType) = sTableKeyWord and Uppercase(sSchema) <> sSysKeyWord and Uppercase(sSchema) <> "SYSTOOLS") to bOK
89815>>>            End
89815>>>>
89815>>>            If (bOK = True) Begin
89817>>>                Move sTable to sReturnArray[iItem]
89818>>>                Increment iItem
89819>>>            End
89819>>>>
89819>>>        Loop
89820>>>>
89820>>>
89820>>>        Send Trap_Error of Error_Object_Id CLIERR_LOGIN_UNSUCCESSFUL
89821>>>
89821>>>        Function_Return sReturnArray
89822>>>    End_Function
89823>>>
89823>>>    Function _SqlProcedureArrayDAW String sStmt String sArgument Returns String[]
89825>>>        String[] sReturnArray  
89826>>>        String sValue                         
89826>>>        Handle hoSQLHandler hoSQLConnect hStmt    
89826>>>        Integer iRetval iCols iFetchResult
89826>>>        tSQLConnection SQLConnection
89826>>>        tSQLConnection SQLConnection
89826>>>        
89826>>>        Get phoSQLManager to hoSQLHandler
89827>>>        Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
89828>>>        Get SqlConnect of hoSQLHandler SQLConnection.sDriverID SQLConnection.sConnectionString to hoSQLConnect
89829>>>
89829>>>        If (hoSQLConnect <> 0) Begin
89831>>>            Get SqlOpen of hoSQLConnect to hStmt
89832>>>            If (hStmt <> 0) Begin
89834>>>                Send SqlSetProcedurename of hStmt sStmt 
89835>>>                If (sArgument <> "") Begin
89837>>>                    Send SqlSetArgument  of hStmt 1 sArgument
89838>>>                End
89838>>>>
89838>>>                            
89838>>>                Send SqlCall             of hStmt      
89839>>>                Get SqlReturnValue       of hStmt to iRetval
89840>>>                If (iRetval = 0) Begin
89842>>>                    Repeat    
89842>>>>
89842>>>                        Get SqlStmtAttribute of hStmt SqlSTMTATTRIB_COLUMNCOUNT to iCols
89843>>>                        If (iCols > 0) Begin 
89845>>>                            Repeat
89845>>>>
89845>>>                                Get SqlFetch of hStmt to iFetchResult
89846>>>                                If (iFetchResult <> 0) Begin
89848>>>                                    Get SqlColumnValue of hStmt 1 to sValue    
89849>>>                                    Move (Trim(sValue)) to sReturnArray[SizeOfArray(sReturnArray)]
89850>>>                                End
89850>>>>
89850>>>                            Until (iFetchResult = 0)
89852>>>                        End
89852>>>>
89852>>>                        Get SqlNextResultSet of hStmt to iRetval
89853>>>                    Until (iRetval = 0) 
89855>>>                    Send SqlClose of hStmt
89856>>>                End
89856>>>>
89856>>>            End                       
89856>>>>
89856>>>            Send SqlDisconnect of hoSQLConnect
89857>>>        End                                                                         
89857>>>>
89857>>>        Function_Return sReturnArray
89858>>>    End_Function
89859>>>
89859>>>    Function SqlProcedureArrayMertech String sStmt String sArgument Returns String[]
89861>>>        String[] sReturnArray
89862>>>        String sValue sUserID sPassword 
89862>>>        Handle hoSQLHandler hoSQLConnect hStmt 
89862>>>        Integer iFetchResult iRetval
89862>>>        tSQLConnection SQLConnection
89862>>>        tSQLConnection SQLConnection
89862>>>        
89862>>>        Get _MertechSQLManagerHandle to hoSQLHandler
89863>>>        If (hoSQLHandler <> 0) Begin 
89865>>>            Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
89866>>>            Get SQLConnect of hoSQLHandler SQLConnection.sDriverID SQLConnection.sServer SQLConnection.sUserID SQLConnection.sPassword to hoSQLConnect
89867>>>            If (hoSQLConnect <> 0) Begin   
89869>>>                Get SQLOpen of hoSQLConnect to hStmt
89870>>>                If (hStmt <> 0) Begin
89872>>>                    Send SQLSetProcedureName of hStmt sStmt
89873>>>                    If (sArgument <> "") Begin
89875>>>                        Send SqlSetArgument  of hStmt 1 sArgument
89876>>>                    End
89876>>>>
89876>>>                    Send SQLCall of hStmt
89877>>>
89877>>>                    Get SqlReturnValue       of hStmt to iRetval
89878>>>                    If (iRetval = 0) Begin
89880>>>                        Repeat
89880>>>>
89880>>>                            Get SQLFetch of hStmt to iFetchResult
89881>>>                            If (iFetchResult <> 0) Begin
89883>>>                                Get SQLColumnValue of hStmt 1 to sValue
89884>>>                                Move (Trim(sValue)) to sReturnArray[SizeOfArray(sReturnArray)
89885>>>                            End
89885>>>>
89885>>>                        Until (iFetchResult = 0)
89887>>>                        Send SQLClose of hStmt
89888>>>                    End
89888>>>>
89888>>>                End
89888>>>>
89888>>>                Send SQLDisconnect of hoSQLConnect    
89889>>>            End
89889>>>>
89889>>>        End
89889>>>>
89889>>>
89889>>>        Function_Return sReturnArray
89890>>>    End_Function
