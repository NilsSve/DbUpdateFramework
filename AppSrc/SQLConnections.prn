98764>>>    Function Verify_Exit_Application Returns Integer
98767>>>        Integer iRetval
98767>>>        Boolean bChanged
98767>>>
98767>>>        Get Should_Save of oSQLConnections_grd to bChanged
98768>>>        If (bChanged = False) Begin
98770>>>            Function_Return False
98771>>>        End
98771>>>>
98771>>>        Else Begin
98772>>>            Get YesNoCancel_Box "Changes exists. Save changes first?" to iRetval
98773>>>            If (iRetval = MBR_Cancel) Begin
98775>>>                Function_Return True
98776>>>            End                     
98776>>>>
98776>>>            If (iRetval = MBR_Yes) Begin
98778>>>                Send KeyAction of oSave_btn
98779>>>                Send Exit_Application
98780>>>            End                      
98780>>>>
98780>>>            If (iRetval = MBR_No) Begin
98782>>>                Function_Return False    
98783>>>            End
98783>>>>
98783>>>        End
98783>>>>
98783>>>        Function_Return True
98784>>>    End_Function
