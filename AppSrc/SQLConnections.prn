85329>>>>>>>Class cDbUpdateDatabaseDriver is a cObject
85330>>>>>>>    Procedure Construct_Object
85332>>>>>>>        Forward Send Construct_Object
85334>>>>>>>        Property String psDriverID DATAFLEX_ID
85335>>>>>>>        Property Handle phoDriverSpecificObject
85336>>>>>>>    End_Procedure
85337>>>>>>>    
85337>>>>>>>    Function CreateDriver Returns Handle
85339>>>>>>>        String sDriverID
85339>>>>>>>        Handle hoDriver hcDriverClass
85339>>>>>>>        
85339>>>>>>>        Get psDriverID to sDriverID
85340>>>>>>>        Case Begin
85340>>>>>>>            Case (sDriverID = MSSQLDRV_ID)
85342>>>>>>>                Move (RefClass(cDbUpdateMSSQLDriver)) to hcDriverClass
85343>>>>>>>                Case Break
85344>>>>>>>            Case (sDriverID = ODBC_DRV_ID)
85347>>>>>>>                Move (RefClass(cDbUpdateODBCDriver)) to hcDriverClass
85348>>>>>>>                Case Break
85349>>>>>>>            Case (sDriverID = DB2_DRV_ID)
85352>>>>>>>                Move (RefClass(cDbUpdateDB2Driver)) to hcDriverClass
85353>>>>>>>                Case Break
85354>>>>>>>            Case (sDriverID = SQLFLEX)
85357>>>>>>>                Move (RefClass(cDbUpdateSQLFLEXDriver)) to hcDriverClass
85358>>>>>>>                Case Break
85359>>>>>>>            Case (sDriverID = ORAFLEX)
85362>>>>>>>                Move (RefClass(cDbUpdateORAFLEXDriver)) to hcDriverClass
85363>>>>>>>                Case Break
85364>>>>>>>            Case (sDriverID = MDSPgSQL)
85367>>>>>>>                Move (RefClass(cDbUpdateMDSPgSQLDriver)) to hcDriverClass
85368>>>>>>>                Case Break
85369>>>>>>>            Case (sDriverID = MDSMySQL)
85372>>>>>>>                Move (RefClass(cDbUpdateMDSMySQLDriver)) to hcDriverClass
85373>>>>>>>                Case Break
85374>>>>>>>            Case (sDriverID = DATAFLEX_ID)
85377>>>>>>>                Move (RefClass(cDbUpdateDataFlexDriver)) to hcDriverClass
85378>>>>>>>                Case Break
85379>>>>>>>            Case Else
85379>>>>>>>                Function_Return 0
85380>>>>>>>        Case End
85380>>>>>>>        
85380>>>>>>>        Get Create hcDriverClass to hoDriver
85381>>>>>>>        Set psDriverID of hoDriver to sDriverID
85382>>>>>>>        Set phoDriverSpecificObject to hoDriver
85383>>>>>>>        
85383>>>>>>>        Function_Return hoDriver
85384>>>>>>>    End_Procedure
85385>>>>>>>    
85385>>>>>>>    Procedure DestroyDriver
85387>>>>>>>        If (phoDriverSpecificObject(Self)) Begin
85389>>>>>>>            Send Destroy of (phoDriverSpecificObject(Self))
85390>>>>>>>        End
85390>>>>>>>>
85390>>>>>>>    End_Procedure
85391>>>>>>>    
85391>>>>>>>    Function ConstructConnectionString String sServer String sDatabase Boolean bTrusted String sUserID String sPassword Returns String
85393>>>>>>>        String sConnect
85393>>>>>>>        Handle hoDriver
85393>>>>>>>        
85393>>>>>>>        Get CreateDriver to hoDriver
85394>>>>>>>        Get ConstructConnectionString of hoDriver sServer sDatabase bTrusted sUserID sPassword to sConnect
85395>>>>>>>        Send DestroyDriver
85396>>>>>>>        Function_Return sConnect
85397>>>>>>>    End_Function
85398>>>>>>>    
85398>>>>>>>    Function DbLogin String sConnectionString String sServer String sDatabase Boolean bTrusted String sUserID String sPassword Returns Boolean
85400>>>>>>>        Boolean bLoginSuccessful
85400>>>>>>>        Handle hoDriver
85400>>>>>>>        
85400>>>>>>>        Get CreateDriver to hoDriver
85401>>>>>>>        Get DbLogin of hoDriver sConnectionString sServer sDatabase bTrusted sUserID sPassword to bLoginSuccessful
85402>>>>>>>        Send DestroyDriver
85403>>>>>>>        Function_Return bLoginSuccessful
85404>>>>>>>    End_Function 
85405>>>>>>>    
85405>>>>>>>End_Class
