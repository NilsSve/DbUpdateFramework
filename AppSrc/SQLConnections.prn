89638>>>    // Formats a columns iLenght & iDecimal parameters as SQL expects them in a string. 
89638>>>    // E.g. (4,2), where 4 is the iLength and 2 the iDecimals param.
89638>>>    Function _SqlFormatLengthAndDecimalAsString Integer iLength Integer iDecimals Returns String
89640>>>        String sRetval
89640>>>        If (iLength <> 0) Begin
89642>>>            Move ("(" + String(iLength)) to sRetval
89643>>>            If (iDecimals <> 0) Begin
89645>>>                Move (sRetval + "," + String(iDecimals)) to sRetval
89646>>>            End
89646>>>>
89646>>>            Move (sRetval + ")") to sRetval
89647>>>        End
89647>>>>
89647>>>        Function_Return sRetval
89648>>>    End_Function
