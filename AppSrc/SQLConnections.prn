95188>>>>>    Procedure Show_Date_Format
95190>>>>>        Integer iDateFormat
95190>>>>>        String sDateFormat
95190>>>>>
95190>>>>>        Get_Attribute DF_DATE_FORMAT to iDateFormat
95193>>>>>        Case Begin
95193>>>>>            Case (iDateFormat = DF_DATE_USA)
95195>>>>>                Move C_$USA To sDateFormat
95196>>>>>                Case Break
95197>>>>>            Case (iDateFormat = DF_DATE_EUROPEAN)
95200>>>>>                Move C_$European To sDateFormat
95201>>>>>                Case Break
95202>>>>>            Case (iDateFormat = DF_DATE_MILITARY)
95205>>>>>                Move C_$Military To sDateFormat
95206>>>>>                Case Break
95207>>>>>            Case Else
95207>>>>>                Move C_$UnknownDateType To sDateFormat
95208>>>>>                Case Break
95209>>>>>        Case End
95209>>>>>
95209>>>>>        Send AppendTextLn (SFormat (C_$DateFormat, sDateformat))
95210>>>>>    End_Procedure
95211>>>>>
95211>>>>>    // 2013-08-14 NGS
95211>>>>>    // Unformatted numeric values shown doesn't look good. These looks much better.
95211>>>>>    Procedure Show_Systemresources
95213>>>>>        tWinMemoryStatusEx MemoryStatusInfo
95213>>>>>        tWinMemoryStatusEx MemoryStatusInfo
95213>>>>>        Integer iRetval
95213>>>>>        Number nValue
95213>>>>>        String sValue
95213>>>>>
95213>>>>>        Move (SizeOfType (tWinMemoryStatusEx)) to MemoryStatusInfo.dwLength
95214>>>>>        Move (GlobalMemoryStatusEx (AddressOf (MemoryStatusInfo))) to iRetval
95215>>>>>        If (iRetval = 0) Begin
95217>>>>>            Move (ShowLastError ()) to iRetval
95218>>>>>            Procedure_Return
95219>>>>>        End
95219>>>>>>
95219>>>>>
95219>>>>>        Send AppendTextLn ""
95220>>>>>        Move MemoryStatusInfo.ullTotalPhys to nValue
95221>>>>>
95221>>>>>        // Show memory in Gigabytes:
95221>>>>>        Move (nValue/1024/1024/1024) to nValue
95222>>>>>        Move (Round(nValue)) to nValue
95223>>>>>        Get FormatNumber nValue 2 to sValue
95224>>>>>        Send AppendTextLn (SFormat (C_$AvailableMemory, (sValue * "GB")))
95225>>>>>        Send AppendTextLn (SFormat (C_$MemoryUtilization, String(MemoryStatusInfo.dwMemoryLoad) * "%"))
95226>>>>>
95226>>>>>//        Send AppendTextLn (SFormat (C_$AvailablePhysicalMemory, Real (MemoryStatusInfo.ullAvailPhys) / Real (MemoryStatusInfo.ullTotalPhys) * 100.0))
95226>>>>>        Move (Real(MemoryStatusInfo.ullAvailPhys) / Real(MemoryStatusInfo.ullTotalPhys) * 100.0) to nValue
95227>>>>>        Move (Round(nValue)) to nValue
95228>>>>>        Get FormatNumber nValue 0 to sValue
95229>>>>>        Send AppendTextLn (SFormat (C_$AvailablePhysicalMemory, (sValue * "%")))
95230>>>>>
95230>>>>>//        Send AppendTextLn (SFormat (C_$AvailablePagefileSpace, Real (MemoryStatusInfo.ullAvailPageFile) / Real (MemoryStatusInfo.ullTotalPageFile) * 100.0))
95230>>>>>        Move (Real(MemoryStatusInfo.ullAvailPageFile) / Real(MemoryStatusInfo.ullTotalPageFile) * 100.0) to nValue
95231>>>>>        Move (Round(nValue)) to nValue
95232>>>>>        Get FormatNumber nValue 0 to sValue
95233>>>>>        Send AppendTextLn (SFormat (C_$AvailablePagefileSpace, (sValue * "%")))
95234>>>>>
95234>>>>>//        Send AppendTextLn (SFormat (C_$AvailableVirtualMemory, Real (MemoryStatusInfo.ullAvailVirtual) / Real (MemoryStatusInfo.ullTotalVirtual) * 100.0))
95234>>>>>        Move (Real(MemoryStatusInfo.ullAvailVirtual) / Real(MemoryStatusInfo.ullTotalVirtual) * 100.0) to nValue
95235>>>>>        Move (Round(nValue)) to nValue
95236>>>>>        Get FormatNumber nValue 0 to sValue
95237>>>>>        Send AppendTextLn (SFormat (C_$AvailableVirtualMemory, (sValue * "%")))
95238>>>>>
95238>>>>>        // Add an empty row after the memory information:
95238>>>>>        Send AppendTextLn ""
95239>>>>>    End_Procedure
95240>>>>>
95240>>>>>    Procedure Show_Registration
95242>>>>>        String sRegName
