88875>>>    // Returns an array with all ".int" files for the passed sDataPath, _except_ for the driver .int files;
88875>>>    // "MSSQLDRV.int", "DB2_DRV.int" & "ODBC_DRV.int".
88875>>>    Function SqlUtilEnumerateIntFiles String sDataPath Returns String[]
88877>>>        String[] sFilesData
88878>>>        Boolean bExists
88878>>>        Integer iCh
88878>>>        String sFileName sExt
88878>>>        
88878>>>        Get vFolderExists sDataPath to bExists
88879>>>        If (bExists = True) Begin
88881>>>            Move (ToANSI(Trim(sDataPath))) to sDataPath
88882>>>            Move ("dir:" + sDataPath)      to sDataPath
88883>>>            Get Seq_New_Channel to iCh  // get free channel for input
88884>>>            Direct_Input channel iCh sDataPath
88886>>>                Repeat
88886>>>>
88886>>>                    Readln channel iCh sFileName
88888>>>                    Get ParseFileExtension sFileName to sExt
88889>>>                    If (Uppercase(sExt) = "INT") Begin
88891>>>                        If (not(Uppercase(sFileName) contains "MSSQLDRV" and Uppercase(sFileName) contains "DB2_DRV" and Uppercase(sFileName) contains "ODBC_DRV")) Begin
88893>>>                            Move sFileName to sFilesData[SizeOfArray(sFilesData)]
88894>>>                        End
88894>>>>
88894>>>                    End
88894>>>>
88894>>>                Until (SeqEof = True)
88896>>>            Close_Input channel iCh
88898>>>        End
88898>>>>
88898>>>        Function_Return sFilesData
88899>>>    End_Function                                  
88900>>>    
88900>>>    // Returns a handle to the SQL server associated with the passed driver ID.
88900>>>    // Pass e.g. the psServer property to determine the current connection server.
88900>>>    // Returns a handle to the database connection, or a zero (0) if it fails.
88900>>>    // This handle can be used to obtain attributes about the server, such as default
88900>>>    // column types.
88900>>>    Function SqlUtilDatabaseHandle String sDriverID String sServer Returns Handle
88902>>>        Handle hDatabase
88902>>>        Integer iDriver iServers iCount
88902>>>        String sValue
88902>>>        
88902>>>        If (sServer = "") Begin
88904>>>            Function_Return 0
88905>>>        End 
88905>>>>
88905>>>        
88905>>>        Get DriverIndex sDriverID to iDriver
88906>>>        If (iDriver = 0) Begin
88908>>>            Function_Return 0
88909>>>        End                  
88909>>>>
88909>>>        
88909>>>        Get_Attribute DF_DRIVER_NUMBER_SERVERS of iDriver to iServers
88912>>>        For iCount from 1 to iServers
88918>>>>
88918>>>            Get_Attribute DF_DRIVER_SERVER_NAME of iDriver iCount to sValue
88921>>>            If (Uppercase(sValue) contains Uppercase(sServer)) Begin
88923>>>                Get_Attribute DF_DATABASE_ID of iDriver iCount to hDatabase
88926>>>            End
88926>>>>
88926>>>        Loop
88927>>>>
88927>>>                
88927>>>        Function_Return hDatabase
88928>>>    End_Function
88929>>>
88929>>>    Procedure SqlUtilExecuteQuery String sStmt String sDriverID Boolean bShowProgr 
88931>>>        String sConnectionString sMessage
88931>>>        Handle hoSqlHandler hoSQLConnect hoStmt hoError
88931>>>        Integer i iMsgs iFetchResult iResultCount iRowType iRows iErr iMessage
88931>>>        String[] sMsg aSQLQueryMessages aSQLFetchResults
88934>>>        DateTime dtQueryExecStart dtQueryExecEnd dtFetchStart dtFetchEnd
88934>>>        TimeSpan tsQuery tsFetch
88934>>>        tSqlErrorArray aSqlErrorArray
88934>>>        tSqlErrorArray aSqlErrorArray
88934>>>        Boolean bOK bMertechDriver bShowProgress
88934>>>        tSQLConnection SQLConnection
88934>>>        tSQLConnection SQLConnection
88934>>>        
88934>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
88935>>>        If (bOK = False) Begin
88937>>>            Procedure_Return
88938>>>        End
88938>>>>
88938>>>        
88938>>>        If (num_arguments > 2) Begin
88940>>>            Move bShowProgr to bShowProgress
88941>>>        End
88941>>>>
88941>>>
88941>>>        Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
88942>>>        
88942>>>        Get IsMertechDriver sDriverID to bMertechDriver
88943>>>        If (bMertechDriver = True) Begin
88945>>>            Get _MertechSQLConnect sDriverID SQLConnection.sServer SQLConnection.sUserID SQLConnection.sPassword to hoSQLConnect
88946>>>        End
88946>>>>
88946>>>        If (bMertechDriver = False) Begin
88948>>>            Get phoSQLManager to hoSqlHandler
88949>>>            Send SqlSetConnect of hoSqlHandler sDriverID SQLConnection.sConnectionString
88950>>>            Get SqlConnect     of hoSqlHandler "" "" to hoSQLConnect
88951>>>        End
88951>>>>
88951>>>
88951>>>        If (hoSQLConnect <> 0) Begin
88953>>>            Get SqlOpen of hoSQLConnect to hoStmt
88954>>>            If (hoStmt <> 0) Begin
88956>>>                // record starting date/time stamp
88956>>>                Move (CurrentDateTime()) to dtQueryExecStart
88957>>>                // turn on error handling if enabled 
88957>>>                If (pbHandleQueryErrors(Self)) Begin
88959>>>                    Set pbSqlError to False 
88960>>>                    Set paSqlErrorArray to aSqlErrorArray
88961>>>                    Move Error_Object_Id to hoError
88962>>>                    Move Self to Error_Object_Id
88963>>>                End               
88963>>>>
88963>>>                
88963>>>                // Before we execute the statement; save it so we can display the faulty statement in the error log.
88963>>>                Set psSQLStatementString to sStmt
88964>>>                Send SqlExecDirect of hoStmt sStmt
88965>>>                
88965>>>                If (pbHandleQueryErrors(Self)) Begin
88967>>>                    Move hoError to Error_Object_Id
88968>>>                End       
88968>>>>
88968>>>                
88968>>>                Move 0 to iMsgs
88969>>>                // ToDo: There seems to be some issues with this code and Mertech drivers that makes
88969>>>                // the debugger crash in some cases like an error in the ESQL statement; so we exclude it for now.
88969>>>                If (bMertechDriver = False) Begin   
88971>>>                    Move Err to iErr
88972>>>                    Get SqlStmtAttribute of hoStmt SQLSTMTATTRIB_NUMMESSAGES   to iMsgs
88973>>>                    Get SqlStmtAttribute of hoStmt SqlSTMTATTRIB_ROWCOUNT      to iRows
88974>>>                    Get SqlStmtAttribute of hoStmt SqlSTMTATTRIB_ROWCOUNT_TYPE to iRowType
88975>>>                    Send _SqlColumnInfo hoStmt
88976>>>                    Send Ignore_Error of Error_Object_Id 12289    
88977>>>                    Set Error_Report_Mode to DUF_ERROR_NO_REPORT
88978>>>                    Repeat     
88978>>>>
88978>>>                        Get SqlFetch of hoStmt to iFetchResult
88979>>>                        If (iFetchResult <> 0) Begin
88981>>>                            Get SQLColumnValue of hoStmt 1 to aSQLFetchResults[SizeOfArray(aSQLFetchResults)]
88982>>>                        End
88982>>>>
88982>>>                    Until (iFetchResult = 0)
88984>>>                    Send Trap_Error of Error_Object_Id 12289    
88985>>>                    Set Error_Report_Mode to DUF_ERROR_REPORT 
88986>>>                    Move iErr to Err
88987>>>                    Set paSQLFetchResults to aSQLFetchResults
88988>>>                End 
88988>>>>
88988>>>                
88988>>>                Set piRows    to iRows
88989>>>                Set piRowType to iRowType
88990>>>                Move (CurrentDateTime()) to dtQueryExecEnd
88991>>>                Move (CurrentDateTime()) to dtFetchStart
88992>>>
88992>>>                If (iMsgs <> 0) Begin
88994>>>                    If (ghoDbUpdateHandler > 0) Begin
88996>>>                        Get paSQLQueryMessages of ghoDbUpdateHandler to aSQLQueryMessages
88997>>>                    End
88997>>>>
88997>>>                    For i from 1 to iMsgs
89003>>>>
89003>>>                        Get SqlGetMessage of hoStmt i to sMessage
89004>>>                        Get RemoveComponentIdentifier of hoStmt sMessage to sMessage
89005>>>                        If (bShowProgress = True) Begin
89007>>>                            If (Active_State(ghoStatusPanel)) Begin
89009>>>                                Send Update_StatusPanel of ghoStatusPanel (Sformat("  SQLGetMessage iMessage %1 returned [%2]",iMessage,sMessage))
89010>>>                            End                                                   
89010>>>>
89010>>>                            Else Begin
89011>>>                                Showln (Sformat("  SQLGetMessage iMessage %1 returned [%2]",iMessage,sMessage))
89013>>>                            End                                           
89013>>>>
89013>>>                        End
89013>>>>
89013>>>                        Move sMessage to sMsg[SizeOfArray(sMsg)]
89014>>>                        Move sMessage to aSQLQueryMessages[SizeOfArray(aSQLQueryMessages)]
89015>>>                    Loop
89016>>>>
89016>>>                    If (ghoDbUpdateHandler > 0) Begin
89018>>>                        Set paSQLQueryMessages of ghoDbUpdateHandler to aSQLQueryMessages
89019>>>                    End
89019>>>>
89019>>>                    Set paQueryMessages to sMsg  
89020>>>                End
89020>>>>
89020>>>                Move (CurrentDateTime()) to dtFetchEnd
89021>>>            End
89021>>>>
89021>>>            Move (dtQueryExecEnd - dtQueryExecStart) to tsQuery
89022>>>            Move (dtFetchStart - dtFetchEnd) to tsFetch
89023>>>            Set ptsQueryExec to tsQuery
89024>>>            Set ptsFetchResults to tsFetch
89025>>>            Send SqlClose of hoStmt
89026>>>        End
89026>>>>
89026>>>
89026>>>        Send SqlDisconnect of hoSQLConnect
89027>>>    End_Procedure
89028>>>
89028>>>    // *** Main message for executing an SQL script that has been compiled into the program as a resource ***
89028>>>    // Use the SQLIncludeScriptFile command to include an SQL script into the program.
89028>>>    // Returns False if no error occured.
89028>>>    Function SqlUtilExecuteResource String sMemFileName String sDriverID Boolean bCreateScriptFile Boolean bShowProgr Returns Boolean
89030>>>        Boolean bOK bShowProgress                               
89030>>>        tSQLScriptArray SQLScriptArray                      
89030>>>        tSQLScriptArray SQLScriptArray                      
89030>>>        Integer iOut iRows iCount
89030>>>        DateTime dtTotalQueryStart dtTotalQueryEnd
89030>>>        TimeSpan tsTotalTime  
89030>>>        String sMessage
89030>>>        
89030>>>        Move (CurrentDateTime()) to dtTotalQueryStart
89031>>>        Get SqlUtilReadResource sMemFileName to SQLScriptArray
89032>>>        If (SQLScriptArray.bError = True) Begin
89034>>>            Function_Return False
89035>>>        End
89035>>>>
89035>>>
89035>>>        If (num_arguments > 3) Begin
89037>>>            Move bShowProgr to bShowProgress
89038>>>        End
89038>>>>
89038>>>
89038>>>        Set Error_Report_Mode to DUF_ERROR_NO_REPORT
89039>>>        Get SqlUtilExecuteEmbeddedScript SQLScriptArray sDriverID bCreateScriptFile sMemFileName bShowProgress to bOK
89040>>>        Set Error_Report_Mode to DUF_ERROR_REPORT 
89041>>>        
89041>>>        If (SQLScriptArray.bArgumentSizeChanged = True) Begin
89043>>>            Set_Argument_Size SQLScriptArray.iOrgArgumentSize
89044>>>>
89044>>>        End
89044>>>>
89044>>>
89044>>>        Move (CurrentDateTime()) to dtTotalQueryEnd
89045>>>        Move (dtTotalQueryEnd - dtTotalQueryStart) to tsTotalTime
89046>>>        Set ptsTotalQueryTime to tsTotalTime
89047>>>        
89047>>>        Function_Return bOK
89048>>>    End_Procedure
