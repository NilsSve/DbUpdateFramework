88843>>>    Function SqlUtilEnumerateLoggedInUsers String sDriverID String sDatabase Returns tSQLLoggedInUser[]
88845>>>        tSQLLoggedInUser[] SQLLoggedInUser
88845>>>        tSQLLoggedInUser[] SQLLoggedInUser
88846>>>        String[] sUsers sPrograms
88848>>>        String sSelect 
88848>>>        Integer iSize iCount
88848>>>        
88848>>>        Case Begin
88848>>>            Case (sDriverID = MSSQLDRV_ID)
88850>>>                Move ("SELECT RTRIM(SP.nt_username) AS Inlog, RTRIM(SP.program_name) as Programma from master.dbo.sysprocesses SP INNER JOIN master.dbo.sysdatabases SD ON SP.dbid = SD.dbid WHERE (SP.nt_username <> '') and (SP.nt_username <> 'SYSTEM') and (SD.name = '" ;                + sDatabase + "') ORDER by Inlog") to sSelect
88851>>>                Get SqlEnumerateEsqlDAW sSelect 1 to sUsers
88852>>>                Get SqlEnumerateEsqlDAW sSelect 2 to sPrograms
88853>>>                Case Break
88854>>>            Case (sDriverID = SQLFLEX)
88857>>>                Move ("SELECT RTRIM(SP.nt_username) AS Inlog, RTRIM(SP.program_name) as Programma from master.dbo.sysprocesses SP INNER JOIN master.dbo.sysdatabases SD ON SP.dbid = SD.dbid WHERE (SP.nt_username <> '') and (SP.nt_username <> 'SYSTEM') and (SD.name = '" ;                + sDatabase + "') ORDER by Inlog") to sSelect
88858>>>                Get SqlEnumerateEsqlMertech sSelect 1 to sUsers
88859>>>                Get SqlEnumerateEsqlMertech sSelect 2 to sPrograms
88860>>>                Case Break                 
88861>>>            Case Else
88861>>>                Error DFERR_PROGRAM ("Not implemented yet for this driver (" + sDriverID + ")")
88862>>>>
88862>>>        Case End
88862>>>        
88862>>>        Move (SizeOfArray(sUsers)) to iSize
88863>>>        Decrement iSize
88864>>>        For iCount from 0 to iSize
88870>>>>
88870>>>            Move sUsers[iCount]    to SQLLoggedInUser[iCount].sUser
88871>>>            Move sPrograms[iCount] to SQLLoggedInUser[iCount].sProgram
88872>>>        Loop
88873>>>>
88873>>>        
88873>>>        Function_Return SQLLoggedInUser
88874>>>    End_Function 
