98495>>>            Get vSelect_File "SQLConnections ini-files (*.ini)|SQLConnections.ini|All Ini Files (*.ini)|*.ini|All Files (*.*)|*.*" "Select a connection ini-file" "" to sFileName
98496>>>            If (sFileName <> "") Begin
98498>>>                Get phoSQLConnectionIniFile of ghoSQLConnectionHandler to ho
98499>>>                Get ParseFolderName sFileName to sPath
98500>>>                Set psIniFilePath of ho to sPath
98501>>>                Get ParseFileName sFileName to sFileName
98502>>>                Set psIniFileName of ho to sFilename    
98503>>>                Set pbDFConnId of ho to (sFileName <> CS_SQLIniFileName)
98504>>>                Send LoadData of oSQLConnections_grd
98505>>>            End
98505>>>>
98505>>>        End_Procedure                           
