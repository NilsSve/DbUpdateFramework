85827>>>>>>Function ParseKeyWord String sConnect String sKeyWord Returns String
85829>>>>>>    Integer iStart iEnd
85829>>>>>>    String sRetval
85829>>>>>>
85829>>>>>>    Move (Trim(sConnect)) to sConnect
85830>>>>>>    Move (Pos(Uppercase(sKeyWord), Uppercase(sConnect)))  to iStart
85831>>>>>>    If (iStart = 0) Begin
85833>>>>>>        Function_Return ""
85834>>>>>>    End
85834>>>>>>>
85834>>>>>>    Move (Left(sConnect, (iStart -1 + Length(sKeyWord)))) to sRetval
85835>>>>>>    Move (Replace(sRetval, sConnect, "")) to sRetval 
85836>>>>>>    If (sKeyWord = Uppercase(CS_SQLConnectionIDText)) Begin
85838>>>>>>        Move (Pos(",", sRetval))          to iEnd
85839>>>>>>    End
85839>>>>>>>
85839>>>>>>    Else Begin
85840>>>>>>        Move (Pos(";", sRetval))          to iEnd
85841>>>>>>    End                                          
85841>>>>>>>
85841>>>>>>    If (iEnd = 0 and (sRetval contains ",")) Begin
85843>>>>>>        Move (Pos(",", sRetval))          to iEnd 
85844>>>>>>        Decrement iEnd
85845>>>>>>    End
85845>>>>>>>
85845>>>>>>    If (iEnd <> 0) Begin
85847>>>>>>        Move (Left(sRetval, (iEnd -1)))   to sRetval
85848>>>>>>    End
85848>>>>>>>
85848>>>>>>    Move (Replace("=", sRetval, ""))      to sRetval
85849>>>>>>
85849>>>>>>    Function_Return (Trim(sRetval))
85850>>>>>>End_Function
