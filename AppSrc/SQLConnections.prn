93685>>>    // The normal connection string looks something like this;
93685>>>    // SERVER=.\SQLEXPRESS; DATABASE=OrderEntry; TRUSTED_CONNECTION=Yes; ,0
93685>>>    // ...and the full connection string looks like this;
93685>>>    // DFConnectionId OrderEntry, SERVER=.\SQLEXPRESS; DATABASE=OrderEntry; TRUSTED_CONNECTION=Yes; ,0
93685>>>    Function psFullConnectionString Returns String
93687>>>        String sConnectionID sConnectionString
93687>>>        If (ghoSQLConnectionHandler = 0) Begin
93689>>>            Error DFERR_PROGRAM "ghoSQLConnectionHandler = 0! This indicates that NO ConnectionID has been setup by the programmer."
93690>>>>
93690>>>            Function_Return
93691>>>        End                                                                   
93691>>>>
93691>>>        Get psConnectionID     of ghoSQLConnectionHandler to sConnectionID                       
93692>>>        Move (Trim(sConnectionID)) to sConnectionID
93693>>>        Get psConnectionString of ghoSQLConnectionHandler to sConnectionString
93694>>>        Function_Return (CS_SQLConnectionIDText * sConnectionID + "," * String(sConnectionString))
93695>>>    End_Function
