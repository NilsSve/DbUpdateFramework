86469>>>    // *** Main Connection Message ***
86469>>>    // It will create a Connection ID for the passed driver. 
86469>>>    // It will also set the psDriverID & psConnectionID of this class.
86469>>>    Procedure CreateSQLConnection String sDriverID String sConnectionID String sServer String sDatabase Boolean bTrusted String sUserID String sPassword Boolean bSilent
86471>>>        Integer iResult
86471>>>        Handle hoCLI hoDriver
86471>>>        String sConnectionString sError  
86471>>>        Boolean bMertech bLoginSuccessful
86471>>>        
86471>>>        Get ConstructConnectionString sDriverID sServer sDatabase bTrusted sUserID sPassword to sConnectionString 
86472>>>        Get Create (RefClass(cDbUpdateDatabaseDriver)) to hoDriver
86473>>>        Set psDriverID of hoDriver to sDriverID
86474>>>        Get DbLogin of hoDriver sConnectionString sServer sDatabase bTrusted sUserID sPassword to bLoginSuccessful
86475>>>        If (bLoginSuccessful = False) Begin
86477>>>            Error DFERR_PROGRAM (CS_DUF_CannotLoginToServer * CS_DUF_ErrorText * String(sError) + "\nConnectionID = " * sConnectionID + "\nConnection String = " * sConnectionString)
86478>>>>
86478>>>        End
86478>>>>
86478>>>        Send Destroy of hoDriver 
86479>>>    
86479>>>    End_Procedure
86480>>>    
86480>>>    Function RedirectConnection String sOldConnection String sNewConnection Returns Integer
86482>>>        Integer iRetval
86482>>>        Handle hoCLI               
86482>>>        String sDriverID
86482>>>        
86482>>>        Get psDriverID to sDriverID
86483>>>        Get Create (Refclass(cCLIHandler)) to hoCLI
86484>>>        If (hoCLI <> 0) Begin
86486>>>            Set psDriverID of hoCLI to sDriverID
86487>>>            Get RedirectConnection of hoCLI sOldConnection sNewConnection to iRetval
86488>>>            Send Destroy of hoCLI
86489>>>        End
86489>>>>
86489>>>        
86489>>>        Function_Return iRetval
86490>>>    End_Function
86491>>>    
86491>>>    Procedure CreateConnParamsFromConnectionString String sDriverID String sConnectionString
86493>>>        Integer iResult
86493>>>        Handle hoCLI
