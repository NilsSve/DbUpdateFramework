87404>>>    
87404>>>    // *** SQL Messages for making changes to the SQL back-end ***
87404>>>    //
87404>>>        
87404>>>    // Function for creating a new *Database*.
87404>>>    // Note: This is for creating SQL DATABASES - not tables!
87404>>>    // Returns True if successful. 
87404>>>    // ToDo: Only works for MS-SQL...
87404>>>    Function SqlDatabaseCreate String sDriverID String sDatabase Boolean bUpdateConnectionString Boolean bPermanantly Returns Boolean
87406>>>        String sSQL sSQL1 sConnectionID sConnectionString sCreateDatabaseKeyWord sSelectFromWhereName
87406>>>        Handle hConnection hStmt hoSQLManager
87406>>>        Integer iFetchResult iDbType
87406>>>        Boolean bOK bMertechDriver
87406>>>        
87406>>>        Get piDbType to iDbType
87407>>>        If (iDbType <> EN_DbTypeMSSQL) Begin
87409>>>            Error DFERR_PROGRAM "Sorry, the SqlDatabaseCreate function is currently only supported for MS-SQL"
87410>>>>
87410>>>            Function_Return False
87411>>>        End
87411>>>>
87411>>>        
87411>>>        Get IsMertechDriver sDriverID to bMertechDriver
87412>>>        If (bMertechDriver = False) Begin
87414>>>            Get phoSQLManager to hoSQLManager       
87415>>>        End 
87415>>>>
87415>>>        Else Begin
87416>>>            Get _MertechSQLManagerHandle to hoSQLManager
87417>>>        End
87417>>>>
87417>>>            
87417>>>        Get psConnectionID     to sConnectionID
87418>>>        Get psConnectionString to sConnectionString 
87419>>>        Move 0 to LastErr
87420>>>        
87420>>>        Send Ignore_Error of Error_Object_Id CLIERR_LOGIN_UNSUCCESSFUL
87421>>>        Get SqlConnect of hoSQLManager sDriverID sConnectionString to hConnection
87422>>>        Send Trap_Error of Error_Object_Id CLIERR_LOGIN_UNSUCCESSFUL
87423>>>        If (LastErr = CLIERR_LOGIN_UNSUCCESSFUL) Begin
87425>>>            Error DFERR_PROGRAM ("Login failed to the database server. The following connect string was used:\n" + sConnectionString)
87426>>>>
87426>>>            Function_Return False
87427>>>        End 
87427>>>>
87427>>>        
87427>>>        Get SqlOpen of hConnection to hStmt
87428>>>
87428>>>        If (hStmt = 0) Begin
87430>>>            Send SqlDisconnect of hoSQLManager
87431>>>            Error DFERR_PROGRAM CS_SQLConnectError
87432>>>>
87432>>>            Function_Return False
87433>>>        End
87433>>>>
87433>>>        
87433>>>        Get _SqlFindKeyWord CI_SQLCreateDatabase to sCreateDatabaseKeyWord 
87434>>>        Get _SqlSelectFromWhereName to sSelectFromWhereName
87435>>>        Move (sSelectFromWhereName + "='" + sDatabase + "'") to sSQL
87436>>>        
87436>>>        // Check if database exists
87436>>>        Send SqlExecDirect of hStmt sSQL
87437>>>        Get SqlFetch of hStmt to iFetchResult
87438>>>        Send SqlClose of hStmt
87439>>>        Send SqlDisconnect of hConnection
87440>>>
87440>>>        // If database already exists we're out of here!
87440>>>        // Note that we return True as this is not an error.
87440>>>        If (iFetchResult > 0) Begin
87442>>>            Function_Return True
87443>>>        End
87443>>>>
87443>>>
87443>>>        // Database doesn't exist, create it.
87443>>>        If (iFetchResult = 0) Begin
87445>>>            Move (sCreateDatabaseKeyWord + " [" + sDatabase + "]") to sSQL1
87446>>>            Send Ignore_Error of Error_Object_Id CLIERR_GENERAL_ERROR
87447>>>
87447>>>            Send SqlUtilExecuteQuery sSQL1 sDriverID
87448>>>
87448>>>            Send Trap_Error of Error_Object_Id CLIERR_GENERAL_ERROR
87449>>>            If (LastErr = CLIERR_GENERAL_ERROR) Begin
87451>>>               Function_Return False
87452>>>            End
87452>>>>
87452>>>            
87452>>>            // We need to wait a short time for Sql to finish, especially Windows to write the new file to disk.
87452>>>            Sleep 1
87453>>>            Send SqlUtilExecuteQuery sSQL sDriverID
87454>>>        End
87454>>>>
87454>>>
87454>>>        // If used in e.g. the cDbUpdteHandler we want to change the login database name to 
87454>>>        // the one we just created.
87454>>>        If (bUpdateConnectionString = True) Begin
87456>>>            Set psDatabase to sDatabase 
87457>>>            //...and perhaps also the SQLConnections.ini file setting.
87457>>>            If (bPermanantly = True) Begin
87459>>>                If (ghoSQLConnectionHandler <> 0) Begin
87461>>>                    Get SQLIniFileSetDefaultConnection of ghoSQLConnectionHandler sConnectionID to bOK        
87462>>>                End
87462>>>>
87462>>>            End
87462>>>>
87462>>>        End
87462>>>>
87462>>>
87462>>>        Function_Return (Err = False)
87463>>>    End_Function   
