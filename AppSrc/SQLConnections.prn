86527>>>    Function ExistingConnectionSettings String sDriverID String sConnectionID Returns tSQLConnection
86529>>>        Integer iResult iDriver iNumConn iConn
86529>>>        Handle hoCLI
86529>>>        String sID sConnectionString sVal sDatabase
86529>>>        tSQLConnection SQLConnection
86529>>>        tSQLConnection SQLConnection
86529>>>        Boolean bTrusted
86529>>>        
86529>>>        Move 0 to iResult
86530>>>        Get Create U_cCLIHandler to hoCLI
86531>>>        If (hoCLI <> 0) Begin
86533>>>            Set psDriverID of hoCLI to sDriverID
86534>>>            Get DriverIndex sDriverID to iDriver
86535>>>            Get_Attribute DF_DRIVER_NUMBER_CONNECTION_IDS of iDriver to iNumConn 
86538>>>            Decrement iNumConn
86539>>>            For iConn from 0 to iNumConn
86545>>>>
86545>>>                Get_Attribute DF_DRIVER_CONNECTION_ID of iDriver iConn to sID
86548>>>                If (Uppercase(sID) = Uppercase(sConnectionID)) Begin                                             
86550>>>                    Move sDriverID                                                      to SQLConnection.sDriverID      // For completeness only...
86551>>>                    Get_Attribute DF_DRIVER_CONNECTION_ID of iDriver iConn              to SQLConnection.sConnectionID  // For completeness only...
86554>>>                    Get_Attribute DF_DRIVER_CONNECTION_ID_STRING of iDriver iConn       to sConnectionString
86557>>>                    Move sConnectionString                                              to SQLConnection.sConnectionString 
86558>>>                    Get_Attribute DF_DRIVER_CONNECTION_ID_OPTIONS of iDriver iConn      to SQLConnection.bSilentLogin
86561>>>                    Get ParseKeyWord sConnectionString (CS_SQLIniServerKeyword + "=")   to SQLConnection.sServer
86562>>>                    Get ParseKeyWord sConnectionString (CS_SQLIniDatabaseKeyword + "=") to SQLConnection.sDatabase
86563>>>                    Get ParseKeyWord sConnectionString (CS_SQLIniUIDKeyword + "=")      to SQLConnection.sUserID
86564>>>                    Get ParseKeyWord sConnectionString (CS_SQLIniPWDKeyword + "=")      to SQLConnection.sPassword
86565>>>                    
86565>>>                    Case Begin
86565>>>                        Case (sDriverID = MSSQLDRV_ID)
86567>>>                            Get ParseKeyWord sConnectionString (CS_SQLIniTrustedKeyword + "=") to sVal
86568>>>                            Move (If(Uppercase(sVal) = Uppercase(CS_SQLIniConnectionYes), True, False)) to bTrusted
86569>>>                            Move bTrusted                                               to SQLConnection.bTrusted
86570>>>                            Case Break
86571>>>                        Case (sDriverID = DB2_DRV_ID)
86574>>>                            Get ParseKeyWord sConnectionString (CS_SQLIniDSNKeyword + "=") to SQLConnection.sServer
86575>>>                            Case Break
86576>>>                        Case (sDriverID = ODBC_DRV_ID)
86579>>>                            Get ParseKeyWord sConnectionString (CS_SQLIniDSNKeyword + "=") to SQLConnection.sServer
86580>>>                            Case Break
86581>>>                        Case (sDriverID = SQLFLEX)
86584>>>                            Get ParseKeyWord sConnectionString (CS_SQLIniDSNKeyword + "=") to SQLConnection.sServer 
86585>>>                            Move (CS_SQLIniServerKeyword + "=" + SQLConnection.sServer)    to sConnectionString
86586>>>                            If (SQLConnection.bTrusted = True) Begin
86588>>>                                Move (sConnectionString + ";" + CS_SQLIniTrustedKeyword + "=" + CS_SQLIniConnectionYes) to sConnectionString
86589>>>                            End
86589>>>>
86589>>>                            Else Begin
86590>>>                                Get ParseKeyWord sConnectionString (CS_SQLIniUIDKeyword + "=")    to sVal
86591>>>                                Move (sConnectionString + ";" + CS_SQLIniUIDKeyword + "=" + sVal) to sConnectionString
86592>>>                                Get ParseKeyWord sConnectionString (CS_SQLIniPWDKeyword + "=")    to sVal
86593>>>                                Move (sConnectionString + ";" + CS_SQLIniPWDKeyword + "=" + sVal) to sConnectionString
86594>>>                            End
86594>>>>
86594>>>                            Move sConnectionString                                         to SQLConnection.sConnectionString
86595>>>                            Case Break
86596>>>                        Case (sDriverID = MDSMySQL)
86599>>>                            Get ParseKeyWord sConnectionString (CS_SQLIniDSNKeyword + "=") to SQLConnection.sServer 
86600>>>                            Move (CS_SQLIniServerKeyword + "=" + SQLConnection.sServer)    to sConnectionString
86601>>>                            If (SQLConnection.bTrusted = True) Begin
86603>>>                                Move (sConnectionString + ";" + CS_SQLIniTrustedKeyword + "=" + CS_SQLIniConnectionYes) to sConnectionString
86604>>>                            End
86604>>>>
86604>>>                            Else Begin
86605>>>                                Get ParseKeyWord sConnectionString (CS_SQLIniUIDKeyword + "=")    to sVal
86606>>>                                Move (sConnectionString + ";" + CS_SQLIniUIDKeyword + "=" + sVal) to sConnectionString
86607>>>                                Get ParseKeyWord sConnectionString (CS_SQLIniPWDKeyword + "=")    to sVal
86608>>>                                Move (sConnectionString + ";" + CS_SQLIniPWDKeyword + "=" + sVal) to sConnectionString
86609>>>                            End
86609>>>>
86609>>>                            Move sConnectionString                                         to SQLConnection.sConnectionString
86610>>>                            Case Break
86611>>>                        Case (sDriverID = MDSPgSQL)
86614>>>                            Get ParseKeyWord sConnectionString (CS_SQLIniDSNKeyword + "=") to SQLConnection.sServer 
86615>>>                            Move (CS_SQLIniServerKeyword + "=" + SQLConnection.sServer)    to sConnectionString
86616>>>                            If (SQLConnection.bTrusted = True) Begin
86618>>>                                Move (sConnectionString + ";" + CS_SQLIniTrustedKeyword + "=" + CS_SQLIniConnectionYes) to sConnectionString
86619>>>                            End
86619>>>>
86619>>>                            Else Begin
86620>>>                                Get ParseKeyWord sConnectionString (CS_SQLIniUIDKeyword + "=")    to sVal
86621>>>                                Move (sConnectionString + ";" + CS_SQLIniUIDKeyword + "=" + sVal) to sConnectionString
86622>>>                                Get ParseKeyWord sConnectionString (CS_SQLIniPWDKeyword + "=")    to sVal
86623>>>                                Move (sConnectionString + ";" + CS_SQLIniPWDKeyword + "=" + sVal) to sConnectionString
86624>>>                            End
86624>>>>
86624>>>                            Move sConnectionString                                                to SQLConnection.sConnectionString
86625>>>                            Case Break
86626>>>                        
86626>>>                        Case (sDriverID = ORAFLEX)
86629>>>                            Get ParseKeyWord sConnectionString (CS_SQLIniDSNKeyword + "=")      to SQLConnection.sServer 
86630>>>                            Move (CS_SQLIniServerKeyword + "=" + SQLConnection.sServer)         to sConnectionString
86631>>>                            Get ParseKeyWord sConnectionString (CS_SQLIniDatabaseKeyword + "=") to sDatabase
86632>>>                            If (sDatabase <> "" and (not(SQLConnection.sServer contains "/"))) Begin
86634>>>                                Move (SQLConnection.sServer + "/" + sDatabase)                  to SQLConnection.sServer
86635>>>                            End
86635>>>>
86635>>>                            If (SQLConnection.bTrusted = True) Begin
86637>>>                                Move (sConnectionString + ";" + CS_SQLIniTrustedKeyword + "=" + CS_SQLIniConnectionYes) to sConnectionString
86638>>>                            End
86638>>>>
86638>>>                            Else Begin
86639>>>                                Get ParseKeyWord sConnectionString (CS_SQLIniUIDKeyword + "=")    to sVal
86640>>>                                Move (sConnectionString + ";" + CS_SQLIniUIDKeyword + "=" + sVal) to sConnectionString
86641>>>                                Get ParseKeyWord sConnectionString (CS_SQLIniPWDKeyword + "=")    to sVal
86642>>>                                Move (sConnectionString + ";" + CS_SQLIniPWDKeyword + "=" + sVal) to sConnectionString
86643>>>                            End
86643>>>>
86643>>>                            Move sConnectionString                                         to SQLConnection.sConnectionString
86644>>>                            Case Break
86645>>>                        Case Else
86645>>>                            Error ("Wrong driver ID passed:" * sDriverID)
86646>>>>
86646>>>                            Case Break
86647>>>                    Case End                    
86647>>>                End
86647>>>>
86647>>>            Loop
86648>>>>
86648>>>            Send Destroy of hoCLI
86649>>>        End
86649>>>>
86649>>>        
86649>>>        Function_Return SQLConnection
86650>>>    End_Function
