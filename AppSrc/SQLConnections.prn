97536>>>>>    Function IsConnectionIDDuplicate tSQLConnection SQLConnection Returns Boolean
97539>>>>>        Integer iCount iSize iItems iCurrentRow
97539>>>>>        String sValue sConnectionID
97539>>>>>        Boolean bExists 
97539>>>>>        tDataSourceRow[] TheData 
97539>>>>>        tDataSourceRow[] TheData 
97540>>>>>        tDataSourceRow TheRow
97540>>>>>        tDataSourceRow TheRow
97540>>>>>        
97540>>>>>        Move 0 to iItems  
97541>>>>>        Get piCurrentRow to iCurrentRow                   
97542>>>>>        Move SQLConnection.sConnectionID to sConnectionID
97543>>>>>        Get MoveSQLConnectionToGridRow SQLConnection to TheRow      
97544>>>>>        Get pTheData to TheData
97545>>>>>        Move (SizeOfArray(TheData)) to iSize  
97546>>>>>        If (iCurrentRow <> -1) Begin  
97548>>>>>            // This is the sConnectionID:
97548>>>>>            Move TheRow.sValue[2] to TheData[iCurrentRow].sValue[2]
97549>>>>>        End 
97549>>>>>>
97549>>>>>        Else Begin
97550>>>>>            Move TheRow to TheData[iSize]
97551>>>>>        End
97551>>>>>>
97551>>>>>        Move (SizeOfArray(TheData)) to iSize  
97552>>>>>        Decrement iSize
97553>>>>>        For iCount from 0 to iSize
97559>>>>>>
97559>>>>>            Move TheData[iCount].sValue[2] to sValue    
97560>>>>>            Move (sValue = sConnectionID) to bExists
97561>>>>>            If (bExists) Begin
97563>>>>>                Increment iItems
97564>>>>>            End
97564>>>>>>
97564>>>>>        Loop
97565>>>>>>
97565>>>>>                
97565>>>>>        Function_Return (iItems > 1)
97566>>>>>    End_Function       
