87564>>>        If (bExists = True) Begin
87566>>>            Function_Return False
87567>>>        End                      
87567>>>>
87567>>>        
87567>>>        Get psDataPathFirstPart to sPath
87568>>>        Get vFilePathExists (sPath + String(sTableName) + ".int") to bExists
87569>>>        If (bExists = True) Begin
87571>>>            // ToDo: What should we do if an .int file already exists?
87571>>>        End
87571>>>>
87571>>>        
87571>>>        Get piDbType to iDbType
87572>>>        Get _SqlProperTableName sTableName to sTableName
87573>>>        Get _SqlFindKeyWord CI_SQLCreateTable iDbType to sCreateTable
87574>>>        Move (sCreateTable * String(sTableName) * "(Dummy Decimal(2,0))") to sSQLString
