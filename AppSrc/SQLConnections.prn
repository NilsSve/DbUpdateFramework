82438>>>>>>>>>>>>>/// @Param Code Set    Code Set used by the database being created
82438>>>>>>>>>>>>>/// @Param Territory   Territory associated to the database being created
82438>>>>>>>>>>>>>/// @Param Path        Location of the database                                    - Optional
82438>>>>>>>>>>>>>/// @Param Node Name   Name of the machine (node) where the database is to reside  - Optional
82438>>>>>>>>>>>>>/// @Param User ID     User ID owning the database                                 - Optional
82438>>>>>>>>>>>>>/// @Param Password    Password of the User owning the database                    - Optional
82438>>>>>>>>>>>>>///
82438>>>>>>>>>>>>>
82438>>>>>>>>>>>>>//=============================================================================
82438>>>>>>>>>>>>>/// @Name        SQL_OPEN_CURSOR_STMT
82438>>>>>>>>>>>>>/// @Description This command is used to create a new SQl Cursor. Once
82438>>>>>>>>>>>>>/// created, SQL_SET_CURRENT_CURSOR_STMT can be called to specify which
82438>>>>>>>>>>>>>/// cursor is to be used for a given SQL statement. Creating multiple
82438>>>>>>>>>>>>>/// cursors using this command allows multiple SQL statements to be
82438>>>>>>>>>>>>>/// opened at once. Optionally a different server can be specified for each
82438>>>>>>>>>>>>>/// cursor by passing the server name to this command as well. If no
82438>>>>>>>>>>>>>/// server is specified, the current server will be used. Note that it
82438>>>>>>>>>>>>>/// is important to close all cursors at the end using SQL_CLOSE_CURSOR_STMT.
82438>>>>>>>>>>>>>///
82438>>>>>>>>>>>>>/// @Assumptions
82438>>>>>>>>>>>>>/// @Status      Public
82438>>>>>>>>>>>>>/// @Drivers     All
82438>>>>>>>>>>>>>/// @VersionNote Last Revised: 2013-10-07 by Aaron Gulack
82438>>>>>>>>>>>>>/// @See                 SQL_CLOSE_CURSOR_STMT SQL_SET_CURRENT_CURSOR_STMT SQL_GET_CURRENT_CURSOR_STMT
82438>>>>>>>>>>>>>///
82438>>>>>>>>>>>>>/// @Syntax SQL_OPEN_CURSOR_STMT [of {server}] to {variable}
82438>>>>>>>>>>>>>/// @Param server                       Name of the server (optional)
82438>>>>>>>>>>>>>/// @Param variable                     Variable to hold the returned cursor handle
82438>>>>>>>>>>>>>///
82438>>>>>>>>>>>>>/// @Example
82438>>>>>>>>>>>>>///
82438>>>>>>>>>>>>>/// Integer iCursor1 iCursor2 iCustomer
82438>>>>>>>>>>>>>/// String  sName
82438>>>>>>>>>>>>>/// Number  nOrderTotal
82438>>>>>>>>>>>>>///
82438>>>>>>>>>>>>>/// SQL_OPEN_CURSOR_STMT to iCursor1
82438>>>>>>>>>>>>>/// SQL_SET_STMT         to "SELECT CUSTOMER_NUMBER,NAME FROM CUSTOMER "
82438>>>>>>>>>>>>>/// SQL_APPEND_STMT      to "ORDER BY NAME "
82438>>>>>>>>>>>>>/// SQL_PREPARE_STMT
82438>>>>>>>>>>>>>/// SQL_EXECUTE_STMT
82438>>>>>>>>>>>>>/// Repeat
82438>>>>>>>>>>>>>///     SQL_SET_CURRENT_CURSOR_STMT TO iCursor1
82438>>>>>>>>>>>>>///     SQL_FETCH_NEXT_ROW INTO iCustomer sName
82438>>>>>>>>>>>>>///     If (Found) Begin
82438>>>>>>>>>>>>>///        SQL_OPEN_CURSOR_STMT to iCursor2
82438>>>>>>>>>>>>>///        SQL_SET_STMT         to "SELECT SUM(ORDER_TOTAL) FROM ORDERHEA "
82438>>>>>>>>>>>>>///        SQL_APPEND_STMT      to ("WHERE CUSTOMER_NUMBER = " + Trim(iCustomer))
82438>>>>>>>>>>>>>///        SQL_PREPARE_STMT
82438>>>>>>>>>>>>>///        SQL_EXECUTE_STMT
82438>>>>>>>>>>>>>///        SQL_FETCH_NEXT_ROW INTO nOrderTotal
82438>>>>>>>>>>>>>///        If (Found and nOrderTotal > 0) Begin
82438>>>>>>>>>>>>>///            Showln "Customer : " iCustomer "-" sName " - Total: " nOrderTotal
82438>>>>>>>>>>>>>///        End
82438>>>>>>>>>>>>>///        SQL_CLOSE_CURSOR_STMT to Cursor2
82438>>>>>>>>>>>>>///
82438>>>>>>>>>>>>>///        Indicate Found True
82438>>>>>>>>>>>>>///     End
82438>>>>>>>>>>>>>/// Until (Not(Found))
82438>>>>>>>>>>>>>///
82438>>>>>>>>>>>>>/// SQL_CLOSE_CURSOR_STMT to Cursor1
82438>>>>>>>>>>>>>
82438>>>>>>>>>>>>>//=============================================================================
82438>>>>>>>>>>>>>/// @Name        SQL_CLOSE_CURSOR_STMT
82438>>>>>>>>>>>>>/// @Description This command closes the specified cursor that was created
82438>>>>>>>>>>>>>/// from SQL_OPEN_CURSOR_STMT. It is good practice to close all cursors
82438>>>>>>>>>>>>>/// once the statements associated with them are complete.
82438>>>>>>>>>>>>>///
82438>>>>>>>>>>>>>/// @Assumptions
82438>>>>>>>>>>>>>/// @Status      Public
82438>>>>>>>>>>>>>/// @Drivers     All
82438>>>>>>>>>>>>>/// @VersionNote Last Revised: 2013-10-07 by Aaron Gulack
82438>>>>>>>>>>>>>/// @See                 SQL_OPEN_CURSOR_STMT SQL_SET_CURRENT_CURSOR_STMT SQL_GET_CURRENT_CURSOR_STMT
82438>>>>>>>>>>>>>///
82438>>>>>>>>>>>>>/// @Syntax SQL_CLOSE_CURSOR_STMT [of {server}] to {variable}
82438>>>>>>>>>>>>>/// @Param server                       Name of the server (optional)
82438>>>>>>>>>>>>>/// @Param variable                     Cursor handle to close
82438>>>>>>>>>>>>>///
82438>>>>>>>>>>>>>/// @Example
82438>>>>>>>>>>>>>///
82438>>>>>>>>>>>>>/// SQL_OPEN_CURSOR_STMT to hCursor1
82438>>>>>>>>>>>>>///
82438>>>>>>>>>>>>>/// SQL_SET_STMT to "SELECT * FROM CUSTOMER WHERE STATUS = 'Active' "
82438>>>>>>>>>>>>>/// SQL_PREPARE_STMT
82438>>>>>>>>>>>>>/// SQL_EXECUTE_STMT
82438>>>>>>>>>>>>>///
82438>>>>>>>>>>>>>/// SQL_OPEN_CURSOR_STMT to hCursor2
82438>>>>>>>>>>>>>///
82438>>>>>>>>>>>>>/// SQL_SET_STMT to "SELECT * FROM CUSTOMER WHERE STATUS = 'Inactive' "
82438>>>>>>>>>>>>>/// SQL_PREPARE_STMT
82438>>>>>>>>>>>>>/// SQL_EXECUTE_STMT
82438>>>>>>>>>>>>>///
82438>>>>>>>>>>>>>/// Repeat
82438>>>>>>>>>>>>>///     SQL_SET_CURRENT_CURSOR_STMT to hCursor1
82438>>>>>>>>>>>>>///     SQL_FETCH_NEXT_ROW INTO  sID sFirstName sLastName
82438>>>>>>>>>>>>>///     If (Found) Begin
82438>>>>>>>>>>>>>///        Showln "Active : " sID "- " sFirstName sLastName
82438>>>>>>>>>>>>>///     End
82438>>>>>>>>>>>>>///
82438>>>>>>>>>>>>>///     SQL_SET_CURRENT_CURSOR_STMT to hCursor2
82438>>>>>>>>>>>>>///     SQL_FETCH_NEXT_ROW into sId sFirstName sLastName
82438>>>>>>>>>>>>>///     If (Found) Begin
82438>>>>>>>>>>>>>///         Showln "Inactive : " sID "- " sFirstName sLastName
82438>>>>>>>>>>>>>///     End
82438>>>>>>>>>>>>>/// Until (FindErr)
82438>>>>>>>>>>>>>///
82438>>>>>>>>>>>>>/// SQL_CLOSE_CURSOR_STMT to hCursor1
82438>>>>>>>>>>>>>/// SQL_CLOSE_CURSOR_STMT to hCursor2
82438>>>>>>>>>>>>>
82438>>>>>>>>>>>>>//=============================================================================
82438>>>>>>>>>>>>>/// @Name        SQL_SET_CURRENT_CURSOR_STMT
82438>>>>>>>>>>>>>/// @Description This command is used to open a cursor to be used for an
82438>>>>>>>>>>>>>/// SQl statement. The cursor must be created using the SQL_OPEN_CURSOR_STMT,
82438>>>>>>>>>>>>>/// but once it has been created, this command can easily switch between
82438>>>>>>>>>>>>>/// cursors as desired. Optionally a different server can be specified for each
82438>>>>>>>>>>>>>/// cursor by passing the server name to this command as well. If no
82438>>>>>>>>>>>>>/// server is specified, the current server will be used. Note that it
82438>>>>>>>>>>>>>/// is important to close all cursors at the end using SQL_CLOSE_CURSOR_STMT.
82438>>>>>>>>>>>>>///
82438>>>>>>>>>>>>>/// @Assumptions
82438>>>>>>>>>>>>>/// @Status      Public
82438>>>>>>>>>>>>>/// @Drivers     All
82438>>>>>>>>>>>>>/// @VersionNote Last Revised: 2013-10-07 by Aaron Gulack
82438>>>>>>>>>>>>>/// @See                 SQL_OPEN_CURSOR_STMT SQL_CLOSE_CURSOR_STMT SQL_GET_CURRENT_CURSOR_STMT
82438>>>>>>>>>>>>>///
82438>>>>>>>>>>>>>/// @Syntax SQL_SET_CURRENT_CURSOR_STMT [of {server}] to {variable}
82438>>>>>>>>>>>>>/// @Param server                       Name of the server (optional)
82438>>>>>>>>>>>>>/// @Param variable                     Cursor handle to use
82438>>>>>>>>>>>>>///
82438>>>>>>>>>>>>>/// @Example
82438>>>>>>>>>>>>>///
82438>>>>>>>>>>>>>/// SQL_OPEN_CURSOR_STMT to hCursor1
82438>>>>>>>>>>>>>///
82438>>>>>>>>>>>>>/// SQL_SET_STMT to "SELECT * FROM CUSTOMER WHERE STATUS = 'Active' "
82438>>>>>>>>>>>>>/// SQL_PREPARE_STMT
82438>>>>>>>>>>>>>/// SQL_EXECUTE_STMT
82438>>>>>>>>>>>>>///
82438>>>>>>>>>>>>>/// SQL_OPEN_CURSOR_STMT to hCursor2
82438>>>>>>>>>>>>>///
82438>>>>>>>>>>>>>/// SQL_SET_STMT to "SELECT * FROM CUSTOMER WHERE STATUS = 'Inactive' "
82438>>>>>>>>>>>>>/// SQL_PREPARE_STMT
82438>>>>>>>>>>>>>/// SQL_EXECUTE_STMT
82438>>>>>>>>>>>>>///
82438>>>>>>>>>>>>>/// Repeat
82438>>>>>>>>>>>>>///     SQL_SET_CURRENT_CURSOR_STMT to hCursor1
82438>>>>>>>>>>>>>///     SQL_FETCH_NEXT_ROW INTO  sID sFirstName sLastName
82438>>>>>>>>>>>>>///     If (Found) Begin
82438>>>>>>>>>>>>>///        Showln "Active : " sID "- " sFirstName sLastName
82438>>>>>>>>>>>>>///     End
82438>>>>>>>>>>>>>///
82438>>>>>>>>>>>>>///     SQL_SET_CURRENT_CURSOR_STMT to hCursor2
82438>>>>>>>>>>>>>///     SQL_FETCH_NEXT_ROW into sId sFirstName sLastName
82438>>>>>>>>>>>>>///     If (Found) Begin
82438>>>>>>>>>>>>>///         Showln "Inactive : " sID "- " sFirstName sLastName
82438>>>>>>>>>>>>>///     End
82438>>>>>>>>>>>>>/// Until (FindErr)
82438>>>>>>>>>>>>>///
82438>>>>>>>>>>>>>/// SQL_CLOSE_CURSOR_STMT to hCursor1
82438>>>>>>>>>>>>>/// SQL_CLOSE_CURSOR_STMT to hCursor2
82438>>>>>>>>>>>>>
82438>>>>>>>>>>>>>//=============================================================================
82438>>>>>>>>>>>>>/// @Name        SQL_GET_CURRENT_CURSOR_STMT
82438>>>>>>>>>>>>>/// @Description This command returns the current active cursor being
82438>>>>>>>>>>>>>/// used. The cursor is returned to the specified variable.
82438>>>>>>>>>>>>>///
82438>>>>>>>>>>>>>/// @Assumptions
82438>>>>>>>>>>>>>/// @Status      Public
82438>>>>>>>>>>>>>/// @Drivers     All
82438>>>>>>>>>>>>>/// @VersionNote Last Revised: 2013-10-07 by Aaron Gulack
82438>>>>>>>>>>>>>/// @See SQL_OPEN_CURSOR_STMT SQL_CLOSE_CURSOR_STMT SQL_SET_CURRENT_CURSOR_STMT
82438>>>>>>>>>>>>>///
82438>>>>>>>>>>>>>/// @Syntax SQL_GET_CURRENT_CURSOR_STMT [of {server}] to {variable}
82438>>>>>>>>>>>>>/// @Param server                       Name of the server (optional)
82438>>>>>>>>>>>>>/// @Param variable         Variable to hold the current cursor handle
82438>>>>>>>>>>>>>///
82438>>>>>>>>>>>>>/// @Example
82438>>>>>>>>>>>>>/// SQL_GET_CURRENT_CURSOR_STMT to hCursor
82438>>>>>>>>>>>>>
82438>>>>>>>>>>>>>//=============================================================================
