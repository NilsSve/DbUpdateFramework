89922>>>
89922>>>    // We might have a split Sql script where the info about which database to use is
89922>>>    // put on top of the Sql script, we then need to save it to be able to retrieve it later and
89922>>>    // insert it for scriplets to come after the first one.
89922>>>    Function _SqlFormatStatement String sStmt Returns String
89924>>>        String sUseDatabase sTmp sUseKeyWord sCreateViewKeyWord sDBOKeyWord sNoCountKeyWord sDriverID
89924>>>        Integer iStart iEnd iDbType
89924>>>        Boolean bOK
89924>>>        
89924>>>        Get piDbType to iDbType 
89925>>>        Get psDriverID to sDriverID
89926>>>        Get _SqlFindKeyWord CI_SQLUse          to sUseKeyWord  
89927>>>        Get _SqlFindKeyWord CI_SQLSetNoCountOn to sNoCountKeyWord
89928>>>        Get _SqlFindKeyWord CI_SQLCreateView   to sCreateViewKeyWord            
89929>>>        Get _SqlFindKeyWord CI_SQLDBO          to sDBOKeyWord 
89930>>>        Move (Replaces(" ", sStmt, "")) to sTmp
89931>>>        If (Uppercase(sTmp) contains (sUseKeyWord +"[")) Begin
89933>>>            Move (Pos("[", (Uppercase(sTmp)))) to iStart
89934>>>            Move (Pos("]", sTmp)) to iEnd
89935>>>            Move (Mid(sTmp, (iEnd -iStart +1), iStart)) to sUseDatabase
89936>>>            Move (sUseKeyWord * sUseDatabase + " ") to sUseDatabase
89937>>>            Set Private.psUseDatabase to sUseDatabase
89938>>>        End
89938>>>>
89938>>>        Else Begin   
89939>>>            Move (Uppercase(sStmt)) to sTmp
89940>>>
89940>>>            // A "Create View" statement _must_ be the very first words in a Sql statement.
89940>>>            If (not(sTmp contains sCreateViewKeyWord)) Begin
89942>>>                Get Private.psUseDatabase to sUseDatabase
89943>>>                Move (Insert(sUseDatabase, sStmt, 1)) to sStmt
89944>>>            End 
89944>>>>
89944>>>            
89944>>>            // This is a bit special to place here but was done so because it was easier that way.
89944>>>            // We will get an error when trying to create a view if it already exists.
89944>>>            // So to avoid such errors; we first remove it & then recreate it.
89944>>>            Else If (sTmp contains sCreateViewKeyWord) Begin 
89947>>>                // Make sure we only have one space between statements/words.  
89947>>>                Move (Replaces("  ", sTmp, " ")) to sTmp
89948>>>                Move (Replace(sCreateViewKeyWord, sTmp, "")) to sTmp
89949>>>                Move (Trim(sTmp)) to sTmp
89950>>>                Move (Pos(" ", sTmp)) to iEnd
89951>>>                Move (Left(sTmp, iEnd)) to sTmp
89952>>>                If ((not(sTmp contains ("[" + sDBOKeyWord + "]."))) and (not(sTmp contains (sDBOKeyWord + ".")))) Begin
89954>>>                    Move (sDBOKeyWord + "." + Trim(sTmp)) to sTmp
89955>>>                End  
89955>>>>
89955>>>                Move (Trim(sTmp)) to sTmp
89956>>>                // Remove data view as it already exists!
89956>>>                Get SqlViewRemove sDriverID sTmp to bOK
89957>>>            End
89957>>>>
89957>>>        End
89957>>>>
89957>>>
89957>>>        Function_Return sStmt    
89958>>>    End_Function
89959>>>    
89959>>>    // Returns the proper Sql language key word(s) for the passed SQL key-word constant
89959>>>    Function _SqlFindKeyWord Integer iSQLKeywordConstant Returns String
89961>>>        String sRetval         
89961>>>        Integer iDbType iSize iItem iIndex
89961>>>        tSQLKeyWords[] SQLKeywordArray 
89961>>>        tSQLKeyWords[] SQLKeywordArray 
89962>>>        tSQLKeyWords   SQLKeyWords
89962>>>        tSQLKeyWords   SQLKeyWords
89962>>>        
89962>>>        // Sql back-end type. E.g. MS-SQL, MySQL, Oracle, DB2...
89962>>>        Get piDbType to iDbType
89963>>>        Move iDbType             to SQLKeyWords.iSQLDbType
89964>>>        Move iSQLKeywordConstant to SQLKeyWords.iSQLWord
89965>>>         
89965>>>        Get paSQLKeywordArray to SQLKeywordArray
89966>>>        Move (SearchArray(SQLKeyWords, SQLKeywordArray, Self, RefFunc(CompareFindSQLKeyWords))) to iIndex
89967>>>        Move SQLKeywordArray[iIndex].sSQLPhrase to sRetval
89968>>>
89968>>>        Function_Return sRetval
89969>>>    End_Function
89970>>>    
89970>>>    // Function will "clean/sanitize" the script by removing all comments and blank lines.
89970>>>    Function _SqlUtilSanitizeScript tSQLScriptArray SqlScriptArray Returns tSQLScriptArray[] 
89972>>>        String[] sSQLScriptArray
89973>>>        String sText sLine sTmp sCommentStart sCommentEnd sDashComment
89973>>>        Integer iCh iSize iArgSize iPos iCount
89973>>>        Boolean bCommentStart bCommentEnd bDashComment
89973>>>        
89973>>>        Move False to bCommentStart
89974>>>        Move False to bCommentEnd 
89975>>>        Move False to bDashComment                                    
89976>>>        Move "/*"  to sCommentStart   // These are the standard comment start & stop tokens...
89977>>>        Move "*/"  to sCommentEnd
89978>>>        Move "--"  to sDashComment    // ...but a comment can also start with two dashes "--".
89979>>>
89979>>>        Move (SizeOfArray(SqlScriptArray.sSQLScriptArray)) to iSize
89980>>>        Decrement iSize
89981>>>        Move "" to sText  
89982>>>        
89982>>>        For iCount from 0 to iSize
89988>>>>
89988>>>            Move SqlScriptArray.sSQLScriptArray[iCount] to sLine
89989>>>            Move (Trim(sLine)) to sTmp
89990>>>            If (sTmp <> "") Begin
89992>>>                Move (Left(sTmp, 2) = sDashComment) to bDashComment
89993>>>                If (bCommentStart = False) Begin
89995>>>                    Move (Left(sTmp, 2) = sCommentStart) to bCommentStart
89996>>>                    If (bCommentStart = False) Begin
89998>>>                    End
89998>>>>
89998>>>                End
89998>>>>
89998>>>                Move (sTmp contains sCommentEnd) to bCommentEnd
89999>>>                If (bCommentEnd = True) Begin
90001>>>                    Move False to bCommentStart
90002>>>                End
90002>>>>
90002>>>                If (bDashComment = False and bCommentStart = False and bCommentEnd = False) Begin
90004>>>                    Move sLine to sSQLScriptArray[SizeOfArray(sSQLScriptArray)] 
90005>>>                End
90005>>>>
90005>>>            End
90005>>>>
90005>>>        Loop 
90006>>>>
90006>>>        
90006>>>        // Update the retval struct array:    
90006>>>        Move sSQLScriptArray to SqlScriptArray.sSQLScriptArray
90007>>>        Function_Return SqlScriptArray
90008>>>    End_Function
90009>>>
90009>>>    // *** Database API Functions: ***
90009>>>    // Instead of using Sql Scripts (ESQL), we can opt to use the DataFlex Database API's to 
90009>>>    // make changes/updates to the database.
90009>>>    //
90009>>>    //
90009>>>    // This might not do what you think - Here's what it does:
90009>>>    // It checks that the passed hTable TableName in filelist.cfg is exactly the same as at the SQL back-end.
90009>>>    // If that is True; it creates an .int file for it and changes Filelist.cfg to point
90009>>>    // to the SQL table.
90009>>>    // Typical usage for this function is when an entry exists in the Filelist for a table and the table
90009>>>    // already exists in SQL. 
90009>>>    // This is a bit fiddly as the DF_FILE_PHYSICAL_NAME attribute can only be set inside a 
90009>>>    // Structure_Start ... Structure_End operation when creating a NEW table. Thus it cannot be set when 
90009>>>    // restructuring an existing table.
90009>>>    Function ApiTableAttachToSQL Handle hTable Boolean bUseConnID Returns Boolean
90011>>>        Boolean bExists bOpened bOK bSystemFile bMertechDriver bUseConnectionID
90011>>>        String sDriverID sTableName sConnectionID sConnectionString sDisplayName sRootName sLogicalName sPhysicalName sSchema
90011>>>        Handle hToTable 
90011>>>        Integer iPos
90011>>>        
90011>>>        Move True to bUseConnectionID
90012>>>        If (num_arguments > 1) Begin
90014>>>            Move bUseConnID to bUseConnectionID
90015>>>        End                                    
90015>>>>
90015>>>        
90015>>>        Get psDriverID to sDriverID
90016>>>        // If the table doesn't exist on the SQL back-end we do nothing.
90016>>>        Get SqlUtilCheckIfTableHandleExists hTable sDriverID to bExists
90017>>>        If (bExists = False) Begin
90019>>>            Function_Return False
90020>>>        End
90020>>>>
90020>>>        
90020>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
90021>>>        If (bOK = False) Begin
90023>>>            Function_Return False
90024>>>        End
90024>>>>
90024>>>        
90024>>>        // Then we need to check that the function hasn't been called before; which in case
90024>>>        // we do nothing
90024>>>        Get SQLUtilTableIsAttached sDriverID hTable to bExists
90025>>>        If (bExists = True) Begin
90027>>>            Function_Return False
90028>>>        End
90028>>>>
90028>>>        
90028>>>        Get psConnectionID     to sConnectionID
90029>>>        Get psConnectionString to sConnectionString 
90030>>>        If (sConnectionID = "" or sConnectionString = "") Begin
90032>>>            Error DFERR_PROGRAM ("An SQL connection has NOT been setup correctly. Could not attach table:" * String(hTable) * "to SQL")
90033>>>>
90033>>>            Function_Return False
90034>>>        End                      
90034>>>>
90034>>>
90034>>>        Get psSchema to sSchema
90035>>>        If (sSchema = "") Begin
90037>>>            Get _SqlFindKeyWord CI_SQLDBO to sSchema  
90038>>>        End
90038>>>>
90038>>>
90038>>>        Get IsMertechDriver sDriverID to bMertechDriver
90039>>>        
90039>>>        // Mertech drivers don't use connection id's, so if the passed bUseConnectionID = True that
90039>>>        // was a programmer's error and we adjust for it here.
90039>>>        If (bMertechDriver = True) Begin
90041>>>            Move False to bUseConnectionID
90042>>>        End
90042>>>>
90042>>>            
90042>>>        // If we should use a connection id we need to check it exists; 
90042>>>        // else we create it before attempting creating the table
90042>>>        If (bUseConnectionID = True) Begin  
90044>>>            Get AutoConnectionIDLogin to bOK
90045>>>            If (bOk = False) Begin
90047>>>                Error DFERR_PROGRAM ("The Connection ID:" * sConnectionID * "could not be created and therefor the table can't be created.")
90048>>>>
90048>>>                Function_Return False
90049>>>            End
90049>>>>
90049>>>        End
90049>>>>
90049>>>            
90049>>>        Get_Attribute DF_FILE_ROOT_NAME of hTable to sRootName
90052>>>        Get _TableNameOnly sRootName to sRootName             
90053>>>        If (sRootName = "") Begin
90055>>>            Function_Return False
90056>>>        End
90056>>>>
90056>>>        Move (sRootName + ".int")                    to sPhysicalName       
90057>>>        Get_Attribute DF_FILE_LOGICAL_NAME of hTable to sLogicalName
90060>>>        Get_Attribute DF_FILE_DISPLAY_NAME of hTable to sDisplayName
90063>>>        If (sDisplayName contains ".") Begin
90065>>>            Move (Pos(".", sDisplayName)) to iPos  
90066>>>            Move (Mid(sDisplayName, 200 ,(iPos + 1))) to sDisplayName
90067>>>            Move (sSchema + "." + sDisplayName)       to sDisplayName
90068>>>        End
90068>>>>
90068>>>        If (not(Lowercase(sDisplayName) contains Lowercase(sSchema + "."))) Begin
90070>>>            Move (Lowercase(sSchema) + "." + sDisplayName) to sDisplayName
90071>>>        End
90071>>>>
90071>>>        
90071>>>        // ToDo: Needs to be revised. Should be able to connect to SQL without table already exist?
90071>>>        Open hTable Mode DF_EXCLUSIVE
90073>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpened
90076>>>        If (bOpened = False) Begin 
90078>>>            Error DFERR_PROGRAM ("Function ApiTableAttachToSQL - Could not open table number:" * String(hTable) * sLogicalName)
90079>>>>
90079>>>            Function_Return False
90080>>>        End                      
90080>>>>
90080>>>        
90080>>>        If (ghoProgressBar <> 0) Begin
90082>>>            Send DoAdvance of ghoProgressBar
90083>>>        End
90083>>>>
90083>>>        // Note: The hToTable will get changed by the Structure_xxx command...
90083>>>        Move hTable to hToTable 
90084>>>        Move False to Err       
90085>>>        
90085>>>        // We now create a stub .int file and after Structure_end and also change the Filelist.cfg,
90085>>>        // then we do a pseudo .int file change with the "SqlUtilUpdateIntFile" function. After that we have
90085>>>        // a proper and updated .int file.
90085>>>        Get_Attribute DF_FILE_IS_SYSTEM_FILE of hTable to bSystemFile  
90088>>>        Get SqlUtilCreateIntFile hTable sDriverID sConnectionID True bSystemFile to bOK
90089>>>        
90089>>>        Structure_Start hToTable sDriverID
90090>>>            If (bUseConnectionID = True) Begin  
90092>>>                Set_Attribute DF_FILE_LOGIN     of hToTable to (CS_DFCONNID + "=" + sConnectionID)
90095>>>            End
90095>>>>
90095>>>            Else Begin
90096>>>                Set_Attribute DF_FILE_LOGIN     of hToTable to sConnectionString
90099>>>            End
90099>>>>
90099>>>            Set_Attribute DF_FILE_OWNER         of hToTable to (Lowercase(sSchema))
90102>>>            // For unknown reason the above sometimes triggers an error and it doesn't help to try to trap the error; so we cheat...
90102>>>            Move False to Err
90103>>>            Move 0 to LastErr
90104>>>        Structure_End hToTable 
90106>>>        
90106>>>        Move (not(Err)) to bOK
90107>>>        If (bOK = True) Begin
90109>>>            // The attributes set above will always trigger an error
90109>>>            // We also adjust the Filelist entries
90109>>>            Set_Attribute DF_FILE_ROOT_NAME    of hTable to (sDriverID + ":" + sRootName)
90112>>>            Set_Attribute DF_FILE_LOGICAL_NAME of hTable to sLogicalName
90115>>>            Set_Attribute DF_FILE_DISPLAY_NAME of hTable to sDisplayName
90118>>>            
90118>>>            // This pseudo updates the .int file to make it up-to-date with the SQL back-end.
90118>>>            Get SqlUtilUpdateIntFile hTable to bOK
90119>>>        End
90119>>>>
90119>>>          
90119>>>        Function_Return (bOK = True)
90120>>>    End_Function
90121>>>    
90121>>>    // Sample usage:    
90121>>>    //    Get ApiTableChangeAttribute SysInfo.File_Number DF_FILE_IS_SYSTEM_FILE True to bOK
90121>>>    //    Get ApiTableChangeAttribute OrderHea.File_Number DF_FILE_REUSE_DELETED DF_FILE_DELETED_NOREUSE to bOK
90121>>>    Function ApiTableChangeAttribute Handle hTable Integer iAttribute Integer iValue Returns Boolean
90123>>>        Boolean bOK
90123>>>        
90123>>>        Get AutoConnectionIDLogin to bOK
90124>>>        Move False to Err
90125>>>        Open hTable Mode DF_EXCLUSIVE
90127>>>        Structure_Start hTable
90128>>>            Set_Attribute iAttribute of hTable to iValue
90131>>>        Structure_End hTable 
90133>>>
90133>>>        Function_Return (Err = False)
90134>>>    End_Function
90135>>>    
90135>>>    // To use a filelist slot for the passed FileName, TableName & DisplayName,
90135>>>    // or to change the filelist slot names.    
90135>>>    Function ApiTableChangeFileListSlot String sRootName String sLogicalName String sDisplayName Handle hTable String sDriverID Returns Boolean       
90137>>>        Move False to Err
90138>>>        Boolean bExists
90138>>>        
90138>>>        Move False to Err
90139>>>        Get UtilTableNumberIsInUse hTable to bExists
90140>>>        If (bExists = False) Begin
90142>>>            Function_Return False
90143>>>        End
90143>>>>
90143>>>
90143>>>        If (ghoProgressBar <> 0) Begin
90145>>>            Send DoAdvance of ghoProgressBar
90146>>>        End
90146>>>>
90146>>>        // If all strings are empty it means that we should remove this entry from filelist.
90146>>>        If (sRootName = "" and sLogicalName = "" and sDisplayName = "") Begin
90148>>>            Set_Attribute DF_FILE_ROOT_NAME     of hTable to ""
90151>>>            Set_Attribute DF_FILE_LOGICAL_NAME  of hTable to ""
90154>>>            Set_Attribute DF_FILE_DISPLAY_NAME  of hTable to ""
90157>>>            Function_Return (Err = False) // And we're done.
90158>>>        End
90158>>>>
90158>>>        
90158>>>        If (sDriverID <> DATAFLEX_ID) Begin
90160>>>            Set_Attribute DF_FILE_ROOT_NAME of hTable to (sDriverID + ":" + sRootName)
90163>>>        End 
90163>>>>
90163>>>        Else Begin
90164>>>            Set_Attribute DF_FILE_ROOT_NAME of hTable to sRootName
90167>>>        End
90167>>>>
90167>>>            
90167>>>        Set_Attribute DF_FILE_LOGICAL_NAME  of hTable to sLogicalName
90170>>>        
90170>>>        If (sDriverID <> DATAFLEX_ID and not(Uppercase(sDisplayName) contains "DBO.")) Begin
90172>>>            Set_Attribute DF_FILE_DISPLAY_NAME  of hTable to ("dbo." + sDisplayName)
90175>>>        End
90175>>>>
90175>>>        Else Begin
90176>>>            Set_Attribute DF_FILE_DISPLAY_NAME  of hTable to sDisplayName
90179>>>        End
90179>>>>
90179>>>        
90179>>>        Function_Return (Err = False)
90180>>>    End_Function
90181>>>    
90181>>>    Function ApiTableChangeRecordLength Handle hTable Integer iRecordLength Returns Boolean
90183>>>        Boolean bOK
90183>>>        
90183>>>        Get AutoConnectionIDLogin to bOK
90184>>>        Move False to Err
