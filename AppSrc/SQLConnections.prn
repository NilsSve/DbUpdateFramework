87464>>>    // Note: To convert an embedded table to SQL use ApiTableConvertToSQL.
87464>>>    //       To convert from SQL -> SQL (e.g. from Oracle - > MS SQL)
87464>>>    //          first use SQLTableConvertToEmbedded in one cDbUpdateVersion object,
87464>>>    //          and then use the ApiTableConvertToSQL method in a second cDbUpdateVersion object.
87464>>>    Function SQLTableConvertToEmbedded Handle hTable Boolean bCpyDat Returns Boolean
87466>>>        Handle hToTable
87466>>>        Boolean bOK bExists bOpened bMertechDriver bDAWDriver bCopyData
87466>>>        String sDriverID sPhysicalName sRootName sDisplayName sEmpty sConnectionID sConnectionString
87466>>>        String sDBOKeyWord sANSI_OEM sSchema sBaseTableSpace sLongTableSpace sIndexTableSpace sDatabase
87466>>>        tSQLConnection SQLConnection  
87466>>>        tSQLConnection SQLConnection  
87466>>>        Integer iPos iMaxRecords
87466>>>        
87466>>>        Get psDriverID to sDriverID
87467>>>        Get SqlUtilCheckIfTableHandleExists hTable sDriverID to bExists
87468>>>        If (bExists = False) Begin
87470>>>            Function_Return False
87471>>>        End                      
87471>>>>
87471>>>        
87471>>>        If (num_arguments > 1) Begin
87473>>>            Move bCpyDat to bCopyData
87474>>>        End                          
87474>>>>
87474>>>        Else Begin
87475>>>            Move False to bCopyData
87476>>>        End                        
87476>>>>
87476>>>        
87476>>>        If (ghoProgressBar <> 0) Begin
87478>>>            Send DoAdvance of ghoProgressBar
87479>>>        End
87479>>>>
87479>>>        
87479>>>        Open hTable
87481>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpened
87484>>>        If (bOpened = False) Begin 
87486>>>            Error DFERR_PROGRAM ("Could not open table number:" * String(hTable))
87487>>>>
87487>>>            Function_Return False
87488>>>        End                      
87488>>>>
87488>>>        Move 0 to hToTable
87489>>>        
87489>>>//        Get_Attribute DF_FILE_MAX_RECORDS  of hTable to iMaxRecords 
87489>>>        Move 16711679 to iMaxRecords
87490>>>        Get_Attribute DF_FILE_DISPLAY_NAME of hTable to sDisplayName  
87493>>>        Move (Pos(".", sDisplayName)) to iPos
87494>>>        If (iPos > 0) Begin
87496>>>            Move (Mid(sDisplayName, 200, (iPos +1))) to sDisplayName
87497>>>        End
87497>>>>
87497>>>        Get_Attribute DF_FILE_ROOT_NAME    of hTable to sRootName
87500>>>        Get _TableNameOnly sRootName                 to sRootName
87501>>>        Move (sRootName + ".dat")                    to sPhysicalName
87502>>>//        Move sRootName                               to sPhysicalName
87502>>>        
87502>>>        Move False to Err   
87503>>>
87503>>>        Structure_Start hToTable DATAFLEX_ID
87504>>>            Structure_Copy hTable to hToTable
87505>>>            
87505>>>            Set_Attribute DF_FILE_PHYSICAL_NAME of hToTable to sPhysicalName  
87508>>>            Set_Attribute DF_FILE_REUSE_DELETED of hToTable to DF_FILE_DELETED_REUSE
87511>>>            Set_Attribute DF_FILE_MULTIUSER     of hToTable to DF_FILE_USER_MULTI  
87514>>>            Set_Attribute DF_FILE_TRANSACTION   of hToTable to DF_FILE_TRANSACTION_CLIENT_ATOMIC
87517>>>            Set_Attribute DF_FILE_MAX_RECORDS   of hToTable to iMaxRecords
87520>>>                   
87520>>>        Structure_End hToTable        
87522>>>        
87522>>>        Move (not(Err)) to bOK
87523>>>        If (bOK = True and bCopyData = True) Begin
87525>>>            Get ApiTableCopyData hTable sPhysicalName sRootName DATAFLEX_ID to bOK
87526>>>        End
87526>>>>
87526>>>
87526>>>        Get IsMertechDriver sDriverID to bMertechDriver
87527>>>        If (bMertechDriver = True) Begin
87529>>>            Open hTable
87531>>>        End
87531>>>>
87531>>>        
87531>>>        // This must be after copying data...    
87531>>>        If (Err = False) Begin
87533>>>            Set_Attribute DF_FILE_ROOT_NAME    of hTable to sRootName
87536>>>            Set_Attribute DF_FILE_DISPLAY_NAME of hTable to sDisplayName
87539>>>        End
87539>>>>
87539>>>        Move (not(Err)) to bOK
87540>>>        
87540>>>        Function_Return (bOK = True)
87541>>>    End_Function                 
