80803>Object oApplication is a cApplication
80805>    Set peHelpType to htHtmlHelp 
80806>    Set psHelpFile to "DataFlex.chm"
80807>    Set psCompany to "RDC Tools International"
80808>    Set psProduct to "SQL Connections Manager"
80809>    Set psVersion to (String(piVersionMajor(phoVersionInfo(Self))) + "." + String(piVersionMinor(phoVersionInfo(Self)))) 
80810>    Set psAutoOpenWorkspace to ""
80811>    
80811>    Property String psCommandLineIniFilePath ""  
80813>    Property Boolean pbIniFileExists False
80815>    
80815>    Procedure OnCreate
80818>        Integer eOpened
80818>        Handle hoCmdLine
80818>        String sArgument sPath sFileName sWsFile
80818>        Integer iRetval                   
80818>        Boolean bExists
80818>
80818>        Get phoCommandLine to hoCmdLine
80819>        Get Argument of hoCmdLine 1 to sArgument
80820>        If (sArgument <> "") Begin
80822>            Get ParseFolderName sArgument to sPath
80823>            Get vFolderExists sPath to iRetval
80824>            If (iRetval = True) Begin
80826>                Set psCommandLineIniFilePath to sPath
80827>                Get vFilePathExists (sPath + "SQLConnections.ini") to bExists
80828>                Set pbIniFileExists to bExists
80829>            End
80829>        End  
80829>        
80829>        Get OpenWorkspaceFile of (phoWorkspace(Self)) "config.ws" to eOpened
80830>        If (eOpened <> wsWorkspaceOpened) Begin
80832>            Get GetApplicationPath to sPath
80833>            Get vSelect_File "Workspace Files (*.ws)|*.ws|All Files (*.*)|*.*" "Please select a Workspace file (*.ws)" sPath to sWsFile
80834>            Get vFilePathExists sWsFile to bExists
80835>            If (bExists = False) Begin
80837>                Send Stop_Box "No Workspace file selected. Cannot continue!"
80838>                Send Exit_Application
80839>            End
80839>            Get OpenWorkspaceFile of (phoWorkspace(Self)) sWsFile to eOpened
80840>            If (eOpened <> wsWorkspaceOpened) Begin
80842>                Set psHome          of (phoWorkspace(Self)) to sPath
80843>                Set psProgramPath   of (phoWorkspace(Self)) to sPath
80844>                Set psDataPath      of (phoWorkspace(Self)) to sPath
80845>                Set psFileList      of (phoWorkspace(Self)) to sPath
80846>                Set psHelpPath      of (phoWorkspace(Self)) to sPath
80847>                Set psBitmapPath    of (phoWorkspace(Self)) to sPath
80848>            End
80848>        End 
80848>    End_Procedure
80849>    
80849>
80849>End_Object  
