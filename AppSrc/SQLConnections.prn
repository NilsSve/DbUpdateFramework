86263>>>    // ************************************        
86263>>>    Function SetupSQLConnection Boolean bReadSettings Returns tSQLConnection
86265>>>        tSQLConnection SQLConnection 
86265>>>        tSQLConnection SQLConnection 
86265>>>        
86265>>>        // If this object was created by the cDbUpdateHandler class we will
86265>>>        // deferr reading SQL connection values until later.
86265>>>        If (bReadSettings = True) Begin
86267>>>            // This is the new SQL login logic for DF 19 and up; "Managed Connections"
86267>>>            If (ghoConnection > 0) Begin
86269>>>                Get ReadcConnections to SQLConnection
86270>>>            End
86270>>>>
86270>>>            
86270>>>            // In addition to the above; there might be other values set even if a cConnection
86270>>>            // object is used.
86270>>>            Get ReadSQLConnectionsIniSettings to SQLConnection
86271>>>        End     
86271>>>>
86271>>>        
86271>>>        Function_Return SQLConnection
86272>>>    End_Function
86273>>>    
86273>>>    // This is for the new cConnection class used by DF 19 and up (only).
86273>>>    Function ReadcConnections Returns tSQLConnection
86275>>>        tConnection Connection                 
86275>>>        tConnection Connection                 
86275>>>        tSQLConnection SQLConnection SQLConnectionEmpty
86275>>>        tSQLConnection SQLConnection SQLConnectionEmpty
86275>>>        Integer iCount iSize iRetval iDbType
86275>>>        Boolean bOK bEnabled bConnected bVal
86275>>>        String sConnectionID sSchema
86275>>>        
86275>>>            // - If the DF 19 cConnection class has been used in the cApplication object
86275>>>            // - and there are multiple connection id's defined for the same driver. This is
86275>>>            //   because otherwise we can't possibly know which connection id to use... So
86275>>>            //   we then generate an error and abort the program...
86275>>>            Get IsSinglecConnection (&sConnectionID) to bOK                                     
86276>>>            If (bOK = False) Begin
86278>>>                Error DFERR_PROGRAM ("Programming error. The psConnectionID must be set in the cDbUpdateVersion object when a cConnect object is used in the cApplication object, and there are multiple connections defined. Program will now exit!")
86279>>>>
86279>>>                Abort
86280>>>>
86280>>>            End  
86280>>>>
86280>>>            
86280>>>            Move 0 to iRetval
86281>>>            // DAW DF19 connection info: 
86281>>>            // We first check that the connection is OK:  
86281>>>            Get ConnectionIdIndex of ghoConnection sConnectionID to iRetval
86282>>>            // It might happen that no connection has been setup although the object exists, in case we do nothing.
86282>>>            If (iRetval = -1) Begin
86284>>>                Function_Return SQLConnectionEmpty
86285>>>            End                                 
86285>>>>
86285>>>
86285>>>            If (sConnectionID <> "") Begin
86287>>>                Get ConnectionIdInfo of ghoConnection sConnectionID to Connection  
86288>>>            End
86288>>>>
86288>>>            If (Connection.sId = "") Begin
86290>>>                Move True to SQLConnectionEmpty.bError
86291>>>                Function_Return SQLConnectionEmpty
86292>>>            End
86292>>>>
86292>>>            
86292>>>            Move Connection.sId to sConnectionID  
86293>>>            Get IsConnectionIdLoggedIn of ghoConnection sConnectionID to bConnected
86294>>>    
86294>>>            If (bConnected = False) Begin
86296>>>                Get LoginConnectionId of ghoConnection to iRetval    
86297>>>                If (iRetval <> 0) Begin 
86299>>>                    Send UserError CS_DUF_CannotLoginToServer
86300>>>                    Send Exit_Application    
86301>>>                End
86301>>>>
86301>>>            End
86301>>>>
86301>>>            
86301>>>            // DUF connection info struct property:
86301>>>            Get Private.pSQLConnection                       to SQLConnection   
86302>>>            Move True                                        to SQLConnection.bEnabled
86303>>>            Move Connection.bTrustedConnection               to SQLConnection.bTrusted
86304>>>    
86304>>>            // Not used in DUF:
86304>>>            // Move Connection.iDriverIndex                    to SQLConnection.iDriverIndex
86304>>>    
86304>>>            Move (If(Connection.iOptions = 0, False, True))  to SQLConnection.bSilentLogin
86305>>>            Move Connection.sConnectionString                to SQLConnection.sConnectionString
86306>>>            Move Connection.sDriver                          to SQLConnection.sDriverID
86307>>>            Move Connection.sId                              to SQLConnection.sConnectionID
86308>>>            Move Connection.sUID                             to SQLConnection.sUserID
86309>>>            Move Connection.sPWD                             to SQLConnection.sPassword
86310>>>    
86310>>>            // Not used in DUF:
86310>>>            // Move Connection.sSection to SQLConnection.xxx
86310>>>            
86310>>>            // The rest of the properties of the SQLConnection struct should have been
86310>>>            // setup in the cDbUpdateHandler object, and we should be able to reach them through delegation:
86310>>>            If (Connection.sDriver <> ODBC_DRV_ID) Begin
86312>>>                Get ParseKeyWord Connection.sString CS_SQLIniServerKeyword to SQLConnection.sServer
86313>>>            End
86313>>>>
86313>>>            If (Connection.sDriver = ODBC_DRV_ID) Begin
86315>>>                Get ParseKeyWord Connection.sString CS_SQLIniDSNKeyword    to SQLConnection.sServer
86316>>>            End
86316>>>>
86316>>>            Get ParseKeyWord Connection.sString CS_SQLIniDatabaseKeyword   to SQLConnection.sDatabase  
86317>>>            
86317>>>            // The DbType is a bit special. If the piDbType has _not_ been setup in object code we try to derave
86317>>>            // the value from the driver id:
86317>>>            Get SqlUtilDbTypeFromDriver of (phoSQLConnectionIniFile(Self)) Connection.sDriver to SQLConnection.iDbType
86318>>>            // ...but in case it has been explicitly set in the object we use that value.
86318>>>            Get piDbType                                     to iDbType
86319>>>            If (iDbType <> SQLConnection.iDbType) Begin
86321>>>                Move iDbType to SQLConnection.iDbType
86322>>>            End
86322>>>>
86322>>>            Get psBaseTableSpace                             to SQLConnection.sBaseTableSpace
86323>>>            Get psLongTableSpace                             to SQLConnection.sLongTableSpace
86324>>>            Get psIndexTableSpace                            to SQLConnection.sIndexTableSpace
86325>>>            Get psSchema                                     to SQLConnection.sSchema
86326>>>            
86326>>>            // We finally set the struct property to the newly fetched values.
86326>>>            Set pSQLConnection to SQLConnection
86327>>>        
86327>>>        Function_Return SQLConnection
86328>>>    End_Function
86329>>>    
86329>>>    // Returns True if the psConnectionID has been set in the cDbUpateHandler object,
86329>>>    // or the DAW cConnect array of registered connection only contains one active/enabled
86329>>>    // connection id for a particular driver.
86329>>>    // So either the psConnectionID or the psDriverID can have been set in the cDbUpdateHandler
86329>>>    // object. We can then match a connection id from the DAW cConnect class array.
86329>>>    // Returns False if there are multiple connections that are enabled or the psConnectionID has
86329>>>    // been set in the cDbUpdateHandler object but it cannot be found amongst the registered 
86329>>>    // connections of the DAW cConnect class.
86329>>>    Function IsSinglecConnection String ByRef sConnectionID Returns Boolean
86331>>>        tConnection[] ConnIdArray
86331>>>        tConnection[] ConnIdArray
86332>>>        Integer iCount iSize iConnectionIDCounter
86332>>>        Boolean bOK bEnabled bFound
86332>>>        String sConnectionID2 sDriverID sDriverConn
86332>>>        
86332>>>        Move False to bFound
86333>>>        If (ghoConnection > 0) Begin           
86335>>>            
86335>>>            // The property of the cDbUpdateHandler container object
86335>>>            Get psDriverID to sDriverID
86336>>>            
86336>>>            Move 0 to iConnectionIDCounter 
86337>>>            // This is the the DAW cConnect array with all registered connection id's.
86337>>>                Get ConnectionIDs of ghoConnection to ConnIdArray
86338>>>            Move (SizeOfArray(ConnIdArray)) to iSize
86339>>>            Decrement iSize
86340>>>            For iCount from 0 to iSize
86346>>>>
86346>>>                Move ConnIdArray[iCount].sDriver to sDriverConn
86347>>>                Move ConnIdArray[iCount].sId to sConnectionID2
86348>>>                Move (ConnIdArray[iCount].bDisabled = False) to bEnabled    
86349>>>                // If no psConnectionID specified in the cDbUpdateHandler, we check if there is a driver
86349>>>                // connection in the DAW cConnect object _and_ that there is only one!
86349>>>                If (sConnectionID = "") Begin
86351>>>                    Move (sDriverID = sDriverConn and bEnabled = True) to bFound 
86352>>>                End 
86352>>>>
86352>>>                Else Begin
86353>>>                    If (Uppercase(sConnectionID) = Uppercase(sConnectionID2)) Begin
86355>>>                        Move iSize to iCount // Then we've found what we were looking for and we're out of here... 
86356>>>                    End
86356>>>>
86356>>>                End
86356>>>>
86356>>>                    
86356>>>                If (bFound = True) Begin
86358>>>                    Increment iConnectionIDCounter
86359>>>                End
86359>>>>
86359>>>            Loop
86360>>>>
86360>>>            Move (iConnectionIDCounter <= 1 and sDriverConn <> "" and sConnectionID2 <> "") to bFound 
86361>>>            If (bFound = True) Begin
86363>>>                Move sConnectionID2 to sConnectionID
86364>>>            End
86364>>>>
86364>>>        End 
86364>>>>
86364>>>        
86364>>>        // Special case; a cConnection object has been setup in the cApplication,
86364>>>        // but no DFConn.ini record has been created.
86364>>>        If (iSize = -1) Begin
86366>>>            Move True to bFound
86367>>>        End
86367>>>>
86367>>>            
86367>>>        Function_Return bFound
86368>>>    End_Function
86369>>>    
86369>>>    // Send on object creation to read the default connection string settings, and
86369>>>    // create a connection to the server.
86369>>>    Function ReadSQLConnectionsIniSettings Returns tSQLConnection
86371>>>        String sPath sFileName sSection sConnectionString sPassword 
86371>>>        Boolean bExists
86371>>>        tSQLConnection[] SQLConnectionArray
86371>>>        tSQLConnection[] SQLConnectionArray
86372>>>        tSQLConnection SQLConnection SQLConnectionEmpty
86372>>>        tSQLConnection SQLConnection SQLConnectionEmpty
86372>>>        Handle hoIniFile
86372>>>        Integer iSize iCount
86372>>>        
86372>>>        Get psIniFilePath to sPath
86373>>>        Get phoSQLConnectionIniFile to hoIniFile
86374>>>        If (sPath = "") Begin
86376>>>            Get ApplicationPath of hoIniFile to sPath 
86377>>>            Set psIniFilePath   of hoIniFile to sPath 
86378>>>        End         
86378>>>>
86378>>>        Get vFolderFormat sPath to sPath
86379>>>        Get psIniFileName to sFileName    
86380>>>        Get vFilePathExists (sPath + sFileName) to bExists
86381>>>//        If (bExists = False) Begin   
86381>>>//            Move True to SQLConnection.bError
86381>>>//            Function_Return SQLConnectionEmpty 
86381>>>//        End                                                         
86381>>>        
86381>>>        Get SQLIniFileReadConnections of hoIniFile to SQLConnectionArray
86382>>>        Move (SizeOfArray(SQLConnectionArray)) to iSize
86383>>>        If (iSize = 0) Begin
86385>>>            // This may have been set by the "ReadcConnections" function,
86385>>>            // if a cConnection object has been setup for DataFlex 19 or later
86385>>>            // in the cApplication object.
86385>>>            Get pSQLConnection to SQLConnection
86386>>>            If (SQLConnection.sConnectionID = "") Begin
86388>>>                Function_Return SQLConnectionEmpty
86389>>>            End
86389>>>>
86389>>>            Move SQLConnection to SQLConnectionArray[0]
86390>>>        End
86390>>>>
86390>>>        
86390>>>        // The first connection should be the one that is active, but just in case...
86390>>>        Decrement iSize
86391>>>        For iCount from 0 to iSize
86397>>>>
86397>>>            Move SQLConnectionArray[iCount] to SQLConnection
86398>>>            If (SQLConnection.bEnabled = True) Begin
86400>>>                Move iSize to iCount // We've found the enabled item, so we're out of here.
86401>>>            End
86401>>>>
86401>>>        Loop
86402>>>>
86402>>>
86402>>>        Send CreateSQLConnection SQLConnection.sDriverID SQLConnection.sConnectionID ;             SQLConnection.sServer SQLConnection.sDatabase SQLConnection.bTrusted ;             SQLConnection.sUserID SQLConnection.sPassword SQLConnection.bSilentLogin   
86403>>>             
86403>>>        Set pSQLConnection to SQLConnection 
86404>>>        Send AutoSetConnectionID
86405>>>        
86405>>>        Function_Return SQLConnection
86406>>>    End_Function
86407>>>    
