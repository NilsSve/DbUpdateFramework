79767>>>Function DDE_Error_To_String Integer iErrorID Returns String
#REM AMBIGUOUS METHODS ON .DESKTOP. ARE .NOT. RECOMMENDED (OBSOLETE TECHNIQUE)
79769>>>  String sMessage
79769>>>  Case Begin
79769>>>    Case (iErrorID = vERROR_FILE_NOT_FOUND)
79771>>>      Move CS_DDE_ERR_FILE_NOT_FOUND To sMessage
79772>>>      Case Break
79773>>>    Case (iErrorID = vERROR_PATH_NOT_FOUND)
79776>>>      Move CS_DDE_ERR_PATH_NOT_FOUND To sMessage
79777>>>      Case Break
79778>>>    Case (iErrorID = vERROR_BAD_FORMAT)
79781>>>      Move CS_DDE_ERR_BAD_FORMAT To sMessage
79782>>>      Case Break
79783>>>    Case (iErrorID = vSE_ERR_ACCESSDENIED)
79786>>>      Move CS_DDE_ERR_ACCESSDENIED To sMessage
79787>>>      Case Break
79788>>>    Case (iErrorID = vSE_ERR_ASSOCINCOMPLETE)
79791>>>      Move CS_DDE_ERR_ASSOCINCOMPLETE To sMessage
79792>>>      Case Break
79793>>>    Case (iErrorID = vSE_ERR_DDEBUSY)
79796>>>      Move CS_DDE_ERR_DDEBUSY To sMessage
79797>>>      Case Break
79798>>>    Case (iErrorID = vSE_ERR_DDEFAIL)
79801>>>      Move CS_DDE_ERR_DDEFAIL To sMessage
79802>>>      Case Break
79803>>>    Case (iErrorID = vSE_ERR_DDETIMEOUT)
79806>>>      Move CS_DDE_ERR_DDETIMEOUT To sMessage
79807>>>      Case Break
79808>>>    Case (iErrorID = vSE_ERR_DLLNOTFOUND)
79811>>>      Move CS_DDE_ERR_DLLNOTFOUND To sMessage
79812>>>      Case Break
79813>>>    Case (iErrorID = vSE_ERR_NOASSOC)
79816>>>      Move CS_DDE_ERR_NOASSOC To sMessage
79817>>>      Case Break
79818>>>    Case ((iErrorID = vSE_ERR_OOM) Or (iErrorID = 0))
79821>>>      Move CS_DDE_ERR_OOM To sMessage
79822>>>      Case Break
79823>>>    Case (iErrorID = vSE_ERR_PNF)
79826>>>      Move CS_DDE_ERR_PNF To sMessage
79827>>>      Case Break
79828>>>    Case (iErrorID = vSE_ERR_SHARE)
79831>>>      Move CS_DDE_ERR_SHARE To sMessage
79832>>>      Case Break
79833>>>    Case Else
79833>>>      Move CS_DDE_ERR_UNKNOWN_LINE1 To sMessage
79834>>>      Move (sMessage*Trim(iErrorID)*CS_DDE_ERR_UNKNOWN_LINE2) To sMessage
79835>>>      Case Break
79836>>>  Case End
79836>>>  Function_Return sMessage
79837>>>End_Function // DDE_Error_To_String
79838>>>
79838>>>
79838>>>Procedure vDDE_Error_Handler Integer iErrorID
#REM AMBIGUOUS METHODS ON .DESKTOP. ARE .NOT. RECOMMENDED (OBSOLETE TECHNIQUE)
79840>>>  String sMessage
79840>>>  Get DDE_Error_To_String iErrorID To sMessage
79841>>>  Append sMessage CS_DDE_ERR_HANDL_PAKTC //  "Press a key to continue..."
79842>>>  Send Stop_Box sMessage CS_DDE_ERR_HANDL_CAPTION
