89133>>>    // This function allows you to put an Sql script in a CM Image. It makes it easier to
89133>>>    // copy and paste between a DataFlex program and an Sql Editor.
89133>>>    Function SqlUtilLoadImageFile String sFileName Returns String
89135>>>        Integer iChannel iPos
89135>>>        String sTextValue sLine sPath
89135>>>        Boolean bSeqEof
89135>>>        
89135>>>        Move "" to sTextValue        
89136>>>        Get ParseFolderName sFileName to sPath
89137>>>        If (Trim(sPath) = "") Begin
89139>>>            Get psDataPathFirstPart to sPath
89140>>>            Move (sPath + sFileName) to sFileName
89141>>>        End
89141>>>>
89141>>>        
89141>>>        Get Seq_New_Channel to iChannel
89142>>>        If (iChannel = DF_SEQ_CHANNEL_NOT_AVAILABLE) Begin
89144>>>            Error DFERR_PROGRAM "No channel available..."
89145>>>>
89145>>>        End
89145>>>>
89145>>>        Else Begin        
89146>>>            Direct_Input channel iChannel sFileName
89148>>>            Move (SeqEof) to bSeqEof
89149>>>            If (bSeqEof = True) Begin
89151>>>                Send Seq_Release_Channel iChannel 
89152>>>                Set psSQLStatementString to ""  
89153>>>                Error DFERR_PROGRAM ("The Sql script file:\n" + sFileName + "\nCould not be found.")
89154>>>>
89154>>>                Function_Return "" 
89155>>>            End
89155>>>>
89155>>>    
89155>>>            While (not(bSeqEof))
89159>>>                Readln channel iChannel sLine 
89161>>>                Move (Pos("/", sLine)) to iPos
89162>>>                Move (SeqEol) to bSeqEof
89163>>>                If (not(bSeqEof) and iPos <> 1) Begin
89165>>>                    Move (sTextValue + sLine + Character(13)) to sTextValue
89166>>>                End
89166>>>>
89166>>>            Loop
89167>>>>
89167>>>            Send Seq_Release_Channel iChannel
89168>>>        End
89168>>>>
89168>>>        
89168>>>        Set psSQLStatementString to sTextValue
89169>>>        Function_Return sTextValue
89170>>>    End_Function  
