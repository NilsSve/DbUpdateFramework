90923>>>    // *** Field/Column Level Functions: ***
90923>>>    //
90923>>>    // Adds a column name to the passed table number.
90923>>>    // Note: Types must be the standard DF_ASCII, DF_DATE etcetera and _cannot_ be any of the SQL_xxx types.
90923>>>    Function ApiColumnAdd Handle hTable String sFieldName Integer iType Integer iLength Integer iPrecision Returns Boolean
90925>>>        Integer iColumn iCount iFile
90925>>>        Boolean bExists bOK  
90925>>>        String sDdSrcPath sTableName
90925>>>    
90925>>>        Get UtilColumnExists hTable sFieldName to bExists
90926>>>        If (bExists = True) Begin
90928>>>            Function_Return False
90929>>>        End  
90929>>>>
90929>>>        If (iPrecision > 0) Begin
90931>>>            Move (iLength + iPrecision) to iLength
90932>>>        End
90932>>>>
90932>>>        
90932>>>        Get AutoConnectionIDLogin to bOK
90933>>>        Move False to Err   
90934>>>        // Structure_start will change the value of hTable...
90934>>>        Move hTable to iFile
90935>>>        Open iFile Mode DF_EXCLUSIVE
90937>>>        
90937>>>        Structure_Start iFile
90938>>>            Move 0 to iColumn
90939>>>            Create_Field hTable At iColumn
90940>>>            Set_Attribute DF_FIELD_NAME      of iFile iColumn to sFieldName
90943>>>            Set_Attribute DF_FIELD_TYPE      of iFile iColumn to iType
90946>>>            Set_Attribute DF_FIELD_LENGTH    of iFile iColumn to iLength
90949>>>            Set_Attribute DF_FIELD_PRECISION of iFile iColumn to iPrecision
90952>>>        Structure_End iFile
90954>>>        
90954>>>        // If in development environment; create .fd file:
90954>>>        Open hTable
90956>>>        Get psDdSrcPath of (phoWorkspace(ghoApplication)) to sDDSrcPath
90957>>>        Get CountOfPaths of (phoWorkspace(ghoApplication)) sDDSrcPath to iCount
90958>>>        If (iCount > 1) Begin
90960>>>            Get PathAtIndex of (phoWorkspace(ghoApplication)) sDDSrcPath 1 to sDDSrcPath    
90961>>>        End 
90961>>>>
90961>>>        Get vFolderExists sDDSrcPath to bExists
90962>>>        If (bExists = True) Begin                                   
90964>>>            Get vFolderFormat sDDSrcPath to sDDSrcPath 
90965>>>            Get_Attribute DF_FILE_ROOT_NAME of hTable to sTableName
90968>>>            Get _TableNameOnly sTableName to sTableName 
90969>>>            Output_Aux_File DF_AUX_FILE_FD for hTable to (sDDSrcPath + sTableName + ".fd")
90971>>>        End
90971>>>>
90971>>>        Close hTable
90972>>>
90972>>>        Function_Return (Err = False)
90973>>>    End_Function  
