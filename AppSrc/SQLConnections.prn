84803>>>>>>>>>>>//*****************************************************************************
84803>>>>>>>>>>>//*** Class  : cDfbtrdrvHandler                                                  ***
84803>>>>>>>>>>>//*** Purpose: An instance of this class can be used as a broker object to  ***
84803>>>>>>>>>>>//***          call several Dfbtrdrv releated methods.                           ***
84803>>>>>>>>>>>//*****************************************************************************
84803>>>>>>>>>>>
84803>>>>>>>>>>>Class cDFBtrDrvHandler Is An Array
84804>>>>>>>>>>>
84804>>>>>>>>>>>    Procedure Construct_Object Integer iImage
84806>>>>>>>>>>>        Forward Send Construct_object iImage
84808>>>>>>>>>>>
84808>>>>>>>>>>>        Property String  psDriverID       Public "DFBTRDRV"
84809>>>>>>>>>>>    End_Procedure // Construct_Object
84810>>>>>>>>>>>
84810>>>>>>>>>>>
84810>>>>>>>>>>>
84810>>>>>>>>>>>    //***
84810>>>>>>>>>>>    //*** Function: CKRevsion
84810>>>>>>>>>>>    //*** Purpose : The revsion of a Dfbtrdrv Connectivity Kit
84810>>>>>>>>>>>    //***
84810>>>>>>>>>>>
84810>>>>>>>>>>>    Function CKRevision Returns String
84812>>>>>>>>>>>        Local String  sDriverID
84812>>>>>>>>>>>        Local String  sRevision
84812>>>>>>>>>>>        Local String  sVoid
84812>>>>>>>>>>>        Local Integer iRetval
84812>>>>>>>>>>>
84812>>>>>>>>>>>        // Ignore error 20491 DFBTRERR_INVALID_DRIVER_FUNCTION_CALL.
84812>>>>>>>>>>>        // This error would otherwise be raised when we have an older
84812>>>>>>>>>>>        // DFBTRDRV version that has no DFBTRFN_CKREVISION function
84812>>>>>>>>>>>        Send Ignore_error To Error_object_Id 20491
84813>>>>>>>>>>>        Get psDriverID To sDriverID
84814>>>>>>>>>>>        Move (Repeat(" ", 255)) To sRevision
84815>>>>>>>>>>>        Call_Driver 0 sDRiverID Function DFBTRFN_CKREVISION Callback 0 Passing sRevision sVoid 0 Result iRetval
84820>>>>>>>>>>>        Send Trap_Error To Error_object_Id 20491
84821>>>>>>>>>>>        If (Trim(sRevision) = "") Begin
84823>>>>>>>>>>>            // Unable to get the revision. return all zeroes.
84823>>>>>>>>>>>            Move "0.0.0.0" To sRevision
84824>>>>>>>>>>>        End
84824>>>>>>>>>>>>
84824>>>>>>>>>>>        Function_Return sRevision
84825>>>>>>>>>>>    End_Function // CKRevision
84826>>>>>>>>>>>
84826>>>>>>>>>>>    Function CkUsesUri Returns Integer
84828>>>>>>>>>>>        Local String  sDriverID
84828>>>>>>>>>>>        Local String  sVoid1
84828>>>>>>>>>>>        Local String  sVoid2
84828>>>>>>>>>>>        Local Integer iRetval
84828>>>>>>>>>>>
84828>>>>>>>>>>>        Get psDriverID To sDriverID
84829>>>>>>>>>>>
84829>>>>>>>>>>>        Move 0 To iRetval
84830>>>>>>>>>>>        // Ignore error 20491 DFBTRERR_INVALID_DRIVER_FUNCTION_CALL.
84830>>>>>>>>>>>        // This error would otherwise be raised when we have an older
84830>>>>>>>>>>>        // DFBTRDRV version that has no DFBTRFN_CKUSESURI function
84830>>>>>>>>>>>        Send Ignore_error To Error_object_Id 20491
84831>>>>>>>>>>>        Call_Driver 0 sDRiverID Function DFBTRFN_CKUSESURI Callback 0 Passing sVoid1 sVoid2 0 Result iRetval
84836>>>>>>>>>>>        Send Trap_Error To Error_object_Id 20491
84837>>>>>>>>>>>
84837>>>>>>>>>>>        Function_Return iRetval
84838>>>>>>>>>>>    End_Function // CKUsesUri
84839>>>>>>>>>>>
84839>>>>>>>>>>>
84839>>>>>>>>>>>
84839>>>>>>>>>>>    //***
84839>>>>>>>>>>>    //*** Function: ExtractPartFromRevsion
84839>>>>>>>>>>>    //*** Purpose : Extarct the Nth part of a a.b.c.d revsion string.
84839>>>>>>>>>>>    //***
84839>>>>>>>>>>>    //*** Returns : The part version number or -1 if there is no such part number.
84839>>>>>>>>>>>    //***
84839>>>>>>>>>>>
84839>>>>>>>>>>>    Function ExtractPartFromRevision Integer iPartNum String sRevision Returns Integer
84841>>>>>>>>>>>        Local Integer iPartRev
84841>>>>>>>>>>>        Local Integer iCurrentPart
84841>>>>>>>>>>>        Local Integer iSeparatorPos
84841>>>>>>>>>>>
84841>>>>>>>>>>>        If (iPartNum > 4) ;            Function_Return -1
84844>>>>>>>>>>>
84844>>>>>>>>>>>        Move 0 To iCurrentPart
84845>>>>>>>>>>>        Repeat
84845>>>>>>>>>>>>
84845>>>>>>>>>>>            Move (Pos(".", sRevision)) To iSeparatorPos
84846>>>>>>>>>>>            If (iSeparatorPos > 0) Begin
84848>>>>>>>>>>>                Move (Left(sRevision, iSeparatorPos - 1)) To iPartRev
84849>>>>>>>>>>>                Move (Right(sRevision, Length(sRevision) - iSeparatorPos)) To sRevision
84850>>>>>>>>>>>                Increment iCurrentPart
84851>>>>>>>>>>>            End
84851>>>>>>>>>>>>
84851>>>>>>>>>>>            Else If (sRevision <> "") Begin
84854>>>>>>>>>>>                Move sRevision To iPartRev
84855>>>>>>>>>>>                Move "" To sRevision
84856>>>>>>>>>>>                Increment iCurrentPart
84857>>>>>>>>>>>            End
84857>>>>>>>>>>>>
84857>>>>>>>>>>>            Else ;                Move -1 To iPartRev
84859>>>>>>>>>>>        Until (iCurrentPart >= iPartNum Or iPartRev = -1)
84861>>>>>>>>>>>
84861>>>>>>>>>>>        Function_Return iPartRev
84862>>>>>>>>>>>    End_Function // EcxtractPartFromRevision
