91039>>>            Get_Attribute DF_FIELD_PRECISION of hTable iOld to iPrecision
91042>>>        End
91042>>>>
91042>>>        Move False to Err
91043>>>    
91043>>>        Structure_Start hTable  
91044>>>            Delete_Field hTable iOld
91045>>>            Create_Field hTable At iNew
91046>>>            Set_Attribute DF_FIELD_NAME of hTable iNew to sColumn
91049>>>            Set_Attribute DF_FIELD_TYPE of hTable iNew to iType
91052>>>    
91052>>>            If (iType <> DF_DATE) Begin
91054>>>                Set_Attribute DF_FIELD_LENGTH of hTable iNew to iLength
91057>>>            End
91057>>>>
91057>>>    
91057>>>            If (iType = DF_BCD) Begin
91059>>>                Set_Attribute DF_FIELD_PRECISION of hTable iNew to iPrecision
91062>>>            End
91062>>>>
91062>>>    
91062>>>            Set_Attribute DF_FIELD_OLD_NUMBER of hTable iNew to iOld
91065>>>        Structure_End hTable
91067>>>        
91067>>>        Function_Return (Err = False)
91068>>>    End_Function
