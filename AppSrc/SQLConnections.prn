97794>>>>>            Get Value of oStudioMinorVersion_sf to iMinorVersion
97795>>>>>            Move (String(iMajorVersion) + "." + String(iMinorVersion)) to sStudioVersion
97796>>>>>            Get AddProgramToStudioToolsMenu sStudioVersion to iRetval
97797>>>>>            Case Begin
97797>>>>>                Case (iRetval = cx_RegKeyAlreadyExist)
97799>>>>>                    Move ("The program already exists in the" * sStudioVersion * "DataFlex Studios Tools menu.") to sText
97800>>>>>                    Break
97801>>>>>                Case (iRetval = cx_RegKeyCreated)
97804>>>>>                    Move ("Success. The tool was added to the" * sStudioVersion *  "DataFlex Studios Tools menu.") to sText
97805>>>>>                    Break
97806>>>>>                Case (iRetval = cx_RegkeyFailed)
97809>>>>>                    Move "Failed. Could not create the registry key for adding the program to the DataFlex Studio's Tools menu." to sText
97810>>>>>                    Break
97811>>>>>                Case (iRetval = cx_RegKeyVDFKeyDoesNotExist)
97814>>>>>                    Move ("Could not find the Studio registry key. Is DataFlex Studio version" * sStudioVersion * "really installed on this machine?") to sText
97815>>>>>                    Break
97816>>>>>                Case (iRetval = CX_InstalledOkVdfUnder16)
97819>>>>>                    Move ("The program was added to the" * sStudioVersion * "Studios Tools menu successfully, but because you installed for an earlier version of the Studio than 16.0 you need to compile the program under that same VDF version, else the Studio can't start the program properly. (Sorry, just a 'feature' of earlier versions of the Studio)") to sText
97820>>>>>                    Break
97821>>>>>            Case End
97821>>>>>
97821>>>>>            Send Info_Box sText
97822>>>>>        End_Procedure
