80629>>>        Send ComAddWindowClass "DFentry"                 "Edit"
80630>>>        Send ComAddWindowClass "DFtextbox"               "Edit"
80631>>>        Send ComAddWindowClass "DFRichEditCtrl"          "Edit"
80632>>>        Send ComAddWindowClass "DFcombobox"              "ComboBox"
80633>>>        Send ComAddWindowClass "DFformlist"              "Edit"
80634>>>        Send ComAddWindowClass "DFFormListHeader"        "SysHeader32"
80635>>>        Send ComAddWindowClass "DFbutton"                "Button"
80636>>>        Send ComAddWindowClass "HPromptBtn"              "Button"
80637>>>        Send ComAddWindowClass "Hspinbtn"                "msctls_updown32"
80638>>>        Send ComAddWindowClass "DFSysTabControl32"       "SysTabControl32"
80639>>>        Send ComAddWindowClass "DFMDIClient"             "MDIClient" 
80640>>>        Send ComAddWindowClass "DFedit"                  "edit"
80641>>>        Send ComAddWindowClass "DFlistedit"              "edit"
80642>>>        Send ComAddWindowClass "DFscrollbar"             "scrollbar"
80643>>>        Send ComAddWindowClass "DFgroup"                 "Button"
