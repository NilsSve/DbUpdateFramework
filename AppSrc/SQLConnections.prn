96049>>>>>>>        
96049>>>>>>>        Get pbFocusSubItems to bSubFocus
96050>>>>>>>        Get pbAutoSearch to bAutoSearch
96051>>>>>>>        Forward Send OnComKeyDown llKeyCode llShift
96053>>>>>>>        If (bAutoSearch and not(bSubFocus)) Begin
96055>>>>>>>            If ((llShift iand 6)=0) Begin // skip alt and ctrl
96057>>>>>>>                Get GetVKeyToAnsi llKeyCode llShift to iVal
96058>>>>>>>                Move (iVal<>0) to bChar
96059>>>>>>>            End
96059>>>>>>>>
96059>>>>>>>            If bChar Begin
96061>>>>>>>                // this can get called multiple times before a search dialog pops up
96061>>>>>>>                Send AddToSearchKeys llKeyCode llShift
96062>>>>>>>            End
96062>>>>>>>>
96062>>>>>>>        End
96062>>>>>>>>
