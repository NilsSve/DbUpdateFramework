85925>>>>>    // Returns the full path of the Application (no trailing "\")
85925>>>>>    Function ApplicationPath Returns String
85927>>>>>        String sApplicationFileName sPath
85927>>>>>        Integer iNumChars iRetval
85927>>>>>
85927>>>>>        Move (Repeat(Character(0), 1024))    to sApplicationFileName
85928>>>>>        Move (GetModuleFileName(0, AddressOf(sApplicationFileName), 1024)) to iNumChars
85929>>>>>        Move (CString(sApplicationFileName)) to sApplicationFileName
85930>>>>>        Move (PathRemoveFileSpec(AddressOf(sApplicationFileName))) to iRetval
85931>>>>>        Move (CString(sApplicationFileName)) to sPath
85932>>>>>
85932>>>>>        Function_Return sPath
85933>>>>>    End_Function
