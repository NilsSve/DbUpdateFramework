91270>>>    // To delete an index
91270>>>    Function ApiIndexRemove Handle hTable Integer iIndex Returns Boolean
91272>>>        Integer iTableNo iNumSegments
91272>>>        String sDriverID
91272>>>        Boolean bOK
91272>>>        
91272>>>        Get AutoConnectionIDLogin to bOK
91273>>>        Move False to Err
91274>>>        Move hTable to iTableNo
91275>>>        Open hTable Mode DF_EXCLUSIVE
91277>>>        Get_Attribute DF_FILE_DRIVER of hTable to sDriverID
91280>>>        
91280>>>        // Check to see if the index exists or not...
91280>>>        Get_Attribute DF_INDEX_NUMBER_SEGMENTS of hTable iIndex to iNumSegments
91283>>>        If (iNumSegments = 0) Begin
91285>>>            Function_Return False
91286>>>        End
91286>>>>
91286>>>        
91286>>>        Structure_Start hTable sDriverID
91287>>>            Send Ignore_Error of Error_Object_Id DFERR_BAD_PARAMETER
91288>>>            Delete_Index iTableNo iIndex
