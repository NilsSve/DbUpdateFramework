94230>>>    
94230>>>    // Returns the handle of the Mertech SQL handler.
94230>>>    // It also ensures that the correct Server & Database attributes are set both for 
94230>>>    // embedded SQL calls and "normal" database commands like e.g. "Open".
94230>>>    Function _MertechSQLManagerHandle Returns Handle
94232>>>        Handle hoSQLHandler
94232>>>        String sDriverID sServer sDatabase
94232>>>        
94232>>>        Move 0 to hoSQLHandler
94233>>>        Get psDriverID to sDriverID       
94234>>>        Get psServer   to sServer
94235>>>        Get psDatabase to sDatabase
94236>>>        // This command is used to set the server to be used when opening tables   
94236>>>        SET_CURRENT_SQL_SERVER            to sServer  
94255>>>>
94255>>>        // This command is used to specify which server to use for embedded SQL statements,
94255>>>        // but it has been constructed rather studidly as only constants and not variables
94255>>>        // are allowed...
94255>>>        If (sDriverID = MDSPgSQL) Begin
94257>>>            SET_CURRENT_SQL_SERVER_CONNECTION of MDSPgSQL to sServer
94273>>>        End
94273>>>>
94273>>>        If (sDriverID = MDSMySQL) Begin
94275>>>            SET_CURRENT_SQL_SERVER_CONNECTION of MDSMySQL to sServer
94291>>>        End
94291>>>>
94291>>>        If (sDriverID = ORAFLEX) Begin
94293>>>            SET_CURRENT_SQL_SERVER_CONNECTION of ORAFLEX to sServer
94309>>>        End
94309>>>>
94309>>>        If (sDriverID = SQLFLEX) Begin
94311>>>            SET_CURRENT_SQL_SERVER_CONNECTION of SQLFLEX to sServer
94327>>>        End
94327>>>>
94327>>>        
94327>>>        // This command is used to specify which database is used for SQL statements only.
94327>>>        SQL_USE_DATABASE sDatabase
94341>>>>
94341>>>        SET_DATABASE_NAME to sDatabase
94355>>>>
94355>>>        
94355>>>        Get phoSQLManagerMT to hoSQLHandler  
94356>>>        
94356>>>        Function_Return hoSQLHandler
94357>>>    End_Function
94358>>>    
94358>>>    // For Mertech drivers we cannot use Structure_Start/End. Instead we must use
94358>>>    // macro-commands <sigh!>
94358>>>    // Note: The function sets the Err flag.
94358>>>    Function _MertechApiTableConvertToSQL Handle hTable String sRootName String sDatabase String sDriverID String sBaseTableSpace String sIndexTableSpace Boolean bCopyData Returns Boolean
94360>>>        Move False to Err
94361>>>        
94361>>>            MERTECH_WARNING_MESSAGE Disabled
94370>>>>
94370>>>            SET_DATABASE_NAME to sDatabase 
94384>>>>
94384>>>            If (sBaseTableSpace <> "") Begin
94386>>>                SET_DEFAULT_TABLESPACE to sBaseTableSpace
94399>>>>
94399>>>            End
94399>>>>
94399>>>            If (sIndexTableSpace <> "") Begin
94401>>>                SET_DEFAULT_INDEX_TABLESPACE to sIndexTableSpace
94414>>>>
94414>>>            End
94414>>>>
94414>>>            CREATE_TABLE_FROM_DAT_FILE hTable DF_STRUCTEND_OPT_FORCE_NOT_NULL sRootName
94436>>>>
94436>>>            If (bCopyData = True) Begin
94438>>>                COPY_DATA sRootName to (sDriverID + ":" + sRootName) CALLBACK (Callback(Self))
94453>>>>
94453>>>            End
94453>>>>
94453>>>        
94453>>>        Function_Return (Err = False)
94454>>>    End_Function    
94455>>>        
94455>>>End_Class
