90869>>>    
90869>>>    Function ApiTableRename Integer hTable String sRootName String sDisplayName String sLogicalName Returns Boolean
90871>>>        String sPhysicalName sDataPath sDriverID
90871>>>        Boolean bOK bExists
90871>>>        Integer iRetval
90871>>>        
90871>>>        Move False to Err
90872>>>        Get psDataPathFirstPart to sDataPath
90873>>>        Get_Attribute DF_FILE_PHYSICAL_NAME of hTable to sPhysicalName
90876>>>        
90876>>>        Get_Attribute DF_FILE_DRIVER of hTable to sDriverID
90879>>>        Close hTable  
90880>>>        If (sDriverID = DATAFLEX_ID) Begin                    
90882>>>            Get vFilePathExists (sDataPath + sRootName + ".dat") to bExists
90883>>>            If (bExists = True) Begin
90885>>>                If (Uppercase(sPhysicalName) = Uppercase(sRootName)) Begin
90887>>>                    Function_Return False
90888>>>                End
90888>>>>
90888>>>
90888>>>                // ToDo: How do we handle this when the library has been imported into 
90888>>>                // the cDbUpdateVersion Class?
90888>>>                // Get YesNo_Box ("The table:\n" + (sDataPath + sPhysicalName) + "\nis to be renamed to:\n" + (sDataPath + sRootName) + "\nBut the destination already exists. Overwrite?") to iRetval
90888>>>                If (iRetval <> MBR_Yes) Begin
90890>>>                    Function_Return False
90891>>>                End                      
90891>>>>
90891>>>            End                                           
90891>>>>
90891>>>            Copy_db (sDataPath + sPhysicalName) to (sDataPath + sRootName) 
90894>>>        End
90894>>>>
90894>>>        
90894>>>        If (sDriverID <> DATAFLEX_ID) Begin
90896>>>            Move (sDriverID + ":" + sRootName) to sRootName
90897>>>        End
90897>>>>
90897>>>
90897>>>        Set_Attribute DF_FILE_ROOT_NAME     of hTable to sRootName
90900>>>        Set_Attribute DF_FILE_DISPLAY_NAME  of hTable to sDisplayName
90903>>>        Set_Attribute DF_FILE_LOGICAL_NAME  of hTable to sLogicalName
90906>>>        
90906>>>        // We need a short break here before attempting to delete the physical file or Windows
90906>>>        // might report "File in use..." and the deletion will fail.
90906>>>        Sleep 2
90907>>>        If (sDriverID = DATAFLEX_ID) Begin                    
90909>>>            Get vDeleteFile (sDataPath + sPhysicalName + ".*") to bOK
90910>>>        End
90910>>>>
90910>>>        
90910>>>        Function_Return (Err = False)
90911>>>    End_Function
