87579>>>    // First deletes the data cache file and then drops the passed SQL table. 
87579>>>    // Note: The table needs to exist in filelist.cfg, and it must be possible to open it,
87579>>>    //       else try using the SqlTableRemoveByTableName message.    
87579>>>    Function SqlTableRemove Integer hTable Returns Boolean
87581>>>        String sSQLString sPath sDropTable sTableName sDriverID 
87581>>>        Integer iRetval iDbType
87581>>>        Boolean bExists bMertechDriver bOK
87581>>>        
87581>>>        Get psDriverID to sDriverID   
87582>>>        Get IsMertechDriver sDriverID to bMertechDriver
87583>>>        Get UtilTableHandleToString hTable to sTableName
87584>>>        Get SqlUtilCheckIfTableNameExists sTableName sDriverID to bExists
87585>>>        If (bExists = False) Begin
87587>>>            Function_Return False
87588>>>        End                      
87588>>>>
87588>>>        
87588>>>        Get psDataPathFirstPart to sPath               
87589>>>        Get UtilDeleteCacheFile sTableName to iRetval
87590>>>            
87590>>>        Get piDbType to iDbType
87591>>>        Get _SqlProperTableName sTableName to sTableName
87592>>>        Get _SqlFindKeyWord CI_SQLDropTable iDbType to sDropTable
87593>>>        Move (sDropTable * String(sTableName)) to sSQLString
87594>>>        
87594>>>        Move False to Err               
87595>>>        Send SqlUtilExecuteQuery sSQLString sDriverID
87596>>>    
87596>>>        // We also need to remove the cache-file since the table has been changed
87596>>>        Get UtilDeleteCacheFile sTableName to bOK
87597>>>    
87597>>>        Function_Return (Err = False)
87598>>>    End_Function 
87599>>>    
87599>>>    // First deletes the data cache file and then drops the passed data table. 
87599>>>    Function SqlTableRemoveByTableName String sTableName Returns Boolean
87601>>>        String sSQLString sPath sDropTable sVal sSchema sDriverID 
87601>>>        Integer iRetval iDbType
87601>>>        Boolean bMertechDriver bOK
87601>>>        
87601>>>        Get psDriverID to sDriverID
87602>>>        Get IsMertechDriver sDriverID to bMertechDriver
87603>>>        Get psDataPathFirstPart to sPath               
87604>>>        Get UtilDeleteCacheFile sTableName to iRetval
87605>>>        
87605>>>        Get piDbType to iDbType
87606>>>        Get _SqlFindKeyWord CI_SQLDropTable iDbType to sDropTable 
87607>>>        Get psSchema to sSchema
87608>>>        If (sSchema = "") Begin
87610>>>            Get _SqlFindKeyWord CI_SQLDBO to sSchema 
87611>>>        End
87611>>>>
87611>>>        Move (Uppercase(sTableName)) to sVal
87612>>>        If (not(sVal contains (sSchema + "."))) Begin    
87614>>>            Move (Lowercase(sSchema) + "." + sTableName) to sTableName
87615>>>        End    
87615>>>>
87615>>>        Move (sDropTable * String(sTableName)) to sSQLString
87616>>>        
87616>>>        Move False to Err               
87617>>>        Send SqlUtilExecuteQuery sSQLString sDriverID
87618>>>    
87618>>>        // We also need to remove the cache-file since the table has been changed
87618>>>        Get UtilDeleteCacheFile sTableName to bOK
87619>>>    
87619>>>        Function_Return (Err = False)
87620>>>    End_Function 
87621>>>
87621>>>    // *** Sql View Messages ***
87621>>>
87621>>>    // First deletes the data cache file and then drops the passed Sql data view. 
87621>>>    Function SqlViewRemove String sDataView Returns Boolean
87623>>>        String sDriverID sSQLString sPath sDropViewKeyWord 
87623>>>        Integer iRetval                                
87623>>>        Boolean bMertechDriver bOK
87623>>>        
87623>>>        Get psDriverID to sDriverID
87624>>>        Get IsMertechDriver sDriverID to bMertechDriver
87625>>>        Get UtilDeleteCacheFile sDataView to iRetval
87626>>>        
87626>>>        Get _SqlFindKeyWord CI_SQLDropView to sDropViewKeyWord
87627>>>        Move (sDropViewKeyWord * String(sDataView)) to sSQLString
87628>>>        Set psSQLStatementString to sSQLString 
87629>>>        
87629>>>        // As we don't check if the view exist or not, it might happen
87629>>>        // that it doesn't and that would through an error, so guard for that eventuality (just ignore it).
87629>>>        Move False to Err 
87630>>>        Set Error_Report_Mode to DUF_ERROR_NO_REPORT
87631>>>        Send SqlUtilExecuteQuery sSQLString sDriverID
87632>>>        Set Error_Report_Mode to DUF_ERROR_REPORT
87633>>>        Move 0 to LastErr
87634>>>        
87634>>>        // We also need to remove the cache-file since the table has been changed
87634>>>        Get UtilDeleteCacheFile sDataView to bOK
87635>>>    
87635>>>        Function_Return (Err = False)
87636>>>    End_Function
