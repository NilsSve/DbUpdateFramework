90709>>>    // ToDo: Needs to be revised
90709>>>    Procedure ApiTableCreateFromDEF String sPath String sFileName String sTableName String sDisplayName Integer iFilelistSlot
90711>>>        Handle hTable 
90711>>>        String sDEFName sDataPath sDriverID
90711>>>        Boolean bExists
90711>>>        
90711>>>        // Do nothing if MSSQL Driver.
90711>>>//        Get IsMSSQLDriver to bExists
90711>>>//        If (bExists = True) Begin
90711>>>//            Procedure_Return
90711>>>//        End
90711>>>        
90711>>>        Get psDataPathFirstPart to sDataPath
90712>>>        Get vFilePathExists (sDataPath + sFileName + ".dat") to bExists
90713>>>        If (bExists = True) Begin      
90715>>>            // We also needs to check if it is an Alias file, in case the sFileName.dat exists, but it may
90715>>>            // still be missing from the filelist and needs to be added.
90715>>>            Get UtilTableNumberIsInUse iFilelistSlot to bExists
90716>>>            If (bExists = True) Begin
90718>>>                Procedure_Return
90719>>>            End 
90719>>>>
90719>>>            // Do _not_ use the DEF file if an alias, it will overwrite the base table data.
90719>>>            Else Begin
90720>>>                Set_Attribute DF_FILE_ROOT_NAME    of iFilelistSlot to sFileName
90723>>>                Set_Attribute DF_FILE_LOGICAL_NAME of iFilelistSlot to sTableName
90726>>>                Set_Attribute DF_FILE_DISPLAY_NAME of iFilelistSlot to sDisplayName
90729>>>                Procedure_Return
90730>>>            End
90730>>>>
90730>>>        End
90730>>>>
90730>>>    
90730>>>        Move (sPath + sFileName + ".def") to sDEFName
90731>>>        Move 0 to hTable
90732>>>        Move False to Err
90733>>>    
90733>>>        Structure_Start hTable DATAFLEX_ID
90734>>>            Load_Def sDEFName Onto hTable
90735>>>            Set_Attribute DF_FILE_PHYSICAL_NAME of hTable to sFileName
90738>>>        Structure_End hTable DF_STRUCTEND_OPT_NONE
90740>>>    
90740>>>        Move iFilelistSlot to hTable
90741>>>        Set_Attribute DF_FILE_ROOT_NAME    of hTable to sFileName
90744>>>        Set_Attribute DF_FILE_LOGICAL_NAME of hTable to sTableName
90747>>>        Set_Attribute DF_FILE_DISPLAY_NAME of hTable to sDisplayName
90750>>>    
90750>>>    End_Procedure      
