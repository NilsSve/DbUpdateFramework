96031>>>>>>>    Procedure OnMoveValueOutByValue
96033>>>>>>>        String sValue
96033>>>>>>>        Handle hoInvokingObject hoCol  hoDataSource
96033>>>>>>>        Integer iRow iCol
96033>>>>>>>        Integer[] SelRowsIndexes
96034>>>>>>>
96034>>>>>>>        Get phoInvokingObject to hoInvokingObject
96035>>>>>>>        Get pSelectedRows to SelRowsIndexes
96036>>>>>>>        If (SizeOfArray(SelRowsIndexes)>0) Begin
96038>>>>>>>            Get piUpdateColumn to iCol
96039>>>>>>>            Get ColumnObject iCol to hoCol
96040>>>>>>>            Get RowValue of hoCol SelRowsIndexes[0] to sValue
96041>>>>>>>            Set Value of hoInvokingObject to sValue
96042>>>>>>>            Set Item_Changed_State of hoInvokingObject to True
96043>>>>>>>        End
96043>>>>>>>>
96043>>>>>>>    End_Procedure
