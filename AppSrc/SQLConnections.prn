89649>>>    Procedure _SqlColumnInfo Handle hoStmt
89651>>>        Integer i iCols iItem
89651>>>        tSqlColumnNew[] aQueryColumns
89651>>>        tSqlColumnNew[] aQueryColumns
89652>>>
89652>>>        Get SqlStmtAttribute of hoStmt SqlSTMTATTRIB_COLUMNCOUNT to iCols
89653>>>        For i from 1 to iCols
89659>>>>
89659>>>            Move (SizeOfArray(aQueryColumns)) to iItem
89660>>>            Get SqlColAttribute of hoStmt i SqlCOLATTRIB_BASECOLUMNNAME to aQueryColumns[iItem].sBaseColumnName
89661>>>            Get SqlColAttribute of hoStmt i SqlCOLATTRIB_BASETABLENAME  to aQueryColumns[iItem].sBaseTableName
89662>>>            Get SqlColAttribute of hoStmt i SqlCOLATTRIB_LABEL          to aQueryColumns[iItem].sLabel
89663>>>            Get SqlColAttribute of hoStmt i SqlCOLATTRIB_SQLTYPE        to aQueryColumns[iItem].iSqlType
89664>>>            Get SqlColAttribute of hoStmt i SqlCOLATTRIB_DFTYPE         to aQueryColumns[iItem].iDFType
89665>>>            Get SqlColAttribute of hoStmt i SqlCOLATTRIB_SIZE           to aQueryColumns[iItem].iSize
89666>>>            Get SqlColAttribute of hoStmt i SqlCOLATTRIB_PRECISION      to aQueryColumns[iItem].iPrecision
89667>>>        Loop
89668>>>>
89668>>>        Set piColumns to iCols
89669>>>        Set paQueryColumns to aQueryColumns
89670>>>    End_Procedure
