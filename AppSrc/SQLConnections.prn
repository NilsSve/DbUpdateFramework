79844>>>
79844>>>// Does the directory exist? - No = 0, Yes = 1
79844>>>// This also works with UNC path encoding and wildcards
79844>>>Function vFolderExists Global String sFolderName Returns Integer
79846>>>  String  sFolder sTmp
79846>>>  Integer bFolderExists iCh
79846>>>
79846>>>  // 2013-09-29 NGS Check for empty folder name and convert to ANSI
79846>>>  Move (ToANSI(Trim(sFolderName))) to sFolderName
79847>>>  If (sFolderName = "") Begin
79849>>>    Function_Return False
79850>>>  End
79850>>>>
79850>>>
79850>>>  Move dfTrue To bFolderExists
79851>>>  Move "dir:" To sFolder
79852>>>  Append sFolder sFolderName
79853>>>  Get Seq_New_Channel To iCh  // get free channel for input
79854>>>  Direct_Input Channel iCh sFolder
79856>>>    Repeat
79856>>>>
79856>>>      Readln Channel iCh sTmp
79858>>>      If (Trim(sTmp)="") Move dfFalse To bFolderExists
79861>>>      Else Begin
79862>>>        Move dfTrue To bFolderExists
79863>>>        Indicate seqeof True  // end loop
79864>>>        End
79864>>>>
79864>>>    Until (seqeof)
79866>>>  Close_Input Channel iCh
79868>>>  Send Seq_Release_Channel iCh
79869>>>  Function_Return bFolderExists
79870>>>End_Function  // vFolderExists
79871>>>
79871>>>
79871>>>// returns folder name if a folder was selected, otherwise returns ""
79871>>>Function vSHBrowseForFolder Global String sDialogTitle Returns String
79873>>>  String sFolder sBrowseInfo sTitle
79873>>>  Pointer lpItemIdList lpsFolder lpsBrowseInfo lpsTitle
79873>>>  Integer iFolderSelected iRetval
79873>>>
79873>>>  // fill string variable with null characters
79873>>>  ZeroType vtBrowseInfo To sBrowseInfo
79874>>>
79874>>>  If (sDialogTitle<>"") Begin
79876>>>    Move sDialogTitle To sTitle
79877>>>    // Torben Lund suggested converting the string with toansi. Doing it like that
79877>>>    // disables showing some commonly used ascii characters like ascii 137 (‰)
79877>>>    // These chars are correctly shown if no toansi is used.
79877>>>    // I can imagine that he wanted to path to be ANSI, but as long as it isa just
79877>>>    // selected it will always be valid.
79877>>>    GetAddress Of sTitle To lpsTitle
79878>>>    Put lpsTitle To sBrowseInfo At vtBrowseInfo.lpszTitle
79879>>>  End
79879>>>>
79879>>>
79879>>>  Put vBIF_RETURNONLYFSDIRS To sBrowseInfo At vtBrowseInfo.ulFlags
79880>>>
79880>>>  // Torben Lund added line below. Move handle of focus object to structure before
79880>>>  // calling function. Otherwise, the folderdialog will be started as a seperate task.
79880>>>  Put (window_handle(focus(desktop))) To sBrowseInfo At vtBrowseInfo.hWndOwner
79881>>>
79881>>>  GetAddress Of sBrowseInfo To lpsBrowseInfo
79882>>>
79882>>>  // null 128 chars into var (make space)
79882>>>  Move (Repeat(Character(0), vMAX_PATH)) To sFolder
79883>>>  GetAddress Of sFolder To lpsFolder
79884>>>
79884>>>  // select folder
79884>>>  Move (vWin32_SHBrowseForFolder(lpsBrowseInfo)) To lpItemIdList
79885>>>  // get selected folder name
79885>>>  Move (vWin32_SHGetPathFromIDList(lpItemIdList, lpsFolder)) To iFolderSelected
79886>>>
79886>>>  // release memory resources that are used by the ItemIdList
79886>>>  Move (vWin32_CoTaskMemFree(lpItemIdList)) To iRetval
79887>>>
79887>>>  If (iFolderSelected<>0) Function_Return (CString(sFolder))
79890>>>  Else Function_Return ""
79892>>>End_Function // vSHBrowseForFolder
79893>>>
79893>>>
79893>>>// returns 0 if the folder is created.
79893>>>//         1 if the API-call returned an error.
79893>>>Function vCreateDirectory Global String sNewFolder Returns Integer
79895>>>  String  sFolder sSA
79895>>>  Pointer lpsFolder lpsSecurity_Attributes lpDescriptor
79895>>>  Integer iRetval bFolderCreated bInheritHandle
79895>>>
79895>>>  Move (False) To bFolderCreated
79896>>>  // fill string variable with null characters
79896>>>  ZeroType vtSecurity_attributes To sSA
79897>>>
79897>>>  // null MAX_PATH chars into var (make space)
79897>>>  Move (Repeat(Character(0), vMAX_PATH)) To sFolder
79898>>>
79898>>>  If (sNewFolder <> "") Begin
79900>>>
79900>>>    Move dfTrue To  bInheritHandle
79901>>>    // Setting this to NULL is already done by the zerotype command
79901>>>    // Move NULL   To  lpDescriptor
79901>>>    Put (length(sSA))   To sSA At vtSecurity_attributes.nLength
79902>>>    //Put lpDescriptor To sSA at vtSecurity_attributes.lpDescriptor
79902>>>    Put bInheritHandle To sSA At vtSecurity_attributes.bInheritHandle
79903>>>
79903>>>    GetAddress Of sSA To lpsSecurity_Attributes
79904>>>
79904>>>    //
79904>>>    Move sNewFolder To sFolder
79905>>>    GetAddress Of sFolder To lpsFolder
79906>>>    Move (vWin32_CreateDirectory(lpsFolder, lpsSecurity_Attributes)) To bFolderCreated
79907>>>  End
79907>>>>
79907>>>
79907>>>  Ifnot bFolderCreated Move 1 To iRetVal
79910>>>  Function_Return iRetVal
79911>>>End_Function // vCreateDirectory
79912>>>
79912>>>
79912>>>// **WvA: 03-02-2002 Function created.
79912>>>// With this function one can remove a directory.
79912>>>// returns 0 if the folder is removed.
79912>>>//         1 if the API-call returned an error (Use GetLastError API to get the details)
79912>>>//         2 if the folder did not exist
79912>>>//         3 if the sFolder parameter passed is equal to ""
79912>>>Function vRemoveDirectory Global String sFolder Returns Integer
79914>>>  String  sPath
79914>>>  Pointer lpsPath
79914>>>  Integer iRetval bRemoved bExists
79914>>>
79914>>>  Move (False) To bRemoved
79915>>>  Move 0 To iRetVal
79916>>>  Move (Trim(sFolder)) To sFolder
79917>>>  If (sFolder="") Begin
79919>>>    Move 3 To iRetVal
79920>>>  End
79920>>>>
79920>>>  If (vFolderExists(sFolder)=False) Begin
79922>>>    Move 2 To iRetVal
79923>>>  End
79923>>>>
79923>>>  If (iRetVal=0) Begin
79925>>>    // null MAX_PATH chars into var (make space)
79925>>>    Move (Repeat(Character(0), vMAX_PATH)) To sPath
79926>>>    //
79926>>>    Move (Insert(sFolder,sPath,1)) To sPath
79927>>>    GetAddress Of sPath To lpsPath
79928>>>    Move (vWin32_RemoveDirectory(lpsPath)) To bRemoved
79929>>>  End
79929>>>>
79929>>>
79929>>>  If ((iRetVal=0) And (bRemoved=False)) Begin
79931>>>    Move 1 To iRetVal
79932>>>  End
79932>>>>
79932>>>  Function_Return iRetVal
79933>>>End_Function // vRemoveDirectory
79934>>>
79934>>>
79934>>>
79934>>>// This function informs the user that he entered a yet unknown folder and
79934>>>// asks if he/she wants to create the folder (Yes/No)
79934>>>// Choice: "Yes" - this creates the folder
79934>>>//                 if successful, the function returns false
79934>>>//                 else it will be true.
79934>>>// Choice: "No"  - returns TRUE, This allows the programmer to take action
79934>>>//                 For example: to stop a save
79934>>>// Precondition: A foldername must be entered. We do not check for empty paths
79934>>>// This function returns a non-zero value if the folder isn't created afterwards
79934>>>Function vVerifyNewFolder Global String sFolderName Returns Integer
79936>>>  Integer bIsNotValid
79936>>>  Integer iUsers_Choice
79936>>>  String  sMessage
79936>>>
79936>>>  If (vFolderExists(sFolderName) Eq 0) Begin
79938>>>    Move "The folder '" To sMessage
79939>>>    Append sMessage sFolderName
79940>>>    Append sMessage "' does not yet exist,\n"
79941>>>    Append sMessage "Do you want to create it now?"
79942>>>    Get YesNo_Box sMessage "Confirm" MB_DefButton1 To iUsers_Choice
79943>>>    Case Begin
79943>>>      Case (iUsers_Choice = MBR_Yes)
79945>>>        Move (vCreateDirectory(sFolderName)) To bIsNotValid
79946>>>        If bIsNotValid Begin
79948>>>          Move "An error occurred while trying to create folder '" To sMessage
79949>>>          Append sMessage sFolderName "'.\n\n"
79951>>>          Send Info_Box sMessage "Info"
79952>>>          End
79952>>>>
79952>>>        Case Break
79953>>>      Case (iUsers_Choice = MBR_No)
79956>>>        Move dfTrue To bIsNotValid // Cancel the save
79957>>>        Case Break
79958>>>    Case End
79958>>>  End
79958>>>>
79958>>>  Function_Return bIsNotValid
79959>>>End_Function // vVerifyNewFolder
79960>>>
79960>>>
79960>>>// This will perform an operation on a file (e.g. open) with the application
79960>>>// registered in the Windows Registry to open that type of file (via its extension)
79960>>>// sOperation would be "OPEN" (it could also be "PRINT" etc).
79960>>>Procedure vShellExecute global String sOperation String sDocument String sParameters String sPath
79962>>>  Handle  hInstance hWnd
79962>>>  Pointer lpsOperation
79962>>>  Pointer lpsDocument
79962>>>  Pointer lpsParameters
79962>>>  Pointer lpsPath
79962>>>  // remove any leading/trailing spaces in the string
79962>>>  Move (Trim(sDocument)) To sDocument
79963>>>  Move (Trim(sPath))     To sPath
79964>>>  // Make the strings readable for windows API, by converting them to null-terminated
79964>>>  Append sOperation   (Character(0))
79965>>>  Append sDocument    (Character(0))
79966>>>  Append sParameters  (Character(0))
79967>>>  Append sPath        (Character(0))
79968>>>  // Connect the corresponding pointers to the strings
79968>>>  GetAddress Of sOperation  To lpsOperation
79969>>>  GetAddress Of sDocument   To lpsDocument
79970>>>  GetAddress Of sParameters To lpsParameters
79971>>>  GetAddress Of sPath       To lpsPath
79972>>>
79972>>>  Get Window_Handle To hWnd
79973>>>  Move (vWin32_ShellExecute (hWnd, lpsOperation, lpsDocument, lpsParameters, lpsPath, 1)) To hInstance
79974>>>  If (hInstance <= 32) Begin
79976>>>    Send vDDE_Error_Handler hInstance
79977>>>  End
79977>>>>
79977>>>End_Procedure // vShellExecute
79978>>>
