91916>>>    // Returns True if the passed hTable (filelist slot number) is an Alias table.
91916>>>    // An Alias file/table is a filelist number that share the same Physical filename
91916>>>    // but which Logical name is different.
91916>>>    // Note: If the table cannot be opened; the table is not considered to be an Alias.
91916>>>    Function UtilTableIsAlias Handle hTable Returns Boolean
91918>>>        String sPhysicalName sPhysicalNameCompare     
91918>>>        Boolean bOpened bOK
91918>>>        
91918>>>        Open hTable
91920>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpened
91923>>>        If (bOpened = False) Begin
91925>>>            Function_Return False
91926>>>        End                      
91926>>>>
91926>>>        
91926>>>        Get_Attribute DF_FILE_PHYSICAL_NAME of hTable to sPhysicalName 
91929>>>        Get _TableNameOnly sPhysicalName to sPhysicalName
91930>>>        Close hTable
91931>>>        
91931>>>        Move 0 to hTable
91932>>>        Repeat
91932>>>>
91932>>>            Get_Attribute DF_FILE_NEXT_USED of hTable to hTable
91935>>>            If (hTable > 0) Begin         
91937>>>                Open hTable
91939>>>                Get_Attribute DF_FILE_OPENED of hTable to bOpened
91942>>>                If (bOpened = True) Begin
91944>>>                    Get_Attribute DF_FILE_PHYSICAL_NAME of hTable to sPhysicalNameCompare 
91947>>>                    Close hTable
91948>>>                    Get _TableNameOnly sPhysicalNameCompare to sPhysicalNameCompare
91949>>>                    If (Uppercase(sPhysicalName) = Uppercase(sPhysicalNameCompare)) Begin
91951>>>                        Function_Return True
91952>>>                    End
91952>>>>
91952>>>                End
91952>>>>
91952>>>            End
91952>>>>
91952>>>        Until (hTable = 0)
91954>>>        
91954>>>        Function_Return False
91955>>>    End_Function
91956>>>    
91956>>>    // To Open a table with any driver.
91956>>>    // Note: If the driver is <> DATAFLEX_ID  - login credentials are used; it is then assumed 
91956>>>    //       that the proper login properties has been setup properly with the cSQLConnections object.
91956>>>    //
91956>>>    // If the open command fails the Err flag will be reset to false, at the end of the function!
91956>>>    // The found flag is still used to indicate if the open was successful or not. The function
91956>>>    // returns a True if successful (table could be opened).
91956>>>    //
91956>>>    // Using the "Open As" syntax with drivers means that we don't need to rely on .int file settings.
91956>>>    // This is good because with DFConnectionID's those credentials doesn't need to be available in
91956>>>    // the .int file (and probably aren't). As long as the login properties of this object have been
91956>>>    // set properly we can open the table.
91956>>>    //
91956>>>    // DAW Driver Syntax:
91956>>>    //  <CKId>:<Schema>#<Table>@<ConnectString>|<Filename>.int
91956>>>    //  Now the @<ConnectString> can be followed by a pipe character '|' followed by the name of the INT file.
91956>>>    //  Doing so, the driver will apply the information from the .INT file to the passed direct Open String.
91956>>>    //  Note that when an INT file has been passed, it will skip the keyword DRIVER_NAME, SERVER_NAME,
91956>>>    //  DATABASE_NAME and SCHEMA_NAME from the INT file because those are supposed to be supplied in the String already. 
91956>>>    //  Open mode; iMode = DF_SHARE or DF_EXCLUSIVE.
91956>>>    //
91956>>>    // DAW Driver Sample:
91956>>>    //   Open "MSSQLDRV:dbo#MyFile@SERVER=(local)\SQLEXPRESS;Trusted_Connection=yes;DATABASE=OrderEntry|options|intfile=MyFile.int"
91956>>>    //
91956>>>    // Mertech Driver Samples:
91956>>>    //   SQLFlex:   Open "sql_drv:\\<serverName>\<database>*<owner>*<tableName>=<numberFieds>" as table 
91956>>>    //   MySQLFlex: Open "mdsmysql:\\<serverName>\<database>*<tableName>=<numberFieds>" as table 
91956>>>    //   PgFlex:    Open "mdspgsql:\\<serverName>\<database>*<schema>*<tableName>=<numberFieds>" as table 
91956>>>    //   ORAFlex:   Open "ora_drv:\\<serverName>\<owner>*<tableName>=<numberFieds>" as table 
91956>>>    Function UtilTableOpen Integer hTable String sTableName Integer iMode Returns Boolean
91958>>>        String sDriverID sConnection sSchema sExt sTableNameShort sTableNameOrg
91958>>>        Boolean bOpen bMertechDriver
91958>>>        Integer iRetval              
91958>>>        tSQLConnection SQLConnection
91958>>>        tSQLConnection SQLConnection
91958>>>
91958>>>        Move sTableName to sTableNameOrg
91959>>>        If (hTable > 0 and Trim(sTableName) = "") Begin
91961>>>            Send Ignore_Error of Error_Object_Id 20529
91962>>>            Send Ignore_Error of Error_Object_Id DFERR_CANT_OPEN_DATA_FILE
91963>>>            Send Ignore_Error of Error_Object_Id CLIERR_CONNECTIONIDNOTFOUND
91964>>>            Open hTable
91966>>>            Send Trap_Error of Error_Object_Id 20529
91967>>>            Send Trap_Error of Error_Object_Id DFERR_CANT_OPEN_DATA_FILE
91968>>>            Send Trap_Error of Error_Object_Id CLIERR_CONNECTIONIDNOTFOUND
91969>>>            Function_Return (Found = True)
91970>>>        End
91970>>>>
91970>>>        
91970>>>        Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
91971>>>        Move SQLConnection.sDriverID to sDriverID
91972>>>        Get IsMertechDriver sDriverID to bMertechDriver
91973>>>        Move SQLConnection.sConnectionString to sConnection
91974>>>        Move SQLConnection.sSchema to sSchema
91975>>>        If (sSchema = "") Begin 
91977>>>            Get _SqlFindKeyWord CI_SQLDBO to sSchema 
91978>>>        End
91978>>>>
91978>>>
91978>>>        // We need to remove the ".int" part of the table name because
91978>>>        // the table name after the "#" in the connection syntax below wants the
91978>>>        // "bare" table name without any extension.
91978>>>        If (sDriverID <> DATAFLEX_ID) Begin
91980>>>            If (Lowercase(sTableName) contains ".int") Begin
91982>>>                Get ParseFileExtension sTableName to sExt
91983>>>                Move (Replace(("." + sExt), sTableName, "")) to sTableNameShort
91984>>>            End                                                                
91984>>>>
91984>>>            Else Begin
91985>>>                Move sTableName to sTableNameShort  
91986>>>                Move (Append(sTableName, ".int")) to sTableName
91987>>>            End   
91987>>>>
91987>>>            If (bMertechDriver = False) Begin
91989>>>                Move (sDriverID + ":" + sSchema + "#" + sTableNameShort + "@" + sConnection + "|options|intfile=" + sTableName) to sConnection
91990>>>                Move sConnection to sTableName
91991>>>            End
91991>>>>
91991>>>        End
91991>>>>
91991>>>
91991>>>        Send Ignore_Error of Error_Object_Id CLIERR_LOGIN_UNSUCCESSFUL
91992>>>        Send Ignore_Error of Error_Info_Object DFERR_FILE_ACCESS_VIOLATION 
91993>>>        If (hTable = 0) Begin
91995>>>            Get NextFreeFilelistSlot to hTable
91996>>>        End
91996>>>>
91996>>>
91996>>>        Case Begin
91996>>>            Case (sDriverID = MSSQLDRV_ID)
91998>>>                // If not df_exclusive mode, we use the "Open As" syntax.
91998>>>                If (iMode <> DF_EXCLUSIVE) Begin
92000>>>                    Open sTableName as hTable
92002>>>                End
92002>>>>
92002>>>                Else Begin
92003>>>                    Open hTable mode DF_Exclusive
92005>>>                End
92005>>>>
92005>>>                Case Break
92006>>>
92006>>>            Case (sDriverID = DB2_DRV_ID)
92009>>>                // If not df_exclusive mode, we use the "Open As" syntax.
92009>>>                If (iMode <> DF_EXCLUSIVE) Begin
92011>>>                    Open sTableName as hTable
92013>>>                End
92013>>>>
92013>>>                Else Begin
92014>>>                    Open hTable mode DF_Exclusive
92016>>>                End
92016>>>>
92016>>>                Case Break
92017>>>
92017>>>            Case (sDriverID = ODBC_DRV_ID)
92020>>>                // If not df_exclusive mode, we use the "Open As" syntax.
92020>>>                If (iMode <> DF_EXCLUSIVE) Begin
92022>>>                    Open sTableName as hTable
92024>>>                End
92024>>>>
92024>>>                Else Begin
92025>>>                    Open hTable mode DF_Exclusive
92027>>>                End
92027>>>>
92027>>>                Case Break 
92028>>>                
92028>>>            Case (sDriverID = SQLFLEX)                                                                               
92031>>>                // ToDo: What is the <owner>? Same as Schema?
92031>>>                // SQLFlex:   Open "sql_drv:\\<serverName>\<database>*<owner>*<tableName>=<numberFieds>" as table 
92031>>>                Move (SQLFLEX + ":\\" + SQLConnection.sServer + "\" + SQLConnection.sDatabase + SQLConnection.sSchema + "*" + sTableNameOrg) to sTableName
92032>>>                // If not df_exclusive mode, we use the "Open As" syntax.
92032>>>                If (iMode <> DF_EXCLUSIVE) Begin
92034>>>                    Open sTableName as hTable
92036>>>                End
92036>>>>
92036>>>                Else Begin
92037>>>                    Open hTable mode DF_Exclusive
92039>>>                End
92039>>>>
92039>>>                Case Break
92040>>>
92040>>>            Case (sDriverID = MDSMySQL)
92043>>>                // MySQLFlex: Open "mdsmysql:\\<serverName>\<database>*<tableName>=<numberFieds>" as table 
92043>>>                Move (MDSMySQL + ":\\" + SQLConnection.sServer + "\" + SQLConnection.sDatabase + "*" + sTableNameOrg) to sTableName
92044>>>                // If not df_exclusive mode, we use the "Open As" syntax.
92044>>>                If (iMode <> DF_EXCLUSIVE) Begin
92046>>>                    Open sTableName as hTable
92048>>>                End
92048>>>>
92048>>>                Else Begin
92049>>>                    Open hTable mode DF_Exclusive
92051>>>                End
92051>>>>
92051>>>                Case Break
92052>>>
92052>>>            Case (sDriverID = MDSPgSQL)
92055>>>                // PgFlex: Open "mdspgsql:\\<serverName>\<database>*<schema>*<tableName>=<numberFieds>" as table 
92055>>>                Move (MDSPgSQL + ":\\" + SQLConnection.sServer + "\" + SQLConnection.sDatabase + "*" + SQLConnection.sSchema + "*" + sTableNameOrg) to sTableName
92056>>>                // If not df_exclusive mode, we use the "Open As" syntax.
92056>>>                If (iMode <> DF_EXCLUSIVE) Begin
92058>>>                    Open sTableName as hTable
92060>>>                End
92060>>>>
92060>>>                Else Begin
92061>>>                    Open hTable mode DF_Exclusive
92063>>>                End
92063>>>>
92063>>>                Case Break
92064>>>
92064>>>            Case (sDriverID = ORAFLEX)
92067>>>                // ToDo: What is the <owner>? Same as Schema?
92067>>>                // ORAFlex: Open "ora_drv:\\<serverName>\<owner>*<tableName>=<numberFieds>" as table 
92067>>>                Move (ORAFLEX + ":\\" + SQLConnection.sServer + "\" + SQLConnection.sSchema + "*" + sTableName) to sTableName
92068>>>                // If not df_exclusive mode, we use the "Open As" syntax.
92068>>>                If (iMode <> DF_EXCLUSIVE) Begin
92070>>>                    Open sTableName as hTable
92072>>>                End
92072>>>>
92072>>>                Else Begin
92073>>>                    Open hTable mode DF_Exclusive
92075>>>                End
92075>>>>
92075>>>                Case Break
92076>>>
92076>>>            Case (sDriverID = DATAFLEX_ID)
92079>>>                If (sTableName <> "" and iMode <> DF_EXCLUSIVE) Begin
92081>>>                    Open sTableName as hTable
92083>>>                End
92083>>>>
92083>>>                Else If (iMode = DF_EXCLUSIVE) Begin
92086>>>                    Open hTable mode DF_Exclusive
92088>>>                End
92088>>>>
92088>>>                Else Begin
92089>>>                    Open hTable
92091>>>                End
92091>>>>
92091>>>                Case Break
92092>>>                
92092>>>            // ToDo: Logic needs to be expanded for Mertech drivers!
92092>>>
92092>>>            Case Else
92092>>>                Error DFERR_PROGRAM ("Invalid driver:" * sDriverID)
92093>>>>
92093>>>        Case End
92093>>>
92093>>>        Send Trap_Error of Error_Object_Id CLIERR_LOGIN_UNSUCCESSFUL 
92094>>>        Send Trap_Error of Error_Info_Object DFERR_FILE_ACCESS_VIOLATION
92095>>>        If (LastErr = CLIERR_LOGIN_UNSUCCESSFUL) Begin
92097>>>            Move False to Found
92098>>>        End
92098>>>>
92098>>>        // If open failed, the Err is set to true,
92098>>>        // but we don't want that because it could end our loop.
92098>>>        Move False to Err
92099>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpen
92102>>>
92102>>>        Function_Return bOpen
92103>>>    End_Function
92104>>>    
92104>>>    // Pass a table handle
92104>>>    // Returns True if the table exists in filelist.cfg.
92104>>>    Function UtilTableNumberIsInUse Handle hCheckTable Returns Boolean
92106>>>        Handle hTable
92106>>>        Boolean bFound
92106>>>        
92106>>>        Move False to bFound
92107>>>        Move 0 to hTable              
92108>>>        Repeat
92108>>>>
92108>>>            Get_Attribute DF_FILE_NEXT_USED of hTable to hTable
92111>>>            If (hTable > 0) Begin
92113>>>                If (hTable = hCheckTable) Begin
92115>>>                    Move True to bFound
92116>>>                End
92116>>>>
92116>>>            End
92116>>>>
92116>>>            If (bFound = True) Break
92119>>>        Until (hTable = 0)
92121>>>    
92121>>>        Function_Return (bFound = True)
92122>>>    End_Function
92123>>>    
92123>>>    Function UtilEnumerateOverlapFields Integer hTable Integer iField Returns String[]
92125>>>        String  sRetval sColumnName
92125>>>        String[] sOverlapFieldsArray
92126>>>        Integer iType iColumn iColumns 
92126>>>        Boolean bOpen bOverlap
92126>>>        
92126>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpen
92129>>>        If (bOpen = False) Begin
92131>>>            Open hTable
92133>>>        End
92133>>>>
92133>>>        
92133>>>        Move "" to sRetval
92134>>>        
92134>>>        Get_Attribute DF_FILE_NUMBER_FIELDS of hTable to iColumns
92137>>>        
92137>>>        for iColumn from 0 to iColumns
92143>>>>
92143>>>            Get_Attribute DF_FIELD_TYPE of hTable iColumn to iType
92146>>>            If (iField <> iColumn and iType <> DF_OVERLAP) Begin
92148>>>                Get_Attribute DF_FIELD_OVERLAP of hTable iField iColumn to bOverlap
92151>>>                If (bOverlap) Begin
92153>>>                    If (sRetval <> "") Begin
92155>>>                        Append sRetval ","
92156>>>                    End
92156>>>>
92156>>>                    Append sRetval iColumn
92157>>>                End
92157>>>>
92157>>>            End
92157>>>>
92157>>>        Loop
92158>>>>
92158>>>        
92158>>>        If (bOpen = False) Begin
92160>>>            Close hTable
92161>>>        End    
92161>>>>
92161>>>        
92161>>>        Move (StrSplitToArray(sRetval, ",")) to sOverlapFieldsArray
92162>>>        
92162>>>        Function_Return sOverlapFieldsArray
92163>>>    End_Function
92164>>>    
92164>>>    // Returns a struct array with all data types for the passed driver & dbtype.
92164>>>    Function UtilEnumerateColumnTypes String sDriverID Integer iDbType Returns tColumnType[]
92166>>>        tColumnType[] ColumnType               
92166>>>        tColumnType[] ColumnType               
92167>>>            
92167>>>        Case Begin
92167>>>            Case (iDbType = EN_dbTypeDataFlex)  
92169>>>                Get _UtilEnumerateDataFlexTypes to ColumnType
92170>>>                Case Break
92171>>>                
92171>>>            Case (iDbType = EN_DbTypeDB2)
92174>>>                Get _UtilEnumerateDB2Types to ColumnType
92175>>>                Case Break
92176>>>                
92176>>>            Case (iDbType = EN_DbTypeMSSQL)
92179>>>                Get _UtilEnumerateMSSQLTypes sDriverID to ColumnType
92180>>>                Case Break
92181>>>            
92181>>>            Case (sDriverID = MDSMySQL)            
92184>>>                Get _UtilEnumerateMySQLTypes to ColumnType
92185>>>                Case Break
92186>>>            
92186>>>            Case (sDriverID = ORAFLEX)
92189>>>                Get _UtilEnumerateOracleTypes to ColumnType
92190>>>                Case Break
92191>>>
92191>>>            Case (sDriverID = MDSPgSQL)   
92194>>>                Get _UtilEnumeratePostgreSQLTypes to ColumnType
92195>>>                Case Break
92196>>>        Case End
92196>>>        
92196>>>        Function_Return ColumnType
92197>>>    End_Function
92198>>>
92198>>>    // DataFlex Embedded Database Data Types:
92198>>>    // Helper function for UtilEnumerateColumnTypes
92198>>>    Function _UtilEnumerateDataFlexTypes Returns tColumnType[]
92200>>>        tColumnType[] ColumnType               
92200>>>        tColumnType[] ColumnType               
92201>>>        Integer i
92201>>>        
92201>>>        Move DF_ASCII           to ColumnType[i].iType
92202>>>        Move "ASCII"            to ColumnType[i].sType
92203>>>        Move DF_ASCII           to ColumnType[i].iDataFlexType
92204>>>        Move "ASCII"            to ColumnType[i].sDataFlexType
92205>>>        Move "254"              to ColumnType[i].sPrecision
92206>>>        Increment i 
92207>>>        
92207>>>        Move DF_BCD             to ColumnType[i].iType
92208>>>        Move "Numeric"          to ColumnType[i].sType
92209>>>        Move DF_BCD             to ColumnType[i].iDataFlexType
92210>>>        Move "Numeric"          to ColumnType[i].sDataFlexType
92211>>>        Move "14.8"             to ColumnType[i].sPrecision
92212>>>        Increment i             
92213>>>        
92213>>>        Move DF_DATE            to ColumnType[i].iType
