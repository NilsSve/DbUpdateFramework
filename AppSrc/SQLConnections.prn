98662>>>    Function IsDFConnId Returns Boolean
98665>>>        Boolean bDFConnId
98665>>>        Handle ho
98665>>>        String sFileName
98665>>>
98665>>>        Get phoSQLConnectionIniFile of ghoSQLConnectionHandler to ho
98666>>>        Get psIniFileName of ho to sFileName
98667>>>        Move (Uppercase(sFileName) = Uppercase(CS_SQLDF19IniFileName)) to bDFConnId 
98668>>>        Set pbDFConnId of ho to bDFConnId
98669>>>
98669>>>        Function_Return bDFConnId
98670>>>    End_Function
98671>>>
98671>>>    Procedure OnFileDropped String sFilename Boolean bLast
98674>>>        Boolean bHasChange
98674>>>        Handle ho hoGrid
98674>>>        Integer iRetval
98674>>>        String sPath
98674>>>
98674>>>        Forward Send OnFileDropped sFilename bLast
98676>>>
98676>>>        If (bLast = True) Begin
98678>>>            Move (oSQLConnections_grd(Self)) to hoGrid
98679>>>            Get ParseFolderName sFilename to sPath
98680>>>            Get ParseFileName   sFilename to sFilename
98681>>>            If (Uppercase(sFilename) <> Uppercase(CS_SQLIniFileName) and Uppercase(sFilename) <> Uppercase(CS_SQLDF19IniFileName)) Begin
98683>>>                Send Info_Box ("Sorry, only" * CS_SQLIniFileName * "files can be dropped!")
98684>>>                Procedure_Return
98685>>>            End
98685>>>>
98685>>>            Get Should_Save of hoGrid to bHasChange
98686>>>            If (bHasChange = True) Begin
98688>>>                Get YesNo_Box "Changes exist! Do you still want to load the new file?" to iRetval
98689>>>                If (iRetval <> MBR_Yes) Begin
98691>>>                    Procedure_Return
98692>>>                End
98692>>>>
98692>>>            End
98692>>>>
98692>>>            Get phoSQLConnectionIniFile of ghoSQLConnectionHandler to ho
98693>>>            Set psIniFilePath of ho to sPath
98694>>>            Set psIniFileName of ho to sFilename
98695>>>            Send LoadData of oSQLConnections_grd
98696>>>        End
98696>>>>
98696>>>    End_Procedure
98697>>>
98697>>>    // This is only being called where no SQLConnections.ini file exists;
98697>>>    // thus a new active/enabled DFConnection ID needs to be established.
98697>>>    Procedure ConnectionDoesNotExist
98700>>>        tSQLConnection SQLConnection
98700>>>        tSQLConnection SQLConnection
98700>>>        Boolean bChanged bDFConnId bEnabled
98700>>>        Handle ho
98700>>>        tDataSourceRow TheRow
98700>>>        tDataSourceRow TheRow
98700>>>        Handle hoDataSource
98700>>>        tDataSourceRow[] TheData
98700>>>        tDataSourceRow[] TheData
98701>>>
98701>>>        Get IsDFConnId to bDFConnId
98702>>>
98702>>>        Move (oSQLMaintainConnections_dg(Self)) to ho
98703>>>        Move True to bEnabled
98704>>>        Set pbNew to True
98705>>>        Set pbNew of ho to True
98706>>>
98706>>>        Get phoDataSource of oSQLConnections_grd to hoDataSource
98707>>>        Get DataSource of hoDataSource to TheData
98708>>>
98708>>>        Send Activate_SQLMaintainConnections_dg of (Client_Id(phoMainPanel(ghoApplication))) (pbNew(Self)) -1 (&SQLConnection) (&bChanged) bDFConnId TheData
98709>>>        If (bChanged = True) Begin
98711>>>            // We also need to tell the main connection object that we now have
98711>>>            // created a connection.           
98711>>>            Set pSQLConnection            of ghoSQLConnectionHandler to SQLConnection
98712>>>//            Set psConnectionID            of ghoSQLConnectionHandler to SQLConnection.sConnectionID
98712>>>//            Send UpdateConnectionString   of ghoSQLConnectionHandler SQLConnection
98712>>>//            Set psConnectionString        of ghoSQLConnectionHandler to SQLConnection.sConnectionString
98712>>>            // And add the data to the grid.
98712>>>            Get MoveSQLConnectionToGridRow of oSQLConnections_grd SQLConnection to TheRow
98713>>>            Send AddConnection of oSQLConnections_grd TheRow
98714>>>            // Not new anymore.
98714>>>            Set pbNew to False
98715>>>            Set pbNew of ho to False
98716>>>        End
98716>>>>
98716>>>    End_Procedure
