98447>>>        Function ReadIniFile Returns tSQLConnection[]
98450>>>            tSQLConnection[] SQLConnectionsArray
98450>>>            tSQLConnection[] SQLConnectionsArray
98451>>>            Handle ho
98451>>>
98451>>>            Get phoSQLConnectionIniFile of ghoSQLConnectionHandler to ho
98452>>>            Get SQLIniFileReadConnections of ho to SQLConnectionsArray
