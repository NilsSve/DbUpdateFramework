80173>>>// **WvA:
80173>>>// A windows replacement for the standard function FileExists.
80173>>>// This version will also return (true) for a file when it is open by an application.
80173>>>// Note that you can apply normal windows mask-signs in the filename such as * and ?
80173>>>// Example: Get vFilePathExists "C:\config.sy?"
80173>>>// This will return true if you have a file matching these conditions. (aka config.sys)
80173>>>Function vFilePathExists Global String sFilePathMask Returns Integer
80175>>>  String  sWin32FindData
80175>>>  String  sDirSep
80175>>>  Pointer lpsFilePathMask lpsWin32FindData
80175>>>  Handle  hFindFile
80175>>>  Integer iVoid
80175>>>
80175>>>  Move vINVALID_HANDLE_VALUE To hFindFile
80176>>>  Move (ToANSI(trim(sFilePathMask))) To sFilePathMask
80177>>>  
80177>>>  If (length(sFilePathMask)>0) Begin
80179>>>    // 2014-09-29 NGS Remove any trailing dir separators, as they make the function fail.
80179>>>    Move (sysconf(SYSCONF_DIR_SEPARATOR)) to sDirSep
80180>>>    While (Right(sFilePathMask, 1) = sDirSep)
80184>>>      Move (Left(sFilePathMask, Length(sFilePathMask) -1)) to sFilePathMask
80185>>>    Loop
80186>>>>
80186>>>    
80186>>>    GetAddress Of sFilePathMask To lpsFilePathMask
80187>>>    ZeroType vWin32_Find_Data To sWin32FindData
80188>>>    GetAddress Of sWin32FindData To lpswin32FindData
80189>>>    Move (vWin32_FindFirstFile (lpsFilePathMask, lpsWin32FindData)) To hFindFile
80190>>>    Move (vWin32_FindClose (hFindFile)) To iVoid
80191>>>  End
80191>>>>
80191>>>  Function_Return (hFindFile <> vINVALID_HANDLE_VALUE)
80192>>>End_Function // vFilePathExists
80193>>>
80193>>>
80193>>>// **WvA
80193>>>// Formats a foldername by first trimming it and after that by sticking a
80193>>>// directory separator (/\) to the end if it doesn't have one there already.
80193>>>// The folder may contain a drive letter or UNC encoding.
80193>>>Function vFolderFormat Global String sFolderName Returns String
80195>>>  String sDirSep
80195>>>  Move (sysconf(SYSCONF_DIR_SEPARATOR)) To sDirSep  // normally \ (backslash)
80196>>>  Move (Trim(sFolderName)) To sFolderName
80197>>>  If (Right(sFolderName,1)<>sDirSep) Begin
80199>>>    Move (sFolderName+sDirSep) To sFolderName
80200>>>  End
80200>>>>
80200>>>  Function_Return sFolderName
80201>>>End_Function // vFolderFormat
80202>>>//
80202>>>// Returns the amount of files in the folder (if it exists)
80202>>>// Returns -1 if folder doesn't exist.
80202>>>// The files "." and ".." are not counted.
80202>>>//
80202>>>Function vFolderFileCount Global String sFolderName Returns Integer
80204>>>  Boolean bFound
80204>>>  Handle  hFindFile
80204>>>  Integer iCount  iVoid
80204>>>  Integer iSuccess
80204>>>  Pointer lpsFolderName lpsWin32FindData
80204>>>  String  sWin32FindData
80204>>>  String  sFileName
80204>>>  
80204>>>  Move -1 To iCount
80205>>>  Get vFolderFormat sFolderName To sFolderName
80206>>>  Move (sFolderName+"*") To sFolderName // match any filename in the folder
80207>>>  GetAddress Of sFolderName To lpsFolderName
80208>>>  ZeroType vWin32_Find_Data To sWin32FindData
80209>>>  GetAddress Of sWin32FindData To lpswin32FindData
80210>>>  Move (vWin32_FindFirstFile (lpsFolderName, lpsWin32FindData)) To hFindFile
80211>>>  Move (hFindFile<>vINVALID_HANDLE_VALUE) To bFound
80212>>>  If (bFound) Move 0 To iCount
80215>>>  While (bFound)
80219>>>    Increment iCount
80220>>>    GetBuff_String From sWin32FindData At vWin32_Find_Data.cFileName To sFileName
80221>>>    If (sFileName="." or sFileName="..") Decrement iCount
80224>>>    Move (vWin32_FindNextFile(hFindFile, lpsWin32FindData)) To iSuccess
80225>>>    Move (iSuccess<>0) To bFound
80226>>>  Loop
80227>>>>
80227>>>  Move (vWin32_FindClose (hFindFile)) To iVoid
80228>>>  Function_Return iCount
80229>>>End_Function // vFolderFileCount
80230>>>   
80230>>>
80230>>>//
80230>>>// Gets the parent path of the currently supplied path
80230>>>// Returns "" when we are at the root folder.
80230>>>//
80230>>>Function vParentPath Global String sPath Returns String
80232>>>  String sStrip
80232>>>  
80232>>>  If (Right(sPath,1)="\") Begin
80234>>>    Move (Left(sPath,Length(sPath)-1)) To sPath
80235>>>  End
80235>>>>
80235>>>  If (Pos("\",sPath)) Begin
80237>>>    Move (StringFromRightOfChar(sPath,"\")) To sStrip
80238>>>    Move (Replace(sStrip,sPath,"")) To sPath
80239>>>  End
80239>>>>
80239>>>  Else Begin
80240>>>    Move "" To sPath
80241>>>  End
80241>>>>
80241>>>  Function_Return sPath
80242>>>End_Function // vParentPath
80243>>>
80243>>>// Create the folder, including intermediate directories.
80243>>>// Don't panic if the folder already exists.
80243>>>// Michael Mullan June 2009.
80243>>>Function vshCreateDirectoryEX Global String sNewFolder Returns Integer
80245>>>  String  sFolder sSA
80245>>>  Pointer lpsFolder lpsSecurity_Attributes
80245>>>  Integer iRetval bFolderCreated bInheritHandle
80245>>>  Move (False) to bFolderCreated
80246>>>  // fill string variable with null characters
80246>>>  ZeroType vtSecurity_attributes to sSA
80247>>>  // null MAX_PATH chars into var (make space)
80247>>>  Move (Repeat(Character(0), vMAX_PATH)) to sFolder
80248>>>  If (sNewFolder <> "") Begin
80250>>>    Move dfTrue to  bInheritHandle
80251>>>    // Setting this to NULL is already done by the zerotype command
80251>>>    // Move NULL   To  lpDescriptor
80251>>>    Put (length(sSA))   to sSA At vtSecurity_attributes.nLength
80252>>>    //Put lpDescriptor To sSA at vtSecurity_attributes.lpDescriptor
80252>>>    Put bInheritHandle to sSA At vtSecurity_attributes.bInheritHandle
80253>>>    GetAddress of sSA to lpsSecurity_Attributes
80254>>>    //
80254>>>    Move sNewFolder to sFolder
80255>>>    GetAddress of sFolder to lpsFolder
80256>>>    Move (vWin32_SHCreateDirectoryEx(0,lpsFolder, lpsSecurity_Attributes)) to bFolderCreated
80257>>>  End
80257>>>>
80257>>> 
80257>>>  If (bFolderCreated <> 0) Begin
80259>>>    Move 1 to iRetVal
80260>>>   
80260>>>    If (bFolderCreated = 161 ) Error DFERR_OPERATOR ("Path " + sNewFolder + " is Not Valid (ERROR_BAD_PATHNAME)")
80263>>>    Else If (bFolderCreated = 206 ) Error DFERR_OPERATOR ("Path " + sNewFolder + " is Not Valid (ERROR_FILENAME_EXCED_RANGE)")
80267>>>    Else If (bFolderCreated = 3   ) Error DFERR_OPERATOR ("Path " + sNewFolder + " is Not Valid (ERROR_PATH_NOT_FOUND)")
80271>>>    Else If (bFolderCreated = 80  ) Move 0 to iRetval // "ERROR_FILE_EXISTS"     not really an error
80275>>>    Else If (bFolderCreated = 183 ) Move 0 to iRetval //  "ERROR_ALREADY_EXISTS"     not really an error
80279>>>    Else If (bFolderCreated = 1223) Error DFERR_OPERATOR ("Path " + sNewFolder + " is Not Valid (ERROR_CANCELLED)")
80283>>>    Else Error DFERR_OPERATOR ("Folder Creation Error # " + String(bfoldercreated) + "\n" + sNewFolder + "(FILE_CREATION_ERROR)")
80285>>>  End
80285>>>>
80285>>>  Function_Return iRetVal
80286>>>End_Function // vshCreateDirectoryEX
