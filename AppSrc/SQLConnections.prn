90546>>>    // The bANSI parameter's default value = True, meaning a table in ANSI format will be created.
90546>>>    // i.e. DF_FILE_TABLE_CHARACTER_FORMAT {"OEM"|"ANSI"}
90546>>>    Function ApiTableCreate Handle hTable String sRoot String sDisplay String sTableName Boolean bUseConnectionID Boolean bANSI Boolean bRecnum Returns Boolean
90548>>>        Handle hFile
90548>>>        String sConnectionID sPhysicalFile sANSI_OEM sVal sSchema sOriginalDriverID sDriverID
90548>>>        Integer iColumn 
90548>>>        Boolean bOk bExists bMertechDriver
90548>>>        tSQLConnection SQLConnection
90548>>>        tSQLConnection SQLConnection
90548>>>
90548>>>        If (ghoProgressBar <> 0) Begin
90550>>>            Send DoAdvance of ghoProgressBar
90551>>>        End
90551>>>>
90551>>>        
90551>>>        // First check if the passed filenumber already exists; in case we do nothing
90551>>>        Get UtilTableNumberIsInUse hTable to bOk
90552>>>        If (bOk = True) Begin
90554>>>            Function_Return False
90555>>>        End
90555>>>>
90555>>>        
90555>>>        Get psDriverID to sDriverID
90556>>>        // If this is a SQL based driver we also check if the table exists
90556>>>        // in the SQL back end; in case we do nothing.
90556>>>        Get IsSQLDriver sDriverID to bOk
90557>>>        If (bOk = True) Begin
90559>>>            Get SqlUtilCheckIfTableHandleExists hTable sDriverID to bExists
90560>>>            If (bExists = True) Begin
90562>>>                Function_Return False
90563>>>            End                      
90563>>>>
90563>>>        
90563>>>            // Get all connection properties
90563>>>            Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection  
90564>>>            Move SQLConnection.sSchema to sSchema
90565>>>            If (sSchema = "") Begin
90567>>>                Get _SqlFindKeyWord CI_SQLDBO to sSchema  
90568>>>            End
90568>>>>
90568>>>        End
90568>>>>
90568>>>        
90568>>>        Move CS_ANSI_Txt to sANSI_OEM
90569>>>        If (num_arguments > 6) Begin
90571>>>            If (bANSI = False) Begin
90573>>>                Move CS_OEM_Txt to sANSI_OEM
90574>>>            End
90574>>>>
90574>>>        End  
90574>>>>
90574>>>        
90574>>>        // Mertech drivers don't use connection id's, so if the passed bUseConnectionID = True that
90574>>>        // is a programmer's error and we auto-correct for it here.
90574>>>        // This is also a bit messy. If a Mertech driver is used and we want to create a new table,
90574>>>        // we first need to create it as embedded (DataFlex) and then convert it to SQL (!)
90574>>>        // So we set the driver ID temporarily to "DataFlex" to get the table created as embedded and later
90574>>>        // set it back and use a Mertech function to convert it to SQL.
90574>>>        Get IsMertechDriver sDriverID to bMertechDriver
90575>>>        If (bMertechDriver = True) Begin
90577>>>            If (bUseConnectionID = True) Begin
90579>>>                Move False to bUseConnectionID
90580>>>            End
90580>>>>
90580>>>            Move sDriverID to sOriginalDriverID
90581>>>            Move DATAFLEX_ID to sDriverID
90582>>>        End
90582>>>>
90582>>>            
90582>>>        Move False to Err
90583>>>        If (sDriverID = DATAFLEX_ID) Begin
90585>>>            Move sRoot to sPhysicalFile 
90586>>>        End
90586>>>>
90586>>>        
90586>>>        If (sDriverID <> DATAFLEX_ID) Begin 
90588>>>            Move SQLConnection.sConnectionID to sConnectionID
90589>>>            
90589>>>            // If DAW driver and we should use a connection id we need to
90589>>>            // check if the connection ID exists; else we create it before attempting creating the table
90589>>>            If (bMertechDriver = False and bUseConnectionID = True) Begin
90591>>>                Get IsConnectionID sConnectionID sDriverID to bExists
90592>>>                If (bExists = False) Begin
90594>>>                    Get UtilCreateConnectionID sConnectionID to bOk
90595>>>                    If (bOk = False) Begin
90597>>>                        Error DFERR_PROGRAM ("The Connection ID:" * sConnectionID * "could not be created and therefor the table can't be created.")
90598>>>>
90598>>>                        Function_Return False
90599>>>                    End
90599>>>>
90599>>>                End
90599>>>>
90599>>>            End
90599>>>>
90599>>>            
90599>>>            Move (sRoot + ".int") to sPhysicalFile
90600>>>            Move (Uppercase(sDisplay)) to sVal
90601>>>            If (not(sVal contains (sSchema + "."))) Begin    
90603>>>                Move (Lowercase(sSchema) + "." + sTableName) to sDisplay
90604>>>            End                                       
90604>>>>
90604>>>        End                                          
90604>>>>
90604>>>        Move 0 to hFile   
90605>>>        Move False to Err 
90606>>>        
90606>>>        Structure_Start hFile sDriverID
90607>>>            If (sDriverID <> DATAFLEX_ID) Begin
90609>>>                If (bUseConnectionID = True) Begin
90611>>>                    Set_Attribute DF_FILE_LOGIN              of hFile to (CS_DFCONNID + "=" + sConnectionID)
90614>>>                End 
90614>>>>
90614>>>                Else Begin
90615>>>                    Set_Attribute DF_FILE_LOGIN              of hFile to SQLConnection.sConnectionString
90618>>>                End
90618>>>>
90618>>>                Set_Attribute DF_FILE_TABLE_NAME             of hFile to sRoot  
90621>>>                Set_Attribute DF_FILE_USE_DUMMY_ZERO_DATE    of hFile to True     
90624>>>                Set_Attribute DF_FILE_TABLE_CHARACTER_FORMAT of hFile to sANSI_OEM
90627>>>                Set_Attribute DF_FILE_RECNUM_TABLE           of hFile to bRecnum
90630>>>
90630>>>                If (sSchema <> "") Begin
90632>>>                    Set_Attribute DF_FILE_OWNER                of hFile to sSchema
90635>>>                End
90635>>>>
90635>>>    
90635>>>                If (sDriverID = DB2_DRV_ID) Begin                           
90637>>>                    If (SQLConnection.sLongTableSpace <> "") Begin
90639>>>                        Set_Attribute DF_FILE_LONG_TABLESPACE  of hFile to SQLConnection.sLongTableSpace
90642>>>                    End
90642>>>>
90642>>>                End   
90642>>>>
90642>>>                If (sDriverID = DB2_DRV_ID or sDriverID = ORAFLEX or sDriverID = MDSPgSQL) Begin
90644>>>                    If (SQLConnection.sBaseTableSpace <> "") Begin
90646>>>                        Set_Attribute DF_FILE_TABLE_TABLESPACE of hFile to SQLConnection.sBaseTableSpace
90649>>>                    End
90649>>>>
90649>>>                    If (SQLConnection.sIndexTableSpace <> "") Begin
90651>>>                        Set_Attribute DF_FILE_INDEX_TABLESPACE of hFile to SQLConnection.sIndexTableSpace
90654>>>                    End
90654>>>>
90654>>>                End
90654>>>>
90654>>>            End 
90654>>>>
90654>>>                       
90654>>>            Set_Attribute DF_FILE_PHYSICAL_NAME              of hFile to sPhysicalFile 
90657>>>            
90657>>>            // We need to create at least one column else the table creation will fail.
90657>>>            // We remove it before the end of this function.
90657>>>            Move 0 to iColumn
90658>>>            Create_Field hFile at iColumn                   
90659>>>            
90659>>>            Set_Attribute DF_FIELD_NAME of hFile iColumn to "temp"
90662>>>            Set_Attribute DF_FIELD_TYPE of hFile iColumn to DF_DATE
90665>>>        Structure_End hFile
90667>>>        
90667>>>        // If Mertech driver we convert the newly created embedded table (DataFlex) to SQL
90667>>>        If (bMertechDriver = True) Begin
90669>>>            Move sOriginalDriverID to sDriverID
90670>>>            If (not(sVal contains (sSchema + "."))) Begin    
90672>>>                Move (Lowercase(sSchema) + "." + sTableName) to sDisplay
90673>>>            End                                       
90673>>>>
90673>>>            // Note: This function also sets the Err flag.
90673>>>            Get _MertechApiTableConvertToSQL hTable sRoot SQLConnection.sDatabase sDriverID SQLConnection.sBaseTableSpace SQLConnection.sIndexTableSpace False to bOK
90674>>>        End
90674>>>>
90674>>>
90674>>>        Move (not(Err)) to bOK                                     
90675>>>        If (bOk = True) Begin
90677>>>            If (sDriverID <> DATAFLEX_ID) Begin
90679>>>                Move (sDriverID + ":" + sRoot) to sRoot
90680>>>            End
90680>>>>
90680>>>    
90680>>>            If (sDriverID <> DATAFLEX_ID and not(Uppercase(sRoot) contains sDriverID)) Begin
90682>>>                Move (sDriverID + ":" + sRoot) to sRoot
90683>>>            End
90683>>>>
90683>>>            Set_Attribute DF_FILE_ROOT_NAME     of hTable to sRoot
90686>>>            Set_Attribute DF_FILE_LOGICAL_NAME  of hTable to sTableName 
90689>>>            Set_Attribute DF_FILE_DISPLAY_NAME  of hTable to sDisplay
90692>>>        
90692>>>            // Lastly we remove the temporary column we created above, if all went well.
90692>>>            Get ApiColumnRemove hTable "temp" to bOk
90693>>>        End
90693>>>>
90693>>>        
90693>>>        Function_Return (bOK = True)
90694>>>    End_Function  
