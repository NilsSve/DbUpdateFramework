95709>>>>>    Procedure Set Version String sVersion
95711>>>>>        Handle hoVersionInfo
95711>>>>>        Boolean bIncluded
95711>>>>>        Integer iMajor iMinor iRelease iBuild
95711>>>>>        Date dCompileDate
95711>>>>>
95711>>>>>        If (sVersion = "") Begin
95713>>>>>            // This automatically shows the program version of the program, if available.
95713>>>>>            // It will be displayed as the second item in the edit object.
95713>>>>>            If (ghoApplication <> 0) Begin
95715>>>>>                Get phoVersionInfo of ghoApplication to hoVersionInfo
95716>>>>>                If (hoVersionInfo <> 0) Begin
95718>>>>>                    Get pbIncluded of hoVersionInfo to bIncluded
95719>>>>>                    If (bIncluded) Begin
95721>>>>>                        Get piVersionMajor of hoVersionInfo to iMajor
95722>>>>>                        Get piVersionMinor of hoVersionInfo to iMinor
95723>>>>>                        Get piVersionRelease of hoVersionInfo to iRelease
95724>>>>>                        Get piVersionBuild of hoVersionInfo to iBuild
95725>>>>>                        Move (SFormat (C_$VERSION + ": %1.%2.%3.%4", iMajor, iMinor, iRelease, iBuild)) to sVersion
95726>>>>>                    End
95726>>>>>>
95726>>>>>                End
95726>>>>>>
95726>>>>>            End
95726>>>>>>
95726>>>>>        End
95726>>>>>>
95726>>>>>
95726>>>>>        // Display the compiled date as the next row in the edit object, after the program version.
95726>>>>>        Get GetCompileDate to dCompileDate
95727>>>>>        If (sVersion <> "") Begin
95729>>>>>            Send Add_Lineln (sVersion + (Character(13)) + C_$Compile_Date * String(dCompileDate))
95730>>>>>        End
95730>>>>>>
95730>>>>>    End_Procedure
95731>>>>>
95731>>>>>    Function GetCompileDate Returns Date
95733>>>>>        Date dCompileDate
95733>>>>>        String sAppFilename sData sCompileDate
95733>>>>>        Integer iChannel iPos iDateFormat
95733>>>>>
95733>>>>>        // Get full path to the current running executable
95733>>>>>        Get GetApplicationFileName of ghoApplication to sAppFilename
95734>>>>>
95734>>>>>        //Read the current file  up to where the data we're interesting in is (this was hand calced and so could vary)
95734>>>>>        Get Seq_Open_Input_Channel ("binary:" * sAppFilename) to iChannel
95735>>>>>        Read_Block channel iChannel sData (8 * 1024)    // First 8K is .exe header skip it
95737>>>>>        Read_Block channel iChannel sData 75            // The compile information we're interested in
95739>>>>>        Send Seq_Close_Channel iChannel
95740>>>>>
95740>>>>>        // The data is padded with Character(0)s. Strip them out
95740>>>>>        Move (CString(sData)) to sData
95741>>>>>
95741>>>>>        // The compile date is after the first ", ", so string parsing is required
95741>>>>>        Move (Pos(", ", sData)) to iPos
95742>>>>>        Move (Mid(sData, 10, (iPos + 2) ))  to sCompileDate // In US format
95743>>>>>        // If the current date format is non US, we need to temporary
95743>>>>>        // change the format and then move the string to the date variable.
95743>>>>>        Get_Attribute DF_DATE_FORMAT        to iDateFormat
95746>>>>>        Set_Attribute DF_DATE_FORMAT        to DF_DATE_USA
95749>>>>>        Move (Date(sCompileDate))           to dCompileDate
95750>>>>>        Set_Attribute DF_DATE_FORMAT        to iDateFormat // Reset date format
95753>>>>>
95753>>>>>        Function_Return dCompileDate
95754>>>>>    End_Function
