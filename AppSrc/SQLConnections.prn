85442>>>>>    // *** Generalized messages to Get & Set values of the ini file.
85442>>>>>    // Sets a value in the program's ini file (write)
85442>>>>>    // Pass a section name, the value name parameter and the value itself to be written.
85442>>>>>    Procedure Set IniFileValue String sSection String sValueName String sValue
85444>>>>>        String sIniFile sPath
85444>>>>>
85444>>>>>        Get psIniFilePath to sPath   
85445>>>>>        Get psIniFileName to sIniFile
85446>>>>>        Move (sPath + sIniFile) to sIniFile
85447>>>>>        Set psFileName to sIniFile
85448>>>>>        Send WriteString sSection sValueName sValue
85449>>>>>    End_Procedure
85450>>>>>
85450>>>>>    // Get a value from program's ini-file (read)
85450>>>>>    // Pass a section name and the name of the value parameter & a default value.
85450>>>>>    // Returns the value
