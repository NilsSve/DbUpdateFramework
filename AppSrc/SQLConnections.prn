85864>>>>>                If (sDatabase <> "") Begin
85866>>>>>                    Move (sConnect * ";" + CS_SQLIniDatabaseKeyword + "=" + sDatabase) to sConnect
85867>>>>>                End
85867>>>>>>
85867>>>>>                Case Break
85868>>>>>
85868>>>>>            Case (sDriverID = ODBC_DRV_ID)
85871>>>>>                Move (sConnect * CS_SQLIniDSNKeyword + "=" + sServer) to sConnect
85872>>>>>                If (sDatabase <> "") Begin
85874>>>>>                    Move (sConnect * ";" + CS_SQLIniDatabaseKeyword + "=" + sDatabase) to sConnect
85875>>>>>                End
85875>>>>>>
85875>>>>>                Case Break
85876>>>>>
85876>>>>>            Case (sDriverID = DB2_DRV_ID)
85879>>>>>                Move (sConnect * CS_SQLIniDSNKeyword + "=" + sServer) to sConnect
85880>>>>>                If (sDatabase <> "") Begin
85882>>>>>                    Move (sConnect * ";" + CS_SQLIniDatabaseKeyword + "=" + sDatabase) to sConnect
85883>>>>>                End
85883>>>>>>
85883>>>>>                Case Break
85884>>>>>            
85884>>>>>            Case (sDriverID = ORAFLEX)
85887>>>>>                Move (sConnect * CS_SQLIniDSNKeyword + "=" + sServer) to sConnect
85888>>>>>                If (sDatabase <> "") Begin
85890>>>>>                    Move (sConnect * ";" + CS_SQLIniDatabaseKeyword + "=" + sDatabase) to sConnect
85891>>>>>                End
85891>>>>>>
85891>>>>>                Case Break
85892>>>>>
85892>>>>>            Case (sDriverID = MDSPgSQL)
85895>>>>>                Move (sConnect * CS_SQLIniDSNKeyword + "=" + sServer) to sConnect
85896>>>>>                If (sDatabase <> "") Begin
85898>>>>>                    Move (sConnect * ";" + CS_SQLIniDatabaseKeyword + "=" + sDatabase) to sConnect
85899>>>>>                End
85899>>>>>>
85899>>>>>                Case Break
85900>>>>>
85900>>>>>            Case (sDriverID = MDSMySQL)
