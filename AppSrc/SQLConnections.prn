94045>>>    // Note: If the psDriverID + other connection properties are to be changed,
94045>>>    //       the psDriverID *must* be the first property that is changed!
94045>>>    //       Otherwise errors might be raised by the driver when e.g. the format
94045>>>    //       for a connection string has the wrong format for that driver.
94045>>>    Procedure Set psDriverID String sValue
94047>>>        Send Ignore_Error of Error_Object_Id DFERR_BAD_MESSAGE
94048>>>        Delegate Set psDriverID to sValue
94050>>>        Send Trap_Error of Error_Object_Id DFERR_BAD_MESSAGE
94051>>>        Set psDriverID of ghoSQLConnectionHandler to sValue
94052>>>    End_Procedure
94053>>>    
94053>>>    Function psDriverID Returns String
94055>>>        String sDriverID
94055>>>        
94055>>>        Send Ignore_Error of Error_Object_Id DFERR_BAD_MESSAGE
94056>>>        // This should get it from the parent object (when using the cDbUpdateHandler class)
94056>>>        Delegate Get psDriverID to sDriverID
94058>>>        Send Trap_Error of Error_Object_Id DFERR_BAD_MESSAGE
94059>>>        Move False to Err
94060>>>
94060>>>        // ...and in case it didn't use property of this class. Then the library is
94060>>>        // probably used as "utilites" from a special made program and
94060>>>        // the ghoSQLConnectionHandler must have been setup
94060>>>        If (sDriverID = "") Begin
94062>>>            Get psDriverID of ghoSQLConnectionHandler to sDriverID
94063>>>        End            
94063>>>>
94063>>>        Function_Return sDriverID
94064>>>    End_Function  
94065>>>    
94065>>>    Procedure Set piDbType Integer iValue
94067>>>        Send Ignore_Error of Error_Object_Id DFERR_BAD_MESSAGE
94068>>>        Delegate Set piDbType to iValue
94070>>>        Send Trap_Error of Error_Object_Id DFERR_BAD_MESSAGE
94071>>>        Set piDbType of ghoSQLConnectionHandler to iValue
94072>>>    End_Procedure
94073>>>    
94073>>>    Function piDbType Returns String
94075>>>        Integer iRetval
94075>>>        
94075>>>        Move False to Err
94076>>>        Send Ignore_Error of Error_Object_Id DFERR_BAD_MESSAGE
94077>>>        // This should get it from the parent object (when using the cDbUpdateHandler class)
94077>>>        Set Error_Report_Mode to DUF_ERROR_NO_REPORT
94078>>>        Delegate Get piDbType to iRetval
94080>>>        Set Error_Report_Mode to DUF_ERROR_REPORT
94081>>>        Send Trap_Error of Error_Object_Id DFERR_BAD_MESSAGE
94082>>>
94082>>>        // ...and in case it didn't use property of this class. Then the library is
94082>>>        // probably used as "utilites" from a special made program and
94082>>>        // the ghoSQLConnectionHandler must have been setup
94082>>>        If (Err = True) Begin
94084>>>            Get piDbType of ghoSQLConnectionHandler to iRetval
94085>>>        End            
94085>>>>
94085>>>
94085>>>        Move False to Err
94086>>>        Function_Return iRetval
94087>>>    End_Function  
94088>>>    
94088>>>    // When dropping columns on some SQL back-ends they doesn't reclaim the space taken up by the columns dropped. 
94088>>>    // For data types that are stored inline in the rows (int for example) it may even take up space on 
94088>>>    // the new rows added after the alter statement. to get around this you need to create a clustered 
94088>>>    // index on the table _or_ rebuild the clustered Index if it already has one. Rebuilding the index 
94088>>>    // can be done with a REBUILD command after modifying the table. But be warned this can be slow on very big tables.
94088>>>    //   ALTER TABLE MyTable
94088>>>    //       REBUILD
94088>>>    Function _SqlUtilRemoveTableColumnMSSQL String sTableName String sColumnName Returns Boolean
94090>>>        Boolean bOK  
94090>>>        
94090>>>        If (Trim(sTableName) = "" or Trim(sColumnName) = "") Begin
94092>>>            Function_Return False
94093>>>        End                             
94093>>>>
94093>>>        
94093>>>        SQLIncludeScriptFile ..\Scripts\DropConstraintAndColumnNameMSSQL.sql as DropConstraintAndColumnNameMSSQL.sql
94093>>>        Get _SqlUtilRemoveTableColumnByScript "DropConstraintAndColumnNameMSSQL.sql" sTableName sColumnName to bOK
94094>>>        
94094>>>        Function_Return (bOK = True)
94095>>>    End_Function
94096>>>
94096>>>
94096>>>    // *** Helper functions with compiled sql script code ***
94096>>>    //  
94096>>>    // When dropping columns SQL Sever does not reclaim the space taken up by the columns dropped. 
94096>>>    // For data types that are stored inline in the rows (int for example) it may even take up space on 
94096>>>    // the new rows added after the alter statement. To get around this you need to create a clustered 
94096>>>    // index on the table or rebuild the clustered Index if it already has one. Rebuilding the index 
94096>>>    // can be done with a REBUILD command after modifying the table. But be warned this can be slow on very big tables.
94096>>>    //   ALTER TABLE MyTable
94096>>>    //       REBUILD
94096>>>    Function _SqlUtilRemoveTableColumnByScript String sMemScriptFile String sTableName String sColumnName Returns Boolean
94098>>>        tSQLScriptArray SQLScriptArray                      
94098>>>        tSQLScriptArray SQLScriptArray                      
94098>>>        String sDriverID sVal
94098>>>        Boolean bOK  
94098>>>        Integer iSize iCount
94098>>>        
94098>>>        If (Trim(sTableName) = "" or Trim(sColumnName) = "") Begin
94100>>>            Function_Return False
94101>>>        End                             
94101>>>>
94101>>>        
94101>>>        Get psDriverID to sDriverID
94102>>>        Get SqlUtilReadResource sMemScriptFile to SQLScriptArray
94103>>>        If (SQLScriptArray.bError = True) Begin
94105>>>            Function_Return False
94106>>>        End                     
94106>>>>
94106>>>        
94106>>>        Move (SizeOfArray(SQLScriptArray.sSQLScriptArray)) to iSize
94107>>>        Decrement iSize
94108>>>        
94108>>>        for iCount from 0 to iSize   
94114>>>>
94114>>>            If (SQLScriptArray.sSQLScriptArray[iCount] contains "TABLE_NAME_XXX") Begin
94116>>>                Move (Replaces("TABLE_NAME_XXX",  SQLScriptArray.sSQLScriptArray[iCount], String(sTableName))) to SQLScriptArray.sSQLScriptArray[iCount]
94117>>>            End
94117>>>>
94117>>>            If (SQLScriptArray.sSQLScriptArray[iCount] contains "COLUMN_NAME_XXX") Begin
94119>>>                Move (Replaces("COLUMN_NAME_XXX", SQLScriptArray.sSQLScriptArray[iCount], String(sColumnName))) to SQLScriptArray.sSQLScriptArray[iCount]
94120>>>            End
94120>>>>
94120>>>        Loop
94121>>>>
94121>>>        
94121>>>        Get SqlUtilExecuteEmbeddedScript SQLScriptArray sDriverID False "" to bOK
94122>>>        
94122>>>        Function_Return (bOK = True)
94123>>>    End_Function
94124>>>    
94124>>>    // *** Helper functions for Mertech Drivers ***
94124>>>    // Created to not clutter up the standard function code with lots of #IFDEF's
94124>>>    // and commands that the Studio editor knows nothing about.
94124>>>    Function _MertechDeleteTDFile String sTableName Returns Integer
94126>>>        Integer iRetval
94126>>>        String sPath
94126>>>
94126>>>            SQL_GET_LOCAL_TD_PATH to sPath
94140>>>>
94140>>>        If (sPath = "" or sTableName = "") Begin
94142>>>            Function_Return 0
94143>>>        End                              
94143>>>>
94143>>>        
94143>>>        Get vFolderFormat sPath to sPath
94144>>>        Get vDeleteFile (sPath + String(sTableName) + ".td") to iRetval
94145>>>        Function_Return iRetval
94146>>>    End_Function
