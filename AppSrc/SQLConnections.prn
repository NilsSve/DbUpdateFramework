90823>>>    // Removes the passed table name completely from disk, filelist (& Sql Server if an Sql-driver)
90823>>>    Function ApiTableRemove Handle hTable Returns Boolean
90825>>>        String sTableName sDriverID  
90825>>>        Boolean bOk     
90825>>>        String sDataPath
90825>>>        
90825>>>        Get AutoConnectionIDLogin to bOK
90826>>>        Move False to Err 
90827>>>        Get psDriverID to sDriverID
90828>>>        Get UtilTableHandleToString hTable sDriverID to sTableName
90829>>>        If (sTableName = "") Begin
90831>>>            Function_Return False
90832>>>        End                      
90832>>>>
90832>>>        
90832>>>        Send Ignore_Error of Error_Object_Id DFERR_CANT_DELETE_FILE
90833>>>        Delete_db sTableName 
90834>>>        Send Trap_Error of Error_Object_Id DFERR_CANT_DELETE_FILE 
90835>>>        
90835>>>        If (sDriverID <> DATAFLEX_ID) Begin
90837>>>            Get SqlTableRemoveByTableName sDriverID sTableName to bOk   
90838>>>            Get psDataPathFirstPart to sDataPath
90839>>>            Get vDeleteFile (sDataPath + sTableName + ".int") to bOk
90840>>>        End
90840>>>>
90840>>>        // Also remove table from filelist.cfg in case the physical file didn't exist.  
90840>>>        If (hTable <> 0) Begin
90842>>>            Set_Attribute DF_FILE_ROOT_NAME     of hTable to ""
90845>>>            Set_Attribute DF_FILE_DISPLAY_NAME  of hTable to ""
90848>>>            Set_Attribute DF_FILE_LOGICAL_NAME  of hTable to ""  
90851>>>        End
90851>>>>
90851>>>        
90851>>>        Function_Return (hTable <> 0)
90852>>>    End_Function
