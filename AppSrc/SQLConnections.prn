88778>>>    // Returns a string array with all table names the passed table handle has relation ships with.
88778>>>    // The format of the array is "TableName.FieldName"
88778>>>    Function SqlUtilEnumerateRelations String sTableName String sDriverID Returns tSQLRelation[]
88780>>>        String[] sFileNameArray sFieldNameArray
88782>>>        tSQLRelation[] sRelationsArray
88782>>>        tSQLRelation[] sRelationsArray
88783>>>        String sServer sConnectionString sSelect sSchema sFileName sFieldName sVal
88783>>>        Boolean bOK  
88783>>>        Integer iCount iSize iLength iPos 
88783>>>        Integer iFileNumber iFieldNumber
88783>>>        
88783>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
88784>>>        If (bOK = False) Begin
88786>>>            Error DFERR_PROGRAM ("Unsupported driver. A list of table columns could not be retrieved for:" * sDriverID + ".")
88787>>>>
88787>>>            Function_Return sRelationsArray
88788>>>        End   
88788>>>>
88788>>>       
88788>>>        Get psConnectionString to sConnectionString  
88789>>>        Get psSchema to sSchema
88790>>>        
88790>>>        Case Begin
88790>>>            Case (sDriverID = MSSQLDRV_ID)    
88792>>>                Move ("SELECT object_name(parent_object_id), object_name(referenced_object_id), name from sys.foreign_keys WHERE parent_object_id = object_id( '" + sTableName + "')") to sSelect
88793>>>                Get SqlEnumerateEsqlDAW sSelect 2 to sFileNameArray
88794>>>                Get SqlEnumerateEsqlDAW sSelect 3 to sFieldNameArray
88795>>>                Case Break
88796>>>
88796>>>            Case (sDriverID = DB2_DRV_ID) 
88799>>>                Error "Not implemented yet! The select statement has not been finalized."
88800>>>>
88800>>>//                Move () to sSelect
88800>>>//                Get SqlEnumerateEsqlDAW sSelect 2 to sReturnArray
88800>>>//                Get SqlEnumerateEsqlDAW sSelect 3 to sFieldNameArray
88800>>>                Case Break
88801>>>
88801>>>            Case (sDriverID = SQLFLEX)
88804>>>                Error "Not implemented yet! The select statement has not been finalized."
88805>>>>
88805>>>//                Move () to sSelect
88805>>>//                Get SqlEnumerateEsqlMertech sSelect 2 to sReturnArray
88805>>>//                Get SqlEnumerateEsqlDAW sSelect 3 to sFieldNameArray
88805>>>                Case Break
88806>>>            
88806>>>            Case (sDriverID = MDSMySQL) 
88809>>>                Error "Not implemented yet! The select statement has not been finalized."
88810>>>>
88810>>>//                Move () to sSelect
88810>>>//                Get SqlEnumerateEsqlMertech sSelect 2 to sReturnArray
88810>>>//                Get SqlEnumerateEsqlDAW sSelect 3 to sFieldNameArray
88810>>>                Case Break
88811>>>            
88811>>>            Case (sDriverID = MDSPgSQL) 
88814>>>                Error "Not implemented yet! The select statement has not been finalized."
88815>>>>
88815>>>//                Move () to sSelect
88815>>>//                Get SqlEnumerateEsqlMertech sSelect 2 to sReturnArray
88815>>>//                Get SqlEnumerateEsqlDAW sSelect 3 to sFieldNameArray
88815>>>                Case Break            
88816>>>            
88816>>>            Case (sDriverID = ORAFLEX) 
88819>>>                Error "Not implemented yet! The select statement has not been finalized."
88820>>>>
88820>>>//                Move () to sSelect
88820>>>//                Get SqlEnumerateEsqlMertech sSelect to sReturnArray
88820>>>//                Get SqlEnumerateEsqlDAW sSelect 3 to sFieldNameArray
88820>>>                Case Break
88821>>>                            
88821>>>            Case Else     
88821>>>                Error DFERR_PROGRAM "Unsupported driver passed to the SqlUtilEnumerateRelations function."
88822>>>>
88822>>>                Case Break
88823>>>        Case End   
88823>>>        
88823>>>        Move (Length(sTableName)) to iLength
88824>>>        Move (iLength + 4)        to iLength // The related to field key has the format "FK_TableName + FieldName"
88825>>>        Move (SizeOfArray(sFileNameArray)) to iSize
88826>>>        Decrement iSize
88827>>>        For iCount from 0 to iSize
88833>>>>
88833>>>            If (Trim(sFileNameArray[iCount]) <> "") Begin
88835>>>                Move sFileNameArray[iCount]         to sFileName 
88836>>>                Move sFieldNameArray[iCount]        to sFieldName
88837>>>                Move (Mid(sFieldName, 99, iLength)) to sFieldName
88838>>>                Move sFileName  to sRelationsArray[iCount].sFileName
88839>>>                Move sFieldName to sRelationsArray[iCount].sFieldName
88840>>>            End
88840>>>>
88840>>>        Loop
88841>>>>
88841>>>        
88841>>>        Function_Return sRelationsArray
88842>>>    End_Function  
