90215>>>    Procedure ApiTableConvertAllAddException Integer hTable
90217>>>        Integer[] iTableConvertExceptions
90218>>>        Get piTableConvertExceptions to iTableConvertExceptions
90219>>>        Move hTable to iTableConvertExceptions[SizeOfArray(iTableConvertExceptions)]
90220>>>        Set piTableConvertExceptions to iTableConvertExceptions
90221>>>    End_Procedure
90222>>>    
90222>>>    Procedure ApiTableConvertALLToSQL 
90224>>>        Integer[] iTablesArray                 
90225>>>        Integer iSize iCount                     
90225>>>        Boolean bUseConnectionID bToANSI bRecnum bCopyData bOK
90225>>>        String sDriverID
90225>>>        
90225>>>        Get psDriverID to sDriverID   
90226>>>        Get pbUseConnectionID to bUseConnectionID
90227>>>        Get pbToANSI          to bToANSI
90228>>>        Get pbRecnum          to bRecnum
90229>>>        Get pbCopyData        to bCopyData
90230>>>        
90230>>>        Get _AllTablesToConvert to iTablesArray
90231>>>        Move (SizeOfArray(iTablesArray)) to iSize
90232>>>        Decrement iSize
90233>>>        For iCount from 0 to iSize
90239>>>>
90239>>>            Get ApiTableConvertToSQL_Ex iTablesArray[iCount] sDriverID bUseConnectionID bToANSI bRecnum bCopyData to bOK
90240>>>        Loop
90241>>>>
90241>>>    
90241>>>    End_Procedure
90242>>>    
90242>>>    Function _AllTablesToConvert Returns Integer[]
90244>>>        Integer[] iTableConvertExceptions iTablesArray
90246>>>        Handle hTable
90246>>>        Integer iIndex   
90246>>>        String sTableName
90246>>>        
90246>>>        // a) Get the exception table array the developer has specified
90246>>>        Get piTableConvertExceptions to iTableConvertExceptions        
90247>>>        
90247>>>        // b) Add CodeMast, CodeType & DbVersion to exceptions
90247>>>        Repeat 
90247>>>>
90247>>>            Get_Attribute DF_FILE_NEXT_USED of hTable to hTable
90250>>>            If (hTable > 0 and hTable <> 50) Begin // 50 = Flexerrs.
90252>>>                Get_Attribute DF_FILE_LOGICAL_NAME of hTable to sTableName
90255>>>                If (Uppercase(sTableName) = "CODEMAST" or Uppercase(sTableName) = "CODETYPE" or Uppercase(sTableName) = "DBVERSION") Begin
90257>>>                    Move (SearchArray(hTable, iTableConvertExceptions)) to iIndex
90258>>>                    If (iIndex = -1) Begin
90260>>>                        Move hTable to iTableConvertExceptions[SizeOfArray(iTableConvertExceptions)]
90261>>>                    End
90261>>>>
90261>>>                End
90261>>>>
90261>>>            End
90261>>>>
90261>>>        Until (hTable = 0) 
90263>>>        
90263>>>        Move 0 to hTable
90264>>>        
90264>>>        // c) Spin through filelist.cfg and add all tables except those from the exception array, to the return array.
90264>>>        Repeat 
90264>>>>
90264>>>            Get_Attribute DF_FILE_NEXT_USED of hTable to hTable
90267>>>            If (hTable > 0 and hTable <> 50) Begin // 50 = Flexerrs.
90269>>>                Move (SearchArray(hTable, iTableConvertExceptions)) to iIndex
90270>>>                If (iIndex = -1) Begin
90272>>>                    Move hTable to iTablesArray[SizeOfArray(iTablesArray)]    
90273>>>                End
90273>>>>
90273>>>            End
90273>>>>
90273>>>        Until (hTable = 0) 
90275>>>        
90275>>>        Function_Return iTablesArray
90276>>>    End_Function
90277>>>        
90277>>>    Function ApiTableConvertToSQL_Ex Handle hTable String sDriverID Boolean bUseConnectionID Boolean bToAnsi Boolean bRecnum Boolean bCopyData Returns Boolean
90279>>>        Handle hToTable
90279>>>        Boolean bOK bExists bOpened bMertechDriver bDAWDriver
90279>>>        String sPhysicalName sRootName sDisplayName sEmpty sConnectionID sConnectionString
