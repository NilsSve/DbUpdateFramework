91564>>>    Function UtilColumnTypePrecisionSize String sDriverID Integer iDbType Integer iDataType Returns Integer
91566>>>        tColumnType RetvalType  
91566>>>        tColumnType RetvalType  
91566>>>        String sValue
91566>>>        Integer iRetval iPos
91566>>>        
91566>>>        Get _UtilColumnType sDriverID iDbType iDataType "" True to RetvalType 
91567>>>        Move RetvalType.sPrecision to sValue
91568>>>        Move (Pos(".", sValue)) to iPos
91569>>>        If (iPos <> 0) Begin
91571>>>            Move (Left(sValue, (iPos -1))) to iRetval
91572>>>        End                                          
91572>>>>
91572>>>        Else Begin
91573>>>            Move sValue to iRetval
91574>>>        End
91574>>>>
91574>>>        Function_Return iRetval
