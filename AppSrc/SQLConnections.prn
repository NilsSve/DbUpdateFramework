85197>>>>>>>Class cDbUpdateGenericDatabaseDriver is a cObject
85198>>>>>>>    Procedure Construct_Object
85200>>>>>>>        Forward Send Construct_Object
85202>>>>>>>        Property String psDriverID DATAFLEX_ID
85203>>>>>>>    End_Procedure 
85204>>>>>>>    
85204>>>>>>>    Function ServerKeyword Returns String
85206>>>>>>>        Function_Return CS_SQLIniDSNKeyword
85207>>>>>>>    End_Function
85208>>>>>>>    
85208>>>>>>>    Function ConstructConnectionString String sServer String sDatabase Boolean bTrusted String sUserID String sPassword Returns String
85210>>>>>>>        String sConnect
85210>>>>>>>        
85210>>>>>>>        Move (sConnect * ServerKeyword(Self) + "=" + sServer) to sConnect
85211>>>>>>>        If (sDatabase <> "") Begin
85213>>>>>>>            Move (sConnect * ";" + CS_SQLIniDatabaseKeyword + "=" + sDatabase) to sConnect
85214>>>>>>>        End
85214>>>>>>>>
85214>>>>>>>        If (bTrusted = True) Begin
85216>>>>>>>            Move (sConnect * ";" + CS_SQLIniTrustedKeyword + "=Yes") to sConnect
85217>>>>>>>        End
85217>>>>>>>>
85217>>>>>>>        Else Begin
85218>>>>>>>            Move (sConnect * ";" + CS_SQLIniUIDKeyword + "=" + sUserID * ";" + CS_SQLIniPWDKeyword + "=" + sPassword) to sConnect
85219>>>>>>>        End
85219>>>>>>>>
85219>>>>>>>        Function_Return sConnect
85220>>>>>>>    End_Function
85221>>>>>>>    
85221>>>>>>>    Function DbLogin String sConnectionString String sServer String sDatabase Boolean bTrusted String sUserID String sPassword Returns Boolean
85223>>>>>>>        Boolean bLoginSuccessful
85223>>>>>>>        String sDriverID 
85223>>>>>>>        
85223>>>>>>>        Get psDriverID to sDriverID
85224>>>>>>>        Move 0 to LastErr  // Do NOT use the Err flag, it will be set true by the login command although it is successful.
85225>>>>>>>        If (bTrusted = False) Begin
85227>>>>>>>            Login sServer sUserId sPassword sDriverID
85229>>>>>>>        End 
85229>>>>>>>>
85229>>>>>>>        Else Begin
85230>>>>>>>            Login sConnectionString "" "" sDriverID
85232>>>>>>>        End
85232>>>>>>>>
85232>>>>>>>        Move (LastErr = 0) to bLoginSuccessful
85233>>>>>>>        Function_Return bLoginSuccessful
85234>>>>>>>    End_Function
85235>>>>>>>End_Class
85236>>>>>>>
