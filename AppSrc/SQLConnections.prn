98455>>>        Procedure WriteIniFile
98458>>>            Integer iCount iSize
98458>>>            Handle hoDataSource ho
98458>>>            tDataSourceRow[] TheData
98458>>>            tDataSourceRow[] TheData
98459>>>            tDataSourceRow TheRow
98459>>>            tDataSourceRow TheRow
98459>>>            tSQLConnection[] SQLConnectionArray
98459>>>            tSQLConnection[] SQLConnectionArray
98460>>>            tSQLConnection SQLConnection
98460>>>            tSQLConnection SQLConnection
98460>>>            Boolean bIsOneActive bOK 
98460>>>            String sPath sFileName
98460>>>
98460>>>            Get IsOneItemActive to bIsOneActive
98461>>>            If (bIsOneActive = False) Begin
98463>>>                Send Info_Box "Sorry, you need to set one connection as active before changes can be saved."
98464>>>                Procedure_Return
98465>>>            End
98465>>>>
98465>>>
98465>>>            Move 0 to iCount
98466>>>            Get phoSQLConnectionIniFile of ghoSQLConnectionHandler to ho
98467>>>            Get phoDataSource to hoDataSource
98468>>>            Get DataSource of hoDataSource to TheData
98469>>>            Move (SizeOfArray(TheData)) to iSize
98470>>>            Decrement iSize
98471>>>
98471>>>            // Load data from the grid datasource array to SQLConnection array
98471>>>            For iCount from 0 to iSize
98477>>>>
98477>>>                Move TheData[iCount] to TheRow
98478>>>                Get MoveGridRowToSQLConnection TheRow to SQLConnection
98479>>>                Move SQLConnection to SQLConnectionArray[iCount]
98480>>>            Loop                                                
98481>>>>
98481>>>            
98481>>>            Get SQLIniFileWriteConnections of ho SQLConnectionArray to bOK
98482>>>            If (bOK = False) Begin
98484>>>                Send ChangeStatusRowText "Sorry, an error occured while saving the file and changes were not saved."
98485>>>                Procedure_Return
98486>>>            End
98486>>>>
98486>>>            
98486>>>            // Update the view property with the newly saved values. (Used to check if anything has changed)
98486>>>            Set pTheData to TheData
98487>>>            Send ChangeHeaderText
98488>>>            Send ChangeStatusRowText "Ready! File saved."
98489>>>        End_Procedure
98490>>>
98490>>>        Procedure OnHeaderClick Integer iCol
