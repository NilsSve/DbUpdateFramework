94610>>>>>>>>>use VDFBase.pkg
94610>>>>>>>>>
94610>>>>>>>>>Class cFormatter is an cObject
94611>>>>>>>>>
94611>>>>>>>>>    Procedure Construct_object
94613>>>>>>>>>        Integer iCh
94613>>>>>>>>>        forward send construct_object
94615>>>>>>>>>        Property String  psCurrencySymbol
94616>>>>>>>>>        Set psCurrencySymbol to (Default_Currency_Symbol())
94617>>>>>>>>>
94617>>>>>>>>>        Property string  psLeft
94618>>>>>>>>>        Property string  psright
94619>>>>>>>>>        Property integer pbThousandsSep
94620>>>>>>>>>        Property integer piPoints
94621>>>>>>>>>
94621>>>>>>>>>        Property string  psCurPosLeft
94622>>>>>>>>>        Property string  psCurPosright
94623>>>>>>>>>        Property integer pbCurPosThousandsSep
94624>>>>>>>>>        Property integer piCurPosPoints
94625>>>>>>>>>
94625>>>>>>>>>        Property string  psCurNegLeft
94626>>>>>>>>>        Property string  psCurNegright
94627>>>>>>>>>        Property integer pbCurNegThousandsSep
94628>>>>>>>>>        Property integer piCurNegPoints
94629>>>>>>>>>
94629>>>>>>>>>        Property string  psNumPosLeft
94630>>>>>>>>>        Property string  psNumPosright
94631>>>>>>>>>        Property integer pbNumPosThousandsSep
94632>>>>>>>>>        Property integer piNumPosPoints
94633>>>>>>>>>
94633>>>>>>>>>        Property string  psNumNegLeft
94634>>>>>>>>>        Property string  psNumNegright
94635>>>>>>>>>        Property integer pbNumNegThousandsSep
94636>>>>>>>>>        Property integer piNumNegPoints
94637>>>>>>>>>
94637>>>>>>>>>        Send SetFormat "$,#.##;($,#.##)" true  // currency
94638>>>>>>>>>        Send SetFormat  ",#.*"           false // numeric
94639>>>>>>>>>
94639>>>>>>>>>    end_procedure
94640>>>>>>>>>
94640>>>>>>>>>    // internal
94640>>>>>>>>>    // parse passed format string and set temporary properties with result
94640>>>>>>>>>    //
94640>>>>>>>>>    Procedure ParseFormat string sFmt
94642>>>>>>>>>
94642>>>>>>>>>        string sLeft sRight sDigit
94642>>>>>>>>>        integer bSep iPos i iDigits
94642>>>>>>>>>
94642>>>>>>>>>        // replace any literals. A "/" followed by anything.
94642>>>>>>>>>        // some literals are special. $ . , / #
94642>>>>>>>>>        Move (Replaces("/$",sFmt,Character(1)))    to sFmt
94643>>>>>>>>>        Move (Replaces("/.",sFmt,Character(2)))    to sFmt
94644>>>>>>>>>        Move (Replaces("/,",sFmt,Character(3)))    to sFmt
94645>>>>>>>>>        Move (Replaces("/"+"/",sFmt,Character(4))) to sFmt
94646>>>>>>>>>        Move (Replaces("/#",sFmt,Character(5)))    to sFmt
94647>>>>>>>>>        Move (Character(9)) to sDigit
94648>>>>>>>>>        Move (Replaces("#",sFmt,sDigit))           to sFmt
94649>>>>>>>>>        Move (Replaces("/",sFmt,""))               to sFmt // replace all others
94650>>>>>>>>>
94650>>>>>>>>>        Move (Pos(",",sFmt))                 to bSep // if we have any , we use thousand seps
94651>>>>>>>>>        If bSep Move (Replaces(",",sFmt,"")) to sFmt // remove all ,
94654>>>>>>>>>
94654>>>>>>>>>        Move (Replaces("$",sFmt,psCurrencySymbol(self))) to sFmt // replace any $ with currency symbol
94655>>>>>>>>>
94655>>>>>>>>>        Move (Pos(".",sFmt)) to iPos                 // position of decimal
94656>>>>>>>>>
94656>>>>>>>>>        // Move all the special literals back into place before parsing
94656>>>>>>>>>        Move (Replaces(Character(1),sFmt,"$")) to sFmt
94657>>>>>>>>>        Move (Replaces(Character(2),sFmt,".")) to sFmt
94658>>>>>>>>>        Move (Replaces(Character(3),sFmt,",")) to sFmt
94659>>>>>>>>>        Move (Replaces(Character(4),sFmt,"/")) to sFmt
94660>>>>>>>>>        Move (Replaces(Character(5),sFmt,"#")) to sFmt
94661>>>>>>>>>
94661>>>>>>>>>        If (iPos>0) Begin                      // if we have a decimanl point
94663>>>>>>>>>            Move 1 to i                        // look for first non # to right and count the #s
94664>>>>>>>>>            If (mid(sFmt,1,iPos+i)="*") Begin  // the "*" is special. It means as many as you want
94666>>>>>>>>>               Move -2 to iDigits
94667>>>>>>>>>               increment i
94668>>>>>>>>>            end
94668>>>>>>>>>>
94668>>>>>>>>>            While (mid(sFmt,1,iPos+i)=sDigit)
94672>>>>>>>>>                 Increment i
94673>>>>>>>>>            end
94674>>>>>>>>>>
94674>>>>>>>>>            Move (Mid(sFmt,255,iPos+i)) to sRight // everything to the right of the last # is format stuff
94675>>>>>>>>>            If (iDigits=0) Move (i-1) to iDigits
94678>>>>>>>>>            //
94678>>>>>>>>>            Move 1 to i                           // find the first non-# to the left of the point
94679>>>>>>>>>            While (mid(sFmt,1,iPos-i)=sDigit)     // everything to the left is format stuff
94683>>>>>>>>>                 increment i
94684>>>>>>>>>            end
94685>>>>>>>>>>
94685>>>>>>>>>            Move (left(sFmt,iPos-i)) to sLeft
94686>>>>>>>>>        end
94686>>>>>>>>>>
94686>>>>>>>>>        else begin                             // we have no decinal
94687>>>>>>>>>            Move 0 to iDigits                  // so points is none
94688>>>>>>>>>            Move (Pos(sDigit,sFmt)) to iPos    // find first #.
94689>>>>>>>>>            If (iPos=0) Begin                  // if none, entire string is left format stuff..wierd!
94691>>>>>>>>>                Move sFmt to sLeft
94692>>>>>>>>>                Move ""   to sRight
94693>>>>>>>>>            end
94693>>>>>>>>>>
94693>>>>>>>>>            else begin
94694>>>>>>>>>                Move (left(sFmt,iPos-1)) to sLeft // all char to left of first # is left format stuff
94695>>>>>>>>>                Move 1 to i
94696>>>>>>>>>                While (mid(sFmt,1,iPos+i)=sDigit) // find last #, all char to right is right format
94700>>>>>>>>>                    Increment i
94701>>>>>>>>>                end
94702>>>>>>>>>>
94702>>>>>>>>>                Move (Mid(sFmt,255,i+iPos)) to sRight
94703>>>>>>>>>            end
94703>>>>>>>>>>
94703>>>>>>>>>        end
94703>>>>>>>>>>
94703>>>>>>>>>        // set temporary format properties and exit
94703>>>>>>>>>        Set pbThousandsSep to bSep
94704>>>>>>>>>        set psLeft         to sLeft
94705>>>>>>>>>        set psRight        to sRight
94706>>>>>>>>>        Set piPoints       to iDigits
94707>>>>>>>>>     End_procedure
94708>>>>>>>>>
94708>>>>>>>>>    // Public: Sets a format string. Pass full format for Positve and negative in sFmt. Pass
94708>>>>>>>>>    //         bCurrency true is this is a currency format, false if a numeric format
94708>>>>>>>>>    //
94708>>>>>>>>>    //  e.g. Send SetFormat "$,#.##;($,#.##)" True
94708>>>>>>>>>    //
94708>>>>>>>>>    Procedure SetFormat string sFmt integer bCurrency
94710>>>>>>>>>        string sPos sNeg
94710>>>>>>>>>        integer iPos
94710>>>>>>>>>
94710>>>>>>>>>        Move (Pos(";",sFmt)) to iPos
94711>>>>>>>>>        If iPos begin
94713>>>>>>>>>            Move (left(sFmt,iPos-1))    to sPos
94714>>>>>>>>>            Move (mid(sFmt,255,iPos+1)) to sNeg
94715>>>>>>>>>        end
94715>>>>>>>>>>
94715>>>>>>>>>        else Begin
94716>>>>>>>>>            Move sFmt         to sPos
94717>>>>>>>>>            Move ("-" + sFmt) to sNeg
94718>>>>>>>>>        end
94718>>>>>>>>>>
94718>>>>>>>>>        Send ParseFormat sPos
94719>>>>>>>>>        If bCurrency begin
94721>>>>>>>>>            Set pbCurPosThousandsSep to (pbThousandsSep(self))
94722>>>>>>>>>            set psCurPosLeft         to (psLeft(self))
94723>>>>>>>>>            set psCurPosRight        to (psRight(self))
94724>>>>>>>>>            Set piCurPosPoints       to (piPoints(self))
94725>>>>>>>>>        End
94725>>>>>>>>>>
94725>>>>>>>>>        else Begin
94726>>>>>>>>>            Set pbNumPosThousandsSep to (pbThousandsSep(self))
94727>>>>>>>>>            set psNumPosLeft         to (psLeft(self))
94728>>>>>>>>>            set psNumPosRight        to (psRight(self))
94729>>>>>>>>>            Set piNumPosPoints       to (piPoints(self))
94730>>>>>>>>>        end
94730>>>>>>>>>>
94730>>>>>>>>>
94730>>>>>>>>>        Send ParseFormat sNeg
94731>>>>>>>>>        If bCurrency begin
94733>>>>>>>>>            Set pbCurNegThousandsSep to (pbThousandsSep(self))
94734>>>>>>>>>            set psCurNegLeft         to (psLeft(self))
94735>>>>>>>>>            set psCurNegRight        to (psRight(self))
94736>>>>>>>>>            Set piCurNegPoints       to (piPoints(self))
94737>>>>>>>>>        End
94737>>>>>>>>>>
94737>>>>>>>>>        else Begin
94738>>>>>>>>>            Set pbNumNegThousandsSep to (pbThousandsSep(self))
94739>>>>>>>>>            set psNumNegLeft         to (psLeft(self))
94740>>>>>>>>>            set psNumNegRight        to (psRight(self))
94741>>>>>>>>>            Set piNumNegPoints       to (piPoints(self))
94742>>>>>>>>>        end
94742>>>>>>>>>>
94742>>>>>>>>>    End_procedure
94743>>>>>>>>>
94743>>>>>>>>>    // low level formatting. Pass parameters
94743>>>>>>>>>    Function Format_Num number nNumber integer iPoints integer bSep ;                       string sPrefix string sSuffix returns string
94745>>>>>>>>>        string  sLeft sRight sNumber sSep sDec
94745>>>>>>>>>        integer bIsNegative iDec iLen iCh
94745>>>>>>>>>
94745>>>>>>>>>        Get_Attribute DF_DECIMAL_SEPARATOR to iCh
94748>>>>>>>>>        Move (Character(iCh)) to sDec
94749>>>>>>>>>
94749>>>>>>>>>        Move (abs(nNumber)) to sNumber
94750>>>>>>>>>        Move (Pos(sDec,sNumber)) to iDec
94751>>>>>>>>>        Move (If(iDec=0, sNumber, left(sNumber,iDec-1))) to sLeft
94752>>>>>>>>>        Move (If(iDec=0, "", mid(sNumber,255,iDec+1)))   to sRight
94753>>>>>>>>>        // format for decimal separator
94753>>>>>>>>>        If (iPoints>=0) ; // if -2, leave it alone, it should not be -1            Move (left(sRight+repeat("0",iPoints),iPoints)) to sRight
94756>>>>>>>>>
94756>>>>>>>>>        // format for thousand sep.
94756>>>>>>>>>        If bSep Begin
94758>>>>>>>>>            Get_Attribute DF_THOUSANDS_SEPARATOR to iCh
94761>>>>>>>>>            Move (Character(iCh)) to sSep
94762>>>>>>>>>            Move (Length(sLeft)) to iLen
94763>>>>>>>>>            While (iLen>3)
94767>>>>>>>>>                Move (insert(sSep,sLeft,iLen-2)) to sLeft
94768>>>>>>>>>                Move (iLen-3) to iLen
94769>>>>>>>>>            End
94770>>>>>>>>>>
94770>>>>>>>>>        End
94770>>>>>>>>>>
94770>>>>>>>>>        // if decimal points or -2 (allow anything) and there are points to show
94770>>>>>>>>>        If (iPoints>0 OR (iPoints=-2 AND sRight<>"")) ;            Move (sLeft + sDec + sright) to sLeft
94773>>>>>>>>>        Function_return (sPrefix + sLeft+ sSuffix)
94774>>>>>>>>>    End_Function
94775>>>>>>>>>
94775>>>>>>>>>    // Public: Format for currency
94775>>>>>>>>>    //
94775>>>>>>>>>    Function FormatCur number nNumber integer iPoints returns string
94777>>>>>>>>>        string  sLeft sRight
94777>>>>>>>>>        integer bSep
94777>>>>>>>>>        If (nNumber<0) Begin
94779>>>>>>>>>            get pbCurNegThousandsSep to bSep
94780>>>>>>>>>            get psCurNegLeft         to sLeft
94781>>>>>>>>>            get psCurNegRight        to sRight
94782>>>>>>>>>            If (iPoints=-1) get piCurNegPoints       to iPoints
94785>>>>>>>>>        end
94785>>>>>>>>>>
94785>>>>>>>>>        Else Begin
94786>>>>>>>>>            get pbCurPosThousandsSep to bSep
94787>>>>>>>>>            get psCurPosLeft         to sLeft
94788>>>>>>>>>            get psCurPosRight        to sRight
94789>>>>>>>>>            If (iPoints=-1) get piCurPosPoints       to iPoints
94792>>>>>>>>>        end
94792>>>>>>>>>>
94792>>>>>>>>>        Function_return (Format_Num(self, nNumber,iPoints,bSep,sLeft,sRight))
94793>>>>>>>>>    End_function
94794>>>>>>>>>
94794>>>>>>>>>    // Public: Format for numeric
94794>>>>>>>>>    //
94794>>>>>>>>>    Function FormatNum number nNumber integer iPoints returns string
94796>>>>>>>>>        string  sLeft sRight
94796>>>>>>>>>        integer bSep
94796>>>>>>>>>        If (nNumber<0) Begin
94798>>>>>>>>>            get pbNumNegThousandsSep to bSep
94799>>>>>>>>>            get psNumNegLeft         to sLeft
94800>>>>>>>>>            get psNumNegRight        to sRight
94801>>>>>>>>>            If (iPoints=-1) get piNumNegPoints       to iPoints
94804>>>>>>>>>        end
94804>>>>>>>>>>
94804>>>>>>>>>        Else Begin
94805>>>>>>>>>            get pbNumPosThousandsSep to bSep
94806>>>>>>>>>            get psNumPosLeft         to sLeft
94807>>>>>>>>>            get psNumPosRight        to sRight
94808>>>>>>>>>            If (iPoints=-1) get piNumPosPoints       to iPoints
94811>>>>>>>>>        end
94811>>>>>>>>>>
94811>>>>>>>>>        Function_return (Format_Num(self, nNumber,iPoints,bSep,sLeft,sRight))
94812>>>>>>>>>    End_function
94813>>>>>>>>>
94813>>>>>>>>>
94813>>>>>>>>>    // Public: Format passing format string
94813>>>>>>>>>    //
94813>>>>>>>>>    Function FormatVal number nNumber string sFmt returns string
94815>>>>>>>>>        integer iPos bIsNeg
94815>>>>>>>>>        string  sLeft sRight
94815>>>>>>>>>        integer iPoints bSep
94815>>>>>>>>>        Move (nNumber<0) to bIsNeg
94816>>>>>>>>>        Move (Pos(";",sFmt)) to iPos
94817>>>>>>>>>        Case Begin
94817>>>>>>>>>            Case (iPos and Not(bIsNeg))      Move (left(sFmt,iPos-1))    to sFmt
94820>>>>>>>>>            Case (iPos and bIsNeg)           Move (mid(sFmt,255,iPos+1)) to sFmt
94824>>>>>>>>>            Case (not(iPos) and not(bIsNeg)) Move sFmt                   to sFmt
94828>>>>>>>>>            Case else                        Move ("-" + sFmt)           to sFmt
94830>>>>>>>>>        case end
94830>>>>>>>>>        Send ParseFormat sFmt
94831>>>>>>>>>        get pbThousandsSep to bSep
94832>>>>>>>>>        get psLeft         to sLeft
94833>>>>>>>>>        get psRight        to sRight
94834>>>>>>>>>        get piPoints       to iPoints
94835>>>>>>>>>        Function_return (Format_Num(self, nNumber,iPoints,bSep,sLeft,sRight))
94836>>>>>>>>>    end_function
94837>>>>>>>>>
94837>>>>>>>>>End_Class
