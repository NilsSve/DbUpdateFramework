90519>>>    Procedure SetAllIndexesToBatch Handle hTable
90521>>>        Integer iLastIndex iIndex iNumSegments iIndexType
90521>>>        String sTable
90521>>>    
90521>>>        If (hTable > 0) Begin
90523>>>            Close hTable
90524>>>            Open hTable Mode DF_EXCLUSIVE
90526>>>            Get_Attribute DF_FILE_LAST_INDEX_NUMBER of hTable to iLastIndex
90529>>>            for iIndex from 1 to iLastIndex
90535>>>>
90535>>>                Get_Attribute DF_INDEX_NUMBER_SEGMENTS of hTable iIndex to iNumSegments
90538>>>                If (iNumSegments > 0) Begin
90540>>>                    Set_Attribute DF_INDEX_TYPE of hTable iIndex to DF_INDEX_TYPE_BATCH
90543>>>                End
90543>>>>
90543>>>            Loop
90544>>>>
90544>>>            Close hTable
90545>>>        End
90545>>>>
90545>>>    End_Procedure 
