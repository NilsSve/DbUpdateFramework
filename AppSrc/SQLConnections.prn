79700>>>>>Type vtShFileOpStruct
79700>>>>>  Field vtShFileOpStruct.hWnd                   as Handle
79700>>>>>  Field vtShFileOpStruct.wFunc                  as Integer
79700>>>>>  Field vtShFileOpStruct.pFrom                  as Pointer
79700>>>>>  Field vtShFileOpStruct.pTo                    as Pointer
79700>>>>>  Field vtShFileOpStruct.fFlags                 as Short
79700>>>>>  Field vtShFileOpStruct.fAnyOperationsAborted  as Short
79700>>>>>  Field vtShFileOpStruct.hNameMappings          as Pointer
79700>>>>>  Field vtShFileOpStruct.lpszProgressTitle      as Pointer // only used if FOF_SIMPLEPROGRESS
79700>>>>>End_Type // tShFileOpStruct
79700>>>>>
79700>>>>>// hwnd
79700>>>>>//   Handle of the dialog box to use to display information about the status of the operation.
79700>>>>>
79700>>>>>// wFunc
79700>>>>>//   Operation to perform. This member can be one of the following values:
79700>>>>>//     FO_COPY     Copies the files specified by pFrom to the location specified by pTo.
79700>>>>>//     FO_DELETE   Deletes the files specified by pFrom (pTo is ignored).
79700>>>>>//     FO_MOVE     Moves the files specified by pFrom to the location specified by pTo.
79700>>>>>//     FO_RENAME   Renames the files specified by pFrom.
79700>>>>>
79700>>>>>// pFrom
79700>>>>>//   Pointer to a buffer that specifies one or more source file names. Multiple names must
79700>>>>>//   be null-separated. The list of names must be double null-terminated.
79700>>>>>
79700>>>>>// pTo
79700>>>>>//   Pointer to a buffer that contains the name of the destination file or directory. The
79700>>>>>//   buffer can contain mutiple destination file names if the fFlags member specifies
79700>>>>>//   FOF_MULTIDESTFILES. Multiple names must be null-separated. The list of names must be
79700>>>>>//   double null-terminated.
79700>>>>>
79700>>>>>// fAnyOperationsAborted
79700>>>>>//   Value that receives TRUE if the user aborted any file operations before they
79700>>>>>//   were completed or FALSE otherwise.
79700>>>>>
79700>>>>>
79700>>>>>// Performs a copy, move, rename, or delete operation on a file system object.
79700>>>>>// This can be a file or a folder.
79700>>>>>// With thanks to Andrew S Kaplan
79700>>>>>External_function vWin32_SHFileOperation "SHFileOperationA" Shell32.dll ;        Pointer lpFileOp Returns Integer
