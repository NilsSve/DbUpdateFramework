96240>>>>>>>    Procedure Search
96242>>>>>>>        Send Activate // give focus back to list so focus things are correct
96243>>>>>>>        Send Request_Search 0 0
96244>>>>>>>    End_Procedure
96245>>>>>>>    
96245>>>>>>>    // do a search using the current keys in the search key buffer for the sort column.
96245>>>>>>>    // Becaue this is called via an OnIdle it is possible to have multiple keys pressed before
96245>>>>>>>    // the OnIdle. These have been stored in pSearchKeys and will be passed to the popup dialog
96245>>>>>>>    Procedure Request_SearchEx
96247>>>>>>>        tGridKeyPair[] Keys
96247>>>>>>>        tGridKeyPair[] Keys
96248>>>>>>>        Integer iCol
96248>>>>>>>        Handle hoCol hoSearchDialog 
96248>>>>>>>        Boolean bOk
96248>>>>>>>        String sValue
96248>>>>>>>
96248>>>>>>>        Get piSortColumn to iCol
96249>>>>>>>        If (iCol<>-1) Begin
96251>>>>>>>            Get ColumnObject iCol to hoCol
96252>>>>>>>                Get pSearchKeys to Keys
96253>>>>>>>            Get CreateGridSearchDialogObject to hoSearchDialog
96254>>>>>>>            Get RequestGridSearchEx of hoSearchDialog Keys hoCol (&sValue) to bOk
96255>>>>>>>            If bOk Begin
96257>>>>>>>               Send RequestFindColumnValue iCol sValue True 0  
96258>>>>>>>            End
96258>>>>>>>>
96258>>>>>>>            Send Destroy of hoSearchDialog
96259>>>>>>>        End
96259>>>>>>>>
96259>>>>>>>        Send ClearSearchRequest // clear the search keys
96260>>>>>>>    End_Procedure
96261>>>>>>>    
96261>>>>>>>    // set pbRequestSearch to true and add the keys to the search buffer.
96261>>>>>>>    Procedure AddToSearchKeys Integer iKeyCode Integer iShiftCode
96263>>>>>>>        tGridKeyPair[] Keys
96263>>>>>>>        tGridKeyPair[] Keys
96264>>>>>>>        tGridKeyPair KeyPair
96264>>>>>>>        tGridKeyPair KeyPair
96264>>>>>>>        Set pbRequestSearch to True
96265>>>>>>>        Move iKeyCode to KeyPair.KeyCode
96266>>>>>>>        Move iShiftCode to KeyPair.ShiftCode
96267>>>>>>>        Get pSearchKeys to Keys                
96268>>>>>>>        Move KeyPair to Keys[SizeOfArray(Keys)]
96269>>>>>>>        Set pSearchKeys to Keys                
96270>>>>>>>    End_Procedure
96271>>>>>>>
96271>>>>>>>    Procedure ClearSearchRequest
96273>>>>>>>        tGridKeyPair[] SearchKeys
96273>>>>>>>        tGridKeyPair[] SearchKeys
96274>>>>>>>        Set pSearchKeys to SearchKeys
96275>>>>>>>        Set pbRequestSearch to False
96276>>>>>>>    End_Procedure
