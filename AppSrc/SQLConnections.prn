89539>>>    Function SqlEnumerateEsqlMertech String sStmt Returns String[]
89541>>>        String[] sReturnArray
89542>>>        String sValue sUserID sPassword 
89542>>>        Handle hoSQLHandler hoSQLConnect hStmt
89542>>>        Integer iFetchResult iRows
89542>>>        tSQLConnection SQLConnection
89542>>>        tSQLConnection SQLConnection
89542>>>        
89542>>>        Get _MertechSQLManagerHandle to hoSQLHandler
89543>>>
89543>>>        If (hoSQLHandler <> 0) Begin 
89545>>>            Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
89546>>>            Get SQLConnect of hoSQLHandler SQLConnection.sDriverID SQLConnection.sServer SQLConnection.sUserID SQLConnection.sPassword to hoSQLConnect
89547>>>            
89547>>>            If (hoSQLConnect <> 0) Begin   
89549>>>                Get SQLOpen of hoSQLConnect to hStmt
89550>>>                If (hStmt <> 0) Begin                                   
89552>>>                    Send SqlExecDirect of hStmt sStmt                                             
89553>>>                    Get SqlStmtAttribute of hStmt SqlSTMTATTRIB_ROWCOUNT to iRows
89554>>>                    Repeat
89554>>>>
89554>>>                        Get SQLFetch of hStmt to iFetchResult
89555>>>                        If (iFetchResult <> 0) Begin
89557>>>                            Get SQLColumnValue of hStmt 1 to sValue
89558>>>                            Move (Trim(sValue)) to sReturnArray[SizeOfArray(sReturnArray)
89559>>>                        End
89559>>>>
89559>>>                    Until (iFetchResult = 0)
89561>>>                    Send SQLClose of hStmt
89562>>>                End
89562>>>>
89562>>>                Send SQLDisconnect of hoSQLConnect    
89563>>>            End
89563>>>>
89563>>>        End
89563>>>>
89563>>>    
89563>>>        Function_Return sReturnArray
89564>>>    End_Function 
