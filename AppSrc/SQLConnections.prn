81359>>>>>>>>>>>>>/// @Name        DF_FETCH_FIELD_COUNT
81359>>>>>>>>>>>>>/// @Description This attribute is used to get the number of fields or columns
81359>>>>>>>>>>>>>/// in the given table. Note that this is referring to the columns in the SQL
81359>>>>>>>>>>>>>/// backend and may not necessarily reflect the number of columns in DataFlex.
81359>>>>>>>>>>>>>///
81359>>>>>>>>>>>>>/// This is a readonly attribute.
81359>>>>>>>>>>>>>///
81359>>>>>>>>>>>>>/// @Assumptions
81359>>>>>>>>>>>>>/// @Status      Public
81359>>>>>>>>>>>>>/// @Drivers     MsSQLFlex MySQLFlex
81359>>>>>>>>>>>>>/// @VersionNote Last Revised: 2013-08-14 by Aaron Gulack
81359>>>>>>>>>>>>>/// @See
81359>>>>>>>>>>>>>/// @INTOPT
81359>>>>>>>>>>>>>///
81359>>>>>>>>>>>>>/// @Syntax Get_Attribute DF_FETCH_FIELD_COUNT of {FileNumber} to {variable}
81359>>>>>>>>>>>>>/// @Param  FileNumber            Number of the file
81359>>>>>>>>>>>>>/// @Param  variable              Name of the Tablespace.
81359>>>>>>>>>>>>>/// @Example
81359>>>>>>>>>>>>>
81359>>>>>>>>>>>>>/// Get_Attribute DF_FETCH_FIELD_COUNT of hFile To "INDXS"
81359>>>>>>>>>>>>>Define DF_FETCH_FIELD_COUNT                         For (DF_FILE_RECORD_REREAD+13)
81359>>>>>>>>>>>>>
81359>>>>>>>>>>>>>//=============================================================================
81359>>>>>>>>>>>>>/// @Name        DF_FILE_TABLESPACE_NAME
81359>>>>>>>>>>>>>/// @Description A tablespace is a container of segments (objects that have an
81359>>>>>>>>>>>>>/// allotted amount of space), i.e. tables and indexes. This attribute is
81359>>>>>>>>>>>>>/// used to get or set the name of the tablespace being used for the data tables.
81359>>>>>>>>>>>>>/// To set or get the tablespace name for indexes, use the DF_FILE_INDEXTABLESPACE_NAME
81359>>>>>>>>>>>>>/// attribute. Setting the tablespace name can only be done during a Structure_Start
81359>>>>>>>>>>>>>/// (during table creation).  Getting the name, however can be done at
81359>>>>>>>>>>>>>/// anytime.  Note that when setting the tablespace name, it must be set to an
81359>>>>>>>>>>>>>/// already existing tablespace, this attribute does not create the tablespace itself.
81359>>>>>>>>>>>>>/// Even though MYSQL uses tablespaces, this this attribute is only supported
81359>>>>>>>>>>>>>/// in Oracle and PostgreSQL.
81359>>>>>>>>>>>>>///
81359>>>>>>>>>>>>>/// @Assumptions
81359>>>>>>>>>>>>>/// @Status      Public
81359>>>>>>>>>>>>>/// @Drivers     ORAFlex PGFlex
81359>>>>>>>>>>>>>/// @VersionNote Last Revised: 2013-07-25 by Aaron Gulack
81359>>>>>>>>>>>>>/// @See         DF_FILE_INDEXTABLESPACE_NAME
81359>>>>>>>>>>>>>/// @INTOPT
81359>>>>>>>>>>>>>///
81359>>>>>>>>>>>>>/// @Syntax Get_Attribute DF_FILE_TABLESPACE_NAME of {FileNumber} to {variable}
81359>>>>>>>>>>>>>/// @Syntax Set_Attribute DF_FILE_TABLESPACE_NAME of {FileNumber} to {variable}
81359>>>>>>>>>>>>>/// @Param  FileNumber            Number of the file
81359>>>>>>>>>>>>>/// @Param  variable              Name of the Tablespace.
81359>>>>>>>>>>>>>/// @Example
81359>>>>>>>>>>>>>/// Handle hFile
81359>>>>>>>>>>>>>/// move 0 to hFile
81359>>>>>>>>>>>>>/// Structure_Start hFile "ORA_DRV"
81359>>>>>>>>>>>>>///     Set_Attribute DF_FILE_TABLESPACE_NAME      of hFile To "USERS"
81359>>>>>>>>>>>>>///     Set_Attribute DF_FILE_INDEXTABLESPACE_NAME of hFile To "INDXS"
81359>>>>>>>>>>>>>///
81359>>>>>>>>>>>>>///             // More table creation here
81359>>>>>>>>>>>>>///
81359>>>>>>>>>>>>>/// Structure_End hFile DF_STRUCTEND_OPT_NONE "." 0
81359>>>>>>>>>>>>>Define DF_FILE_TABLESPACE_NAME                      For (DF_FILE_RECORD_REREAD+14)
81359>>>>>>>>>>>>>
81359>>>>>>>>>>>>>// TODO: This is probably deprecated. Investigate.
81359>>>>>>>>>>>>>Define DF_FETCH_FIELDNUMBER                         For (DF_FILE_RECORD_REREAD+15)
81359>>>>>>>>>>>>>
81359>>>>>>>>>>>>>//=============================================================================
81359>>>>>>>>>>>>>/// @Name        DF_FILE_INDEXTABLESPACE_NAME
81359>>>>>>>>>>>>>/// @Description This attribute is used to get or set the name of the tablespace
81359>>>>>>>>>>>>>/// being used for the index segment of a database. For a description of tablespaces,
81359>>>>>>>>>>>>>/// see the description above for DF_FILE_TABLESPACE_NAME. Similar to the Tablespace
81359>>>>>>>>>>>>>/// name attribute, setting the index tablespace name can only be done during creation
81359>>>>>>>>>>>>>/// and must use an already existing tablespace as the variable. This attribute is
81359>>>>>>>>>>>>>/// only available for Oracle and Postgre.
81359>>>>>>>>>>>>>///
81359>>>>>>>>>>>>>/// @Assumptions
81359>>>>>>>>>>>>>/// @Status      Public
81359>>>>>>>>>>>>>/// @Drivers     ORAFlex PGFlex
81359>>>>>>>>>>>>>/// @VersionNote Last Revised: 2013-07-25 by Aaron Gulack
81359>>>>>>>>>>>>>/// @See         DF_FILE_TABLESPACE_NAME
81359>>>>>>>>>>>>>/// @INTOPT
81359>>>>>>>>>>>>>///
81359>>>>>>>>>>>>>/// @Syntax Get_Attribute DF_FILE_INDEXTABLESPACE_NAME of {File Number} to {variable}
81359>>>>>>>>>>>>>/// @Syntax Set_Attribute DF_FILE_INDEXTABLESPACE_NAME of {File Number} to {variable}
81359>>>>>>>>>>>>>/// @Param  FileNumber            Number of the file
81359>>>>>>>>>>>>>/// @Param  variable              Name of the Tablespace
81359>>>>>>>>>>>>>/// @Example
81359>>>>>>>>>>>>>/// Handle hFile
81359>>>>>>>>>>>>>/// move 0 to hFile
81359>>>>>>>>>>>>>/// Structure_Start hFile "ORA_DRV"
81359>>>>>>>>>>>>>///     Set_Attribute DF_FILE_TABLESPACE_NAME      of hFile To "USERS"
81359>>>>>>>>>>>>>///     Set_Attribute DF_FILE_INDEXTABLESPACE_NAME of hFile To "INDXS"
81359>>>>>>>>>>>>>///
81359>>>>>>>>>>>>>///             // More table creation here
81359>>>>>>>>>>>>>///             //
81359>>>>>>>>>>>>>/// Structure_End hFile DF_STRUCTEND_OPT_NONE "." 0
81359>>>>>>>>>>>>>Define DF_FILE_INDEXTABLESPACE_NAME                 For (DF_FILE_RECORD_REREAD+16)
81359>>>>>>>>>>>>>
81359>>>>>>>>>>>>>//=============================================================================
81359>>>>>>>>>>>>>/// @Name        DF_FILE_RETRIEVE_RECNUM
81359>>>>>>>>>>>>>/// @Description When creating records on a table with RECNUM support, the
81359>>>>>>>>>>>>>/// record number is returned after creation. When this attribute is false, the newly
81359>>>>>>>>>>>>>/// created record's RECNUM is not returned from the server. This could result in a
81359>>>>>>>>>>>>>/// slight performance improvement when many records are being created in a loop.
81359>>>>>>>>>>>>>/// The optimization, however, is negligible.  Having this attribute set to false can
81359>>>>>>>>>>>>>/// have detrimental effects if used improperly; i.e. DD-based saves or UI-based
81359>>>>>>>>>>>>>/// operations. Thus, this should almost always be set to true unless there is a
81359>>>>>>>>>>>>>/// compelling reason to do otherwise.
81359>>>>>>>>>>>>>///
81359>>>>>>>>>>>>>/// Default Value: True
81359>>>>>>>>>>>>>///
81359>>>>>>>>>>>>>/// @Assumptions
81359>>>>>>>>>>>>>/// @Status      Public
81359>>>>>>>>>>>>>/// @Drivers     All
81359>>>>>>>>>>>>>/// @VersionNote Last Revised: 2013-07-31 by Aaron Gulack
81359>>>>>>>>>>>>>/// @See
81359>>>>>>>>>>>>>/// @INTOPT
81359>>>>>>>>>>>>>///
81359>>>>>>>>>>>>>/// @Syntax Get_Attribute DF_FILE_RETRIEVE_RECNUM of {FileNumber} to {variable}
81359>>>>>>>>>>>>>/// @Syntax Set_Attribute DF_FILE_RETRIEVE_RECNUM of {FileNumber} to {variable}
81359>>>>>>>>>>>>>/// @Param  FileNumber            Number of the file
81359>>>>>>>>>>>>>/// @Param  variable              Boolean variable. false to not retrieve record number, true otherwise.
81359>>>>>>>>>>>>>
81359>>>>>>>>>>>>>/// @Example
81359>>>>>>>>>>>>>/// open ORDERHEA
81359>>>>>>>>>>>>>/// Handle  hFile
81359>>>>>>>>>>>>>/// Boolean bRetrieve
81359>>>>>>>>>>>>>///
81359>>>>>>>>>>>>>/// Set_Attribute DF_FILE_RETRIEVE_RECNUM of hFile to false
81359>>>>>>>>>>>>>/// Get_Attribute DF_FILE_RETRIEVE_RECNUM of hFile To bRetrieve
81359>>>>>>>>>>>>>Define DF_FILE_RETRIEVE_RECNUM                      For (DF_FILE_RECORD_REREAD+17)
81359>>>>>>>>>>>>>
81359>>>>>>>>>>>>>//=============================================================================
81359>>>>>>>>>>>>>/// @Name        DF_FILE_NAME_SPACE
81359>>>>>>>>>>>>>/// @Description In Postgres, schemas are objects where all the tables,views and indexes
81359>>>>>>>>>>>>>/// are stored. Separate schemas are used to specify relational data. This attribute is
81359>>>>>>>>>>>>>/// used to set the name of the schema where a table is created. Schema's do not account
81359>>>>>>>>>>>>>/// for any physical space but are merely used as theory to explain the order of a database.
81359>>>>>>>>>>>>>///
81359>>>>>>>>>>>>>/// @Assumptions
81359>>>>>>>>>>>>>/// @Status      Public
81359>>>>>>>>>>>>>/// @Drivers     PGFlex
81359>>>>>>>>>>>>>/// @VersionNote Last Revised: 2013-07-25 by Aaron Gulack
81359>>>>>>>>>>>>>/// @See
81359>>>>>>>>>>>>>/// @INTOPT
81359>>>>>>>>>>>>>///
81359>>>>>>>>>>>>>/// @Syntax Get_Attribute DF_FILE_NAME_SPACE of {FileNumber} to {variable}
81359>>>>>>>>>>>>>/// @Syntax Set_Attribute DF_FILE_NAME_SPACE of {FileNumber} to {variable}
81359>>>>>>>>>>>>>/// @Param  FileNumber            Number of the file
81359>>>>>>>>>>>>>/// @Param  variable              Name of the Schema
81359>>>>>>>>>>>>>/// @Example
81359>>>>>>>>>>>>>/// open ORDERHEA
81359>>>>>>>>>>>>>/// Handle hFile
81359>>>>>>>>>>>>>/// String sSchemaName
81359>>>>>>>>>>>>>///
81359>>>>>>>>>>>>>/// Set_Attribute DF_FILE_NAME_SPACE of hFile to "ORDERHEA"
81359>>>>>>>>>>>>>/// Get_Attribute DF_FILE_NAME_SPACE of hFile To sSchemaName
81359>>>>>>>>>>>>>Define DF_FILE_NAME_SPACE                           For (DF_FILE_RECORD_REREAD+18)
81359>>>>>>>>>>>>>
81359>>>>>>>>>>>>>// Currently does not serve any function. May be included in future versions.
81359>>>>>>>>>>>>>Define DF_FILE_STORAGE_PCTFREE                      For (DF_FILE_RECORD_REREAD+19)
81359>>>>>>>>>>>>>
81359>>>>>>>>>>>>>// Currently does not serve any function. May be included in future versions.
81359>>>>>>>>>>>>>Define DF_FILE_STORAGE_PCTUSED                      For (DF_FILE_RECORD_REREAD+21)
81359>>>>>>>>>>>>>
81359>>>>>>>>>>>>>// Currently does not serve any function. May be included in future versions.
81359>>>>>>>>>>>>>Define DF_FILE_STORAGE_INITIAL                      For (DF_FILE_RECORD_REREAD+23)
81359>>>>>>>>>>>>>
81359>>>>>>>>>>>>>// Currently does not serve any function. May be included in future versions.
81359>>>>>>>>>>>>>Define DF_FILE_STORAGE_NEXT                         For (DF_FILE_RECORD_REREAD+25)
81359>>>>>>>>>>>>>
81359>>>>>>>>>>>>>// Currently does not serve any function. May be included in future versions.
81359>>>>>>>>>>>>>Define DF_FILE_ALLOW_NULL                           For (DF_FILE_RECORD_REREAD+27)
