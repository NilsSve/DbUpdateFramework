84632>>>>>>>>>>>    Function DriverIndex String sDriver Returns Integer
84634>>>>>>>>>>>        String sCurrentDriver
84634>>>>>>>>>>>        Integer iDriver
84634>>>>>>>>>>>        Integer iNumDrivers
84634>>>>>>>>>>>     
84634>>>>>>>>>>>        Get_Attribute DF_NUMBER_DRIVERS to iNumDrivers
84637>>>>>>>>>>>        For iDriver from 1 to iNumDrivers
84643>>>>>>>>>>>>
84643>>>>>>>>>>>          Get_Attribute DF_DRIVER_NAME of iDriver to sCurrentDriver
84646>>>>>>>>>>>          If (Uppercase(sDriver) = Uppercase(sCurrentDriver)) ;              Function_Return iDriver
84649>>>>>>>>>>>        Loop
84650>>>>>>>>>>>>
84650>>>>>>>>>>>        Function_Return 0
84651>>>>>>>>>>>    End_Function // DriverIndex
84652>>>>>>>>>>> 
84652>>>>>>>>>>>    Function FirstServerForDriverNo Integer iDriver Returns String 
84654>>>>>>>>>>>        String sServer
84654>>>>>>>>>>>        Integer iNumServers
84654>>>>>>>>>>>        Integer iServer 
84654>>>>>>>>>>>        
84654>>>>>>>>>>>        If (iDriver <> 0) Begin
84656>>>>>>>>>>>            Get_Attribute DF_DRIVER_NUMBER_SERVERS of iDriver to iNumServers
84659>>>>>>>>>>>            If (iNumServers<>0) Begin
84661>>>>>>>>>>>                Move 1 to iServer
84662>>>>>>>>>>>                Get_Attribute DF_DRIVER_SERVER_NAME of iDriver iServer to sServer
84665>>>>>>>>>>>            End 
84665>>>>>>>>>>>>
84665>>>>>>>>>>>        End
84665>>>>>>>>>>>>
84665>>>>>>>>>>>        
84665>>>>>>>>>>>        Function_Return sServer
84666>>>>>>>>>>>    End_Function
84667>>>>>>>>>>>
84667>>>>>>>>>>>    Procedure Set CurrentConnection String sDriver String sServer
84669>>>>>>>>>>>        Integer iDriver 
84669>>>>>>>>>>>        String sUsername 
84669>>>>>>>>>>>        String sPassword 
84669>>>>>>>>>>>        
84669>>>>>>>>>>>        If (sDriver="") Begin 
84671>>>>>>>>>>>            DO_GETFILENUMBER_DRIVERNAME 0
84673>>>>>>>>>>>            Move MertechInc_DriverName to sDriver
84674>>>>>>>>>>>        End
84674>>>>>>>>>>>>
84674>>>>>>>>>>>        
84674>>>>>>>>>>>        If ("MDSMYSQL|ORA_DRV|MDSPGSQL|SQL_DRV|MDS_DB2" contains Uppercase(Trim(sDriver))) Begin
84676>>>>>>>>>>>            Move (Uppercase(Trim(sDriver))) to MertechInc_DriverName
84677>>>>>>>>>>>            
84677>>>>>>>>>>>            If (Trim(sDriver) <> "") Move (Uppercase(Trim(sDriver))) to MertechInc_CurrentDriver
84680>>>>>>>>>>>            Else Move "" to MertechInc_CurrentDriver
84682>>>>>>>>>>>
84682>>>>>>>>>>>            Get psUsername to sUsername
84683>>>>>>>>>>>            Get psPassword to sPassword 
84684>>>>>>>>>>>            
84684>>>>>>>>>>>            Get DriverIndex MertechInc_CurrentDriver to iDriver
84685>>>>>>>>>>>            
84685>>>>>>>>>>>            If (sServer="") Get FirstServerForDriverNo iDriver to sServer
84688>>>>>>>>>>>            If (sUsername="") GET_CURRENT_USER_NAME of sServer to sUsername
84705>>>>>>>>>>>            If (sPassword="") get_current_user_password of sServer to sPassword
84722>>>>>>>>>>>            Move False to Err  
84723>>>>>>>>>>>            Send Ignore_Error of Error_Object_Id 25000
84724>>>>>>>>>>>            Login sServer sUsername sPassword sDriver
84726>>>>>>>>>>>            Send Trap_Error of Error_Object_Id 25000
84727>>>>>>>>>>>            If (Err = False) Begin
84729>>>>>>>>>>>                Call_Driver 0 MertechInc_DriverName Function CALLDRV_CURRENT_SQL_SERVER_CONNECTION CALLBACK 0 PASSING sServer MertechInc_Blank 0 RESULT MertechInc_iRet
84734>>>>>>>>>>>            End
84734>>>>>>>>>>>>
84734>>>>>>>>>>>            Else Begin
84735>>>>>>>>>>>                Procedure_Return
84736>>>>>>>>>>>            End
84736>>>>>>>>>>>>
84736>>>>>>>>>>>                
84736>>>>>>>>>>>            If MertechInc_iRet EQ -1 INDICATE ERR True
84739>>>>>>>>>>>        End
84739>>>>>>>>>>>>
84739>>>>>>>>>>>        Else Error 4099 "Invalid Driver"
84741>>>>>>>>>>>        
84741>>>>>>>>>>>    End_Procedure
84742>>>>>>>>>>>
84742>>>>>>>>>>>End_Class
