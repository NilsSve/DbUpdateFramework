93225>>>    // Internal usage. Use the UtilColumnTypeXXX functions instead.
93225>>>    Function _UtilColumnType String sDriverID Integer iDbType Integer iType String sType Boolean bIntegerInputType Returns tColumnType
93227>>>        Integer iValue iSize iCount iStart
93227>>>        tColumnType[] ColumnTypeArray   
93227>>>        tColumnType[] ColumnTypeArray   
93228>>>        tColumnType RetvalType 
93228>>>        tColumnType RetvalType 
93228>>>        String sValue
93228>>>        
93228>>>        Move "Undefined" to RetvalType.sType 
93229>>>        Move -1999       to RetvalType.iType
93230>>>        
93230>>>        Move 0 to iStart
93231>>>        Move (Uppercase(sType)) to sType            
93232>>>        
93232>>>        If (iType <= -1500) Begin
93234>>>            Move EN_dbTypeDataFlex to iDbType
93235>>>            Move DATAFLEX_ID       to sDriverID
93236>>>        End
93236>>>>
93236>>>
93236>>>        Get UtilEnumerateColumnTypes sDriverID iDbType to ColumnTypeArray
93237>>>        
93237>>>        Move (SizeOfArray(ColumnTypeArray)) to iSize 
93238>>>        Decrement iSize
93239>>>        
93239>>>        for iCount from iStart to iSize
93245>>>>
93245>>>            Move ColumnTypeArray[iCount].iType to iValue
93246>>>            Move ColumnTypeArray[iCount].sType to sValue 
93247>>>            If (bIntegerInputType = True) Begin
93249>>>                If (iValue = iType) Begin
93251>>>                    Move ColumnTypeArray[iCount].sType          to RetvalType.sType  
93252>>>                    Move iType                                  to RetvalType.iType
93253>>>                    Move ColumnTypeArray[iCount].sDataFlexType  to RetvalType.sDataFlexType
93254>>>                    Move ColumnTypeArray[iCount].iDataFlexType  to RetvalType.iDataFlexType
93255>>>                    Move ColumnTypeArray[iCount].sPrecision     to RetvalType.sPrecision
93256>>>                    Move ColumnTypeArray[iCount].bFixedSize     to RetvalType.bFixedSize
93257>>>                    Move iSize to iCount // We're done!
93258>>>                End
93258>>>>
93258>>>            End
93258>>>>
93258>>>            Else Begin
93259>>>                Move (Uppercase(sValue)) to sValue
93260>>>                If (sValue = sType) Begin
93262>>>                    Move sType                                  to RetvalType.sType
93263>>>                    Move ColumnTypeArray[iCount].iType          to RetvalType.iType 
93264>>>                    Move ColumnTypeArray[iCount].sDataFlexType  to RetvalType.sDataFlexType
93265>>>                    Move ColumnTypeArray[iCount].iDataFlexType  to RetvalType.iDataFlexType
93266>>>                    Move ColumnTypeArray[iCount].sPrecision     to RetvalType.sPrecision
93267>>>                    Move ColumnTypeArray[iCount].bFixedSize     to RetvalType.bFixedSize
93268>>>                    Move iSize to iCount // We're done!
93269>>>                End
93269>>>>
93269>>>            End
93269>>>>
93269>>>        Loop
93270>>>>
93270>>>        
93270>>>        Function_Return RetvalType
93271>>>    End_Function
93272>>>    
93272>>>    // *** Miscellaneous other functions ***
93272>>>    // Some of which can be used by both "Sqlxxx" and "Apixxx" functions.
93272>>>    //
93272>>>    
93272>>>    // Callback functionality used when e.g. calling driver functions directly.
93272>>>    Function Callback String sCallback_Text Integer iCallback_Type Returns Integer
93274>>>        Integer iRetval iPos iPerc
93274>>>        String sVal1 sVal2 
93274>>>        Number nReady nTotal 
93274>>>        
93274>>>        Send DoAdvance of ghoProgressBar           
93275>>>        
93275>>>        If (sCallback_Text contains "Copy records") Begin
93277>>>            Move CS_SQLCopyingData to sCallback_Text
93278>>>        End                                        
93278>>>>
93278>>>        If (sCallback_Text contains "Dropping index" or sCallback_Text contains "Temporary delete of all indices of table") Begin
93280>>>            Move (Replace("Dropping index", sCallback_Text, CS_SQLDeletingIndex)) to sCallback_Text 
93281>>>            Move (Replace("Temporary delete of all indices of table", sCallback_Text, CS_SQLDeletingIndex)) to sCallback_Text
93282>>>        End
93282>>>>
93282>>>        If (sCallback_Text contains "Creating index") Begin
93284>>>            Move (Replace("Creating index", sCallback_Text, CS_SQLCreatingIndex)) to sCallback_Text
93285>>>        End                                               
93285>>>>
93285>>>        
93285>>>        Case Begin
93285>>>            Case (iCallback_Type = DF_Message_Text) 
93287>>>                Set Message_Text of ghoStatusPanel to sCallback_Text  
93288>>>                Set Action_Text  of ghoStatusPanel to ""
93289>>>                Case Break
93290>>>            Case (iCallback_Type = DF_Message_Heading_1) 
93293>>>                Set Message_Text of ghoStatusPanel to sCallback_Text 
93294>>>                Set Action_Text  of ghoStatusPanel to ""
93295>>>                Case Break
93296>>>            Case (iCallback_Type = DF_Message_Heading_2) 
93299>>>                Set Message_Text of ghoStatusPanel to sCallback_Text 
93300>>>                Set Action_Text  of ghoStatusPanel to ""
93301>>>                Case Break
93302>>>            Case (iCallback_Type = DF_Message_Heading_3) 
93305>>>                Set Message_Text of ghoStatusPanel to sCallback_Text 
93306>>>                Set Action_Text  of ghoStatusPanel to ""
93307>>>                Case Break
93308>>>            Case (iCallback_Type = DF_Message_Heading_4) 
93311>>>                Set Message_Text of ghoStatusPanel to sCallback_Text 
93312>>>                Set Action_Text  of ghoStatusPanel to ""
93313>>>                Case Break
93314>>>            Case (iCallback_Type = DF_Message_Heading_5) 
93317>>>                Set Message_Text of ghoStatusPanel to sCallback_Text 
93318>>>                Set Action_Text  of ghoStatusPanel to ""
93319>>>                Case Break
93320>>>            Case (iCallback_Type = DF_Message_Warning) 
93323>>>                Send None
93324>>>                Case Break
93325>>>            Case (iCallback_Type = DF_Message_Progress_Title) 
93328>>>                Set Message_Text of ghoStatusPanel to sCallback_Text 
93329>>>                Set Action_Text  of ghoStatusPanel to ""
93330>>>                Case Break
93331>>>            Case (iCallback_Type = DF_Message_Progress_Value) 
93334>>>                //*** Interpret numbers
93334>>>                Move (Left(sCallback_Text, (Pos(",", sCallback_Text) - 1)))                       to nReady
93335>>>                Move (Right(sCallback_Text, (Length(sCallback_Text) - Pos(",", sCallback_Text)))) to nTotal
93336>>>                Move ((nReady / nTotal) * 100)                                                    to iPerc
93337>>>                Set Action_Text of ghoStatusPanel to (String(iPerc) * String("% (Total:") * String(nTotal) + ")")
93338>>>                Case Break
93339>>>            Case Else
93339>>>                Set Message_Text to ""
93340>>>                Set Action_Text  to ""    
93341>>>        Case End
93341>>>
93341>>>        Send ProcessEvents of ghoStatusPanel
93342>>>        Function_Return False
93343>>>    End_Function
93344>>>    
93344>>>    Function NextFreeFilelistSlot Returns Handle
93346>>>        Handle hTable
93346>>>        
93346>>>        Move 0 to hTable              
93347>>>        Get_Attribute DF_FILE_NEXT_EMPTY to hTable
93350>>>        
93350>>>        Function_Return hTable
93351>>>    End_Function
93352>>>    
93352>>>    // Returns the connection ID for the passed driver ID.
93352>>>    // Note: If more than one connection ID has been defined for the driver, the _last_
93352>>>    // connection ID will be returned.
93352>>>//    Function ConnectionID String sDriverID Returns String
93352>>>//        String sID
93352>>>//        Integer iDriver iNumConn iCount
93352>>>//        Handle hoCLI
93352>>>//
93352>>>//        Get psConnectionID to sID
93352>>>//        Function_Return sID
93352>>>//    End_Function
93352>>>    
93352>>>    // For debugging purposes. To print Sql statements as they are build...
93352>>>    Procedure DebugPrint String sStmt String sFileName
93354>>>        Integer iCh
93354>>>        Get Seq_Append_Output_Channel sFileName to iCh
93355>>>            Write channel iCh sStmt  
93357>>>        Send Seq_Close_Channel iCh
93358>>>    End_Procedure
93359>>>        
93359>>>    // Returns the integer number for the passed Driver ID that is 
93359>>>    // needed by some database API calls.
93359>>>    Function DriverIndex String sDriverID Returns Integer
93361>>>        String  sCurrentDriver
93361>>>        Integer iNumberOfDrivers iDriver iCount
93361>>>    
93361>>>        Move 0 to iDriver
93362>>>    
93362>>>        Get_Attribute DF_NUMBER_DRIVERS to iNumberOfDrivers
93365>>>        for iCount from 1 to iNumberOfDrivers
93371>>>>
93371>>>    
93371>>>            Get_Attribute DF_DRIVER_NAME of iCount to sCurrentDriver
93374>>>            If ( Uppercase(sCurrentDriver) = Uppercase(sDriverID) ) Begin
93376>>>                Move iCount to iDriver
93377>>>            End
93377>>>>
93377>>>        Loop
93378>>>>
93378>>>        
93378>>>        // In case it was not found, it wasn't loaded so we do that now.
93378>>>        If (iDriver = 0) Begin
93380>>>            Move False to Err
93381>>>            Load_Driver sDriverID
93382>>>            If (Err = False) Begin
93384>>>                Move 1 to iDriver
93385>>>            End
93385>>>>
93385>>>        End
93385>>>>
93385>>>    
93385>>>        Function_Return iDriver
93386>>>    End_Function 
93387>>>    
93387>>>    // Scans to see if all tables can be opened exclusivly. I.e. that nobody else is running the application.
93387>>>    // Returns: False if nobody else is running
93387>>>    //          True if at least one table is open by another process (e.g. another user is running the application) 
93387>>>    // N.B! Only works for Embedded DataFlex Tables! It will _not_ work for Sql tables because; these
93387>>>    //      tables are not locked as DataFlex tables are.
93387>>>    Function IsDatabaseInUse Returns Boolean
93389>>>        Handle  hTable
93389>>>        Integer iTemp
93389>>>        String  sRootName sOrgOpenPath sOrgFileList
93389>>>        Boolean bOpen bErr bAlias bOK bIsSQLTable
93389>>>
93389>>>        Get AutoConnectionIDLogin to bOK
93390>>>        Move 0 to hTable
93391>>>        Get_Attribute DF_FILE_NEXT_USED of hTable to hTable
93394>>>        Move False to bErr
93395>>>        Send Ignore_Error of Error_Object_Id DFERR_FILE_ACCESS_VIOLATION
93396>>>
93396>>>        Repeat
93396>>>>
93396>>>            Get_Attribute DF_FILE_ROOT_NAME of hTable to sRootName
93399>>>            
93399>>>            // This test is only applicable for DataFlex embedded tables; so skip test if driver based table.
93399>>>            Get UtilTableIsSQLByRootName sRootName to bIsSQLTable
93400>>>            Move False to bOpen
93401>>>            
93401>>>            // Don't bother about FlexErrs (Table 50)
93401>>>            If (bIsSQLTable = False and hTable <> 0 and hTable <> 50) Begin
93403>>>                Set Error_Report_Mode to DUF_ERROR_NO_REPORT
93404>>>                Open hTable 
93406>>>                Get_Attribute DF_FILE_OPENED of hTable to bOpen
93409>>>                Set Error_Report_Mode to DUF_ERROR_REPORT
93410>>>                If (bOpen = True) Begin                        
93412>>>                    // We cannot open an Alias file exclusive as it will generate an error (4177 - "File in use")
93412>>>                    Get UtilTableIsAlias hTable to bAlias
93413>>>                    If (bAlias = False) Begin
93415>>>                        Open hTable mode DF_EXCLUSIVE   
93417>>>                        Get_Attribute DF_FILE_OPENED of hTable to bOpen
93420>>>                        If (bOpen = False) Begin
93422>>>                            Move True to bErr
93423>>>                        End
93423>>>>
93423>>>                    End
93423>>>>
93423>>>                End
93423>>>>
93423>>>            End
93423>>>>
93423>>>            Get_Attribute DF_FILE_NEXT_USED of hTable to hTable
93426>>>            If (bOpen = False) Break
93429>>>        Until (not(hTable))
93431>>>
93431>>>        Send Trap_Error of Error_Object_Id DFERR_FILE_ACCESS_VIOLATION
93432>>>        Move False to Err
93433>>>        
93433>>>        Function_Return bErr
93434>>>    End_Function  
93435>>>    
93435>>>    // Checks if the passed connection id exists in the CLI interface.
93435>>>    // This might be needed by API-methods when a connection id is to be used and
93435>>>    // the connection id hasn't been established with the driver's CLI interface.
93435>>>    // NOTE: Only applicable for DAW drivers.
93435>>>    Function IsConnectionID String sConnectionID String sDriverID Returns Boolean
93437>>>        String sID 
93437>>>        Integer iDriver iNumConn iCount
93437>>>        Handle hoCLI                                            
93437>>>        Boolean bOK
93437>>>        
93437>>>        Get IsDAWSQLDriver sDriverID to bOK
93438>>>        If (bOK = False) Begin
93440>>>            Error DFERR_PROGRAM "Connection ID's can only be used with DAW drivers (not Mertech)."
93441>>>>
93441>>>            Function_Return False
93442>>>        End
93442>>>>
93442>>>        
93442>>>        Move False to bOK
93443>>>        Get phoCLIHandler to hoCLI 
93444>>>        If (hoCLI <> 0) Begin
93446>>>            Set psDriverID of hoCLI to sDriverID
93447>>>            Get DriverIndex of hoCLI sDriverID to iDriver
93448>>>            
93448>>>            // If driver not loaded; load it.
93448>>>            If (iDriver = 0) Begin
93450>>>                Load_Driver sDriverID
93451>>>                Get DriverIndex sDriverID to iDriver
93452>>>            End                      
93452>>>>
93452>>>            If (iDriver <> 0) Begin
93454>>>                Get_Attribute DF_DRIVER_NUMBER_CONNECTION_IDS of iDriver to iNumConn
93457>>>                Decrement iNumConn
93458>>>                For iCount from 0 to iNumConn
93464>>>>
93464>>>                    Get_Attribute DF_DRIVER_CONNECTION_ID of iDriver iCount to sID
93467>>>                    If (sID = sConnectionID) Move True to bOK
93470>>>                Loop
93471>>>>
93471>>>            End
93471>>>>
93471>>>        End
93471>>>>
93471>>>        
93471>>>        Function_Return bOK
93472>>>    End_Function                   
93473>>>    
93473>>>    Function IsDAWSQLDriver String sDriverID Returns Boolean
93475>>>        Boolean bOK
93475>>>        Move (sDriverID = MSSQLDRV_ID or sDriverID = DB2_DRV_ID or sDriverID = ODBC_DRV_ID) to bOK
93476>>>        Function_Return bOK
93477>>>    End_Function
93478>>>
93478>>>    Function IsMertechDriver String sDriverID Returns Boolean
93480>>>        Boolean bOK
93480>>>        Move False to bOK
93481>>>        Move (sDriverID = SQLFLEX or sDriverID = ORAFLEX or sDriverID = MDSPgSQL or sDriverID = MDSMySQL) to bOK
93482>>>        Function_Return bOK
93483>>>    End_Function
93484>>>            
93484>>>    Function IsMSSQLDriver Returns Boolean
93486>>>        Handle ho
93486>>>        Integer iDriverIndex
93486>>>        
93486>>>        Get DriverIndex MSSQLDRV_ID to iDriverIndex
93487>>>        
93487>>>        Function_Return (iDriverIndex <> 0)
93488>>>    End_Function
93489>>>        
93489>>>    // Similar to _SqlCheckCurrentDriver but generates no error and it doesn't 
93489>>>    // attempt to load the driver.
93489>>>    // Returns true if the passed driver is SQL based.        
93489>>>    Function IsSQLDriver String sDriverID Returns Boolean
93491>>>        Boolean bOK                         
93491>>>        Integer iDriver
93491>>>        
93491>>>        Get IsDAWSQLDriver sDriverID to bOK
93492>>>
93492>>>        If (bOK = False) Begin
93494>>>            Get IsMertechDriver sDriverID to bOK
93495>>>        End                                     
93495>>>>
93495>>>
93495>>>        Function_Return bOK
93496>>>    End_Function
93497>>>            
93497>>>    // *** Error Handler ***
93497>>>    //
93497>>>    // Note: If the cDbUpdateHandler & cDbUpdateVersion classes are used this error handler is _not_
93497>>>    //       used. Instead the Error_Report in the cDbUpdateHandler i used.
93497>>>    Procedure Error_Report Integer iErrorNumber Integer iErrorLine String sErrorText
93499>>>        String sText
93499>>>        Integer iSize iErrorMode
93499>>>        tSqlErrorArray aSqlErrorArray
93499>>>        tSqlErrorArray aSqlErrorArray
93499>>>        
93499>>>        If (pbProcessingError(Self)) Begin
93501>>>            Procedure_Return
93502>>>        End 
93502>>>>
93502>>>        
93502>>>        Get Error_Report_Mode to iErrorMode
93503>>>        If (iErrorMode = DUF_ERROR_NO_REPORT) Begin
93505>>>            Procedure_Return
93506>>>        End
93506>>>>
93506>>>
93506>>>        Set pbProcessingError to True
93507>>>        Set pbSqlError to True
93508>>>        Get paSqlErrorArray      to aSqlErrorArray
93509>>>        Move (SizeOfArray(aSqlErrorArray.sSqlErrorArray)) to iSize
93510>>>        Move sErrorText          to aSqlErrorArray.sSqlErrorArray[iSize]
93511>>>        Get psSQLStatementString to aSqlErrorArray.sSqlStatementArray[iSize]
93512>>>        Move iErrorNumber        to aSqlErrorArray.iSqlErrorArray[iSize]
93513>>>        Set paSqlErrorArray      to aSqlErrorArray
93514>>>        Set pbProcessingError to False
93515>>>    End_Procedure
93516>>>
93516>>>    // *** Miscellanous Helper Functions ***
93516>>>    //
93516>>>    // Helper function. Takes a DF_FILE_XXXX_NAME value as parameter and 
93516>>>    // returns the table name only; stripped of any path or filename extension.
93516>>>    Function _TableNameOnly String sName Returns String
93518>>>        String sPath sExt
93518>>>        
93518>>>        Get ParseFolderName sName to sPath
93519>>>        If (sPath <> "") Begin
93521>>>            Move (Replace(sPath, sName, "")) to sName
93522>>>        End                                                  
93522>>>>
93522>>>        Get ParseFileExtension sName to sExt
93523>>>        If (sExt <> "") Begin
93525>>>            Move (Replace(("." + sExt), sName, "")) to sName
93526>>>        End
93526>>>>
93526>>>        
93526>>>        Function_Return sName
93527>>>    End_Function
93528>>>
93528>>>    // Returns the first datapath found in the psDataPath property.
93528>>>    // The returned path always ends with a "\"
93528>>>    Function psDataPathFirstPart Returns String
93530>>>        String sDataPath
93530>>>        Integer iCount
93530>>>        
93530>>>        Get psDataPath of (phoWorkspace(ghoApplication)) to sDataPath
93531>>>        Get CountOfPaths of (phoWorkspace(ghoApplication)) sDataPath to iCount
93532>>>        If (iCount > 1) Begin
93534>>>            Get PathAtIndex of (phoWorkspace(ghoApplication)) sDataPath 1 to sDataPath    
93535>>>        End             
93535>>>>
93535>>>        If (sDataPath <> "") Begin
93537>>>            Get vFolderFormat sDataPath to sDataPath
93538>>>        End
93538>>>>
93538>>>        
93538>>>        Function_Return sDataPath
93539>>>    End_Function
