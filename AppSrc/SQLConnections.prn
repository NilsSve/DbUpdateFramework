98360>>>            Move (TheRow.sValue[piColumnid(oActive_Col(Self))]) to bEnabled
98361>>>            If (bEnabled = True) Begin
98363>>>                // Then bEnabled state have changed; deactivate all current rows.
98363>>>                For iCount from 0 to (iSize -1)
98369>>>>
98369>>>                    Move False to TheData[iCount].sValue[piColumnId(oActive_Col(Self))]
98370>>>                Loop
98371>>>>
98371>>>            End
98371>>>>
98371>>>
