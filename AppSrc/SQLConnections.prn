87388>>>    Procedure Construct_Object                                
87390>>>        Handle ho
87390>>>        Forward Send Construct_Object
87392>>>        
87392>>>        Move Self to ghoDbUpdateFunctionLibrary    
87393>>>
87393>>>        Send CreateDbUpdateLibraryProperties
87394>>>        // If no ghoSQLConnectionHandler object has been created prior to this object,
87394>>>        // we will create one as it is used for all ConnectionID, ConnectionString 
87394>>>        // etc settings.
87394>>>        If (ghoSQLConnectionHandler = 0) Begin
87396>>>            Get Create (RefClass(cSQLConnectionHandler)) to ho
87397>>>            Set phoSQLConnectionHandler to ho
87398>>>        End
87398>>>>
87398>>>            
87398>>>    End_Procedure
87399>>>    
87399>>>    Procedure End_Construct_Object                    
87401>>>        Forward Send End_Construct_Object
