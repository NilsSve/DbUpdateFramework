95250>>>>>
95250>>>>>    //****************************************************************************
95250>>>>>    // If workspaces are used, we will send the message EnumerateWorkspaceData
95250>>>>>    // To the workspace object passing the an object and message To send back
95250>>>>>    // To this object. It is expected that the workspace object will send this
95250>>>>>    // message for every line Of information it wants displayed (passing the
95250>>>>>    // information To be displayed
95250>>>>>    //****************************************************************************
95250>>>>>    Register_Procedure EnumerateWorkspaceData Integer hObjId Integer hmMessId
95250>>>>>
95250>>>>>    Procedure Show_ServicePack
95252>>>>>        String sKey sVersion sDataFlex
95252>>>>>        Handle hoRegistry
95252>>>>>        Boolean bExists bOpened
95252>>>>>
95252>>>>>        Move "DataFlex"        to sDataFlex
95253>>>>>
95253>>>>>        Get Create U_cRegistry to hoRegistry
95254>>>>>        Set phRootKey of hoRegistry to HKEY_LOCAL_MACHINE
95255>>>>>        Set pfAccessRights of hoRegistry to KEY_READ
95256>>>>>        Get KeyExists of hoRegistry "SOFTWARE\Wow6432Node" to bExists
95257>>>>>
95257>>>>>        If (bExists) Begin
95259>>>>>            Move ("SOFTWARE\Wow6432Node\Data Access Worldwide\" + sDataFlex + "\" + SysConf (SYSCONF_DATAFLEX_REV)) to sKey
95260>>>>>        End
95260>>>>>>
95260>>>>>        Else Begin
95261>>>>>            Move ("SOFTWARE\Data Access Worldwide\"             + sDataFlex + "\" + SysConf (SYSCONF_DATAFLEX_REV)) to sKey
95262>>>>>        End
95262>>>>>>
95262>>>>>        Get KeyExists of hoRegistry sKey to bExists
95263>>>>>        If (bExists) Begin
95265>>>>>            Get OpenKey of hoRegistry sKey to bOpened
95266>>>>>            If (bOpened) Begin
95268>>>>>                Get ValueExists of hoRegistry "CurrentVersionDescription" to bExists
95269>>>>>                If (bExists) Begin
95271>>>>>                    Get ReadString of hoRegistry "CurrentVersionDescription" to sVersion
95272>>>>>                End
95272>>>>>>
95272>>>>>                Send CloseKey of hoRegistry
95273>>>>>            End
95273>>>>>>
95273>>>>>        End
95273>>>>>>
95273>>>>>        Send Destroy of hoRegistry
95274>>>>>
95274>>>>>        If (sVersion <> "") Begin
95276>>>>>           Send AppendTextLn sVersion
95277>>>>>           Send AppendTextLn ""
95278>>>>>        End
95278>>>>>>
95278>>>>>    End_Procedure
95279>>>>>
95279>>>>>    Procedure Show_WorkspaceInformation
95281>>>>>        Integer hoWorkspace
95281>>>>>
95281>>>>>        If (ghoApplication <> 0) Begin
95283>>>>>            Get phoWorkspace of ghoApplication to hoWorkspace
95284>>>>>            If (hoWorkspace <> 0) Begin
95286>>>>>                Send EnumerateWorkspaceData of hoWorkspace Self msg_AppendTextLn
95287>>>>>            End
95287>>>>>>
95287>>>>>        End
95287>>>>>>
95287>>>>>    End_Procedure
95288>>>>>
95288>>>>>    //****************************************************************************
95288>>>>>    // If connection ids are used, we will send the message EnumerateConnections
95288>>>>>    // to the connection manager object passing the an object and message to send 
95288>>>>>    // back to this object. It is expected that the connection manager object will 
95288>>>>>    // send this message for every line Of information it wants displayed (passing 
95288>>>>>    // the information To be displayed
95288>>>>>    //****************************************************************************
95288>>>>>    Register_Procedure EnumerateConnections Integer hObjId Integer hmMessId
95288>>>>>
95288>>>>>    Procedure Show_ConnectionIdInformation
95290>>>>>        If (ghoConnection > 0) Begin
95292>>>>>            Send EnumerateConnections of ghoConnection Self (RefProc(AppendTextLn))
95293>>>>>            Send AppendTextLn ""
95294>>>>>        End
95294>>>>>>
95294>>>>>    End_Procedure
95295>>>>>
95295>>>>>    Function VersionStr Integer iVer Integer iRev Integer iBld Returns String
95297>>>>>        Function_Return (String (iVer) - "." - String (iRev) - "." - String (iBld))
95298>>>>>    End_Function
95299>>>>>
95299>>>>>    Procedure Show_Versions
95301>>>>>        Integer iVersion iRevision iBuild
95301>>>>>
95301>>>>>        Version_information iVersion iRevision iBuild
95303>>>>>
95303>>>>>        Send AppendTextLn (SFormat (C_$RuntimeVersion, VersionStr(self,iVersion,iRevision,iBuild) ))
95304>>>>>        Send AppendTextLn (SFormat (C_$PackageVersion, VersionStr(self,PKG_VERSION, PKG_REVISION, PKG_BUILD) ))
95305>>>>>        Send AppendTextLn (SFormat (C_$FMACVersion, VersionStr(self,FMAC_VERSION, FMAC_REVISION, FMAC_BUILD) ))
95306>>>>>    End_Procedure                                           
95307>>>>>    
95307>>>>>    Function IsDAWSQLDriver String sDriverID Returns Boolean
95309>>>>>        Boolean bOK
95309>>>>>        Move (sDriverID = MSSQLDRV_ID or sDriverID = DB2_DRV_ID or sDriverID = ODBC_DRV_ID) to bOK
95310>>>>>        Function_Return bOK
95311>>>>>    End_Function
95312>>>>>
95312>>>>>    Function IsMertechDriver String sDriverID Returns Boolean
95314>>>>>        Boolean bOK   
95314>>>>>        Move (sDriverID = SQLFLEX or sDriverID = ORAFLEX or sDriverID = MDSPgSQL or sDriverID = MySQLFlex) to bOK
95315>>>>>        Function_Return bOK
95316>>>>>    End_Function
95317>>>>>
95317>>>>>    //***
95317>>>>>    //*** BW
95317>>>>>    //*** Procedure: Show_Drivers
95317>>>>>    //*** Purpose  : Show loaded database drivers
95317>>>>>    //***
95317>>>>>
95317>>>>>    Procedure Show_Drivers
95319>>>>>        String sDriverID sVersion sClient sMertechSQLFlexVersion sValue
95319>>>>>        Integer iNumberOfDrivers iDriver iClient iUsersMax iSerialNo iNumServers iCount
95319>>>>>        Handle hoCLIHandler hoBtrvHandler
95319>>>>>        Boolean bStudioLicense bIsDAWDriver bIsMertechDriver
95319>>>>>
95319>>>>>        Move False to bStudioLicense
95320>>>>>
95320>>>>>        Get Create U_cCLIHandler      to hoCLIHandler
95321>>>>>        Get Create U_cDFBtrDrvHandler to hoBtrvHandler 
95322>>>>>
95322>>>>>        // For testing purposes:        
95322>>>>>//        Send Ignore_Error of Error_Object_Id DFERR_CANT_LOAD_DLL
95322>>>>>//        Load_Driver MSSQLDRV_ID
95322>>>>>//        Load_Driver ODBC_DRV_ID
95322>>>>>//        Load_Driver DB2_DRV_ID
95322>>>>>//        Send Trap_Error of Error_Object_Id DFERR_CANT_LOAD_DLL
95322>>>>>//
95322>>>>>//        #IFDEF DUF_Use_Mertech_Drivers  
95322>>>>>//            Send Ignore_Error of Error_Object_Id DFERR_CANT_LOAD_DLL
95322>>>>>//            Load_Driver SQLFLEX 
95322>>>>>//            Load_Driver MDSPgSQL
95322>>>>>//            Load_Driver MDSMySQL
95322>>>>>//            Load_Driver ORAFLEX
95322>>>>>//            Send Trap_Error of Error_Object_Id DFERR_CANT_LOAD_DLL
95322>>>>>//        #ENDIF
95322>>>>>        Move False to Err
95323>>>>>        
95323>>>>>        // Loop through all loaded drivers.
95323>>>>>        Get_Attribute DF_NUMBER_DRIVERS to iNumberOfDrivers
95326>>>>>        If (iNumberOfDrivers > 1) Begin
95328>>>>>            Send AppendTextLn ""
95329>>>>>        End
95329>>>>>>
95329>>>>>        For iDriver from 1 to iNumberOfDrivers           
95335>>>>>>
95335>>>>>            // For some weird reason it can happen that - when using Mertech drivers - that the driver index
95335>>>>>            // was increased in the CLI array, but it has no value. In that case a "Bad parameter..." error
95335>>>>>            // would be thrown, so we safeguard from that here.
95335>>>>>            Send Ignore_Error of Error_Object_Id DFERR_BAD_PARAMETER
95336>>>>>            Get_Attribute DF_DRIVER_NAME of iDriver to sDriverID
95339>>>>>            Send Trap_Error of Error_Object_Id DFERR_BAD_PARAMETER
95340>>>>>            Get IsDAWSQLDriver sDriverID to bIsDAWDriver
95341>>>>>            Get IsMertechDriver sDriverID to bIsMertechDriver
95342>>>>>
95342>>>>>            If (sDriverID = DFBTRDRV_ID or bIsDAWDriver = True or bIsMertechDriver = True) Begin
95344>>>>>
95344>>>>>                // Pervasive/Btrieve database
95344>>>>>                If (sDriverID = DFBTRDRV_ID) Begin
95346>>>>>                    Get CKRevision of hoBtrvHandler to sVersion
95347>>>>>                    Get PSQLLocalEngineVersionInfo of hoBtrvHandler 0 to sClient
95348>>>>>                    If (sClient <> "0.0.0") Begin
95350>>>>>                        Send AppendTextLn (SFormat (C_$Pervasive_Local_Engine_Version, sClient))
95351>>>>>                    End
95351>>>>>>
95351>>>>>                    Get PSQLServerEngineVersionInfo of hoBtrvHandler 0 to sClient
95352>>>>>                    If (sClient <> "0.0.0") Begin
95354>>>>>                        Send AppendTextLn (SFormat (C_$Pervasive_Server_Engine_Version, sClient))
95355>>>>>                    End
95355>>>>>>
95355>>>>>                End
95355>>>>>>
95355>>>>>
95355>>>>>                Else Begin
95356>>>>>                    Set psDriverID of hoCLIHandler to sDriverID 
95357>>>>>                    Move 0 to iNumServers
95358>>>>>                    If (sDriverID <> DATAFLEX_ID) Begin
95360>>>>>                        Get_Attribute DF_DRIVER_NUMBER_SERVERS of iDriver to iNumServers
95363>>>>>                    End
95363>>>>>>
95363>>>>>                    
95363>>>>>                    If (bIsDAWDriver = True) Begin
95365>>>>>                        If (sDriverID = MSSQLDRV_ID) Begin
95367>>>>>                            // This info is only available for the MS SQL driver:
95367>>>>>                            Get_Attribute DF_DRIVER_SQLSERVER_CLIENT_VERSION of iDriver to iClient
95370>>>>>                            If (iClient = 13) Move C_$SQLSERVER2016DRVRSTR              to sClient
95373>>>>>                            If (iClient = 12) Move C_$SQLSERVER2014DRVRSTR              to sClient
95376>>>>>                            If (iClient = 11) Move C_$SQL_Server_Native_Client_11_0     to sClient
95379>>>>>                            If (iClient = 10) Move C_$SQL_Server_Native_Client_10_0     to sClient
95382>>>>>                            If (iClient = 9)  Move C_$SQL_Native_Client                 to sClient
95385>>>>>                            If (iClient = 8)  Move C_$SQL_Server_SQL_Server_2000_client to sClient
95388>>>>>                            If (sClient <> "") Begin
95390>>>>>                                Move ("    " + sClient) to sClient
95391>>>>>                            End
95391>>>>>>
95391>>>>>                        End
95391>>>>>>
95391>>>>>                    
95391>>>>>                        Get CKRevision of hoCLIHandler to sVersion 
95392>>>>>                    End
95392>>>>>>
95392>>>>>                    
95392>>>>>                    If (bIsMertechDriver = True) Begin
95394>>>>>                        GET_DRIVER_REVISION to sVersion
95407>>>>>>
95407>>>>>                    End
95407>>>>>>
95407>>>>>                    
95407>>>>>                    // If the serialnumber is = 0, it means that the
95407>>>>>                    // Studio licens is in use and there is no
95407>>>>>                    // number of max users defined because the driver is
95407>>>>>                    // relying on the info from the VDF license.
95407>>>>>                    If (bStudioLicense = False) Begin
95409>>>>>                        Get SerialNumber of hoCLIHandler to iSerialNo
95410>>>>>                        Move (iSerialNo = 0) to bStudioLicense
95411>>>>>                    End
95411>>>>>>
95411>>>>>                End
95411>>>>>>
95411>>>>>                Send AppendTextLn (SFormat (C_$DatabaseDriver, (sDriverID * "-" * (C_$Version + ": " + sVersion))))
95412>>>>>                If (iNumServers <> 0) Begin
95414>>>>>                    For iCount from 1 to iNumServers
95420>>>>>>
95420>>>>>                        Get_Attribute DF_DRIVER_SERVER_NAME of iDriver iCount to sValue 
95423>>>>>                        Send AppendTextLn ("    " + "Server/DSN:" * sValue)
95424>>>>>                    Loop
95425>>>>>>
95425>>>>>                End
95425>>>>>>
95425>>>>>                If (sClient <> "" and sDriverID = MSSQLDRV_ID) Begin
95427>>>>>                    Send AppendTextLn sClient
95428>>>>>                End  
95428>>>>>>
95428>>>>>            End
95428>>>>>>
95428>>>>>        Loop
95429>>>>>>
95429>>>>>
95429>>>>>        Send AppendTextLn ""
95430>>>>>        If (bStudioLicense = False) Begin
95432>>>>>            Get MaxUsers of hoCLIHandler to iUsersMax 
95433>>>>>            Send AppendTextLn (SFormat (C_$Max_DbDriver_Licensed_User_Count, iUsersMax))
95434>>>>>        End
95434>>>>>>
95434>>>>>        Else Begin
95435>>>>>            Send AppendTextLn C_$VDF_Studio_License_Text
95436>>>>>        End
95436>>>>>>
95436>>>>>        Send Destroy of hoCLIHandler
95437>>>>>        Send Destroy of hoBtrvHandler
95438>>>>>    End_Procedure
95439>>>>>
95439>>>>>    Procedure Show_HelpFile
95441>>>>>        String sHelpFile
95441>>>>>        Integer eHelpType
95441>>>>>
95441>>>>>        If (ghoApplication <> 0) Begin
95443>>>>>            Get peHelpType Of ghoApplication To eHelpType
95444>>>>>            If (eHelpType = htHtmlHelp and ghoHtmlHelp) Begin
95446>>>>>                Get GetHelpFile Of ghoHtmlHelp To sHelpFile
95447>>>>>            End
95447>>>>>>
95447>>>>>            Else If (eHelpType = htWinHelp and Help_object_id) Begin
95450>>>>>                Get Help_filename Of Help_object_id To sHelpFile
95451>>>>>            End
95451>>>>>>
95451>>>>>            Else Begin
95452>>>>>                Move C_$ThereIsNoHelpfileDefined To sHelpFile
95453>>>>>            End
95453>>>>>>
95453>>>>>
95453>>>>>            Send AppendTextLn (SFormat (C_$HelpFile, sHelpFile))
95454>>>>>        End
95454>>>>>>
95454>>>>>    End_Procedure
95455>>>>>
95455>>>>>    Procedure Show_EnterAsTab
