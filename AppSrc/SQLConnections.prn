87542>>>    // Creates an SQL Table at the SQL end by its filelist number;
87542>>>    // Also creates a 'DUMMY' column because SQL doesn't like to create a table with no columns!  
87542>>>    Function SqlTableCreate Integer hTable Returns Boolean
87544>>>        String sTableName sSQLString sPath sVal sCreateTable sDriverID
87544>>>        Integer iRetval iDbType                      
87544>>>        Boolean bExists bOK
87544>>>        
87544>>>        Get psDriverID to sDriverID       
87545>>>        Get UtilTableHandleToString hTable to sTableName
87546>>>        Get SqlUtilCheckIfTableNameExists sTableName sDriverID to bExists
87547>>>        If (bExists = True) Begin
87549>>>            Function_Return False
87550>>>        End                      
87550>>>>
87550>>>        
87550>>>        Get psDataPathFirstPart to sPath
87551>>>        Get vFilePathExists (sPath + String(sTableName) + ".int") to bExists
87552>>>        
87552>>>        Get piDbType to iDbType
87553>>>        Get _SqlProperTableName sTableName to sTableName
87554>>>        Get _SqlFindKeyWord CI_SQLCreateTable iDbType to sCreateTable
87555>>>        Move (sCreateTable * String(sTableName) * "(Dummy Decimal(2,0))") to sSQLString
87556>>>        
87556>>>        Move False to Err               
87557>>>        Send SqlUtilExecuteQuery sSQLString sDriverID
87558>>>    
87558>>>        Function_Return (Err = False)
87559>>>    End_Function       
87560>>>    
