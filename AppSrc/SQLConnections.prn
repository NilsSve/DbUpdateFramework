80132>>>
80132>>>// This function creates a uniquely named temporary file in folder sPath
80132>>>// The file created will have a prefix based on the first 3 characters in sPrefix
80132>>>// Note that you will have to cleanup the tempfile yourself as the function
80132>>>// does not take care of that.
80132>>>Function vCreateTempFileInPath String sPath String sPrefix Returns String
#REM AMBIGUOUS METHODS ON .DESKTOP. ARE .NOT. RECOMMENDED (OBSOLETE TECHNIQUE)
80134>>>    String sTempFileName
80134>>>    Integer iCnt iRetVal
80134>>>    Pointer lpTempFileName
80134>>>    Pointer lpPath
80134>>>    Pointer lpPrefix
80134>>>
80134>>>    Move (ToAnsi(sPath)+Character(0))   To sPath
80135>>>    Move (ToAnsi(sPrefix)+Character(0)) To sPrefix
80136>>>    Move (pad("", vMAX_PATH)) To sTempFileName
80137>>>    GetAddress Of sTempFileName To lpTempFileName
80138>>>    GetAddress Of sPath         To lpPath
80139>>>    GetAddress Of sPrefix       To lpPrefix
80140>>>
80140>>>    Move (vWin32_GetTempFileName(lpPath, lpPrefix, 0, lpTempFileName)) To iRetVal
80141>>>    Move (Trim(Cstring(sTempFileName))) To sTempFileName
80142>>>    Function_Return sTempFileName
80143>>>End_Function // vCreateTempFileInPath
