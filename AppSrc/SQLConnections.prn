85546>>>>>    // Returns all connection details for the passed Connection ID as a tSQLConnection
85546>>>>>    // If it fails the returned struct member SQLConnection.bError = True. 
85546>>>>>    Function SQLIniFileConnectionID String sConnectionID Returns tSQLConnection
85548>>>>>        tSQLConnection[] SQLConnectionsArray
85548>>>>>        tSQLConnection[] SQLConnectionsArray
85549>>>>>        tSQLConnection   SQLConnection
85549>>>>>        tSQLConnection   SQLConnection
85549>>>>>        Integer iIndex
85549>>>>>        
85549>>>>>        Get SQLIniFileConnectionIDIndex sConnectionID to iIndex
85550>>>>>        If (iIndex = -1) Begin
85552>>>>>            Move True to SQLConnection.bError
85553>>>>>            Function_Return SQLConnection
85554>>>>>        End
85554>>>>>>
85554>>>>>
85554>>>>>        Get SQLIniFileReadConnections to SQLConnectionsArray
85555>>>>>        Move SQLConnectionsArray[iIndex -1] to SQLConnection
85556>>>>>        
85556>>>>>        Function_Return SQLConnection    
85557>>>>>    End_Function
85558>>>>>            
85558>>>>>    // Returns -1 if the passed connection ID was not found, else the item number.
85558>>>>>    Function SQLIniFileConnectionIDIndex String sConnectionID Returns Integer
85560>>>>>        tSQLConnection[] SQLConnectionsArray
85560>>>>>        tSQLConnection[] SQLConnectionsArray
85561>>>>>        Integer iRetval iCount iSize
85561>>>>>        String sValue
85561>>>>>        Boolean bExists
85561>>>>>        
85561>>>>>        Move -1 to iRetval
85562>>>>>
85562>>>>>        Get SQLIniFileReadConnections to SQLConnectionsArray
85563>>>>>        Move (SizeOfArray(SQLConnectionsArray)) to iSize
85564>>>>>        Decrement iSize
85565>>>>>        For iCount from 0 to iSize
85571>>>>>>
85571>>>>>            Move SQLConnectionsArray[iCount].sConnectionID to sValue 
85572>>>>>            Move (Uppercase(sValue) = Uppercase(sConnectionID)) to bExists
85573>>>>>            If (bExists) Begin
85575>>>>>                Move (iCount + 1) to iRetval // The [ConnectionX] keys are one-based (starts at 1) but the loop starts at zero.
85576>>>>>                Move iSize to iCount         // We're done!
85577>>>>>            End
85577>>>>>>
85577>>>>>        Loop
85578>>>>>>
85578>>>>>                
85578>>>>>        Function_Return iRetval
85579>>>>>    End_Function       
85580>>>>>    
85580>>>>>    // Checks if the passed sConnectionID exists more than once in the passed struct array.
85580>>>>>    // Used to check that ConnectionID's are unique.
85580>>>>>    Function IsConnectionIDDuplicate String sConnectionID Returns Boolean
85582>>>>>        Integer iCount iSize iItems
85582>>>>>        String sValue
85582>>>>>        Boolean bExists                                   
85582>>>>>        tSQLConnection[] SQLConnectionsArray 
85582>>>>>        tSQLConnection[] SQLConnectionsArray 
85583>>>>>        
85583>>>>>        Move 0 to iItems                     
85584>>>>>        Get SQLIniFileReadConnections to SQLConnectionsArray
85585>>>>>        Move (SizeOfArray(SQLConnectionsArray)) to iSize
85586>>>>>        Decrement iSize
85587>>>>>        For iCount from 0 to iSize
85593>>>>>>
85593>>>>>            Move SQLConnectionsArray[iCount].sConnectionID to sValue 
85594>>>>>            Move (sValue = sConnectionID) to bExists
85595>>>>>            If (bExists) Begin
85597>>>>>                Increment iItems
85598>>>>>            End
85598>>>>>>
85598>>>>>        Loop
85599>>>>>>
85599>>>>>                
85599>>>>>        Function_Return (iItems > 1)
85600>>>>>    End_Function       
85601>>>>>    
85601>>>>>    // To update the SQLConnections.ini file with a new default Connection ID.
85601>>>>>    Function SQLIniFileSetDefaultConnection String sConnectionID Returns Boolean
85603>>>>>        Boolean bRetval bOK
85603>>>>>        Integer iItem iSize iCount
85603>>>>>        tSQLConnection[] SQLConnectionsArray
85603>>>>>        tSQLConnection[] SQLConnectionsArray
85604>>>>>        tSQLConnection SQLConnection
85604>>>>>        tSQLConnection SQLConnection
85604>>>>>        String sConnectionString
85604>>>>>        
85604>>>>>        Move False to Err     
85605>>>>>        Get psConnectionString to sConnectionString             
85606>>>>>        
85606>>>>>        Get SQLIniFileReadConnections to SQLConnectionsArray
85607>>>>>        Move (SizeOfArray(SQLConnectionsArray)) to iSize
85608>>>>>        Decrement iSize
85609>>>>>        // Set all current connection to inactive.
85609>>>>>        For iCount from 0 to iSize
85615>>>>>>
85615>>>>>            Move False to SQLConnectionsArray[iCount].bEnabled
85616>>>>>        Loop                                              
85617>>>>>>
85617>>>>>        
85617>>>>>        Get SQLIniFileConnectionID sConnectionID to SQLConnection
85618>>>>>        Move True              to SQLConnection.bEnabled
85619>>>>>        Move sConnectionString to SQLConnection.sConnectionString
85620>>>>>        Move (InsertInArray(SQLConnectionsArray, 0, SQLConnection)) to SQLConnectionsArray
85621>>>>>        Get SQLIniFileWriteConnections SQLConnectionsArray to bOK
85622>>>>>        
85622>>>>>        Function_Return (bOK = True)
85623>>>>>    End_Function
85624>>>>>    
85624>>>>>    // Used for updating an existing connection with new data.
85624>>>>>    // Returns True if successful.
85624>>>>>    Function SQLIniFileUpdateConnection tSQLConnection SQLConnection Returns Boolean
85626>>>>>        Boolean bRetval bOK
85626>>>>>        Integer iItem iSize iCount
85626>>>>>        tSQLConnection[] SQLConnectionsArray
85626>>>>>        tSQLConnection[] SQLConnectionsArray
85627>>>>>        
85627>>>>>        Move False to Err           
85628>>>>>        Move -1 to iItem  
85629>>>>>        Get SQLIniFileReadConnections to SQLConnectionsArray
85630>>>>>        Move (SizeOfArray(SQLConnectionsArray)) to iSize
85631>>>>>        Decrement iSize
85632>>>>>        // Set all current connection to inactive.
85632>>>>>        For iCount from 0 to iSize
85638>>>>>>
85638>>>>>            Move False to SQLConnectionsArray[iCount].bEnabled 
85639>>>>>            If (SQLConnectionsArray[iCount].sConnectionID = SQLConnection.sConnectionID) Begin
85641>>>>>                Move iCount to iItem
85642>>>>>            End
85642>>>>>>
85642>>>>>        Loop                                              
85643>>>>>>
85643>>>>>        
85643>>>>>        If (iItem <> -1) Begin
85645>>>>>            Move True to SQLConnection.bEnabled
85646>>>>>            Move SQLConnection to SQLConnectionsArray[iItem]
85647>>>>>            Get SQLIniFileWriteConnections SQLConnectionsArray to bOK
85648>>>>>        End
85648>>>>>>
85648>>>>>        
85648>>>>>        Function_Return (bOK = True)
85649>>>>>    End_Function
85650>>>>>    
85650>>>>>    Function SQLIniFileReadConnections Returns tSQLConnection[]
85652>>>>>        tSQLConnection[] SQLConnectionsArray
85652>>>>>        tSQLConnection[] SQLConnectionsArray
85653>>>>>        String sSection sValue
85653>>>>>        Integer iCount
85653>>>>>        Boolean bExists bEnabled
85653>>>>>        
85653>>>>>        Get psIniSectionName to sSection
85654>>>>>        Get SectionExists sSection to bExists
85655>>>>>        If (bExists = False) Begin   
85657>>>>>            Function_Return SQLConnectionsArray
85658>>>>>        End                                  
85658>>>>>>
85658>>>>>        Get SectionExists CS_SQLIniConnectionSection to bExists
85659>>>>>        If (bExists = True) Begin
85661>>>>>            Error DFERR_PROGRAM "Sorry, the format for the SQLConnections.ini file has been changed and this file has the old format that is no longer valid and thus cannot be read. You need to re-enter your connection(s)."
85662>>>>>>
85662>>>>>        End
85662>>>>>>
85662>>>>>                
85662>>>>>        Move 1 to iCount // The section name "[ConnectionXX]" starts with "1"
85663>>>>>        Get SectionExists (CS_SQLIniSectionName + String(iCount)) to bExists 
85664>>>>>        
85664>>>>>        While (bExists = True)
85668>>>>>            // We always put the enabled/active connection at the top
85668>>>>>            Move (iCount = 1) to bEnabled
85669>>>>>            Move bEnabled to SQLConnectionsArray[iCount].bEnabled
85670>>>>>            
85670>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniConnectionIdKeyword ""        to SQLConnectionsArray[iCount].sConnectionID
85671>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniDriverKeyword       ""        to SQLConnectionsArray[iCount].sDriverID
85672>>>>>
85672>>>>>            // The iDbType might be missing from the ini-file. This is e.g. the case when a DAW Managed Connection "DFConnId.ini" file is read.
85672>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniDbTypeKeyword       "99"      to sValue
85673>>>>>            If (sValue = "99") Begin
85675>>>>>                Get SqlUtilDbTypeFromDriver SQLConnectionsArray[iCount].sDriverID to sValue
85676>>>>>            End
85676>>>>>>
85676>>>>>            Move sValue                                                                                     to SQLConnectionsArray[iCount].iDbType
85677>>>>>
85677>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniConnectionKeyWord   ""        to SQLConnectionsArray[iCount].sConnectionString
85678>>>>>            Get ParseKeyWord SQLConnectionsArray[iCount].sConnectionString (CS_SQLIniServerKeyword + "=")   to SQLConnectionsArray[iCount].sServer
85679>>>>>            If (SQLConnectionsArray[iCount].sServer = "") Begin
85681>>>>>                Get ParseKeyWord SQLConnectionsArray[iCount].sConnectionString (CS_SQLIniDSNKeyword +"=")   to SQLConnectionsArray[iCount].sServer
85682>>>>>            End
85682>>>>>>
85682>>>>>            Get ParseKeyWord SQLConnectionsArray[iCount].sConnectionString (CS_SQLIniDatabaseKeyword + "=") to SQLConnectionsArray[iCount].sDatabase
85683>>>>>
85683>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniTrustedKeyword      ""        to sValue
85684>>>>>            Move (If(Uppercase(sValue) = "YES", True, False))                                               to SQLConnectionsArray[iCount].bTrusted
85685>>>>>
85685>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniUIDKeyword          ""        to SQLConnectionsArray[iCount].sUserID
85686>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniDFPWDKeyword        ""        to sValue
85687>>>>>            If (pbDFConnId(Self) = False and sValue <> "") Begin
85689>>>>>                Get DecryptPassword sValue to sValue    
85690>>>>>            End
85690>>>>>>
85690>>>>>            Move sValue                                                                                     to SQLConnectionsArray[iCount].sPassword
85691>>>>>            
85691>>>>>            // Here we reconstruct the connection string to be complete with all params;
85691>>>>>            Get ConstructConnectionString SQLConnectionsArray[iCount].sDriverID SQLConnectionsArray[iCount].sServer SQLConnectionsArray[iCount].sDatabase ;                                          SQLConnectionsArray[iCount].bTrusted SQLConnectionsArray[iCount].sUserID SQLConnectionsArray[iCount].sPassword ;                                          to SQLConnectionsArray[iCount].sConnectionString    
85692>>>>>            
85692>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniSchemaKeyword          ""     to SQLConnectionsArray[iCount].sSchema
85693>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniBaseTableSpaceKeyword  ""     to SQLConnectionsArray[iCount].sBaseTableSpace
85694>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniLongTableSpaceKeyword  ""     to SQLConnectionsArray[iCount].sLongTableSpace
85695>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniIndexTableSpaceKeyword ""     to SQLConnectionsArray[iCount].sIndexTableSpace
85696>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniSilentLoginKeyword     ""     to SQLConnectionsArray[iCount].bSilentLogin  
85697>>>>>//            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniDisabledKeyword        ""     to SQLConnectionsArray[iCount].bDisabled
85697>>>>>
85697>>>>>            Increment iCount
85698>>>>>            Get SectionExists (CS_SQLIniSectionName + String(iCount)) to bExists
85699>>>>>        Loop
85700>>>>>>
85700>>>>>        
85700>>>>>        // Lastly, we remove the very first array item as it is empty (we started at 1 because that is the first [Connection#])
85700>>>>>        If (SizeOfArray(SQLConnectionsArray) > 0) Begin
85702>>>>>            Move (RemoveFromArray(SQLConnectionsArray, 0)) to SQLConnectionsArray
85703>>>>>        End
85703>>>>>>
85703>>>>>        
85703>>>>>        Function_Return SQLConnectionsArray
85704>>>>>    End_Function 
85705>>>>>        
85705>>>>>    Function SQLIniFileWriteConnections tSQLConnection[] SQLConnectionsArray Returns Boolean
85707>>>>>        Integer iCount iSize iItem
85707>>>>>        Boolean bIsOneActive bEnabled bExists bOK
85707>>>>>        String sConnectionString sSection sValue
85707>>>>>        
85707>>>>>        // First we need to _remove_ all current connections in the ini-file, we
85707>>>>>        // do that by setting their values to "".
85707>>>>>        Move 0 to iCount  
85708>>>>>        Get SQLIniFileDeleteAllConnections to bOK
85709>>>>>        If (bOK = False) Begin
85711>>>>>            Function_Return False
85712>>>>>        End                 
85712>>>>>>
85712>>>>>        
85712>>>>>        Move False to Err
85713>>>>>        Get psIniSectionName to sSection                                                          
85714>>>>>        // Sorting will make sure we have the active connection record as the first connection item in the ini-file.
85714>>>>>        Move (SortArray(SQLConnectionsArray, Self, (RefFunc(SortActiveFirst)))) to SQLConnectionsArray
85715>>>>>        Move (SizeOfArray(SQLConnectionsArray)) to iSize
85716>>>>>        Decrement iSize       
85717>>>>>        
85717>>>>>        For iCount from 0 to iSize
85723>>>>>>
85723>>>>>            // DF 19 compatible settings:
85723>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniConnectionIdKeyword   to SQLConnectionsArray[iCount].sConnectionID
85724>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniDriverKeyword         to SQLConnectionsArray[iCount].sDriverID
85725>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniUIDKeyword            to SQLConnectionsArray[iCount].sUserID
85726>>>>>            
85726>>>>>            Move SQLConnectionsArray[iCount].sPassword to sValue
85727>>>>>            If (pbDFConnId(Self) = False and sValue <> "") Begin
85729>>>>>                Get EncryptPassword sValue to sValue    
85730>>>>>            End
85730>>>>>>
85730>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniDFPWDKeyword          to sValue
85731>>>>>
85731>>>>>            If (SQLConnectionsArray[iCount].bTrusted = True) Begin
85733>>>>>                Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniTrustedKeyword    to CS_SQLIniConnectionYes
85734>>>>>            End                                                                
85734>>>>>>
85734>>>>>            
85734>>>>>            Get ConstructShortConnectionString SQLConnectionsArray[iCount].sDriverID SQLConnectionsArray[iCount].sServer SQLConnectionsArray[iCount].sDatabase ;                                            to SQLConnectionsArray[iCount].sConnectionString
85735>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniConnectionKeyWord     to SQLConnectionsArray[iCount].sConnectionString
85736>>>>>            
85736>>>>>            // The Database Update Framework extended settings:
85736>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniDbTypeKeyword          to SQLConnectionsArray[iCount].iDbType
85737>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniSchemaKeyword          to SQLConnectionsArray[iCount].sSchema
85738>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniBaseTableSpaceKeyword  to SQLConnectionsArray[iCount].sBaseTableSpace
85739>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniLongTableSpaceKeyword  to SQLConnectionsArray[iCount].sLongTableSpace
85740>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniIndexTableSpaceKeyword to SQLConnectionsArray[iCount].sIndexTableSpace
85741>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniSilentLoginKeyword     to SQLConnectionsArray[iCount].bSilentLogin
85742>>>>>        Loop                 
85743>>>>>>
85743>>>>>        
85743>>>>>        Function_Return (bOK and Err = False)
85744>>>>>    End_Function
85745>>>>>
85745>>>>>    // *** DbType conversion routines - Converts between string/integer and driver ID values ***
85745>>>>>    //
85745>>>>>    // SQL utility function that returns a database type (string) constant
85745>>>>>    // corresponding to the passed iDbType.
85745>>>>>    Function SqlUtilDbTypeToString Integer iDbType Returns String
85747>>>>>        String sRetval
85747>>>>>        If (iDbType = EN_dbTypeMSSQL)       Move CS_dbTypeMSSQL     to sRetval
85750>>>>>        If (iDbType = EN_dbTypeMySQL)       Move CS_dbTypeMySQL     to sRetval
85753>>>>>        If (iDbType = EN_dbTypeOracle)      Move CS_dbTypeOracle    to sRetval
85756>>>>>        If (iDbType = EN_dbTypeDB2)         Move CS_dbTypeDB2       to sRetval
85759>>>>>        If (iDbType = EN_dbTypePostgre)     Move CS_dbTypePostgre   to sRetval
85762>>>>>        Function_Return sRetval
85763>>>>>    End_Function
85764>>>>>    
85764>>>>>    // SQL utility function that returns a database type constant (integer)
85764>>>>>    // corresponding to the passed sDbType string constant.
85764>>>>>    Function SqlUtilDbTypeToInteger String sDbType  Returns Integer
85766>>>>>        Integer iRetval
85766>>>>>        If (sDbType = CS_dbTypeMSSQL)       Move EN_dbTypeMSSQL     to iRetval
85769>>>>>        If (sDbType = CS_dbTypeMySQL)       Move EN_dbTypeMySQL     to iRetval
85772>>>>>        If (sDbType = CS_dbTypeOracle)      Move EN_dbTypeOracle    to iRetval
85775>>>>>        If (sDbType = CS_dbTypeDB2)         Move EN_dbTypeDB2       to iRetval
85778>>>>>        If (sDbType = CS_dbTypePostgre)     Move EN_dbTypePostgre   to iRetval
85781>>>>>        Function_Return iRetval
85782>>>>>    End_Function    
85783>>>>>    
85783>>>>>    // Pass an integer DbType and function returns the database type integer as a string value.
85783>>>>>    // Used e.g. when reading a connection ini-file to display the database type in
85783>>>>>    // the SQL Connection program's grid.
85783>>>>>    Function SqlUtilDbTypeIntegerToStringConstant Integer iDbType Returns String
85785>>>>>        String sRetval
85785>>>>>        If (iDbType = EN_dbTypeMSSQL)       Move "EN_dbTypeMSSQL"   to sRetval
85788>>>>>        If (iDbType = EN_dbTypeMySQL)       Move "EN_dbTypeMySQL"   to sRetval
85791>>>>>        If (iDbType = EN_dbTypeOracle)      Move "EN_dbTypeOracle"  to sRetval
85794>>>>>        If (iDbType = EN_dbTypeDB2)         Move "EN_dbTypeDB2"     to sRetval
85797>>>>>        If (iDbType = EN_dbTypePostgre)     Move "EN_dbTypePostgre" to sRetval
85800>>>>>        Function_Return sRetval
85801>>>>>    End_Function    
85802>>>>>
85802>>>>>    // Pass a driver id and the function will return
85802>>>>>    // a dbType as an integer. Obviously for the ODBC_DRV this doesn't
85802>>>>>    // quite work and always returns "MS SQL Server"
85802>>>>>    Function SqlUtilDbTypeFromDriver String sDriverID Returns Integer
85804>>>>>        Integer iRetval
85804>>>>>        If (sDriverID = MSSQLDRV_ID)  Move EN_dbTypeMSSQL     to iRetval
