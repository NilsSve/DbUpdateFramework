91576>>>    
91576>>>    Function UtilColumnTypePrecisionDec String sDriverID Integer iDbType Integer iDataType Returns Integer
91578>>>        tColumnType RetvalType  
91578>>>        tColumnType RetvalType  
91578>>>        String sValue
91578>>>        Integer iRetval iPos
91578>>>        
91578>>>        Get _UtilColumnType sDriverID iDbType iDataType "" True to RetvalType 
91579>>>        Move RetvalType.sPrecision to sValue
91580>>>        Move (Pos(".", sValue)) to iPos
91581>>>        If (iPos = 0) Begin
91583>>>            Function_Return 0
91584>>>        End
91584>>>>
91584>>>        Move (Mid(sValue, 99, (iPos + 1))) to iRetval
91585>>>
91585>>>        Function_Return iRetval
91586>>>    End_Function
91587>>>    
91587>>>    // The default value used for a datatype as specified in the driver int file.
91587>>>    Function UtilDataTypeDefaultValue String sDriverID Integer iDbType Integer iDataType Returns String
91589>>>        String sRetval sServer
91589>>>        tColumnType RetvalType 
91589>>>        tColumnType RetvalType 
91589>>>        Integer iDriver iDataFlexType
91589>>>        Handle hDatabase
91589>>>        
91589>>>        Get _UtilColumnType sDriverID iDbType iDataType "" True to RetvalType 
91590>>>        Move RetvalType.iDataFlexType to iDataFlexType
91591>>>        Get DriverIndex sDriverID to iDriver
91592>>>        Get psServer to sServer
91593>>>        Get SqlUtilDatabaseHandle sDriverID sServer to hDatabase 
91594>>>        If (hDatabase = 0) Begin
91596>>>            Function_Return ""
91597>>>        End                   
91597>>>>
91597>>>        
91597>>>        Case Begin
91597>>>            Case (iDataFlexType = DF_ASCII)
91599>>>                Get_Attribute DF_DATABASE_DEFAULT_DEFAULT_ASCII     of iDriver hDatabase to sRetval
91602>>>                Case Break
91603>>>            Case (iDataFlexType = DF_BCD)
91606>>>                Get_Attribute DF_DATABASE_DEFAULT_DEFAULT_NUMERIC   of iDriver hDatabase to sRetval
91609>>>                Case Break
91610>>>            Case (iDataFlexType = DF_BINARY)
91613>>>                Get_Attribute DF_DATABASE_DEFAULT_DEFAULT_BINARY    of iDriver hDatabase to sRetval
91616>>>                Case Break
91617>>>            Case (iDataFlexType = DF_DATE)
91620>>>                Get_Attribute DF_DATABASE_DEFAULT_DEFAULT_DATE      of iDriver hDatabase to sRetval
91623>>>                Case Break
91624>>>            Case (iDataFlexType = DF_DATETIME)
91627>>>                Get_Attribute DF_DATABASE_DEFAULT_DEFAULT_DATETIME  of iDriver hDatabase to sRetval
91630>>>                Case Break
91631>>>            Case (iDataFlexType = DF_TEXT)
91634>>>                Get_Attribute DF_DATABASE_DEFAULT_DEFAULT_TEXT      of iDriver hDatabase to sRetval
91637>>>                Case Break
91638>>>            Case Else
91638>>>                Move "" to sRetval            
91639>>>        Case End
91639>>>        
91639>>>        Function_Return sRetval
91640>>>    End_Function  
91641>>>    
91641>>>    Function SQLUtilDefaultNullValue String sDriverID Integer iDbType Integer iDataType Returns String
91643>>>        String sNotNull sRetval sDefaultValue
91643>>>        Boolean bOK
91643>>>        
91643>>>        Get IsSQLDriver sDriverID to bOK
91644>>>        If (bOK = False) Begin
91646>>>            Function_Return ""
91647>>>        End                   
91647>>>>
91647>>>        
91647>>>        Get UtilDataTypeDefaultValue sDriverID iDbType iDataType to sDefaultValue
91648>>>        Get _SqlFindKeyWord CI_SQLNotNull to sNotNull
91649>>>        
91649>>>        Case Begin
91649>>>            Case (iDbType = EN_dbTypeMSSQL)
91651>>>                Move ("DEFAULT" * String(sDefaultValue) * String(sNotNull)) to sRetval
91652>>>                Case Break
91653>>>            Case (iDbType = EN_dbTypeMySQL)
91656>>>                Move (String(sNotNull) * "DEFAULT" * String(sDefaultValue)) to sRetval
91657>>>                Case Break
91658>>>            Case (iDbType = EN_dbTypePostgre)
91661>>>                Move (String(sNotNull) * "DEFAULT" * String(sDefaultValue)) to sRetval
91662>>>                Case Break
91663>>>            Case (iDbType = EN_dbTypeDB2)
91666>>>                Move (String(sNotNull))                                     to sRetval
91667>>>                Case Break
91668>>>            
91668>>>            // Seems like Oracle can't handle setting a new column to 'NOT NULL' if the table exists with data(!)
91668>>>            // ToDo: We need to look deeper into how Oracle handles NULL
91668>>>            Case (iDbType = EN_dbTypeOracle)
91671>>>                Move  ""                                                    to sRetval
91672>>>                Case Break                                              
91673>>>
91673>>>            Case Else
91673>>>                Move  ""                                                    to sRetval
91674>>>        Case End        
91674>>>        
91674>>>        Function_Return sRetval
91675>>>    End_Function
91676>>>    
91676>>>    // Returns a struct array with the default column types for the SQL back-end and how they
91676>>>    // are mapped to the standard DataFlex data types. 
91676>>>    // The DataFlex data types are: "ASCII", "BINARY", "DATE", "DATETIME", "NUMERIC" and "TEXT".
91676>>>    Function UtilDefaultSqlTypeMappings String sDriverID Integer iDbType Returns tColumnType
91678>>>        tColumnType[] ColumnTypeArray
91678>>>        tColumnType[] ColumnTypeArray
91679>>>        String sDataType
91679>>>        Integer iDataType iDriverID iCount
91679>>>        
91679>>>        Move 0 to iCount
91680>>>        Get DriverIndex sDriverID to iDriverID
91681>>>
91681>>>        // DF_ASCII       
91681>>>        If (sDriverID = ODBC_DRV_ID) Begin
91683>>>            Get_Attribute DF_DRIVER_MAP_DFASCII_TO_ODBCTYPE of iDriverID to iDataType
91686>>>        End                                                             
91686>>>>
91686>>>        Else Begin
91687>>>            Get_Attribute DF_DRIVER_MAP_DFASCII_TO_SQLTYPE  of iDriverID to iDataType 
91690>>>        End
91690>>>>
91690>>>        Move DF_ASCII    to ColumnTypeArray[iCount].iDataFlexType
91691>>>        Move "ASCII"     to ColumnTypeArray[iCount].sDataFlexType  
91692>>>        Get UtilColumnTypeToString sDriverID iDbType iDataType to sDataType
91693>>>        Move sDataType   to ColumnTypeArray[iCount].sType
91694>>>        Move iDataType   to ColumnTypeArray[iCount].iType
91695>>>        Increment iCount
91696>>>        
91696>>>        // DF_BINARY 
91696>>>        If (sDriverID = ODBC_DRV_ID) Begin
91698>>>            Get_Attribute DF_DRIVER_MAP_DFBINARY_TO_ODBCTYPE of iDriverID to iDataType
91701>>>        End                                                                          
91701>>>>
91701>>>        Else Begin
91702>>>            Get_Attribute DF_DRIVER_MAP_DFBINARY_TO_SQLTYPE  of iDriverID to iDataType
91705>>>        End
91705>>>>
91705>>>        Move DF_BINARY   to ColumnTypeArray[iCount].iDataFlexType
91706>>>        Move "Binary"    to ColumnTypeArray[iCount].sDataFlexType  
91707>>>        Get UtilColumnTypeToString sDriverID iDbType iDataType to sDataType
91708>>>        Move sDataType   to ColumnTypeArray[iCount].sType
91709>>>        Move iDataType   to ColumnTypeArray[iCount].iType
91710>>>        Increment iCount
91711>>>        
91711>>>        // DF_DATE
91711>>>        If (sDriverID = ODBC_DRV_ID) Begin
91713>>>            Get_Attribute DF_DRIVER_MAP_DFDATE_TO_ODBCTYPE of iDriverID to iDataType
91716>>>        End                                                                          
91716>>>>
91716>>>        Else Begin
91717>>>            Get_Attribute DF_DRIVER_MAP_DFDATE_TO_SQLTYPE  of iDriverID to iDataType
91720>>>        End
91720>>>>
91720>>>        Move DF_DATE     to ColumnTypeArray[iCount].iDataFlexType
91721>>>        Move "Date"      to ColumnTypeArray[iCount].sDataFlexType  
91722>>>        Get UtilColumnTypeToString sDriverID iDbType iDataType to sDataType
91723>>>        Move sDataType   to ColumnTypeArray[iCount].sType
91724>>>        Move iDataType   to ColumnTypeArray[iCount].iType
91725>>>        Increment iCount
91726>>>        
91726>>>        // DF_DATETIME
91726>>>        If (sDriverID = ODBC_DRV_ID) Begin
91728>>>            Get_Attribute DF_DRIVER_MAP_DFDATETIME_TO_ODBCTYPE of iDriverID to iDataType
91731>>>        End                                                                          
91731>>>>
91731>>>        Else Begin
91732>>>            Get_Attribute DF_DRIVER_MAP_DFDATETIME_TO_SQLTYPE  of iDriverID to iDataType
91735>>>        End
91735>>>>
91735>>>        Move DF_DATETIME to ColumnTypeArray[iCount].iDataFlexType
91736>>>        Move "DateTime"  to ColumnTypeArray[iCount].sDataFlexType  
91737>>>        Get UtilColumnTypeToString sDriverID iDbType iDataType to sDataType
91738>>>        Move sDataType   to ColumnTypeArray[iCount].sType
91739>>>        Move iDataType   to ColumnTypeArray[iCount].iType
91740>>>        Increment iCount
91741>>>
91741>>>        // DF_NUMERIC
91741>>>        // *** Why is there no DF_DRIVER_MAP available for BCD/Numeric??? ***
91741>>>        // DF_BCD can in SQL be either of "SmallInt", "Int", or "Numeric", but
91741>>>        // we make them here all "Numeric"...
91741>>>//        If (sDriverID = ODBC_DRV_ID) Begin
91741>>>//            Get_Attribute DF_DRIVER_MAP_DFDATE_TO_ODBCTYPE of iDriverID to iDataType
91741>>>//        End                                                                          
91741>>>//        Else Begin
91741>>>//            Get_Attribute DF_DRIVER_MAP_DFDATE_TO_SQLTYPE  of iDriverID to iDataType
91741>>>//        End                        
91741>>>        Move DF_BCD      to ColumnTypeArray[iCount].iDataFlexType
91742>>>        Move "Numeric"   to ColumnTypeArray[iCount].sDataFlexType
91743>>>        Move "Numeric"   to ColumnTypeArray[iCount].sType
91744>>>        Move SQL_NUMERIC to ColumnTypeArray[iCount].iType
91745>>>
91745>>>        // DF_TEXT
91745>>>        If (sDriverID = ODBC_DRV_ID) Begin
91747>>>            Get_Attribute DF_DRIVER_MAP_DFTEXT_TO_ODBCTYPE of iDriverID to iDataType
91750>>>        End                                                                          
91750>>>>
91750>>>        Else Begin
91751>>>            Get_Attribute DF_DRIVER_MAP_DFTEXT_TO_SQLTYPE  of iDriverID to iDataType
91754>>>        End
91754>>>>
91754>>>        Move DF_TEXT     to ColumnTypeArray[iCount].iDataFlexType
91755>>>        Move "Text"      to ColumnTypeArray[iCount].sDataFlexType  
91756>>>        Get UtilColumnTypeToString sDriverID iDbType iDataType to sDataType
91757>>>        Move sDataType   to ColumnTypeArray[iCount].sType
91758>>>        Move iDataType   to ColumnTypeArray[iCount].iType
91759>>>        Increment iCount
91760>>>        
91760>>>        Function_Return ColumnTypeArray
91761>>>    End_Function
91762>>>    
91762>>>    Function UtilDeleteCacheFile String sTableName Returns Boolean
91764>>>        String sDataPath sDriverID
91764>>>        Boolean bMertechDriver bOK  
91764>>>        Integer iPos
91764>>>        
91764>>>        If (sTableName contains ".") Begin
91766>>>            Move (Pos(".", sTableName)) to iPos
91767>>>            Move (Mid(sTableName, 999, (iPos +1))) to sTableName    
91768>>>        End                                                     
91768>>>>
91768>>>        
91768>>>        Get psDriverID to sDriverID
91769>>>        Get psDataPathFirstPart to sDataPath 
91770>>>        Get IsMertechDriver sDriverID to bMertechDriver
91771>>>        // First delete the cache file:
91771>>>        If (bMertechDriver = False) Begin
91773>>>            Get vDeleteFile (sDataPath + sTableName + ".cch") to bOK
91774>>>        End 
91774>>>>
91774>>>        Else Begin
91775>>>            Get _MertechDeleteTDFile sTableName to bOK
91776>>>        End                
91776>>>>
91776>>>        
91776>>>        Function_Return bOK
91777>>>    End_Function
91778>>>
91778>>>    // Changes source code files.
91778>>>    // Pass a file name with full path and a value to search for, together with the value
91778>>>    // to change to. Can e.g. be used for changing all .int files from using a fixed server name,
91778>>>    // to use a Connection ID. 
91778>>>    // Sample: Get UtilChangeSourceCodeLine "C:\DataFlex 18.2 Examples\Order Entry\Data\Order.int" "SERVER_NAME SERVER=(local)\SQLEXPRESS1" "SERVER_NAME DFCONNID=ChinookDb"
91778>>>    // Pass "True" for the bShowResult if you want to see the result while it works. Showln will then be used for output
91778>>>    // Returns True if no errors occured. 
91778>>>    Function UtilChangeSourceCodeLine String sFileName String sChangeFrom String sChangeTo Boolean bShowResult Returns Boolean
91780>>>        Integer iCh iRow iItems iCount
91780>>>        String sValue sRow
91780>>>        String[] sFileArray
91781>>>        Boolean bExists
91781>>>    
91781>>>        Move False to Err
91782>>>        Move 0 to iRow
91783>>>    
91783>>>        Get vFilePathExists sFileName to bExists
91784>>>        If (bExists = False) Begin
91786>>>            If (bShowResult = True) Begin
91788>>>                Showln "File does not exist: " sFileName
91791>>>            End
91791>>>>
91791>>>            Function_Return False
91792>>>        End
91792>>>>
91792>>>    
91792>>>        Get Seq_Open_Input_Channel sFileName to iCh
91793>>>        If (iCh < 1) Begin
91795>>>            Function_Return False
91796>>>        End
91796>>>>
91796>>>        
91796>>>        If (bShowResult = True) Begin  
91798>>>            Showln ""
91800>>>            Showln "sFileName = " sFileName
91803>>>            Showln "sChangeFrom = " sChangeFrom " sChangeTo = " sChangeTo
91808>>>        End
91808>>>>
91808>>>        
91808>>>        While (not(SeqEof))
91812>>>            Readln channel iCh sRow
91814>>>            If (Uppercase(sRow) contains Uppercase(sChangeFrom)) Begin 
91816>>>                If (bShowResult = True) Begin
91818>>>                    Showln "Changed from: " sRow " to: " sChangeTo
91823>>>                End
91823>>>>
91823>>>                // Change the whole line to the new connection id:
91823>>>                Move sChangeTo to sRow
91824>>>                // Move (Replaces(sChangeFrom, sRow, sChangeTo)) to sValue
91824>>>            End
91824>>>>
91824>>>            Move sRow to sFileArray[iRow]
91825>>>            Increment iRow
91826>>>        End
91827>>>>
91827>>>        Send Seq_Close_Channel iCh
91828>>>        
91828>>>        Sleep 1 // Wait for Windows to close the file
91829>>>    
91829>>>        Get Seq_Open_Output_Channel sFileName to iCh
91830>>>        If (iCh < 1) Begin
91832>>>            Function_Return False
91833>>>        End
91833>>>>
91833>>>        Move (SizeOfArray(sFileArray)) to iItems
91834>>>        Decrement iItems
91835>>>    
91835>>>        For iCount from 0 to iItems
91841>>>>
91841>>>            Move sFileArray[iCount] to sValue
91842>>>            Writeln channel iCh sValue
91845>>>        Loop
91846>>>>
91846>>>        Send Seq_Close_Channel iCh
91847>>>    
91847>>>        Function_Return (Err = False)
91848>>>    End_Function
91849>>>    
91849>>>    // This might be needed by API-methods when a connection id is to be used and
91849>>>    // the connection ID hasn't been established with the driver's CLI interface.
91849>>>    // NOTE: Only applicable for DAW drivers, as Mertech drivers doesn't use connection ID's.
91849>>>    Function UtilCreateConnectionID String sConnectionID Returns Boolean
91851>>>        String sConnectionString sDriverID
91851>>>        Boolean bOK bSilent bDawDriver
91851>>>        Handle hoCLI
91851>>>        
91851>>>        Move False to bOK   
91852>>>        Get psDriverID to sDriverID
91853>>>        Get IsDAWSQLDriver sDriverID to bDawDriver
91854>>>        If (bDawDriver = False) Begin
91856>>>            Error DFERR_PROGRAM "The UtilCreateConnectionID function is only available for DAW drivers. (Not Mertech)."
91857>>>>
91857>>>            Function_Return False
91858>>>        End
91858>>>>
91858>>>        
91858>>>        Get psConnectionString to sConnectionString
91859>>>        Get pbSilentLogin      to bSilent
91860>>>        
91860>>>        Get phoCLIHandler to hoCLI 
91861>>>        If (hoCLI <> 0) Begin
91863>>>            Set psDriverID of hoCLI to sDriverID
91864>>>            Get CreateConnectionID of hoCLI sConnectionID sConnectionString bSilent to bOK
91865>>>        End
91865>>>>
91865>>>        
91865>>>        Function_Return (bOK = False)
91866>>>    End_Function
91867>>>
91867>>>    // This message creates an error log in the "Home" folder named "SQLErrorLog.txt",
91867>>>    // and opens it in "notepad.exe".
91867>>>    // Note: This is _not_ used by the cDbUpdateHandler & cDbUpdateVersion classes!
91867>>>    //       Instead the cDbUpdateLogFile's WriteErrorLog & ShowErrorLog are then used.
91867>>>    Procedure UtilShowErrorList
91869>>>        tSqlErrorArray aSqlErrorArray 
91869>>>        tSqlErrorArray aSqlErrorArray 
91869>>>        Integer iRows iCount iCh iErrorNum
91869>>>        String sPath sFileName sErrorTxt sStatement
91869>>>        
91869>>>        Get psHome of (phoWorkspace(ghoApplication)) to sPath
91870>>>        Get vFolderFormat sPath to sPath
91871>>>        Move "SQLErrorLog.txt"  to sFileName
91872>>>        Get Seq_Open_Output_Channel (sPath + sFileName) to iCh
91873>>>            Get paSqlErrorArray to aSqlErrorArray
91874>>>            Move (SizeOfArray(aSqlErrorArray.sSqlErrorArray)) to iRows
91875>>>            If (iRows > 0) Begin
91877>>>                Decrement iRows
91878>>>                for iCount from 0 to iRows
91884>>>>
91884>>>                    Move aSqlErrorArray.sSqlErrorArray[iCount]      to sErrorTxt
91885>>>                    Move aSqlErrorArray.sSqlStatementArray[iCount]  to sStatement
91886>>>                    Move aSqlErrorArray.iSqlErrorArray[iCount]      to iErrorNum
91887>>>                    Writeln channel iCh "Error No: " iErrorNum " Error Text: " sErrorTxt
91893>>>                    Writeln channel iCh "SQL Statement: " sStatement
91897>>>                Loop
91898>>>>
91898>>>            End
91898>>>>
91898>>>        Send Seq_Close_Channel iCh
91899>>>        
91899>>>        If (iRows > 0) Begin
91901>>>            Runprogram Background "Notepad.exe" (sPath + sFileName)
91902>>>        End
91902>>>>
91902>>>    End_Procedure
