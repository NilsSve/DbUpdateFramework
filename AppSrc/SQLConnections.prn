89701>>>    Function _SqlProperTableName String sTableName Returns String
89703>>>        String sVal sSchema sDriverID sValue
89703>>>        Handle hTable  
89703>>>        Integer iDbType
89703>>>        
89703>>>        If (Trim(sTableName) = "") Begin
89705>>>            Function_Return ""
89706>>>        End
89706>>>>
89706>>>
89706>>>        Get psDriverID to sDriverID
89707>>>        Get piDbType   to iDbType
89708>>>        If (iDbType = EN_dbTypeOracle) Begin
89710>>>            Get psUserID to sSchema
89711>>>            // Not sure about this uppercasing but it seems like Oracle wants that?
89711>>>            Move (Uppercase(sSchema)) to sSchema
89712>>>            Move ('"' + sSchema + '"."' + sTableName + '"') to sTableName
89713>>>            Function_Return sTableName
89714>>>        End 
89714>>>>
89714>>>        If (iDbType = EN_DbTypeMySQL) Begin
89716>>>            Get psDatabase to sVal
89717>>>            Move (sVal + "." + sTableName) to sTableName
89718>>>            Function_Return sTableName
89719>>>        End 
89719>>>>
89719>>>        If (iDbType = EN_DbTypePostgre) Begin
89721>>>            Move ('"' + sTableName + '"') to sTableName
89722>>>            Function_Return sTableName
89723>>>        End
89723>>>>
89723>>>        
89723>>>        Get psSchema to sSchema   
89724>>>        If (sSchema = "") Begin
89726>>>            Get _SqlFindKeyWord CI_SQLDBO to sSchema
89727>>>        End
89727>>>>
89727>>>
89727>>>        Move (Uppercase(sTableName)) to sVal
89728>>>        If (not(sVal contains (sSchema + "."))) Begin  
89730>>>            If (iDbType = EN_dbTypeDB2) Begin
89732>>>                Move (Lowercase(sSchema) + "." + sTableName) to sTableName
89733>>>            End 
89733>>>>
89733>>>            Else Begin
89734>>>                Move (sSchema + "." + sTableName) to sTableName
89735>>>            End
89735>>>>
89735>>>        End    
89735>>>>
89735>>>
89735>>>        Function_Return sTableName
89736>>>    End_Function
89737>>>    
89737>>>    // SQL column names can be case-sensitive. This function is used to check that
89737>>>    // the passed sFieldName has the correct spelling.                            
89737>>>    // Used with Embedded SQL statement calls.
89737>>>    // If the spelling or fieldname doesn't exist, the return value is "" (blank).
89737>>>    Function _SqlFindColumnName String sTableName String sColumnName Returns String
89739>>>        String sRetval sValue sConnectionString sDriverID 
89739>>>        String[] sColumnNamesArray
89740>>>        Integer iCount iColumns
89740>>>
89740>>>        Move "" to sRetval
89741>>>        Get psDriverID to sDriverID
89742>>>        Get SqlUtilEnumerateColumns sDriverID sTableName to sColumnNamesArray
89743>>>        Move (SizeOfArray(sColumnNamesArray)) to iColumns
89744>>>        Decrement iColumns
89745>>>        
89745>>>        For iCount from 0 to iColumns
89751>>>>
89751>>>            Move sColumnNamesArray[iCount] to sValue
89752>>>            If (Uppercase(sColumnName) = Uppercase(sValue)) Begin
89754>>>                Move sValue to sRetval
89755>>>                Move iColumns to iCount // We're done.
89756>>>            End
89756>>>>
89756>>>        Loop                           
89757>>>>
89757>>>        
89757>>>        Function_Return sRetval
89758>>>    End_Function
