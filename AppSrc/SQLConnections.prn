89298>>>    
89298>>>    // *** Helper Functions ***
89298>>>    // They all start with an underscore: "_" in the function name.
89298>>>    //
89298>>>    // Reads a SQL script file that has been compiled into the .exe program as a resource.
89298>>>    // Pass: The memory resource reference and a boolean True if you want to create the file on disk (in the Home folder).
89298>>>    // Returns: A tSQLScriptArray Struct with the Sql script as an uChar Array will be returned along with the a bError boolean.
89298>>>    Function SqlUtilReadResource String sMemFileName Returns tSQLScriptArray
89300>>>        Integer iChannel iArgumentSize iOut iChunk iPointer iCount iSize
89300>>>        Number nByteCount
89300>>>        String sCharacter sSQLScript 
89300>>>        Boolean bSeqEof
89300>>>        tSQLScriptArray SqlScriptArray
89300>>>        tSQLScriptArray SqlScriptArray
89300>>>        UChar[] uCharData
89301>>>        
89301>>>        Move False to Err
89302>>>        Get Seq_New_Channel to iChannel
89303>>>        If (iChannel = DF_SEQ_CHANNEL_NOT_AVAILABLE) Begin
89305>>>            Error DFERR_PROGRAM 'No channel available...'
89306>>>>
89306>>>            Move True to SqlScriptArray.bError
89307>>>            Function_Return SqlScriptArray
89308>>>        End                    
89308>>>>
89308>>>        
89308>>>        // First decide the size of the script
89308>>>        Direct_Input channel iChannel ("Resource: " + sMemFileName)
89310>>>        Read_Block channel iChannel uCharData -1 // -1 means that all data should be read.
89312>>>        Close_Input channel iChannel
89314>>>
89314>>>        Move (SizeOfArray(uCharData)) to nByteCount 
89315>>>        If (nByteCount  < 1) Begin
89317>>>            Send Seq_Release_Channel iChannel  
89318>>>            Move True to SqlScriptArray.bError
89319>>>            Function_Return SqlScriptArray
89320>>>        End
89320>>>>
89320>>>        
89320>>>        // If necessary change the string argument_size
89320>>>        Get_Argument_Size to iArgumentSize
89321>>>        If (nByteCount >= iArgumentSize) Begin
89323>>>            Move (nByteCount + 2048) to nByteCount
89324>>>            Set_Argument_Size nByteCount // Set new argument size just a bit higher than "needed" for overhead margin.
89325>>>>
89325>>>            Move True          to SqlScriptArray.bArgumentSizeChanged
89326>>>            Move iArgumentSize to SqlScriptArray.iOrgArgumentSize
89327>>>        End                         
89327>>>>
89327>>>        Else Begin
89328>>>            Move False to SqlScriptArray.bArgumentSizeChanged
89329>>>        End
89329>>>>
89329>>>        
89329>>>        // Read the script file from memory line-by-line
89329>>>        Direct_Input channel iChannel ("Resource: " + sMemFileName) 
89331>>>            Move 0 to iCount
89332>>>            Repeat
89332>>>>
89332>>>                Readln channel iChannel sSQLScript
89334>>>                Move sSQLScript to SqlScriptArray.sSQLScriptArray[iCount]
89335>>>                Increment iCount
89336>>>            Until (SeqEof = True)
89338>>>        Close_Input channel iChannel
89340>>>        Send Seq_Release_Channel iChannel 
89341>>>        
89341>>>        // Finally "sanitize" the script by removing all comments.
89341>>>        Get _SqlUtilSanitizeScript SqlScriptArray to SqlScriptArray  
89342>>>
89342>>>        Function_Return SqlScriptArray
89343>>>    End_Function 
89344>>>    
89344>>>    Function SqlUtilExecuteEmbeddedScript tSQLScriptArray SQLScriptArray String sDriverID Boolean bCreateScriptFile String sMemFileName Boolean bShowProgr Returns Boolean
89346>>>        String sSQLVal sStmt sCR sDebugFileName sTmp sGOKeyWord sNoCountKeyWord sMessage sExportFile
89346>>>        Handle hoSql hoSQLConnect hoStmt hoError
89346>>>        Integer i iMsgs iFetchResult iResultCount iRows iRowType iCount iChunkCounter iChunkMax iPos iOut iNextSet iMessage
89346>>>        String[] sMsg aSQLQueryMessages
89348>>>        DateTime dtQueryExecStart dtQueryExecEnd
89348>>>        TimeSpan tsQuery
89348>>>        tSqlErrorArray aSqlErrorArray  
89348>>>        tSqlErrorArray aSqlErrorArray  
89348>>>        tSQLConnection SQLConnection
89348>>>        tSQLConnection SQLConnection
89348>>>        Boolean bOK bMertechDriver bShowProgress
89348>>>        
89348>>>        If (num_arguments > 4) Begin
89350>>>            Move bShowProgr to bShowProgress
89351>>>        End
89351>>>>
89351>>>        Get IsMertechDriver sDriverID to bMertechDriver
89352>>>        If (bMertechDriver = False) Begin
89354>>>            Get phoSQLManager to hoSql
89355>>>        End 
89355>>>>
89355>>>        Else Begin
89356>>>            Get _MertechSQLManagerHandle to hoSql
89357>>>        End
89357>>>>
89357>>>            
89357>>>        Get _SqlFindKeyWord CI_SQLGO to sGOKeyWord
89358>>>        // There seems to be a problem to pass strings when their value gets really big, aka
89358>>>        // above the argument_size level. It isn't clear when these problems starts but sooner
89358>>>        // or later SqlExecDirect stops working correctly with no error messages!
89358>>>        // To guard from this we set a max number of lines (iChunkMax) that can be processed
89358>>>        // at a time. Testing with the Create Chinook Database script; 500 seems like a number that works fine. 
89358>>>        // A bonus of this is that it turns out that it is actually faster to run in chunks!
89358>>>        Get piChunkMax to iChunkMax    
89359>>>        Move 0 to iChunkCounter                                 
89360>>>        Move "" to sStmt   
89361>>>
89361>>>        Get _SqlFindKeyWord CI_SQLSetNoCountOn to sNoCountKeyWord
89362>>>        Move (Character(13) + Character(10)) to sCR
89363>>>
89363>>>        Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
89364>>>        
89364>>>        If (bMertechDriver = True) Begin
89366>>>            Get _MertechSQLConnect sDriverID SQLConnection.sServer SQLConnection.sUserID SQLConnection.sPassword to hoSQLConnect
89367>>>        End
89367>>>>
89367>>>        If (bMertechDriver = False) Begin
89369>>>            Get phoSQLManager  to hoSQL
89370>>>            Send SqlSetConnect of hoSQL sDriverID SQLConnection.sConnectionString
89371>>>            Get SqlConnect     of hoSQL "" "" to hoSQLConnect
89372>>>        End
89372>>>>
89372>>>
89372>>>        If (hoSQLConnect <> 0) Begin 
89374>>>            Move False to Err
89375>>>            Get SqlOpen of hoSQLConnect to hoStmt
89376>>>            If (hoStmt <> 0) Begin
89378>>>
89378>>>                // If the embedded resource should be written as a script file to disk:
89378>>>                If (bCreateScriptFile = True) Begin
89380>>>                    Get psHome of (phoWorkspace(ghoApplication)) to sExportFile
89381>>>                    Get vFolderFormat sExportFile to sExportFile
89382>>>                    Move (sExportFile + sMemFileName) to sExportFile
89383>>>                    Get Seq_New_Channel to iOut 
89384>>>                    If (iOut <> DF_SEQ_CHANNEL_NOT_AVAILABLE) Begin
89386>>>                        Direct_Output channel iOut sExportFile  
89388>>>                    End
89388>>>>
89388>>>                End
89388>>>>
89388>>>        
89388>>>                // Record starting date/time stamp
89388>>>                Move (CurrentDateTime()) to dtQueryExecStart
89389>>>                // Turn on error handling if enabled
89389>>>                If (pbHandleQueryErrors(Self)) Begin
89391>>>                    Set pbSqlError to False  
89392>>>                    Set paSqlErrorArray to aSqlErrorArray
89393>>>                    Move Error_Object_Id to hoError
89394>>>                    Move Self to Error_Object_Id
89395>>>                End                                                    
89395>>>>
89395>>>                
89395>>>                Move (SizeOfArray(SQLScriptArray.sSQLScriptArray)) to iRows  
89396>>>                Decrement iRows
89397>>>                Move (sNoCountKeyWord + sCR) to sStmt
89398>>>
89398>>>                For iCount from 0 to iRows   
89404>>>>
89404>>>                    Move (SQLScriptArray.sSQLScriptArray[iCount]) to sSQLVal
89405>>>                    
89405>>>                    If (Uppercase(sSQLVal) <> sGOKeyWord) Begin
89407>>>                        If (sSQLVal <> "") Begin
89409>>>                            Move (sSQLVal + sCR) to sSQLVal
89410>>>                        End
89410>>>>
89410>>>                        Move (Append(sStmt, (sSQLVal))) to sStmt
89411>>>                    End
89411>>>>
89411>>>                    
89411>>>                    // - Each time we encounter a "GO" statement we execute it,
89411>>>                    // or if at the very end of the script.
89411>>>                    If (Uppercase(sSQLVal) = sGOKeyWord or iChunkCounter >= iChunkMax or iCount = iRows) Begin 
89413>>>                        
89413>>>                        // - It turns out it can be at least 10 times faster to execute SQL statements in chunks,
89413>>>                        // instead of all in one go. 
89413>>>                        Send SqlExecDirect of hoStmt sStmt 
89414>>>                        
89414>>>                        If (bCreateScriptFile = True) Begin
89416>>>                            Write channel iOut sStmt
89418>>>                        End
89418>>>>
89418>>>                        Move "" to sStmt   
89419>>>                        Move 0 to iChunkCounter
89420>>>                    End
89420>>>>
89420>>>                    Increment iChunkCounter
89421>>>                Loop
89422>>>>
89422>>>                       
89422>>>                Repeat
89422>>>>
89422>>>                    If (pbHandleQueryErrors(Self)) Begin
89424>>>                        Move hoError to Error_Object_Id
89425>>>                    End
89425>>>>
89425>>>                    Move (CurrentDateTime()) to dtQueryExecEnd  
89426>>>                    
89426>>>                    Send _SqlColumnInfo hoStmt
89427>>>                    Get SqlStmtAttribute of hoStmt SqlSTMTATTRIB_ROWCOUNT to iRows
89428>>>                    Get SqlStmtAttribute of hoStmt SqlSTMTATTRIB_ROWCOUNT_TYPE to iRowType
89429>>>                    Get SqlStmtAttribute of hoStmt SqlSTMTATTRIB_NUMMESSAGES to iMsgs
89430>>>                    Set piRows    to iRows
89431>>>                    Set piRowType to iRowType
89432>>>                   
89432>>>                    If (iMsgs <> 0) Begin
89434>>>                        If (ghoDbUpdateHandler > 0) Begin
89436>>>                            Get paSQLQueryMessages of ghoDbUpdateHandler to aSQLQueryMessages
89437>>>                        End
89437>>>>
89437>>>                        For i from 1 to iMsgs
89443>>>>
89443>>>                            Get SqlGetMessage of hoStmt i to sMessage     
89444>>>                            Get RemoveComponentIdentifier of hoStmt sMessage to sMessage   
89445>>>                            If (bShowProgress = True) Begin
89447>>>                                If (Active_State(ghoStatusPanel)) Begin
89449>>>                                    Send Update_StatusPanel of ghoStatusPanel (Sformat("  SQLGetMessage iMessage %1 returned [%2]", iMessage, sMessage))
89450>>>                                End                                                   
89450>>>>
89450>>>                                Else Begin
89451>>>                                    Showln (Sformat("  SQLGetMessage iMessage %1 returned [%2]", iMessage, sMessage))
89453>>>                                End
89453>>>>
89453>>>                            End
89453>>>>
89453>>>                            Move sMessage to sMsg[SizeOfArray(sMsg)]
89454>>>                            Move sMessage to aSQLQueryMessages[SizeOfArray(aSQLQueryMessages)]
89455>>>                        Loop   
89456>>>>
89456>>>                    
89456>>>                    
89456>>>                        If (ghoDbUpdateHandler > 0) Begin
89458>>>                            Set paSQLQueryMessages of ghoDbUpdateHandler to aSQLQueryMessages
89459>>>                        End
89459>>>>
89459>>>                        Set paQueryMessages to sMsg
89460>>>                    End
89460>>>>
89460>>>
89460>>>                    Get SQLNextResultSet of hoStmt to iNextSet
89461>>>                Until (iNextSet = 0)
89463>>>                
89463>>>                Move (CurrentDateTime()) to dtQueryExecEnd
89464>>>            End 
89464>>>>
89464>>>            
89464>>>            Move (dtQueryExecEnd - dtQueryExecStart) to tsQuery
89465>>>            Set ptsQueryExec to tsQuery  
89466>>>            Send SqlClose of hoStmt
89467>>>
89467>>>            If (bCreateScriptFile = True) Begin
89469>>>                Close_Output channel iOut
89471>>>                Send Seq_Release_Channel iOut
89472>>>            End
89472>>>>
89472>>>        End
89472>>>>
89472>>>        Send SqlDisconnect of hoSQLConnect
89473>>>
89473>>>        Function_Return (hoSQLConnect <> 0 and Err = False)
89474>>>    End_Function
89475>>>        
89475>>>    // Returns the index for the passed sTableName
89475>>>    // Returns >= 0 if successful. It is e.g. needed to get the SchemaName for a table.
89475>>>    Function _SqlUtilEnumerateTableIndex String sTableName String sDriverID Returns Integer
89477>>>        Integer iIndex iSize iCount
89477>>>        String[] sTablesArray
89478>>>        String sVal sConnectionString
89478>>>        
89478>>>        Move -1 to iIndex            
89479>>>        Get psConnectionString to sConnectionString
89480>>>        Get SqlUtilEnumerateTables sDriverID to sTablesArray
89481>>>        Move (SizeOfArray(sTablesArray)) to iSize
89482>>>        Decrement iSize
89483>>>        For iCount from 0 to iSize
89489>>>>
89489>>>            Move sTablesArray[iCount] to sVal
89490>>>            If (Uppercase(sVal) = Uppercase(sTableName)) Begin
89492>>>                Move iCount to iIndex // We found it!
89493>>>                Move iSize to iCount  // End the loop    
89494>>>            End
89494>>>>
89494>>>        Loop                  
89495>>>>
89495>>>        
89495>>>        Function_Return iIndex
89496>>>    End_Function
