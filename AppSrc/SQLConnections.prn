96096>>>>>>>    Procedure Add_Focus Handle hoParent Returns Integer
96098>>>>>>>        Integer eMode
96098>>>>>>>        Integer[] SelRowsIndexes
96099>>>>>>>        Set pbCanceled to True // assume cancel unless changed
96100>>>>>>>        Set pSelectedRows to SelRowsIndexes // empty
96101>>>>>>>        Get peUpdateMode to eMode
96102>>>>>>>        If (eMode<>umPromptNonInvoking) Begin
96104>>>>>>>            Send OnStoreDefaults
96105>>>>>>>        End
96105>>>>>>>>
96105>>>>>>>        Send InitializePromptList
96106>>>>>>>        Forward Send Add_Focus hoParent
96108>>>>>>>        Send LoadData
96109>>>>>>>        Set psSeedValue to ""
96110>>>>>>>    End_Procedure
96111>>>>>>>    
96111>>>>>>>    // called before the list is activated. 
96111>>>>>>>    Procedure InitializePromptList
96113>>>>>>>        Integer hoInvokingObject
96113>>>>>>>        Boolean bAutoColumn bAutoSeed 
96113>>>>>>>        Integer i iOldMode eUpdateMode
96113>>>>>>>        String sValue
96113>>>>>>>        
96113>>>>>>>        Get peUpdateMode to eUpdateMode
96114>>>>>>>        If (eUpdateMode<>umPromptNonInvoking) Begin
96116>>>>>>>            Get Focus of Desktop to hoInvokingObject
96117>>>>>>>            If (hoInvokingObject<=Desktop) Begin
96119>>>>>>>                Error DFERR_PROGRAM "Prompt list has no invoking object"
96120>>>>>>>>
96120>>>>>>>                Procedure_Return
96121>>>>>>>            End
96121>>>>>>>>
96121>>>>>>>
96121>>>>>>>            Set phoInvokingObject to hoInvokingObject
96122>>>>>>>
96122>>>>>>>            Send Prompt_Callback to hoInvokingObject Self
96123>>>>>>>            Get peUpdateMode to eUpdateMode
96124>>>>>>>        End
96124>>>>>>>>
96124>>>>>>>
96124>>>>>>>        Send ClearSearchRequest // clear the search keys
96125>>>>>>>        Set pbNeedsNewOrdering to False
96126>>>>>>>
96126>>>>>>>        Get pbAutoSeed to bAutoSeed
96127>>>>>>>
96127>>>>>>>        If (eUpdateMode=umPromptValue) Begin // else not used here intentionally
96129>>>>>>>            Get Value of hoInvokingObject to sValue
96130>>>>>>>            Set psSeedValue to sValue
96131>>>>>>>        End
96131>>>>>>>>
96131>>>>>>>        
96131>>>>>>>    End_Procedure
96132>>>>>>>    
96132>>>>>>>    // called after list is created and active. Load Data, seed list, select start column, etc.
96132>>>>>>>    Procedure LoadData
96134>>>>>>>        Handle hoInvokingObject hoDataSource hoInitialColumn
96134>>>>>>>        Integer iUpdateColumn iRows iInitialColumn iInitialOrder
96134>>>>>>>        Integer eUpdateMode
96134>>>>>>>        Boolean bAutoSeed bAutoColumn bCancel bSubFocus bAutoOrder 
96134>>>>>>>        
96134>>>>>>>        Get phoDataSource to hoDataSource
96135>>>>>>>        Get peUpdateMode to eUpdateMode
96136>>>>>>>        Get phoInvokingObject to hoInvokingObject
96137>>>>>>>        Get pbAutoSeed to bAutoSeed
96138>>>>>>>        Get piInitialColumn to iInitialColumn
96139>>>>>>>        Get piUpdateColumn to iUpdateColumn
96140>>>>>>>        Get RowCount of hoDataSource to iRows
96141>>>>>>>        
96141>>>>>>>        // We need an initial column. if you specified an initial column that will get used for the start column
96141>>>>>>>        // and the initial sort order. If you did not, which is typical, it will use the update column
96141>>>>>>>        If (iInitialColumn=-1) Begin
96143>>>>>>>            Move iUpdateColumn to iInitialColumn
96144>>>>>>>        End
96144>>>>>>>>
96144>>>>>>>        If (iInitialColumn>=0) Begin
96146>>>>>>>            Get ColumnObject iInitialColumn to hoInitialColumn
96147>>>>>>>            Set pbVisible of hoInitialColumn to True // initial column should be visible
96148>>>>>>>        End
96148>>>>>>>>
96148>>>>>>>        Send OnSeedData // find a good starting place for the row
96149>>>>>>>        Get pbFocusSubItems to bSubFocus
96150>>>>>>>        If bSubFocus Begin
96152>>>>>>>            // if column focus, which is normal, go to initialcolumn       
96152>>>>>>>            If hoInitialColumn Begin
96154>>>>>>>                Get MoveToColumnObject hoInitialColumn to bCancel
96155>>>>>>>            End
96155>>>>>>>>
96155>>>>>>>            Else Begin
96156>>>>>>>                Send MoveToFirstEnterableColumn
96157>>>>>>>            End
96157>>>>>>>>
96157>>>>>>>        End
96157>>>>>>>>
96157>>>>>>>
96157>>>>>>>    End_Procedure
96158>>>>>>>    
96158>>>>>>>    // This is only called in a successful close
96158>>>>>>>    Procedure ClosePromptList
96160>>>>>>>        Handle hoDataSource hoInvokingObject
96160>>>>>>>        Handle hmCallBack
96160>>>>>>>        Integer iRow eUpdateMode
96160>>>>>>>        Integer[] SelRowsIndexes
96161>>>>>>>        
96161>>>>>>>        Get phoDataSource to hoDataSource
96162>>>>>>>        Get phoInvokingObject to hoInvokingObject
96163>>>>>>>        
96163>>>>>>>        If (pbMultipleSelection(Self)) Begin
96165>>>>>>>            Get GetIndexesForSelectedRows to SelRowsIndexes
96166>>>>>>>        End
96166>>>>>>>>
96166>>>>>>>        Else Begin
96167>>>>>>>            Get SelectedRow of hoDataSource to iRow
96168>>>>>>>            If (iRow<>-1) Begin
96170>>>>>>>                Move iRow to SelRowsIndexes[0]
96171>>>>>>>            End
96171>>>>>>>>
96171>>>>>>>        End
96171>>>>>>>>
96171>>>>>>>        
96171>>>>>>>        Set pbCanceled to False
96172>>>>>>>        Set pSelectedRows to SelRowsIndexes
96173>>>>>>>        
96173>>>>>>>        Get peUpdateMode to eUpdateMode
96174>>>>>>>        // if non-invoking there is by definition, no move value out
96174>>>>>>>        If (eUpdateMode<>umPromptNonInvoking) Begin
96176>>>>>>>            
96176>>>>>>>            If (eUpdateMode=umPromptValue) Begin
96178>>>>>>>                Send OnMoveValueOutByValue
96179>>>>>>>            End
96179>>>>>>>>
96179>>>>>>>            Else If (eUpdateMode=umPromptCustom) Begin
96182>>>>>>>                Send OnMoveValueOutByCustom
96183>>>>>>>            End
96183>>>>>>>>
96183>>>>>>>                Get phmPromptUpdateCallback to hmCallBack
96184>>>>>>>                If hmCallBack Begin
96186>>>>>>>                    Send hmCallBack of hoInvokingObject Self
96187>>>>>>>                End
96187>>>>>>>>
96187>>>>>>>        End
96187>>>>>>>>
96187>>>>>>>
96187>>>>>>>        Send Close_Panel
96188>>>>>>>    End_Procedure
96189>>>>>>>
