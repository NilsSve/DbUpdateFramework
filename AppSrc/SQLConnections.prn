87371>>>>>
87371>>>>    Move (Left(sConnect, (iStart -1 + Length(sKeyWord)))) to sRetval
87372>>>>    Move (Replace(sRetval, sConnect, "")) to sRetval 
87373>>>>    If (sKeyWord = Uppercase(CS_SQLConnectionIDText)) Begin
87375>>>>        Move (Pos(",", sRetval))          to iEnd
87376>>>>    End
87376>>>>>
87376>>>>    Else Begin
87377>>>>        Move (Pos(";", sRetval))          to iEnd
87378>>>>    End                                          
87378>>>>>
87378>>>>    If (iEnd = 0 and (sRetval contains ",")) Begin
87380>>>>        Move (Pos(",", sRetval))          to iEnd 
87381>>>>        Decrement iEnd
87382>>>>    End
87382>>>>>
87382>>>>    If (iEnd <> 0) Begin
87384>>>>        Move (Left(sRetval, (iEnd -1)))   to sRetval
87385>>>>    End
87385>>>>>
87385>>>>    Move (Replace("=", sRetval, ""))      to sRetval
87386>>>>
87386>>>>    Function_Return (Trim(sRetval))
87387>>>>End_Function
