87746>>>        Get piDbType to iDbType
87747>>>        Get UtilColumnTypeToString sDriverID iDbType iDataType to sDataType
87748>>>        
87748>>>        Move False to Err   
87749>>>        Get _SqlProperTableName sTableName    to sTableName
87750>>>        Get _SqlFindKeyWord CI_SQLAlterTable  to sAlterTable
87751>>>        Get _SqlFindKeyWord CI_SQLAlterColumn to sAlterColumn
87752>>>        Get SQLUtilDefaultNullValue sDriverID iDbType iDataType to sNotNull
87753>>>
87753>>>        Get UtilColumnTypeFixed sDriverID iDbType iDataType to bFixed
87754>>>        If (bFixed = False) Begin
87756>>>            Get _SqlFormatLengthAndDecimalAsString iLength iDecimals to sLengthAndDecimals
87757>>>        End
87757>>>>
87757>>>        
87757>>>        Move (sAlterTable * sTableName * sAlterColumn * sColumnName * sDataType + sLengthAndDecimals * sNotNull) to sStmt
87758>>>        Send SqlUtilExecuteQuery sStmt sDriverID
87759>>>    
87759>>>        // We also need to remove the cache-file since the table has been changed
87759>>>        Get UtilDeleteCacheFile sTableName to bOK
87760>>>    
87760>>>        Function_Return (Err = False)    
87761>>>    End_Function    
87762>>>    
87762>>>    Function SqlColumnDefaultValue Handle hTable Integer iColumn String sValue Returns Boolean
87764>>>        Boolean bOK bErr bIsSQLDriver
87764>>>        String sDriverID
87764>>>        
87764>>>        Get psDriverID to sDriverID
87765>>>        Get IsSQLDriver sDriverID to bIsSQLDriver
87766>>>        If (bIsSQLDriver = False) Begin
87768>>>            Function_Return False
87769>>>        End
87769>>>>
87769>>>
87769>>>        Move Err to bErr
87770>>>        Move False to bErr                                      
87771>>>        
87771>>>        // There seems to be a problem with the ODBC_DRV driver that sometimes
87771>>>        // inserts randomly character(10) and spaces, so we correct from that here:
87771>>>        Move (Replaces(Character(10), Trim(sValue), "")) to sValue                   
87772>>>        
87772>>>        Set_Attribute DF_FIELD_DEFAULT_VALUE of hTable iColumn to sValue
87775>>>        Move (not(Err)) to bOK
87776>>>        Move bErr to Err
87777>>>        
87777>>>        Function_Return bOK
87778>>>    End_Function
87779>>>    
87779>>>    Function SqlColumnNullable Handle hTable Integer iColumn Boolean bNullable Returns Boolean
87781>>>        Boolean bOK bErr bCurrentState bOpen bIsSQLDriver
87781>>>        String sDriverID
87781>>>        
87781>>>        Get psDriverID to sDriverID
87782>>>        Get IsSQLDriver sDriverID to bIsSQLDriver
87783>>>        If (bIsSQLDriver = False) Begin
87785>>>            Function_Return False
87786>>>        End
87786>>>>
87786>>>        
87786>>>        Move Err to bErr
87787>>>        Move False to bErr
87788>>>        Get_Attribute DF_FIELD_NULL_ALLOWED of hTable iColumn to bCurrentState
87791>>>        If (bNullable = bCurrentState) Begin
87793>>>            Function_Return True
87794>>>        End                     
87794>>>>
87794>>>        
87794>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpen
87797>>>        If (bOpen = False) Begin                       
87799>>>            Get AutoConnectionIDLogin to bOK
87800>>>            Send Ignore_Error of Error_Object_Id DFERR_CANT_OPEN_DATA_FILE
87801>>>            Send Ignore_Error of Error_Object_Id DFERR_CANT_OPEN_INTERMEDIATE_FILE
87802>>>            Send Ignore_Error of Error_Object_Id CLIERR_GENERAL_ERROR
87803>>>            Open hTable
87805>>>            Send Trap_Error of Error_Object_Id DFERR_CANT_OPEN_DATA_FILE
87806>>>            Send Trap_Error of Error_Object_Id DFERR_CANT_OPEN_INTERMEDIATE_FILE
87807>>>            Send Trap_Error of Error_Object_Id CLIERR_GENERAL_ERROR
87808>>>            Get_Attribute DF_FILE_OPENED of hTable to bOpen
87811>>>        End
87811>>>>
87811>>>        If (bOpen = True) Begin
87813>>>            Structure_Start hTable sDriverID
87814>>>                Set_Attribute DF_FIELD_NULL_ALLOWED of hTable iColumn to bNullable
87817>>>            Structure_End hTable
87819>>>        End
87819>>>>
87819>>>
87819>>>        Move (not(Err)) to bOK
87820>>>        Move bErr to Err
87821>>>        
87821>>>        Function_Return bOK
87822>>>    End_Function
87823>>>    
87823>>>    // Drop column by its table handle 
87823>>>    Function SqlColumnRemove Handle hTable String sColumnName Returns Boolean
87825>>>        Integer iColumn idbType
87825>>>        String sDriverID sStmt sAlterTable sDropColumn sVal sTableName 
87825>>>        Boolean bExists bOK
87825>>>        
87825>>>        Get psDriverID to sDriverID
87826>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
87827>>>        If (bOK = False) Begin
87829>>>            Function_Return False
87830>>>        End
87830>>>>
87830>>>        
87830>>>        Get UtilTableHandleToString hTable to sTableName
87831>>>        If (sTableName = "") Begin
87833>>>            Function_Return False
87834>>>        End  
87834>>>>
87834>>>        
87834>>>        Get SqlColumnRemoveByTableName sTableName sColumnName to bOK
87835>>>            
87835>>>        Function_Return (bOK = True)    
87836>>>    End_Function    
87837>>>    
87837>>>    // Drop column by its table name as a string.
87837>>>    Function SqlColumnRemoveByTableName String sTableName String sColumnName Returns Boolean
87839>>>        Integer iColumn iDbType iDriver
87839>>>        String sDriverID sStmt sAlterTable sDropColumn sVal 
87839>>>        Boolean bExists bOK bRetval bDriverIgnoreErrorState
87839>>>        Handle hTable 
87839>>>        
87839>>>        Get psDriverID to sDriverID
87840>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
87841>>>        If (bOK = False) Begin
87843>>>            Function_Return False
87844>>>        End
87844>>>>
87844>>>
87844>>>        Get DriverIndex sDriverID to iDriver
87845>>>        Get_Attribute DF_DRIVER_IGNORE_WARNINGS of iDriver to bDriverIgnoreErrorState
87848>>>        Set_Attribute DF_DRIVER_IGNORE_WARNINGS of iDriver to True
87851>>>        
87851>>>        Get UtilTableNameToHandle sTableName to hTable
87852>>>        If (hTable <> 0) Begin
87854>>>            Get SQLUtilColumnExists sTableName sColumnName to bExists
87855>>>            If (bExists = False) Begin
87857>>>                Set_Attribute DF_DRIVER_IGNORE_WARNINGS of iDriver to bDriverIgnoreErrorState
87860>>>                Function_Return False
87861>>>            End
87861>>>>
87861>>>        End
87861>>>>
87861>>>
87861>>>        Get piDbType to iDbType
87862>>>        If (iDbType = EN_DbTypeMSSQL) Begin
87864>>>            Get _SqlUtilRemoveTableColumnMSSQL sTableName sColumnName to bOK
87865>>>            Get UtilDeleteCacheFile sTableName to bOK
87866>>>            Set_Attribute DF_DRIVER_IGNORE_WARNINGS of iDriver to bDriverIgnoreErrorState
87869>>>            Function_Return bOK
87870>>>        End
87870>>>>
87870>>>        
87870>>>        Move False to Err   
87871>>>        Get _SqlProperTableName sTableName    to sTableName
87872>>>        Get _SqlFindKeyWord CI_SQLAlterTable  to sAlterTable
87873>>>        Get _SqlFindKeyWord CI_SQLDropColumn  to sDropColumn   
87874>>>        
87874>>>        Move (sAlterTable * sTableName * sDropColumn * sColumnName) to sStmt
87875>>>        Send SqlUtilExecuteQuery sStmt sDriverID
87876>>>        Move (not(Err)) to bRetval
87877>>>    
87877>>>        // We also need to remove the cache-file since the table has been changed
87877>>>        Get UtilDeleteCacheFile sTableName to bOK
87878>>>        Set_Attribute DF_DRIVER_IGNORE_WARNINGS of iDriver to bDriverIgnoreErrorState
87881>>>    
87881>>>        Function_Return bRetval
87882>>>    End_Function    
87883>>>    
87883>>>    // Rename a field/column by table handle (filelist number)
87883>>>    Function SqlColumnRename Integer hTable String sColumnName String sNewColumnName Returns Boolean
87885>>>        Integer iColumn idbType
87885>>>        String sDriverID sTableName sStmt sAlterTable sRenameColumn sVal sColumnKeyWord
87885>>>        Boolean bExists bOK
87885>>>        
87885>>>        Get psDriverID to sDriverID
87886>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
87887>>>        If (bOK = False) Begin
87889>>>            Function_Return False
87890>>>        End
87890>>>>
87890>>>        
87890>>>        Get UtilTableHandleToString hTable to sTableName   
87891>>>        Get SqlColumnRenameByTableName sTableName sColumnName sNewColumnName to bOK
87892>>>
87892>>>        Function_Return (Err = False)    
87893>>>    End_Function    
87894>>>    
87894>>>    // Rename a field/column by table name.
87894>>>    Function SqlColumnRenameByTableName String sTableName String sColumnName String sNewColumnName Returns Boolean
87896>>>        Integer iColumn iDbType iDataType
87896>>>        String sDriverID sStmt sAlterTable sRenameColumn sVal sColumnKeyWord sOrgTableName sDatabase sDataType
87896>>>        Boolean bExists bOK bRetval                                        
87896>>>        Handle hTable
87896>>>        
87896>>>        Move sTableName to sOrgTableName
87897>>>        Get psDriverID to sDriverID
87898>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
87899>>>        If (bOK = False) Begin
87901>>>            Function_Return False
87902>>>        End
87902>>>>
87902>>>        
87902>>>        Get _SqlFindColumnName sTableName sColumnName to sVal
87903>>>        If (sVal = "") Begin
87905>>>            Function_Return False
87906>>>        End                          
87906>>>>
87906>>>        
87906>>>        Get piDbType to iDbType
87907>>>        Get _SqlFindKeyWord CI_SQLColumn       to sColumnKeyWord
87908>>>        Get _SqlProperTableName sTableName     to sTableName
87909>>>        Get _SqlFindKeyWord CI_SQLAlterTable   to sAlterTable
87910>>>        Get _SqlFindKeyWord CI_SQLRenameColumn to sRenameColumn
87911>>>        
87911>>>        Case Begin
87911>>>            Case (iDbType = EN_dbTypeMSSQL) 
87913>>>                Move (sRenameColumn * "'" + sTableName + "." + sColumnName + "'," * "'" + sNewColumnName + "'," * "'" + sColumnKeyWord + "'") to sStmt
87914>>>                Case Break
87915>>>            // Alter table "SYS"."Customer" rename column "Comments" to "NewColumnName"    
87915>>>            Case (iDbType = EN_dbTypeOracle) 
87918>>>                Move (sAlterTable * '"' + sTableName + '"' * sRenameColumn * '"' + sColumnName + '"' * "TO" * '"' + sNewColumnName + '"') to sStmt
87919>>>                Case Break  
87920>>>            // ALTER TABLE Schema.TableName RENAME COLUMN "deptnumb" TO "deptnum"
87920>>>            Case (iDbType = EN_dbTypeDB2)
87923>>>                Move (sAlterTable *  sTableName * sRenameColumn * '"' + sColumnName + '"' * "TO" * '"' + sNewColumnName + '"') to sStmt
87924>>>                Case Break
87925>>>            // ALTER TABLE "Customer" RENAME COLUMN "Comments" TO "NewColumnName"
87925>>>            Case (iDbType = EN_dbTypePostgre) 
87928>>>                Move sOrgTableName to sTableName
87929>>>                Move (sAlterTable * '"' + sTableName + '"' * sRenameColumn * '"' + sColumnName + '"' * "TO" * '"' + sNewColumnName + '"') to sStmt
87930>>>                Case Break  
87931>>>            Case (iDbType = EN_dbTypeMySQL)
87934>>>                // ALTER TABLE orderentry.customer CHANGE Comments NewColumnName text // Note: The last token is the column type!
87934>>>                Move sOrgTableName to sTableName
87935>>>                Get psDatabase to sDatabase 
87936>>>                Get UtilTableNameToHandle sTableName to hTable
87937>>>                If (hTable = 0) Begin
87939>>>                    Get UtilTableOpen hTable sTableName DF_SHARE to bOK
87940>>>                    If (bOK = False) Begin
87942>>>                        Function_Return False 
87943>>>                    End
87943>>>>
87943>>>                    Get NextFreeFilelistSlot to hTable
87944>>>                End
87944>>>>
87944>>>                Else Begin
87945>>>                    Open hTable
87947>>>                End          
87947>>>>
87947>>>                Get SQLColumnType sDriverID hTable sTableName sColumnName to iDataType
87948>>>                Get UtilColumnTypeToString sDriverID iDbType iDataType    to sDataType
87949>>>                Move (sAlterTable * sDatabase + "." + sTableName * sRenameColumn * sColumnName * sNewColumnName * sDataType) to sStmt
87950>>>                Case Break  
87951>>>            Case Else 
87951>>>                Move (sAlterTable * "'" + sTableName + "'" * sRenameColumn * "'" + sTableName + "." + sColumnName + "'" * "TO" * "'" + sNewColumnName + "'") to sStmt
87952>>>        Case End
87952>>>        
87952>>>        Move False to Err   
87953>>>        Send SqlUtilExecuteQuery sStmt sDriverID
87954>>>        Move (Err = False) to bRetval
87955>>>        // We also need to remove the cache-file since the table has been changed
87955>>>        Get UtilDeleteCacheFile sTableName to bOK
87956>>>    
87956>>>        Function_Return bRetval
87957>>>    End_Function    
87958>>>
87958>>>    Function SqlColumnType String sDriverID Handle hTable String sTableName String sColumnName Returns Integer
87960>>>        Handle hoSQLHandler hSQLConnect hStmt
87960>>>        Boolean bMertechDriver                                     
87960>>>        Integer iNumCols iCount iSQLType iDataType
87960>>>        String sValue 
87960>>>        
87960>>>        Get IsMertechDriver sDriverID to bMertechDriver
87961>>>        If (bMertechDriver = False) Begin
87963>>>            Get phoSQLManager to hoSQLHandler
87964>>>        End                                  
87964>>>>
87964>>>        Else Begin
87965>>>            Get _MertechSQLManagerHandle to hoSQLHandler
87966>>>        End                                    
87966>>>>
87966>>>        
87966>>>        Get SQLFileConnect of hoSQLHandler hTable to hSQLConnect
87967>>>        If (hSQLConnect <> 0) Begin
87969>>>            Get SQLOpen of hSQLConnect to hStmt
87970>>>            If (hStmt <> 0) Begin
87972>>>                Send SQLExecDirect of hStmt ("select * from" * sTableName)
87973>>>        
87973>>>                Get SQLStmtAttribute of hStmt SQLSTMTATTRIB_COLUMNCOUNT to iNumCols
87974>>>                For iCount from 1 to iNumCols
87980>>>>
87980>>>                    Get SQLColAttribute of hStmt iCount SQLCOLATTRIB_LABEL to sValue
87981>>>                    If (Lowercase(sValue) = Lowercase(sColumnName)) Begin
87983>>>                        Get SQLColAttribute of hStmt iCount SQLCOLATTRIB_SQLTYPE to iDataType
87984>>>                        Move iNumCols to iCount // We're out of here
87985>>>                    End
87985>>>>
87985>>>                Loop                                                
87986>>>>
87986>>>                
87986>>>                Send SQLClose of hStmt
87987>>>            End
87987>>>>
87987>>>            Send SQLDisconnect of hSQLConnect    
87988>>>        End
87988>>>>
87988>>>        
87988>>>        Function_Return iDataType
87989>>>    End_Function
87990>>>        
87990>>>    
87990>>>    // *** SQL Utility Messages ***
87990>>>    // They are not geared at making database changes.
87990>>>    //
87990>>>
87990>>>    // Will create an SQL table with the passed sTableName & sColumnName as Numeric 4.2 to keep
87990>>>    // the DbUpdateVersion database revision in.  
87990>>>    // Also pass the file number of the current (embedded?) table number used in development.
87990>>>    // It will first create the SQL Table & column, then create the .int file and change Filelist.cfg
87990>>>    Function SQLCreateDbVersionTable Handle hTable String sColumnName String sDriverID Returns Boolean
87992>>>        Boolean bOK bOpened
87992>>>        String sTableName sDataType sAlterTable sAddColumn sLengthAndDecimals sStmt sDropColumn
87992>>>        
87992>>>        Get_Attribute DF_FILE_ROOT_NAME of hTable to sTableName
87995>>>        Get _TableNameOnly sTableName to sTableName   
87996>>>        If (sTableName = "") Begin
87998>>>            Function_Return False
87999>>>        End 
87999>>>>
87999>>>        
87999>>>        // This just creates the table and a "dummy" column.
87999>>>        Get SqlTableCreate hTable sDriverID to bOK
88000>>>        If (bOK = False) Begin
88002>>>            Function_Return False 
88003>>>        End                      
88003>>>>
88003>>>        
88003>>>        Close hTable
88004>>>        Move False to Err
88005>>>        
88005>>>        Get _SqlFindKeyWord CI_SQLAlterTable to sAlterTable
88006>>>        Get _SqlFindKeyWord CI_SQLAdd        to sAddColumn
88007>>>        Move "Decimal" to sDataType
88008>>>        Get _SqlFormatLengthAndDecimalAsString 4 2 to sLengthAndDecimals
88009>>>        
88009>>>        // Adds the "sColumnName" passed to the function
88009>>>        Move (sAlterTable * sTableName * sAddColumn * sColumnName * sDataType + sLengthAndDecimals) to sStmt 
88010>>>        Send SqlUtilExecuteQuery sStmt sDriverID
88011>>>        
88011>>>        // Now we can delete the dummy column:
88011>>>        Get SqlColumnRemoveByTableName sTableName "Dummy" to bOK
88012>>>        
88012>>>        // Finally, we attach to the newly created table.
88012>>>        If (Err = False) Begin    
88014>>>            Get ApiTableAttachToSQL hTable True to bOK
88015>>>        End
88015>>>>
88015>>>        Open hTable                                                  
88017>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpened
88020>>>        
88020>>>        Function_Return (Err = False and bOK = True and bOpened = True)
88021>>>    End_Function
88022>>>    
88022>>>    // Checks if a column/field name exists in a SQL table definition
88022>>>    // Returns True if it does
88022>>>    // Sample:
88022>>>    //   Get SQLUtilColumnExists "MySQLTable" "MyColumnName" to bExists
88022>>>    Function SQLUtilColumnExists String sTableName String sFieldName Returns Boolean
88024>>>        Integer iNumColumns iColumn
88024>>>        String sColumn sDriverID
88024>>>        String[] sColumnsArray
88025>>>        Boolean bExists bOK
88025>>>    
88025>>>        Move False to bExists  
88026>>>        Get AutoConnectionIDLogin to bOK
88027>>>        Get psDriverID to sDriverID
88028>>>        
88028>>>        Get SqlUtilEnumerateColumns sDriverID sTableName to sColumnsArray
88029>>>        Move (SizeOfArray(sColumnsArray)) to iNumColumns
88030>>>        Decrement iNumColumns
88031>>>        For iColumn from 0 to iNumColumns
88037>>>>
88037>>>            Move sColumnsArray[iColumn] to sColumn
88038>>>            If (Uppercase(sFieldName) = Uppercase(sColumn)) Begin
88040>>>                Move True to bExists
88041>>>                Move iNumColumns to iColumn // We're out of here
88042>>>            End
88042>>>>
88042>>>        Loop
88043>>>>
88043>>>    
88043>>>        Function_Return bExists
88044>>>    End_Function
88045>>>    
88045>>>    Function SQLUtilConvertColumnTypesToSQL2008 Handle hTable Returns Boolean
88047>>>        Integer iNumColumns iColumn iDFType iNativeType
88047>>>        Boolean bOpened bOK
88047>>>        String sColumnName sNativeTypeName
88047>>>        
88047>>>        Get AutoConnectionIDLogin to bOK
88048>>>        Open hTable Mode DF_EXCLUSIVE
88050>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpened
88053>>>        If (bOpened = False) Begin
88055>>>            Error DFERR_PROGRAM ("Function SQLUtilConvertColumnTypesToSQL2008; Could not open table" * String(hTable))
88056>>>>
88056>>>            Function_Return False 
88057>>>        End
88057>>>>
88057>>>        
88057>>>        Move False to Err                               
88058>>>        
88058>>>        Structure_Start hTable
88059>>>            Get_Attribute DF_FILE_NUMBER_FIELDS of hTable to iNumColumns
88062>>>        
88062>>>            For iColumn from 1 to iNumColumns
88068>>>>
88068>>>                Get_Attribute DF_FIELD_TYPE             of hTable iColumn to iDfType
88071>>>                Get_Attribute DF_FIELD_NAME             of hTable iColumn to sColumnName
88074>>>                Get_Attribute DF_FIELD_NATIVE_TYPE      of hTable iColumn to iNativeType
88077>>>                Get_Attribute DF_FIELD_NATIVE_TYPE_Name of hTable iColumn to sNativeTypeName
88080>>>                
88080>>>                Case Begin
88080>>>                    Case (iDFType = DF_DATE) 
88082>>>                        If (iNativeType = SQL_TYPE_TIMESTAMP) Begin
88084>>>                            // Convert datetime to date
88084>>>                            Set_Attribute DF_FIELD_NATIVE_TYPE of hTable iColumn to SQL_TYPE_DATE
88087>>>                        End
88087>>>>
88087>>>                        Case Break
88088>>>                    Case (iDFType = DF_DATETIME) 
88091>>>                        If (iNativeType = SQL_TYPE_TIMESTAMP) Begin
88093>>>                            // Convert datetime to datetime2
88093>>>                            Set_Attribute DF_FIELD_NATIVE_TYPE of hTable iColumn to SQL_TYPE_TIMESTAMP2
88096>>>                        End
88096>>>>
88096>>>                        Case Break
88097>>>                    Case (iDFType = DF_ASCII) 
88100>>>                        If (iNativeType = SQL_CHAR) Begin
88102>>>                            // Convert char to varchar
88102>>>                            Set_Attribute DF_FIELD_NATIVE_TYPE of hTable iColumn to SQL_VARCHAR
88105>>>                        End
88105>>>>
88105>>>                        Case Break
88106>>>                    Case (iDFType = DF_TEXT) 
88109>>>                        If (iNativeType = SQL_LONGVARCHAR) Begin 
88111>>>                            // Convert text to varchar(max)
88111>>>                            Set_Attribute DF_FIELD_NATIVE_TYPE of hTable iColumn to SQL_VARCHAR
88114>>>                        End
88114>>>>
88114>>>                        Case Break
88115>>>                    Case (iDFType = DF_BINARY) 
88118>>>                        If (iNativeType = SQL_LONGVARBINARY) Begin
88120>>>                            // Convert image to varbinary(max)
88120>>>                            Set_Attribute DF_FIELD_NATIVE_TYPE of hTable iColumn to SQL_VARBINARY
88123>>>                        End
88123>>>>
88123>>>                        Case Break
88124>>>                Case End
88124>>>            Loop
88125>>>>
88125>>>        Structure_End hTable
88127>>>    
88127>>>        Function_Return (Err = False)    
88128>>>    End_Function  
88129>>>    
88129>>>    // Does three things with auxilirary files;
88129>>>    // 1) Deletes the cache file in the first Data folder of the psDataPath property as the table at the SQL end has been changed.
88129>>>    // 2) Adds the sColumnName to the TableName.tag file in the first Data folder of the psDataPath property
88129>>>    // 3) Creates a new TableName.fd file if the DdSrc folder is available (if this is a development environment)
88129>>>    Function SqlUtilAdjustAuxFiles Handle hTable String sTableName String sColumnName Returns Boolean
88131>>>        String sDataPath sDDSrcPath sVal sDriverID
88131>>>        Boolean bOK bExists bMertechDriver
88131>>>        Integer iCount iItems iCh iPos
88131>>>        
88131>>>        // If table name equals e.g. "dbo.MyTable" we need to remove the prefix.
88131>>>        If (sTableName contains ".") Begin
88133>>>            Move (Pos(".", sTableName)) to iPos
88134>>>            Move (Mid(sTableName, 999, (iPos +1))) to sTableName    
88135>>>        End                                                     
88135>>>>
88135>>>        
88135>>>        Get psDriverID to sDriverID
88136>>>        Get psDataPathFirstPart to sDataPath 
88137>>>        Get vFolderExists sDataPath to bOK
88138>>>        If (bOK = False) Begin
88140>>>            Error DFERR_PROGRAM "Function SqlUtilAdjustAuxFiles; psDataPath not found!"
88141>>>>
88141>>>            Function_Return False    
88142>>>        End                      
88142>>>>
88142>>>        
88142>>>        Get IsMertechDriver sDriverID to bMertechDriver
88143>>>        // First delete the cache file:
88143>>>        Get UtilDeleteCacheFile sTableName to bOK
88144>>>            
88144>>>        Get Seq_New_Channel to iCh  
88145>>>        If (iCh = DF_SEQ_CHANNEL_NOT_AVAILABLE) Begin
88147>>>            Function_Return False
88148>>>        End                      
88148>>>>
88148>>>        
88148>>>        Get vFilePathExists (sDataPath + sTableName + ".tag") to bExists
88149>>>        If (bExists = False) Begin
88151>>>            Function_Return False
88152>>>        End                      
88152>>>>
88152>>>        
88152>>>        // Add the new column name to the .tag file: 
88152>>>        Append_Output channel iCh (sDataPath + sTableName + ".tag")
88154>>>            Writeln channel iCh sColumnName
88157>>>        Close_Output
88158>>>        
88158>>>        // If in development environment; output new .fd file:
88158>>>        Get psDdSrcPath of (phoWorkspace(ghoApplication)) to sDDSrcPath
88159>>>        Get CountOfPaths of (phoWorkspace(ghoApplication)) sDDSrcPath to iCount
88160>>>        If (iCount > 1) Begin
88162>>>            Get PathAtIndex of (phoWorkspace(ghoApplication)) sDDSrcPath 1 to sDDSrcPath    
88163>>>        End 
88163>>>>
88163>>>        Get vFolderExists sDDSrcPath to bExists
88164>>>        If (bExists = True) Begin                                   
88166>>>            Get vFolderFormat sDDSrcPath to sDDSrcPath  
88167>>>            Move False to Err 
88168>>>            Get AutoConnectionIDLogin to bOK
88169>>>            If (hTable <> 0) Begin
88171>>>                Open hTable
88173>>>            End 
88173>>>>
88173>>>            Else Begin
88174>>>                Get UtilTableOpen hTable sTableName DF_SHARE to bOK
88175>>>            End
88175>>>>
88175>>>                
88175>>>            Get_Attribute DF_FILE_OPENED of hTable to bOK
88178>>>            If (bOK = True) Begin
88180>>>                Output_Aux_File DF_AUX_FILE_FD for hTable to (sDDSrcPath + sTableName + ".fd")
88182>>>            End
88182>>>>
88182>>>            If (Err = True) Begin
88184>>>                Move False to bOK
88185>>>            End
88185>>>>
88185>>>        End
88185>>>>
88185>>>        
88185>>>        Function_Return (bOK = True)
88186>>>    End_Function  
88187>>>    
88187>>>    // The table must already exist in the filelist for this function to work.
88187>>>    // It creates a rudimentary .int file in the first Data folder of the psDataPath property.
88187>>>    Function SqlUtilCreateIntFile Handle hTable String sDriverID String sConnectionID Boolean bAnsi Boolean bSysFile Returns Boolean
88189>>>        Boolean bOK bExists bUseConnectionID bMertech
88189>>>        String sDataPath sRootName sPhysicalFileName sConnectionString sDatabaseName sSchemaName sANSI_OEM
88189>>>        String[] sIndexArray
88190>>>        Integer iCount iCh iSize
88190>>>        
88190>>>        Move (Trim(sConnectionID) <> "") to bUseConnectionID
88191>>>        Get psConnectionString to sConnectionString
88192>>>
88192>>>        Move CS_ANSI_Txt to sANSI_OEM
88193>>>        If (bANSI = False) Begin
88195>>>            Move CS_OEM_Txt to sANSI_OEM
88196>>>        End
88196>>>>
88196>>>        
88196>>>        Get psDataPathFirstPart to sDataPath
88197>>>        Get vFolderExists sDataPath to bOK
88198>>>        If (bOK = False) Begin
88200>>>            Error DFERR_PROGRAM "Function SqlUtilCreateIntFile; psDataPath not found!"
88201>>>>
88201>>>            Function_Return False    
88202>>>        End                      
88202>>>>
88202>>>        Get vFolderFormat sDataPath to sDataPath 
88203>>>
88203>>>        Get_Attribute DF_FILE_ROOT_NAME of hTable to sRootName
88206>>>        Get _TableNameOnly sRootName to sDatabaseName
88207>>>        Move sDatabaseName to sPhysicalFileName
88208>>>        Move (sPhysicalFileName + ".int") to sPhysicalFileName
88209>>>
88209>>>        Get IsMertechDriver sDriverID to bMertech
88210>>>        If (bMertech = True) Begin       
88212>>>            // This should not be called here. Instead it is called by the SqlUtilUpdateIntFile!
88212>>>            // Else it will create an error in the error log (although it won't do anything...)
88212>>>            // Get _MertechSqlUtilCreateIntFile hTable sDataPath sPhysicalFileName to bOK
88212>>>            Function_Return (bOK = True)
88213>>>        End
88213>>>>
88213>>>        
88213>>>        Get psSchema hTable to sSchemaName
88214>>>        If (sSchemaName = "") Begin   
88216>>>            Get _SqlFindKeyWord CI_SQLDBO to sSchemaName
88217>>>        End
88217>>>>
88217>>>
88217>>>        // If the .int file already exists; we rename it to "FileName" + ".bak"
88217>>>        Get vFilePathExists (sDataPath + sPhysicalFileName) to bExists
88218>>>        If (bExists = True) Begin            
88220>>>            Get vRenameFile (sDataPath + sPhysicalFileName) (sDataPath + sPhysicalFileName + ".bak") to bOK 
88221>>>        End
88221>>>>
88221>>>        
88221>>>        Get UtilDeleteCacheFile sRootName to bOK
88222>>>        Get SqlUtilEnumerateIndexes sRootName sDriverID to sIndexArray
88223>>>        
88223>>>        Get Seq_Open_Output_Channel (sDataPath + sPhysicalFileName) to iCh
88224>>>            Writeln channel iCh CS_DRIVER_NAME     " " sDriverID 
88229>>>            If (bUseConnectionID = True) Begin
88231>>>                Writeln channel iCh CS_SERVER_NAME " " CS_DFCONNID "=" sConnectionID
88238>>>            End 
88238>>>>
88238>>>            Else Begin
88239>>>                Writeln channel iCh CS_SERVER_NAME " " CS_SERVER "=" sConnectionString
88246>>>            End                                                      
88246>>>>
88246>>>            Writeln channel iCh CS_DATABASE_NAME          " " sDatabaseName
88251>>>            Writeln channel iCh CS_SCHEMA_NAME            " " (Lowercase(sSchemaName))
88256>>>            // There seems to be a new order how these are set from DF19.
88256>>>            If (bSysFile = True) Begin
88258>>>                Writeln channel iCh CS_RECNUM_TABLE       " " "NO"
88263>>>            End 
88263>>>>
88263>>>            Writeln channel iCh CS_TABLE_CHARACTER_FORMAT " " sANSI_OEM
88268>>>            Writeln channel iCh CS_USE_DUMMY_ZERO_DATE    " " "YES" // ToDo: We maybe need to paramerize this setting?  
88273>>>            If (bSysFile = True) Begin
88275>>>                Writeln channel iCh CS_SYSTEM_FILE        " " "YES" 
88280>>>            End  
88280>>>>
88280>>>            
88280>>>            If (bSysFile = False) Begin
88282>>>                Move (SizeOfArray(sIndexArray)) to iSize  
88283>>>                Move (SortArray(sIndexArray)) to sIndexArray
88284>>>                If (iSize > 0) Begin
88286>>>                    Writeln channel iCh (CS_PRIMARY_INDEX * String("0"))
88289>>>                    Writeln channel iCh // Just an empty line
88291>>>                End
88291>>>>
88291>>>                Decrement iSize                              
88292>>>                For iCount from 0 to iSize
88298>>>>
88298>>>                    Writeln channel iCh (CS_INDEX_NUMBER * String(iCount))
88301>>>                    Writeln channel iCh (CS_INDEX_NAME   * String(sIndexArray[iCount]))
88304>>>                    Writeln channel iCh
88306>>>                Loop
88307>>>>
88307>>>            End
88307>>>>
88307>>>        Send Seq_Close_Channel iCh 
88308>>>        
88308>>>        // Wait a sec for Windows to finish writing the file:
88308>>>        Sleep 1
88309>>>        
88309>>>        Function_Return (bOK = True)
88310>>>    End_Function
88311>>>    
88311>>>    // Message for changing .int files to use connection ID's
88311>>>    //
88311>>>    // Changes all ".int" files for the passed sDataPath to use a sConnectionID,
88311>>>    // OR changes an existing connection id to a new id.
88311>>>    // Pass the full path to the data folder and the name of the connection id (string value). 
88311>>>    // Pass a True for the bShowResult parameter to show work in progress (showln's).
88311>>>    Procedure SqlUtilChangeIntFilesToConnectionIDs String sDataPath String sConnectionID Boolean bShowResult
88313>>>        String sFileName sDriverID sDriverFile sConnectionString
88313>>>        String[] sFilesData
88314>>>        Boolean bExists bOK                               
88314>>>        Integer iSize iCount
88314>>>        
88314>>>        Get SqlUtilEnumerateIntFiles sDataPath to sFilesData
88315>>>        Move (SizeOfArray(sFilesData))    to iSize
88316>>>        If (iSize = 0) Begin
88318>>>            Send Info_Box "No .int files found! Nothing was changed."
88319>>>            Procedure_Return
88320>>>        End                                                          
88320>>>>
88320>>>        
88320>>>        Move (Trim(sConnectionID)) to sConnectionID
88321>>>        Get vFolderFormat sDataPath to sDataPath
88322>>>        Decrement iSize
88323>>>        For iCount from 0 to iSize
88329>>>>
88329>>>            Move sFilesData[iCount] to sFileName                                   
88330>>>            // This makes sure that we also can change an existing connection id to something new:
88330>>>            Get UtilChangeSourceCodeLine (sDataPath + sFileName) CS_SERVER_NAME (CS_SERVER_NAME * CS_DFCONNID + "=" + sConnectionID) bShowResult to bOK 
88331>>>        Loop                      
88332>>>>
88332>>>        
88332>>>        Get psDriverID to sDriverID
88333>>>        
88333>>>         // Finally also change the driver file e.g. MSSQLDRV.int file in the Data folder in case it has a "DFconnectionID xxxxID,SERVER..."
88333>>>        Move "" to sFileName
88334>>>        If (sDriverID = MSSQLDRV_ID) Begin
88336>>>            Move "MSSQLDrv.int" to sFileName
88337>>>        End                 
88337>>>>
88337>>>        If (sDriverID = DB2_DRV_ID) Begin
88339>>>            Move "DB2_Drv.int" to sFileName
88340>>>        End                                
88340>>>>
88340>>>        If (sDriverID = ODBC_DRV_ID) Begin
88342>>>            Move "ODBC_Drv.int" to sFileName
88343>>>        End                                 
88343>>>>
88343>>>        If (sFileName <> "") Begin     
88345>>>            Move "" to sDriverFile
88346>>>            Get_File_Path sFileName to sDriverFile
88347>>>            If (sDriverFile <> "") Begin                        
88349>>>                Get psConnectionString to sConnectionString
88350>>>                Get UtilChangeSourceCodeLine sDriverFile CS_SQLConnectionIDText (CS_SQLConnectionIDText * String(sConnectionID) + "," * String(sConnectionString) * String(",0")) bShowResult to bOK
88351>>>            End
88351>>>>
88351>>>        End
88351>>>>
88351>>>    End_Procedure
88352>>>
88352>>>    // Checks if the database exists in SQL. Returns = True if it does.
88352>>>    Function SqlUtilCheckIfDatabaseExists String sDatabase Returns Boolean
88354>>>        String[] sDatabaseArray
88355>>>        String sVal sServer sDriverID
88355>>>        Integer iCount iSize iPos
88355>>>        Boolean bExists            
88355>>>        tSQLConnection SQLConnection
88355>>>        tSQLConnection SQLConnection
88355>>>        
88355>>>        Move False to bExists                              
88356>>>        Get psDriverID to sDriverID
88357>>>        // DB2 doesn't need to have a "Database" name, so we always return True.
88357>>>        If (sDriverID = DB2_DRV_ID) Begin
88359>>>            Function_Return bExists
88360>>>        End                     
88360>>>>
88360>>>        
88360>>>        Get SqlUtilEnumerateDatabases sDriverID to sDatabaseArray
88361>>>        If (SizeOfArray(sDatabaseArray) = 0) Begin
88363>>>            Function_Return False
88364>>>        End
88364>>>>
88364>>>        
88364>>>        Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
88365>>>        Get ParseKeyWord SQLConnection.sConnectionString (CS_SQLIniDSNKeyword + "=") to sServer
88366>>>        If (sServer contains "/") Begin
88368>>>            Move (Pos("/", sServer)) to iPos
88369>>>            Move (Mid(sServer, 999, (iPos +1)))                        to sDatabase
88370>>>        End
88370>>>>
88370>>>        
88370>>>        Move (SizeOfArray(sDatabaseArray)) to iSize
88371>>>        Decrement iSize
88372>>>        For iCount from 0 to iSize
88378>>>>
88378>>>            Move sDatabaseArray[iCount] to sVal
88379>>>            If (Uppercase(sVal) = Uppercase(sDatabase)) Begin
88381>>>                Move True to bExists
88382>>>            End
88382>>>>
88382>>>        Loop
88383>>>>
88383>>>        
88383>>>        Function_Return bExists
88384>>>    End_Function
88385>>>        
88385>>>    // Checks if a table exists as an SQL table. Returns = True if it does.
88385>>>    Function SqlUtilCheckIfTableHandleExists Handle hTable String sDriverID Returns Boolean
88387>>>        String sTableName sVal
88387>>>        Boolean bExists  
88387>>>        String[] sTablesArray                                 
88388>>>        Integer iSize iCount
88388>>>        
88388>>>        Move False to bExists
88389>>>        Get UtilTableHandleToString hTable to sTableName
88390>>>        Get SqlUtilEnumerateTables sDriverID to sTablesArray  
88391>>>        Move (SizeOfArray(sTablesArray)) to iSize
88392>>>        Decrement iSize
88393>>>        For iCount from 0 to iSize
88399>>>>
88399>>>            Move sTablesArray[iCount] to sVal
88400>>>            If (Uppercase(sVal) = Uppercase(sTableName)) Begin
88402>>>                Move True to bExists
88403>>>                Move iSize to iCount // We're done!
88404>>>            End
88404>>>>
88404>>>        Loop
88405>>>>
88405>>>    
88405>>>        Function_Return bExists
88406>>>    End_Function   
88407>>>    
