91013>>>    // To move an existing field to another position in a table.
91013>>>    Function ApiColumnMove Handle hTable Integer iOld Integer iNew Returns Boolean
91015>>>        String sColumn sDriverID
91015>>>        Integer iType iLength iPrecision
91015>>>        Boolean bOK
91015>>>        
91015>>>        Get_Attribute DF_FILE_DRIVER of hTable to sDriverID
91018>>>        If (sDriverID = DFBTRDRV_ID) Begin
91020>>>            Error DFERR_PROGRAM "Function 'ColumnMove' is not supported for the Pervasive database."
91021>>>>
91021>>>            Function_Return False
91022>>>        End                      
91022>>>>
91022>>>        
91022>>>        Close hTable
91023>>>        Get AutoConnectionIDLogin to bOK
91024>>>        Open hTable Mode DF_EXCLUSIVE
91026>>>        Get_Attribute DF_FIELD_NAME of hTable iOld to sColumn
91029>>>        Get_Attribute DF_FIELD_TYPE of hTable iOld to iType
91032>>>    
