90751>>>    Function ApiTableMoveToFileSlot Integer iFromFileSlot Integer iToFileSlot String sDriverID Returns Boolean
90753>>>        Boolean bTmp bErr bOK 
90753>>>        String sTableName sDisplayName sFileName sDBOKeyWord sVal
90753>>>        
90753>>>        // We preserve the value of the Err flag, by saving its current state and resetting it before end of function.
90753>>>        Move Err to bTmp
90754>>>        Move False to Err
90755>>>        
90755>>>        Get AutoConnectionIDLogin to bOK
90756>>>        // First get the info for the current filelist slot:
90756>>>        Open iFromFileSlot                      
90758>>>        Get_Attribute DF_FILE_OPENED of iFromFileSlot to bOK
90761>>>        If (bOK = True) Begin
90763>>>            Get_Attribute DF_FILE_ROOT_NAME    of iFromFileSlot to sFileName
90766>>>            Get_Attribute DF_FILE_LOGICAL_NAME of iFromFileSlot to sTableName
90769>>>            Get_Attribute DF_FILE_DISPLAY_NAME of iFromFileSlot to sDisplayName
90772>>>            
90772>>>            //...then move it.
90772>>>            Set_Attribute DF_FILE_ROOT_NAME    of iToFileSlot to sFileName
90775>>>            Set_Attribute DF_FILE_LOGICAL_NAME of iToFileSlot to sTableName
90778>>>            Set_Attribute DF_FILE_DISPLAY_NAME of iToFileSlot to sDisplayName
90781>>>            
90781>>>            //...and finally remove the old filelist values.
90781>>>            Set_Attribute DF_FILE_ROOT_NAME    of iFromFileSlot to ""
90784>>>            Set_Attribute DF_FILE_LOGICAL_NAME of iFromFileSlot to ""
90787>>>            Set_Attribute DF_FILE_DISPLAY_NAME of iFromFileSlot to ""
90790>>>        End
90790>>>>
90790>>>        Close iFromFileSlot
90791>>>        
90791>>>        Move Err to bErr                     
90792>>>        Move bTmp to Err
90793>>>        Function_Return (bErr = False)
90794>>>    End_Function
