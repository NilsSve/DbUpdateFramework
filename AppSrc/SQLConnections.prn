84984>>>>>>>>>    // Custom array find function. It compares both the iSQLWord & iSQLDbType params.
84984>>>>>>>>>    Function CompareFindSQLKeyWords tSQLKeyWords SQLKeywords1 tSQLKeyWords SQLKeywords2 Returns Integer
84986>>>>>>>>>        If (SQLKeywords1.iSQLWord = SQLKeywords2.iSQLWord and SQLKeywords1.iSQLDbType = SQLKeywords2.iSQLDbType) Begin
84988>>>>>>>>>            Function_Return (EQ)
84989>>>>>>>>>        End
84989>>>>>>>>>>
84989>>>>>>>>>        Function_Return (NE)
84990>>>>>>>>>    End_Function
84991>>>>>>>>>    
84991>>>>>>>>>    // Custom array sort function. It compares both the iSQLWord & iSQLDbType params.
84991>>>>>>>>>    Function CompareSortSQLKeyWords tSQLKeyWords SQLKeywords1 tSQLKeyWords SQLKeywords2 Returns Integer
84993>>>>>>>>>        If (SQLKeywords1.iSQLWord   < SQLKeywords2.iSQLWord) Begin
84995>>>>>>>>>            Function_Return (LT)
84996>>>>>>>>>        End
84996>>>>>>>>>>
84996>>>>>>>>>        If (SQLKeywords1.iSQLWord   > SQLKeywords2.iSQLWord) Begin
84998>>>>>>>>>            Function_Return (GT)
84999>>>>>>>>>        End
84999>>>>>>>>>>
84999>>>>>>>>>        If (SQLKeywords1.iSQLDbType < SQLKeywords2.iSQLDbType) Begin
85001>>>>>>>>>            Function_Return (LT)
85002>>>>>>>>>        End
85002>>>>>>>>>>
85002>>>>>>>>>        If (SQLKeywords1.iSQLDbType > SQLKeywords2.iSQLDbType) Begin
85004>>>>>>>>>            Function_Return (GT)
85005>>>>>>>>>        End
85005>>>>>>>>>>
85005>>>>>>>>>
85005>>>>>>>>>        Function_Return (EQ)    
85006>>>>>>>>>    End_Function
