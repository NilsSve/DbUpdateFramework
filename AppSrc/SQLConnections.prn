82693>>>>>>>>>>>    Function IsProcedure String sFunctionName Returns Boolean
82695>>>>>>>>>>>        String sRoutineType
82695>>>>>>>>>>>
82695>>>>>>>>>>>        SQL_SET_CURRENT_CURSOR_STMT to (piCursorNum(Self))
82709>>>>>>>>>>>>
82709>>>>>>>>>>>
82709>>>>>>>>>>>        Case Begin
82709>>>>>>>>>>>            Case (MertechInc_DriverName = SQLFLEX)
82711>>>>>>>>>>>                sql_set_stmt to (SFormat("select type from master.sys.sysobjects where name = '%1' union all select type from sys.sysobjects where name = '%1'", sFunctionName))
82719>>>>>>>>>>>                sql_prepare_stmt
82731>>>>>>>>>>>                sql_execute_stmt
82746>>>>>>>>>>>
82746>>>>>>>>>>>                sql_fetch_next_row into sRoutineType
82770>>>>>>>>>>>>
82770>>>>>>>>>>>                If (sRoutineType = "P") Move "PROCEDURE" to sRoutineType
82773>>>>>>>>>>>                Else Move "FUNCTION" to sRoutineType
82775>>>>>>>>>>>                Case Break
82776>>>>>>>>>>>            Case (MertechInc_DriverName = MySQLFlex)
82779>>>>>>>>>>>                sql_set_stmt to (SFormat("select routine_type from information_schema.routines where routine_name = '%1'", sFunctionName))
82787>>>>>>>>>>>                sql_prepare_stmt
82799>>>>>>>>>>>                sql_execute_stmt
82814>>>>>>>>>>>                sql_fetch_next_row into sRoutineType
82838>>>>>>>>>>>>
82838>>>>>>>>>>>
82838>>>>>>>>>>>                Case Break
82839>>>>>>>>>>>            Case (MertechInc_DriverName = ORAFLEX)
82842>>>>>>>>>>>                sql_set_stmt  to (SFormat("SELECT object_type from all_objects where object_name = '%1'", sFunctionName))
82850>>>>>>>>>>>                sql_prepare_stmt
82862>>>>>>>>>>>                sql_execute_stmt
82877>>>>>>>>>>>                sql_fetch_next_row into sRoutineType
82901>>>>>>>>>>>>
82901>>>>>>>>>>>
82901>>>>>>>>>>>                Case Break
82902>>>>>>>>>>>            Case (MertechInc_DriverName = PgFlex)
82905>>>>>>>>>>>                // Postgres doesn't differentiate between procedures and functions, so treat everything as procedures
82905>>>>>>>>>>>                // because that is better tested.
82905>>>>>>>>>>>                Move "PROCEDURE" to sRoutineType
82906>>>>>>>>>>>                Case Break
82907>>>>>>>>>>>        Case End
82907>>>>>>>>>>>
82907>>>>>>>>>>>        Function_Return (sRoutineType = "PROCEDURE")
82908>>>>>>>>>>>    End_Function
82909>>>>>>>>>>>
82909>>>>>>>>>>>    Function ProcParams String sFunctionName Returns Variant[]
82911>>>>>>>>>>>        Variant[] vFuncParams
82912>>>>>>>>>>>        Integer i iParamType
82912>>>>>>>>>>>
82912>>>>>>>>>>>        SQL_SET_CURRENT_CURSOR_STMT to (piCursorNum(Self))
82926>>>>>>>>>>>>
82926>>>>>>>>>>>
82926>>>>>>>>>>>        Case Begin
82926>>>>>>>>>>>            Case (MertechInc_DriverName = SQLFLEX)
82928>>>>>>>>>>>                sql_set_stmt to (SFormat("sys.sp_procedure_params_managed @procedure_name = '%1'", sFunctionName))
82936>>>>>>>>>>>                sql_prepare_stmt
82948>>>>>>>>>>>                sql_execute_stmt
82963>>>>>>>>>>>
82963>>>>>>>>>>>                Repeat
82963>>>>>>>>>>>>
82963>>>>>>>>>>>                    sql_fetch_next_row
82978>>>>>>>>>>>>
82978>>>>>>>>>>>                    If (Found) Begin
82980>>>>>>>>>>>                        sql_fetch_column 6 into iParamType
82985>>>>>>>>>>>
82985>>>>>>>>>>>                        If (iParamType = 1) Move "IN" to vFuncParams[i]
82988>>>>>>>>>>>                        If (iParamType = 2) Move "INOUT" to vFuncParams[i]
82991>>>>>>>>>>>                        If (iParamType = 3) Move "OUT" to vFuncParams[i]
82994>>>>>>>>>>>                        If (iParamType <> 4) Increment i
82997>>>>>>>>>>>                    End
82997>>>>>>>>>>>>
82997>>>>>>>>>>>                Until (not(Found))
82999>>>>>>>>>>>
82999>>>>>>>>>>>                Function_Return vFuncParams
83000>>>>>>>>>>>
83000>>>>>>>>>>>                Case Break
83001>>>>>>>>>>>            Case (MertechInc_DriverName = MySQLFlex)
83004>>>>>>>>>>>                sql_set_stmt to (SFormat("select parameter_mode from INFORMATION_SCHEMA.PARAMETERS where SPECIFIC_NAME = '%1' order by ordinal_position", sFunctionName))
83012>>>>>>>>>>>                sql_prepare_stmt
83024>>>>>>>>>>>                sql_execute_stmt
83039>>>>>>>>>>>
83039>>>>>>>>>>>                Case Break
83040>>>>>>>>>>>            Case (MertechInc_DriverName = ORAFLEX)
83043>>>>>>>>>>>                sql_set_stmt to    "SELECT all_arguments.in_out as parameter_mode "
83051>>>>>>>>>>>                sql_append_stmt to "FROM all_objects inner join all_arguments on all_objects.object_id = all_arguments.object_id "
83059>>>>>>>>>>>                sql_append_stmt to (SFormat("WHERE all_objects.object_name = '%1' order by all_arguments.position", sFunctionName))
83067>>>>>>>>>>>                sql_prepare_stmt
83079>>>>>>>>>>>                sql_execute_stmt
83094>>>>>>>>>>>
83094>>>>>>>>>>>                Case Break
83095>>>>>>>>>>>            Case (MertechInc_DriverName = PgFlex)
83098>>>>>>>>>>>                sql_set_stmt    to "select information_schema.parameters.parameter_mode "
83106>>>>>>>>>>>                sql_append_stmt to "from information_schema.routines inner join information_schema.parameters "
83114>>>>>>>>>>>                sql_append_stmt to "on information_schema.routines.specific_name=information_schema.parameters.specific_name "
83122>>>>>>>>>>>                sql_append_stmt to (SFormat("where information_schema.routines.routine_name = '%1' ", sFunctionName))
83130>>>>>>>>>>>                sql_append_stmt to "order by information_schema.parameters.ordinal_position"
83138>>>>>>>>>>>                sql_prepare_stmt
83150>>>>>>>>>>>                sql_execute_stmt
83165>>>>>>>>>>>
83165>>>>>>>>>>>                Case Break
83166>>>>>>>>>>>        Case End
83166>>>>>>>>>>>
83166>>>>>>>>>>>        Repeat
83166>>>>>>>>>>>>
83166>>>>>>>>>>>            sql_fetch_next_row into vFuncParams[i]
83190>>>>>>>>>>>>
83190>>>>>>>>>>>            Increment i
83191>>>>>>>>>>>        Until (not(Found))
83193>>>>>>>>>>>        
83193>>>>>>>>>>>        Function_Return vFuncParams
83194>>>>>>>>>>>    End_Function
