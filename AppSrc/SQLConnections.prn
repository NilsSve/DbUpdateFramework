90441>>>    // Calls a driver function directly to copy data from one table to another (table structures needs to be the same).
90441>>>    // It will first drop all indicies, copy the data and then recreate indicies. 
90441>>>    // An error log file with the sRootname + ".err" will be created in the Data folder.
90441>>>    Function ApiTableCopyData Integer hFromTable String sPhysicalName String sRootName String sDriverID Returns Boolean
90443>>>        Boolean bOpened bOK
90443>>>        Integer hToTable iIndex iCount iRetval iVoid iOrgFreq
90443>>>        String sErrorFile sEmpty sPath
90443>>>        
90443>>>        Get_Attribute DF_FILE_NEXT_EMPTY of 0 to hToTable
90446>>>        Get AutoConnectionIDLogin to bOK
90447>>>        If (sDriverID = DATAFLEX_ID) Begin
90449>>>            Send IncreaseSortBufferSize  
90450>>>//            Send SetAllIndexesToBatch hToTable
90450>>>        End                          
90450>>>>
90450>>>
90450>>>        Move False to Err
90451>>>        Open sPhysicalName as hToTable
90453>>>        Get_Attribute DF_FILE_OPENED of hToTable to bOpened
90456>>>        If (bOpened = False) Begin
90458>>>            Function_Return False
90459>>>        End                      
90459>>>>
90459>>>        
90459>>>        Move "" to sEmpty 
90460>>>        Move False to Err   
90461>>>        Move True to bOK       
90462>>>        
90462>>>        Get_Attribute DF_RUNTIME_PROGRESS_FREQUENCY to iOrgFreq
90465>>>        Set_Attribute DF_RUNTIME_PROGRESS_FREQUENCY to 10        
90468>>>        If (sDriverID <> DATAFLEX_ID) Begin
90470>>>            // Remove all indices to speed up copying of data:
90470>>>            Call_Driver hToTable sDriverID Function CLI_DROPINDICES Callback Self Passing sEmpty sEmpty iVoid Result iRetval
90475>>>            If (iRetval <> 0) Begin
90477>>>                Error DFERR_PROGRAM ("Failed dropping indices for table:" * sRootName)
90478>>>>
90478>>>                Function_Return False
90479>>>            End
90479>>>>
90479>>>        End
90479>>>>
90479>>>        
90479>>>        Move (sRootName + ".err") to sErrorFile  
90480>>>        Move 0 to iIndex           
90481>>>        Move False to Err   
90482>>>        
90482>>>        Copy_Records hFromTable to hToTable using 0 Callback Self
90485>>>                  
90485>>>        If (Err = False) Begin             
90487>>>            Get psHome of (phoWorkspace(ghoApplication)) to sPath  
90488>>>            Get vDeleteFile (sPath + sErrorFile) to iRetval
90489>>>        End                                                          
90489>>>>
90489>>>        
90489>>>        If (sDriverID <> DATAFLEX_ID) Begin
90491>>>            // Recreate indices:
90491>>>            Call_Driver hToTable sDriverID Function CLI_CREATEINDICES Callback Self Passing sEmpty sEmpty iVoid Result iRetval
90496>>>        End
90496>>>>
90496>>>        
90496>>>        Close hToTable
90497>>>        Set_Attribute DF_RUNTIME_PROGRESS_FREQUENCY to iOrgFreq
90500>>>        
90500>>>        If (bOK = True) Begin
90502>>>            Move (not(Err)) to bOK
90503>>>        End
90503>>>>
90503>>>        
90503>>>        If (ghoStatusPanel <> 0) Begin
90505>>>            Set Message_Text of ghoStatusPanel to ""
90506>>>            Set Action_Text  of ghoStatusPanel to ""
90507>>>        End
90507>>>>
90507>>>        
90507>>>        Function_Return (bOK = True)
90508>>>    End_Function 
