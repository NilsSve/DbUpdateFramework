85280>>>>>>>Class cDbUpdateORAFLEXDriver is a cDbUpdateGenericDatabaseDriver
85281>>>>>>>    Function DbLogin String sConnectionString String sServer String sDatabase Boolean bTrusted String sUserID String sPassword Returns Boolean
85283>>>>>>>        Boolean bLoginSuccessful
85283>>>>>>>        String sDriverID sErrorMsg
85283>>>>>>>        String sVal
85283>>>>>>>        Integer iPos
85283>>>>>>>
85283>>>>>>>        Get psDriverID to sDriverID
85284>>>>>>>        Move (Pos("/", sServer)) to iPos
85285>>>>>>>        If (iPos = 0) Begin
85287>>>>>>>            If (sDatabase <> "") Begin
85289>>>>>>>                Move (sServer + "/" + sDatabase) to sServer        
85290>>>>>>>            End
85290>>>>>>>>
85290>>>>>>>        End
85290>>>>>>>>
85290>>>>>>>        // For the Mertech driver, using the Err indicator is the sanctioned way
85290>>>>>>>        Move False to Err
85291>>>>>>>        // For Oracle I don't believe "Trusted" doesn't exist.
85291>>>>>>>        Login sServer sUserId sPassword sDriverID
85293>>>>>>>        
85293>>>>>>>        Move (not(Err)) to bLoginSuccessful
85294>>>>>>>        Function_Return bLoginSuccessful
85295>>>>>>>    End_Function
85296>>>>>>>End_Class
