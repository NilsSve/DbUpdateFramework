95781>>>// *************************************************************************
95781>>>//  Public message. This is the default message. It is expected that you will
95781>>>//   create your own message to override this
95781>>>// *************************************************************************
95781>>>
95781>>>Procedure Activate_About
95784>>>   Send DoAbout "" "" "" "" ""
95785>>>End_Procedure
95786>>>
95786>>>// *************************************************************************
95786>>>//  Public message. It is expected that you will send this message (most
95786>>>//  likely from Activate_About. This creates an about object, activates it
95786>>>//  and destroys it when done. It is not exepected that you will augment this.
95786>>>// *************************************************************************
95786>>>// Sample usage:
95786>>>//   The first two params will automatically be filled from the application settings if not provided.
95786>>>//   Send DoAbout "" "" ("Copyright: 2013" * psCompany(ghoApplication)) "Created by: Your Name" "YourAppBitmap.bmp" "Internet: http://www.YourWebAddress.com" "E-mail: mailto:support@YourEmailAddress.com" "Some other description of choice" "9th param" "and last param"
95786>>>
95786>>>Procedure DoAbout String sTitle String sVersion String sCopyRight String sAuthor String sBitmap ;                  String sParam6 String sParam7 String sParam8 String sParam9 String sParam10
95789>>>        Integer hoObj hoMain iArgs
95789>>>        String sValue
95789>>>
95789>>>        // Create object
95789>>>        Object About is an AboutDialog
95791>>>            // Uncomment these two lines if you would like to have a resizable About object.
95791>>>//            Set Border_Style to Border_Thick
95791>>>//            Set peAnchors to anAll
95791>>>
95791>>>            // Add checking for the number of arguments passed to avoid runtime errors
95791>>>            // if one of them is not passed. This makes the interface
95791>>>            // more flexible.
95791>>>            Move num_arguments to iArgs
95792>>>
95792>>>            // If no title is passed use the label of the main panel (if a main panel exists).
95792>>>            If (iArgs > 0 and sTitle = "") Begin
95794>>>                Get Main_Window of Desktop to hoMain
95795>>>                If hoMain Get Label of hoMain to sValue
95798>>>            End
95798>>>>
95798>>>            Else If (iArgs > 0 and sTitle <> "") Begin
95801>>>                Move sTitle to sValue
95802>>>            End
95802>>>>
95802>>>            Else If (iArgs = 0) Begin
95805>>>                Get Main_Window of Desktop to hoMain
95806>>>                If hoMain Get Label of hoMain to sValue
95809>>>            End
95809>>>>
95809>>>
95809>>>            If (sValue <> "") Send Add_LineLn sValue
95812>>>            Move "" to sValue
95813>>>
95813>>>            // If the passed sVersion value is blank, the info will be retrieved from the cApplication object.
95813>>>            // For this to work the Project Properties Version must have been set in the Studio.
95813>>>            If (iArgs < 2) Begin
95815>>>                Move "" to sValue
95816>>>            End
95816>>>>
95816>>>            Else Begin
95817>>>                Move sVersion to sValue
95818>>>            End
95818>>>>
95818>>>            Set Version to sValue
95819>>>
95819>>>            If (iArgs > 2 and sCopyRight <> "") Send Add_LineLn sCopyRight
95822>>>
95822>>>            // If only the five "standard" params were passed we don't add an extra linefeed;
95822>>>            // else we do.
95822>>>            If (iArgs > 3 and iArgs < 6 and sAuthor <> "") Begin
95824>>>                Send Add_Line sAuthor
95825>>>            End
95825>>>>
95825>>>            Else If (iArgs > 5 and sAuthor <> "") Begin
95828>>>                Send Add_LineLn sAuthor
95829>>>            End
95829>>>>
95829>>>
95829>>>            // Square bitmaps of 80x80 works best
95829>>>            If (iArgs > 4 and sBitmap <> "") Begin
95831>>>               Set Logo to sBitMap
95832>>>            End
95832>>>>
95832>>>
95832>>>            // Here starts handling of the five optional params:
95832>>>            If (iArgs = 6 and sParam6  <> "") Begin
95834>>>                Send Add_Line sParam6
95835>>>            End
95835>>>>
95835>>>            Else If (iArgs > 6 and sParam6  <> "") Begin
95838>>>                Send Add_LineLn sParam6
95839>>>            End
95839>>>>
95839>>>
95839>>>            If (iArgs = 7 and sParam7  <> "") Begin
95841>>>                Send Add_Line sParam7
95842>>>            End
95842>>>>
95842>>>            Else If (iArgs > 7 and sParam7  <> "") Begin
95845>>>                Send Add_LineLn sParam7
95846>>>            End
95846>>>>
95846>>>
95846>>>            If (iArgs = 8 and sParam8  <> "") Begin
95848>>>                Send Add_Line sParam8
95849>>>            End
95849>>>>
95849>>>            Else If (iArgs > 8 and sParam8  <> "") Begin
95852>>>                Send Add_LineLn sParam8
95853>>>            End
95853>>>>
95853>>>
95853>>>            If (iArgs = 9 and sParam9  <> "") Begin
95855>>>                Send Add_Line sParam9
95856>>>            End
95856>>>>
95856>>>            Else If (iArgs > 9 and sParam9  <> "") Begin
95859>>>                Send Add_LineLn sParam9
95860>>>            End
95860>>>>
95860>>>
95860>>>            If (iArgs = 10 and sParam10 <> "") Begin
95862>>>                Send Add_Line sParam10
95863>>>            End
95863>>>>
95863>>>
95863>>>            Move Self to hoObj
95864>>>        End_Object
95865>>>
95865>>>        Send Popup   of hoObj // Popup the about object
95866>>>        Send Destroy of hoObj // When done, it will be destroyed
95867>>>End_Procedure
