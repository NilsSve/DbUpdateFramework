94977>>>>>>>>>>>
94977>>>>>>>>>>>    Procedure View_File_Help Integer Obj
94979>>>>>>>>>>>       String Context FilFld
94979>>>>>>>>>>>       Integer File# Field# Dot
94979>>>>>>>>>>>       If Obj gt 0 Begin
94981>>>>>>>>>>>          // This should return the file and field as a string in
94981>>>>>>>>>>>          // FFF.fff format (F=File, f=format).
94981>>>>>>>>>>>          Get Help_Context of Obj HELP_CONTEXT_DATAFILE to FilFld
94982>>>>>>>>>>>          // Parse FilFld into File# and Field#.
94982>>>>>>>>>>>          Pos '.' in FilFld to Dot
94984>>>>>>>>>>>>
94984>>>>>>>>>>>          if Dot ne 0 begin
94986>>>>>>>>>>>             Left FilFld to File#  (dot-1)
94988>>>>>>>>>>>>
94988>>>>>>>>>>>             Mid  FilFld to Field# 255 (dot+1)
94991>>>>>>>>>>>>
94991>>>>>>>>>>>          End
94991>>>>>>>>>>>>
94991>>>>>>>>>>>       End
94991>>>>>>>>>>>>
94991>>>>>>>>>>>       Get System_Help_File_id File# Field# to Context
94992>>>>>>>>>>>       Send Exec_Context_Help Context
94993>>>>>>>>>>>    End_Procedure // View_File_Help
94994>>>>>>>>>>>
94994>>>>>>>>>>>    //  View help on an error. Current version uses context id help.
94994>>>>>>>>>>>    //  The error number should be in global integer last_err
94994>>>>>>>>>>>    //
94994>>>>>>>>>>>    procedure View_Error_Help Integer Obj
94996>>>>>>>>>>>        String Context
94996>>>>>>>>>>>        If Obj gt 0 ;           Get Help_Context of obj HELP_CONTEXT_ERROR to Context
94999>>>>>>>>>>>        if (left(context,1)) in '0123456789' ;           Get System_Help_Error_id Context to Context
95002>>>>>>>>>>>        Send Exec_Context_Help Context
95003>>>>>>>>>>>    end_procedure
95004>>>>>>>>>>>
95004>>>>>>>>>>>    // View list of help topics.
95004>>>>>>>>>>>    //
95004>>>>>>>>>>>    Procedure View_Help_on_Topic Integer obj
95006>>>>>>>>>>>        Send Exec_System_Help HELP_ON_TOPIC_STRING
95007>>>>>>>>>>>    end_procedure
95008>>>>>>>>>>>
95008>>>>>>>>>>>    // Request context help. If context is a number assume that it is
95008>>>>>>>>>>>    // context id help, else assume it is keyword help.
95008>>>>>>>>>>>    //
95008>>>>>>>>>>>    Procedure Exec_Context_Help string Context
95010>>>>>>>>>>>       if (left(context,1)) in '0123456789' ;    // if first character is a          Send Exec_System_Context_Help Context  // numeric we assume ID help
95013>>>>>>>>>>>       else ;                                    // otherwise we assume key-          Send Exec_System_Help Context          // word help.
95015>>>>>>>>>>>    End_Procedure // Exec_Context_Help
95016>>>>>>>>>>>
95016>>>>>>>>>>>    // NOTE: the following two messages are the only messages that directly make calls
95016>>>>>>>>>>>    //       to the windows API. This is important. These two messages could be changed
95016>>>>>>>>>>>    //       to call other help systems (e.g. HTML help) and the rest of the high level
95016>>>>>>>>>>>    //       program remains the same. These are the only two messages that are
95016>>>>>>>>>>>    //       expected to be windows help centric.
95016>>>>>>>>>>>
95016>>>>>>>>>>>    // Get Context Id help for passed ID. Use help file as defined
95016>>>>>>>>>>>    // in Help_filename. If id is 0 use general help id (which must be
95016>>>>>>>>>>>    // defined.
95016>>>>>>>>>>>    //
95016>>>>>>>>>>>    Procedure Exec_System_Context_Help integer Context_id
95018>>>>>>>>>>>        If Context_Id eq 0 ; // if zero, see if we have a contents page            Move (Help_Id_General(self)) to Context_id
95021>>>>>>>>>>>        If Context_Id eq 0 ; // if still zero, jump to the topics popup dialog            Send Exec_System_Help HELP_ON_TOPIC_STRING
95024>>>>>>>>>>>        Else ;            Send gDoWinHelp WH_INTCONTEXT (Help_Filename(self)) Context_Id
95026>>>>>>>>>>>    end_procedure
95027>>>>>>>>>>>
95027>>>>>>>>>>>    // Get keyword help for passed keyword. Use help file as defined
95027>>>>>>>>>>>    // in help_filename.
95027>>>>>>>>>>>    //
95027>>>>>>>>>>>    procedure Exec_System_Help string Keyword
95029>>>>>>>>>>>        If Keyword eq HELP_FOR_HELP_STRING ;            Send gDoWinHelp WH_HELPONHELP
95032>>>>>>>>>>>        else if (Keyword eq HELP_ON_TOPIC_STRING OR KeyWord="");            Send gDoWinHelp WH_FINDER (Help_Filename(self))
95036>>>>>>>>>>>        else ;            Send gDoWinHelp WH_STRINGCONTEXT (Help_Filename(self)) KeyWord
95038>>>>>>>>>>>    end_procedure
95039>>>>>>>>>>>
95039>>>>>>>>>>>end_class
