97835>>>>>    Function AddProgramToStudioToolsMenu String sStudioVersion Returns Integer
97838>>>>>        Boolean bOk bExists bOpen
97838>>>>>        String sKey sValue sProgramPath sProgram sProduct sStudioPath
97838>>>>>        Handle hoReg hoArray
97838>>>>>        Integer i iItems iCreated iRetval
97838>>>>>
97838>>>>>        Move False to bOk
97839>>>>>        Move (CS_StudioPath + (Trim(sStudioVersion)))  to sStudioPath
97840>>>>>        If (sStudioVersion > "17.1") Begin
97842>>>>>            Move (Replace("Visual ", sStudioPath, "")) to sStudioPath
97843>>>>>        End
97843>>>>>>
97843>>>>>
97843>>>>>        Get psProgramPath of (phoWorkspace(ghoApplication)) to sProgramPath
97844>>>>>        Get PathAtIndex of (phoWorkspace(ghoApplication)) sProgramPath 1 to sProgramPath
97845>>>>>        Get vFolderFormat sProgramPath to sProgramPath
97846>>>>>        Get psProduct     of (phoWorkspace(ghoApplication)) to sProduct
97847>>>>>        Get Module_Name to sProgram
97848>>>>>        Get Create U_cRegistry to hoReg
97849>>>>>        Set phRootKey of hoReg to HKEY_CURRENT_USER
97850>>>>>
97850>>>>>        // First check if the DataFlex version is installed
97850>>>>>        Get KeyExists of hoReg sStudioPath to bExists
97851>>>>>        If (bExists = False) Begin
97853>>>>>            Send Destroy of hoReg
97854>>>>>            Function_Return cx_RegKeyVDFKeyDoesNotExist
97855>>>>>        End
97855>>>>>>
97855>>>>>
97855>>>>>        // Then check if any tools have been installed in the Tools Menu.
97855>>>>>        // If no tools created yet, create the Tools registry key.
97855>>>>>        Move (sStudioPath + CS_StudioTools) to sStudioPath
97856>>>>>        Get KeyExists of hoReg sStudioPath to bExists
97857>>>>>        If (bExists = False) Begin
97859>>>>>            Set pfAccessRights of hoReg to KEY_ALL_ACCESS
97860>>>>>            Get CreateKey of hoReg sStudioPath to iCreated
97861>>>>>            If (iCreated <> 0) Begin
97863>>>>>                Move cx_RegkeyFailed to iRetval
97864>>>>>            End
97864>>>>>>
97864>>>>>            Else Begin
97865>>>>>                Move True to bExists
97866>>>>>            End
97866>>>>>>
97866>>>>>        End
97866>>>>>>
97866>>>>>
97866>>>>>        If (bExists = True) Begin
97868>>>>>            Get OpenKey of hoReg sStudioPath to bOk
97869>>>>>            If (bOk = True) Begin
97871>>>>>                Get Create U_Array to hoArray
97872>>>>>                Get GetSubkeys of hoReg hoArray to iItems
97873>>>>>                Decrement iItems
97874>>>>>                Move False to bExists
97875>>>>>                Set pfAccessRights of hoReg to KEY_READ
97876>>>>>                // Check if the key already exists:
97876>>>>>                For i from 0 to iItems
97882>>>>>>
97882>>>>>                    Get Value of hoArray item i to sKey
97883>>>>>                    Move (sStudioPath + "\" + sKey) to sKey
97884>>>>>                    Get OpenKey of hoReg sKey to bOpen
97885>>>>>                    If (bOpen = True) Begin
97887>>>>>                        Get ReadString of hoReg CS_Name to sValue
97888>>>>>                        If (sValue = sProduct) Move True to bExists
97891>>>>>                    End
97891>>>>>>
97891>>>>>                Loop
97892>>>>>>
97892>>>>>                Send Destroy of hoArray
97893>>>>>                If (bExists = False) Begin
97895>>>>>                    Set pfAccessRights of hoReg to KEY_ALL_ACCESS
97896>>>>>                    // We need to create the next key number:
97896>>>>>                    // The studio expect tools menu items to be numbered 1,2,3...n
97896>>>>>                    Increment iItems
97897>>>>>                    Increment iItems
97898>>>>>                    Get CreateKey of hoReg (sStudioPath + "\" + String(iItems)) to iCreated
97899>>>>>                    If (iCreated = 0) Begin
97901>>>>>                        Send WriteString of hoReg CS_Name sProduct
97902>>>>>                        // From DataFlex 16 and up the params for the Studio's Tools menu changed slightly:
97902>>>>>                        If (sStudioVersion >= "16.0") Begin
97904>>>>>                            Send WriteString of hoReg CS_Command (sProgramPath + sProgram)
97905>>>>>                            Send WriteString of hoReg CS_CommandLine (psTag(Self))
97906>>>>>                        End
97906>>>>>>
97906>>>>>                        Else Begin
97907>>>>>                            Send WriteString of hoReg CS_CommandLine ('"' + sProgramPath + sProgram + ".exe" + '"' * psTag(Self))
97908>>>>>                            Move CX_InstalledOkVdfUnder16 to iRetval
97909>>>>>                        End
97909>>>>>>
97909>>>>>                        Send WriteDword  of hoReg CS_Separator 1
97910>>>>>                        Move cx_RegKeyCreated to iRetval
97911>>>>>                    End
97911>>>>>>
97911>>>>>                    Else Begin
97912>>>>>                        Move cx_RegkeyFailed to iRetval
97913>>>>>                    End
97913>>>>>>
97913>>>>>                End
97913>>>>>>
97913>>>>>                Else Begin
97914>>>>>                    Move cx_RegKeyAlreadyExist to iRetval
97915>>>>>                End
97915>>>>>>
97915>>>>>                Send CloseKey of hoReg
97916>>>>>            End
97916>>>>>>
97916>>>>>        End
97916>>>>>>
97916>>>>>
97916>>>>>        Send Destroy of hoReg
97917>>>>>        Function_Return iRetval
97918>>>>>    End_Function
97919>>>>>
