85197>>>>>>>Struct tSQLConnection
85197>>>>>>>    Boolean bEnabled                // 1. There can only be one active/enabled connection at a time.
85197>>>>>>>    String sConnectionID            // 2. The name of the connection ID.      
85197>>>>>>>    Integer iDbType                 // 3. Database type; "MS-SQL Server", "DB2", "Oracle", "MySQL", "PostgreSQL"
85197>>>>>>>    String sDriverID                // 4. Name of the driver. E.g. "MSSQLDRV", "DB2_DRV" or "ODBC_DRV".
85197>>>>>>>    String sServer                  // 5. SQL Server/DSN/ODBC source name. (In DF19 this is the "sString" member of the tConnection struct.)
85197>>>>>>>    String sDatabase                // 6. SQL Database
85197>>>>>>>    String sConnectionString        // 7. Full connection string as is needed by e.g. the login command.
85197>>>>>>>    Boolean bTrusted                // 8. Trusted connection (then is UID & PWD not used)                
85197>>>>>>>    String sUserID                  // 9. User ID
85197>>>>>>>    String sPassword                // 10. Password
85197>>>>>>>    String sSchema                  // 11. DB2 (and perhaps ODBC specific)
85197>>>>>>>    String sBaseTableSpace          // 12. DB2 specific
85197>>>>>>>    String sLongTableSpace          // 13. DB2 specific
85197>>>>>>>    String sIndexTableSpace         // 14. DB2 specific 
85197>>>>>>>    Boolean bSilentLogin            // 15. True=Silent login. (i.e. don't show Database login dialog if database login to fails). Same as driver "Options" parameter.
85197>>>>>>>    Boolean bError                  // 16. Set to true on error.
85197>>>>>>>//    Boolean bDisabled               // 17. For compatability with DF19 Managed Connections only. Not used by DUF (Database Update Framework).
85197>>>>>>>//    Integer iDriverIndex            // 18. For compatability with DF19 Managed Connections only. Not used by DUF (Database Update Framework).
85197>>>>>>>End_Struct            
