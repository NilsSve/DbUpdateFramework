86496>>>    End_Procedure
86497>>>    
86497>>>    // This is needed when e.g. the connection id we have specified in the program code
86497>>>    // also exists in e.g. the MSSQLDRV.ini file (can either be local in the Data folder
86497>>>    // or the one in the DataFlex Bin folder.)
86497>>>    // We then need to delete the current one before creating a new one.
86497>>>    // This is because the parameters may differ between the program code and the
86497>>>    // MSSQLDRV.ini file in a deployed environment. Also DataFlex will generate an error
86497>>>    // when one tries to create a Connection ID that already exists.
86497>>>    Procedure RemoveExistingConnectionID String sDriverID String sConnectionID
86499>>>        Integer iResult iDriver iNumConn iConn
86499>>>        Handle hoCLI
86499>>>        String sID   
86499>>>        
86499>>>        If (sDriverID = "" or sConnectionID = "") Begin
86501>>>            Procedure_Return
86502>>>        End                 
86502>>>>
86502>>>        
86502>>>        Move 0 to iResult
86503>>>        Get Create U_cCLIHandler to hoCLI
86504>>>        If (hoCLI <> 0) Begin
86506>>>            Set psDriverID of hoCLI to sDriverID   
86507>>>            Get DriverIndex sDriverID to iDriver
86508>>>            Get_Attribute DF_DRIVER_NUMBER_CONNECTION_IDS of iDriver to iNumConn 
86511>>>            Decrement iNumConn
86512>>>            For iConn from 0 to iNumConn
86518>>>>
86518>>>                Get_Attribute DF_DRIVER_CONNECTION_ID of iDriver iConn to sID
86521>>>                If (Uppercase(sID) = Uppercase(sConnectionID)) Begin
86523>>>                    Get DeleteConnectionID of hoCLI sConnectionID -1 to iResult
86524>>>                End
86524>>>>
86524>>>            Loop
86525>>>>
86525>>>            Send Destroy of hoCLI
86526>>>        End
86526>>>>
86526>>>    
86526>>>    End_Procedure   
