96795>>>>>        Procedure Refill_Comboform Integer iDbType
96798>>>>>            String sValue
96798>>>>>            Send Combo_Delete_Data 
96799>>>>>            Case Begin
96799>>>>>                Case (iDbType = EN_dbTypeMSSQL)
96801>>>>>                    Send Combo_Add_Item MSSQLDRV_ID
96802>>>>>                    Send Combo_Add_Item SQLFLEX
96803>>>>>                    Move MSSQLDRV_ID to sValue
96804>>>>>                    Case Break
96805>>>>>                Case (iDbType = EN_dbTypeMySQL)
96808>>>>>                    Send Combo_Add_Item ODBC_DRV_ID
96809>>>>>                    Send Combo_Add_Item MDSMySQL
96810>>>>>                    Move MDSMySQL to sValue
96811>>>>>                    Case Break
96812>>>>>                Case (iDbType = EN_dbTypeOracle)
96815>>>>>                    Send Combo_Add_Item ODBC_DRV_ID
96816>>>>>                    Send Combo_Add_Item ORAFLEX
96817>>>>>                    Move ORAFLEX to sValue
96818>>>>>                    Case Break
96819>>>>>                Case (iDbType = EN_dbTypeDB2)
96822>>>>>                    Send Combo_Add_Item DB2_DRV_ID
96823>>>>>                    Move DB2_DRV_ID to sValue
96824>>>>>                    Case Break
96825>>>>>                Case (iDbType = EN_dbTypePostgre)
96828>>>>>                    Send Combo_Add_Item ODBC_DRV_ID
96829>>>>>                    Send Combo_Add_Item MDSPgSQL
96830>>>>>                    Move MDSPgSQL to sValue
96831>>>>>                    Case Break
96832>>>>>                Case Else
96832>>>>>                    Send Combo_Add_Item DATAFLEX_ID
96833>>>>>                    Move DATAFLEX_ID to sValue
96834>>>>>//                Case (iDbType = EN_dbTypeMSSQL)
96834>>>>>//                    Send Combo_Add_Item (MSSQLDRV_ID * "- (DAW)")
96834>>>>>//                    Send Combo_Add_Item (SQLFLEX * "- (Mertech)")
96834>>>>>//                    Move (MSSQLDRV_ID * "- (DAW)") to sValue
96834>>>>>//                    Case Break
96834>>>>>//                Case (iDbType = EN_dbTypeMySQL)
96834>>>>>//                    Send Combo_Add_Item (ODBC_DRV_ID * "- (DAW)")
96834>>>>>//                    Send Combo_Add_Item (MDSMySQL * "- (Mertech)")
96834>>>>>//                    Move (MDSMySQL * "- (Mertech)") to sValue
96834>>>>>//                    Case Break
96834>>>>>//                Case (iDbType = EN_dbTypeOracle)
96834>>>>>//                    Send Combo_Add_Item (ODBC_DRV_ID * "- (DAW)")
96834>>>>>//                    Send Combo_Add_Item (ORAFLEX * "- (Mertech)")
