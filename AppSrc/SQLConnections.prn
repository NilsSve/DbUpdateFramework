86984>>>>Function ParseKeyWord String sConnect String sKeyWord Returns String
86986>>>>    Integer iStart iEnd
86986>>>>    String sRetval
86986>>>>
86986>>>>    Move (Trim(sConnect)) to sConnect
86987>>>>    Move (Pos(Uppercase(sKeyWord), Uppercase(sConnect)))  to iStart
86988>>>>    If (iStart = 0) Begin
86990>>>>        Function_Return ""
86991>>>>    End
86991>>>>>
86991>>>>    Move (Left(sConnect, (iStart -1 + Length(sKeyWord)))) to sRetval
86992>>>>    Move (Replace(sRetval, sConnect, "")) to sRetval 
86993>>>>    If (sKeyWord = Uppercase(CS_SQLConnectionIDText)) Begin
86995>>>>        Move (Pos(",", sRetval))          to iEnd
86996>>>>    End
86996>>>>>
86996>>>>    Else Begin
86997>>>>        Move (Pos(";", sRetval))          to iEnd
86998>>>>    End                                          
86998>>>>>
86998>>>>    If (iEnd = 0 and (sRetval contains ",")) Begin
87000>>>>        Move (Pos(",", sRetval))          to iEnd 
87001>>>>        Decrement iEnd
87002>>>>    End
87002>>>>>
87002>>>>    If (iEnd <> 0) Begin
87004>>>>        Move (Left(sRetval, (iEnd -1)))   to sRetval
87005>>>>    End
87005>>>>>
87005>>>>    Move (Replace("=", sRetval, ""))      to sRetval
87006>>>>
87006>>>>    Function_Return (Trim(sRetval))
87007>>>>End_Function
