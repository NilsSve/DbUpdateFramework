95557>>>>>Class cAboutEdit is an cRichEdit
95558>>>>>    Procedure Construct_Object
95560>>>>>        Forward Send Construct_Object
95562>>>>>
95562>>>>>        Set Size to 57 153
95563>>>>>        Set Location to 8 60
95564>>>>>
95564>>>>>        Set Read_Only_State to True
95565>>>>>        Set Skip_State to True
95566>>>>>        // Font size is calculated in "Twips", which are 1/1440 of an inch,
95566>>>>>        // or 1/20 of a printer's point.
95566>>>>>//        Set piFontSize    to (9 * 20)
95566>>>>>        Set piRightMargin to (0.1 * 1440)
95567>>>>>        Set Border_Style  to Border_None
95568>>>>>    End_Procedure
95569>>>>>
95569>>>>>    // Adds a line of text to the edit object
95569>>>>>    Procedure Add_Line String sVal
95571>>>>>        String sText
95571>>>>>        Address aAddress
95571>>>>>        Get paValue to aAddress
95572>>>>>        Move aAddress to sText
95573>>>>>        Move (sText + String(sVal)) to sVal
95574>>>>>        GetAddress of sVal to aAddress
95575>>>>>        Set paValue to aAddress
95576>>>>>    End_Procedure
95577>>>>>
95577>>>>>    // Compared to Add_Line above, this adds an extra empty line after the passed value.
95577>>>>>    // Note that we use the paValue interface,
95577>>>>>    // because the object isn't paged yet when we add the
95577>>>>>    // values and the COM edit object needs to be paged
95577>>>>>    // for the "Set Value" interface to be used.
95577>>>>>    Procedure Add_LineLn String sVal
95579>>>>>        String sText
95579>>>>>        Address aAddress
95579>>>>>        Get paValue to aAddress
95580>>>>>        Move aAddress to sText
95581>>>>>        Move (sText + String(sVal) + Character(10) + Character(13)) to sVal
95582>>>>>        GetAddress of sVal to aAddress
95583>>>>>        Set paValue to aAddress
95584>>>>>    End_Procedure
