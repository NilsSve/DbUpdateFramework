98421>>>        Function IsOneItemActive Returns Boolean
98424>>>            Handle hoDataSource ho
98424>>>            tDataSourceRow[] TheData
98424>>>            tDataSourceRow[] TheData
98425>>>            Integer iSize iCount
98425>>>            Boolean bRetval bExists
