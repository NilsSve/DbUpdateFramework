89108>>>    // To open all Sql based tables in Filelist.cfg
89108>>>    Procedure SqlUtilOpenAllTables
89110>>>        Handle hTable
89110>>>        String sRoot sDriverID
89110>>>        Boolean bOK
89110>>>        
89110>>>        Move 0 to hTable
89111>>>        Move "" to sDriverID
89112>>>        Get AutoConnectionIDLogin to bOK
89113>>>        
89113>>>        Repeat
89113>>>>
89113>>>            Get_Attribute DF_FILE_NEXT_USED of hTable to hTable
89116>>>            If (hTable > 0) Begin     
89118>>>                Get_Attribute DF_FILE_DRIVER of hTable to sDriverID
89121>>>                If (sDriverID = MSSQLDRV_ID or sDriverID = DB2_DRV_ID or sDriverID = ODBC_DRV_ID) Begin
89123>>>                    Get_Attribute DF_FILE_ROOT_NAME of hTable to sRoot
89126>>>                    If (Uppercase(sRoot) contains ".INT" or Uppercase(sRoot) contains MSSQLDRV_ID or Uppercase(sRoot) contains DB2_DRV_ID or Uppercase(sRoot) contains ODBC_DRV_ID) Begin
89128>>>                        Open hTable
89130>>>                    End
89130>>>>
89130>>>                End
89130>>>>
89130>>>            End
89130>>>>
89130>>>    
89130>>>        Until (hTable = 0)
89132>>>    End_Procedure             
