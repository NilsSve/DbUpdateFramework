85935>>>Use cDbUpdateDatabaseDriver.pkg
85935>>>
85935>>>// The cConnection class is the new SQL connections class for DF 19.
85935>>>// If an object of the cConnection class hasn't been instantiated we use a "dummy" class in its place.
85935>>>
85935>>>// We're making references to this object handle so we need it defined
85935>>>// here as well as for the cDbUpdateHandler class
85935>>>
85935>>>    Global_Variable Handle ghoSQLConnectionHandler
85935>>>    
85935>>>Class cSQLConnectionHandler is a cObject  
85936>>>    
85936>>>    Procedure Construct_Object
85938>>>        Forward Send Construct_Object
85940>>>        Move Self to ghoSQLConnectionHandler
85941>>>        
85941>>>        Property Handle phoSQLConnectionIniFile (Create(Self,RefClass(cSQLConnectionIniFile))) 
85942>>>        
85942>>>        // These properties are used by the cDbUpdateVersion and cDbUpdateFunctionLibrary classes,
85942>>>        // but put here so they can be set/get in both class objects. Those classes has "relay"
85942>>>        // methods to this class.
85942>>>        Property Boolean pbUseConnectionID True
85943>>>        Property Boolean pbToANSI          True
85944>>>        Property Boolean pbRecnum          True
85945>>>        Property Boolean pbCopyData        True
85946>>>
85946>>>        // Driver default value settings:
85946>>>        // Note: When the object is created the corresponding values
85946>>>        // from the driver .int files are read.
85946>>>        // Sample: Get_Attribute DF_DRIVER_DEFAULT_DEFAULT_NUMERIC of {driverNumber} to {StringVariable}
85946>>>        Property String psDriverDefaultValueASCII    ""
85947>>>        Property String psDriverDefaultValueBinary   ""
85948>>>        Property String psDriverDefaultValueDate     ""
85949>>>        Property String psDriverDefaultValueDateTime ""
85950>>>        Property String psDriverDefaultValueNumeric  ""
85951>>>        Property String psDriverDefaultValueText     ""
85952>>>        
85952>>>        // Driver "nullability" settings:
85952>>>        // Note: When the object is created the corresponding values
85952>>>        // from the driver .int files are read.
85952>>>        // Get_Attribute DF_DRIVER_DEFAULT_NULLABLE_ASCII of {driverNumber} to {BooleanVariable}
85952>>>        Property Boolean pbDriverDefaultNullableASCII    False
85953>>>        Property Boolean pbDriverDefaultNullableBinary   False
85954>>>        Property Boolean pbDriverDefaultNullableDate     False
85955>>>        Property Boolean pbDriverDefaultNullableDateTime False
85956>>>        Property Boolean pbDriverDefaultNullableNumeric  False
85957>>>        Property Boolean pbDriverDefaultNullableText     False
85958>>>
85958>>>        // *** This is the central point of connection data for the Database Update Framework ***
85958>>>        //     It is private because the get/set version also updates the DAW/Mertech
85958>>>        //     driver interfaces.
85958>>>        //     There are also procedure/function pairs to set/get individual data members
85958>>>        //     of the struct they are all routed throu this struct property.
85958>>>        Property tSQLConnection Private.pSQLConnection
85959>>>
85959>>>    End_Procedure
85960>>>    
85960>>>    Procedure End_Construct_Object             
85962>>>        Boolean bReadSettings 
85962>>>        tSQLConnection SQLConnection 
85962>>>        tSQLConnection SQLConnection 
85962>>>
85962>>>        Forward Send End_Construct_Object
85964>>>
85964>>>        // Now is the time to read and apply SQL connection settings.
85964>>>        Get SetupSQLConnection True to SQLConnection   
85965>>>        // ToDo: Should we use two pSQLConnection properties; one for the "from" database (in case of not Embedded);
85965>>>        //       and one for the "to" database??
85965>>>        Set Private.pSQLConnection to SQLConnection
85966>>>    End_Procedure    
85967>>>    
85967>>>    // *** Properties ***
85967>>>    // All connection related "properties" (get/set pairs) are really done by changing the
85967>>>    // private.pSQLConnection struct connection property. These "properties" are 
85967>>>    // merely here for conveniance.
85967>>>    //           
85967>>>    // The pSQLConnection get/set are here so we have a "central hub"
85967>>>    // where we update data to/from the DAW & Mertech driver interfaces and this framework.
85967>>>    // This struct property contains all the connection data.
85967>>>    //
85967>>>    Procedure Set pSQLConnection tSQLConnection SQLConnection
85969>>>        Boolean bIsDaw bIsMertech bOK
85969>>>        
85969>>>        Set Private.pSQLConnection to SQLConnection 
85970>>>        
85970>>>        // When starting a program we might not have a connection id yet:
85970>>>        If (SQLConnection.sConnectionID = "" or SQLConnection.sDriverID = DATAFLEX_ID) Begin
85972>>>            Procedure_Return
85973>>>        End                 
85973>>>>
85973>>>        
85973>>>        // After we have set the class property we need to tell the DAW/Mertech
85973>>>        // driver interfaces about the change & make a new login.
85973>>>        Get SQLLogin SQLConnection to bOK
85974>>>        If (bOK = False) Begin
85976>>>            Error DFERR_PROGRAM "Login error."       
85977>>>>
85977>>>        End 
85977>>>>
85977>>>        
85977>>>        // Now is the time to setup our driver default values by reading the driver .int file:
85977>>>        Send SetupDriverDefaults SQLConnection.sDriverID
85978>>>        
85978>>>    End_Procedure                 
85979>>>    
85979>>>    // Similar to _SqlCheckCurrentDriver but generates no error and it doesn't 
85979>>>    // attempt to load the driver.
85979>>>    // Returns true if the passed driver is SQL based.        
85979>>>    Function IsSQLDriver String sDriverID Returns Boolean
85981>>>        Boolean bOK                         
85981>>>        Integer iDriver
85981>>>        
85981>>>        Get IsDAWSQLDriver sDriverID to bOK
85982>>>
85982>>>        If (bOK = False) Begin
85984>>>            Get IsMertechDriver sDriverID to bOK
85985>>>        End                                     
85985>>>>
85985>>>
85985>>>        Function_Return bOK
85986>>>    End_Function
85987>>>            
85987>>>    // Reads the driver .int file and sets class properties of the cDbUpdateFunctionLibrary accordingly.
85987>>>    Procedure SetupDriverDefaults String sDriverID
85989>>>        String sAttributeValue                                               
85989>>>        Integer iDriverID
85989>>>        Boolean bNULL bSQLDriver
85989>>>        
85989>>>        Get IsSQLDriver sDriverID to bSQLDriver
85990>>>        If (bSQLDriver = False) Begin
85992>>>            Procedure_Return
85993>>>        End
85993>>>>
85993>>>            
85993>>>        Get DriverIndex sDriverID to iDriverID
85994>>>        
85994>>>        // Driver default values for various data types:
85994>>>        Get_Attribute DF_DRIVER_DEFAULT_DEFAULT_ASCII of iDriverID      to sAttributeValue
85997>>>        Set psDriverDefaultValueASCII                                   to sAttributeValue
85998>>>
85998>>>        Get_Attribute DF_DRIVER_DEFAULT_DEFAULT_BINARY of iDriverID     to sAttributeValue
86001>>>        Set psDriverDefaultValueBinary                                  to sAttributeValue
86002>>>
86002>>>        Get_Attribute DF_DRIVER_DEFAULT_DEFAULT_DATE of iDriverID       to sAttributeValue
86005>>>        Set psDriverDefaultValueDate                                    to sAttributeValue
86006>>>
86006>>>        Get_Attribute DF_DRIVER_DEFAULT_DEFAULT_DATETIME of iDriverID   to sAttributeValue
86009>>>        Set psDriverDefaultValueDateTime                                to sAttributeValue
86010>>>
86010>>>        Get_Attribute DF_DRIVER_DEFAULT_DEFAULT_NUMERIC of iDriverID    to sAttributeValue
86013>>>        Set psDriverDefaultValueNumeric                                 to sAttributeValue
86014>>>
86014>>>        Get_Attribute DF_DRIVER_DEFAULT_DEFAULT_TEXT of iDriverID       to sAttributeValue
86017>>>        Set psDriverDefaultValueText                                    to sAttributeValue
86018>>>        
86018>>>        // The default setting for the "nullability" of newly created ASCII columns.
86018>>>        Get_Attribute DF_DRIVER_DEFAULT_NULLABLE_ASCII      of iDriverID to bNULL
86021>>>        Set pbDriverDefaultNullableASCII to bNULL
86022>>>        
86022>>>        Get_Attribute DF_DRIVER_DEFAULT_NULLABLE_BINARY     of iDriverID to bNULL
86025>>>        Set pbDriverDefaultNullableBinary to bNULL
86026>>>        
86026>>>        Get_Attribute DF_DRIVER_DEFAULT_NULLABLE_DATE       of iDriverID to bNULL
86029>>>        Set pbDriverDefaultNullableDate to bNULL
86030>>>        
86030>>>        Get_Attribute DF_DRIVER_DEFAULT_NULLABLE_DATETIME   of iDriverID to bNULL
86033>>>        Set pbDriverDefaultNullableDateTime to bNULL
86034>>>        
86034>>>        Get_Attribute DF_DRIVER_DEFAULT_NULLABLE_NUMERIC    of iDriverID to bNULL
86037>>>        Set pbDriverDefaultNullableNumeric to bNULL
86038>>>        
86038>>>        Get_Attribute DF_DRIVER_DEFAULT_NULLABLE_TEXT       of iDriverID to bNULL
86041>>>        Set pbDriverDefaultNullableText to bNULL
86042>>>        
86042>>>    End_Procedure
86043>>>    
86043>>>    Function SQLLogin tSQLConnection SQLConnection Returns Boolean
86045>>>        Boolean bOK bIsDaw bIsMertech bTrusted 
86045>>>        String sConnectionString sServer sDatabase sUserId sPassword sDriverID sCheck
86045>>>        Handle hoErrorObj hoDriver hoIniFile 
86045>>>        Integer iDriverID
86045>>>        
86045>>>        Move False to bOK
86046>>>        
86046>>>        Get IsDAWSQLDriver SQLConnection.sDriverID to bIsDaw
86047>>>        If (bIsDaw = False) Begin
86049>>>            Get IsMertechDriver SQLConnection.sDriverID to bIsMertech
86050>>>            If (bIsMertech = False) Begin
86052>>>                Function_Return False
86053>>>            End
86053>>>>
86053>>>        End  
86053>>>>
86053>>>        
86053>>>        Move Error_Object_Id to hoErrorObj
86054>>>        Move Self to Error_Object_Id        
86055>>>        
86055>>>        Get phoSQLConnectionIniFile to hoIniFile
86056>>>        Get ConstructConnectionString SQLConnection.sDriverID SQLConnection.sServer SQLConnection.sDatabase SQLConnection.bTrusted SQLConnection.sUserID SQLConnection.sPassword to sConnectionString
86057>>>        Get DriverIndex SQLConnection.sDriverID to iDriverID
86058>>>        If (iDriverID = 0) Begin
86060>>>            Move hoErrorObj to Error_Object_Id
86061>>>            Function_Return False
86062>>>        End
86062>>>>
86062>>>        
86062>>>        // There's a bug in Mertech drivers creating "an Exception error" in the debugger (probably will crash an application too.)
86062>>>        If (bIsMertech = False) Begin
86064>>>            Set_Attribute DF_DRIVER_SILENT_LOGIN of iDriverID to SQLConnection.bSilentLogin
86067>>>        End
86067>>>>
86067>>>        
86067>>>        Get Create (RefClass(cDbUpdateDatabaseDriver)) to hoDriver
86068>>>        Set psDriverID of hoDriver to SQLConnection.sDriverID
86069>>>        Get DbLogin    of hoDriver sConnectionString SQLConnection.sServer SQLConnection.sDatabase SQLConnection.bTrusted SQLConnection.sUserID SQLConnection.sPassword to bOK
86070>>>        Send Destroy   of hoDriver
86071>>>        Move hoErrorObj to Error_Object_Id
86072>>>        
86072>>>        Function_Return bOK
86073>>>    End_Function
86074>>>    
86074>>>    Function pSQLConnection Returns tSQLConnection
86076>>>        tSQLConnection SQLConnection
86076>>>        tSQLConnection SQLConnection
86076>>>        Get Private.pSQLConnection to SQLConnection
86077>>>        Function_Return SQLConnection
86078>>>    End_Function
86079>>>    
86079>>>    Procedure Set psConnectionID String sValue
86081>>>        tSQLConnection SQLConnection                                       
86081>>>        tSQLConnection SQLConnection                                       
86081>>>        Integer iIndex
86081>>>        
86081>>>        Get Private.pSQLConnection to SQLConnection
86082>>>        If (SQLConnection.sConnectionID = "") Begin
86084>>>            Move sValue to SQLConnection.sConnectionID
86085>>>        End
86085>>>>
86085>>>        
86085>>>        // Else we might want to change the current connection ID
86085>>>        Else If (SQLConnection.sConnectionID <> "" and SQLConnection.sConnectionID <> sValue) Begin   
86088>>>            Move False to Err
86089>>>            Logout SQLConnection.sDriverID  
86090>>>            // This will also make a login to the new server.
86090>>>            Get SQLIniFileConnectionID of (phoSQLConnectionIniFile(Self)) sValue to SQLConnection
86091>>>        End
86091>>>>
86091>>>        Set pSQLConnection to SQLConnection
86092>>>    End_Procedure
86093>>>        
86093>>>    Function psConnectionID Returns String
86095>>>        tSQLConnection SQLConnection
86095>>>        tSQLConnection SQLConnection
86095>>>        Get Private.pSQLConnection to SQLConnection
86096>>>        Function_Return SQLConnection.sConnectionID
86097>>>    End_Procedure
86098>>>    
86098>>>    // Note: If the psDriverID + other connection properties are to be changed,
86098>>>    //       the psDriverID *must* be the first property that is changed!
86098>>>    //       Otherwise errors might be raised by the driver when e.g. the format
86098>>>    //       for a connection string has the wrong format for that driver.
86098>>>    Procedure Set psDriverID String sValue
86100>>>        tSQLConnection SQLConnection 
86100>>>        tSQLConnection SQLConnection 
86100>>>        Get pSQLConnection to SQLConnection
86101>>>        Move sValue        to SQLConnection.sDriverID 
86102>>>        Set pSQLConnection to SQLConnection
86103>>>        If (sValue <> DATAFLEX_ID) Begin
86105>>>            Get ConstructConnectionString SQLConnection.sDriverID SQLConnection.sServer SQLConnection.sDatabase SQLConnection.bTrusted SQLConnection.sUserID SQLConnection.sPassword to SQLConnection.sConnectionString
86106>>>        End
86106>>>>
86106>>>    End_Procedure
86107>>>    
86107>>>    Function psDriverID Returns String
86109>>>        tSQLConnection SQLConnection  
86109>>>        tSQLConnection SQLConnection  
86109>>>        Get Private.pSQLConnection to SQLConnection
86110>>>        If (SQLConnection.sDriverID = "") Begin
86112>>>            Move MSSQLDRV_ID to SQLConnection.sDriverID // Default is the MS-SQL driver.
86113>>>        End
86113>>>>
86113>>>        Function_Return SQLConnection.sDriverID
86114>>>    End_Function  
