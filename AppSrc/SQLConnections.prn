97567>>>>>    // Transfers data between a tSQLConnection struct and a grid data row.
97567>>>>>    Function MoveSQLConnectionToGridRow tSQLConnection SQLConnection Returns tDataSourceRow
97570>>>>>        tDataSourceRow TheRow
97570>>>>>        tDataSourceRow TheRow
97570>>>>>        Integer iDbType
97570>>>>>        String sValue
97570>>>>>
97570>>>>>        Move 0                                  to TheRow.sValue[0]
97571>>>>>        Move SQLConnection.bEnabled             to TheRow.sValue[1]
97572>>>>>        Move SQLConnection.sConnectionID        to TheRow.sValue[2]
97573>>>>>        Move SQLConnection.sDriverID            to TheRow.sValue[3]
97574>>>>>
97574>>>>>        // We only show three asterisks ("***") instead of the password in the grid.
97574>>>>>        Move (Replace(SQLConnection.sPassword, SQLConnection.sConnectionString, "***")) to sValue
97575>>>>>        Move sValue                             to TheRow.sValue[4]
97576>>>>>
97576>>>>>        Move SQLConnection.iDbType to iDbType
97577>>>>>        Get SqlUtilDbTypeToString of ghoDbUpdateFunctionLibrary iDbType to sValue
97578>>>>>        Move sValue                             to TheRow.sValue[5]
97579>>>>>        Move SQLConnection.sServer              to TheRow.sValue[6]
97580>>>>>        Move SQLConnection.sDatabase            to TheRow.sValue[7]
97581>>>>>
97581>>>>>        // Hidden columns (to make Should_Save function work)
97581>>>>>        Move SQLConnection.sConnectionString    to TheRow.sValue[8] // "Untouched" connection string.
97582>>>>>        Move SQLConnection.bTrusted             to TheRow.sValue[9]
97583>>>>>        Move SQLConnection.sUserID              to TheRow.sValue[10]
97584>>>>>        Move SQLConnection.sPassword            to TheRow.sValue[11]
97585>>>>>        Move SQLConnection.sSchema              to TheRow.sValue[12]
97586>>>>>        Move SQLConnection.sBaseTableSpace      to TheRow.sValue[13]
97587>>>>>        Move SQLConnection.sLongTableSpace      to TheRow.sValue[14]
97588>>>>>        Move SQLConnection.sIndexTableSpace     to TheRow.sValue[15]
97589>>>>>        Move SQLConnection.bSilentLogin         to TheRow.sValue[16]
97590>>>>>//        Move SQLConnection.bDisabled            to TheRow.sValue[17]
97590>>>>>//        Move SQLConnection.iDriverIndex         to TheRow.sValue[18]
97590>>>>>
97590>>>>>        Function_Return TheRow
97591>>>>>    End_Function
