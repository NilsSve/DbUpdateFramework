81206>>>>>>>>>        Function_Return (CryptDestroyHash(hHash))
81207>>>>>>>>>    End_Function
81208>>>>>>>>>    
81208>>>>>>>>>    // Function : HashData
81208>>>>>>>>>    // Purpose  : Adds data to hash object
81208>>>>>>>>>    Function HashData Handle hHash String sData Returns Boolean
81210>>>>>>>>>        Function_Return (CryptHashData(hHash,AddressOf(sData),Length(sData),0))
81211>>>>>>>>>    End_Function
81212>>>>>>>>>    
81212>>>>>>>>>    // Function : DeriveKey
81212>>>>>>>>>    // Purpose  : Generates session key
81212>>>>>>>>>    Function DeriveKey Handle hProv Handle hHash Returns Handle
81214>>>>>>>>>        Integer iAlgorithm
81214>>>>>>>>>        Handle hKey
81214>>>>>>>>>        Boolean bOk
81214>>>>>>>>>        
81214>>>>>>>>>        Move 0 to hKey
81215>>>>>>>>>        Get piCipher to iAlgorithm
81216>>>>>>>>>        Move (CryptDeriveKey(hProv,iAlgorithm,hHash,CRYPT_EXPORTABLE,AddressOf(hKey))) to bOk
81217>>>>>>>>>        
81217>>>>>>>>>        Function_Return hKey
81218>>>>>>>>>    End_Function
81219>>>>>>>>>    
81219>>>>>>>>>    // Function : ImportPlainTextKey
81219>>>>>>>>>    // Purpose  : Imports a plain text key
81219>>>>>>>>>    Function ImportPlainTextKey Handle hProv UChar[] ucaKey Returns Handle
81221>>>>>>>>>        tPLAINTEXTKEYBLOB blobhead
81221>>>>>>>>>        tPLAINTEXTKEYBLOB blobhead
81221>>>>>>>>>        Boolean   bSuccess
81221>>>>>>>>>        Handle    hKey
81221>>>>>>>>>        Integer   iHeadSize iKeySize
81221>>>>>>>>>        UChar[]   ucaKeyblob
81222>>>>>>>>>        Integer iVoid
81222>>>>>>>>>    
81222>>>>>>>>>        Move (SizeOfType(tPLAINTEXTKEYBLOB)) to iHeadSize
81223>>>>>>>>>        Move (SizeOfArray(ucaKey)) to iKeySize
81224>>>>>>>>>    
81224>>>>>>>>>        Move PLAINTEXTKEYBLOB to blobhead.hdr.bType
81225>>>>>>>>>        Move CUR_BLOB_VERSION   to blobhead.hdr.bVersion
81226>>>>>>>>>        Get piCipher            to blobhead.hdr.aiKeyAlg
81227>>>>>>>>>        Move iKeySize           to blobhead.dwKeySize
81228>>>>>>>>>    
81228>>>>>>>>>        Move (ResizeArray(ucaKeyblob, iHeadSize)) to ucaKeyblob
81229>>>>>>>>>        Move (CopyMemory(AddressOf(ucaKeyblob), AddressOf(blobhead), iHeadSize)) to iVoid
81230>>>>>>>>>        Move (AppendArray(ucaKeyblob, ucaKey)) to ucaKeyblob
81231>>>>>>>>>    
81231>>>>>>>>>        Move 0 to hKey
81232>>>>>>>>>        Move (CryptImportKey(hProv, AddressOf(ucaKeyblob), SizeOfArray(ucaKeyblob), 0, 0, AddressOf(hKey))) to bSuccess
81233>>>>>>>>>        If (not(bSuccess)) Begin 
81235>>>>>>>>>            Move (ShowLastError()) to iVoid
81236>>>>>>>>>        End
81236>>>>>>>>>>
81236>>>>>>>>>    
81236>>>>>>>>>        Function_Return hKey
81237>>>>>>>>>    End_Function
81238>>>>>>>>>
81238>>>>>>>>>    // Function : DestroyKey
81238>>>>>>>>>    // Purpose  : Destroys the key
81238>>>>>>>>>    Function DestroyKey Handle hKey Returns Boolean
81240>>>>>>>>>        Function_Return (CryptDestroyKey(hKey))
81241>>>>>>>>>    End_Function
81242>>>>>>>>>    
81242>>>>>>>>>    // Function : KeyParameter
81242>>>>>>>>>    // Purpose  : Retrieves key data
81242>>>>>>>>>    Function KeyParameter Handle hKey Integer iQuery Returns Integer
81244>>>>>>>>>        Integer iBuffer iLen
81244>>>>>>>>>        Boolean bOk
81244>>>>>>>>>        
81244>>>>>>>>>        Move (SizeOfType(Integer)) to iLen
81245>>>>>>>>>        Move (CryptGetKeyParam(hKey,iQuery,AddressOf(iBuffer),AddressOf(iLen),0)) to bOk
81246>>>>>>>>>        Function_Return iBuffer
81247>>>>>>>>>    End_Function
81248>>>>>>>>>    
81248>>>>>>>>>    // Function : HashValue
81248>>>>>>>>>    // Purpose  : Retrieves a hash value
81248>>>>>>>>>    Function HashValue Handle lhHash Returns String
81250>>>>>>>>>        Pointer lpSize
81250>>>>>>>>>        Pointer lpHash
81250>>>>>>>>>        String  lsSize
81250>>>>>>>>>        String  lsHash
81250>>>>>>>>>        Integer liResult
81250>>>>>>>>>
81250>>>>>>>>>        Move (Repeat(Character(0),4)) to lsSize
81251>>>>>>>>>        GetAddress of lsSize to lpSize
81252>>>>>>>>>
81252>>>>>>>>>        Move (CryptGetHashParam(lhHash,HP_HASHVAL,0,lpSize,0)) to liResult
81253>>>>>>>>>        If (liResult = 0) Function_Return ""
81256>>>>>>>>>
81256>>>>>>>>>        Move (Repeat(Character(0),BytesTodWord(lsSize,1))) to lsHash
81257>>>>>>>>>        GetAddress of lsHash to lpHash
81258>>>>>>>>>
81258>>>>>>>>>        Move (CryptGetHashParam(lhHash,HP_HASHVAL,lpHash,lpSize,0)) to liResult
81259>>>>>>>>>        If (liResult = 0) Function_Return ""
81262>>>>>>>>>
81262>>>>>>>>>        Function_Return lsHash
81263>>>>>>>>>    End_Function  // HashValue
81264>>>>>>>>>    
81264>>>>>>>>>            
81264>>>>>>>>>    // Function : Encrypt
81264>>>>>>>>>    // Purpose  : Encrypts data
81264>>>>>>>>>    Function Encrypt String sPassword String sData Returns String
81266>>>>>>>>>        Handle hProv hHash hKey
81266>>>>>>>>>        Integer iAlgorithm iDataLen iCipherLen iErr
81266>>>>>>>>>        Boolean bOk
81266>>>>>>>>>        
81266>>>>>>>>>        Get AcquireContext to hProv
81267>>>>>>>>>        If (hProv) Begin
81269>>>>>>>>>            Get CreateHash hProv to hHash
81270>>>>>>>>>            If (hHash) Begin
81272>>>>>>>>>                Get HashData hHash sPassword to bOk
81273>>>>>>>>>                If (bOk) Begin
81275>>>>>>>>>                    Get piCipher to iAlgorithm
81276>>>>>>>>>                    Get DeriveKey hProv hHash to hKey
81277>>>>>>>>>                End // If (bOk) Begin            
81277>>>>>>>>>>
81277>>>>>>>>>                Get DestroyHash hHash to bOk
81278>>>>>>>>>            End // If (hHash) Begin
81278>>>>>>>>>>
81278>>>>>>>>>            
81278>>>>>>>>>            If (hKey) Begin
81280>>>>>>>>>                //  First call to determine resulting data size
81280>>>>>>>>>                Move (Length(sData)) to iDataLen
81281>>>>>>>>>                Move (Length(sData)) to iCipherLen
81282>>>>>>>>>                Move (CryptEncrypt(hKey, 0, True, 0, 0, AddressOf(iCipherLen), iDataLen)) to bOk
81283>>>>>>>>>                
81283>>>>>>>>>                //  Reserve space in string
81283>>>>>>>>>                If (iDataLen < iCipherLen) Begin
81285>>>>>>>>>                    Move (sData + Repeat(" ", iCipherLen - iDataLen)) to sData
81286>>>>>>>>>                End
81286>>>>>>>>>>
81286>>>>>>>>>                
81286>>>>>>>>>                //  Call to really decrypt
81286>>>>>>>>>                Move (CryptEncrypt(hKey,0,True,0,AddressOf(sData),AddressOf(iDataLen),Length(sData))) to bOk
81287>>>>>>>>>                //If (not(bOk)) Begin
81287>>>>>>>>>                    //Move "" to sData
81287>>>>>>>>>                    //Move (GetLastError()) to iErr
81287>>>>>>>>>                //End
81287>>>>>>>>>                
81287>>>>>>>>>                Get DestroyKey hKey to bOk
81288>>>>>>>>>            End // If (hKey) Begin
81288>>>>>>>>>>
81288>>>>>>>>>            Get ReleaseContext hProv to bOk
81289>>>>>>>>>        End // If (hProv) Begin
81289>>>>>>>>>>
81289>>>>>>>>>        Function_Return sData
81290>>>>>>>>>    End_Function
81291>>>>>>>>>    
81291>>>>>>>>>    // Function : Decrypt
81291>>>>>>>>>    // Purpose  : Decrypts data
81291>>>>>>>>>    Function Decrypt String sPassword String sData Returns String
81293>>>>>>>>>        Handle hProv hHash hKey
81293>>>>>>>>>        Integer iAlgorithm iDataLen
81293>>>>>>>>>        Boolean bOk
81293>>>>>>>>>        
81293>>>>>>>>>        Get AcquireContext to hProv
81294>>>>>>>>>        If (hProv) Begin
81296>>>>>>>>>            Get CreateHash hProv to hHash
81297>>>>>>>>>            If (hHash) Begin
81299>>>>>>>>>                Get HashData hHash sPassword to bOk
81300>>>>>>>>>                If (bOk) Begin
81302>>>>>>>>>                    Get piCipher to iAlgorithm
81303>>>>>>>>>                    Get DeriveKey hProv hHash to hKey
81304>>>>>>>>>                End // If (bOk) Begin            
81304>>>>>>>>>>
81304>>>>>>>>>                Get DestroyHash hHash to bOk
81305>>>>>>>>>            End // If (hHash) Begin
81305>>>>>>>>>>
81305>>>>>>>>>            
81305>>>>>>>>>            If (hKey) Begin
81307>>>>>>>>>                Move (Length(sData)) to iDataLen
81308>>>>>>>>>                Move (CryptDecrypt(hKey,0,True,0,AddressOf(sData),AddressOf(iDataLen))) to bOk
81309>>>>>>>>>                //If (bOk = False) Move "" to sData
81309>>>>>>>>>                
81309>>>>>>>>>                //  Resulting dat can be shorter as the input string, in that case we shorten the result string
81309>>>>>>>>>                If (Length(sData) > iDataLen) Begin
81311>>>>>>>>>                    Move (Left(sData, iDataLen)) to sData
81312>>>>>>>>>                End
81312>>>>>>>>>>
81312>>>>>>>>>                
81312>>>>>>>>>                Get DestroyKey hKey to bOk
81313>>>>>>>>>            End // If (hKey) Begin
81313>>>>>>>>>>
81313>>>>>>>>>            Get ReleaseContext hProv to bOk
81314>>>>>>>>>        End // If (hProv) Begin
81314>>>>>>>>>>
81314>>>>>>>>>        Function_Return sData
81315>>>>>>>>>    End_Function
81316>>>>>>>>>    
81316>>>>>>>>>    //  Function : GenerateRandom
81316>>>>>>>>>    //  Purpose  : Generates random data.
81316>>>>>>>>>    Function GenerateRandom Integer iBytes Returns UChar[]
81318>>>>>>>>>        Handle hProv
81318>>>>>>>>>        UChar[] uaResult
81319>>>>>>>>>        Boolean bRes
81319>>>>>>>>>        
81319>>>>>>>>>        Get AcquireContext to hProv
81320>>>>>>>>>        
81320>>>>>>>>>        Move (ResizeArray(uaResult, iBytes)) to uaResult
81321>>>>>>>>>        Move (CryptGenRandom(hProv, iBytes, AddressOf(uaResult))) to bRes
81322>>>>>>>>>        
81322>>>>>>>>>        Get ReleaseContext hProv to bRes
81323>>>>>>>>>        
81323>>>>>>>>>        Function_Return uaResult
81324>>>>>>>>>    End_Function
81325>>>>>>>>>    
81325>>>>>>>>>    //  Function : GenerateRandomString
81325>>>>>>>>>    //  Purpose  : Generates random data and does a base64 encoding to properly present it as a string.
81325>>>>>>>>>    Function GenerateRandomString Integer iLenght Returns String
81327>>>>>>>>>        String sResult
81327>>>>>>>>>        UChar[] aData
81328>>>>>>>>>        Address pBase64
81328>>>>>>>>>        Integer iVoid
81328>>>>>>>>>
81328>>>>>>>>>        Get GenerateRandom iLenght to aData
81329>>>>>>>>>        
81329>>>>>>>>>        Move (Base64Encode(AddressOf(aData), iLenght)) to pBase64
81330>>>>>>>>>        Move pBase64 to sResult
81331>>>>>>>>>        Move (Free(pBase64)) to iVoid    
81332>>>>>>>>>        
81332>>>>>>>>>        Function_Return (Left(sResult, iLenght))
81333>>>>>>>>>    End_Function
