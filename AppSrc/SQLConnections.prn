89671>>>    // Checks that the passed sDriverID is defined.
89671>>>    // Also checks if the driver has been loaded; else it gets loaded.
89671>>>    Function _SqlCheckCurrentDriver String sDriverID Returns Boolean
89673>>>        Boolean bOK                         
89673>>>        Integer iDriver
89673>>>        
89673>>>        If (sDriverID = DATAFLEX_ID) Begin
89675>>>            Function_Return False
89676>>>        End                      
89676>>>>
89676>>>
89676>>>        Get IsDAWSQLDriver sDriverID to bOK
89677>>>
89677>>>        If (bOK = False) Begin
89679>>>            Get IsMertechDriver sDriverID to bOK
89680>>>        End   
89680>>>>
89680>>>        
89680>>>        If (bOK = False) Begin        
89682>>>            Error DFERR_PROGRAM "Driver needs to be one of MSSQLDRV, DB2_DRV, ODBC_DRV, SQLFLEX, ORAFLEX, MDSPgSQL or MDSMySQL"
89683>>>>
89683>>>            Function_Return False
89684>>>        End 
89684>>>>
89684>>>        
89684>>>        Get DriverIndex sDriverID to iDriver
89685>>>        If (iDriver = 0) Begin
89687>>>            Load_Driver sDriverID
89688>>>        End
89688>>>>
89688>>>        
89688>>>        Function_Return True
89689>>>    End_Function
