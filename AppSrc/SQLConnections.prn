91294>>>    
91294>>>    // Checks if a field name exists in a table definition
91294>>>    // Returns True if it does
91294>>>    // Sample:
91294>>>    //   Get UtilColumnExists MyTable.File_Number "MyColumnName" to iExists
91294>>>    Function UtilColumnExists Handle hTable String sFieldName Returns Boolean
91296>>>        Integer iNumColumns iColumn
91296>>>        String sColumn
91296>>>        Boolean bExists bOK
91296>>>    
91296>>>        Get AutoConnectionIDLogin to bOK
91297>>>        Send Ignore_Error of Error_Object_Id DFERR_CANT_OPEN_DATA_FILE
91298>>>        Open hTable                       
91300>>>        Send Trap_Error   of Error_Object_Id DFERR_CANT_OPEN_DATA_FILE
91301>>>        If (Found = False) Begin
91303>>>            Function_Return False
91304>>>        End                      
91304>>>>
91304>>>        
91304>>>        Move False to bExists  
91305>>>        Get_Attribute DF_FILE_NUMBER_FIELDS of hTable to iNumColumns
91308>>>        for iColumn from 1 to iNumColumns
91314>>>>
91314>>>            Get_Attribute DF_FIELD_NAME of hTable iColumn to sColumn
91317>>>            If (Uppercase(sFieldName) = Uppercase(sColumn)) Begin
91319>>>                Move iNumColumns to iColumn
91320>>>                Move True to bExists
91321>>>            End
91321>>>>
91321>>>        Loop
91322>>>>
91322>>>        Close hTable
91323>>>    
91323>>>        Function_Return bExists
91324>>>    End_Function
91325>>>    
91325>>>    // Checks if the current psConnectionID is logged in; if not
91325>>>    // attempts to make a login. 
91325>>>    // Because
91325>>>    // Returns True if already logged in or the new login was successful.
91325>>>    Function AutoConnectionIDLogin Returns Boolean
91327>>>        String sConnectionID sConnectionString sDriverID
91327>>>        Boolean bExists bOK bDAWDriver
91327>>>        Handle hoCLI hoDriver                                    
91327>>>        Integer iRetval
91327>>>        tSQLConnection SQLConnection
91327>>>        tSQLConnection SQLConnection
91327>>>        
91327>>>        Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
91328>>>        Move SQLConnection.sDriverID                  to sDriverID      
91329>>>        Move SQLConnection.sConnectionString          to sConnectionString
91330>>>        Get IsDAWSQLDriver sDriverID to bOK
91331>>>        If (bOK = False) Begin                         
91333>>>            Get _MertechSQLManagerHandle to hoCLI
91334>>>            Get Create (RefClass(cDbUpdateDatabaseDriver)) to hoDriver
91335>>>            Set psDriverID of hoDriver to SQLConnection.sDriverID
91336>>>            Get DbLogin    of hoDriver sConnectionString SQLConnection.sServer SQLConnection.sDatabase SQLConnection.bTrusted SQLConnection.sUserID SQLConnection.sPassword to bOK
91337>>>            Send Destroy   of hoDriver
91338>>>            Function_Return False
91339>>>        End                      
91339>>>>
91339>>>        
91339>>>        Move SQLConnection.sConnectionID to sConnectionID
91340>>>        
91340>>>        Get IsConnectionID sConnectionID sDriverID to bExists
91341>>>        If (bExists = False) Begin
91343>>>            // We always start by deleting the current connection - if any - because the
91343>>>            // login details my have changed.
91343>>>            Get phoCLIHandler to hoCLI   
91344>>>            Set psDriverID    of hoCLI to sDriverID
91345>>>            Get DeleteConnectionID of hoCLI sConnectionID -1 to iRetval
91346>>>            Get UtilCreateConnectionID sConnectionID to bOk
91347>>>            If (bOk = False) Begin
91349>>>                Error DFERR_PROGRAM ("The Connection ID:" * sConnectionID * "could not be created and therefor the table can't be changed.")
91350>>>>
91350>>>                Function_Return False
91351>>>            End
91351>>>>
91351>>>            Move bOK to bExists
91352>>>        End
91352>>>>
91352>>>        
91352>>>        Function_Return (bExists = True)
91353>>>    End_Function
91354>>>    
91354>>>    // *** Utility Messages ***
91354>>>    // 
91354>>>    //
91354>>>    // To add a value to the CodeMast & CodeType tables. Pass; a) bCodeType if it is CodeType that should be updated. 
91354>>>    // Else it is CodeMast. b) sTypeValue; either to be added If bCodeType = True, or it will be used to find the correct 
91354>>>    // CodeType record. c) sValue1 and d) sValue2 is the CodeType Description & Comment, or CodeMast Type and Code values.
91354>>>    Function UtilCodeMasterAddValue Boolean bCodeType String sTypeValue String sValue2 String sValue3 Returns Boolean
91356>>>        Boolean bError bFound
91356>>>        
91356>>>        Move False to Err
91357>>>        Open CodeMast
91359>>>        Open CodeType
91361>>>        
91361>>>        If (bCodeType = True) Begin
91363>>>            Clear CodeType
91364>>>            Move sTypeValue to CODETYPE.Type 
91365>>>            Find eq CODETYPE.Type
91366>>>>
91366>>>            Move (Found = True) to bFound
91367>>>            If (bFound = True) Begin
91369>>>                Reread CodeType
91373>>>            End
91373>>>>
91373>>>            If (bFound = False) Begin
91375>>>                Clear CodeType
91376>>>            End       
91376>>>>
91376>>>                Move sTypeValue to CODETYPE.Type 
91377>>>                Move sValue2    to CODETYPE.Description
91378>>>                Move sValue3    to CODETYPE.Comment
91379>>>                SaveRecord CODETYPE
91380>>>            If (bFound = True) Begin
91382>>>                Unlock
91383>>>>
91383>>>            End
91383>>>>
91383>>>        End
91383>>>>
91383>>>        
91383>>>        If (bCodeType = False) Begin
91385>>>            Clear CODEMAST
91386>>>            Move sTypeValue to CODEMAST.Type
91387>>>            Move sValue2    to CODEMAST.Code  
91388>>>            Find eq CODEMAST.Code
91389>>>>
91389>>>            Move (Found = True) to bFound
91390>>>            If (bFound = True) Begin
91392>>>                Reread CODEMAST
91396>>>            End
91396>>>>
91396>>>            If (bFound = False) Begin
91398>>>                Clear CODEMAST
91399>>>            End   
91399>>>>
91399>>>                Move sTypeValue to CODEMAST.Type
91400>>>                Move sValue2    to CODEMAST.Code  
91401>>>                Move sValue3    to CODEMAST.Description
91402>>>                SaveRecord CODEMAST
91403>>>            If (bFound = True) Begin
91405>>>            Unlock
91406>>>>
91406>>>            End
91406>>>>
91406>>>        End
91406>>>>
91406>>>        
91406>>>        Close CodeMast
91407>>>        Close CodeType
91408>>>        
91408>>>        Function_Return (Err = False)
91409>>>    End_Function
91410>>>
91410>>>    // Changes values in CodeType & CodeMast - From type value To type value. It first changes the type value in 
91410>>>    // CodeType and then spins through all CodeMast records to change all related records.
91410>>>    Function UtilCodeMasterChangeValue String sFromValue String sToValue Returns Boolean
91412>>>        Boolean bFound
91412>>>        
91412>>>        Move False to Err
91413>>>        Open CodeMast
91415>>>        Open CodeType
91417>>>        
91417>>>        Clear CodeType
91418>>>        Move sFromValue to CODETYPE.Type
91419>>>        Find eq CODETYPE.Type
91420>>>>
91420>>>        If (Found = True) Begin
91422>>>            Reread CODETYPE
91426>>>                Move sToValue to CODETYPE.Type
91427>>>                SaveRecord CODETYPE
91428>>>            Unlock                 
91429>>>>
91429>>>        End
91429>>>>
91429>>>            
91429>>>        Clear CODEMAST
91430>>>        Find gt CODEMAST by Recnum
91431>>>>
91431>>>        While (Found = True)
91435>>>            Move (Trim(Uppercase(CODEMAST.Type) = Trim(Uppercase(sFromValue)))) to bFound
91436>>>            If (bFound = True) Begin
91438>>>                Reread CODEMAST
91442>>>                    Move sToValue to CODEMAST.Type
91443>>>                    SaveRecord CODEMAST
91444>>>                Unlock
91445>>>>
91445>>>            End
91445>>>>
91445>>>            Find gt CODEMAST by Recnum
91446>>>>
91446>>>        Loop
91447>>>>
91447>>>        
91447>>>        Close CodeMast
91448>>>        Close CodeType
91449>>>        
91449>>>        Function_Return (Err = False)
91450>>>    End_Function
91451>>>    
91451>>>    // Removes a value from CodeMast. Pass the sTypeValue and the sValue2 to remove.
91451>>>    Function UtilCodeMasterRemoveValue String sTypeValue String sValue2 Returns Boolean
91453>>>        Boolean bError bFound
91453>>>        
91453>>>        Move False to Err
91454>>>        Open CodeMast
91456>>>        
91456>>>        Clear CODEMAST
91457>>>        Move sTypeValue to CODEMAST.Type
91458>>>        Move sValue2    to CODEMAST.Code  
91459>>>        Find eq CODEMAST.Code
91460>>>>
91460>>>        Move (Found = True) to bFound
91461>>>        If (bFound = True) Begin
91463>>>            Delete CODEMAST
91464>>>        End
91464>>>>
91464>>>        
91464>>>        Close CodeMast
91465>>>        
91465>>>        Function_Return (Err = False)
91466>>>    End_Function
91467>>>
91467>>>    // Note:
91467>>>    // The DF_FILE_TABLE_NAME attribute holds the name of the table at the back end. Depending on the back end, table 
91467>>>    // names may be case sensitive, contain spaces or other special characters. This attribute is used to determine a table's 
91467>>>    // back end name when using Embedded SQL. Since Embedded SQL works on the back end directly, the back end's name must be used. 
91467>>>    // In most cases the back end name will be the same as the table name used in DataFlex.
91467>>>    // To do the opposite; To get the file handle from a table name string use the UtilTableNameToHandle function.
91467>>>    Function UtilTableHandleToString Handle hTable Returns String
91469>>>        String sTableName
91469>>>        Boolean bOpen bExists bRecnum bOK
91469>>>        
91469>>>        Get UtilTableNumberIsInUse hTable to bExists
91470>>>        If (bExists = False) Begin
91472>>>            Move True to Err
91473>>>            Function_Return ""
91474>>>        End
91474>>>>
91474>>>
91474>>>        Set Error_Report_Mode to DUF_ERROR_NO_REPORT
91475>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpen
91478>>>        If (bOpen = False) Begin                       
91480>>>            Get AutoConnectionIDLogin to bOK
91481>>>            Send Ignore_Error of Error_Object_Id DFERR_CANT_OPEN_DATA_FILE
91482>>>            Send Ignore_Error of Error_Object_Id DFERR_CANT_OPEN_INTERMEDIATE_FILE
91483>>>            Send Ignore_Error of Error_Object_Id CLIERR_GENERAL_ERROR
91484>>>            Open hTable
91486>>>            Send Trap_Error of Error_Object_Id DFERR_CANT_OPEN_DATA_FILE
91487>>>            Send Trap_Error of Error_Object_Id DFERR_CANT_OPEN_INTERMEDIATE_FILE
91488>>>            Send Trap_Error of Error_Object_Id CLIERR_GENERAL_ERROR
91489>>>            Get_Attribute DF_FILE_OPENED of hTable to bOpen
91492>>>        End
91492>>>>
91492>>>        If (bOpen = True) Begin
91494>>>            Send Ignore_Error of Error_Object_Id DFERR_UNSUPPORTED_ATTRIBUTE 
91495>>>            Get_Attribute DF_FILE_TABLE_NAME of hTable to sTableName 
91498>>>            // If blank it is an embedded table:
91498>>>            If (sTableName = "") Begin
91500>>>                Get_Attribute DF_FILE_LOGICAL_NAME of hTable to sTableName 
91503>>>                Move 0 to LastErr
91504>>>                Move False to Err
91505>>>            End
91505>>>>
91505>>>            Send Trap_Error of Error_Object_Id DFERR_UNSUPPORTED_ATTRIBUTE
91506>>>        End
91506>>>>
91506>>>        Set Error_Report_Mode to DUF_ERROR_REPORT
91507>>>            
91507>>>        Function_Return sTableName
91508>>>    End_Function
91509>>>    
91509>>>    // Returns the filenumber for the passed Table name from Filelist.cfg.
91509>>>    // Returns 0 if unsuccessful.
91509>>>    // To do the opposite; To get the string value from a table handle string use the UtilTableHandleToString function.
91509>>>    Function UtilTableNameToHandle String sTableName Returns Integer
91511>>>        String sValue sPrefixTableName sDriverID
91511>>>        Handle hTable hRetval
91511>>>        
91511>>>        Get psDriverID to sDriverID 
91512>>>        If (sDriverID <> DATAFLEX_ID and not(sTableName contains ":")) Begin
91514>>>            Move (sDriverID + ":" + sTableName) to sPrefixTableName
91515>>>        End
91515>>>>
91515>>>        Move 0 to hTable 
91516>>>        Move 0 to hRetval
91517>>>        Repeat 
91517>>>>
91517>>>            Get_Attribute DF_FILE_NEXT_USED of hTable to hTable
91520>>>            If (hTable <> 0) Begin
91522>>>                Get_Attribute DF_FILE_ROOT_NAME of hTable to sValue
91525>>>                If (Uppercase(sValue) = Uppercase(sTableName) or Uppercase(sValue) = Uppercase(sPrefixTableName)) Begin
91527>>>                    Move hTable to hRetval
91528>>>                    Move 0 to hTable
91529>>>                End
91529>>>>
91529>>>            End
91529>>>>
91529>>>        Until (hTable = 0)
91531>>>        
91531>>>        Function_Return hRetval
91532>>>    End_Function
91533>>>        
91533>>>    // Check if the file exists in the Data folder,
91533>>>    // else creates it from memory as it has been compiled into the program as a resource:
91533>>>    Function UtilCheckCreateIfFileExists String sFileName String sResourceName Boolean bDataFile Returns Boolean
91535>>>        String sPath sDataPath
91535>>>        Boolean bExists
91535>>>    
91535>>>        Get psDataPathFirstPart to sPath
91536>>>        Move (sPath + sFileName) to sFileName
91537>>>        Get vFilePathExists sFileName to bExists
91538>>>    
91538>>>        If (bExists = False) Begin
91540>>>            // Read from memory & create file on disk.
91540>>>            Send SqlUtilCreateFileFromMemory sResourceName sFileName
91541>>>            Get vFilePathExists sFileName to bExists
91542>>>        End     
91542>>>>
91542>>>        Function_Return bExists
91543>>>    End_Function
