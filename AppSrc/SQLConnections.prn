89171>>>    Function SqlUtilUpdateIntFile Integer hTable Returns Boolean           
89173>>>        String sOrgFormat sNewFormat sRootName sDatabaseName sPhysicalFileName sDriverID sDataPath         
89173>>>        Boolean bOpened bOK bMertech
89173>>>        
89173>>>        Move CS_OEM_Txt  to sOrgFormat
89174>>>        Move CS_ANSI_Txt to sNewFormat
89175>>>        Get AutoConnectionIDLogin to bOK
89176>>>        Send Ignore_Error of Error_Object_Id DFERR_MISSING_VALUE
89177>>>        Open hTable //Mode DF_EXCLUSIVE
89179>>>        Send Trap_Error of Error_Object_Id DFERR_MISSING_VALUE
89180>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpened
89183>>>        
89183>>>        // ToDo: What to do if we cannot open the table?!
89183>>>        If (bOpened = False) Begin
89185>>>            Function_Return False
89186>>>        End
89186>>>>
89186>>>        
89186>>>        Get psDriverID to sDriverID
89187>>>        Get IsMertechDriver sDriverID to bMertech
89188>>>        If (bMertech = True) Begin       
89190>>>            Get psDataPathFirstPart to sDataPath
89191>>>            Get vFolderExists sDataPath to bOK
89192>>>            If (bOK = False) Begin
89194>>>                Error DFERR_PROGRAM "Function SqlUtilUpdateIntFile; psDataPath not found!"
89195>>>>
89195>>>                Function_Return False    
89196>>>            End                      
89196>>>>
89196>>>            Get vFolderFormat sDataPath to sDataPath 
89197>>>            Get_Attribute DF_FILE_ROOT_NAME of hTable to sRootName
89200>>>            Get _TableNameOnly sRootName to sDatabaseName
89201>>>            Move sDatabaseName to sPhysicalFileName
89202>>>            Move (sPhysicalFileName + ".int") to sPhysicalFileName
89203>>>            Get _MertechSqlUtilCreateIntFile hTable sDataPath sPhysicalFileName to bOK
89204>>>            Function_Return (bOK = True)
89205>>>        End
89205>>>>
89205>>>        
89205>>>        Move False to Err
89206>>>        Get_Attribute DF_FILE_TABLE_CHARACTER_FORMAT of hTable to sOrgFormat
89209>>>        Move (Uppercase(sOrgFormat)) to sOrgFormat       
89210>>>        // Lets swap the OEM/ANSI format, just to make a change in Structure_Start below (and back),
89210>>>        // to "touch" the table so the driver feels there has been a change and updates the .int file.
89210>>>        Move (If(sOrgFormat = CS_OEM_Txt, CS_ANSI_Txt, CS_OEM_Txt)) to sNewFormat
89211>>>        
89211>>>        Structure_Start hTable
89212>>>            Set_Attribute DF_FILE_TABLE_CHARACTER_FORMAT of hTable to sNewFormat
89215>>>            Set_Attribute DF_FILE_TABLE_CHARACTER_FORMAT of hTable to sOrgFormat
89218>>>        Structure_End hTable (DF_STRUCTEND_OPT_IN_PLACE ior DF_STRUCTEND_OPT_FORCE)
89220>>>        
89220>>>        Function_Return (Err = False)
89221>>>    End_Function 
89222>>>    
89222>>>    // Checks if the passed Table;
89222>>>    // 1) Already has a Filelist entry that points to SQL and
89222>>>    // 2) It has an .int file. 
89222>>>    // If both is True it should already be connected to SQL
89222>>>    Function SQLUtilTableIsAttached String sDriverID Handle hTable Returns Boolean
89224>>>        Boolean bExists bRootName
89224>>>        String sRootName sDataPath
89224>>>        Integer iCount
89224>>>        
89224>>>        Get_Attribute DF_FILE_ROOT_NAME of hTable to sRootName
89227>>>        Move (sRootName contains sDriverID) to bRootName
89228>>>        
89228>>>        Get psDataPathFirstPart to sDataPath
89229>>>        Get vFolderExists sDataPath to bExists
89230>>>        If (bExists = False) Begin
89232>>>            // If the path doesn't exist it cannot have an .int file and we're done, although it shouldn't happen.
89232>>>            Function_Return False
89233>>>        End                      
89233>>>>
89233>>>        
89233>>>        Get vFolderFormat sDataPath to sDataPath         
89234>>>        Get _TableNameOnly sRootName to sRootName
89235>>>        Get vFilePathExists (sDataPath + sRootName + ".int") to bExists
89236>>>
89236>>>        Function_Return (bRootName = True and bExists = True)
89237>>>    End_Function       
89238>>>    
89238>>>    Function SQLUtilTableIsViewType String sDriverID Handle hTable Returns Boolean
89240>>>        Boolean bViewTableType bOpen bMertechDriver bOK
89240>>>        Integer hoSQLHandler
89240>>>        Integer iTableCount iNumTables iPos iTableIndex
89240>>>        String sTableName sOwner sTableType sLogin sEnumTableName sEnumSchemaName sCurrent_Login
89240>>>        Handle hoCliHandler  
89240>>>        tSQLConnection SQLConnection
89240>>>        tSQLConnection SQLConnection
89240>>>        
89240>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpen
89243>>>        If (bOpen = False) Begin  
89245>>>            Get AutoConnectionIDLogin to bOK
89246>>>            Open hTable
89248>>>        End
89248>>>>
89248>>>        
89248>>>        Get pSQLConnection to SQLConnection   
89249>>>        Get phoCLIHandler to hoCliHandler
89250>>>        Set psDriverID of hoCliHandler to sDriverID
89251>>>        
89251>>>        Get_Attribute DF_FILE_ROOT_NAME of hTable to sTableName 
89254>>>        Get _TableNameOnly sTableName to sTableName             
89255>>>        Get_Attribute DF_FILE_OWNER     of hTable to sOwner
89258>>>        Get EnumerateTables of hoCliHandler SQLConnection.sConnectionString to iNumTables
89259>>>        
89259>>>        For iTableCount from 1 to iNumTables
89265>>>>
89265>>>            Get TableName  of hoCliHandler iTableCount to sEnumTableName
89266>>>            Get SchemaName of hoCliHandler iTableCount to sEnumSchemaName
89267>>>            If ((Uppercase(sEnumTableName)  = Uppercase(sTableName)) and (Uppercase(sEnumSchemaName) = Uppercase(sOwner))) Begin
89269>>>                Get TableType of hoCliHandler iTableCount to sTableType
89270>>>                Move iNumTables to iTableCount // We're done.
89271>>>            End
89271>>>>
89271>>>        Loop
89272>>>>
89272>>>        
89272>>>        Move (sTableType = "VIEW") to bViewTableType
89273>>>        If (bOpen = False) Begin
89275>>>            Close hTable
89276>>>        End
89276>>>>
89276>>>        
89276>>>        Function_Return bViewTableType
89277>>>    End_Function
