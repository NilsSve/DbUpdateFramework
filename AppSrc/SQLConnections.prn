89510>>>    // To enumerate SQL database resources with ESQL and return the result as a string array,
89510>>>    // for DAW drivers.
89510>>>    // Returns: A string array.
89510>>>    Function SqlEnumerateEsqlDAW String sStmt Integer iColumn Returns String[]
89512>>>        String[] sReturnArray
89513>>>        String sValue sPrevious
89513>>>        Handle hoSQLHandler hoSQLConnect hstmt
89513>>>        Integer iFetchResult iRows
89513>>>        tSQLConnection SQLConnection
89513>>>        tSQLConnection SQLConnection
89513>>>        
89513>>>        Get phoSQLManager to hoSQLHandler
89514>>>                
89514>>>        If (hoSQLHandler <> 0) Begin 
89516>>>            Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
89517>>>            Get SQLConnect of hoSQLHandler SQLConnection.sDriverID SQLConnection.sConnectionString to hoSQLConnect
89518>>>            
89518>>>            If (hoSQLConnect <> 0) Begin   
89520>>>                Get SQLOpen of hoSQLConnect to hstmt
89521>>>                If (hstmt <> 0) Begin                                   
89523>>>                    Send SqlExecDirect of hstmt sStmt                                             
89524>>>                    Get SqlStmtAttribute of hstmt SqlSTMTATTRIB_ROWCOUNT to iRows 
89525>>>                    Repeat
89525>>>>
89525>>>                        Get SQLFetch of hstmt to iFetchResult
89526>>>                        If (iFetchResult <> 0) Begin
89528>>>                            Get SQLColumnValue of hstmt iColumn to sValue
89529>>>                            If (sValue <> sPrevious) Begin
89531>>>                                Move (Trim(sValue)) to sReturnArray[SizeOfArray(sReturnArray)
89532>>>                            End
89532>>>>
89532>>>                            Move sValue to sPrevious
89533>>>                        End
89533>>>>
89533>>>                    Until (iFetchResult = 0)
89535>>>                    Send SQLClose of hstmt
89536>>>                End
89536>>>>
89536>>>                Send SQLDisconnect of hoSQLConnect    
89537>>>            End
89537>>>>
89537>>>        End
89537>>>>
89537>>>    
89537>>>        Function_Return sReturnArray
89538>>>    End_Function   
89539>>>
89539>>>    // To enumerate SQL database resources with ESQL and return the result as a string array,
89539>>>    // for Mertech drivers.
