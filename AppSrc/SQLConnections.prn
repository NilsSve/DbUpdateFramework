83307>>>>>>>>>>>
83307>>>>>>>>>>>    Function SQLColumnValue Integer iCol Returns String
83309>>>>>>>>>>>        String sResult
83309>>>>>>>>>>>        Integer iCols
83309>>>>>>>>>>>        Integer iOrgDateFmt
83309>>>>>>>>>>>        Integer iOrgDateSep
83309>>>>>>>>>>>        String sType 
83309>>>>>>>>>>>
83309>>>>>>>>>>>        SQL_SET_CURRENT_CURSOR_STMT to (piCursorNum(Self))
83323>>>>>>>>>>>>
83323>>>>>>>>>>>        
83323>>>>>>>>>>>        SQL_GET_NUM_COLS to iCols
83333>>>>>>>>>>>>
83333>>>>>>>>>>>        If (iCol <= iCols) Begin
83335>>>>>>>>>>>            //DAC SQL Driver currently uses military format for the SQL getting of dates.
83335>>>>>>>>>>>            If (giSQLCompatibilityMode=SQL_DAC_HIGH_COMPATABILITY) Begin             
83337>>>>>>>>>>>                Get_Attribute DF_DATE_FORMAT to iOrgDateFmt
83340>>>>>>>>>>>                Get_Attribute DF_DATE_SEPARATOR to iOrgDateSep
83343>>>>>>>>>>>                Set_Attribute DF_DATE_FORMAT to DF_DATE_MILITARY
83346>>>>>>>>>>>                Set_Attribute DF_DATE_SEPARATOR to (Ascii('-'))
83349>>>>>>>>>>>            End 
83349>>>>>>>>>>>>
83349>>>>>>>>>>>            
83349>>>>>>>>>>>            //DAC SQL Driver cannot directly get TEXT fields into a result. 
83349>>>>>>>>>>>            If (giSQLCompatibilityMode=SQL_DAC_HIGH_COMPATABILITY) Begin             
83351>>>>>>>>>>>                SQL_GET_COL_ATTRIBUTE of iCol DFTYPE to sType
83368>>>>>>>>>>>>
83368>>>>>>>>>>>                If (sType=5) Move "" to sResult 
83371>>>>>>>>>>>                Else Begin 
83372>>>>>>>>>>>                    SQL_FETCH_COLUMN iCol into sResult
83377>>>>>>>>>>>                End
83377>>>>>>>>>>>>
83377>>>>>>>>>>>            End 
83377>>>>>>>>>>>>
83377>>>>>>>>>>>            Else Begin 
83378>>>>>>>>>>>               SQL_FETCH_COLUMN iCol into sResult 
83383>>>>>>>>>>>            End
83383>>>>>>>>>>>>
83383>>>>>>>>>>>            
83383>>>>>>>>>>>
83383>>>>>>>>>>>            If (giSQLCompatibilityMode=SQL_DAC_HIGH_COMPATABILITY) Begin             
83385>>>>>>>>>>>                Set_Attribute DF_DATE_FORMAT to iOrgDateFmt
83388>>>>>>>>>>>                Set_Attribute DF_DATE_SEPARATOR to iOrgDateSep
83391>>>>>>>>>>>            End 
83391>>>>>>>>>>>>
83391>>>>>>>>>>>
83391>>>>>>>>>>>            Function_Return sResult
83392>>>>>>>>>>>        End
83392>>>>>>>>>>>>
83392>>>>>>>>>>>        Else Send HandleError (phCLIHandle(Self)) (phCLIHandle(Parent(Self))) (psDriverID(Self)) "SQLColumnValue"
83394>>>>>>>>>>>    End_Function // SQLColumnValue
