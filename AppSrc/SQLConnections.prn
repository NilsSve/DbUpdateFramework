81614>>>>>>>>>>>>>/// @Drivers     SQLFlex and ORAFlex
81614>>>>>>>>>>>>>/// @VersionNote Last Revised: 2013-09-24 by Aaron Gulack
81614>>>>>>>>>>>>>/// @See                 SET_SCHEMA_NAME
81614>>>>>>>>>>>>>///
81614>>>>>>>>>>>>>/// @Syntax GET_SCHEMA_NAME to {variable}
81614>>>>>>>>>>>>>/// @Param variable                     variable to hold the schema name
81614>>>>>>>>>>>>>///
81614>>>>>>>>>>>>>/// @Example
81614>>>>>>>>>>>>>/// GET_SCHEMA_NAME to sName
81614>>>>>>>>>>>>>/// Showln sName
81614>>>>>>>>>>>>>
81614>>>>>>>>>>>>>//=============================================================================
81614>>>>>>>>>>>>>/// @Name        CALL_ORACLE_STORED_PROCEDURE
81614>>>>>>>>>>>>>/// @Description This command is used to call a stored procedure on the SQL
81614>>>>>>>>>>>>>/// backend. To successfully call a procedure with this command, a string
81614>>>>>>>>>>>>>/// must be passed containing a valid procedure name. In addition, if the
81614>>>>>>>>>>>>>/// procedure takes any arguments, they must also be passed using the constant
81614>>>>>>>>>>>>>/// "passing" along with all of the needed arguments. If the procedure has a
81614>>>>>>>>>>>>>/// return value, then SQL_GET_FUNCTION_RETURN or SQL_FETCH_NEXT_ROW can be
81614>>>>>>>>>>>>>/// used to get the value(s). If an error is found then the indicator "Err"
81614>>>>>>>>>>>>>/// is set to true.
81614>>>>>>>>>>>>>///
81614>>>>>>>>>>>>>/// @Assumptions
81614>>>>>>>>>>>>>/// @Status      Deprecated
81614>>>>>>>>>>>>>/// @Drivers     ORAFLex
81614>>>>>>>>>>>>>/// @VersionNote Last Revised: 2013-09-25 by Aaron Gulack
81614>>>>>>>>>>>>>/// @See                 CALL_STORED_PROCEDURE
81614>>>>>>>>>>>>>///
81614>>>>>>>>>>>>>/// @Syntax CALL_ORACLE_STORED_PROCEDURE {procedure} Passing {variable}
81614>>>>>>>>>>>>>/// @Param procedure            Full name of the procedure
81614>>>>>>>>>>>>>/// @Param variable                     Argument being passed to procedure (can be multiple)
81614>>>>>>>>>>>>>///
81614>>>>>>>>>>>>>/// @Example
81614>>>>>>>>>>>>>/// CALL_ORACLE_STORED_PROCEDURE "sys.sp_addmessage" passing 50003 15 "Please enter a valid date"
81614>>>>>>>>>>>>>
81614>>>>>>>>>>>>>//=============================================================================
81614>>>>>>>>>>>>>/// @Name        SQL_SET_PROCEDURE_NAME
81614>>>>>>>>>>>>>/// @Description This command is used to set the procedure to be executed.
81614>>>>>>>>>>>>>/// This is used when the procedure is being split up into multiple lines
81614>>>>>>>>>>>>>/// as shown below. When using this command, SQL_PROCEDURE_EXECUTE must be
81614>>>>>>>>>>>>>/// called after all parameters have been set to successfully execute the
81614>>>>>>>>>>>>>/// procedure. The constant "NUMPAR" is used to indicate how many parameters
81614>>>>>>>>>>>>>/// will be passed.
81614>>>>>>>>>>>>>///
81614>>>>>>>>>>>>>/// @Assumptions The procedure is a valid procedure in the SQL database
81614>>>>>>>>>>>>>/// @Status      Public
81614>>>>>>>>>>>>>/// @Drivers     All
81614>>>>>>>>>>>>>/// @VersionNote Last Revised: 2013-09-25 by Aaron Gulack
81614>>>>>>>>>>>>>/// @See                 SQL_SET_PROCEDURE_PARAMETER SQL_PROCEDURE_EXECUTE
81614>>>>>>>>>>>>>///
81614>>>>>>>>>>>>>/// @Syntax SQL_SET_PROCEDURE_NAME {procedure} NUMPAR {variable}
81614>>>>>>>>>>>>>/// @Param procedure            Full name of the procedure
81614>>>>>>>>>>>>>/// @Param variable                     Number of parameters to be passed
81614>>>>>>>>>>>>>///
81614>>>>>>>>>>>>>/// @Example
81614>>>>>>>>>>>>>/// SQL_SET_PROCEDURE_NAME "sys.sp_addmessage" NUMPAR 3
81614>>>>>>>>>>>>>/// SQL_SET_PROCEDURE_PARAMETER 1 to 500004 IN
81614>>>>>>>>>>>>>/// SQL_SET_PROCEDURE_PARAMETER 2 to 15 IN
81614>>>>>>>>>>>>>/// SQL_SET_PROCEDURE_PARAMETER 3 to "Please enter a valid Date" IN
81614>>>>>>>>>>>>>/// SQL_PROCEDURE_EXECUTE
81614>>>>>>>>>>>>>
81614>>>>>>>>>>>>>
81614>>>>>>>>>>>>>Procedure MertechInc_SQL_SET_ORAPROCEDURE_NAME Global String strProcName Integer iNumpar
81616>>>>>>>>>>>>>    Local Integer iParam
81616>>>>>>>>>>>>>
81616>>>>>>>>>>>>>    Move 0 to MertechInc_iParamCount       //Redundant, but left in incase called
81617>>>>>>>>>>>>>    INDICATE ERR False              //directly and not via SQL_SET_PROCEDURE_NAME
81618>>>>>>>>>>>>>    Move ORAFlex to MertechInc_DriverName  //
81619>>>>>>>>>>>>>
81619>>>>>>>>>>>>>    SQL_SET_STMT to "BEGIN "
81627>>>>>>>>>>>>>    SQL_APPEND_STMT to strProcName
81635>>>>>>>>>>>>>    SQL_APPEND_STMT to "( "
81643>>>>>>>>>>>>>    For iParam from 1 to iNumpar
81649>>>>>>>>>>>>>>
81649>>>>>>>>>>>>>        DO_PASS_ARGUMENTS iParam
81681>>>>>>>>>>>>>    Loop
81682>>>>>>>>>>>>>>
81682>>>>>>>>>>>>>    SQL_APPEND_STMT to  " ); END;"
81690>>>>>>>>>>>>>    SQL_PREPARE_STMT
81702>>>>>>>>>>>>> End_Procedure
81703>>>>>>>>>>>>>
81703>>>>>>>>>>>>>Procedure MertechInc_SQL_SET_MYPROCEDURE_NAME Global String strProcName Integer iNumpar
81705>>>>>>>>>>>>>    Local Integer iParam
81705>>>>>>>>>>>>>
81705>>>>>>>>>>>>>    Move 0 to MertechInc_iParamCount           //Redundant, but left in incase called
81706>>>>>>>>>>>>>    INDICATE ERR False                  //directly and not via SQL_SET_PROCEDURE_NAME
81707>>>>>>>>>>>>>    Move MySQLFlex to MertechInc_DriverName    //
81708>>>>>>>>>>>>>
81708>>>>>>>>>>>>>    SQL_SET_STMT to "CALL "
81716>>>>>>>>>>>>>    SQL_APPEND_STMT to strProcName
81724>>>>>>>>>>>>>    SQL_APPEND_STMT to "("
81732>>>>>>>>>>>>>    For iParam from 1 to iNumpar
81738>>>>>>>>>>>>>>
81738>>>>>>>>>>>>>        DO_PASS_ARGUMENTS iParam
81770>>>>>>>>>>>>>    Loop
81771>>>>>>>>>>>>>>
81771>>>>>>>>>>>>>    SQL_APPEND_STMT to ")"
81779>>>>>>>>>>>>>    SQL_PREPARE_STMT
81791>>>>>>>>>>>>>End_Procedure
81792>>>>>>>>>>>>>
81792>>>>>>>>>>>>>Procedure MertechInc_SQL_SET_MSPROCEDURE_NAME Global String strProcName Integer iNumpar
81794>>>>>>>>>>>>>    local Integer iParam
81794>>>>>>>>>>>>>    local String  sParam
81794>>>>>>>>>>>>>
81794>>>>>>>>>>>>>    Move SQLFlex to MertechInc_DriverName
81795>>>>>>>>>>>>>
81795>>>>>>>>>>>>>    // This calling syntax is referred to as the "ODBC CALL escape sequence".  This syntax is
81795>>>>>>>>>>>>>    // advised over the execute command since CALL allows for the retrieval of the return codes
81795>>>>>>>>>>>>>    // from the call.
81795>>>>>>>>>>>>>    SQL_SET_STMT to "{? = CALL "
81803>>>>>>>>>>>>>    SQL_APPEND_STMT to strProcName
81811>>>>>>>>>>>>>
81811>>>>>>>>>>>>>    // Note that DO_PASS_ARGUMENTS can add the open paren for us, but only if the keyword "PASSING"
81811>>>>>>>>>>>>>    // is passed to it first time through.  This is a bit weird, so we ignore that and just add
81811>>>>>>>>>>>>>    // the open and close parens ourself to make things more clear.
81811>>>>>>>>>>>>>    If (iNumpar > 0) SQL_APPEND_STMT to " ("
81821>>>>>>>>>>>>>
81821>>>>>>>>>>>>>    For iParam from 1 to iNumpar
81827>>>>>>>>>>>>>>
81827>>>>>>>>>>>>>        DO_PASS_ARGUMENTS iParam
81859>>>>>>>>>>>>>    Loop
81860>>>>>>>>>>>>>>
81860>>>>>>>>>>>>>
81860>>>>>>>>>>>>>    If (iNumpar > 0) SQL_APPEND_STMT to ")"
81870>>>>>>>>>>>>>    SQL_APPEND_STMT to  " };"
81878>>>>>>>>>>>>>
81878>>>>>>>>>>>>>    SQL_PREPARE_STMT
81890>>>>>>>>>>>>>
81890>>>>>>>>>>>>>    // This bind parameter is for the "{? = " which is technically the first parameter even though
81890>>>>>>>>>>>>>    // it is the return value.  The driver will bind MertechInc_iWork to it.
81890>>>>>>>>>>>>>    DO_BIND_PARAMETERS MertechInc_iWork
81913>>>>>>>>>>>>>End_Procedure
81914>>>>>>>>>>>>>
81914>>>>>>>>>>>>>Procedure MertechInc_SQL_SET_PGPROCEDURE_NAME Global String strProcName Integer iNumpar
81916>>>>>>>>>>>>>    local Integer iParam
81916>>>>>>>>>>>>>    local String  sParam
81916>>>>>>>>>>>>>
81916>>>>>>>>>>>>>    Move PgFlex to MertechInc_DriverName
81917>>>>>>>>>>>>>
81917>>>>>>>>>>>>>    // For Postgres, you can call a function just by passing the function name and
81917>>>>>>>>>>>>>    // open/close parens
81917>>>>>>>>>>>>>    SQL_SET_STMT to strProcName
81925>>>>>>>>>>>>>
81925>>>>>>>>>>>>>    // Note that DO_PASS_ARGUMENTS can add the open paren for us, but only if the keyword "PASSING"
81925>>>>>>>>>>>>>    // is passed to it first time through.  This is a bit weird, so we ignore that and just add
81925>>>>>>>>>>>>>    // the open and close parens ourself to make things more clear.
81925>>>>>>>>>>>>>    SQL_APPEND_STMT to "( "
81933>>>>>>>>>>>>>
81933>>>>>>>>>>>>>    For iParam from 1 to iNumpar
81939>>>>>>>>>>>>>>
81939>>>>>>>>>>>>>        DO_PASS_ARGUMENTS iParam
81971>>>>>>>>>>>>>    Loop
81972>>>>>>>>>>>>>>
81972>>>>>>>>>>>>>
81972>>>>>>>>>>>>>    SQL_APPEND_STMT to ")"
81980>>>>>>>>>>>>>
81980>>>>>>>>>>>>>    SQL_PREPARE_STMT
81992>>>>>>>>>>>>>    // Indicate that a stored function will be executed - Query = 0, Procedure = 1, Function = 2
81992>>>>>>>>>>>>>    Call_Driver 0 MertechInc_DriverName Function CALLDRV_EMBEDDED_SQL_TYPE CALLBACK 0 PASSING MertechInc_Blank MertechInc_Blank 1 RESULT MertechInc_iRet
81997>>>>>>>>>>>>>End_Procedure
81998>>>>>>>>>>>>>
81998>>>>>>>>>>>>>//=============================================================================
81998>>>>>>>>>>>>>/// @Name        SQL_GET_STMT
81998>>>>>>>>>>>>>/// @Description This command returns the last embedded SQL statement that
81998>>>>>>>>>>>>>/// was executed into a string. Optional parameters can be passed to specify
81998>>>>>>>>>>>>>/// what character to start the string at and also the maximum number of
81998>>>>>>>>>>>>>/// characters to allow for the string.
81998>>>>>>>>>>>>>///
81998>>>>>>>>>>>>>/// @Assumptions
81998>>>>>>>>>>>>>/// @Status      Public
81998>>>>>>>>>>>>>/// @Drivers     All
81998>>>>>>>>>>>>>/// @VersionNote Last Revised: 2013-09-24 by Aaron Gulack
81998>>>>>>>>>>>>>/// @See                 SQL_GET_STATEMENT
81998>>>>>>>>>>>>>///
81998>>>>>>>>>>>>>/// @Syntax SQL_GET_STMT to {variable} [{max} {start}]
81998>>>>>>>>>>>>>/// @Param variable                     SQL statement to be executed
81998>>>>>>>>>>>>>/// @Param max                          Indicates the maximum number of characters to get (optional)
81998>>>>>>>>>>>>>/// @Param start                        Indicates what character to start at for the returned string (optional)
81998>>>>>>>>>>>>>///
81998>>>>>>>>>>>>>/// @Example
81998>>>>>>>>>>>>>/// SQL_SET_STMT to "SELECT * FROM CUSTOMER WHERE STATUS = 'Active' "
81998>>>>>>>>>>>>>/// SQL_PREPARE_STMT
81998>>>>>>>>>>>>>/// SQL_EXECUTE_STMT
81998>>>>>>>>>>>>>/// SQL_FETCH_NEXT_ROW into sFirstName sLastName
81998>>>>>>>>>>>>>/// If (Found) Begin
81998>>>>>>>>>>>>>///     Showln sFirstName
81998>>>>>>>>>>>>>///     Showln sLastName
81998>>>>>>>>>>>>>/// End
81998>>>>>>>>>>>>>///
81998>>>>>>>>>>>>>/// SQL_GET_STATEMENT to sValue
81998>>>>>>>>>>>>>/// Showln sValue
81998>>>>>>>>>>>>>
81998>>>>>>>>>>>>>
81998>>>>>>>>>>>>>Function MertechInc_SQL_GET_STATEMENT Global Integer iLength Integer iStart Returns String
82000>>>>>>>>>>>>>    Local String sStatement
82000>>>>>>>>>>>>>
82000>>>>>>>>>>>>>    DO_GETFILENUMBER_DRIVERNAME 0
82002>>>>>>>>>>>>>
82002>>>>>>>>>>>>>    If (MertechInc_FileNumber <> -1) Begin
82004>>>>>>>>>>>>>        Get MertechInc_Pre_Size_String 0 to sStatement
82005>>>>>>>>>>>>>        Call_Driver 0 MertechInc_DriverName Function CALLDRV_GET_SQL_STMT CALLBACK 0 PASSING sStatement iStart iLength RESULT MertechInc_iRet
82010>>>>>>>>>>>>>    End
82010>>>>>>>>>>>>>>
82010>>>>>>>>>>>>>    Function_Return sStatement
82011>>>>>>>>>>>>>End_Function
82012>>>>>>>>>>>>>
82012>>>>>>>>>>>>>//=============================================================================
82012>>>>>>>>>>>>>/// @Name        SQL_SET_FUNCTION_NAME
82012>>>>>>>>>>>>>/// @Description This command is used in the same way as SQL_SET_PROCEDURE_NAME
82012>>>>>>>>>>>>>/// and SQL_SET_STMT to set the name of the function to be executed. When
82012>>>>>>>>>>>>>/// calling SQL functions in this fashion, this command must be used along with
82012>>>>>>>>>>>>>/// SQL_FUNCTION_EXECUTE (to execute the function), SQL_SET_FUNCTION_PARAMETER
82012>>>>>>>>>>>>>/// (to set the needed parameters) and SQL_GET_FUNCTION_RETURN (to get any
82012>>>>>>>>>>>>>/// returned value). The number of parameters must be set using the constant,
82012>>>>>>>>>>>>>/// NUMPAR, followed by the number of parameters. Note that when setting the
82012>>>>>>>>>>>>>/// name of the function, the user can be specified or, if left blank, the
82012>>>>>>>>>>>>>/// current user will be inserted before the function name.
82012>>>>>>>>>>>>>///
82012>>>>>>>>>>>>>/// @Assumptions
82012>>>>>>>>>>>>>/// @Status      Public
82012>>>>>>>>>>>>>/// @Drivers     All
82012>>>>>>>>>>>>>/// @VersionNote Last Revised: 2013-10-01 by Aaron Gulack
82012>>>>>>>>>>>>>/// @See                 SQL_FUNCTION_EXECUTE SQL_SET_FUNCTION_PARAMETER SQL_GET_FUNCTION_RETURN
82012>>>>>>>>>>>>>///
82012>>>>>>>>>>>>>/// @Syntax SQL_SET_FUNCTION_NAME {function} NUMPAR {parameters}
82012>>>>>>>>>>>>>/// @Param function                     Full name of the function
82012>>>>>>>>>>>>>/// @Param parameters           Number of parameters to pass
82012>>>>>>>>>>>>>///
82012>>>>>>>>>>>>>/// @Example
82012>>>>>>>>>>>>>/// SQL_SET_FUNCTION_NAME "getCustomerStatus" NUMPAR 1
82012>>>>>>>>>>>>>/// SQL_SET_FUNCTION_PARAMETER 1 to 'Jones' IN
82012>>>>>>>>>>>>>/// SQL_FUNCTION_EXECUTE
82012>>>>>>>>>>>>>/// SQL_GET_FUNCTION_RETURN to dDOB
82012>>>>>>>>>>>>>/// Showln dDOB
82012>>>>>>>>>>>>>
82012>>>>>>>>>>>>>Procedure MertechInc_SQL_SET_ORAFUNCTION_NAME Global String strProcName Integer iNumpar
82014>>>>>>>>>>>>>    Local Integer iParam
82014>>>>>>>>>>>>>
82014>>>>>>>>>>>>>    SQL_SET_STMT to "BEGIN "
82022>>>>>>>>>>>>>    SQL_APPEND_STMT to ":PAR_RET := "
82030>>>>>>>>>>>>>    SQL_APPEND_STMT to strProcName
82038>>>>>>>>>>>>>    SQL_APPEND_STMT to "( "
82046>>>>>>>>>>>>>    For iParam from 1 to iNumpar
82052>>>>>>>>>>>>>>
82052>>>>>>>>>>>>>        DO_PASS_ARGUMENTS iParam
82084>>>>>>>>>>>>>    Loop
82085>>>>>>>>>>>>>>
82085>>>>>>>>>>>>>    SQL_APPEND_STMT to  " ); END;"
82093>>>>>>>>>>>>>    SQL_PREPARE_STMT
82105>>>>>>>>>>>>>
82105>>>>>>>>>>>>>    Move IS_OUT to MertechInc_iArg
82106>>>>>>>>>>>>>    Call_Driver 0 ORAFLEX Function CALLDRV_SET_PROC_ATTRIBUTE_TYPE CALLBACK 0 PASSING MertechInc_Blank MertechInc_Blank MertechInc_iArg RESULT MertechInc_iRet
82111>>>>>>>>>>>>>
82111>>>>>>>>>>>>>    Increment MertechInc_iParamCount
82112>>>>>>>>>>>>>    Move ":PAR_RET" to MertechInc_sArg2
82113>>>>>>>>>>>>>    Call_Driver 0 MertechInc_DriverName Function CALLDRV_BIND_PARAMETER CALLBACK 0 PASSING MertechInc_Blank MertechInc_sArg2 16384 RESULT MertechInc_iRet
82118>>>>>>>>>>>>>End_Procedure
82119>>>>>>>>>>>>>
82119>>>>>>>>>>>>>Procedure MertechInc_SQL_SET_MYFUNCTION_NAME Global String strProcName Integer iNumpar
82121>>>>>>>>>>>>>    Local Integer iParam
82121>>>>>>>>>>>>>
82121>>>>>>>>>>>>>    Move MySQLFlex to MertechInc_DriverName
82122>>>>>>>>>>>>>
82122>>>>>>>>>>>>>    SQL_SET_STMT to "SELECT "
82130>>>>>>>>>>>>>    SQL_APPEND_STMT to strProcName
82138>>>>>>>>>>>>>    SQL_APPEND_STMT to "("
82146>>>>>>>>>>>>>    For iParam from 1 to iNumpar
82152>>>>>>>>>>>>>>
82152>>>>>>>>>>>>>        DO_PASS_ARGUMENTS iParam
82184>>>>>>>>>>>>>    Loop
82185>>>>>>>>>>>>>>
82185>>>>>>>>>>>>>    SQL_APPEND_STMT to ")"
82193>>>>>>>>>>>>>    SQL_PREPARE_STMT
82205>>>>>>>>>>>>>End_Procedure
82206>>>>>>>>>>>>>
82206>>>>>>>>>>>>>Procedure MertechInc_SQL_SET_SQLFUNCTION_NAME Global String strProcName Integer iNumpar
82208>>>>>>>>>>>>>    Local Integer iParam
82208>>>>>>>>>>>>>
82208>>>>>>>>>>>>>    Move SQLFlex to MertechInc_DriverName
82209>>>>>>>>>>>>>
82209>>>>>>>>>>>>>    If (not(strProcName contains ".")) Begin
82211>>>>>>>>>>>>>        String schema
82211>>>>>>>>>>>>>        GET_SCHEMA_NAME to schema
82233>>>>>>>>>>>>>        Move (schema + "." + strProcName) to strProcName
82234>>>>>>>>>>>>>    End
82234>>>>>>>>>>>>>>
82234>>>>>>>>>>>>>
82234>>>>>>>>>>>>>    SQL_SET_STMT    to "SELECT "
82242>>>>>>>>>>>>>    SQL_APPEND_STMT to strProcName
82250>>>>>>>>>>>>>    SQL_APPEND_STMT to "("
82258>>>>>>>>>>>>>End_Procedure
82259>>>>>>>>>>>>>
82259>>>>>>>>>>>>>Procedure MertechInc_SQL_SET_PGFUNCTION_NAME Global String strProcName Integer iNumpar
82261>>>>>>>>>>>>>    Local Integer iParam
82261>>>>>>>>>>>>>
82261>>>>>>>>>>>>>    Move PgFlex to MertechInc_DriverName
82262>>>>>>>>>>>>>
82262>>>>>>>>>>>>>    SQL_SET_STMT    to "SELECT "
82270>>>>>>>>>>>>>    SQL_APPEND_STMT to strProcName
82278>>>>>>>>>>>>>    SQL_APPEND_STMT to "("
82286>>>>>>>>>>>>>End_Procedure
82287>>>>>>>>>>>>>
82287>>>>>>>>>>>>>//=============================================================================
82287>>>>>>>>>>>>>/// @Name        SQL_SET_PROCEDURE_PARAMETER
82287>>>>>>>>>>>>>/// @Description
82287>>>>>>>>>>>>>/// With this command you can pass one or more parameters to predefined
82287>>>>>>>>>>>>>/// stored procedures on a MySQL or Oracle server. The SQL_SET_PROCEDURE_PARAMETER
82287>>>>>>>>>>>>>/// command enables you to add a parameter to a stored procedure which you are
82287>>>>>>>>>>>>>/// planning to call. You can pass multiple parameters by calling the command
82287>>>>>>>>>>>>>/// for each parameter.
82287>>>>>>>>>>>>>///
82287>>>>>>>>>>>>>/// When passing parameters you'll have to inform the driver which variable
82287>>>>>>>>>>>>>/// you are passing, starting with 1 from left-to-right in the parameter list.
82287>>>>>>>>>>>>>///
82287>>>>>>>>>>>>>/// For each parameter you'll have to indicate if the variable is to be
82287>>>>>>>>>>>>>/// regarded as input, output or both.
82287>>>>>>>>>>>>>///
82287>>>>>>>>>>>>>///@Assumptions
82287>>>>>>>>>>>>>/// @Status      Public
82287>>>>>>>>>>>>>/// @Drivers     All
82287>>>>>>>>>>>>>/// @VersionNote Last Revised: 2013-09-27 by Aaron Gulack
82287>>>>>>>>>>>>>/// @See                 SQL_SET_PROCEDURE_NAME SQL_PROCEDURE_EXECUTE
82287>>>>>>>>>>>>>///
82287>>>>>>>>>>>>>/// @Syntax SQL_SET_PROCEDURE_PARAMETER {number} to {variable} {direction}
82287>>>>>>>>>>>>>/// @Param number                       Index number of the parameter being defined.
82287>>>>>>>>>>>>>/// @Param variable                     Variable holding the parameter to be passed.
82287>>>>>>>>>>>>>/// @Param direction            IN, OUT, IN_OUT, RSET, or leave blank
82287>>>>>>>>>>>>>///
82287>>>>>>>>>>>>>/// @Example
82287>>>>>>>>>>>>>/// SQL_SET_PROCEDURE_NAME "sys.sp_addmessage" NUMPAR 3
82287>>>>>>>>>>>>>/// SQL_SET_PROCEDURE_PARAMETER 1 to 500004 IN
82287>>>>>>>>>>>>>/// SQL_SET_PROCEDURE_PARAMETER 2 to 15 IN
82287>>>>>>>>>>>>>/// SQL_SET_PROCEDURE_PARAMETER 3 to "Please enter a valid Date" IN
82287>>>>>>>>>>>>>/// SQL_PROCEDURE_EXECUTE
82287>>>>>>>>>>>>>
82287>>>>>>>>>>>>>
82287>>>>>>>>>>>>>
82287>>>>>>>>>>>>>//=============================================================================
82287>>>>>>>>>>>>>/// @Name        SQL_GET_PROCEDURE_PARAMETER
82287>>>>>>>>>>>>>/// @Description This command is used to get the value of a specific
82287>>>>>>>>>>>>>/// parameter associated with a stored procedure.  Although this
82287>>>>>>>>>>>>>/// command will work with any parameter, it is mostly be used with
82287>>>>>>>>>>>>>/// IN/OUT or OUT parameters as their value will more often be important
82287>>>>>>>>>>>>>/// once returned. When multiple values are returned, this command can be
82287>>>>>>>>>>>>>/// more efficient than other options. Note that the specified parameter
82287>>>>>>>>>>>>>/// must first be defined using the SQL_SET_PROCEDURE_PARAMETER command
82287>>>>>>>>>>>>>/// in order to work properly.
82287>>>>>>>>>>>>>///
82287>>>>>>>>>>>>>/// @Assumptions
82287>>>>>>>>>>>>>/// @Status      Public
82287>>>>>>>>>>>>>/// @Drivers     All
82287>>>>>>>>>>>>>/// @VersionNote Last Revised: 2013-10-02 by Aaron Gulack
82287>>>>>>>>>>>>>/// @See                 SQL_SET_PROCEDURE_NAME SQL_SET_PROCEDURE_PARAMETER SQL_PROCEDURE_EXECUTE
82287>>>>>>>>>>>>>///
82287>>>>>>>>>>>>>/// @Syntax SQL_GET_PROCEDURE_PARAMETER {parameter} to {variable}
82287>>>>>>>>>>>>>/// @Param parameter            Number of paramater to return
82287>>>>>>>>>>>>>/// @Param variable                     Variable to hold the value of the parameter
82287>>>>>>>>>>>>>///
82287>>>>>>>>>>>>>/// @Example
82287>>>>>>>>>>>>>/// SQL_SET_PROCEDURE_NAME "user.getCustomerStatus" NUMPAR 1
82287>>>>>>>>>>>>>/// SQL_SET_PROCEDURE_PARAMETER 1 to sCustomerID IN_OUT
82287>>>>>>>>>>>>>/// SQL_PROCEDURE_EXECUTE
82287>>>>>>>>>>>>>/// SQL_GET_PROCEDURE_PARAMETER 1 to sStatus
82287>>>>>>>>>>>>>///
82287>>>>>>>>>>>>>/// Showln sStatus
82287>>>>>>>>>>>>>///
82287>>>>>>>>>>>>>/// @Example
82287>>>>>>>>>>>>>/// SQL_SET_PROCEDURE_NAME "user.getCustomerStatus" NUMPAR 2
82287>>>>>>>>>>>>>/// SQL_SET_PROCEDURE_PARAMETER 1 to sCustomerID IN
82287>>>>>>>>>>>>>/// SQL_SET_PROCEDURE_PARAMETER 2 to sStatus OUT
82287>>>>>>>>>>>>>/// SQL_PROCEDURE_EXECUTE
82287>>>>>>>>>>>>>/// SQL_GET_PROCEDURE_PARAMETER 2 to sStatus
82287>>>>>>>>>>>>>///
82287>>>>>>>>>>>>>/// Showln sStatus
82287>>>>>>>>>>>>>
82287>>>>>>>>>>>>>
82287>>>>>>>>>>>>>
82287>>>>>>>>>>>>>//=============================================================================
82287>>>>>>>>>>>>>/// @Name        SQL_GET_FUNCTION_RETURN
82287>>>>>>>>>>>>>/// @Description This variable is used to get the value returned from a SQL
82287>>>>>>>>>>>>>/// function call. After the function has been successfully called, this
82287>>>>>>>>>>>>>/// command takes the returned value and inserts it the given variable.
82287>>>>>>>>>>>>>///
82287>>>>>>>>>>>>>/// @Assumptions
82287>>>>>>>>>>>>>/// @Status      Public
82287>>>>>>>>>>>>>/// @Drivers     All
82287>>>>>>>>>>>>>/// @VersionNote Last Revised: 2013-10-01 by Aaron Gulack
82287>>>>>>>>>>>>>/// @See                 SQL_SET_FUNCTION_NAME SQL_SET_FUNCTION_PARAMETER SQL_FUNCTION_EXECUTE
82287>>>>>>>>>>>>>///
82287>>>>>>>>>>>>>/// @Syntax SQL_GET_FUNCTION_RETURN to {variable}
82287>>>>>>>>>>>>>/// @Param variable                     Variable to hold the returned value
82287>>>>>>>>>>>>>///
82287>>>>>>>>>>>>>/// @Example
82287>>>>>>>>>>>>>/// SQL_SET_FUNCTION_NAME "getCustomerStatus" NUMPAR 1
82287>>>>>>>>>>>>>/// SQL_SET_FUNCTION_PARAMETER 1 to 'Jones' IN
82287>>>>>>>>>>>>>/// SQL_FUNCTION_EXECUTE
82287>>>>>>>>>>>>>/// SQL_GET_FUNCTION_RETURN to dDOB
82287>>>>>>>>>>>>>/// Showln dDOB
82287>>>>>>>>>>>>>
82287>>>>>>>>>>>>>//=============================================================================
82287>>>>>>>>>>>>>/// @Name        SQL_FUNCTION_EXECUTE
82287>>>>>>>>>>>>>/// @Description This command is used to execute the function statement
82287>>>>>>>>>>>>>/// that was built by the SQL_SET_FUNCTION_NAME and subsequent
82287>>>>>>>>>>>>>/// SQL_SET_FUNCTION_PARAMETER commands. This works similarly to the
82287>>>>>>>>>>>>>/// SQL_EXECUTE_STMT command. Note that executing the function with this
82287>>>>>>>>>>>>>/// command will not get any returned values but will simply execute the
82287>>>>>>>>>>>>>/// function.
82287>>>>>>>>>>>>>///
82287>>>>>>>>>>>>>/// @Assumptions
82287>>>>>>>>>>>>>/// @Status      Public
82287>>>>>>>>>>>>>/// @Drivers     All
82287>>>>>>>>>>>>>/// @VersionNote Last Revised: 2013-10-01 by Aaron Gulack
82287>>>>>>>>>>>>>/// @See                 SQL_SET_FUNCTION_NAME SQL_SET_FUNCTION_PARAMETER SQL_GET_FUNCTION_RETURN
82287>>>>>>>>>>>>>///
82287>>>>>>>>>>>>>/// @Syntax SQL_FUNCTION_EXECUTE
82287>>>>>>>>>>>>>///
82287>>>>>>>>>>>>>/// @Example
82287>>>>>>>>>>>>>/// SQL_SET_FUNCTION_NAME "getCustomerStatus" NUMPAR 1
82287>>>>>>>>>>>>>/// SQL_SET_FUNCTION_PARAMETER 1 to 'Jones' IN
82287>>>>>>>>>>>>>/// SQL_FUNCTION_EXECUTE
82287>>>>>>>>>>>>>/// SQL_GET_FUNCTION_RETURN to dDOB
82287>>>>>>>>>>>>>/// Showln dDOB
82287>>>>>>>>>>>>>
82287>>>>>>>>>>>>>Procedure MertechInc_SQL_FUNCTION_EXECUTE Global String sDriverName
82289>>>>>>>>>>>>>    Local Integer iParam
82289>>>>>>>>>>>>>    Local String  sParam
82289>>>>>>>>>>>>>
82289>>>>>>>>>>>>>    If (sDriverName = SQLFLEX or sDriverName = PgFlex) Begin
82291>>>>>>>>>>>>>       SQL_APPEND_STMT to ')'
82299>>>>>>>>>>>>>       SQL_PREPARE_STMT
82311>>>>>>>>>>>>>    End
82311>>>>>>>>>>>>>>
82311>>>>>>>>>>>>>
82311>>>>>>>>>>>>>    SQL_EXECUTE_STMT
82326>>>>>>>>>>>>>    If (sDriverName <> ORAFLEX) Begin
82328>>>>>>>>>>>>>        SQL_FETCH_NEXT_ROW
82343>>>>>>>>>>>>>>
82343>>>>>>>>>>>>>    End
82343>>>>>>>>>>>>>>
82343>>>>>>>>>>>>>End_Procedure
82344>>>>>>>>>>>>>
82344>>>>>>>>>>>>>//=============================================================================
82344>>>>>>>>>>>>>/// @Name        REEXEC_ORACLE_STORED_PROCEDURE
82344>>>>>>>>>>>>>/// @Description This command is used to re-execute a stored procedure
82344>>>>>>>>>>>>>/// when using Oracle. Although it follows the same format as
82344>>>>>>>>>>>>>/// CALL_STORED_PROCEDURE, it can be useful because it does not need to
82344>>>>>>>>>>>>>/// prepare the procedure again before executing. This can cause speed
82344>>>>>>>>>>>>>/// improvements when calling a stored procedure multiple times.
82344>>>>>>>>>>>>>///
82344>>>>>>>>>>>>>/// @Assumptions A procedure has already been created through CALL_STORED_PROCEDURE
82344>>>>>>>>>>>>>/// @Status      Public
82344>>>>>>>>>>>>>/// @Drivers     ORAFLex
82344>>>>>>>>>>>>>/// @VersionNote Last Revised: 2013-10-04 by Aaron Gulack
82344>>>>>>>>>>>>>/// @See                 CALL_STORED_PROCEDURE
82344>>>>>>>>>>>>>///
82344>>>>>>>>>>>>>/// @Syntax CALL_ORACLE_STORED_PROCEDURE {procedure} Passing {variable}
82344>>>>>>>>>>>>>/// @Param procedure            Full name of the procedure
82344>>>>>>>>>>>>>/// @Param variable                     Parameter to pass (optional and can be multiple)
82344>>>>>>>>>>>>>///
82344>>>>>>>>>>>>>/// @Example
82344>>>>>>>>>>>>>/// CALL_STORED_PROCEDURE "user.getCustomerStatus" Passing sCustomerID sStatus
82344>>>>>>>>>>>>>/// Showln sStatus
82344>>>>>>>>>>>>>///
82344>>>>>>>>>>>>>/// Move (sCustomerID + 1) to sCustomerID
82344>>>>>>>>>>>>>///
82344>>>>>>>>>>>>>/// REEXEC_ORACLE_STORED_PROCEDURE "user.getCustomerStatus" passing sCustomerID sStatus
82344>>>>>>>>>>>>>/// Showln sStatus
82344>>>>>>>>>>>>>
82344>>>>>>>>>>>>>
82344>>>>>>>>>>>>>//=============================================================================
82344>>>>>>>>>>>>>/// @Name        CALL_STORED_FUNCTION
82344>>>>>>>>>>>>>/// @Description This command is used to execute a function stored in the
82344>>>>>>>>>>>>>/// SQL backend. This is an alternative to building a function with the
82344>>>>>>>>>>>>>/// SQL_SET_FUNCTION_NAME, SQL_SET_FUNCTION_PARAMETER and SQL_FUNCTION_EXECUTE
82344>>>>>>>>>>>>>/// commands. This command builds and executes the function by setting the full
82344>>>>>>>>>>>>>/// function name, the parameter(s) to pass and the variable to hold the
82344>>>>>>>>>>>>>/// returned value. Note that this command can only return a single value
82344>>>>>>>>>>>>>/// so SQL_SET_FUNCTION_PARAMETER and SQL_SET_FUNCTION_NAME must be used when
82344>>>>>>>>>>>>>/// dealing with multiple return values.
82344>>>>>>>>>>>>>///
82344>>>>>>>>>>>>>/// Assumptions
82344>>>>>>>>>>>>>/// @Status      Public
82344>>>>>>>>>>>>>/// @Drivers     ORAFLex MySQLFlex PgFlex
82344>>>>>>>>>>>>>/// @VersionNote Last Revised: 2013-10-01 by Aaron Gulack
82344>>>>>>>>>>>>>/// @See
82344>>>>>>>>>>>>>///
82344>>>>>>>>>>>>>/// @Syntax CALL_STORED_FUNCTION {function} Returns {variable} Passing {parameters}
82344>>>>>>>>>>>>>/// @Param function                     Full name of the function
82344>>>>>>>>>>>>>/// @Param variable                     Variable to hold the returned value
82344>>>>>>>>>>>>>/// @Param parameters           Parameter to pass to the function (can be multiple)
82344>>>>>>>>>>>>>///
82344>>>>>>>>>>>>>/// @Example
82344>>>>>>>>>>>>>/// Move 5 to sCustomerID
82344>>>>>>>>>>>>>/// CALL_STORED_FUNCTION "getCustomerStatus" Returns sStatus Passing sCustomerID
82344>>>>>>>>>>>>>/// Showln sStatus
82344>>>>>>>>>>>>>
82344>>>>>>>>>>>>>//=============================================================================
82344>>>>>>>>>>>>>/// @Name        OUTPUT_INT_FILE
82344>>>>>>>>>>>>>/// @Description This command is used to output the int file of an opened
82344>>>>>>>>>>>>>/// table. If the file to be output to does not exist, it will be created
82344>>>>>>>>>>>>>/// upon execution of this command. Note that the INT file can be output
82344>>>>>>>>>>>>>/// into multiple types of files i.e. .doc, .txt, .int.
82344>>>>>>>>>>>>>///
82344>>>>>>>>>>>>>/// @Assumptions
82344>>>>>>>>>>>>>/// @Status      Public
82344>>>>>>>>>>>>>/// @Drivers     All
82344>>>>>>>>>>>>>/// @VersionNote Last Revised: 2013-10-01 by Aaron Gulack
82344>>>>>>>>>>>>>/// @See
82344>>>>>>>>>>>>>///
82344>>>>>>>>>>>>>/// @Syntax OUTPUT_INT_FILE for {FileNumber} to {variable}
82344>>>>>>>>>>>>>/// @Param FileNumber           The file number
82344>>>>>>>>>>>>>/// @Param variable                     Path of the file being output to
82344>>>>>>>>>>>>>///
82344>>>>>>>>>>>>>///@Example
82344>>>>>>>>>>>>>/// OUTPUT_INT_FILE for Customer.File_Number to "C:\Temp\Customer.int"
82344>>>>>>>>>>>>>
82344>>>>>>>>>>>>>//=============================================================================
82344>>>>>>>>>>>>>/// @Name        SQL_ERROR_MESSAGE
82344>>>>>>>>>>>>>/// @Description This command is used to get an error message
82344>>>>>>>>>>>>>/// from a given SQL statement. If the given statement is executed with
82344>>>>>>>>>>>>>/// no errors, the variable specified with this command will be blank.
82344>>>>>>>>>>>>>/// Otherwise the message will be stored in the given variable. Note that
82344>>>>>>>>>>>>>/// unless specified, strings have a size limit of 80 characters, so using
82344>>>>>>>>>>>>>/// a variant can ensure the full message is retrieved.
82344>>>>>>>>>>>>>///
82344>>>>>>>>>>>>>/// @Assumptions
82344>>>>>>>>>>>>>/// @Status      Public
82344>>>>>>>>>>>>>/// @Drivers     All
82344>>>>>>>>>>>>>/// @VersionNote Last Revised: 2013-10-01 by Aaron Gulack
82344>>>>>>>>>>>>>/// @See         SQL_ERROR_MESSAGE2
82344>>>>>>>>>>>>>///
82344>>>>>>>>>>>>>/// @Syntax SQL_ERROR_MESSAGE {variable}
82344>>>>>>>>>>>>>/// @Param variable                     Variable to hold the error message
82344>>>>>>>>>>>>>///
82344>>>>>>>>>>>>>/// @Example
82344>>>>>>>>>>>>>/// SQL_ERROR_MESSAGE sError
82344>>>>>>>>>>>>>
82344>>>>>>>>>>>>>Function MertechInc_SQL_ERROR_MESSAGE Global Returns String
82346>>>>>>>>>>>>>    Local String sMessage
82346>>>>>>>>>>>>>
82346>>>>>>>>>>>>>    Get MertechInc_Pre_Size_String 0 to sMessage
82347>>>>>>>>>>>>>    Call_Driver 0 MertechInc_DriverName Function CALLDRV_SQL_ERROR_MESSAGE CALLBACK 0 PASSING MertechInc_Blank sMessage 0 RESULT MertechInc_iRet
82352>>>>>>>>>>>>>
82352>>>>>>>>>>>>>    Function_Return sMessage
82353>>>>>>>>>>>>>End_Function
82354>>>>>>>>>>>>>
82354>>>>>>>>>>>>>//=============================================================================
82354>>>>>>>>>>>>>/// @Name        SQL_ERROR_MESSAGE2
82354>>>>>>>>>>>>>/// @Description This command is used to get the last error message used
82354>>>>>>>>>>>>>/// for the specified server. This can be useful once a transaction has
82354>>>>>>>>>>>>>/// already been completed and any error messages need to be retrieved.
82354>>>>>>>>>>>>>///
82354>>>>>>>>>>>>>/// @Assumptions
82354>>>>>>>>>>>>>/// @Status      Public
82354>>>>>>>>>>>>>/// @Drivers     All
82354>>>>>>>>>>>>>/// @VersionNote Last Revised: 2013-10-01 by Aaron Gulack
82354>>>>>>>>>>>>>/// @See         SQL_ERROR_MESSAGE SQL_ERROR_MESSAGE2
82354>>>>>>>>>>>>>///
82354>>>>>>>>>>>>>/// @Syntax SQL_ERROR_MESSAGE2 of {server} to {variable}
82354>>>>>>>>>>>>>/// @Param server                       Name of the server
82354>>>>>>>>>>>>>/// @Param variable                     Variable to hold the error message
82354>>>>>>>>>>>>>///
82354>>>>>>>>>>>>>/// @Example
82354>>>>>>>>>>>>>/// SQL_ERROR_MESSAGE2 of "localhost" to sError
82354>>>>>>>>>>>>>
82354>>>>>>>>>>>>>Function MertechInc_SQL_ERROR_MESSAGE2 Global String sServer Returns String
82356>>>>>>>>>>>>>    Local String sMessage
82356>>>>>>>>>>>>>
82356>>>>>>>>>>>>>    Get MertechInc_Pre_Size_String 800 to sMessage
82357>>>>>>>>>>>>>    Call_Driver 0 MertechInc_DriverName Function CALLDRV_SQL_ERROR_MESSAGE2 CALLBACK 0 PASSING sServer sMessage 0 RESULT MertechInc_iRet
82362>>>>>>>>>>>>>
82362>>>>>>>>>>>>>    Function_Return sMessage
82363>>>>>>>>>>>>>End_Function
82364>>>>>>>>>>>>>
82364>>>>>>>>>>>>>//=============================================================================
82364>>>>>>>>>>>>>/// @Name        MERTECH_WARNING_MESSAGE
82364>>>>>>>>>>>>>/// @Description When restructuring a table, i.e. Structure_Start, a warning
82364>>>>>>>>>>>>>/// message will appear to confirm the restructure before it is executed.
82364>>>>>>>>>>>>>/// This command is used to disable or enable that warning message. All that
82364>>>>>>>>>>>>>/// is passed is either the constant "Enabled" or "Disabled". By default,
82364>>>>>>>>>>>>>/// this message is enabled.
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Assumptions
82364>>>>>>>>>>>>>/// @Status      Public
82364>>>>>>>>>>>>>/// @Drivers     All
82364>>>>>>>>>>>>>/// @VersionNote Last Revised: 2013-10-01 by Aaron Gulack
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Syntax MERTECH_WARNING_MESSAGE {Enabled|Disabled}
82364>>>>>>>>>>>>>/// @Param Enabled                      Enables the restructure warning
82364>>>>>>>>>>>>>/// @Param Disabled                     Disables the restructure warning
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Example
82364>>>>>>>>>>>>>/// Move Customer.File_Number to hFile
82364>>>>>>>>>>>>>/// MERTECH_WARNING_MESSAGE Disabled
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// Structure_Start hFile
82364>>>>>>>>>>>>>///     Set_Attribute DF_FILE_OEM_TRANSLATION of hFile to True
82364>>>>>>>>>>>>>/// Structure_End hFile
82364>>>>>>>>>>>>>
82364>>>>>>>>>>>>>//=============================================================================
82364>>>>>>>>>>>>>/// @Name        DISABLE_SELECT_COLUMNS_ERRORS
82364>>>>>>>>>>>>>/// @Description When using SELECT_COLUMNS_FIND to limit the number of columns
82364>>>>>>>>>>>>>/// to fetch, the framework might still ask for columns that you do not need.
82364>>>>>>>>>>>>>/// As a result you'll end up getting runtime errors you do not want to see.
82364>>>>>>>>>>>>>/// This command gives you the ability to stop reporting errors for querying
82364>>>>>>>>>>>>>/// for data from columns that are not part of the query.
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// DISABLED_SELECT_COLUMNS_ERRORS DISABLED will disable the errors, use
82364>>>>>>>>>>>>>/// ENABLED to turn the error messages back on.
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// By default triggering error messages on unknown columns is ENABLED
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Assumptions
82364>>>>>>>>>>>>>/// @Status      Public
82364>>>>>>>>>>>>>/// @Drivers     All
82364>>>>>>>>>>>>>/// @VersionNote Last Revised: 2014-04-28 by Wil van Antwerpen
82364>>>>>>>>>>>>>/// @See         SELECT_COLUMNS_FIND RESET_FETCH_FIELDS
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Example
82364>>>>>>>>>>>>>/// Open Customer
82364>>>>>>>>>>>>>/// RESET_FETCH_FIELDS  CUSTOMER DF_FETCH_FALSE
82364>>>>>>>>>>>>>/// SELECT_COLUMNS_FIND CUSTOMER CUSTOMER_NUMBER NAME
82364>>>>>>>>>>>>>/// DISABLE_SELECT_COLUMNS_ERRORS DISABLED
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// Clear Customer
82364>>>>>>>>>>>>>/// Repeat
82364>>>>>>>>>>>>>///    Find Gt Customer by Index.1
82364>>>>>>>>>>>>>///    If (Found) Showln Customer.Customer_Number '-' Customer.Name
82364>>>>>>>>>>>>>/// Until (Not(Found))
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// RESET_FETCH_FIELDS Customer DF_FETCH_TRUE
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Syntax DISABLE_SELECT_COLUMNS_ERRORS {ENABLED|DISABLED}
82364>>>>>>>>>>>>>
82364>>>>>>>>>>>>>//=============================================================================
82364>>>>>>>>>>>>>/// @Name        SQLFlex_REVISION
82364>>>>>>>>>>>>>/// @Description This command will put the current version (decimals included)
82364>>>>>>>>>>>>>/// of the MSSQL driver associated with the current workspace into the
82364>>>>>>>>>>>>>/// specified variable.
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Assumptions
82364>>>>>>>>>>>>>/// @Status      Deprecated
82364>>>>>>>>>>>>>/// @Drivers     SQLFlex
82364>>>>>>>>>>>>>/// @VersionNote Last Revised: 2013-10-01 by Aaron Gulack
82364>>>>>>>>>>>>>/// @See                 GET_DRIVER_REVISION
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Syntax SQLFlex_REVISION {variable}
82364>>>>>>>>>>>>>/// @Param variable                     String variable to hold the returned version
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Example
82364>>>>>>>>>>>>>/// SQLFlex_REVISION sVersion
82364>>>>>>>>>>>>>
82364>>>>>>>>>>>>>//=============================================================================
82364>>>>>>>>>>>>>/// @Name        SQLFlex_MAJOR_REVISION
82364>>>>>>>>>>>>>/// @Description This command will put the major version (no decimals) of
82364>>>>>>>>>>>>>/// the the MSSQL driver associated with the current workspace into the
82364>>>>>>>>>>>>>/// specified variable.
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Assumptions
82364>>>>>>>>>>>>>/// @Status      Deprecated
82364>>>>>>>>>>>>>/// @Drivers     SQLFlex
82364>>>>>>>>>>>>>/// @VersionNote Last Revised: 2013-10-01 by Aaron Gulack
82364>>>>>>>>>>>>>/// @See                 GET_DRIVER_MAJOR_REVISION
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Syntax SQLFlex_MAJOR_REVISION {variable}
82364>>>>>>>>>>>>>/// @Param variable                     String variable to hold the returned version
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Example
82364>>>>>>>>>>>>>/// SQLFlex_MAJOR_REVISION sVersion
82364>>>>>>>>>>>>>
82364>>>>>>>>>>>>>//=============================================================================
82364>>>>>>>>>>>>>/// @Name        LOGGED_USERS
82364>>>>>>>>>>>>>/// @Description This command returns the number of native users that are
82364>>>>>>>>>>>>>/// using the driver currently. This number is stored in the variable that
82364>>>>>>>>>>>>>/// is passed with the command.
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Assumptions
82364>>>>>>>>>>>>>/// @Status      Public
82364>>>>>>>>>>>>>/// @Drivers     All
82364>>>>>>>>>>>>>/// @VersionNote Last Revised: 2013-10-01 by Aaron Gulack
82364>>>>>>>>>>>>>/// @See                 MAXIMUM_NUMBER_OF_USERS
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Syntax LOGGED_USERS {variable}
82364>>>>>>>>>>>>>/// @Param variable                     Variable to hold the number of users
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Example LOGGED_USERS sUsers
82364>>>>>>>>>>>>>
82364>>>>>>>>>>>>>//=============================================================================
82364>>>>>>>>>>>>>/// @Name        MAXIMUM_NUMBER_OF_USERS
82364>>>>>>>>>>>>>/// @Description This command returns the maximum number of user allowed by
82364>>>>>>>>>>>>>/// the current license.
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Assumptions
82364>>>>>>>>>>>>>/// @Status      Public
82364>>>>>>>>>>>>>/// @Drivers     All
82364>>>>>>>>>>>>>/// @VersionNote Last Revised: 2013-10-01 by Aaron Gulack
82364>>>>>>>>>>>>>/// @See                 LOGGED_USERS
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Syntax MAXIMUM_NUMBER_OF_USERS {variable}
82364>>>>>>>>>>>>>/// @Param variable                     Variable to hold the maximum number of users
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Example
82364>>>>>>>>>>>>>/// MAXIMUM_NUMBER_OF_USERS sMax
82364>>>>>>>>>>>>>
82364>>>>>>>>>>>>>//=============================================================================
82364>>>>>>>>>>>>>/// @Name        SET_DATABASE_NAME
82364>>>>>>>>>>>>>/// @Description This command overrides the database set in the INT file
82364>>>>>>>>>>>>>/// under DATABASE_SPACE_NAME. Any opens or finds will use the database
82364>>>>>>>>>>>>>/// specified here. This can be used when the database is not stated in
82364>>>>>>>>>>>>>/// the INT file or if the database needs to be dynamically changed for
82364>>>>>>>>>>>>>/// a certain query. If the database is not specified with this command
82364>>>>>>>>>>>>>/// or in the INT file, then the default database for the server will be
82364>>>>>>>>>>>>>/// used. To set the database to be used for embedded SQL statements,
82364>>>>>>>>>>>>>/// use SQL_USE_DATABASE.
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Assumptions
82364>>>>>>>>>>>>>/// @Status      Public
82364>>>>>>>>>>>>>/// @Drivers     SQLFlex, MySQLFlex and PGFlex
82364>>>>>>>>>>>>>/// @VersionNote Last Revised: 2013-10-09 by Aaron Gulack
82364>>>>>>>>>>>>>/// @See                 GET_DATABASE_NAME SQL_USE_DATABASE
82364>>>>>>>>>>>>>/// @INTOPT              DATABASE_SPACE_NAME
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Syntax SET_DATABASE_NAME to {database}
82364>>>>>>>>>>>>>/// @Param database                     Name of the database
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Example
82364>>>>>>>>>>>>>/// Login "localhost" "user" "pas123" "sql_drv"
82364>>>>>>>>>>>>>/// SET_DATABASE_NAME to "TestDB"
82364>>>>>>>>>>>>>/// Open Customer
82364>>>>>>>>>>>>>
82364>>>>>>>>>>>>>//=============================================================================
82364>>>>>>>>>>>>>/// @Name        GET_DATABASE_NAME
82364>>>>>>>>>>>>>/// @Description This command is used to get the name of the database
82364>>>>>>>>>>>>>/// currently being used. The name of the database is returned into the
82364>>>>>>>>>>>>>/// specified string. Even though this command works either way, it is
82364>>>>>>>>>>>>>/// typically used when the INT file does not contain the DATABASE_SPACE_NAME.
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Assumptions
82364>>>>>>>>>>>>>/// @Status      Public
82364>>>>>>>>>>>>>/// @Drivers     SQLFlex, MySQLFlex and PgFlex
82364>>>>>>>>>>>>>/// @VersionNote Last Revised: 2013-10-01 by Aaron Gulack
82364>>>>>>>>>>>>>/// @See SET_DATABASE_NAME SQL_USE_DATABASE
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Syntax GET_DATABASE_NAME to {variable}
82364>>>>>>>>>>>>>/// @Param variable                     Variable to hold the database name
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Example
82364>>>>>>>>>>>>>/// GET_DATABASE_NAME to sDbName
82364>>>>>>>>>>>>>
82364>>>>>>>>>>>>>//=============================================================================
82364>>>>>>>>>>>>>/// @Name        GET_NAME_SPACE
82364>>>>>>>>>>>>>/// @Description This command returns the name space, or schema, being
82364>>>>>>>>>>>>>/// used with the current application.
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Assumptions
82364>>>>>>>>>>>>>/// @Status      Public
82364>>>>>>>>>>>>>/// @Drivers     PgFlex
82364>>>>>>>>>>>>>/// @VersionNote Last Revised: 2013-10-01 by Aaron Gulack
82364>>>>>>>>>>>>>/// @See                 SET_NAME_SPACE
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Syntax GET_NAME_SPACE to {variable}
82364>>>>>>>>>>>>>/// @Param variable                     Variable to hold the returned name space.
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Example
82364>>>>>>>>>>>>>/// GET_NAME_SPACE to sNameSpace
82364>>>>>>>>>>>>>
82364>>>>>>>>>>>>>//=============================================================================
82364>>>>>>>>>>>>>/// @Name        SET_NAME_SPACE
82364>>>>>>>>>>>>>/// @Description This command sets the name space, or schema, to be used
82364>>>>>>>>>>>>>/// for the application. In Postgres, schemas are objects where all the
82364>>>>>>>>>>>>>/// tables,views and indexes are stored. Separate schemas are used to
82364>>>>>>>>>>>>>/// specify relational data. Note that this command will override the
82364>>>>>>>>>>>>>/// NAME_SPACE value in the INT file.
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Assumptions
82364>>>>>>>>>>>>>/// @Status      Public
82364>>>>>>>>>>>>>/// @Drivers     PgFlex
82364>>>>>>>>>>>>>/// @VersionNote Last Revised: 2009-08-14 By Ian Smith
82364>>>>>>>>>>>>>/// @See                 GET_NAME_SPACE
82364>>>>>>>>>>>>>/// @INTOPT              NAME_SPACE
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Syntax SET_NAME_SPACE to {variable}
82364>>>>>>>>>>>>>/// @Param variable                     Name of the name space
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Example
82364>>>>>>>>>>>>>/// SET_NAME_SPACE to "public"
82364>>>>>>>>>>>>>
82364>>>>>>>>>>>>>//=============================================================================
82364>>>>>>>>>>>>>/// @Name        SQL_USE_DATABASE
82364>>>>>>>>>>>>>/// @Description This command is used to specify which database is used
82364>>>>>>>>>>>>>/// for SQL statements only. Any normal table queries or changes will
82364>>>>>>>>>>>>>/// still use the default database, this only effects SQL statements.
82364>>>>>>>>>>>>>/// If none is specified then the default database is used. This can
82364>>>>>>>>>>>>>/// be useful if a certain SQL statement needs to query data from a
82364>>>>>>>>>>>>>/// database not currently being used. Note that this only works if
82364>>>>>>>>>>>>>/// the table name is not fully qualified in the SQl statement, i.e.
82364>>>>>>>>>>>>>/// "TestDB.Customer".
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Assumptions
82364>>>>>>>>>>>>>/// @Status      Public
82364>>>>>>>>>>>>>/// @Drivers     SQLFlex MySQLFLex PgSQL
82364>>>>>>>>>>>>>/// @VersionNote Last Revised: 2013-10-07 by Aaron Gulack
82364>>>>>>>>>>>>>/// @See                 SET_DATABASE_NAME GET_DATABASE_NAME
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Syntax SQL_USE_DATABASE of {server} to {database}
82364>>>>>>>>>>>>>/// @Param server                       Name of the server (Postgre only)
82364>>>>>>>>>>>>>/// @Param database                     Name of the database
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Example
82364>>>>>>>>>>>>>/// SQL_USE_DATABASE "testDB"
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// SQL_SET_STMT to "SELECT * FROM CUSTOMER WHERE STATUS = 'Active' "
82364>>>>>>>>>>>>>/// SQL_PREPARE_STMT
82364>>>>>>>>>>>>>/// SQL_EXECUTE_STMT
82364>>>>>>>>>>>>>/// SQL_FETCH_NEXT_ROW into sID sFirstName sLastName
82364>>>>>>>>>>>>>/// If (Found) Begin
82364>>>>>>>>>>>>>///     Showln sFirstName
82364>>>>>>>>>>>>>///     Showln sLastName
82364>>>>>>>>>>>>>/// End
82364>>>>>>>>>>>>>/// SQL_CANCEL_QUERY_STMT
82364>>>>>>>>>>>>>
82364>>>>>>>>>>>>>//=============================================================================
82364>>>>>>>>>>>>>/// @Name        SET_CURRENT_SQL_SERVER
82364>>>>>>>>>>>>>/// @Description This command is used to set the server to be used when
82364>>>>>>>>>>>>>/// opening tables. It will override the SERVER_NAME token in the INT file.
82364>>>>>>>>>>>>>/// If the server is not specified in the INT file or with this command,
82364>>>>>>>>>>>>>/// then the server used during login will be used. This command is only
82364>>>>>>>>>>>>>/// needed when connecting to multiple SQL servers. To set the server to
82364>>>>>>>>>>>>>/// use for embedded SQL statements, use SET_CURRENT_SQL_SERVER_CONNECTION.
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Assumptions
82364>>>>>>>>>>>>>/// @Status      Public
82364>>>>>>>>>>>>>/// @Drivers     All
82364>>>>>>>>>>>>>/// @VersionNote Last Revised: 2013-10-09 by Aaron Gulack
82364>>>>>>>>>>>>>/// @See                 GET_CURRENT_SQL_SERVER  SET_CURRENT_SQL_SERVER_CONNECTION GET_CURRENT_SQL_SERVER_CONNECTION
82364>>>>>>>>>>>>>/// @INTOPT              SERVER_NAME
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Syntax SET_CURRENT_SQL_SERVER to {server}
82364>>>>>>>>>>>>>/// @Param server                       Name of the server
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Example
82364>>>>>>>>>>>>>/// SET_CURRENT_SQL_SERVER to "localhost"
82364>>>>>>>>>>>>>
82364>>>>>>>>>>>>>//IGS - removed. CURRENT_SERVER is a property of Validation_List_Mixin so this
82364>>>>>>>>>>>>>//               replace conflicts with the property SET message.
82364>>>>>>>>>>>>>//#Replace SET_CURRENT_SERVER SET_CURRENT_SQL_SERVER
82364>>>>>>>>>>>>>
82364>>>>>>>>>>>>>//=============================================================================
82364>>>>>>>>>>>>>/// @Name        GET_CURRENT_SQL_SERVER
82364>>>>>>>>>>>>>/// @Description This command returns the name of the server to be used
82364>>>>>>>>>>>>>/// for opening and querying tables.
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Assumptions
82364>>>>>>>>>>>>>/// @Status      Public
82364>>>>>>>>>>>>>/// @Drivers     All
82364>>>>>>>>>>>>>/// @VersionNote Last Revised: 2013-10-07 by Aaron Gulack
82364>>>>>>>>>>>>>/// @See SET_CURRENT_SQL_SERVER SET_CURRENT_SQL_SERVER_CONNECTION GET_CURRENT_SQL_SERVER_CONNECTION
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Syntax GET_CURRENT_SERVER to {variable}
82364>>>>>>>>>>>>>/// @Param variable                     Variable to hold the server name
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Example
82364>>>>>>>>>>>>>/// GET_CURRENT_SQL_SERVER to sServer
82364>>>>>>>>>>>>>
82364>>>>>>>>>>>>>//IGS - removed. CURRENT_SERVER is a property of Validation_List_Mixin so this
82364>>>>>>>>>>>>>//               replace conflicts with the property GET message.
82364>>>>>>>>>>>>>//#Replace GET_CURRENT_SERVER GET_CURRENT_SQL_SERVER
82364>>>>>>>>>>>>>
82364>>>>>>>>>>>>>//=============================================================================
82364>>>>>>>>>>>>>/// @Name        SET_CURRENT_SQL_SERVER_CONNECTION
82364>>>>>>>>>>>>>/// @Description This command is used to specify which server to use for
82364>>>>>>>>>>>>>/// embedded SQL statements. By default, the last logged in server will
82364>>>>>>>>>>>>>/// be used. Note that in addition to setting the server, this command
82364>>>>>>>>>>>>>/// also sets the driver to be used. This command is only needed when
82364>>>>>>>>>>>>>/// connecting to multiple servers. To set the server for opening tables,
82364>>>>>>>>>>>>>/// use SET_CURRENT_SQL_SERVER.
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Assumptions
82364>>>>>>>>>>>>>/// @Status      Public
82364>>>>>>>>>>>>>/// @Drivers     All
82364>>>>>>>>>>>>>/// @VersionNote Last Revised: 2013-10-09 by Aaron Gulack
82364>>>>>>>>>>>>>/// @See                 GET_CURRENT_SQL_SERVER_CONNECTION GET_CURRENT_SQL_SERVER SET_CURRENT_SQL_SERVER
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Syntax SET_CURRENT_SQL_SERVER_CONNECTION of {constant} to {server}
82364>>>>>>>>>>>>>/// @Param constant                     MYSQLFLEX, ORAFLEX, PGFLEX, or SQLFLEX
82364>>>>>>>>>>>>>/// @Param server               Name of the server
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Example
82364>>>>>>>>>>>>>/// SET_CURRENT_SQL_SERVER_CONNECTION of SQLFLEX to "(localdb)\v11.0"
82364>>>>>>>>>>>>>
82364>>>>>>>>>>>>>//=============================================================================
82364>>>>>>>>>>>>>/// @Name        GET_CURRENT_SQL_SERVER_CONNECTION
82364>>>>>>>>>>>>>/// @Description This command returns the server currently being used for
82364>>>>>>>>>>>>>/// embedded SQL statements.
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Assumptions
82364>>>>>>>>>>>>>/// @Status      Public
82364>>>>>>>>>>>>>/// @Drivers     All
82364>>>>>>>>>>>>>/// @VersionNote Last Revised: 2013-10-09 by Aaron Gulack
82364>>>>>>>>>>>>>/// @See                 SET_CURRENT_SQL_SERVER_CONNECTION GET_CURRENT_SQL_SERVER SET_CURRENT_SQL_SERVER
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Syntax GET_CURRENT_SQL_SERVER_CONNECTION of {constant} to {variable}
82364>>>>>>>>>>>>>/// @Param constant                     MYSQLFLEX, ORAFLEX, PGFLEX, or SQLFLEX
82364>>>>>>>>>>>>>/// @Param variable             Variable to hold the name of the server
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Example
82364>>>>>>>>>>>>>/// GET_CURRENT_SQL_SERVER_CONNECTION of SQLFLEX to sServer
82364>>>>>>>>>>>>>
82364>>>>>>>>>>>>>//=============================================================================
82364>>>>>>>>>>>>>/// @Name        LOGIN_SQLFLEX
82364>>>>>>>>>>>>>/// @Description This command allows the user to login with a specified
82364>>>>>>>>>>>>>/// hostname. The default hostname that is passed is the path of the
82364>>>>>>>>>>>>>/// executable. Passing a custom hostname can be very useful for tracking
82364>>>>>>>>>>>>>/// a specific user for different situations. For example, if a company
82364>>>>>>>>>>>>>/// is using a terminal server and a whole sales team logs in under the
82364>>>>>>>>>>>>>/// same username and hostname, locating a specific user could otherwise
82364>>>>>>>>>>>>>/// be difficult. With this command, each user can pass a custom hostname,
82364>>>>>>>>>>>>>/// easily distinguishing themselves from other users.
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Assumptions
82364>>>>>>>>>>>>>/// @Status      Public
82364>>>>>>>>>>>>>/// @Drivers     SQLFlex
82364>>>>>>>>>>>>>/// @VersionNote Last Revised: 2013-10-02 by Aaron Gulack
82364>>>>>>>>>>>>>/// @See
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Syntax LOGIN_SQLFLEX {server} {username} {password} {hostname}
82364>>>>>>>>>>>>>/// @Param server               Server to use for login
82364>>>>>>>>>>>>>/// @Param username     Username to use for login
82364>>>>>>>>>>>>>/// @Param password     Password to use for login
82364>>>>>>>>>>>>>/// @Param hostname     Hostname to use for login
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Example
82364>>>>>>>>>>>>>/// LOGIN_SQLFLEX "localhost" "guestUser" "pas123" "WIN-MM7PQS5CP6C"
82364>>>>>>>>>>>>>
82364>>>>>>>>>>>>>//=============================================================================
82364>>>>>>>>>>>>>/// @Name        SQL_CANCEL_QUERY_STMT
82364>>>>>>>>>>>>>/// @Description This command is used to close any open cursors related to
82364>>>>>>>>>>>>>/// an SQL_EXECUTE_STMT. This should be used once the SQL statement has
82364>>>>>>>>>>>>>/// been executed and all rows have been fetched.
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Assumptions
82364>>>>>>>>>>>>>/// @Status      Public
82364>>>>>>>>>>>>>/// @Drivers     All
82364>>>>>>>>>>>>>/// @VersionNote Last Revised: 2013-10-03 by Aaron Gulack
82364>>>>>>>>>>>>>/// @See                 SQL_SET_STMT SQL_EXECUTE_STMT SQL_FETCH_NEXT_ROW SQL_APPEND_STMT SQL_PREPARE_STMT
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Syntax SQL_CANCEL_QUERY_STMT [of {FileName}]
82364>>>>>>>>>>>>>/// @Param FileName             Name of the file (optional)
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Example
82364>>>>>>>>>>>>>/// SQL_SET_STMT to "SELECT * FROM CUSTOMER WHERE STATUS = 'Active' "
82364>>>>>>>>>>>>>/// SQL_PREPARE_STMT
82364>>>>>>>>>>>>>/// SQL_BINDCOLUMNS_STMT of Customer to DF_BIND_ALL_COLUMNS
82364>>>>>>>>>>>>>/// SQL_EXECUTE_STMT of Customer
82364>>>>>>>>>>>>>/// SQL_FETCH_NEXT_ROW of Customer
82364>>>>>>>>>>>>>/// If (Found) Begin
82364>>>>>>>>>>>>>///     Showln Customer.FirstName
82364>>>>>>>>>>>>>///     Showln Customer.LastName
82364>>>>>>>>>>>>>/// End
82364>>>>>>>>>>>>>/// SQL_CANCEL_QUERY_STMT of Customer
82364>>>>>>>>>>>>>
82364>>>>>>>>>>>>>//=============================================================================
82364>>>>>>>>>>>>>/// @Name        NATIVE_OPTIMIZATION
82364>>>>>>>>>>>>>/// @Description Allows user to turn off the use of index hints on the native
82364>>>>>>>>>>>>>/// server. Setting this command to DEFAULT will cause the server to use the
82364>>>>>>>>>>>>>/// default settings for hints. Hints are off by default in Microsoft SQL
82364>>>>>>>>>>>>>/// Server but are on in Oracle. Care should be taken with changing the
82364>>>>>>>>>>>>>/// default, and should only be used if the diagnostics tool for your server
82364>>>>>>>>>>>>>/// indicates performance problems with the type of queries that are being
82364>>>>>>>>>>>>>/// generated. Note that this can be turned off or on for the whole server
82364>>>>>>>>>>>>>/// or just for a specific table.
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// DEFAULT             - The specified server's default settings
82364>>>>>>>>>>>>>/// USE_INDEXHINT       - All Index hints will be used
82364>>>>>>>>>>>>>/// NO_INDEXHINT        - No index hints will be used
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Assumptions
82364>>>>>>>>>>>>>/// @Status      Public
82364>>>>>>>>>>>>>/// @Drivers     SQLFlex, ORAFlex
82364>>>>>>>>>>>>>/// @VersionNote Last Revised: 2013-10-08 by Aaron Gulack
82364>>>>>>>>>>>>>/// @See
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Syntax NATIVE_OPTIMIZATION of {scopeLevel} {variable} to {constant}
82364>>>>>>>>>>>>>/// @Param scopeLevel           TABLE or SERVER. Indicates the scope of the setting
82364>>>>>>>>>>>>>/// @Param variable                     Either the name of the server or of the table
82364>>>>>>>>>>>>>/// @Param constant                     DEFAULT, USE_INDEXHINT, or NO_INDEXHINT
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Example
82364>>>>>>>>>>>>>/// NATIVE_OPTIMIZATION of SERVER "localhost" to USE_INDEXHINT
82364>>>>>>>>>>>>>
82364>>>>>>>>>>>>>//=============================================================================
82364>>>>>>>>>>>>>/// @Name        SET_ISOLATION_LEVEL
82364>>>>>>>>>>>>>/// @Description This command sets the locking and row versioning behavior
82364>>>>>>>>>>>>>/// for SQL statements. See the options below for information on the various
82364>>>>>>>>>>>>>/// effects they can have on transactions.
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// DEFAULT  - The default isolation level for the server (READ_COMMITTED
82364>>>>>>>>>>>>>/// for MSSQL).
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// READ_COMMITTED - This option is used to prevent dirty reads. A dirty
82364>>>>>>>>>>>>>/// read is when one transaction reads data from another transaction that
82364>>>>>>>>>>>>>/// has yet to be committed. If one transaction fails, the other now is
82364>>>>>>>>>>>>>/// dealing with invalid data. By setting the isolation level to
82364>>>>>>>>>>>>>/// READ_COMMITTED, dirty reads will be avoided by not allowing transactions
82364>>>>>>>>>>>>>/// to deal with any other data that has not been committed yet. However,
82364>>>>>>>>>>>>>/// in between statements within the current transaction, data can be changed
82364>>>>>>>>>>>>>/// by other transactions. This can result in phantom data or non-repeatable
82364>>>>>>>>>>>>>/// reads. Note that this can slow down performance speeds but is usually
82364>>>>>>>>>>>>>/// good practice.
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// READ_UNCOMMITTED - This option is the least restrictive isolation level.
82364>>>>>>>>>>>>>/// With this option, dirty reads are allowed, thus no exclusive locks are
82364>>>>>>>>>>>>>/// honored and modified data from one uncommitted transaction can be read
82364>>>>>>>>>>>>>/// by other transactions.
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// REPEATABLE_READ - This option is similar to the READ_COMMITTED option
82364>>>>>>>>>>>>>/// in that locks all placed on all transactions and uncommitted data from
82364>>>>>>>>>>>>>///     other transactions cannot be read, preventing dirty reads. However, unlike
82364>>>>>>>>>>>>>/// READ_COMMITTED, new rows that are added by other transactions can be read
82364>>>>>>>>>>>>>/// by the current transaction if it is retried, possibly resulting in phantom
82364>>>>>>>>>>>>>/// reads. This option should not be used unless there is a specific reason to
82364>>>>>>>>>>>>>/// do so.
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// SERIALIZABLE - This option is the most restrictive isolation level. With
82364>>>>>>>>>>>>>/// this option, no interaction is allowed between transactions until they
82364>>>>>>>>>>>>>/// have been committed. Similar to READ_COMMITTED, no transaction can deal
82364>>>>>>>>>>>>>/// with any uncommitted data. On top of that though, range locks are placed on
82364>>>>>>>>>>>>>/// all rows being modified until the current transaction is complete. Because
82364>>>>>>>>>>>>>/// concurrency is so low with this option, performance speeds can be much lower
82364>>>>>>>>>>>>>/// and so this should only be used when there is a specific reason to do so.
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Assumptions
82364>>>>>>>>>>>>>/// @Status      Public
82364>>>>>>>>>>>>>/// @Drivers     All
82364>>>>>>>>>>>>>/// @VersionNote Last Revised: 2013-10-08 by Aaron Gulack
82364>>>>>>>>>>>>>/// @See
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Syntax SET_ISOLATION_LEVEL of {server} to {constant}
82364>>>>>>>>>>>>>/// @Param server                       Name of the server
82364>>>>>>>>>>>>>/// @Param constant                     DEFAULT, READ_COMMITTED, READ_UNCOMMITTED, REPEATABLE_READ, or SERIALIZABLE
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Example
82364>>>>>>>>>>>>>/// LOGIN "localhost" "user" "pass123" "SQL_DRV"
82364>>>>>>>>>>>>>/// SET_ISOLATION_LEVEL of "localhost" to READ_COMMITTED
82364>>>>>>>>>>>>>
82364>>>>>>>>>>>>>//=============================================================================
82364>>>>>>>>>>>>>/// @Name        SET_SESSION_PARAMETER
82364>>>>>>>>>>>>>/// @Description There are two sets of code pages used in windows, ANSI and
82364>>>>>>>>>>>>>/// OEM. ANSI is what is commonly used now, but some data still uses the OEM
82364>>>>>>>>>>>>>/// code pages. When migrating data, this command is used to determine whether
82364>>>>>>>>>>>>>/// the OEM data will be translated to ANSI during the migration. For example,
82364>>>>>>>>>>>>>/// migrating passwords with special characters may call for different code
82364>>>>>>>>>>>>>/// pages. Sending true will convert the OEM data to ANSI, sending false will
82364>>>>>>>>>>>>>/// not. Both OEM_TO_ANSI and OEM_TRANSLATION_STATE do essentially the same
82364>>>>>>>>>>>>>/// thing, however since MSSQL has the functionality built in, OEM_TO_ANSI
82364>>>>>>>>>>>>>/// will use MSSQL's built in translation and thus only works with SQLFlex.
82364>>>>>>>>>>>>>/// OEM_TRANSLATION_STATE is internal and built into the driver so it works
82364>>>>>>>>>>>>>/// for all drivers. Note that if using custom entries with
82364>>>>>>>>>>>>>/// SET_CUSTOM_OEM_TO_ANSI then OEM_TRANSLATION_STATE must be used. Also, if
82364>>>>>>>>>>>>>/// there are already custom entries set then turning OEM_TRANSLATION_STATE
82364>>>>>>>>>>>>>/// on will automatically enable those custom translations.
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Assumptions
82364>>>>>>>>>>>>>/// @Status      Public
82364>>>>>>>>>>>>>/// @Drivers     All
82364>>>>>>>>>>>>>/// @VersionNote Last Revised: 2013-10-08 by Aaron Gulack
82364>>>>>>>>>>>>>/// @See                 SET_CUSTOM_OEM_TO_ANSI GET_CUSTOM_OEM_TO_ANSI
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Syntax SET_SESSION_PARAMETER {OEM_TO_ANSI/OEM_TRANSLATION_STATE} to {variable}
82364>>>>>>>>>>>>>/// @Param variable                     Boolean variable enabling or disabling translation
82364>>>>>>>>>>>>>///
82364>>>>>>>>>>>>>/// @Example
82364>>>>>>>>>>>>>/// SET_SESSION_PARAMETER OEM_TO_ANSI to True
82364>>>>>>>>>>>>>
82364>>>>>>>>>>>>>Procedure MertechInc_SET_CUSTOM_OEM_TO_ANSI Global Integer iChar Integer iOem Integer iAnsi
82366>>>>>>>>>>>>>    Move iChar to MertechInc_sArg1
82367>>>>>>>>>>>>>    move (String(iOem) + "," + String(iAnsi)) to MertechInc_sArg2
82368>>>>>>>>>>>>>    Call_Driver 0 MertechInc_DriverName Function CALLDRV_LICENSE_ENVIRONMENT_SET CALLBACK 0 PASSING MertechInc_sArg1 MertechInc_sArg2 CALLDRV_SET_CUSTOM_OEM_TO_ANSI RESULT MertechInc_iRet
82373>>>>>>>>>>>>>    IF MertechInc_iRet EQ -1 INDICATE ERR TRUE
82376>>>>>>>>>>>>>End_Procedure
82377>>>>>>>>>>>>>
82377>>>>>>>>>>>>>//=============================================================================
82377>>>>>>>>>>>>>/// @Name        SET_CUSTOM_OEM_TO_ANSI
82377>>>>>>>>>>>>>/// @Description In very rare situations, a custom OEM to ANSI translation
82377>>>>>>>>>>>>>/// is needed. When that is the case, this command can be used to create
82377>>>>>>>>>>>>>/// those custom entries. This is done by passing the character numbered
82377>>>>>>>>>>>>>/// position, the OEM value and the ANSI value. Note that
82377>>>>>>>>>>>>>/// OEM_TRANSLATION_STATE must be set to true for these custom entries to
82377>>>>>>>>>>>>>/// work.
82377>>>>>>>>>>>>>///
82377>>>>>>>>>>>>>/// @Assumptions
82377>>>>>>>>>>>>>/// @Status      Public
82377>>>>>>>>>>>>>/// @Drivers     All
82377>>>>>>>>>>>>>/// @VersionNote Last Revised: 2013-10-08 by Aaron Gulack
82377>>>>>>>>>>>>>/// @See                 GET_CUSTOM_OEM_TO_ANSI SET_SESSION_PARAMETER
82377>>>>>>>>>>>>>///
82377>>>>>>>>>>>>>/// @Syntax SET_CUSTOM_OEM_TO_ANSI {character} to OEM {value1} ANSI {value2}
82377>>>>>>>>>>>>>/// @Param character            Numbered position (0-255) of the character
82377>>>>>>>>>>>>>/// @Param value1                       Character number for the OEM value
82377>>>>>>>>>>>>>/// @Param value2                       Character number for the ANSI value
82377>>>>>>>>>>>>>
82377>>>>>>>>>>>>>Procedure MertechInc_GET_CUSTOM_OEM_TO_ANSI Global Integer iChar Integer iOem Integer iAnsi
82379>>>>>>>>>>>>>    Move iChar to MertechInc_sArg1
82380>>>>>>>>>>>>>    Move (Repeat(" ", 255)) to MertechInc_sArg2
82381>>>>>>>>>>>>>    Call_Driver 0 MertechInc_DriverName Function CALLDRV_LICENSE_ENVIRONMENT_SET CALLBACK 0 PASSING MertechInc_sArg1 MertechInc_sArg2 CALLDRV_GET_CUSTOM_OEM_TO_ANSI RESULT MertechInc_iRet
82386>>>>>>>>>>>>>    IF MertechInc_iRet EQ -1 INDICATE ERR TRUE
82389>>>>>>>>>>>>>End_Function
82390>>>>>>>>>>>>>
82390>>>>>>>>>>>>>//=============================================================================
82390>>>>>>>>>>>>>/// @Name        GET_CUSTOM_OEM_TO_ANSI
82390>>>>>>>>>>>>>/// @Description This command returns the custom OEM and ANSI values
82390>>>>>>>>>>>>>/// respectively for a given character. If there is no custom translation
82390>>>>>>>>>>>>>/// for the specified character then no error will be raised, but nothing
82390>>>>>>>>>>>>>/// will be returned.
82390>>>>>>>>>>>>>///
82390>>>>>>>>>>>>>/// @Assumptions There exists a custom translation for the specified character
82390>>>>>>>>>>>>>/// @Status      Public
82390>>>>>>>>>>>>>/// @Drivers     All
82390>>>>>>>>>>>>>/// @VersionNote Last Revised: 2013-10-08 by Aaron Gulack
82390>>>>>>>>>>>>>/// @See
82390>>>>>>>>>>>>>///
82390>>>>>>>>>>>>>/// @Syntax SET_CUSTOM_OEM_TO_ANSI {character} to OEM {value1} ANSI {value2}
82390>>>>>>>>>>>>>/// @Param character            Numbered position (0-255) of the character
82390>>>>>>>>>>>>>/// @Param value1                       Variable to hold the OEM value
82390>>>>>>>>>>>>>/// @Param value2                       Variable to hold the ANSI value
82390>>>>>>>>>>>>>
82390>>>>>>>>>>>>>//=============================================================================
82390>>>>>>>>>>>>>/// @Name        SET_AUTOMATIC_NUMERIC_DATATYPE_REMAPPING
82390>>>>>>>>>>>>>/// @Description This command toggles off and on the automatic numeric
82390>>>>>>>>>>>>>/// data type remapping built into SQLFlex. When adding or creating
82390>>>>>>>>>>>>>/// smaller numeric columns during a restructure, SQLFlex will change
82390>>>>>>>>>>>>>/// the type to a more specific data type i.e. smallint or tinyint since
82390>>>>>>>>>>>>>/// they are handled more efficiently by the server. Sending false to this
82390>>>>>>>>>>>>>/// command will force SQl to keep the column as a numeric field, preserving
82390>>>>>>>>>>>>>/// the length and precision. Passing true will leave the remapping up to the
82390>>>>>>>>>>>>>/// driver.
82390>>>>>>>>>>>>>///
82390>>>>>>>>>>>>>/// @Assumptions
82390>>>>>>>>>>>>>/// @Status      Public
82390>>>>>>>>>>>>>/// @Drivers     SQLFlex
82390>>>>>>>>>>>>>/// @VersionNote Last Revised: 2013-10-04 by Aaron Gulack
82390>>>>>>>>>>>>>/// @See
82390>>>>>>>>>>>>>///
82390>>>>>>>>>>>>>/// @Syntax SET_AUTOMATIC_NUMERIC_DATATYPE_REMAPPING to {variable}
82390>>>>>>>>>>>>>/// @Param variable                     Boolean variable enabling or disabling remapping
82390>>>>>>>>>>>>>///
82390>>>>>>>>>>>>>/// @Example
82390>>>>>>>>>>>>>/// Structure_Start hFile
82390>>>>>>>>>>>>>///
82390>>>>>>>>>>>>>///     Create_Field hFile
82390>>>>>>>>>>>>>///
82390>>>>>>>>>>>>>///     SET_AUTOMATIC_NUMERIC_DATATYPE_REMAPPING to False
82390>>>>>>>>>>>>>///
82390>>>>>>>>>>>>>///     Set_Attribute DF_FIELD_NAME   of hFile iColumn to "Transaction_Count"
82390>>>>>>>>>>>>>///     Set_Attribute DF_FIELD_TYPE   of hFile iColumn to DF_BCD
82390>>>>>>>>>>>>>///     Set_Attribute DF_FIELD_LENGTH of hFile iColumn to 1
82390>>>>>>>>>>>>>///
82390>>>>>>>>>>>>>/// Structure_End hFile
82390>>>>>>>>>>>>>
82390>>>>>>>>>>>>>//=============================================================================
82390>>>>>>>>>>>>>/// @Name        SET_FORCE_DATE_FORMAT_INIT
82390>>>>>>>>>>>>>/// @Description At times, a stored procedure, function or trigger may
82390>>>>>>>>>>>>>/// alter the default format for dates. This could cause problems because,
82390>>>>>>>>>>>>>/// for example, if a trigger on a table does this, then every time a save
82390>>>>>>>>>>>>>/// takes place on that table, the format for dates will be changed. By
82390>>>>>>>>>>>>>/// sending true to this command, the date formats will reset to their
82390>>>>>>>>>>>>>/// default format. Note that this is essentially the same thing as running
82390>>>>>>>>>>>>>/// the SQL statement: "ALTER SESSION SET NLS_DATE_FORMAT='MM/DD/YYYY'", so
82390>>>>>>>>>>>>>/// in most situations, that should be used instead of this command.
82390>>>>>>>>>>>>>///
82390>>>>>>>>>>>>>/// @Assumptions
82390>>>>>>>>>>>>>/// @Status      Deprecated
82390>>>>>>>>>>>>>/// @Drivers     ORAFlex
82390>>>>>>>>>>>>>/// @VersionNote Last Revised: 2013-10-08 by Aaron Gulack
82390>>>>>>>>>>>>>/// @See
82390>>>>>>>>>>>>>///
82390>>>>>>>>>>>>>/// @Syntax SET_FORCE_DATE_FORMAT_INIT to {variable}
82390>>>>>>>>>>>>>/// @Param variable             Boolean variable enabling or disabling format reset
82390>>>>>>>>>>>>>
82390>>>>>>>>>>>>>//=============================================================================
82390>>>>>>>>>>>>>/// @Name        SET_STATIC_TABLE_OPTIMIZATION
82390>>>>>>>>>>>>>/// @Description At this time, this command no longer serves any function.
82390>>>>>>>>>>>>>///
