89497>>>    // Helper function that builds a string like;
89497>>>    // "SELECT name from [Master].[sys].[databases] where name"
89497>>>    Function _SqlSelectFromWhereName Returns String
89499>>>        String sRetval sSelect sName sFrom sMaster sSys sDatabases sWhere sDBO
89499>>>        
89499>>>        Get _SqlFindKeyWord CI_SQLSelect       to sSelect
89500>>>        Get _SqlFindKeyWord CI_SQLName         to sName                             
89501>>>        Get _SqlFindKeyWord CI_SQLDBO          to sDBO
89502>>>        Get _SqlFindKeyWord CI_SQLFrom         to sFrom
89503>>>        Get _SqlFindKeyWord CI_SQLMaster       to sMaster
89504>>>        Get _SqlFindKeyWord CI_SQLSys          to sSys
89505>>>        Get _SqlFindKeyWord CI_SQLDatabases    to sDatabases
89506>>>        Get _SqlFindKeyWord CI_SQLWhere        to sWhere
89507>>>        Move (sSelect * sName * sFrom * "[" + sMaster + "].[" + sDBO + "].[" + sSys + sDatabases + "]" * sWhere * sName) to sRetval
89508>>>        Function_Return sRetval
89509>>>    End_Function  
