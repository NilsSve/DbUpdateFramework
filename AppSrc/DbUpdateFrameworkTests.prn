86775>>>>>>>>>>>>>
86775>>>>>>>>>>>>>    Function IsProcedure String sFunctionName Returns Boolean
86777>>>>>>>>>>>>>        String sRoutineType
86777>>>>>>>>>>>>>
86777>>>>>>>>>>>>>        SQL_SET_CURRENT_CURSOR_STMT to (piCursorNum(Self))
86791>>>>>>>>>>>>>>
86791>>>>>>>>>>>>>
86791>>>>>>>>>>>>>        Case Begin
86791>>>>>>>>>>>>>            Case (MertechInc_DriverName = SQLFLEX)
86793>>>>>>>>>>>>>                sql_set_stmt to (SFormat("select type from master.sys.sysobjects where name = '%1' union all select type from sys.sysobjects where name = '%1'", sFunctionName))
86801>>>>>>>>>>>>>                sql_prepare_stmt
86813>>>>>>>>>>>>>                sql_execute_stmt
86828>>>>>>>>>>>>>
86828>>>>>>>>>>>>>                sql_fetch_next_row into sRoutineType
86852>>>>>>>>>>>>>>
86852>>>>>>>>>>>>>                If (sRoutineType = "P") Move "PROCEDURE" to sRoutineType
86855>>>>>>>>>>>>>                Else Move "FUNCTION" to sRoutineType
86857>>>>>>>>>>>>>                Case Break
86858>>>>>>>>>>>>>            Case (MertechInc_DriverName = MySQLFlex)
86861>>>>>>>>>>>>>                sql_set_stmt to (SFormat("select routine_type from information_schema.routines where routine_name = '%1'", sFunctionName))
86869>>>>>>>>>>>>>                sql_prepare_stmt
86881>>>>>>>>>>>>>                sql_execute_stmt
86896>>>>>>>>>>>>>                sql_fetch_next_row into sRoutineType
86920>>>>>>>>>>>>>>
86920>>>>>>>>>>>>>
86920>>>>>>>>>>>>>                Case Break
86921>>>>>>>>>>>>>            Case (MertechInc_DriverName = ORAFLEX)
86924>>>>>>>>>>>>>                sql_set_stmt  to (SFormat("SELECT object_type from all_objects where object_name = '%1'", sFunctionName))
86932>>>>>>>>>>>>>                sql_prepare_stmt
86944>>>>>>>>>>>>>                sql_execute_stmt
86959>>>>>>>>>>>>>                sql_fetch_next_row into sRoutineType
86983>>>>>>>>>>>>>>
86983>>>>>>>>>>>>>
86983>>>>>>>>>>>>>                Case Break
86984>>>>>>>>>>>>>            Case (MertechInc_DriverName = PgFlex)
86987>>>>>>>>>>>>>                // Postgres doesn't differentiate between procedures and functions, so treat everything as procedures
86987>>>>>>>>>>>>>                // because that is better tested.
86987>>>>>>>>>>>>>                Move "PROCEDURE" to sRoutineType
86988>>>>>>>>>>>>>                Case Break
86989>>>>>>>>>>>>>        Case End
86989>>>>>>>>>>>>>
86989>>>>>>>>>>>>>        Function_Return (sRoutineType = "PROCEDURE")
86990>>>>>>>>>>>>>    End_Function
86991>>>>>>>>>>>>>
86991>>>>>>>>>>>>>    Function ProcParams String sFunctionName Returns Variant[]
86993>>>>>>>>>>>>>        Variant[] vFuncParams
86994>>>>>>>>>>>>>        Integer i iParamType
86994>>>>>>>>>>>>>
86994>>>>>>>>>>>>>        SQL_SET_CURRENT_CURSOR_STMT to (piCursorNum(Self))
87008>>>>>>>>>>>>>>
87008>>>>>>>>>>>>>
87008>>>>>>>>>>>>>        Case Begin
87008>>>>>>>>>>>>>            Case (MertechInc_DriverName = SQLFLEX)
87010>>>>>>>>>>>>>                sql_set_stmt to (SFormat("sys.sp_procedure_params_managed @procedure_name = '%1'", sFunctionName))
87018>>>>>>>>>>>>>                sql_prepare_stmt
87030>>>>>>>>>>>>>                sql_execute_stmt
87045>>>>>>>>>>>>>
87045>>>>>>>>>>>>>                Repeat
87045>>>>>>>>>>>>>>
87045>>>>>>>>>>>>>                    sql_fetch_next_row
87060>>>>>>>>>>>>>>
87060>>>>>>>>>>>>>                    If (Found) Begin
87062>>>>>>>>>>>>>                        sql_fetch_column 6 into iParamType
87067>>>>>>>>>>>>>
87067>>>>>>>>>>>>>                        If (iParamType = 1) Move "IN" to vFuncParams[i]
87070>>>>>>>>>>>>>                        If (iParamType = 2) Move "INOUT" to vFuncParams[i]
87073>>>>>>>>>>>>>                        If (iParamType = 3) Move "OUT" to vFuncParams[i]
87076>>>>>>>>>>>>>                        If (iParamType <> 4) Increment i
87079>>>>>>>>>>>>>                    End
87079>>>>>>>>>>>>>>
87079>>>>>>>>>>>>>                Until (not(Found))
87081>>>>>>>>>>>>>
87081>>>>>>>>>>>>>                Function_Return vFuncParams
87082>>>>>>>>>>>>>
87082>>>>>>>>>>>>>                Case Break
87083>>>>>>>>>>>>>            Case (MertechInc_DriverName = MySQLFlex)
87086>>>>>>>>>>>>>                sql_set_stmt to (SFormat("select parameter_mode from INFORMATION_SCHEMA.PARAMETERS where SPECIFIC_NAME = '%1' order by ordinal_position", sFunctionName))
87094>>>>>>>>>>>>>                sql_prepare_stmt
87106>>>>>>>>>>>>>                sql_execute_stmt
87121>>>>>>>>>>>>>
87121>>>>>>>>>>>>>                Case Break
87122>>>>>>>>>>>>>            Case (MertechInc_DriverName = ORAFLEX)
87125>>>>>>>>>>>>>                sql_set_stmt to    "SELECT all_arguments.in_out as parameter_mode "
87133>>>>>>>>>>>>>                sql_append_stmt to "FROM all_objects inner join all_arguments on all_objects.object_id = all_arguments.object_id "
87141>>>>>>>>>>>>>                sql_append_stmt to (SFormat("WHERE all_objects.object_name = '%1' order by all_arguments.position", sFunctionName))
87149>>>>>>>>>>>>>                sql_prepare_stmt
87161>>>>>>>>>>>>>                sql_execute_stmt
87176>>>>>>>>>>>>>
87176>>>>>>>>>>>>>                Case Break
87177>>>>>>>>>>>>>            Case (MertechInc_DriverName = PgFlex)
87180>>>>>>>>>>>>>                sql_set_stmt    to "select information_schema.parameters.parameter_mode "
87188>>>>>>>>>>>>>                sql_append_stmt to "from information_schema.routines inner join information_schema.parameters "
87196>>>>>>>>>>>>>                sql_append_stmt to "on information_schema.routines.specific_name=information_schema.parameters.specific_name "
87204>>>>>>>>>>>>>                sql_append_stmt to (SFormat("where information_schema.routines.routine_name = '%1' ", sFunctionName))
87212>>>>>>>>>>>>>                sql_append_stmt to "order by information_schema.parameters.ordinal_position"
87220>>>>>>>>>>>>>                sql_prepare_stmt
87232>>>>>>>>>>>>>                sql_execute_stmt
87247>>>>>>>>>>>>>
87247>>>>>>>>>>>>>                Case Break
87248>>>>>>>>>>>>>        Case End
87248>>>>>>>>>>>>>
87248>>>>>>>>>>>>>        Repeat
87248>>>>>>>>>>>>>>
87248>>>>>>>>>>>>>            sql_fetch_next_row into vFuncParams[i]
87272>>>>>>>>>>>>>>
87272>>>>>>>>>>>>>            Increment i
87273>>>>>>>>>>>>>        Until (not(Found))
87275>>>>>>>>>>>>>        
87275>>>>>>>>>>>>>        Function_Return vFuncParams
87276>>>>>>>>>>>>>    End_Function
87277>>>>>>>>>>>>>    
