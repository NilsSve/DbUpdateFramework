97688>>>>>    // *** Helper functions with compiled sql script code ***
97688>>>>>    //  
97688>>>>>    // When dropping columns SQL Sever does not reclaim the space taken up by the columns dropped. 
97688>>>>>    // For data types that are stored inline in the rows (int for example) it may even take up space on 
97688>>>>>    // the new rows added after the alter statement. To get around this you need to create a clustered 
97688>>>>>    // index on the table or rebuild the clustered Index if it already has one. Rebuilding the index 
97688>>>>>    // can be done with a REBUILD command after modifying the table. But be warned this can be slow on very big tables.
97688>>>>>    //   ALTER TABLE MyTable
97688>>>>>    //       REBUILD
97688>>>>>    Function _SqlUtilRemoveTableColumnByScript String sMemScriptFile String sTableName String sColumnName Returns Boolean
97690>>>>>        tSQLScriptArray SQLScriptArray                      
97690>>>>>        tSQLScriptArray SQLScriptArray                      
97690>>>>>        String sDriverID sVal
97690>>>>>        Boolean bOK  
97690>>>>>        Integer iSize iCount
97690>>>>>        
97690>>>>>        If (Trim(sTableName) = "" or Trim(sColumnName) = "") Begin
97692>>>>>            Function_Return False
97693>>>>>        End                             
97693>>>>>>
97693>>>>>        
97693>>>>>        Get psDriverID to sDriverID
97694>>>>>        Get SqlUtilReadResource sMemScriptFile to SQLScriptArray
97695>>>>>        If (SQLScriptArray.bError = True) Begin
97697>>>>>            Function_Return False
97698>>>>>        End                     
97698>>>>>>
97698>>>>>        
97698>>>>>        Move (SizeOfArray(SQLScriptArray.sSQLScriptArray)) to iSize
97699>>>>>        Decrement iSize
97700>>>>>        
97700>>>>>        for iCount from 0 to iSize   
97706>>>>>>
97706>>>>>            If (SQLScriptArray.sSQLScriptArray[iCount] contains "TABLE_NAME_XXX") Begin
97708>>>>>                Move (Replaces("TABLE_NAME_XXX",  SQLScriptArray.sSQLScriptArray[iCount], String(sTableName))) to SQLScriptArray.sSQLScriptArray[iCount]
97709>>>>>            End
97709>>>>>>
97709>>>>>            If (SQLScriptArray.sSQLScriptArray[iCount] contains "COLUMN_NAME_XXX") Begin
97711>>>>>                Move (Replaces("COLUMN_NAME_XXX", SQLScriptArray.sSQLScriptArray[iCount], String(sColumnName))) to SQLScriptArray.sSQLScriptArray[iCount]
97712>>>>>            End
97712>>>>>>
97712>>>>>        Loop
97713>>>>>>
97713>>>>>        
97713>>>>>        Get SqlUtilExecuteEmbeddedScript SQLScriptArray sDriverID False "" to bOK
97714>>>>>        
97714>>>>>        Function_Return (bOK = True)
97715>>>>>    End_Function
