95368>>>>>        End                
95368>>>>>>
95368>>>>>        
95368>>>>>        Function_Return bOK
95369>>>>>    End_Function
95370>>>>>
95370>>>>>    // Changes source code files.
95370>>>>>    // Pass a file name with full path and a value to search for, together with the value
95370>>>>>    // to change to. Can e.g. be used for changing all .int files from using a fixed server name,
95370>>>>>    // to use a Connection ID. 
95370>>>>>    // Sample: Get UtilChangeSourceCodeLine "C:\DataFlex 18.2 Examples\Order Entry\Data\Order.int" "SERVER_NAME SERVER=(local)\SQLEXPRESS1" "SERVER_NAME DFCONNID=ChinookDb"
95370>>>>>    // Pass "True" for the bShowResult if you want to see the result while it works. Showln will then be used for output
95370>>>>>    // Returns True if no errors occured. 
95370>>>>>    Function UtilChangeSourceCodeLine String sFileName String sChangeFrom String sChangeTo Boolean bShowResult Returns Boolean
95372>>>>>        Integer iCh iRow iItems iCount
95372>>>>>        String sValue sRow
95372>>>>>        String[] sFileArray
95373>>>>>        Boolean bExists
95373>>>>>    
95373>>>>>        Move False to Err
95374>>>>>        Move 0 to iRow
95375>>>>>    
95375>>>>>        Get vFilePathExists sFileName to bExists
95376>>>>>        If (bExists = False) Begin
95378>>>>>            If (bShowResult = True) Begin
95380>>>>>                Showln "File does not exist: " sFileName
95383>>>>>            End
95383>>>>>>
95383>>>>>            Function_Return False
95384>>>>>        End
95384>>>>>>
95384>>>>>    
95384>>>>>        Get Seq_Open_Input_Channel sFileName to iCh
95385>>>>>        If (iCh < 1) Begin
95387>>>>>            Function_Return False
95388>>>>>        End
95388>>>>>>
95388>>>>>        
95388>>>>>        If (bShowResult = True) Begin  
95390>>>>>            Showln ""
95392>>>>>            Showln "sFileName = " sFileName
95395>>>>>            Showln "sChangeFrom = " sChangeFrom " sChangeTo = " sChangeTo
95400>>>>>        End
95400>>>>>>
95400>>>>>        
95400>>>>>        While (not(SeqEof))
95404>>>>>            Readln channel iCh sRow
95406>>>>>            If (Uppercase(sRow) contains Uppercase(sChangeFrom)) Begin 
95408>>>>>                If (bShowResult = True) Begin
95410>>>>>                    Showln "Changed from: " sRow " to: " sChangeTo
95415>>>>>                End
95415>>>>>>
95415>>>>>                // Change the whole line to the new connection id:
95415>>>>>                Move sChangeTo to sRow
95416>>>>>                // Move (Replaces(sChangeFrom, sRow, sChangeTo)) to sValue
95416>>>>>            End
95416>>>>>>
95416>>>>>            Move sRow to sFileArray[iRow]
95417>>>>>            Increment iRow
95418>>>>>        End
95419>>>>>>
95419>>>>>        Send Seq_Close_Channel iCh
95420>>>>>        
95420>>>>>        Sleep 1 // Wait for Windows to close the file
95421>>>>>    
95421>>>>>        Get Seq_Open_Output_Channel sFileName to iCh
95422>>>>>        If (iCh < 1) Begin
95424>>>>>            Function_Return False
95425>>>>>        End
95425>>>>>>
95425>>>>>        Move (SizeOfArray(sFileArray)) to iItems
95426>>>>>        Decrement iItems
95427>>>>>    
95427>>>>>        For iCount from 0 to iItems
95433>>>>>>
95433>>>>>            Move sFileArray[iCount] to sValue
95434>>>>>            Writeln channel iCh sValue
95437>>>>>        Loop
95438>>>>>>
95438>>>>>        Send Seq_Close_Channel iCh
95439>>>>>    
95439>>>>>        Function_Return (Err = False)
95440>>>>>    End_Function
95441>>>>>    
95441>>>>>    // This might be needed by API-methods when a connection id is to be used and
95441>>>>>    // the connection ID hasn't been established with the driver's CLI interface.
95441>>>>>    // NOTE: Only applicable for DAW drivers, as Mertech drivers doesn't use connection ID's.
95441>>>>>    Function UtilCreateConnectionID String sConnectionID Returns Boolean
95443>>>>>        String sConnectionString sDriverID
95443>>>>>        Boolean bOK bSilent bDawDriver
95443>>>>>        Handle hoCLI
95443>>>>>        
95443>>>>>        Move False to bOK   
95444>>>>>        Get psDriverID to sDriverID
95445>>>>>        Get IsDAWSQLDriver sDriverID to bDawDriver
95446>>>>>        If (bDawDriver = False) Begin
95448>>>>>            Error DFERR_PROGRAM "The UtilCreateConnectionID function is only available for DAW drivers. (Not Mertech)."
95449>>>>>>
95449>>>>>            Function_Return False
95450>>>>>        End
95450>>>>>>
95450>>>>>        
95450>>>>>        Get psConnectionString to sConnectionString
95451>>>>>        Get pbSilentLogin      to bSilent
95452>>>>>        
95452>>>>>        Get phoCLIHandler to hoCLI 
95453>>>>>        If (hoCLI <> 0) Begin
95455>>>>>            Set psDriverID of hoCLI to sDriverID
95456>>>>>            Get CreateConnectionID of hoCLI sConnectionID sConnectionString bSilent to bOK
95457>>>>>        End
95457>>>>>>
95457>>>>>        
95457>>>>>        Function_Return (bOK = False)
95458>>>>>    End_Function
95459>>>>>
95459>>>>>    // This message creates an error log in the "Home" folder named "SQLErrorLog.txt",
95459>>>>>    // and opens it in "notepad.exe".
95459>>>>>    // Note: This is _not_ used by the cDbUpdateHandler & cDbUpdateVersion classes!
95459>>>>>    //       Instead the cDbUpdateLogFile's WriteErrorLog & ShowErrorLog are then used.
95459>>>>>    Procedure UtilShowErrorList
95461>>>>>        tSqlErrorArray aSqlErrorArray 
95461>>>>>        tSqlErrorArray aSqlErrorArray 
95461>>>>>        Integer iRows iCount iCh iErrorNum
95461>>>>>        String sPath sFileName sErrorTxt sStatement
95461>>>>>        
95461>>>>>        Get psHome of (phoWorkspace(ghoApplication)) to sPath
95462>>>>>        Get vFolderFormat sPath to sPath
95463>>>>>        Move "SQLErrorLog.txt"  to sFileName
95464>>>>>        Get Seq_Open_Output_Channel (sPath + sFileName) to iCh
95465>>>>>            Get paSqlErrorArray to aSqlErrorArray
95466>>>>>            Move (SizeOfArray(aSqlErrorArray.sSqlErrorArray)) to iRows
95467>>>>>            If (iRows > 0) Begin
95469>>>>>                Decrement iRows
95470>>>>>                for iCount from 0 to iRows
95476>>>>>>
95476>>>>>                    Move aSqlErrorArray.sSqlErrorArray[iCount]      to sErrorTxt
95477>>>>>                    Move aSqlErrorArray.sSqlStatementArray[iCount]  to sStatement
95478>>>>>                    Move aSqlErrorArray.iSqlErrorArray[iCount]      to iErrorNum
95479>>>>>                    Writeln channel iCh "Error No: " iErrorNum " Error Text: " sErrorTxt
95485>>>>>                    Writeln channel iCh "SQL Statement: " sStatement
95489>>>>>                Loop
95490>>>>>>
95490>>>>>            End
95490>>>>>>
95490>>>>>        Send Seq_Close_Channel iCh
95491>>>>>        
95491>>>>>        If (iRows > 0) Begin
95493>>>>>            Runprogram Background "Notepad.exe" (sPath + sFileName)
95494>>>>>        End
95494>>>>>>
95494>>>>>    End_Procedure
