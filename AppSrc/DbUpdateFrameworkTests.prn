95179>>>>>    // The default value used for a datatype as specified in the driver int file.
95179>>>>>    Function UtilDataTypeDefaultValue String sDriverID Integer iDbType Integer iDataType Returns String
95181>>>>>        String sRetval sServer
95181>>>>>        tColumnType RetvalType 
95181>>>>>        tColumnType RetvalType 
95181>>>>>        Integer iDriver iDataFlexType
95181>>>>>        Handle hDatabase
95181>>>>>        
95181>>>>>        Get _UtilColumnType sDriverID iDbType iDataType "" True to RetvalType 
95182>>>>>        Move RetvalType.iDataFlexType to iDataFlexType
95183>>>>>        Get DriverIndex sDriverID to iDriver
95184>>>>>        Get psServer to sServer
95185>>>>>        Get SqlUtilDatabaseHandle sDriverID sServer to hDatabase 
95186>>>>>        If (hDatabase = 0) Begin
95188>>>>>            Function_Return ""
95189>>>>>        End                   
95189>>>>>>
95189>>>>>        
95189>>>>>        Case Begin
95189>>>>>            Case (iDataFlexType = DF_ASCII)
95191>>>>>                Get_Attribute DF_DATABASE_DEFAULT_DEFAULT_ASCII     of iDriver hDatabase to sRetval
95194>>>>>                Case Break
95195>>>>>            Case (iDataFlexType = DF_BCD)
95198>>>>>                Get_Attribute DF_DATABASE_DEFAULT_DEFAULT_NUMERIC   of iDriver hDatabase to sRetval
95201>>>>>                Case Break
95202>>>>>            Case (iDataFlexType = DF_BINARY)
95205>>>>>                Get_Attribute DF_DATABASE_DEFAULT_DEFAULT_BINARY    of iDriver hDatabase to sRetval
95208>>>>>                Case Break
95209>>>>>            Case (iDataFlexType = DF_DATE)
95212>>>>>                Get_Attribute DF_DATABASE_DEFAULT_DEFAULT_DATE      of iDriver hDatabase to sRetval
95215>>>>>                Case Break
95216>>>>>            Case (iDataFlexType = DF_DATETIME)
95219>>>>>                Get_Attribute DF_DATABASE_DEFAULT_DEFAULT_DATETIME  of iDriver hDatabase to sRetval
95222>>>>>                Case Break
95223>>>>>            Case (iDataFlexType = DF_TEXT)
95226>>>>>                Get_Attribute DF_DATABASE_DEFAULT_DEFAULT_TEXT      of iDriver hDatabase to sRetval
95229>>>>>                Case Break
95230>>>>>            Case Else
95230>>>>>                Move "" to sRetval            
95231>>>>>        Case End
95231>>>>>        
95231>>>>>        Function_Return sRetval
95232>>>>>    End_Function  
