93401>>>>>            Move (Trim(sTable)) to sTable
93402>>>>>            If (SQLConnection.sDriverID = DB2_DRV_ID) Begin
93404>>>>>                Move (sTable <> "" and Uppercase(sTableType) = sTableKeyWord and Uppercase(sSchema) = sDefSchema) to bOK
93405>>>>>            End
93405>>>>>>
93405>>>>>            Else Begin
93406>>>>>                Move (sTable <> "" and Uppercase(sTableType) = sTableKeyWord and Uppercase(sSchema) <> sSysKeyWord and Uppercase(sSchema) <> "SYSTOOLS") to bOK
93407>>>>>            End
93407>>>>>>
