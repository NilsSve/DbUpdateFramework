90197>>>>>>>    
90197>>>>>>>    // ************************************        
90197>>>>>>>    Function SetupSQLConnection Boolean bReadSettings Returns tSQLConnection
90199>>>>>>>        tSQLConnection SQLConnection 
90199>>>>>>>        tSQLConnection SQLConnection 
90199>>>>>>>        
90199>>>>>>>        // If this object was created by the cDbUpdateHandler class we will
90199>>>>>>>        // deferr reading SQL connection values until later.
90199>>>>>>>        If (bReadSettings = True) Begin
90201>>>>>>>            // This is the new SQL login logic for DF 19 and up; "Managed Connections"
90201>>>>>>>            If (ghoConnection > 0) Begin
90203>>>>>>>                Get ReadcConnections to SQLConnection
90204>>>>>>>            End
90204>>>>>>>>
90204>>>>>>>            
90204>>>>>>>            // In addition to the above; there might be other values set even if a cConnection
90204>>>>>>>            // object is used.
90204>>>>>>>            Get ReadSQLConnectionsIniSettings to SQLConnection
90205>>>>>>>        End     
90205>>>>>>>>
90205>>>>>>>        
90205>>>>>>>        Function_Return SQLConnection
90206>>>>>>>    End_Function
90207>>>>>>>    
90207>>>>>>>    // This is for the new cConnection class used by DF 19 and up (only).
90207>>>>>>>    Function ReadcConnections Returns tSQLConnection
90209>>>>>>>        tConnection Connection                 
90209>>>>>>>        tConnection Connection                 
90209>>>>>>>        tSQLConnection SQLConnection SQLConnectionEmpty
90209>>>>>>>        tSQLConnection SQLConnection SQLConnectionEmpty
90209>>>>>>>        Integer iCount iSize iRetval iDbType
90209>>>>>>>        Boolean bOK bEnabled bConnected bVal
90209>>>>>>>        String sConnectionID sSchema
90209>>>>>>>        
90209>>>>>>>            // - If the DF 19 cConnection class has been used in the cApplication object
90209>>>>>>>            // - and there are multiple connection id's defined for the same driver. This is
90209>>>>>>>            //   because otherwise we can't possibly know which connection id to use... So
90209>>>>>>>            //   we then generate an error and abort the program...
90209>>>>>>>            Get IsSinglecConnection (&sConnectionID) to bOK                                     
90210>>>>>>>            If (bOK = False) Begin
90212>>>>>>>                Error DFERR_PROGRAM ("Programming error. The psConnectionID must be set in the cDbUpdateVersion object when a cConnect object is used in the cApplication object, and there are multiple connections defined. Program will now exit!")
90213>>>>>>>>
90213>>>>>>>                Abort
90214>>>>>>>>
90214>>>>>>>            End  
90214>>>>>>>>
90214>>>>>>>            
90214>>>>>>>            Move 0 to iRetval
90215>>>>>>>            // DAW DF19 connection info: 
90215>>>>>>>            // We first check that the connection is OK:  
90215>>>>>>>            Get ConnectionIdIndex of ghoConnection sConnectionID to iRetval
90216>>>>>>>            // It might happen that no connection has been setup although the object exists, in case we do nothing.
90216>>>>>>>            If (iRetval = -1) Begin
90218>>>>>>>                Function_Return SQLConnectionEmpty
90219>>>>>>>            End                                 
90219>>>>>>>>
90219>>>>>>>
90219>>>>>>>            If (sConnectionID <> "") Begin
90221>>>>>>>                Get ConnectionIdInfo of ghoConnection sConnectionID to Connection  
90222>>>>>>>            End
90222>>>>>>>>
90222>>>>>>>            If (Connection.sId = "") Begin
90224>>>>>>>                Move True to SQLConnectionEmpty.bError
90225>>>>>>>                Function_Return SQLConnectionEmpty
90226>>>>>>>            End
90226>>>>>>>>
90226>>>>>>>            
90226>>>>>>>            Move Connection.sId to sConnectionID  
90227>>>>>>>            Get IsConnectionIdLoggedIn of ghoConnection sConnectionID to bConnected
90228>>>>>>>    
90228>>>>>>>            If (bConnected = False) Begin
90230>>>>>>>                Get LoginConnectionId of ghoConnection to iRetval    
90231>>>>>>>                If (iRetval <> 0) Begin 
90233>>>>>>>                    Send UserError CS_DUF_CannotLoginToServer
90234>>>>>>>                    Send Exit_Application    
90235>>>>>>>                End
90235>>>>>>>>
90235>>>>>>>            End
90235>>>>>>>>
90235>>>>>>>            
90235>>>>>>>            // DUF connection info struct property:
90235>>>>>>>            Get Private.pSQLConnection                       to SQLConnection   
90236>>>>>>>            Move True                                        to SQLConnection.bEnabled
90237>>>>>>>            Move Connection.bTrustedConnection               to SQLConnection.bTrusted
90238>>>>>>>    
90238>>>>>>>            // Not used in DUF:
90238>>>>>>>            // Move Connection.iDriverIndex                    to SQLConnection.iDriverIndex
90238>>>>>>>    
90238>>>>>>>            Move (If(Connection.iOptions = 0, False, True))  to SQLConnection.bSilentLogin
90239>>>>>>>            Move Connection.sConnectionString                to SQLConnection.sConnectionString
90240>>>>>>>            Move Connection.sDriver                          to SQLConnection.sDriverID
90241>>>>>>>            Move Connection.sId                              to SQLConnection.sConnectionID
90242>>>>>>>            Move Connection.sUID                             to SQLConnection.sUserID
90243>>>>>>>            Move Connection.sPWD                             to SQLConnection.sPassword
90244>>>>>>>    
90244>>>>>>>            // Not used in DUF:
90244>>>>>>>            // Move Connection.sSection to SQLConnection.xxx
90244>>>>>>>            
90244>>>>>>>            // The rest of the properties of the SQLConnection struct should have been
90244>>>>>>>            // setup in the cDbUpdateHandler object, and we should be able to reach them through delegation:
90244>>>>>>>            If (Connection.sDriver <> ODBC_DRV_ID) Begin
90246>>>>>>>                Get ParseKeyWord Connection.sString CS_SQLIniServerKeyword to SQLConnection.sServer
90247>>>>>>>            End
90247>>>>>>>>
90247>>>>>>>            If (Connection.sDriver = ODBC_DRV_ID) Begin
90249>>>>>>>                Get ParseKeyWord Connection.sString CS_SQLIniDSNKeyword    to SQLConnection.sServer
90250>>>>>>>            End
90250>>>>>>>>
90250>>>>>>>            Get ParseKeyWord Connection.sString CS_SQLIniDatabaseKeyword   to SQLConnection.sDatabase  
90251>>>>>>>            
90251>>>>>>>            // The DbType is a bit special. If the piDbType has _not_ been setup in object code we try to derave
90251>>>>>>>            // the value from the driver id:
90251>>>>>>>            Get SqlUtilDbTypeFromDriver of (phoSQLConnectionIniFile(Self)) Connection.sDriver to SQLConnection.iDbType
90252>>>>>>>            // ...but in case it has been explicitly set in the object we use that value.
90252>>>>>>>            Get piDbType                                     to iDbType
90253>>>>>>>            If (iDbType <> SQLConnection.iDbType) Begin
90255>>>>>>>                Move iDbType to SQLConnection.iDbType
90256>>>>>>>            End
90256>>>>>>>>
90256>>>>>>>            Get psBaseTableSpace                             to SQLConnection.sBaseTableSpace
90257>>>>>>>            Get psLongTableSpace                             to SQLConnection.sLongTableSpace
90258>>>>>>>            Get psIndexTableSpace                            to SQLConnection.sIndexTableSpace
90259>>>>>>>            Get psSchema                                     to SQLConnection.sSchema
90260>>>>>>>            
90260>>>>>>>            // We finally set the struct property to the newly fetched values.
90260>>>>>>>            Set pSQLConnection to SQLConnection
90261>>>>>>>        
90261>>>>>>>        Function_Return SQLConnection
90262>>>>>>>    End_Function
90263>>>>>>>    
90263>>>>>>>    // Returns True if the psConnectionID has been set in the cDbUpateHandler object,
90263>>>>>>>    // or the DAW cConnect array of registered connection only contains one active/enabled
90263>>>>>>>    // connection id for a particular driver.
90263>>>>>>>    // So either the psConnectionID or the psDriverID can have been set in the cDbUpdateHandler
90263>>>>>>>    // object. We can then match a connection id from the DAW cConnect class array.
90263>>>>>>>    // Returns False if there are multiple connections that are enabled or the psConnectionID has
90263>>>>>>>    // been set in the cDbUpdateHandler object but it cannot be found amongst the registered 
90263>>>>>>>    // connections of the DAW cConnect class.
90263>>>>>>>    Function IsSinglecConnection String ByRef sConnectionID Returns Boolean
90265>>>>>>>        tConnection[] ConnIdArray
90265>>>>>>>        tConnection[] ConnIdArray
90266>>>>>>>        Integer iCount iSize iConnectionIDCounter
90266>>>>>>>        Boolean bOK bEnabled bFound
90266>>>>>>>        String sConnectionID2 sDriverID sDriverConn
90266>>>>>>>        
90266>>>>>>>        Move False to bFound
90267>>>>>>>        If (ghoConnection > 0) Begin           
90269>>>>>>>            
90269>>>>>>>            // The property of the cDbUpdateHandler container object
90269>>>>>>>            Get psDriverID to sDriverID
90270>>>>>>>            
90270>>>>>>>            Move 0 to iConnectionIDCounter 
90271>>>>>>>            // This is the the DAW cConnect array with all registered connection id's.
90271>>>>>>>                Get ConnectionIDs of ghoConnection to ConnIdArray
90272>>>>>>>            Move (SizeOfArray(ConnIdArray)) to iSize
90273>>>>>>>            Decrement iSize
90274>>>>>>>            For iCount from 0 to iSize
90280>>>>>>>>
90280>>>>>>>                Move ConnIdArray[iCount].sDriver to sDriverConn
90281>>>>>>>                Move ConnIdArray[iCount].sId to sConnectionID2
90282>>>>>>>                Move (ConnIdArray[iCount].bDisabled = False) to bEnabled    
90283>>>>>>>                // If no psConnectionID specified in the cDbUpdateHandler, we check if there is a driver
90283>>>>>>>                // connection in the DAW cConnect object _and_ that there is only one!
90283>>>>>>>                If (sConnectionID = "") Begin
90285>>>>>>>                    Move (sDriverID = sDriverConn and bEnabled = True) to bFound 
90286>>>>>>>                End 
90286>>>>>>>>
90286>>>>>>>                Else Begin
90287>>>>>>>                    If (Uppercase(sConnectionID) = Uppercase(sConnectionID2)) Begin
90289>>>>>>>                        Move iSize to iCount // Then we've found what we were looking for and we're out of here... 
90290>>>>>>>                    End
90290>>>>>>>>
90290>>>>>>>                End
90290>>>>>>>>
90290>>>>>>>                    
90290>>>>>>>                If (bFound = True) Begin
90292>>>>>>>                    Increment iConnectionIDCounter
90293>>>>>>>                End
90293>>>>>>>>
90293>>>>>>>            Loop
90294>>>>>>>>
90294>>>>>>>            Move (iConnectionIDCounter <= 1 and sDriverConn <> "" and sConnectionID2 <> "") to bFound 
90295>>>>>>>            If (bFound = True) Begin
90297>>>>>>>                Move sConnectionID2 to sConnectionID
90298>>>>>>>            End
90298>>>>>>>>
90298>>>>>>>        End 
90298>>>>>>>>
90298>>>>>>>        
90298>>>>>>>        // Special case; a cConnection object has been setup in the cApplication,
90298>>>>>>>        // but no DFConn.ini record has been created.
90298>>>>>>>        If (iSize = -1) Begin
90300>>>>>>>            Move True to bFound
90301>>>>>>>        End
90301>>>>>>>>
90301>>>>>>>            
90301>>>>>>>        Function_Return bFound
90302>>>>>>>    End_Function
90303>>>>>>>    
90303>>>>>>>    // Send on object creation to read the default connection string settings, and
90303>>>>>>>    // create a connection to the server.
90303>>>>>>>    Function ReadSQLConnectionsIniSettings Returns tSQLConnection
90305>>>>>>>        String sPath sFileName sSection sConnectionString sPassword 
90305>>>>>>>        Boolean bExists
90305>>>>>>>        tSQLConnection[] SQLConnectionArray
90305>>>>>>>        tSQLConnection[] SQLConnectionArray
90306>>>>>>>        tSQLConnection SQLConnection SQLConnectionEmpty
90306>>>>>>>        tSQLConnection SQLConnection SQLConnectionEmpty
90306>>>>>>>        Handle hoIniFile
90306>>>>>>>        Integer iSize iCount
90306>>>>>>>        
90306>>>>>>>        Get psIniFilePath to sPath
90307>>>>>>>        Get phoSQLConnectionIniFile to hoIniFile
90308>>>>>>>        If (sPath = "") Begin
90310>>>>>>>            Get ApplicationPath of hoIniFile to sPath 
90311>>>>>>>            Set psIniFilePath   of hoIniFile to sPath 
90312>>>>>>>        End         
90312>>>>>>>>
90312>>>>>>>        Get vFolderFormat sPath to sPath
90313>>>>>>>        Get psIniFileName to sFileName    
90314>>>>>>>        Get vFilePathExists (sPath + sFileName) to bExists
90315>>>>>>>//        If (bExists = False) Begin   
90315>>>>>>>//            Move True to SQLConnection.bError
90315>>>>>>>//            Function_Return SQLConnectionEmpty 
90315>>>>>>>//        End                                                         
90315>>>>>>>        
90315>>>>>>>        Get SQLIniFileReadConnections of hoIniFile to SQLConnectionArray
90316>>>>>>>        Move (SizeOfArray(SQLConnectionArray)) to iSize
90317>>>>>>>        If (iSize = 0) Begin
90319>>>>>>>            // This may have been set by the "ReadcConnections" function,
90319>>>>>>>            // if a cConnection object has been setup for DataFlex 19 or later
90319>>>>>>>            // in the cApplication object.
90319>>>>>>>            Get pSQLConnection to SQLConnection
90320>>>>>>>            If (SQLConnection.sConnectionID = "") Begin
90322>>>>>>>                Function_Return SQLConnectionEmpty
90323>>>>>>>            End
90323>>>>>>>>
90323>>>>>>>            Move SQLConnection to SQLConnectionArray[0]
90324>>>>>>>        End
90324>>>>>>>>
90324>>>>>>>        
90324>>>>>>>        // The first connection should be the one that is active, but just in case...
90324>>>>>>>        Decrement iSize
90325>>>>>>>        For iCount from 0 to iSize
90331>>>>>>>>
90331>>>>>>>            Move SQLConnectionArray[iCount] to SQLConnection
90332>>>>>>>            If (SQLConnection.bEnabled = True) Begin
90334>>>>>>>                Move iSize to iCount // We've found the enabled item, so we're out of here.
90335>>>>>>>            End
90335>>>>>>>>
90335>>>>>>>        Loop
90336>>>>>>>>
90336>>>>>>>
90336>>>>>>>        Send CreateSQLConnection SQLConnection.sDriverID SQLConnection.sConnectionID ;             SQLConnection.sServer SQLConnection.sDatabase SQLConnection.bTrusted ;             SQLConnection.sUserID SQLConnection.sPassword SQLConnection.bSilentLogin   
90337>>>>>>>             
90337>>>>>>>        Set pSQLConnection to SQLConnection 
90338>>>>>>>        Send AutoSetConnectionID
90339>>>>>>>        
90339>>>>>>>        Function_Return SQLConnection
90340>>>>>>>    End_Function
