85056>>>>>//            // It will be displayed as the last item in the edit object.
85056>>>>>//            If (ghoApplication <> 0) Begin
85056>>>>>//                Get phoVersionInfo of ghoApplication to hoVersionInfo
85056>>>>>//                If (hoVersionInfo <> 0) Begin
85056>>>>>//                    Get pbIncluded of hoVersionInfo to bIncluded
85056>>>>>//                    If (bIncluded) Begin
85056>>>>>//                        Get piVersionMajor of hoVersionInfo to iMajor
85056>>>>>//                        Get piVersionMinor of hoVersionInfo to iMinor
85056>>>>>//                        Get piVersionRelease of hoVersionInfo to iRelease
85056>>>>>//                        Get piVersionBuild of hoVersionInfo to iBuild
85056>>>>>//                        Move (SFormat (C_$VERSION + ": %1.%2.%3.%4", iMajor, iMinor, iRelease, iBuild)) to sLabel
85056>>>>>//                        Set Version to sLabel
85056>>>>>//                    End
85056>>>>>//                End
85056>>>>>//            End
85056>>>>>//        End
85056>>>>>//
85056>>>>>//        Forward Send End_Construct_Object
85056>>>>>//    End_Procedure
