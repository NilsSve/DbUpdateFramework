92370>>>>>    // Returns a string array with all table names the passed table handle has relation ships with.
92370>>>>>    // The format of the array is "TableName.FieldName"
92370>>>>>    Function SqlUtilEnumerateRelations String sTableName String sDriverID Returns tSQLRelation[]
92372>>>>>        String[] sFileNameArray sFieldNameArray
92374>>>>>        tSQLRelation[] sRelationsArray
92374>>>>>        tSQLRelation[] sRelationsArray
92375>>>>>        String sServer sConnectionString sSelect sSchema sFileName sFieldName sVal
92375>>>>>        Boolean bOK  
92375>>>>>        Integer iCount iSize iLength iPos 
92375>>>>>        Integer iFileNumber iFieldNumber
92375>>>>>        
92375>>>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
92376>>>>>        If (bOK = False) Begin
92378>>>>>            Error DFERR_PROGRAM ("Unsupported driver. A list of table columns could not be retrieved for:" * sDriverID + ".")
92379>>>>>>
92379>>>>>            Function_Return sRelationsArray
92380>>>>>        End   
92380>>>>>>
92380>>>>>       
92380>>>>>        Get psConnectionString to sConnectionString  
92381>>>>>        Get psSchema to sSchema
92382>>>>>        
92382>>>>>        Case Begin
92382>>>>>            Case (sDriverID = MSSQLDRV_ID)    
92384>>>>>                Move ("SELECT object_name(parent_object_id), object_name(referenced_object_id), name from sys.foreign_keys WHERE parent_object_id = object_id( '" + sTableName + "')") to sSelect
92385>>>>>                Get SqlEnumerateEsqlDAW sSelect 2 to sFileNameArray
92386>>>>>                Get SqlEnumerateEsqlDAW sSelect 3 to sFieldNameArray
92387>>>>>                Case Break
92388>>>>>
92388>>>>>            Case (sDriverID = DB2_DRV_ID) 
92391>>>>>                Error "Not implemented yet! The select statement has not been finalized."
92392>>>>>>
92392>>>>>//                Move () to sSelect
92392>>>>>//                Get SqlEnumerateEsqlDAW sSelect 2 to sReturnArray
92392>>>>>//                Get SqlEnumerateEsqlDAW sSelect 3 to sFieldNameArray
92392>>>>>                Case Break
92393>>>>>
92393>>>>>            Case (sDriverID = SQLFLEX)
92396>>>>>                Error "Not implemented yet! The select statement has not been finalized."
92397>>>>>>
92397>>>>>//                Move () to sSelect
92397>>>>>//                Get SqlEnumerateEsqlMertech sSelect 2 to sReturnArray
92397>>>>>//                Get SqlEnumerateEsqlDAW sSelect 3 to sFieldNameArray
92397>>>>>                Case Break
92398>>>>>            
92398>>>>>            Case (sDriverID = MDSMySQL) 
92401>>>>>                Error "Not implemented yet! The select statement has not been finalized."
92402>>>>>>
92402>>>>>//                Move () to sSelect
92402>>>>>//                Get SqlEnumerateEsqlMertech sSelect 2 to sReturnArray
92402>>>>>//                Get SqlEnumerateEsqlDAW sSelect 3 to sFieldNameArray
92402>>>>>                Case Break
92403>>>>>            
92403>>>>>            Case (sDriverID = MDSPgSQL) 
92406>>>>>                Error "Not implemented yet! The select statement has not been finalized."
92407>>>>>>
92407>>>>>//                Move () to sSelect
92407>>>>>//                Get SqlEnumerateEsqlMertech sSelect 2 to sReturnArray
92407>>>>>//                Get SqlEnumerateEsqlDAW sSelect 3 to sFieldNameArray
92407>>>>>                Case Break            
92408>>>>>            
92408>>>>>            Case (sDriverID = ORAFLEX) 
92411>>>>>                Error "Not implemented yet! The select statement has not been finalized."
92412>>>>>>
92412>>>>>//                Move () to sSelect
92412>>>>>//                Get SqlEnumerateEsqlMertech sSelect to sReturnArray
92412>>>>>//                Get SqlEnumerateEsqlDAW sSelect 3 to sFieldNameArray
92412>>>>>                Case Break
92413>>>>>                            
92413>>>>>            Case Else     
92413>>>>>                Error DFERR_PROGRAM "Unsupported driver passed to the SqlUtilEnumerateRelations function."
92414>>>>>>
92414>>>>>                Case Break
92415>>>>>        Case End   
92415>>>>>        
92415>>>>>        Move (Length(sTableName)) to iLength
92416>>>>>        Move (iLength + 4)        to iLength // The related to field key has the format "FK_TableName + FieldName"
92417>>>>>        Move (SizeOfArray(sFileNameArray)) to iSize
92418>>>>>        Decrement iSize
92419>>>>>        For iCount from 0 to iSize
92425>>>>>>
92425>>>>>            If (Trim(sFileNameArray[iCount]) <> "") Begin
92427>>>>>                Move sFileNameArray[iCount]         to sFileName 
92428>>>>>                Move sFieldNameArray[iCount]        to sFieldName
92429>>>>>                Move (Mid(sFieldName, 99, iLength)) to sFieldName
92430>>>>>                Move sFileName  to sRelationsArray[iCount].sFileName
92431>>>>>                Move sFieldName to sRelationsArray[iCount].sFieldName
92432>>>>>            End
92432>>>>>>
92432>>>>>        Loop
92433>>>>>>
92433>>>>>        
92433>>>>>        Function_Return sRelationsArray
92434>>>>>    End_Function  
92435>>>>>    
92435>>>>>    Function SqlUtilEnumerateLoggedInUsers String sDriverID String sDatabase Returns tSQLLoggedInUser[]
92437>>>>>        tSQLLoggedInUser[] SQLLoggedInUser
92437>>>>>        tSQLLoggedInUser[] SQLLoggedInUser
92438>>>>>        String[] sUsers sPrograms
92440>>>>>        String sSelect 
92440>>>>>        Integer iSize iCount
92440>>>>>        
92440>>>>>        Case Begin
92440>>>>>            Case (sDriverID = MSSQLDRV_ID)
92442>>>>>                Move ("SELECT RTRIM(SP.nt_username) AS Inlog, RTRIM(SP.program_name) as Programma from master.dbo.sysprocesses SP INNER JOIN master.dbo.sysdatabases SD ON SP.dbid = SD.dbid WHERE (SP.nt_username <> '') and (SP.nt_username <> 'SYSTEM') and (SD.name = '" ;                + sDatabase + "') ORDER by Inlog") to sSelect
92443>>>>>                Get SqlEnumerateEsqlDAW sSelect 1 to sUsers
92444>>>>>                Get SqlEnumerateEsqlDAW sSelect 2 to sPrograms
92445>>>>>                Case Break
92446>>>>>            Case (sDriverID = SQLFLEX)
92449>>>>>                Move ("SELECT RTRIM(SP.nt_username) AS Inlog, RTRIM(SP.program_name) as Programma from master.dbo.sysprocesses SP INNER JOIN master.dbo.sysdatabases SD ON SP.dbid = SD.dbid WHERE (SP.nt_username <> '') and (SP.nt_username <> 'SYSTEM') and (SD.name = '" ;                + sDatabase + "') ORDER by Inlog") to sSelect
92450>>>>>                Get SqlEnumerateEsqlMertech sSelect 1 to sUsers
92451>>>>>                Get SqlEnumerateEsqlMertech sSelect 2 to sPrograms
92452>>>>>                Case Break                 
92453>>>>>            Case Else
92453>>>>>                Error DFERR_PROGRAM ("Not implemented yet for this driver (" + sDriverID + ")")
92454>>>>>>
92454>>>>>        Case End
92454>>>>>        
92454>>>>>        Move (SizeOfArray(sUsers)) to iSize
92455>>>>>        Decrement iSize
92456>>>>>        For iCount from 0 to iSize
92462>>>>>>
92462>>>>>            Move sUsers[iCount]    to SQLLoggedInUser[iCount].sUser
92463>>>>>            Move sPrograms[iCount] to SQLLoggedInUser[iCount].sProgram
92464>>>>>        Loop
92465>>>>>>
92465>>>>>        
92465>>>>>        Function_Return SQLLoggedInUser
92466>>>>>    End_Function 
92467>>>>>    
92467>>>>>    // Returns an array with all ".int" files for the passed sDataPath, _except_ for the driver .int files;
92467>>>>>    // "MSSQLDRV.int", "DB2_DRV.int" & "ODBC_DRV.int".
92467>>>>>    Function SqlUtilEnumerateIntFiles String sDataPath Returns String[]
92469>>>>>        String[] sFilesData
92470>>>>>        Boolean bExists
92470>>>>>        Integer iCh
92470>>>>>        String sFileName sExt
92470>>>>>        
92470>>>>>        Get vFolderExists sDataPath to bExists
92471>>>>>        If (bExists = True) Begin
92473>>>>>            Move (ToANSI(Trim(sDataPath))) to sDataPath
92474>>>>>            Move ("dir:" + sDataPath)      to sDataPath
92475>>>>>            Get Seq_New_Channel to iCh  // get free channel for input
92476>>>>>            Direct_Input channel iCh sDataPath
92478>>>>>                Repeat
92478>>>>>>
92478>>>>>                    Readln channel iCh sFileName
92480>>>>>                    Get ParseFileExtension sFileName to sExt
92481>>>>>                    If (Uppercase(sExt) = "INT") Begin
92483>>>>>                        If (not(Uppercase(sFileName) contains "MSSQLDRV" and Uppercase(sFileName) contains "DB2_DRV" and Uppercase(sFileName) contains "ODBC_DRV")) Begin
92485>>>>>                            Move sFileName to sFilesData[SizeOfArray(sFilesData)]
92486>>>>>                        End
92486>>>>>>
92486>>>>>                    End
92486>>>>>>
92486>>>>>                Until (SeqEof = True)
92488>>>>>            Close_Input channel iCh
92490>>>>>        End
92490>>>>>>
92490>>>>>        Function_Return sFilesData
92491>>>>>    End_Function                                  
92492>>>>>    
92492>>>>>    // Returns a handle to the SQL server associated with the passed driver ID.
92492>>>>>    // Pass e.g. the psServer property to determine the current connection server.
92492>>>>>    // Returns a handle to the database connection, or a zero (0) if it fails.
92492>>>>>    // This handle can be used to obtain attributes about the server, such as default
92492>>>>>    // column types.
92492>>>>>    Function SqlUtilDatabaseHandle String sDriverID String sServer Returns Handle
92494>>>>>        Handle hDatabase
92494>>>>>        Integer iDriver iServers iCount
92494>>>>>        String sValue
92494>>>>>        
92494>>>>>        If (sServer = "") Begin
92496>>>>>            Function_Return 0
92497>>>>>        End 
92497>>>>>>
92497>>>>>        
92497>>>>>        Get DriverIndex sDriverID to iDriver
92498>>>>>        If (iDriver = 0) Begin
92500>>>>>            Function_Return 0
92501>>>>>        End                  
92501>>>>>>
92501>>>>>        
92501>>>>>        Get_Attribute DF_DRIVER_NUMBER_SERVERS of iDriver to iServers
92504>>>>>        For iCount from 1 to iServers
92510>>>>>>
92510>>>>>            Get_Attribute DF_DRIVER_SERVER_NAME of iDriver iCount to sValue
92513>>>>>            If (Uppercase(sValue) contains Uppercase(sServer)) Begin
92515>>>>>                Get_Attribute DF_DATABASE_ID of iDriver iCount to hDatabase
92518>>>>>            End
92518>>>>>>
92518>>>>>        Loop
92519>>>>>>
92519>>>>>                
92519>>>>>        Function_Return hDatabase
92520>>>>>    End_Function
92521>>>>>
92521>>>>>    Procedure SqlUtilExecuteQuery String sStmt String sDriverID Boolean bShowProgr 
92523>>>>>        String sConnectionString sMessage
92523>>>>>        Handle hoSqlHandler hoSQLConnect hoStmt hoError
92523>>>>>        Integer i iMsgs iFetchResult iResultCount iRowType iRows iErr iMessage
92523>>>>>        String[] sMsg aSQLQueryMessages aSQLFetchResults
92526>>>>>        DateTime dtQueryExecStart dtQueryExecEnd dtFetchStart dtFetchEnd
92526>>>>>        TimeSpan tsQuery tsFetch
92526>>>>>        tSqlErrorArray aSqlErrorArray
92526>>>>>        tSqlErrorArray aSqlErrorArray
92526>>>>>        Boolean bOK bMertechDriver bShowProgress
92526>>>>>        tSQLConnection SQLConnection
92526>>>>>        tSQLConnection SQLConnection
92526>>>>>        
92526>>>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
92527>>>>>        If (bOK = False) Begin
92529>>>>>            Procedure_Return
92530>>>>>        End
92530>>>>>>
92530>>>>>        
92530>>>>>        If (num_arguments > 2) Begin
92532>>>>>            Move bShowProgr to bShowProgress
92533>>>>>        End
92533>>>>>>
92533>>>>>
92533>>>>>        Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
92534>>>>>        
92534>>>>>        Get IsMertechDriver sDriverID to bMertechDriver
92535>>>>>        If (bMertechDriver = True) Begin
92537>>>>>            Get _MertechSQLConnect sDriverID SQLConnection.sServer SQLConnection.sUserID SQLConnection.sPassword to hoSQLConnect
92538>>>>>        End
92538>>>>>>
92538>>>>>        If (bMertechDriver = False) Begin
92540>>>>>            Get phoSQLManager to hoSqlHandler
92541>>>>>            Send SqlSetConnect of hoSqlHandler sDriverID SQLConnection.sConnectionString
92542>>>>>            Get SqlConnect     of hoSqlHandler "" "" to hoSQLConnect
92543>>>>>        End
92543>>>>>>
92543>>>>>
92543>>>>>        If (hoSQLConnect <> 0) Begin
92545>>>>>            Get SqlOpen of hoSQLConnect to hoStmt
92546>>>>>            If (hoStmt <> 0) Begin
92548>>>>>                // record starting date/time stamp
92548>>>>>                Move (CurrentDateTime()) to dtQueryExecStart
92549>>>>>                // turn on error handling if enabled 
92549>>>>>                If (pbHandleQueryErrors(Self)) Begin
92551>>>>>                    Set pbSqlError to False 
92552>>>>>                    Set paSqlErrorArray to aSqlErrorArray
92553>>>>>                    Move Error_Object_Id to hoError
92554>>>>>                    Move Self to Error_Object_Id
92555>>>>>                End               
92555>>>>>>
92555>>>>>                
92555>>>>>                // Before we execute the statement; save it so we can display the faulty statement in the error log.
92555>>>>>                Set psSQLStatementString to sStmt
92556>>>>>                Send SqlExecDirect of hoStmt sStmt
92557>>>>>                
92557>>>>>                If (pbHandleQueryErrors(Self)) Begin
92559>>>>>                    Move hoError to Error_Object_Id
92560>>>>>                End       
92560>>>>>>
92560>>>>>                
92560>>>>>                Move 0 to iMsgs
92561>>>>>                // ToDo: There seems to be some issues with this code and Mertech drivers that makes
92561>>>>>                // the debugger crash in some cases like an error in the ESQL statement; so we exclude it for now.
92561>>>>>                If (bMertechDriver = False) Begin   
92563>>>>>                    Move Err to iErr
92564>>>>>                    Get SqlStmtAttribute of hoStmt SQLSTMTATTRIB_NUMMESSAGES   to iMsgs
92565>>>>>                    Get SqlStmtAttribute of hoStmt SqlSTMTATTRIB_ROWCOUNT      to iRows
92566>>>>>                    Get SqlStmtAttribute of hoStmt SqlSTMTATTRIB_ROWCOUNT_TYPE to iRowType
92567>>>>>                    Send _SqlColumnInfo hoStmt
92568>>>>>                    Send Ignore_Error of Error_Object_Id 12289    
92569>>>>>                    Set Error_Report_Mode to DUF_ERROR_NO_REPORT
92570>>>>>                    Repeat     
92570>>>>>>
92570>>>>>                        Get SqlFetch of hoStmt to iFetchResult
92571>>>>>                        If (iFetchResult <> 0) Begin
92573>>>>>                            Get SQLColumnValue of hoStmt 1 to aSQLFetchResults[SizeOfArray(aSQLFetchResults)]
92574>>>>>                        End
92574>>>>>>
92574>>>>>                    Until (iFetchResult = 0)
92576>>>>>                    Send Trap_Error of Error_Object_Id 12289    
92577>>>>>                    Set Error_Report_Mode to DUF_ERROR_REPORT 
92578>>>>>                    Move iErr to Err
92579>>>>>                    Set paSQLFetchResults to aSQLFetchResults
92580>>>>>                End 
92580>>>>>>
92580>>>>>                
92580>>>>>                Set piRows    to iRows
92581>>>>>                Set piRowType to iRowType
92582>>>>>                Move (CurrentDateTime()) to dtQueryExecEnd
92583>>>>>                Move (CurrentDateTime()) to dtFetchStart
92584>>>>>
92584>>>>>                If (iMsgs <> 0) Begin
92586>>>>>                    If (ghoDbUpdateHandler > 0) Begin
92588>>>>>                        Get paSQLQueryMessages of ghoDbUpdateHandler to aSQLQueryMessages
92589>>>>>                    End
92589>>>>>>
92589>>>>>                    For i from 1 to iMsgs
92595>>>>>>
92595>>>>>                        Get SqlGetMessage of hoStmt i to sMessage
92596>>>>>                        Get RemoveComponentIdentifier of hoStmt sMessage to sMessage
92597>>>>>                        If (bShowProgress = True) Begin
92599>>>>>                            If (Active_State(ghoStatusPanel)) Begin
92601>>>>>                                Send Update_StatusPanel of ghoStatusPanel (Sformat("  SQLGetMessage iMessage %1 returned [%2]",iMessage,sMessage))
92602>>>>>                            End                                                   
92602>>>>>>
92602>>>>>                            Else Begin
92603>>>>>                                Showln (Sformat("  SQLGetMessage iMessage %1 returned [%2]",iMessage,sMessage))
92605>>>>>                            End                                           
92605>>>>>>
92605>>>>>                        End
92605>>>>>>
92605>>>>>                        Move sMessage to sMsg[SizeOfArray(sMsg)]
92606>>>>>                        Move sMessage to aSQLQueryMessages[SizeOfArray(aSQLQueryMessages)]
92607>>>>>                    Loop
92608>>>>>>
92608>>>>>                    If (ghoDbUpdateHandler > 0) Begin
92610>>>>>                        Set paSQLQueryMessages of ghoDbUpdateHandler to aSQLQueryMessages
92611>>>>>                    End
92611>>>>>>
92611>>>>>                    Set paQueryMessages to sMsg  
92612>>>>>                End
92612>>>>>>
92612>>>>>                Move (CurrentDateTime()) to dtFetchEnd
92613>>>>>            End
92613>>>>>>
92613>>>>>            Move (dtQueryExecEnd - dtQueryExecStart) to tsQuery
92614>>>>>            Move (dtFetchStart - dtFetchEnd) to tsFetch
92615>>>>>            Set ptsQueryExec to tsQuery
92616>>>>>            Set ptsFetchResults to tsFetch
92617>>>>>            Send SqlClose of hoStmt
92618>>>>>        End
92618>>>>>>
92618>>>>>
92618>>>>>        Send SqlDisconnect of hoSQLConnect
92619>>>>>    End_Procedure
92620>>>>>
92620>>>>>    // *** Main message for executing an SQL script that has been compiled into the program as a resource ***
92620>>>>>    // Use the SQLIncludeScriptFile command to include an SQL script into the program.
92620>>>>>    // Returns False if no error occured.
92620>>>>>    Function SqlUtilExecuteResource String sMemFileName String sDriverID Boolean bCreateScriptFile Boolean bShowProgr Returns Boolean
92622>>>>>        Boolean bOK bShowProgress                               
92622>>>>>        tSQLScriptArray SQLScriptArray                      
92622>>>>>        tSQLScriptArray SQLScriptArray                      
92622>>>>>        Integer iOut iRows iCount
92622>>>>>        DateTime dtTotalQueryStart dtTotalQueryEnd
92622>>>>>        TimeSpan tsTotalTime  
92622>>>>>        String sMessage
92622>>>>>        
92622>>>>>        Move (CurrentDateTime()) to dtTotalQueryStart
92623>>>>>        Get SqlUtilReadResource sMemFileName to SQLScriptArray
92624>>>>>        If (SQLScriptArray.bError = True) Begin
92626>>>>>            Function_Return False
92627>>>>>        End
92627>>>>>>
92627>>>>>
92627>>>>>        If (num_arguments > 3) Begin
92629>>>>>            Move bShowProgr to bShowProgress
92630>>>>>        End
92630>>>>>>
92630>>>>>
92630>>>>>        Set Error_Report_Mode to DUF_ERROR_NO_REPORT
92631>>>>>        Get SqlUtilExecuteEmbeddedScript SQLScriptArray sDriverID bCreateScriptFile sMemFileName bShowProgress to bOK
92632>>>>>        Set Error_Report_Mode to DUF_ERROR_REPORT 
92633>>>>>        
92633>>>>>        If (SQLScriptArray.bArgumentSizeChanged = True) Begin
92635>>>>>            Set_Argument_Size SQLScriptArray.iOrgArgumentSize
92636>>>>>>
92636>>>>>        End
92636>>>>>>
92636>>>>>
92636>>>>>        Move (CurrentDateTime()) to dtTotalQueryEnd
92637>>>>>        Move (dtTotalQueryEnd - dtTotalQueryStart) to tsTotalTime
92638>>>>>        Set ptsTotalQueryTime to tsTotalTime
92639>>>>>        
92639>>>>>        Function_Return bOK
92640>>>>>    End_Procedure
