93157>>>>>    // Backs up an SQL database to a folder of choice. If no path is passed the SQL default backup folder
93157>>>>>    // will be used.
93157>>>>>    Function SqlUtilBackupDatabaseToDisk String sDatabase String sBackupName String sPath Boolean bShowProg Returns Boolean
93159>>>>>        Boolean bOK bExists bShowProgress      
93159>>>>>        String sStatement sDriverID 
93159>>>>>        tSQLScriptArray SQLScriptArray SQLScriptArrayPercentReady
93159>>>>>        tSQLScriptArray SQLScriptArray SQLScriptArrayPercentReady
93159>>>>>        Integer iDbType
93159>>>>>        
93159>>>>>        If (sDatabase = "") Begin
93161>>>>>            Error DFERR_PROGRAM "The database name was not passed as a parameter to the 'SqlUtilBackupDatabaseToDisk' function"
93162>>>>>>
93162>>>>>            Function_Return False
93163>>>>>        End
93163>>>>>>
93163>>>>>        If (sBackupName = "") Begin
93165>>>>>            Error DFERR_PROGRAM "The database backup name was not passed as a parameter to the 'SqlUtilBackupDatabaseToDisk' function"
93166>>>>>>
93166>>>>>            Function_Return False
93167>>>>>        End
93167>>>>>>
93167>>>>>            
93167>>>>>        // Create backup-folder if it doesn't exist
93167>>>>>        Get vFolderExists sPath to bExists
93168>>>>>        If (bExists = False) Begin
93170>>>>>            Get vCreateDirectory sPath to bOK
93171>>>>>            If (bOK = False) Begin
93173>>>>>                Error DFERR_PROGRAM ("Could not create database backup folder:" * sPath)
93174>>>>>>
93174>>>>>                Function_Return False
93175>>>>>            End
93175>>>>>>
93175>>>>>        End                     
93175>>>>>>
93175>>>>>        // Make sure the path ends with a back-slash
93175>>>>>        If (sPath <> "") Begin
93177>>>>>            Get vFolderFormat sPath to sPath
93178>>>>>        End
93178>>>>>>
93178>>>>>        
93178>>>>>        Get psDriverID to sDriverID  
93179>>>>>        Get piDbType   to iDbType        
93180>>>>>        If (num_arguments > 3) Begin
93182>>>>>            Move bShowProg to bShowProgress
93183>>>>>        End
93183>>>>>>
93183>>>>>        
93183>>>>>        Case Begin
93183>>>>>            Case (iDbType = EN_DbTypeMSSQL)
93185>>>>>                SQLIncludeScriptFile ..\Scripts\BackupMSSQLDatabase.sql as BackupMSSQLDatabase.sql
93185>>>>>                SQLIncludeScriptFile ..\Scripts\GetPercentageBackupCompletionMSSQL.sql as GetPercentageBackupCompletionMSSQL.sql
93185>>>>>                Get SqlUtilReadResource of ghoDbUpdateFunctionLibrary "BackupMSSQLDatabase.sql" sDriverID False to SQLScriptArray
93186>>>>>                Get SqlUtilReadResource of ghoDbUpdateFunctionLibrary "GetPercentageBackupCompletionMSSQL.sql" sDriverID False to SQLScriptArrayPercentReady
93187>>>>>                
93187>>>>>                Move SQLScriptArray.sSQLScriptArray[0] to sStatement
93188>>>>>                Move (Replaces("DATABASE_NAME_XXX", sStatement, sDatabase))   to sStatement
93189>>>>>                Move (Replaces("BACKUP_PATH_XXX",   sStatement, sPath))       to sStatement
93190>>>>>                Move (Replaces("BACKUP_NAME_XXX",   sStatement, sBackupName)) to sStatement
93191>>>>>                Move sStatement to SQLScriptArray.sSQLScriptArray[0]    
93192>>>>>                Get SqlUtilExecuteEmbeddedScript of ghoDbUpdateFunctionLibrary SQLScriptArray sDriverID False "" bShowProgress to bOK
93193>>>>>                Case Break
93194>>>>>            Case Else
93194>>>>>                Send Info_Box ("The SqlUtilBackupDatabaseToDisk function is currently not implemented for the driver:" * sDriverID + ". It would be great if you could spend a couple of minutes and add a little ESQL code snippet to make it work for that driver! Thanks for helping out.")
93195>>>>>        Case End
93195>>>>>        
93195>>>>>        Function_Return bOK    
93196>>>>>    End_Function
93197>>>>>
93197>>>>>    // Reads a resource that has been embedded by the compiler and writes it to disk.
93197>>>>>    // Pass the memory resource file reference and the filename to be created,
93197>>>>>    // including full path.
93197>>>>>    Procedure SqlUtilCreateFileFromMemory String sMemFileName String sFileName
93199>>>>>        String sText
93199>>>>>        Integer iCh iSize iArgSize  
93199>>>>>        
93199>>>>>        Move ("Resource:" + sMemFileName) to sMemFileName
93200>>>>>        Get Seq_Open_Input_Channel sMemFileName to iCh
93201>>>>>            Get_Channel_Size iCh to iSize
93202>>>>>            Get_Argument_Size to iArgSize
93203>>>>>            If (iSize > iArgSize) Begin
93205>>>>>                Set_Argument_Size iSize
93206>>>>>>
93206>>>>>            End
93206>>>>>>
93206>>>>>            Read_Block channel iCh sText iSize
93208>>>>>        Send Seq_Close_Channel iCh
93209>>>>>    
93209>>>>>        Get Seq_Open_Output_Channel sFileName to iCh
93210>>>>>            Write channel iCh sText
93212>>>>>        Send Seq_Close_Channel iCh
93213>>>>>    
93213>>>>>        If (iSize <> iArgSize) Begin
93215>>>>>            Set_Argument_Size iArgSize
93216>>>>>>
93216>>>>>        End
93216>>>>>>
93216>>>>>    
93216>>>>>        // Wait for file to be written to disk.
93216>>>>>        Sleep 2
93217>>>>>    End_Procedure 
