89445>>>>>>>>>//        Move False to Err
89445>>>>>>>>>//        Get psIniSectionName to sSection
89445>>>>>>>>>//        Get SQLIniFileNumberOfConnections to iCount
89445>>>>>>>>>//        Increment iCount
89445>>>>>>>>>//        Set IniFileValue sSection (CS_SQLIniSectionName + String(iCount)) to sFullConnectionString
89445>>>>>>>>>//        
89445>>>>>>>>>//        Function_Return (Err = False)
89445>>>>>>>>>//    End_Function
