85356>>>>>    // called before the list is activated. 
85356>>>>>    Procedure InitializePromptList
85358>>>>>        Integer hoInvokingObject
85358>>>>>        Boolean bAutoColumn bAutoSeed 
85358>>>>>        Integer i iOldMode eUpdateMode
85358>>>>>        String sValue
85358>>>>>        
85358>>>>>        Get peUpdateMode to eUpdateMode
85359>>>>>        If (eUpdateMode<>umPromptNonInvoking) Begin
85361>>>>>            Get Focus of Desktop to hoInvokingObject
85362>>>>>            If (hoInvokingObject<=Desktop) Begin
85364>>>>>                Error DFERR_PROGRAM "Prompt list has no invoking object"
85365>>>>>>
85365>>>>>                Procedure_Return
85366>>>>>            End
85366>>>>>>
85366>>>>>
85366>>>>>            Set phoInvokingObject to hoInvokingObject
85367>>>>>
85367>>>>>            Send Prompt_Callback to hoInvokingObject Self
85368>>>>>            Get peUpdateMode to eUpdateMode
85369>>>>>        End
85369>>>>>>
