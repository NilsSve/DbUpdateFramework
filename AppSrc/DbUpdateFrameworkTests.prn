93218>>>>>    // L„s f”rst .int fil och spara alla FIELD_INDEX + FIELD_NUMBER + FIELD_RELATED_FILE + FIELD_RELATED_FIELD i en struct array,
93218>>>>>    // INDEX_NUMBER + INDEX_NAME (string)
93218>>>>>    // samt spara undan .int "header rader" s† de kan skrivas ut senare.
93218>>>>>    // Check if index exists:    
93218>>>>>    //IF EXISTS (
93218>>>>>    //   SELECT 'X'
93218>>>>>    //   from sysindexes
93218>>>>>    //   WHERE id = (SELECT OBJECT_ID('accounts'))
93218>>>>>    //     and name = 'idx_acct_no'
93218>>>>>    //)          
93218>>>>>    //
93218>>>>>    // Helper function to create a SQL statement like;
93218>>>>>    // "SELECT * FROM SYS.INDEXES WHERE NAME = MyIndexName AND OBJECT_ID = OBJECT_ID([MySchmaName].[MyTableName])"
93218>>>>>    // Used for checking if an index exists.
93218>>>>>    Function _SqlQueryIfIndexExists String sSchemaName String sTableName String sIndexName Returns String
93220>>>>>        String sRetval sSelect sFrom sSysIndexes sWhere sObjectID sAnd sName
93220>>>>>        
93220>>>>>        Get _SqlFindKeyWord CI_SQLSelect to sSelect
93221>>>>>        Get _SqlFindKeyWord CI_SQLFrom to sFrom
93222>>>>>        Get _SqlFindKeyWord CI_SQLSysIndexes to sSysIndexes
93223>>>>>        Get _SqlFindKeyWord CI_SQLWhere to sWhere
93224>>>>>        Get _SqlFindKeyWord CI_SQLObjectID to sObjectID
93225>>>>>        Get _SqlFindKeyWord CI_SQLAND to sAnd
93226>>>>>        Get _SqlFindKeyWord CI_SQLName to sName
93227>>>>>        
93227>>>>>        Move (sSelect * String("*") * sFrom * sSysIndexes * sWhere * sName * "=" * sIndexName * sAnd * sObjectID * "=([" + sSchemaName + "].[" + sTableName + "])") to sRetval
93228>>>>>        
93228>>>>>        Function_Return sRetval
93229>>>>>    End_Function  
