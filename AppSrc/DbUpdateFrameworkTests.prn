94343>>>>>    Function ApiTableMoveToFileSlot Integer iFromFileSlot Integer iToFileSlot String sDriverID Returns Boolean
94345>>>>>        Boolean bTmp bErr bOK 
94345>>>>>        String sTableName sDisplayName sFileName sDBOKeyWord sVal
94345>>>>>        
94345>>>>>        // We preserve the value of the Err flag, by saving its current state and resetting it before end of function.
94345>>>>>        Move Err to bTmp
94346>>>>>        Move False to Err
94347>>>>>        
94347>>>>>        Get AutoConnectionIDLogin to bOK
94348>>>>>        // First get the info for the current filelist slot:
94348>>>>>        Open iFromFileSlot                      
94350>>>>>        Get_Attribute DF_FILE_OPENED of iFromFileSlot to bOK
94353>>>>>        If (bOK = True) Begin
94355>>>>>            Get_Attribute DF_FILE_ROOT_NAME    of iFromFileSlot to sFileName
94358>>>>>            Get_Attribute DF_FILE_LOGICAL_NAME of iFromFileSlot to sTableName
94361>>>>>            Get_Attribute DF_FILE_DISPLAY_NAME of iFromFileSlot to sDisplayName
94364>>>>>            
94364>>>>>            //...then move it.
94364>>>>>            Set_Attribute DF_FILE_ROOT_NAME    of iToFileSlot to sFileName
94367>>>>>            Set_Attribute DF_FILE_LOGICAL_NAME of iToFileSlot to sTableName
94370>>>>>            Set_Attribute DF_FILE_DISPLAY_NAME of iToFileSlot to sDisplayName
94373>>>>>            
94373>>>>>            //...and finally remove the old filelist values.
94373>>>>>            Set_Attribute DF_FILE_ROOT_NAME    of iFromFileSlot to ""
94376>>>>>            Set_Attribute DF_FILE_LOGICAL_NAME of iFromFileSlot to ""
94379>>>>>            Set_Attribute DF_FILE_DISPLAY_NAME of iFromFileSlot to ""
94382>>>>>        End
94382>>>>>>
94382>>>>>        Close iFromFileSlot
94383>>>>>        
94383>>>>>        Move Err to bErr                     
94384>>>>>        Move bTmp to Err
94385>>>>>        Function_Return (bErr = False)
94386>>>>>    End_Function
