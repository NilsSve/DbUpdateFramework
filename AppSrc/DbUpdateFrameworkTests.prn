83119>>>>>>>///
83119>>>>>>>/// @Assumptions
83119>>>>>>>/// @Status      Deprecated
83119>>>>>>>/// @Drivers     All
83119>>>>>>>/// @VersionNote Last Revised: 2013-08-20 by Aaron Gulack
83119>>>>>>>/// @See                 SQL_EXECUTE_STMT
83119>>>>>>>
83119>>>>>>>//=============================================================================
83119>>>>>>>/// @Name        LOCK_TABLE
83119>>>>>>>/// @Description Locks a table. This is equivalent to locking a DAT file.
83119>>>>>>>///
83119>>>>>>>/// @Assumptions
83119>>>>>>>/// @Status      Deprecated
83119>>>>>>>/// @Drivers     DB2Flex, and ORAFlex 3.x
83119>>>>>>>/// @VersionNote Last Revised: 2013-08-20 by Aaron Gulack
83119>>>>>>>/// @See
83119>>>>>>>///
83119>>>>>>>/// @Syntax LOCK_TABLE {FileName} {FileName1} {FileName2} {FileName3}...
83119>>>>>>>/// @Param  FileName            The name of file to be locked. Can be more than one
83119>>>>>>>
83119>>>>>>>//=============================================================================
83119>>>>>>>/// @Name        SQL_CHECK_TABLE
83119>>>>>>>/// @Description Use this command to verify that a given table exists on the
83119>>>>>>>/// SQL backend. This command takes three arguments, a string containing the
83119>>>>>>>/// name of the database, a string containing the name of the user and finally
83119>>>>>>>/// a string containing the name of the table being checked. If the table exists,
83119>>>>>>>/// the program proceeds normally. If the table does not exist then the flag
83119>>>>>>>/// "finderr" is set to true. Note that in order to handle the error a check must
83119>>>>>>>/// be done on the "finderr" variable.
83119>>>>>>>///
83119>>>>>>>/// @Assumptions All three parameters are less than 256 characters long.
83119>>>>>>>/// @Status      Public
83119>>>>>>>/// @Drivers     All
83119>>>>>>>/// @VersionNote Last Revised: 2013-08-20 by Aaron Gulack
83119>>>>>>>/// @See
83119>>>>>>>///
83119>>>>>>>/// @Syntax SQL_CHECK_TABLE {database} {username} {table}
83119>>>>>>>/// @Param  database            Name of the database
83119>>>>>>>/// @Param  username            Name of the user
83119>>>>>>>/// @Param  table                       Name of the table being checked
83119>>>>>>>///
83119>>>>>>>/// @Example
83119>>>>>>>/// SQL_CHECK_TABLE "testDB" "user" "Customer"
83119>>>>>>>/// If (finderr) Begin
83119>>>>>>>///     Showln "This table does not exist"
83119>>>>>>>/// End
83119>>>>>>>
83119>>>>>>>//=============================================================================
83119>>>>>>>/// @Name        SET_SQL_CONSTRAINT
83119>>>>>>>/// @Description This command allows you to put an additional constraint on
83119>>>>>>>/// your finds, moving filtering to the SQL backend. Using this command can
83119>>>>>>>/// result in significantly improved performance, since the server network traffic
83119>>>>>>>/// reduced. Note that the SQL statement passed for this command is added onto
83119>>>>>>>/// the predefined Database SQL statement so treat it as such. Because of this,
83119>>>>>>>/// it will almost always begin with "AND" followed by the desired constraint.
83119>>>>>>>///
83119>>>>>>>/// @Assumptions Parameter may be more than 255 characters long so redirect to method.
83119>>>>>>>/// @Status      Public
83119>>>>>>>/// @Drivers     All
83119>>>>>>>/// @VersionNote Last Revised: 2013-08-20 by Aaron Gulack
83119>>>>>>>/// @See         SQL_CONSTRAINT GET_SQL_CONSTRAINT DF_FIELD_PROGRAMMATIC_DEFAULT
83119>>>>>>>///
83119>>>>>>>/// @Syntax SET_SQL_CONSTRAINT of {file} to {variable}
83119>>>>>>>/// @Param  file                        Name or Number of the file.
83119>>>>>>>/// @Param  variable            A SQL expression that constrains the data
83119>>>>>>>///
83119>>>>>>>/// @Example
83119>>>>>>>/// Open Customer
83119>>>>>>>///
83119>>>>>>>/// SET_SQL_CONSTRAINT of 1 to (SFormat('AND "%1"."%2" = ' + "'%3'", "Customer", "Status", "Active"))
83119>>>>>>>///
83119>>>>>>>/// For_All Customer by Index.1 do
83119>>>>>>>///     Showln Customer.FirstName
83119>>>>>>>/// End_For_All
83119>>>>>>>
83119>>>>>>>Procedure MertechInc_SET_SQL_CONSTRAINT Global Integer iFunction String sConstraint
83121>>>>>>>    Call_Driver MertechInc_FileNumber MertechInc_DriverName Function iFunction CALLBACK 0 PASSING sConstraint MertechInc_Blank 0 RESULT MertechInc_iRet
83126>>>>>>>End_Procedure
83127>>>>>>>
83127>>>>>>>Procedure MertechInc_SET_SQL_CONSTRAINT_PROGRAMMATIC Global Integer iFunction
83129>>>>>>>    Call_Driver MertechInc_FileNumber MertechInc_DriverName Function iFunction CALLBACK 0 PASSING MertechInc_Blank MertechInc_Blank 4 RESULT MertechInc_iRet
83134>>>>>>>End_Procedure
83135>>>>>>>
83135>>>>>>>//=============================================================================
83135>>>>>>>/// @Name        GET_SQL_CONSTRAINT
83135>>>>>>>/// @Description This command returns the current SQL constraint for the given
83135>>>>>>>/// table.  If there is no current constraint, then a blank string is returned.
83135>>>>>>>///
83135>>>>>>>/// @Assumptions Parameter may be more than 255 characters long so redirect to method.
83135>>>>>>>/// @Status      Public
83135>>>>>>>/// @Drivers     All
83135>>>>>>>/// @VersionNote Last Revised: 2013-08-20 by Aaron Gulack
83135>>>>>>>/// @See         SQL_CONSTRAINT SET_SQL_CONSTRAINT
83135>>>>>>>///
83135>>>>>>>/// @Syntax GET_SQL_CONSTRAINT of {File} to {variable}
83135>>>>>>>/// @Param  File                        Name or number of the file
83135>>>>>>>/// @Param  variable            The string containing the constraining SQL expression
83135>>>>>>>///
83135>>>>>>>/// @Example
83135>>>>>>>/// Open Customer
83135>>>>>>>///
83135>>>>>>>/// String sCon
83135>>>>>>>///
83135>>>>>>>/// SET_SQL_CONSTRAINT of Customer to (SFormat('AND "%1"."%2" = ' + "'%3'", "Customer", "Status", "Active"))
83135>>>>>>>/// GET_SQL_CONSTRAINT of Customer to sCon
83135>>>>>>>///
83135>>>>>>>/// For_All Customer by Index.1 do
83135>>>>>>>///     Showln Customer.FirstName
83135>>>>>>>///     Showln sCon
83135>>>>>>>/// End_For_All
83135>>>>>>>
83135>>>>>>>Function MertechInc_GET_SQL_CONSTRAINT Global Integer iFunction Returns String
83137>>>>>>>    Local String sConstraint
83137>>>>>>>    Get MertechInc_Pre_Size_String 0 to sConstraint
83138>>>>>>>
83138>>>>>>>    Call_Driver MertechInc_FileNumber MertechInc_DriverName Function iFunction CALLBACK 0 PASSING sConstraint MertechInc_Blank 3 RESULT MertechInc_iRet
83143>>>>>>>    Function_Return sConstraint
83144>>>>>>>End_Function
83145>>>>>>>
83145>>>>>>>//=============================================================================
83145>>>>>>>/// @Name        SQL_CONSTRAINT
83145>>>>>>>/// @Description This command is used to toggle on or off the current SQL
83145>>>>>>>/// constraint that is set for a table. To deactivate the current constraint,
83145>>>>>>>/// pass the constant DEACTIVATE to this command. to reactivate the constraint,
83145>>>>>>>/// pass ACTIVATE to this command.
83145>>>>>>>///
83145>>>>>>>/// @Status      Public
83145>>>>>>>/// @Drivers     All
83145>>>>>>>/// @VersionNote Last Revised: 2013-08-20 by Aaron Gulack
83145>>>>>>>/// @See         SET_SQL_CONSTRAINT GET_SQL_CONSTRAINT
83145>>>>>>>///
83145>>>>>>>/// @Syntax SQL_CONSTRAINT of {File} to {Activate|Deactivate}
83145>>>>>>>/// @Param  File                        Name or Number of the file
83145>>>>>>>/// @Param  Activate            Activates the constraint
83145>>>>>>>/// @Param  Deactivate          Deactivates the constraint
83145>>>>>>>///
83145>>>>>>>/// @Example
83145>>>>>>>/// Open Customer
83145>>>>>>>///
83145>>>>>>>/// SET_SQL_CONSTRAINT of Customer to (SFormat('AND "%1"."%2" = ' + "'%3'", "Customer", "FirstName", "Aaron"))
83145>>>>>>>/// SQL_CONSTRAINT of Customer to Deactivate
83145>>>>>>>///
83145>>>>>>>/// For_All Customer by Index.1 do
83145>>>>>>>///     Showln Customer.FirstName
83145>>>>>>>/// End_For_All
83145>>>>>>>
83145>>>>>>>//=============================================================================
83145>>>>>>>/// @Name        CREATE_TD_FILE
83145>>>>>>>/// @Description A .TD file is created when the attribute is set to True.
83145>>>>>>>///
83145>>>>>>>/// @Assumptions
83145>>>>>>>/// @Status      Deprecated
83145>>>>>>>/// @Drivers     All
83145>>>>>>>/// @VersionNote Last Revised: 2013-08-20 by Aaron Gulack
83145>>>>>>>/// @See
83145>>>>>>>///
83145>>>>>>>/// @Syntax CREATE_TD_FILE {variable}
83145>>>>>>>/// @Param  variable            True to create the .TD file, false doesn't create it.
83145>>>>>>>
83145>>>>>>>//=============================================================================
83145>>>>>>>/// @Name        OPEN_INT
83145>>>>>>>/// @Description This command is used to replace the OPEN command in DataFlex.
83145>>>>>>>/// It can be useful when accessing tables that are not in the current filelist.
83145>>>>>>>/// To access these tables, the INT and FD files must be in the directory. From
83145>>>>>>>/// there, all that is needed is to open the table using this command under an
83145>>>>>>>/// alias name. If the command is executed successfully then the table can be
83145>>>>>>>/// queried normally as if it were a standard table. Note that if the desired
83145>>>>>>>/// table is already in the filelist or doesn't have an INT file then this
83145>>>>>>>/// command will act as a normal open command.
83145>>>>>>>///
83145>>>>>>>/// @Assumptions
83145>>>>>>>/// @Status      Public
83145>>>>>>>/// @Drivers     All
83145>>>>>>>/// @VersionNote Last Revised: 2013-08-21 by Aaron Gulack
83145>>>>>>>/// @See
83145>>>>>>>///
83145>>>>>>>/// @Syntax OPEN_INT {variable} as {aliasName}
83145>>>>>>>/// @Param  variable            The name of the int file without the extension.
83145>>>>>>>/// @Param  aliasName           The alias name being used to query this table.
83145>>>>>>>/// @Example
83145>>>>>>>/// OPEN_INT "customer" as Customer
83145>>>>>>>///
83145>>>>>>>/// For_All Customer by Index.1 do
83145>>>>>>>///     Showln Customer.FirstName
83145>>>>>>>/// End_For_All
83145>>>>>>>
83145>>>>>>>//=============================================================================
83145>>>>>>>/// @Name        SET_OPEN_MODE
83145>>>>>>>/// @Description This command is used to enable an option known as "Lazy Open
83145>>>>>>>/// Mode". When turned on the table's metadata i.e. table, columns, index
83145>>>>>>>/// descriptions, is deferred until a field is accessed, even if a OPEN has
83145>>>>>>>/// already been done. This can significantly improve an application's initial
83145>>>>>>>/// performance, especially when a large number of files are opened when the
83145>>>>>>>/// program is launched. By default, tables are set to open normally, but by
83145>>>>>>>/// passing the constant LAZY_MODE to this command, it can be altered to use
83145>>>>>>>/// this mode. Note that when this mode is activated, it effects all tables
83145>>>>>>>/// that are opened. To deactivate this feature, pass the constant "DEFAULT"
83145>>>>>>>/// to this command at any time. This is the preferred method to activate or
83145>>>>>>>/// deactive this feature but it can also be set globally in the .INI file.
83145>>>>>>>///
83145>>>>>>>/// Default Value: DEFAULT (Off)
83145>>>>>>>///
83145>>>>>>>/// @Assumptions
83145>>>>>>>/// @Status      Public
83145>>>>>>>/// @Drivers     All
83145>>>>>>>/// @VersionNote Last Revised: 2013-08-21 by Aaron Gulack
83145>>>>>>>/// @See
83145>>>>>>>///
83145>>>>>>>/// @Syntax SET_OPEN_MODE to {DEFAULT/LAZY_MODE}
83145>>>>>>>/// @Param  DEFAULT                     Used to turn of the lazy mode feature.
83145>>>>>>>/// @Param  LAZY_MODE           Turns on the lazy mode feature
83145>>>>>>>///
83145>>>>>>>/// @Example
83145>>>>>>>/// SET_OPEN_MODE TO LAZY_MODE
83145>>>>>>>/// Open "customer.int" as Customer
83145>>>>>>>/// ...
83145>>>>>>>/// ...
83145>>>>>>>/// Find gt Customer by Index.1
83145>>>>>>>
83145>>>>>>>//=============================================================================
83145>>>>>>>/// @Name        SQL_SET_STMT
83145>>>>>>>/// @Description Use this command to set an SQL statement to be executed on the
83145>>>>>>>/// desired table. The string passed to this command must be a valid SQL
83145>>>>>>>/// expression and must be on a table that has already been opened. Note that
83145>>>>>>>/// when using this command, the SQL_PREPARE_STMT and SQL_EXECUTE_STMT must be
83145>>>>>>>/// used in addition to carry out the expression. The option to pass the file
83145>>>>>>>/// name as an extra parameter is used in cases where the data needs to be
83145>>>>>>>/// fetched directly into the record buffer of the specified file.
83145>>>>>>>///
83145>>>>>>>/// @Assumptions Parameter may be more than 255 characters long so redirect to method.
83145>>>>>>>/// @Status      Public
83145>>>>>>>/// @Drivers     All
83145>>>>>>>/// @VersionNote Last Revised: 2013-08-21 by Aaron Gulack
83145>>>>>>>/// @See                 SQL_APPEND_STMT SQL_PREPARE_STMT SQL_EXECUTE_STMT SQL_CANCEL_QUERY_STMT SQL_FETCH_NEXT_ROW SQL_BINDCOLUMNS_STMT
83145>>>>>>>///
83145>>>>>>>/// @Syntax SQL_SET_STMT [of {file}] to {variable}
83145>>>>>>>/// @Param file                         Name or number of the file (optional)
83145>>>>>>>/// @Param variable                     String containing the SQL statement
83145>>>>>>>///
83145>>>>>>>/// @Usage SQL_SET_STMT of Customer to "SELECT * FROM CUSTOMER WHERE STATUS = 'Active'"
83145>>>>>>>/// @Usage SQL_SET_STMT to "SELECT * FROM CUSTOMER WHERE STATUS = 'Active'"
83145>>>>>>>///
83145>>>>>>>/// @Example
83145>>>>>>>/// Open Customer
83145>>>>>>>///
83145>>>>>>>/// String sID sFirstName sLastName sDOB
83145>>>>>>>///
83145>>>>>>>/// SQL_SET_STMT to "SELECT * FROM CUSTOMER WHERE STATUS = 'Active'"
83145>>>>>>>/// SQL_PREPARE_STMT
83145>>>>>>>/// SQL_EXECUTE_STMT
83145>>>>>>>/// While (Found)
83145>>>>>>>/// SQL_FETCH_NEXT_ROW into sID sFirstName sLastName sDOB
83145>>>>>>>///     Showln sID
83145>>>>>>>///     Showln sFirstName
83145>>>>>>>///     Showln sLastName
83145>>>>>>>///     Showln sDOB
83145>>>>>>>/// Loop
83145>>>>>>>/// SQL_CANCEL_QUERY_STMT
83145>>>>>>>
83145>>>>>>>Procedure MertechInc_SQL_SET_STMT Global String sStatment
83147>>>>>>>    Call_Driver MertechInc_FileNumber MertechInc_DriverName Function 22 CALLBACK 0 PASSING MertechInc_Blank sStatment 0 RESULT MertechInc_iRet
83152>>>>>>>End_Procedure
83153>>>>>>>
83153>>>>>>>//=============================================================================
83153>>>>>>>/// @Name        SQL_APPEND_STMT
83153>>>>>>>/// @Description This command is used to append a command string to the
83153>>>>>>>/// command buffer initialized by SQL_SET_STMT. SQL_APPEND_STMT was added
83153>>>>>>>/// so that long SQL expressions could be broken into smaller strings and
83153>>>>>>>/// appended to a dynamic command buffer, which is then passed to the server.
83153>>>>>>>/// The SQL_APPEND_STMT will concatenate a string to the command buffer
83153>>>>>>>/// initialized by the SQL_SET_STMT command. SQL_APPEND_STMT can be called as
83153>>>>>>>/// many times as necessary to complete the SQL expression. Subsequently, the
83153>>>>>>>/// SQL_EXECUTE_STMT command executes the completed command.  The option to
83153>>>>>>>/// pass the file name as an extra parameter is used in cases where the data
83153>>>>>>>/// needs to be fetched directly into the record buffer of the specified file.
83153>>>>>>>///
83153>>>>>>>/// @Assumptions Parameter may be more than 255 characters long so redirect to method.
83153>>>>>>>/// @Status      Public
83153>>>>>>>/// @Drivers     All
83153>>>>>>>/// @VersionNote Last Revised: 2013-08-22 by Aaron Gulack
83153>>>>>>>/// @See                 SQL_SET_STMT SQL_PREPARE_STMT SQL_EXECUTE_STMT SQL_CANCEL_QUERY_STMT SQL_FETCH_NEXT_ROW SQL_BINDCOLUMNS_STMT
83153>>>>>>>///
83153>>>>>>>/// @Syntax SQL_APPEND_STMT [of {file}] to {variable}
83153>>>>>>>/// @Param file                         The name or number of the file (optional)
83153>>>>>>>/// @Param variable                     The string to be appended to the current SQL expression
83153>>>>>>>///
83153>>>>>>>/// @Usage SQL_APPEND_STMT to " CUSTOMER.PHONE_NUMBER, CUSTOMER.FAX_NUMBER"
83153>>>>>>>/// @Usage SQL_APPEND_STMT of Customer to " CUSTOMER.PHONE_NUMBER, CUSTOMER.FAX_NUMBER"
83153>>>>>>>///
83153>>>>>>>/// @Example
83153>>>>>>>/// Open Customer
83153>>>>>>>///
83153>>>>>>>/// String sID sFirstName sLastName sDOB
83153>>>>>>>///
83153>>>>>>>/// SQL_SET_STMT to "SELECT * FROM CUSTOMER WHERE STATUS = 'Active'"
83153>>>>>>>/// SQL_PREPARE_STMT
83153>>>>>>>/// SQL_EXECUTE_STMT
83153>>>>>>>/// While (Found)
83153>>>>>>>///     SQL_FETCH_NEXT_ROW into sID sFirstName sLastName sDOB
83153>>>>>>>///     Showln sID
83153>>>>>>>///     Showln sFirstName
83153>>>>>>>///     Showln sLastName
83153>>>>>>>///     Showln sDOB
83153>>>>>>>/// Loop
83153>>>>>>>/// SQL_CANCEL_QUERY_STMT
83153>>>>>>>
83153>>>>>>>Procedure MertechInc_SQL_APPEND_STMT Global String sStatement
83155>>>>>>>    Call_Driver MertechInc_FileNumber MertechInc_DriverName Function 22 CALLBACK 0 PASSING MertechInc_Blank sStatement 1 RESULT MertechInc_iRet
83160>>>>>>>End_Procedure
83161>>>>>>>
83161>>>>>>>//=============================================================================
83161>>>>>>>/// @Name        APPEND_UPDATE_COLUMN
83161>>>>>>>/// @Description Append a given string to the existing SQL statement
83161>>>>>>>/// already set.
83161>>>>>>>///
83161>>>>>>>/// @Assumptions Parameter may be more than 255 characters long so redirect to method
83161>>>>>>>/// @Status      Internal
83161>>>>>>>/// @Drivers     All
83161>>>>>>>/// @VersionNote Last Revised: 2013-08-23 by Aaron Gulack
83161>>>>>>>/// @See
83161>>>>>>>///
83161>>>>>>>/// @Syntax APPEND_UPDCOL_STMT {variable} for {fileName}.{fieldName} {fields...}
83161>>>>>>>/// @Param variable                             SQL expression to be appended
83161>>>>>>>/// @Param fileName                             Name of the file
83161>>>>>>>/// @Param fieldName                    Name of the field
83161>>>>>>>/// @Param fields...                    Any additional fields, use the file.field format
83161>>>>>>>
83161>>>>>>>Procedure MertechInc_APPEND_UPDATE_COLUMN Global String sStatement
83163>>>>>>>    Call_Driver MertechInc_FileNumber MertechInc_DriverName Function 22 CALLBACK 0 PASSING MertechInc_Blank sStatement 1 RESULT MertechInc_iRet
83168>>>>>>>End_Procedure
83169>>>>>>>
83169>>>>>>>//=============================================================================
83169>>>>>>>/// @Name        SQL_APPEND_UPDCOL_STMT
83169>>>>>>>/// @Description Used to optimize the update process of columns being loaded
83169>>>>>>>/// with the same value.
83169>>>>>>>///
83169>>>>>>>/// @Assumptions
83169>>>>>>>/// @Status      Deprecated
83169>>>>>>>/// @Drivers     All
83169>>>>>>>/// @VersionNote Last Revised: 2013-08-23 by Aaron Gulack
83169>>>>>>>/// @See
83169>>>>>>>///
83169>>>>>>>/// @Syntax SQL_APPEND_UPDCOL_STMT [of {file}] Value {variable} for {fileName}.{fieldName} {fields...}
83169>>>>>>>/// @Param file                         The name or number of the file (optional)
83169>>>>>>>/// @Param variable                     The value being uploaded
83169>>>>>>>/// @Param fileName                     The name of the file
83169>>>>>>>/// @Param fieldName            The name of the field
83169>>>>>>>/// @Param fields...            Any additional fields, use the file.field format
83169>>>>>>>///
83169>>>>>>>/// @Example
83169>>>>>>>/// Open Customer
83169>>>>>>>///
83169>>>>>>>/// SQL_SET_STMT    of Customer to "UPDATE CUSTOMER SET"
83169>>>>>>>/// SQL_APPEND_STMT of Customer to " ASC11='x', ASC12='y', ASC13='z'"
83169>>>>>>>///
83169>>>>>>>/// SQL_APPEND_UPDCOL_STMT of Customer value 0 ;
83169>>>>>>>///     for Customer.ID Customer.Purchases Customer.Credit ;
83169>>>>>>>///
83169>>>>>>>/// SQL_APPEND_STMT of Customer to " WHERE RECNUM=1"
83169>>>>>>>///
83169>>>>>>>/// SQL_PREPARE_STMT of Customer
83169>>>>>>>/// SQL_EXECUTE_STMT of Customer
83169>>>>>>>
83169>>>>>>>//=============================================================================
83169>>>>>>>/// @Name        SQL_SET_CURSOR_TYPE
83169>>>>>>>/// @Description Specify the SQL cursor type to be used during the next
83169>>>>>>>/// embedded SQL statement execution.
83169>>>>>>>///
83169>>>>>>>/// @Assumptions
83169>>>>>>>/// @Status      Internal
83169>>>>>>>/// @Drivers     SQLFlex
83169>>>>>>>/// @VersionNote Last Revised: 2013-08-23 by Aaron Gulack
83169>>>>>>>/// @See
83169>>>>>>>///
83169>>>>>>>/// @Syntax SQL_SET_CURSOR_TYPE to {TYPE_NONE/TYPE_CLIENT/TYPE_SERVER}
83169>>>>>>>/// @Param TYPE_NONE                    the default cursor type should be used
83169>>>>>>>/// @Param TYPE_CLIENT                  a client side cursor should be used
83169>>>>>>>/// @Param TYPE_SERVER                  a server side cursor should be used
83169>>>>>>>
83169>>>>>>>//=============================================================================
83169>>>>>>>/// @Name        CLEAR_INT_CACHE
83169>>>>>>>/// @Description Clears all memory-cached INT info. This is used in the
83169>>>>>>>/// test framework to force a "reload" of int info which the framework
83169>>>>>>>/// modifies for its tests. This is a different cache than the TD files
83169>>>>>>>/// which are a file based cache of the structure for use at file open.
83169>>>>>>>///
83169>>>>>>>/// @Assumptions
83169>>>>>>>/// @Status      Internal
83169>>>>>>>/// @Drivers     All
83169>>>>>>>/// @VersionNote Last Revised: 2013-08-23 by Aaron Gulack
83169>>>>>>>/// @See
83169>>>>>>>///
83169>>>>>>>/// @Syntax CLEAR_INT_CACHE
83169>>>>>>>
83169>>>>>>>//=============================================================================
83169>>>>>>>/// @Name        CREATE_INVERSE_KEY_FUNCTIONS
83169>>>>>>>/// @Description Create SQL Functions to handle Inverse Key columns.
83169>>>>>>>///
83169>>>>>>>/// @Assumptions
83169>>>>>>>/// @Status      Internal
83169>>>>>>>/// @Drivers     All (v10.1 and above)
83169>>>>>>>/// @VersionNote Last Revised: 2013-08-23 by Aaron Gulack
83169>>>>>>>/// @See
83169>>>>>>>///
83169>>>>>>>/// @Syntax CREATE_INVERSE_KEY_FUNCTIONS
83169>>>>>>>
83169>>>>>>>//=============================================================================
83169>>>>>>>/// @Name        SQL_PREPARE_STMT
83169>>>>>>>/// @Description Prepares a statement and opens a cursor to be executed by
83169>>>>>>>/// SQL_EXECUTE_STMT. This command tells the server to parse the SQL statement
83169>>>>>>>/// created by the respective SQL_SET_STMT and all subsequent SQL_APPEND_STMT
83169>>>>>>>/// statements and to allocate cursor handles to be used to fetch the data.
83169>>>>>>>/// A cursor can be thought of as a pointer to a record set. The CURSOR_TYPE
83169>>>>>>>/// argument is only supported by SQLFlex and by default SQLFLex is using a
83169>>>>>>>/// TYPE_SERVER cursor type to all embedded SQL. TYPE_CLIENT should be used only
83169>>>>>>>/// for the statements that are querying LOB columns i.e. TEXT, NVARCHAR(MAX),
83169>>>>>>>/// VARCHAR(MAX), IMAGE, VARBINARY(MAX), XML. If the cursor type is
83169>>>>>>>/// TYPE_SERVER and a LOB type column is selected, MS SQL Server will not be
83169>>>>>>>/// able to get into a transaction, either explicitly or implicitly through a
83169>>>>>>>/// REREAD, LOCK, SAVERECORD, etc.
83169>>>>>>>///
83169>>>>>>>/// @Assumptions
83169>>>>>>>/// @Status      Public
83169>>>>>>>/// @Drivers     All
83169>>>>>>>/// @VersionNote Last Revised: 2013-08-23 by Aaron Gulack
83169>>>>>>>/// @See                 SQL_SET_STMT SQL_APPEND_STMT SQL_EXECUTE_STMT SQL_CANCEL_QUERY_STMT SQL_FETCH_NEXT_ROW SQL_BINDCOLUMNS_STMT
83169>>>>>>>///
83169>>>>>>>/// @Syntax SQL_PREPARE_STMT [of {file}] CURSOR_TYPE {TYPE_NONE/TYPE_CLIENT/TYPE_SERVER}
83169>>>>>>>/// @Param file                         The name or number of the file (optional)
83169>>>>>>>/// @Param CURSOR_TYPE          Used if the cursor type is being set, do not include otherwise
83169>>>>>>>/// @Param TYPE_NONE            Default cursor will be used
83169>>>>>>>/// @Param TYPE_CLIENT          A client side cursor should be used
83169>>>>>>>/// @Param TYPE_SERVER          A server side cursor should be used (Default)
83169>>>>>>>///
83169>>>>>>>/// @Usage SQL_PREPARE_STMT
83169>>>>>>>/// @Usage SQL_PREPARE_STMT of Customer
83169>>>>>>>/// @Usage SQL_PREPARE_STMT CURSOR_TYPE TYPE_SERVER
83169>>>>>>>/// @Usage SQL_PREPARE_STMT of Customer CURSOR_TYPE TYPE_CLIENT
83169>>>>>>>///
83169>>>>>>>/// @Example
83169>>>>>>>/// Open Customer
83169>>>>>>>///
83169>>>>>>>/// String sID sFirstName
83169>>>>>>>///
83169>>>>>>>/// SQL_SET_STMT to "SELECT * FROM CUSTOMER WHERE STATUS = 'Active'"
83169>>>>>>>/// SQL_PREPARE_STMT
83169>>>>>>>/// SQL_EXECUTE_STMT
83169>>>>>>>/// SQL_FETCH_NEXT_ROW into sID sFirstName
83169>>>>>>>
83169>>>>>>>//=============================================================================
83169>>>>>>>/// @Name        SQL_BIND_COLUMN
83169>>>>>>>/// @Description Clears all cached INT info. This should be merged with
83169>>>>>>>/// SQL_BINDCOLUMNS_STMT, but has to remain as a separate command for
83169>>>>>>>/// compatibility.
83169>>>>>>>///
83169>>>>>>>/// @Assumptions
83169>>>>>>>/// @Status      Internal
83169>>>>>>>/// @Drivers     All
83169>>>>>>>/// @VersionNote Last Revised: 2013-08-26 by Aaron Gulack
83169>>>>>>>/// @See
83169>>>>>>>///
83169>>>>>>>/// @Syntax SQL_BIND_COLUMN FileNumber FieldNumber | DF_BIND_ALL_COLUMNS
83169>>>>>>>/// @Param FileNumber                   The number of the file
83169>>>>>>>/// @Param FieldNumber                  The number of the field
83169>>>>>>>
83169>>>>>>>//=============================================================================
83169>>>>>>>/// @Name        SQL_BINDCOLUMNS_STMT
83169>>>>>>>/// @Description This command is used to fetch the returned data of a
83169>>>>>>>/// specified SQL expression into the given field in the record buffer. By
83169>>>>>>>/// passing any number of fields to this command, the fetched record will then
83169>>>>>>>/// be put into the subsequent fields in the record buffer. The order of the
83169>>>>>>>/// fields must be the same as the order of the columns being retrieved from
83169>>>>>>>/// the SQL expression. SQL_FETCH_NEXT_ROW can then be called to take the data
83169>>>>>>>/// retrieved from the server and place it into the corresponding fields in the
83169>>>>>>>/// buffer. Instead of specifying each field, DF_BIND_ALL_COLUMNS can be passed,
83169>>>>>>>/// which will retrieve every column in the table.
83169>>>>>>>///
83169>>>>>>>/// @Assumptions
83169>>>>>>>/// @Status      Public
83169>>>>>>>/// @Drivers     All
83169>>>>>>>/// @VersionNote Last Revised: 2013-08-26 by Aaron Gulack
83169>>>>>>>/// @See                 SQL_SET_STMT SQL_APPEND_STMT SQL_PREPARE_STMT SQL_EXECUTE_STMT SQL_CANCEL_QUERY_STMT SQL_FETCH_NEXT_ROW
83169>>>>>>>///
83169>>>>>>>/// @Syntax SQL_BINDCOLUMNS_STMT of {file} to {field/DF_BIND_ALL_COLUMNS}
83169>>>>>>>///
83169>>>>>>>/// @Param file                 Name or number of the file
83169>>>>>>>/// @Param field                        Name or number of the field (can be multiple)
83169>>>>>>>/// @Param DF_BIND_ALL_COLUMNS  Used instead of the field to retrieve all columns in the file
83169>>>>>>>///
83169>>>>>>>/// @Example
83169>>>>>>>/// Open Customer
83169>>>>>>>///
83169>>>>>>>/// SQL_SET_STMT to "SELECT * FROM CUSTOMER WHERE STATUS = 'Active' "
83169>>>>>>>/// SQL_PREPARE_STMT
83169>>>>>>>/// SQL_BINDCOLUMNS_STMT of Customer to DF_BIND_ALL_COLUMNS
83169>>>>>>>/// SQL_EXECUTE_STMT of Customer
83169>>>>>>>/// While (Found)
83169>>>>>>>///     SQL_FETCH_NEXT_ROW of Customer
83169>>>>>>>///     Showln Customer.ID
83169>>>>>>>///     Showln Customer.FirstName
83169>>>>>>>///     Showln Customer.LastName
83169>>>>>>>///     Showln Customer.DOB
83169>>>>>>>/// Loop
83169>>>>>>>/// SQL_CANCEL_QUERY_STMT
83169>>>>>>>
83169>>>>>>>//=============================================================================
83169>>>>>>>/// @Name        SQL_EXECUTE_STMT
83169>>>>>>>/// @Description This command is used to execute the SQL expression created
83169>>>>>>>/// by the SQL_SET_STMT and any subsequent SQL_APPEND_STMT commands issued
83169>>>>>>>/// after a SQL_PREPARE_STMT. If the results will be sent to the record
83169>>>>>>>/// buffer directly, then the file must be specified. An optional parameter
83169>>>>>>>/// can also be passed, indicating the maximum number of rows to be sent to
83169>>>>>>>/// the local cache. This is done by adding the constant ROWCOUNT followed
83169>>>>>>>/// by the maximun number.
83169>>>>>>>///
83169>>>>>>>/// @Assumptions
83169>>>>>>>/// @Status      Public
83169>>>>>>>/// @Drivers     All
83169>>>>>>>/// @VersionNote Last Revised: 2013-08-26 by Aaron Gulack
83169>>>>>>>/// @See                 SQL_SET_STMT SQL_APPEND_STMT SQL_PREPARE_STMT SQL_CANCEL_QUERY_STMT SQL_FETCH_NEXT_ROW SQL_BINDCOLUMNS_STMT
83169>>>>>>>///
83169>>>>>>>/// @Syntax SQL_EXECUTE_STMT [of {file} ROWCOUNT {variable}]
83169>>>>>>>/// @Param file                         Name or number of the file (optional)
83169>>>>>>>/// @Param variable                     Maximum number of rows to send to the local cache (optional)
83169>>>>>>>///
83169>>>>>>>/// @Usage SQL_EXECUTE_STMT
83169>>>>>>>/// @Usage SQL_EXECUTE_STMT of Customer
83169>>>>>>>/// @Usage SQL_EXECUTE_STMT of Customer ROWCOUNT 10
83169>>>>>>>///
83169>>>>>>>/// @Example
83169>>>>>>>/// Open Customer
83169>>>>>>>///
83169>>>>>>>/// SQL_SET_STMT to "SELECT * FROM CUSTOMER WHERE STATUS = 'Active' "
83169>>>>>>>/// SQL_PREPARE_STMT
83169>>>>>>>/// SQL_BINDCOLUMNS_STMT of Customer to DF_BIND_ALL_COLUMNS
83169>>>>>>>/// SQL_EXECUTE_STMT of Customer
83169>>>>>>>/// While (Found)
83169>>>>>>>///     SQL_FETCH_NEXT_ROW of Customer
83169>>>>>>>///     Showln Customer.ID
83169>>>>>>>///     Showln Customer.FirstName
83169>>>>>>>///     Showln Customer.LastName
83169>>>>>>>///     Showln Customer.DOB
83169>>>>>>>/// Loop
83169>>>>>>>/// SQL_CANCEL_QUERY_STMT
83169>>>>>>>
83169>>>>>>>
83169>>>>>>>//This alias may be redundant. Is was only called from MertechInc_SQL_FUNCTION_EXECUTE
83169>>>>>>>//which has been recoded to directly call SQL_EXECUTE_STMT - I.S. 2009-09-19
83169>>>>>>>Procedure MertechInc_SQL_PROCEDURE_EXECUTE Global
83171>>>>>>>    SQL_EXECUTE_STMT
83186>>>>>>>End_Procedure
83187>>>>>>>
83187>>>>>>>//=============================================================================
83187>>>>>>>/// @Name        SQL_START_TRANSACTION_STMT
83187>>>>>>>/// @Description Transactions in SQL are used to maintain atomicity within
83187>>>>>>>/// an process. If one procedure in the transaction fails, then they all
83187>>>>>>>/// will fail. This command is used to start an SQL transaction. Inside of
83187>>>>>>>/// a transaction, there can be any number of SQL statements, none of which
83187>>>>>>>/// will be executed until SQL_COMMIT_STMT is called. Note that transactions
83187>>>>>>>/// are generally only needed when a table is being altered.
83187>>>>>>>///
83187>>>>>>>/// @Assumptions
83187>>>>>>>/// @Status      Public
83187>>>>>>>/// @Drivers     All
83187>>>>>>>/// @VersionNote Last Revised: 2013-08-26 by Aaron Gulack
83187>>>>>>>/// @See         SQL_COMMIT_STMT SQL_ROLLBACK_STMT
83187>>>>>>>///
83187>>>>>>>/// @Syntax SQL_START_TRANSACTION_STMT
83187>>>>>>>///
83187>>>>>>>/// @Example
83187>>>>>>>/// SQL_START_TRANSACTION_STMT
83187>>>>>>>/// SQL_SET_STMT to "UPDATE CUSTOMER SET STATUS = 'Inactive'"
83187>>>>>>>/// SQL_PREPARE_STMT
83187>>>>>>>/// SQL_EXECUTE_STMT
83187>>>>>>>/// SQL_COMMIT_STMT
83187>>>>>>>
83187>>>>>>>//=============================================================================
83187>>>>>>>/// @Name        SQL_COMMIT_STMT
83187>>>>>>>/// @Description Just as the SQL_EXECUTE_STMT is used to execute the SQL
83187>>>>>>>/// statement in the block, this command is used to commit the transaction
83187>>>>>>>/// started by SQL_START_TRANSACTION_STMT. When this command is called, any
83187>>>>>>>/// preceding statements or procedures that are apart of the transaction will
83187>>>>>>>/// be committed. If one or more of these statements fail, then none of them
83187>>>>>>>/// will be successful, thus maintaining atomicity.
83187>>>>>>>///
83187>>>>>>>/// @Assumptions
83187>>>>>>>/// @Status      Public
83187>>>>>>>/// @Drivers     All
83187>>>>>>>/// @VersionNote Last Revised: 2013-08-27 by Aaron Gulack
83187>>>>>>>/// @See                 SQL_START_TRANSACTION_STMT SQL_ROLLBACK_STMT
83187>>>>>>>///
83187>>>>>>>/// @Syntax SQL_COMMIT_STMT
83187>>>>>>>///
83187>>>>>>>/// @Example
83187>>>>>>>/// SQL_START_TRANSACTION_STMT
83187>>>>>>>/// SQL_SET_STMT to "UPDATE CUSTOMER SET STATUS = 'Inactive'"
83187>>>>>>>/// SQL_PREPARE_STMT
83187>>>>>>>/// SQL_EXECUTE_STMT
83187>>>>>>>/// SQL_COMMIT_STMT
83187>>>>>>>
83187>>>>>>>//=============================================================================
83187>>>>>>>/// @Name        SQL_ROLLBACK_STMT
83187>>>>>>>/// @Description Rolls back an SQL transaction, any data changes inside the
83187>>>>>>>/// transaction will not be committed by the server.
83187>>>>>>>///
83187>>>>>>>/// @Assumptions
83187>>>>>>>/// @Status      Public
83187>>>>>>>/// @Drivers     All
83187>>>>>>>/// @VersionNote Last Revised: 2013-08-27 by Aaron Gulack
83187>>>>>>>/// @See                 SQL_START_TRANSACTION_STMT SQL_COMMIT_STMT
83187>>>>>>>///
83187>>>>>>>/// @Syntax SQL_ROLLBACK_STMT
83187>>>>>>>///
83187>>>>>>>/// @Example
83187>>>>>>>/// SQL_START_TRANSACTION_STMT
83187>>>>>>>/// SQL_SET_STMT to "DELETE FROM CUSTOMER WHERE ID = 2145"
83187>>>>>>>/// SQL_PREPARE_STMT
83187>>>>>>>/// SQL_EXECUTE_STMT
83187>>>>>>>/// If (Err) Begin
83187>>>>>>>///             SQL_ERROR_MESSAGE errorString
83187>>>>>>>///     Showln errorString
83187>>>>>>>///     SQL_ROLLBACK_STMT
83187>>>>>>>/// End
83187>>>>>>>/// Else
83187>>>>>>>///     Showln "SQL Statement successful - committing"
83187>>>>>>>///     SQL_COMMIT_STMT
83187>>>>>>>
83187>>>>>>>//=============================================================================
83187>>>>>>>/// @Name        SET_TRANSACTIONS_ALLOWED
83187>>>>>>>/// @Description This command is used to toggle on or off the ability to
83187>>>>>>>/// complete transaction to the server. Passing false to this command will
83187>>>>>>>/// not allow transactions to be made, passing true will allow the transactions.
83187>>>>>>>///
83187>>>>>>>/// @Assumptions
83187>>>>>>>/// @Status      Internal
83187>>>>>>>/// @Drivers     All
83187>>>>>>>/// @VersionNote Last Revised: 2013-08-27 by Aaron Gulack
83187>>>>>>>/// @See
83187>>>>>>>///
83187>>>>>>>/// @Syntax SET_TRANSACTIONS_ALLOWED of {server} to {variable}
83187>>>>>>>/// @Param server                               The name of the server being used
83187>>>>>>>/// @Param variable                     Boolean to enable or disable transactions
83187>>>>>>>///
83187>>>>>>>/// @Example
83187>>>>>>>/// SET_TRANSACTIONS_ALLOWED of "localhost" to True
83187>>>>>>>
83187>>>>>>>//=============================================================================
83187>>>>>>>/// @Name        SQL_FETCH_NEXT_ROW
83187>>>>>>>/// @Description This command is used to fetch the next row returned by the
83187>>>>>>>/// associated SQL statement. The SQL statement is created from the
83187>>>>>>>/// SQL_SET_STMT and executed with the SQL_EXECUTE_STMT. This command can be
83187>>>>>>>/// used in two ways. If the results are to be attached to variables, then no
83187>>>>>>>/// file needs to be specified, just the variables for each column in the row.
83187>>>>>>>/// If the results are to be inserted into the record buffer directly, then the
83187>>>>>>>/// file must be specified. From there, a SQL_BINDCOLUMNS_STMT can be used to
83187>>>>>>>/// bind the fetched row to the specific fields in the file. Note that the
83187>>>>>>>/// columns are fecthed in the order that the SQL statement generates them, so
83187>>>>>>>/// the variables must follow the same order. The two constants, "found" and
83187>>>>>>>/// "finderr" are set depending on whether the next row was found.
83187>>>>>>>///
83187>>>>>>>/// @Assumptions
83187>>>>>>>/// @Status      Public
83187>>>>>>>/// @Drivers     All
83187>>>>>>>/// @VersionNote Last Revised: 2013-08-27 by Aaron Gulack
83187>>>>>>>/// @See                 SQL_SET_STMT SQL_APPEND_STMT SQL_PREPARE_STMT SQL_EXECUTE_STMT SQL_CANCEL_QUERY_STMT SQL_BINDCOLUMNS_STMT
83187>>>>>>>///
83187>>>>>>>/// @Syntax SQL_FETCH_NEXT_ROW [of {file}] into {variable}
83187>>>>>>>/// @Param  file                                The name or number of the file
83187>>>>>>>/// @Param  variable                    The variable that the next column in the fetched row will be put into (can be multiple)
83187>>>>>>>///
83187>>>>>>>/// @Usage SQL_FETCH_NEXT_ROW of Customer
83187>>>>>>>/// @Usage SQL_FETCH_NEXT_ROW into sRecnum sID
83187>>>>>>>///
83187>>>>>>>/// @Example
83187>>>>>>>/// String sID sRecnum
83187>>>>>>>///
83187>>>>>>>/// SQL_SET_STMT to "SELECT * FROM CUSTOMER ID"
83187>>>>>>>/// SQL_APPEND_STMT to " BY NAME DESC"
83187>>>>>>>/// SQL_PREPARE_STMT
83187>>>>>>>/// SQL_EXECUTE_STMT
83187>>>>>>>/// While (found)
83187>>>>>>>///     SQL_FETCH_NEXT_ROW into sRecnum sID
83187>>>>>>>///     If (found) Begin
83187>>>>>>>///             Showln sID
83187>>>>>>>///    End
83187>>>>>>>/// Loop
83187>>>>>>>/// SQL_CANCEL_QUERY_STMT
83187>>>>>>>///
83187>>>>>>>/// @Example
83187>>>>>>>/// Open Customer
83187>>>>>>>///
83187>>>>>>>/// SQL_SET_STMT of Customer to "SELECT * FROM CUSTOMER WHERE STATUS = 'Active'"
83187>>>>>>>/// SQL_PREPARE_STMT of Customer
83187>>>>>>>/// SQL_BINDCOLUMNS_STMT of Customer to DF_BIND_ALL_COLUMNS
83187>>>>>>>/// SQL_EXECUTE_STMT of Customer
83187>>>>>>>/// While (Found)
83187>>>>>>>///     SQL_FETCH_NEXT_ROW of Customer
83187>>>>>>>///     Showln Customer.ID
83187>>>>>>>///     Showln Customer.FirstName
83187>>>>>>>///             Showln Customer.LastName
83187>>>>>>>/// Loop
83187>>>>>>>/// SQL_CANCEL_QUERY_STMT
83187>>>>>>>
83187>>>>>>>
83187>>>>>>>//=============================================================================
83187>>>>>>>/// @Name        GET_RESULT_SET
83187>>>>>>>/// @Description Fetches the next row in the result set returned by a
83187>>>>>>>/// query or stored procedure.
83187>>>>>>>///
83187>>>>>>>/// @Assumptions
83187>>>>>>>/// @Status      Deprecated
83187>>>>>>>/// @Drivers     All
83187>>>>>>>/// @VersionNote Last Revised: 2013-08-27 by Aaron Gulack
83187>>>>>>>/// @See
83187>>>>>>>///
83187>>>>>>>/// @Syntax GET_RESULT_SET into {variable}
83187>>>>>>>/// @Param variable                     The variable receiving the result (can be multiple)
83187>>>>>>>
83187>>>>>>>//=============================================================================
83187>>>>>>>/// @Name        SQL_GET_DATA_CHUNK
83187>>>>>>>/// @Description This command is used to get a chunk of data from a column
83187>>>>>>>/// retrieved through an embedded SQL statement. By passing the column number
83187>>>>>>>/// and the offset number, the chunk will be put into the specified variable.
83187>>>>>>>/// To specify how big of a chunk to get, use the SQL_SET_CHUNK_SIZE command.
83187>>>>>>>/// Otherwise the maximum length will be retrieved. An optional variable can
83187>>>>>>>/// also be passed which will store the length of the chunk. Note that unlike
83187>>>>>>>/// LOB_READ, this command works for any column type, not just LOB columns.
83187>>>>>>>///
83187>>>>>>>/// @Assumptions
83187>>>>>>>/// @Status      Public
83187>>>>>>>/// @Drivers     SQLFlex
83187>>>>>>>/// @VersionNote Last Revised: 2013-10-04 by Aaron Gulack
83187>>>>>>>/// @See                 SQL_SET_CHUNK_SIZE SQL_GET_CHUNK_SIZE SQL_SET_MAX_DATA_SIZE SQL_GET_MAX_DATA_SIZE
83187>>>>>>>///
83187>>>>>>>/// @Syntax SQL_GET_DATA_CHUNK COLUMN {column} OFFSET {offset} to {variable} {length}
83187>>>>>>>/// @Param column                               Column number to get chunk from
83187>>>>>>>/// @Param offset                       Offset to start at for the chunk
83187>>>>>>>/// @Param variable                     Variable to hold the returned chunk
83187>>>>>>>/// @Param length                       Variable to hold the chunk length
83187>>>>>>>///
83187>>>>>>>/// @Example
83187>>>>>>>/// SQL_SET_STMT to "SELECT * FROM CUSTOMER WHERE STATUS = 'Active' "
83187>>>>>>>/// SQL_PREPARE_STMT
83187>>>>>>>/// SQL_EXECUTE_STMT
83187>>>>>>>/// SQL_FETCH_NEXT_ROW into sID sBio
83187>>>>>>>/// If (Found) Begin
83187>>>>>>>///     SQL_SET_CHUNK_SIZE to 150
83187>>>>>>>///     SQL_GET_DATA_CHUNK COLUMN 6 OFFSET 1 to sChunk iLength
83187>>>>>>>///     Showln sChunk
83187>>>>>>>///     Showln iLength
83187>>>>>>>/// End
83187>>>>>>>
83187>>>>>>>Function MertechInc_SQL_GET_DATA_CHUNK Global Integer iColumn Integer iOffset Returns String
83189>>>>>>>    Local Integer iChuck_Size
83189>>>>>>>    Local String sChunk
83189>>>>>>>
83189>>>>>>>    //Get current Chuck size and pre size string
83189>>>>>>>    Call_Driver 0 MertechInc_DriverName Function CALLDRV_CHUNK_SIZE CALLBACK 0 PASSING iChuck_Size MertechInc_Blank 1 RESULT MertechInc_iRet
83194>>>>>>>    Get MertechInc_Pre_Size_String iChuck_Size to sChunk
83195>>>>>>>
83195>>>>>>>    //Get data
83195>>>>>>>    Call_Driver 0 MertechInc_DriverName Function CALLDRV_GET_DATA_CHUNK CALLBACK 0 PASSING iColumn sChunk iOffset RESULT MertechInc_iRet
83200>>>>>>>
83200>>>>>>>    //sArg1 (iColumn) contains the number of bytes returned, so move it to
83200>>>>>>>    //MertechInc_Arg1 to pass the value back
83200>>>>>>>    Move iColumn to MertechInc_sArg1
83201>>>>>>>
83201>>>>>>>    Function_Return sChunk
83202>>>>>>>End_Function
83203>>>>>>>
83203>>>>>>>//=============================================================================
83203>>>>>>>/// @Name        SQL_SET_CHUNK_SIZE
83203>>>>>>>/// @Description This command sets the size of the chunk to retrieve when
83203>>>>>>>/// using SQL_GET_DATA_CHUNK. Whatever number is set here will be the
83203>>>>>>>/// length of the chunk that is retrieved, as long as it does not exceed
83203>>>>>>>/// the maximum chunk size.
83203>>>>>>>///
83203>>>>>>>/// @Assumptions
83203>>>>>>>/// @Status      Public
83203>>>>>>>/// @Drivers     SQLFlex
83203>>>>>>>/// @VersionNote Last Revised: 2013-10-04 by Aaron Gulack
83203>>>>>>>/// @See                 SQL_GET_DATA_CHUNK SQL_GET_CHUNK_SIZE SQL_SET_MAX_DATA_SIZE SQL_GET_MAX_DATA_SIZE
83203>>>>>>>///
83203>>>>>>>/// @Syntax SQL_SET_CHUNK_SIZE to {variable}
83203>>>>>>>/// @Param variable                     Length of chunk to retrive
83203>>>>>>>///
83203>>>>>>>/// @Example
83203>>>>>>>/// SQL_SET_STMT to "SELECT * FROM CUSTOMER WHERE STATUS = 'Active' "
83203>>>>>>>/// SQL_PREPARE_STMT
83203>>>>>>>/// SQL_EXECUTE_STMT
83203>>>>>>>/// SQL_FETCH_NEXT_ROW into sID sBio
83203>>>>>>>/// If (Found) Begin
83203>>>>>>>///     SQL_SET_CHUNK_SIZE to 150
83203>>>>>>>///     SQL_GET_DATA_CHUNK COLUMN 6 OFFSET 1 to sChunk iLength
83203>>>>>>>///     Showln sChunk
83203>>>>>>>///     Showln iLength
83203>>>>>>>/// End
83203>>>>>>>
83203>>>>>>>//=============================================================================
83203>>>>>>>/// @Name        SQL_GET_CHUNK_SIZE
83203>>>>>>>/// @Description This command gets the size of the chunk being retrieved
83203>>>>>>>/// from SQL_GET_DATA_CHUNK and puts it into the specified variable.
83203>>>>>>>///
83203>>>>>>>/// @Assumptions
83203>>>>>>>/// @Status      Public
83203>>>>>>>/// @Drivers     SQLFlex
83203>>>>>>>/// @VersionNote Last Revised: 2013-10-04 by Aaron Gulack
83203>>>>>>>/// @See                 SQL_SET_CHUNK_SIZE SQL_GET_DATA_CHUNK SQL_SET_MAX_DATA_SIZE SQL_GET_MAX_DATA_SIZE
83203>>>>>>>///
83203>>>>>>>/// @Syntax SQL_GET_CHUNK_SIZE to {variable}
83203>>>>>>>/// @Param variable             Variable to hold the chunk size
83203>>>>>>>///
83203>>>>>>>/// @Example
83203>>>>>>>/// SQL_GET_CHUNK_SIZE to iLength
83203>>>>>>>
83203>>>>>>>//=============================================================================
83203>>>>>>>/// @Name        SQL_SET_MAX_DATA_SIZE
83203>>>>>>>/// @Description This command sets the maximum size for data chunks
83203>>>>>>>/// retrieved through SQL_GET_DATA_CHUNK. If SQL_SET_CHUNK_SIZE is higher
83203>>>>>>>/// than the maximum size set with this command, then this will override
83203>>>>>>>/// it and the chunk will be no longer than the maximum size set here.
83203>>>>>>>///
83203>>>>>>>/// @Assumptions
83203>>>>>>>/// @Status      Public
83203>>>>>>>/// @Drivers     SQLFlex
83203>>>>>>>/// @VersionNote Last Revised: 2013-10-04 by Aaron Gulack
83203>>>>>>>/// @See                 SQL_SET_CHUNK_SIZE SQL_GET_CHUNK_SIZE SQL_GET_DATA_CHUNK SQL_GET_MAX_DATA_SIZE
83203>>>>>>>///
83203>>>>>>>/// @Syntax SQL_SET_MAX_DATA_SIZE to {variable}
83203>>>>>>>/// @Param variable                     Max length to allow for chunks
83203>>>>>>>///
83203>>>>>>>/// @Example
83203>>>>>>>/// SQL_SET_MAX_DATA_SIZE to 1000
83203>>>>>>>
83203>>>>>>>//=============================================================================
83203>>>>>>>/// @Name        SQL_GET_MAX_DATA_SIZE
83203>>>>>>>/// @Description This command returns the maximum chunk size allowed
83203>>>>>>>/// for SQL_GET_DATA_CHUNK.
83203>>>>>>>///
83203>>>>>>>/// @Assumptions
83203>>>>>>>/// @Status      Public
83203>>>>>>>/// @Drivers     SQLFlex
83203>>>>>>>/// @VersionNote Last Revised: 2013-10-04 by Aaron Gulack
83203>>>>>>>/// @See                 SQL_SET_CHUNK_SIZE SQL_GET_CHUNK_SIZE SQL_GET_DATA_CHUNK SQL_SET_MAX_DATA_SIZE
83203>>>>>>>///
83203>>>>>>>/// @Syntax SQL_GET_MAX_DATA_SIZE to {variable}
83203>>>>>>>/// @Param variable             Variable to hold the maximum chunk size
83203>>>>>>>///
83203>>>>>>>/// @Example
83203>>>>>>>/// SQL_GET_MAX_DATA_SIZE to iLength
83203>>>>>>>
83203>>>>>>>//=============================================================================
83203>>>>>>>/// @Name        SQL_GET_NUM_COLS
83203>>>>>>>/// @Description This command is used to get the number of columns retrieved
83203>>>>>>>/// from an SQL expression result set. Since the column number is based on
83203>>>>>>>/// the result set, this command cannot be used when the results are being
83203>>>>>>>/// bound to the record buffer.  If this command is used with the record
83203>>>>>>>/// buffer or if no columns are found, -1 is returned.
83203>>>>>>>///
83203>>>>>>>/// @Assumptions
83203>>>>>>>/// @Status      Public
83203>>>>>>>/// @Drivers     All
83203>>>>>>>/// @VersionNote Last Revised: 2013-08-28 by Aaron Gulack
83203>>>>>>>/// @See                 SQL_PREPARE_STMT SQL_EXECUTE_STMT SQL_SET_STMT
83203>>>>>>>///
83203>>>>>>>/// @Syntax SQL_GET_NUM_COLS to {variable}
83203>>>>>>>/// @Param variable                     Variable to hold the number of columns.
83203>>>>>>>///
83203>>>>>>>/// @Example
83203>>>>>>>/// SQL_SET_STMT to "SELECT * FROM CUSTOMER WHERE FIRSTNAME = 'Aaron'"
83203>>>>>>>/// SQL_PREPARE_STMT
83203>>>>>>>/// SQL_EXECUTE_STMT
83203>>>>>>>/// GET_RESULT_SET_NUM_COLS to iNumCols
83203>>>>>>>/// Showln iNumCols
83203>>>>>>>
83203>>>>>>>
83203>>>>>>>//=============================================================================
83203>>>>>>>/// @Name        GET_RESULT_SET_NUM_COLS
83203>>>>>>>/// @Description Returns the number of columns in the result set.
83203>>>>>>>///
83203>>>>>>>/// @Assumptions
83203>>>>>>>/// @Status      Deprecated
83203>>>>>>>/// @Drivers     All
83203>>>>>>>/// @VersionNote Last Revised: 2013-08-28 by Aaron Gulack
83203>>>>>>>/// @See                 SQL_GET_NUM_COLS
83203>>>>>>>///
83203>>>>>>>/// @Syntax GET_RESULT_SET_NUM_COLS to {variable}
83203>>>>>>>/// @Param variable                     Variable to hold the number of columns
83203>>>>>>>///
83203>>>>>>>/// @Example
83203>>>>>>>/// Integer iNumCols
83203>>>>>>>///
83203>>>>>>>/// SQL_SET_STMT to "SELECT * FROM CUSTOMER WHERE FIRSTNAME = 'Aaron'"
83203>>>>>>>/// SQL_PREPARE_STMT
83203>>>>>>>/// SQL_EXECUTE_STMT
83203>>>>>>>/// GET_RESULT_SET_NUM_COLS to iNumCols
83203>>>>>>>/// Showln iNumCols
83203>>>>>>>
83203>>>>>>>//=============================================================================
83203>>>>>>>/// @Name        SQL_GET_NUM_ROWS
83203>>>>>>>/// @Description This command is used to get the number of rows retrieved
83203>>>>>>>/// from a result set of an SQL expression. It cannot be used when binding
83203>>>>>>>/// the result set to the record buffer.
83203>>>>>>>///
83203>>>>>>>/// Note: The number of rows may not always be available, depending
83203>>>>>>>/// on server and cursor types.
83203>>>>>>>///
83203>>>>>>>/// @Assumptions
83203>>>>>>>/// @Status      Public
83203>>>>>>>/// @Drivers     All
83203>>>>>>>/// @VersionNote Last Revised: 2013-08-30 by Aaron Gulack
83203>>>>>>>/// @See                 SQL_PREPARE_STMT SQL_EXECUTE_STMT
83203>>>>>>>///
83203>>>>>>>/// @Syntax SQL_GET_NUM_ROWS to {variable}
83203>>>>>>>/// @Param variable                     Variable to hold the number of rows
83203>>>>>>>///
83203>>>>>>>/// @Example
83203>>>>>>>/// Integer iNumRows
83203>>>>>>>///
83203>>>>>>>/// SQL_SET_STMT to "SELECT * FROM CUSTOMER WHERE STATUS = 'Active'"
83203>>>>>>>/// SQL_PREPARE_STMT
83203>>>>>>>/// SQL_EXECUTE_STMT
83203>>>>>>>/// SQL_GET_NUM_ROWS to iNumRows
83203>>>>>>>/// Showln iNumRows
83203>>>>>>>
83203>>>>>>>
83203>>>>>>>//=============================================================================
83203>>>>>>>/// @Name        SQL_GET_COL_NAME
83203>>>>>>>/// @Description This command is used to retrieve the name of a specified
83203>>>>>>>/// column within an SQL result set. An optional second variable can be used
83203>>>>>>>/// to retrieve the size of the specified column. Note that this command
83203>>>>>>>/// cannot be used when the results are being directly binded to the record
83203>>>>>>>/// buffer, it can only be used for the results of an SQL statement.
83203>>>>>>>///
83203>>>>>>>/// @Assumptions
83203>>>>>>>/// @Status      Public
83203>>>>>>>/// @Drivers     All
83203>>>>>>>/// @VersionNote Last Revised: 2013-08-30 by Aaron Gulack
83203>>>>>>>/// @See                 SQL_GET_NUM_COLS
83203>>>>>>>///
83203>>>>>>>/// @Syntax SQL_GET_COL_NAME {columnNumber} to {variable} [{length}]
83203>>>>>>>/// @Param columnNumber                 The column number being used
83203>>>>>>>/// @Param variable                             String variable for the column name
83203>>>>>>>/// @Param length                       Variable to hold the column length (optional)
83203>>>>>>>///
83203>>>>>>>/// @Example
83203>>>>>>>/// Open Customer
83203>>>>>>>///
83203>>>>>>>/// String sColumnName
83203>>>>>>>/// Integer iLength
83203>>>>>>>///
83203>>>>>>>/// SQL_SET_STMT to "SELECT * FROM CUSTOMER WHERE STATUS = 'Active'"
83203>>>>>>>/// SQL_PREPARE_STMT
83203>>>>>>>/// SQL_EXECUTE_STMT
83203>>>>>>>/// SQL_GET_COL_NAME 1 to sColumnName iLength
83203>>>>>>>/// showln sColumnName
83203>>>>>>>/// showln iLength
83203>>>>>>>
83203>>>>>>>
83203>>>>>>>//=============================================================================
83203>>>>>>>/// @Name        GET_RESULT_SET_COL_NAME
83203>>>>>>>/// @Description Returns the column name being populated from the result set.
83203>>>>>>>///
83203>>>>>>>/// @Assumptions
83203>>>>>>>/// @Status      Deprecated
83203>>>>>>>/// @Drivers     All
83203>>>>>>>/// @VersionNote Last Revised: 2013-08-30 by Aaron Gulack
83203>>>>>>>/// @See                 SQL_GET_COL_NAME
83203>>>>>>>///
83203>>>>>>>/// @Syntax GET_RESULT_SET_COL_NAME {columnNumber} to {variable} [{length}]
83203>>>>>>>/// @Param columnNumber                 The column number being used
83203>>>>>>>/// @Param variable                             String variable for the column name
83203>>>>>>>/// @Param length                       Variable receiving the column length (optional)
83203>>>>>>>
83203>>>>>>>//=============================================================================
83203>>>>>>>/// @Name        SQL_GET_COL_ATTRIBUTE
83203>>>>>>>/// @Description This command is used to get specific column information from
83203>>>>>>>/// the columns in a result set of an SQL statement. By passing one of the
83203>>>>>>>/// supported attributes below, the command will return the desired information.
83203>>>>>>>/// Note that some attributes only work with specific drivers. See the list
83203>>>>>>>/// below for more information.
83203>>>>>>>///
83203>>>>>>>/// Supported attributes are:
83203>>>>>>>/// <dl>
83203>>>>>>>/// <dt>SIZE        </dt><dd>The maximum length of the column</dd>
83203>>>>>>>/// <dt>DATA_LENGTH </dt><dd>Length of data currently in the column</dd>
83203>>>>>>>/// <dt>DECIMALS    </dt><dd>If numeric, shows number of decimal places</dd>
83203>>>>>>>/// <dt>LABEL       </dt><dd>Returns the column name in ORAFlex and MySQLFlex</dd>
83203>>>>>>>/// <dt>COLUMN_NAME </dt><dd>Returns the name of the column</dd>
83203>>>>>>>/// <dt>TABLE_NAME  </dt><dd>Returns the name of the table (MySQLFlex only)</dd>
83203>>>>>>>/// <dt>SQLTYPE     </dt><dd>Returns the number representing the SQL data type</dd>
83203>>>>>>>/// <dt>NULLABLE    </dt><dd>Returns true if null is allowed, false otherwise (doesn't work in PostgreSQL)</dd>
83203>>>>>>>/// <dt>DFTYPE      </dt><dd>Dataflex type column is mapped to</dd>
83203>>>>>>>/// </dl>
83203>>>>>>>///
83203>>>>>>>/// @Assumptions
83203>>>>>>>/// @Status      Public
83203>>>>>>>/// @Drivers     All
83203>>>>>>>/// @VersionNote Last Revised: 2013-09-05 by Aaron Gulack
83203>>>>>>>/// @See
83203>>>>>>>///
83203>>>>>>>/// @Syntax SQL_GET_COL_ATTRIBUTE of {columnNumber} {attribute} to {variable}
83203>>>>>>>/// @Param columnNumber                 The number of the column that is being examined
83203>>>>>>>/// @Param attribute                    The attribute being checked (see list)
83203>>>>>>>/// @Param variable                             Variable to hold the attribute value
83203>>>>>>>///
83203>>>>>>>/// @Example
83203>>>>>>>/// String sFirstName sLastName sColumn1Name sColumn2Name
83203>>>>>>>///
83203>>>>>>>/// Open Customer
83203>>>>>>>///
83203>>>>>>>/// SQL_SET_STMT to "SELECT * FROM CUSTOMER WHERE STATUS = 'Active' "
83203>>>>>>>/// SQL_PREPARE_STMT
83203>>>>>>>/// SQL_EXECUTE_STMT
83203>>>>>>>/// SQL_FETCH_NEXT_ROW into sFirstName sLastName
83203>>>>>>>/// If (Found) Begin
83203>>>>>>>///     SQL_GET_COL_ATTRIBUTE of 1 COLUMN_NAME to sColumn1Name
83203>>>>>>>///     SQL_GET_COL_ATTRIBUTE of 2 COLUMN_NAME to sColumn2Name
83203>>>>>>>///     Showln (sColumn1Name + " = " + sFirstName)
83203>>>>>>>///     Showln (sColumn2Name + " = " + sLastName)
83203>>>>>>>/// End
83203>>>>>>>
83203>>>>>>>//=============================================================================
83203>>>>>>>/// @Name        DDO_GET_BIND_RSPARAMETERS
83203>>>>>>>/// @Description Recursively calls DO_GET_BIND_RSPARAMETERS.
83203>>>>>>>///
83203>>>>>>>/// @Assumptions
83203>>>>>>>/// @Status      Internal
83203>>>>>>>/// @Drivers     All
83203>>>>>>>/// @VersionNote Last Revised: 2013-08-30 by Aaron Gulack
83203>>>>>>>/// @See
83203>>>>>>>
83203>>>>>>>//=============================================================================
83203>>>>>>>/// @Name        DO_GET_BIND_RSPARAMETERS
83203>>>>>>>/// @Description Gets bound parameters values for result set call.
83203>>>>>>>///
83203>>>>>>>/// @Assumptions
83203>>>>>>>/// @Status      Internal
83203>>>>>>>/// @Drivers     All
83203>>>>>>>/// @VersionNote Last Revised: 2013-08-30 by Aaron Gulack
83203>>>>>>>/// @See
83203>>>>>>>
83203>>>>>>>Function MertechInc_DO_GET_BIND_RSPARAMETERS Global Integer bSQLFlex String sArg1 String sArg2 Integer iArg Returns String
83205>>>>>>>    Local String sReturnValue
83205>>>>>>>    Local Integer iSize
83205>>>>>>>
83205>>>>>>>    move 0 to iSize
83206>>>>>>>        SQL_GET_COL_ATTRIBUTE of iArg DATA_LENGTH to iSize
83223>>>>>>>>
83223>>>>>>>
83223>>>>>>>    Get MertechInc_Pre_Size_String (iSize+1) to sReturnValue
83224>>>>>>>    Move (|CI$10000 * iArg) To iArg // Shift column number 16 bits to the left
83225>>>>>>>    Call_Driver 0 MertechInc_DriverName Function 24 CALLBACK 0 PASSING sReturnValue MertechInc_Blank iArg RESULT MertechInc_iRet
83230>>>>>>>
83230>>>>>>>    Function_Return sReturnValue
83231>>>>>>>End_Function
83232>>>>>>>
83232>>>>>>>
83232>>>>>>>//=============================================================================
83232>>>>>>>/// @Name        SQL_NEXT_RESULT_SET
83232>>>>>>>/// @Description This command is used when working with SQL statements that
83232>>>>>>>/// return multiple result sets. In that scenario, calling this command will
83232>>>>>>>/// move to the next result set. That set can now be fetched or binded to
83232>>>>>>>/// columns on a table.
83232>>>>>>>///
83232>>>>>>>/// @See
83232>>>>>>>/// @Status      Public
83232>>>>>>>/// @Drivers     All
83232>>>>>>>/// @VersionNote Last Revised: 2013-09-02 by Aaron Gulack
83232>>>>>>>/// @See
83232>>>>>>>///
83232>>>>>>>/// @Syntax SQL_NEXT_RESULT_SET [of {file}]
83232>>>>>>>/// @Param file                 Name or number of the file (optional)
83232>>>>>>>///
83232>>>>>>>/// @Example
83232>>>>>>>/// SQL_SET_STMT to "SP_HELP CUSTOMER"
83232>>>>>>>/// SQL_PREPARE_STMT
83232>>>>>>>/// SQL_EXECUTE_STMT
83232>>>>>>>/// SQL_FETCH_NEXT_ROW into sTable sOwner sTableType dtCreated
83232>>>>>>>/// If (Found) Begin
83232>>>>>>>///     Showln sTable
83232>>>>>>>///     Showln sOwner
83232>>>>>>>///     Showln sTableType
83232>>>>>>>///     Showln dtCreated
83232>>>>>>>/// End
83232>>>>>>>/// SQL_NEXT_RESULT_SET
83232>>>>>>>/// SQL_FETCH_NEXT_ROW into sColumnName sColumnType sComputed sLength
83232>>>>>>>/// If (Found) Begin
83232>>>>>>>///     Showln sColumnName
83232>>>>>>>///     Showln sColumnType
83232>>>>>>>///     Showln sComputed
83232>>>>>>>///     Showln sLength
83232>>>>>>>/// End
83232>>>>>>>
83232>>>>>>>//=============================================================================
83232>>>>>>>/// @Name        DDO_PASS_ARGUMENTS
83232>>>>>>>/// @Description Calls DO_PASS_ARGUMENTS until the argument is "BINDING" and
83232>>>>>>>/// then stops.
83232>>>>>>>///
83232>>>>>>>/// @Assumptions
83232>>>>>>>/// @Status      Internal
83232>>>>>>>/// @Drivers     All
83232>>>>>>>/// @VersionNote Last Revised: 2013-09-05 by Aaron Gulack
83232>>>>>>>/// @See
83232>>>>>>>
83232>>>>>>>//=============================================================================
83232>>>>>>>/// @Name        DO_PASS_ARGUMENTS
83232>>>>>>>/// @Description Builds parameter statements for stored procedures and adds
83232>>>>>>>/// them to the current query.
83232>>>>>>>///
83232>>>>>>>/// @Assumptions
83232>>>>>>>/// @Status      internal
83232>>>>>>>/// @Drivers     All
83232>>>>>>>/// @VersionNote Last Revised: 2013-09-05 by Aaron Gulack
83232>>>>>>>/// @See
83232>>>>>>>
83232>>>>>>>//=============================================================================
83232>>>>>>>/// @Name        DDO_BIND_PARAMETERS
83232>>>>>>>/// @Description Recursively calls DO_BIND_PARAMETERS until the keyword
83232>>>>>>>/// "BINDING" is encountered.
83232>>>>>>>///
83232>>>>>>>/// @Assumptions
83232>>>>>>>/// @Status      Internal
83232>>>>>>>/// @Drivers     All
83232>>>>>>>/// @VersionNote Last Revised: 2013-09-05 by Aaron Gulack
83232>>>>>>>/// @See
83232>>>>>>>
83232>>>>>>>//=============================================================================
83232>>>>>>>/// @Name        DO_BIND_PARAMETERS
83232>>>>>>>/// @Description Binds parameters for a stored procedure call.
83232>>>>>>>///
83232>>>>>>>/// @Assumptions
83232>>>>>>>/// @Status      Internal
83232>>>>>>>/// @Drivers     All
83232>>>>>>>/// @VersionNote Last Revised: 2013-09-05 by Aaron Gulack
83232>>>>>>>/// @See
83232>>>>>>>
83232>>>>>>>Procedure MertechInc_DO_BIND_PARAMETERS Global String sValue String sName Integer iLength
83234>>>>>>>    Call_Driver 0 MertechInc_DriverName Function CALLDRV_BIND_PARAMETER CALLBACK 0 PASSING sValue sName iLength RESULT MertechInc_iRet
83239>>>>>>>End_Procedure
83240>>>>>>>
83240>>>>>>>//=============================================================================
83240>>>>>>>/// @Name        DO_BIND_PAR_RET
83240>>>>>>>/// @Description Binds parameters for a stored procedure call.
83240>>>>>>>///
83240>>>>>>>/// @Assumptions
83240>>>>>>>/// @Status      Internal
83240>>>>>>>/// @Drivers     OraFlex
83240>>>>>>>/// @VersionNote Last Revised: 2013-09-05 by Aaron Gulack
83240>>>>>>>/// @See
83240>>>>>>>
83240>>>>>>>//=============================================================================
83240>>>>>>>/// @Name        DDO_GET_BIND_PARAMETERS
83240>>>>>>>/// @Description Recursively calls DO_GET_BIND_PARAMETERS.
83240>>>>>>>///
83240>>>>>>>/// @Assumptions
83240>>>>>>>/// @Status      Internal
83240>>>>>>>/// @Drivers     All
83240>>>>>>>/// @VersionNote Last Revised: 2013-09-05 by Aaron Gulack
83240>>>>>>>/// @See
83240>>>>>>>
83240>>>>>>>//=============================================================================
83240>>>>>>>/// @Name        DO_GET_BIND_PARAMETERS
83240>>>>>>>/// @Description Gets bound parameter values for a stored procedure call.
83240>>>>>>>///
83240>>>>>>>/// @Assumptions
83240>>>>>>>/// @Status      Internal
83240>>>>>>>/// @Drivers     All
83240>>>>>>>/// @VersionNote Last Revised: 2013-09-05 by Aaron Gulack
83240>>>>>>>/// @See
83240>>>>>>>
83240>>>>>>>Function MertechInc_DO_GET_BIND_PARAMETERS Global Integer bSQLFlex String sArg1 String sArg2 Integer iArg Returns String
83242>>>>>>>    Local String sReturnValue
83242>>>>>>>    Local Integer iSize
83242>>>>>>>
83242>>>>>>>    if (MertechInc_DriverName = SQLFLEX) ;                move (iArg+1) to iArg
83245>>>>>>>//        SQL_GET_COL_ATTRIBUTE of iArg DATA_LENGTH to iSize
83245>>>>>>>
83245>>>>>>>    Get MertechInc_Pre_Size_String (iSize+1) to sReturnValue
83246>>>>>>>    Call_Driver 0 MertechInc_DriverName Function 24 CALLBACK 0 PASSING sReturnValue MertechInc_Blank iArg RESULT MertechInc_iRet
83251>>>>>>>
83251>>>>>>>    Function_Return sReturnValue
83252>>>>>>>End_Function
83253>>>>>>>
83253>>>>>>>//=============================================================================
83253>>>>>>>/// @Name        SQL_GET_OUTPUT_VALUE
83253>>>>>>>/// @Description This command is used to get the value of a specific
83253>>>>>>>/// parameter associated with a stored procedure.  Although this
83253>>>>>>>/// command will work with any parameter, it is mostly used with
83253>>>>>>>/// IN/OUT or OUT parameters as their value will more often be important
83253>>>>>>>/// once returned. When multiple values are returned, this command can be
83253>>>>>>>/// more efficient than other options. Note that the specified parameter
83253>>>>>>>/// must first be defined using the SQL_SET_PROCEDURE_PARAMETER command
83253>>>>>>>/// in order to work properly.
83253>>>>>>>///
83253>>>>>>>/// @Assumptions
83253>>>>>>>/// @Status      Deprecated
83253>>>>>>>/// @Drivers     All
83253>>>>>>>/// @VersionNote Last Revised: 2013-10-01 by Aaron Gulack
83253>>>>>>>/// @See                 SQL_GET_PROCEDURE_PARAMETER
83253>>>>>>>///
83253>>>>>>>/// @Syntax SQL_GET_OUTPUT_VALUE {parameter} to {variable}
83253>>>>>>>/// @Param parameter            Number of the parameter
83253>>>>>>>/// @Param variable                     Variable to hold the parameter's value
83253>>>>>>>///
83253>>>>>>>/// @Example
83253>>>>>>>/// SQL_SET_PROCEDURE_NAME "user.getCustomerStatus" NUMPAR 1
83253>>>>>>>/// SQL_SET_PROCEDURE_PARAMETER 1 to sCustomerID IN_OUT
83253>>>>>>>/// SQL_PROCEDURE_EXECUTE
83253>>>>>>>/// SQL_GET_OUTPUT_VALUE 1 to sStatus
83253>>>>>>>///
83253>>>>>>>/// Showln sStatus
83253>>>>>>>///
83253>>>>>>>/// @Example
83253>>>>>>>/// SQL_SET_PROCEDURE_NAME "user.getCustomerStatus" NUMPAR 2
83253>>>>>>>/// SQL_SET_PROCEDURE_PARAMETER 1 to sCustomerID IN
83253>>>>>>>/// SQL_SET_PROCEDURE_PARAMETER 2 to sStatus OUT
83253>>>>>>>/// SQL_PROCEDURE_EXECUTE
83253>>>>>>>/// SQL_GET_OUTPUT_VALUE 2 to sStatus
83253>>>>>>>///
83253>>>>>>>/// Showln sStatus
83253>>>>>>>// OLI:
83253>>>>>>>// This function is identical in operation to SQL_GET_PROCEDURE_PARAMETER, so just do a replace
83253>>>>>>>
83253>>>>>>>//=============================================================================
83253>>>>>>>/// @Name        SQL_FETCH_COLUMN
83253>>>>>>>/// @Description This command is used to retrieve a specified column from a
83253>>>>>>>/// result set of an SQL statement. Note that this command cannot be used to
83253>>>>>>>/// replace SQL_FETCH_NEXT_ROW but is used in addition to it when only one
83253>>>>>>>/// column is needed. For most cases, SQL_FETCH_NEXT_ROW can be used alone
83253>>>>>>>/// to retrieve the columns desired so this should only be used if there is
83253>>>>>>>/// a specific reason to do so.
83253>>>>>>>///
83253>>>>>>>/// @Assumptions
83253>>>>>>>/// @Status      Public
83253>>>>>>>/// @Drivers     All
83253>>>>>>>/// @VersionNote Last Revised: 2013-09-05 by Aaron Gulack
83253>>>>>>>/// @See                 SQL_FETCH_NEXT_ROW
83253>>>>>>>///
83253>>>>>>>/// @Syntax SQL_FETCH_COLUMN {columnNumber} into {variable}
83253>>>>>>>/// @Param columnNumber    Number of the column to fetch
83253>>>>>>>/// @Param variable        Variable to hold the fetched value
83253>>>>>>>///
83253>>>>>>>/// @Example
83253>>>>>>>/// SQL_SET_STMT to "SELECT * FROM CUSTOMER WHERE STATUS = 'Active' "
83253>>>>>>>/// SQL_PREPARE_STMT
83253>>>>>>>/// SQL_EXECUTE_STMT
83253>>>>>>>/// SQL_FETCH_NEXT_ROW
83253>>>>>>>/// SQL_GET_NUM_COLS to iCols
83253>>>>>>>/// For fieldIndex from 1 to iCols
83253>>>>>>>///     SQL_FETCH_COLUMN fieldIndex into sValue
83253>>>>>>>///     Showln sValue
83253>>>>>>>/// Loop
83253>>>>>>>
83253>>>>>>>Function MertechInc_SQL_FETCH_COLUMN Global String sArg1 String sArg2 Integer iArg Returns String
83255>>>>>>>    Local String sReturnValue
83255>>>>>>>    Local Integer iSize
83255>>>>>>>
83255>>>>>>>    Move 0 to iSize
83256>>>>>>>        SQL_GET_COL_ATTRIBUTE of iArg DATA_LENGTH to iSize
83273>>>>>>>>
83273>>>>>>>
83273>>>>>>>    Get MertechInc_Pre_Size_String (iSize+1) to sReturnValue
83274>>>>>>>    Move (|CI$10000 * iArg) to iArg // Shift column number 16 bits to the left
83275>>>>>>>    Call_Driver 0 MertechInc_DriverName Function 24 CALLBACK 0 PASSING sReturnValue MertechInc_Blank iArg RESULT MertechInc_iRet
83280>>>>>>>
83280>>>>>>>    Function_Return sReturnValue
83281>>>>>>>End_Function
83282>>>>>>>
83282>>>>>>>//=============================================================================
83282>>>>>>>/// @Name        SET_SCHEMA_NAME
83282>>>>>>>/// @Description This command is used to set the schema name to be used when
83282>>>>>>>/// opening tables. Note that this command will override the schema name that
83282>>>>>>>/// is set in the INT file.  The default schema for the current user is used
83282>>>>>>>/// when no name is set.
83282>>>>>>>///
83282>>>>>>>/// @Assumptions
83282>>>>>>>/// @Status      Public
83282>>>>>>>/// @Drivers     SQLFlex and ORAFlex
83282>>>>>>>/// @VersionNote Last Revised: 2013-09-24 by Aaron Gulack
83282>>>>>>>/// @See                 GET_SCHEMA_NAME
83282>>>>>>>///
83282>>>>>>>/// @Syntax SET_SCHEMA_NAME to {schema}
83282>>>>>>>/// @Param variable                     Name of the schema
83282>>>>>>>///
83282>>>>>>>/// @Example
83282>>>>>>>/// SET_SCHEMA_NAME to 'CustomerSchema'
83282>>>>>>>/// OPEN "CUSTOMER.INT" as CUSTOMER
83282>>>>>>>/// SET_SCHEMA_NAME to 'SalesSchema'
83282>>>>>>>/// OPEN "SALESP.INT" as SALESP
83282>>>>>>>
83282>>>>>>>//=============================================================================
83282>>>>>>>/// @Name        GET_SCHEMA_NAME
83282>>>>>>>/// @Description This command is used to get the name of the schema being
83282>>>>>>>/// used to open tables.
83282>>>>>>>///
83282>>>>>>>/// @Assumptions
83282>>>>>>>/// @Status      Public
83282>>>>>>>/// @Drivers     SQLFlex and ORAFlex
83282>>>>>>>/// @VersionNote Last Revised: 2013-09-24 by Aaron Gulack
83282>>>>>>>/// @See                 SET_SCHEMA_NAME
83282>>>>>>>///
83282>>>>>>>/// @Syntax GET_SCHEMA_NAME to {variable}
83282>>>>>>>/// @Param variable                     variable to hold the schema name
83282>>>>>>>///
83282>>>>>>>/// @Example
83282>>>>>>>/// GET_SCHEMA_NAME to sName
83282>>>>>>>/// Showln sName
83282>>>>>>>
83282>>>>>>>//=============================================================================
83282>>>>>>>/// @Name        CALL_ORACLE_STORED_PROCEDURE
83282>>>>>>>/// @Description This command is used to call a stored procedure on the SQL
83282>>>>>>>/// backend. To successfully call a procedure with this command, a string
83282>>>>>>>/// must be passed containing a valid procedure name. In addition, if the
83282>>>>>>>/// procedure takes any arguments, they must also be passed using the constant
83282>>>>>>>/// "passing" along with all of the needed arguments. If the procedure has a
83282>>>>>>>/// return value, then SQL_GET_FUNCTION_RETURN or SQL_FETCH_NEXT_ROW can be
83282>>>>>>>/// used to get the value(s). If an error is found then the indicator "Err"
83282>>>>>>>/// is set to true.
83282>>>>>>>///
83282>>>>>>>/// @Assumptions
83282>>>>>>>/// @Status      Deprecated
83282>>>>>>>/// @Drivers     ORAFLex
83282>>>>>>>/// @VersionNote Last Revised: 2013-09-25 by Aaron Gulack
83282>>>>>>>/// @See                 CALL_STORED_PROCEDURE
83282>>>>>>>///
83282>>>>>>>/// @Syntax CALL_ORACLE_STORED_PROCEDURE {procedure} Passing {variable}
83282>>>>>>>/// @Param procedure            Full name of the procedure
83282>>>>>>>/// @Param variable                     Argument being passed to procedure (can be multiple)
83282>>>>>>>///
83282>>>>>>>/// @Example
83282>>>>>>>/// CALL_ORACLE_STORED_PROCEDURE "sys.sp_addmessage" passing 50003 15 "Please enter a valid date"
83282>>>>>>>
83282>>>>>>>//=============================================================================
83282>>>>>>>/// @Name        SQL_SET_PROCEDURE_NAME
83282>>>>>>>/// @Description This command is used to set the procedure to be executed.
83282>>>>>>>/// This is used when the procedure is being split up into multiple lines
83282>>>>>>>/// as shown below. When using this command, SQL_PROCEDURE_EXECUTE must be
83282>>>>>>>/// called after all parameters have been set to successfully execute the
83282>>>>>>>/// procedure. The constant "NUMPAR" is used to indicate how many parameters
83282>>>>>>>/// will be passed.
83282>>>>>>>///
83282>>>>>>>/// @Assumptions The procedure is a valid procedure in the SQL database
83282>>>>>>>/// @Status      Public
83282>>>>>>>/// @Drivers     All
83282>>>>>>>/// @VersionNote Last Revised: 2013-09-25 by Aaron Gulack
83282>>>>>>>/// @See                 SQL_SET_PROCEDURE_PARAMETER SQL_PROCEDURE_EXECUTE
83282>>>>>>>///
83282>>>>>>>/// @Syntax SQL_SET_PROCEDURE_NAME {procedure} NUMPAR {variable}
83282>>>>>>>/// @Param procedure            Full name of the procedure
83282>>>>>>>/// @Param variable                     Number of parameters to be passed
83282>>>>>>>///
83282>>>>>>>/// @Example
83282>>>>>>>/// SQL_SET_PROCEDURE_NAME "sys.sp_addmessage" NUMPAR 3
83282>>>>>>>/// SQL_SET_PROCEDURE_PARAMETER 1 to 500004 IN
83282>>>>>>>/// SQL_SET_PROCEDURE_PARAMETER 2 to 15 IN
83282>>>>>>>/// SQL_SET_PROCEDURE_PARAMETER 3 to "Please enter a valid Date" IN
83282>>>>>>>/// SQL_PROCEDURE_EXECUTE
83282>>>>>>>
83282>>>>>>>
83282>>>>>>>Procedure MertechInc_SQL_SET_ORAPROCEDURE_NAME Global String strProcName Integer iNumpar
83284>>>>>>>    Local Integer iParam
83284>>>>>>>
83284>>>>>>>    Move 0 to MertechInc_iParamCount       //Redundant, but left in incase called
83285>>>>>>>    INDICATE ERR False              //directly and not via SQL_SET_PROCEDURE_NAME
83286>>>>>>>    Move ORAFlex to MertechInc_DriverName  //
83287>>>>>>>
83287>>>>>>>    SQL_SET_STMT to "BEGIN "
83295>>>>>>>    SQL_APPEND_STMT to strProcName
83303>>>>>>>    SQL_APPEND_STMT to "( "
83311>>>>>>>    For iParam from 1 to iNumpar
83317>>>>>>>>
83317>>>>>>>        DO_PASS_ARGUMENTS iParam
83349>>>>>>>    Loop
83350>>>>>>>>
83350>>>>>>>    SQL_APPEND_STMT to  " ); END;"
83358>>>>>>>    SQL_PREPARE_STMT
83370>>>>>>> End_Procedure
83371>>>>>>>
83371>>>>>>>Procedure MertechInc_SQL_SET_MYPROCEDURE_NAME Global String strProcName Integer iNumpar
83373>>>>>>>    Local Integer iParam
83373>>>>>>>
83373>>>>>>>    Move 0 to MertechInc_iParamCount           //Redundant, but left in incase called
83374>>>>>>>    INDICATE ERR False                  //directly and not via SQL_SET_PROCEDURE_NAME
83375>>>>>>>    Move MySQLFlex to MertechInc_DriverName    //
83376>>>>>>>
83376>>>>>>>    SQL_SET_STMT to "CALL "
83384>>>>>>>    SQL_APPEND_STMT to strProcName
83392>>>>>>>    SQL_APPEND_STMT to "("
83400>>>>>>>    For iParam from 1 to iNumpar
83406>>>>>>>>
83406>>>>>>>        DO_PASS_ARGUMENTS iParam
83438>>>>>>>    Loop
83439>>>>>>>>
83439>>>>>>>    SQL_APPEND_STMT to ")"
83447>>>>>>>    SQL_PREPARE_STMT
83459>>>>>>>End_Procedure
83460>>>>>>>
83460>>>>>>>Procedure MertechInc_SQL_SET_MSPROCEDURE_NAME Global String strProcName Integer iNumpar
83462>>>>>>>    local Integer iParam
83462>>>>>>>    local String  sParam
83462>>>>>>>
83462>>>>>>>    Move SQLFlex to MertechInc_DriverName
83463>>>>>>>
83463>>>>>>>    // This calling syntax is referred to as the "ODBC CALL escape sequence".  This syntax is
83463>>>>>>>    // advised over the execute command since CALL allows for the retrieval of the return codes
83463>>>>>>>    // from the call.
83463>>>>>>>    SQL_SET_STMT to "{? = CALL "
83471>>>>>>>    SQL_APPEND_STMT to strProcName
83479>>>>>>>
83479>>>>>>>    // Note that DO_PASS_ARGUMENTS can add the open paren for us, but only if the keyword "PASSING"
83479>>>>>>>    // is passed to it first time through.  This is a bit weird, so we ignore that and just add
83479>>>>>>>    // the open and close parens ourself to make things more clear.
83479>>>>>>>    If (iNumpar > 0) SQL_APPEND_STMT to " ("
83489>>>>>>>
83489>>>>>>>    For iParam from 1 to iNumpar
83495>>>>>>>>
83495>>>>>>>        DO_PASS_ARGUMENTS iParam
83527>>>>>>>    Loop
83528>>>>>>>>
83528>>>>>>>
83528>>>>>>>    If (iNumpar > 0) SQL_APPEND_STMT to ")"
83538>>>>>>>    SQL_APPEND_STMT to  " };"
83546>>>>>>>
83546>>>>>>>    SQL_PREPARE_STMT
83558>>>>>>>
83558>>>>>>>    // This bind parameter is for the "{? = " which is technically the first parameter even though
83558>>>>>>>    // it is the return value.  The driver will bind MertechInc_iWork to it.
83558>>>>>>>    DO_BIND_PARAMETERS MertechInc_iWork
83581>>>>>>>End_Procedure
83582>>>>>>>
83582>>>>>>>Procedure MertechInc_SQL_SET_PGPROCEDURE_NAME Global String strProcName Integer iNumpar
83584>>>>>>>    local Integer iParam
83584>>>>>>>    local String  sParam
83584>>>>>>>
83584>>>>>>>    Move PgFlex to MertechInc_DriverName
83585>>>>>>>
83585>>>>>>>    // For Postgres, you can call a function just by passing the function name and
83585>>>>>>>    // open/close parens
83585>>>>>>>    SQL_SET_STMT to strProcName
83593>>>>>>>
83593>>>>>>>    // Note that DO_PASS_ARGUMENTS can add the open paren for us, but only if the keyword "PASSING"
83593>>>>>>>    // is passed to it first time through.  This is a bit weird, so we ignore that and just add
83593>>>>>>>    // the open and close parens ourself to make things more clear.
83593>>>>>>>    SQL_APPEND_STMT to "( "
83601>>>>>>>
83601>>>>>>>    For iParam from 1 to iNumpar
83607>>>>>>>>
83607>>>>>>>        DO_PASS_ARGUMENTS iParam
83639>>>>>>>    Loop
83640>>>>>>>>
83640>>>>>>>
83640>>>>>>>    SQL_APPEND_STMT to ")"
83648>>>>>>>
83648>>>>>>>    SQL_PREPARE_STMT
83660>>>>>>>    // Indicate that a stored function will be executed - Query = 0, Procedure = 1, Function = 2
83660>>>>>>>    Call_Driver 0 MertechInc_DriverName Function CALLDRV_EMBEDDED_SQL_TYPE CALLBACK 0 PASSING MertechInc_Blank MertechInc_Blank 1 RESULT MertechInc_iRet
83665>>>>>>>End_Procedure
83666>>>>>>>
83666>>>>>>>//=============================================================================
83666>>>>>>>/// @Name        SQL_GET_STMT
83666>>>>>>>/// @Description This command returns the last embedded SQL statement that
83666>>>>>>>/// was executed into a string. Optional parameters can be passed to specify
83666>>>>>>>/// what character to start the string at and also the maximum number of
83666>>>>>>>/// characters to allow for the string.
83666>>>>>>>///
83666>>>>>>>/// @Assumptions
83666>>>>>>>/// @Status      Public
83666>>>>>>>/// @Drivers     All
83666>>>>>>>/// @VersionNote Last Revised: 2013-09-24 by Aaron Gulack
83666>>>>>>>/// @See                 SQL_GET_STATEMENT
83666>>>>>>>///
83666>>>>>>>/// @Syntax SQL_GET_STMT to {variable} [{max} {start}]
83666>>>>>>>/// @Param variable                     SQL statement to be executed
83666>>>>>>>/// @Param max                          Indicates the maximum number of characters to get (optional)
83666>>>>>>>/// @Param start                        Indicates what character to start at for the returned string (optional)
83666>>>>>>>///
83666>>>>>>>/// @Example
83666>>>>>>>/// SQL_SET_STMT to "SELECT * FROM CUSTOMER WHERE STATUS = 'Active' "
83666>>>>>>>/// SQL_PREPARE_STMT
83666>>>>>>>/// SQL_EXECUTE_STMT
83666>>>>>>>/// SQL_FETCH_NEXT_ROW into sFirstName sLastName
83666>>>>>>>/// If (Found) Begin
83666>>>>>>>///     Showln sFirstName
83666>>>>>>>///     Showln sLastName
83666>>>>>>>/// End
83666>>>>>>>///
83666>>>>>>>/// SQL_GET_STATEMENT to sValue
83666>>>>>>>/// Showln sValue
83666>>>>>>>
83666>>>>>>>
83666>>>>>>>Function MertechInc_SQL_GET_STATEMENT Global Integer iLength Integer iStart Returns String
83668>>>>>>>    Local String sStatement
83668>>>>>>>
83668>>>>>>>    DO_GETFILENUMBER_DRIVERNAME 0
83670>>>>>>>
83670>>>>>>>    If (MertechInc_FileNumber <> -1) Begin
83672>>>>>>>        Get MertechInc_Pre_Size_String 0 to sStatement
83673>>>>>>>        Call_Driver 0 MertechInc_DriverName Function CALLDRV_GET_SQL_STMT CALLBACK 0 PASSING sStatement iStart iLength RESULT MertechInc_iRet
83678>>>>>>>    End
83678>>>>>>>>
83678>>>>>>>    Function_Return sStatement
83679>>>>>>>End_Function
83680>>>>>>>
83680>>>>>>>//=============================================================================
83680>>>>>>>/// @Name        SQL_SET_FUNCTION_NAME
83680>>>>>>>/// @Description This command is used in the same way as SQL_SET_PROCEDURE_NAME
83680>>>>>>>/// and SQL_SET_STMT to set the name of the function to be executed. When
83680>>>>>>>/// calling SQL functions in this fashion, this command must be used along with
83680>>>>>>>/// SQL_FUNCTION_EXECUTE (to execute the function), SQL_SET_FUNCTION_PARAMETER
83680>>>>>>>/// (to set the needed parameters) and SQL_GET_FUNCTION_RETURN (to get any
83680>>>>>>>/// returned value). The number of parameters must be set using the constant,
83680>>>>>>>/// NUMPAR, followed by the number of parameters. Note that when setting the
83680>>>>>>>/// name of the function, the user can be specified or, if left blank, the
83680>>>>>>>/// current user will be inserted before the function name.
83680>>>>>>>///
83680>>>>>>>/// @Assumptions
83680>>>>>>>/// @Status      Public
83680>>>>>>>/// @Drivers     All
83680>>>>>>>/// @VersionNote Last Revised: 2013-10-01 by Aaron Gulack
83680>>>>>>>/// @See                 SQL_FUNCTION_EXECUTE SQL_SET_FUNCTION_PARAMETER SQL_GET_FUNCTION_RETURN
83680>>>>>>>///
83680>>>>>>>/// @Syntax SQL_SET_FUNCTION_NAME {function} NUMPAR {parameters}
83680>>>>>>>/// @Param function                     Full name of the function
83680>>>>>>>/// @Param parameters           Number of parameters to pass
83680>>>>>>>///
83680>>>>>>>/// @Example
83680>>>>>>>/// SQL_SET_FUNCTION_NAME "getCustomerStatus" NUMPAR 1
83680>>>>>>>/// SQL_SET_FUNCTION_PARAMETER 1 to 'Jones' IN
83680>>>>>>>/// SQL_FUNCTION_EXECUTE
83680>>>>>>>/// SQL_GET_FUNCTION_RETURN to dDOB
83680>>>>>>>/// Showln dDOB
83680>>>>>>>
83680>>>>>>>Procedure MertechInc_SQL_SET_ORAFUNCTION_NAME Global String strProcName Integer iNumpar
83682>>>>>>>    Local Integer iParam
83682>>>>>>>
83682>>>>>>>    SQL_SET_STMT to "BEGIN "
83690>>>>>>>    SQL_APPEND_STMT to ":PAR_RET := "
83698>>>>>>>    SQL_APPEND_STMT to strProcName
83706>>>>>>>    SQL_APPEND_STMT to "( "
83714>>>>>>>    For iParam from 1 to iNumpar
83720>>>>>>>>
83720>>>>>>>        DO_PASS_ARGUMENTS iParam
83752>>>>>>>    Loop
83753>>>>>>>>
83753>>>>>>>    SQL_APPEND_STMT to  " ); END;"
83761>>>>>>>    SQL_PREPARE_STMT
83773>>>>>>>
83773>>>>>>>    Move IS_OUT to MertechInc_iArg
83774>>>>>>>    Call_Driver 0 ORAFLEX Function CALLDRV_SET_PROC_ATTRIBUTE_TYPE CALLBACK 0 PASSING MertechInc_Blank MertechInc_Blank MertechInc_iArg RESULT MertechInc_iRet
83779>>>>>>>
83779>>>>>>>    Increment MertechInc_iParamCount
83780>>>>>>>    Move ":PAR_RET" to MertechInc_sArg2
83781>>>>>>>    Call_Driver 0 MertechInc_DriverName Function CALLDRV_BIND_PARAMETER CALLBACK 0 PASSING MertechInc_Blank MertechInc_sArg2 16384 RESULT MertechInc_iRet
83786>>>>>>>End_Procedure
83787>>>>>>>
83787>>>>>>>Procedure MertechInc_SQL_SET_MYFUNCTION_NAME Global String strProcName Integer iNumpar
83789>>>>>>>    Local Integer iParam
83789>>>>>>>
83789>>>>>>>    Move MySQLFlex to MertechInc_DriverName
83790>>>>>>>
83790>>>>>>>    SQL_SET_STMT to "SELECT "
83798>>>>>>>    SQL_APPEND_STMT to strProcName
83806>>>>>>>    SQL_APPEND_STMT to "("
83814>>>>>>>    For iParam from 1 to iNumpar
83820>>>>>>>>
83820>>>>>>>        DO_PASS_ARGUMENTS iParam
83852>>>>>>>    Loop
83853>>>>>>>>
83853>>>>>>>    SQL_APPEND_STMT to ")"
83861>>>>>>>    SQL_PREPARE_STMT
83873>>>>>>>End_Procedure
83874>>>>>>>
83874>>>>>>>Procedure MertechInc_SQL_SET_SQLFUNCTION_NAME Global String strProcName Integer iNumpar
83876>>>>>>>    Local Integer iParam
83876>>>>>>>
83876>>>>>>>    Move SQLFlex to MertechInc_DriverName
83877>>>>>>>
83877>>>>>>>    If (not(strProcName contains ".")) Begin
83879>>>>>>>        String schema
83879>>>>>>>        GET_SCHEMA_NAME to schema
83901>>>>>>>        Move (schema + "." + strProcName) to strProcName
83902>>>>>>>    End
83902>>>>>>>>
83902>>>>>>>
83902>>>>>>>    SQL_SET_STMT    to "SELECT "
83910>>>>>>>    SQL_APPEND_STMT to strProcName
83918>>>>>>>    SQL_APPEND_STMT to "("
83926>>>>>>>End_Procedure
83927>>>>>>>
83927>>>>>>>Procedure MertechInc_SQL_SET_PGFUNCTION_NAME Global String strProcName Integer iNumpar
83929>>>>>>>    Local Integer iParam
83929>>>>>>>
83929>>>>>>>    Move PgFlex to MertechInc_DriverName
83930>>>>>>>
83930>>>>>>>    SQL_SET_STMT    to "SELECT "
83938>>>>>>>    SQL_APPEND_STMT to strProcName
83946>>>>>>>    SQL_APPEND_STMT to "("
83954>>>>>>>End_Procedure
83955>>>>>>>
83955>>>>>>>//=============================================================================
83955>>>>>>>/// @Name        SQL_SET_PROCEDURE_PARAMETER
83955>>>>>>>/// @Description
83955>>>>>>>/// With this command you can pass one or more parameters to predefined
83955>>>>>>>/// stored procedures on a MySQL or Oracle server. The SQL_SET_PROCEDURE_PARAMETER
83955>>>>>>>/// command enables you to add a parameter to a stored procedure which you are
83955>>>>>>>/// planning to call. You can pass multiple parameters by calling the command
83955>>>>>>>/// for each parameter.
83955>>>>>>>///
83955>>>>>>>/// When passing parameters you'll have to inform the driver which variable
83955>>>>>>>/// you are passing, starting with 1 from left-to-right in the parameter list.
83955>>>>>>>///
83955>>>>>>>/// For each parameter you'll have to indicate if the variable is to be
83955>>>>>>>/// regarded as input, output or both.
83955>>>>>>>///
83955>>>>>>>///@Assumptions
83955>>>>>>>/// @Status      Public
83955>>>>>>>/// @Drivers     All
83955>>>>>>>/// @VersionNote Last Revised: 2013-09-27 by Aaron Gulack
83955>>>>>>>/// @See                 SQL_SET_PROCEDURE_NAME SQL_PROCEDURE_EXECUTE
83955>>>>>>>///
83955>>>>>>>/// @Syntax SQL_SET_PROCEDURE_PARAMETER {number} to {variable} {direction}
83955>>>>>>>/// @Param number                       Index number of the parameter being defined.
83955>>>>>>>/// @Param variable                     Variable holding the parameter to be passed.
83955>>>>>>>/// @Param direction            IN, OUT, IN_OUT, RSET, or leave blank
83955>>>>>>>///
83955>>>>>>>/// @Example
83955>>>>>>>/// SQL_SET_PROCEDURE_NAME "sys.sp_addmessage" NUMPAR 3
83955>>>>>>>/// SQL_SET_PROCEDURE_PARAMETER 1 to 500004 IN
83955>>>>>>>/// SQL_SET_PROCEDURE_PARAMETER 2 to 15 IN
83955>>>>>>>/// SQL_SET_PROCEDURE_PARAMETER 3 to "Please enter a valid Date" IN
83955>>>>>>>/// SQL_PROCEDURE_EXECUTE
83955>>>>>>>
83955>>>>>>>
83955>>>>>>>
83955>>>>>>>//=============================================================================
83955>>>>>>>/// @Name        SQL_GET_PROCEDURE_PARAMETER
83955>>>>>>>/// @Description This command is used to get the value of a specific
83955>>>>>>>/// parameter associated with a stored procedure.  Although this
83955>>>>>>>/// command will work with any parameter, it is mostly be used with
83955>>>>>>>/// IN/OUT or OUT parameters as their value will more often be important
83955>>>>>>>/// once returned. When multiple values are returned, this command can be
83955>>>>>>>/// more efficient than other options. Note that the specified parameter
83955>>>>>>>/// must first be defined using the SQL_SET_PROCEDURE_PARAMETER command
83955>>>>>>>/// in order to work properly.
83955>>>>>>>///
83955>>>>>>>/// @Assumptions
83955>>>>>>>/// @Status      Public
83955>>>>>>>/// @Drivers     All
83955>>>>>>>/// @VersionNote Last Revised: 2013-10-02 by Aaron Gulack
83955>>>>>>>/// @See                 SQL_SET_PROCEDURE_NAME SQL_SET_PROCEDURE_PARAMETER SQL_PROCEDURE_EXECUTE
83955>>>>>>>///
83955>>>>>>>/// @Syntax SQL_GET_PROCEDURE_PARAMETER {parameter} to {variable}
83955>>>>>>>/// @Param parameter            Number of paramater to return
83955>>>>>>>/// @Param variable                     Variable to hold the value of the parameter
83955>>>>>>>///
83955>>>>>>>/// @Example
83955>>>>>>>/// SQL_SET_PROCEDURE_NAME "user.getCustomerStatus" NUMPAR 1
83955>>>>>>>/// SQL_SET_PROCEDURE_PARAMETER 1 to sCustomerID IN_OUT
83955>>>>>>>/// SQL_PROCEDURE_EXECUTE
83955>>>>>>>/// SQL_GET_PROCEDURE_PARAMETER 1 to sStatus
83955>>>>>>>///
83955>>>>>>>/// Showln sStatus
83955>>>>>>>///
83955>>>>>>>/// @Example
83955>>>>>>>/// SQL_SET_PROCEDURE_NAME "user.getCustomerStatus" NUMPAR 2
83955>>>>>>>/// SQL_SET_PROCEDURE_PARAMETER 1 to sCustomerID IN
83955>>>>>>>/// SQL_SET_PROCEDURE_PARAMETER 2 to sStatus OUT
83955>>>>>>>/// SQL_PROCEDURE_EXECUTE
83955>>>>>>>/// SQL_GET_PROCEDURE_PARAMETER 2 to sStatus
83955>>>>>>>///
83955>>>>>>>/// Showln sStatus
83955>>>>>>>
83955>>>>>>>
83955>>>>>>>
83955>>>>>>>//=============================================================================
83955>>>>>>>/// @Name        SQL_GET_FUNCTION_RETURN
83955>>>>>>>/// @Description This variable is used to get the value returned from a SQL
83955>>>>>>>/// function call. After the function has been successfully called, this
83955>>>>>>>/// command takes the returned value and inserts it the given variable.
83955>>>>>>>///
83955>>>>>>>/// @Assumptions
83955>>>>>>>/// @Status      Public
83955>>>>>>>/// @Drivers     All
83955>>>>>>>/// @VersionNote Last Revised: 2013-10-01 by Aaron Gulack
83955>>>>>>>/// @See                 SQL_SET_FUNCTION_NAME SQL_SET_FUNCTION_PARAMETER SQL_FUNCTION_EXECUTE
83955>>>>>>>///
83955>>>>>>>/// @Syntax SQL_GET_FUNCTION_RETURN to {variable}
83955>>>>>>>/// @Param variable                     Variable to hold the returned value
83955>>>>>>>///
83955>>>>>>>/// @Example
83955>>>>>>>/// SQL_SET_FUNCTION_NAME "getCustomerStatus" NUMPAR 1
83955>>>>>>>/// SQL_SET_FUNCTION_PARAMETER 1 to 'Jones' IN
83955>>>>>>>/// SQL_FUNCTION_EXECUTE
83955>>>>>>>/// SQL_GET_FUNCTION_RETURN to dDOB
83955>>>>>>>/// Showln dDOB
83955>>>>>>>
83955>>>>>>>//=============================================================================
83955>>>>>>>/// @Name        SQL_FUNCTION_EXECUTE
83955>>>>>>>/// @Description This command is used to execute the function statement
83955>>>>>>>/// that was built by the SQL_SET_FUNCTION_NAME and subsequent
83955>>>>>>>/// SQL_SET_FUNCTION_PARAMETER commands. This works similarly to the
83955>>>>>>>/// SQL_EXECUTE_STMT command. Note that executing the function with this
83955>>>>>>>/// command will not get any returned values but will simply execute the
83955>>>>>>>/// function.
83955>>>>>>>///
83955>>>>>>>/// @Assumptions
83955>>>>>>>/// @Status      Public
83955>>>>>>>/// @Drivers     All
83955>>>>>>>/// @VersionNote Last Revised: 2013-10-01 by Aaron Gulack
83955>>>>>>>/// @See                 SQL_SET_FUNCTION_NAME SQL_SET_FUNCTION_PARAMETER SQL_GET_FUNCTION_RETURN
83955>>>>>>>///
83955>>>>>>>/// @Syntax SQL_FUNCTION_EXECUTE
83955>>>>>>>///
83955>>>>>>>/// @Example
83955>>>>>>>/// SQL_SET_FUNCTION_NAME "getCustomerStatus" NUMPAR 1
83955>>>>>>>/// SQL_SET_FUNCTION_PARAMETER 1 to 'Jones' IN
83955>>>>>>>/// SQL_FUNCTION_EXECUTE
83955>>>>>>>/// SQL_GET_FUNCTION_RETURN to dDOB
83955>>>>>>>/// Showln dDOB
83955>>>>>>>
83955>>>>>>>Procedure MertechInc_SQL_FUNCTION_EXECUTE Global String sDriverName
83957>>>>>>>    Local Integer iParam
83957>>>>>>>    Local String  sParam
83957>>>>>>>
83957>>>>>>>    If (sDriverName = SQLFLEX or sDriverName = PgFlex) Begin
83959>>>>>>>       SQL_APPEND_STMT to ')'
83967>>>>>>>       SQL_PREPARE_STMT
83979>>>>>>>    End
83979>>>>>>>>
83979>>>>>>>
83979>>>>>>>    SQL_EXECUTE_STMT
83994>>>>>>>    If (sDriverName <> ORAFLEX) Begin
83996>>>>>>>        SQL_FETCH_NEXT_ROW
84011>>>>>>>>
84011>>>>>>>    End
84011>>>>>>>>
84011>>>>>>>End_Procedure
84012>>>>>>>
84012>>>>>>>//=============================================================================
84012>>>>>>>/// @Name        REEXEC_ORACLE_STORED_PROCEDURE
84012>>>>>>>/// @Description This command is used to re-execute a stored procedure
84012>>>>>>>/// when using Oracle. Although it follows the same format as
84012>>>>>>>/// CALL_STORED_PROCEDURE, it can be useful because it does not need to
84012>>>>>>>/// prepare the procedure again before executing. This can cause speed
84012>>>>>>>/// improvements when calling a stored procedure multiple times.
84012>>>>>>>///
84012>>>>>>>/// @Assumptions A procedure has already been created through CALL_STORED_PROCEDURE
84012>>>>>>>/// @Status      Public
84012>>>>>>>/// @Drivers     ORAFLex
84012>>>>>>>/// @VersionNote Last Revised: 2013-10-04 by Aaron Gulack
84012>>>>>>>/// @See                 CALL_STORED_PROCEDURE
84012>>>>>>>///
84012>>>>>>>/// @Syntax CALL_ORACLE_STORED_PROCEDURE {procedure} Passing {variable}
84012>>>>>>>/// @Param procedure            Full name of the procedure
84012>>>>>>>/// @Param variable                     Parameter to pass (optional and can be multiple)
84012>>>>>>>///
84012>>>>>>>/// @Example
84012>>>>>>>/// CALL_STORED_PROCEDURE "user.getCustomerStatus" Passing sCustomerID sStatus
84012>>>>>>>/// Showln sStatus
84012>>>>>>>///
84012>>>>>>>/// Move (sCustomerID + 1) to sCustomerID
84012>>>>>>>///
84012>>>>>>>/// REEXEC_ORACLE_STORED_PROCEDURE "user.getCustomerStatus" passing sCustomerID sStatus
84012>>>>>>>/// Showln sStatus
84012>>>>>>>
84012>>>>>>>
84012>>>>>>>//=============================================================================
84012>>>>>>>/// @Name        CALL_STORED_FUNCTION
84012>>>>>>>/// @Description This command is used to execute a function stored in the
84012>>>>>>>/// SQL backend. This is an alternative to building a function with the
84012>>>>>>>/// SQL_SET_FUNCTION_NAME, SQL_SET_FUNCTION_PARAMETER and SQL_FUNCTION_EXECUTE
84012>>>>>>>/// commands. This command builds and executes the function by setting the full
84012>>>>>>>/// function name, the parameter(s) to pass and the variable to hold the
84012>>>>>>>/// returned value. Note that this command can only return a single value
84012>>>>>>>/// so SQL_SET_FUNCTION_PARAMETER and SQL_SET_FUNCTION_NAME must be used when
84012>>>>>>>/// dealing with multiple return values.
84012>>>>>>>///
84012>>>>>>>/// Assumptions
84012>>>>>>>/// @Status      Public
84012>>>>>>>/// @Drivers     ORAFLex MySQLFlex PgFlex
84012>>>>>>>/// @VersionNote Last Revised: 2013-10-01 by Aaron Gulack
84012>>>>>>>/// @See
84012>>>>>>>///
84012>>>>>>>/// @Syntax CALL_STORED_FUNCTION {function} Returns {variable} Passing {parameters}
84012>>>>>>>/// @Param function                     Full name of the function
84012>>>>>>>/// @Param variable                     Variable to hold the returned value
84012>>>>>>>/// @Param parameters           Parameter to pass to the function (can be multiple)
84012>>>>>>>///
84012>>>>>>>/// @Example
84012>>>>>>>/// Move 5 to sCustomerID
84012>>>>>>>/// CALL_STORED_FUNCTION "getCustomerStatus" Returns sStatus Passing sCustomerID
84012>>>>>>>/// Showln sStatus
84012>>>>>>>
84012>>>>>>>//=============================================================================
84012>>>>>>>/// @Name        OUTPUT_INT_FILE
84012>>>>>>>/// @Description This command is used to output the int file of an opened
84012>>>>>>>/// table. If the file to be output to does not exist, it will be created
84012>>>>>>>/// upon execution of this command. Note that the INT file can be output
84012>>>>>>>/// into multiple types of files i.e. .doc, .txt, .int.
84012>>>>>>>///
84012>>>>>>>/// @Assumptions
84012>>>>>>>/// @Status      Public
84012>>>>>>>/// @Drivers     All
84012>>>>>>>/// @VersionNote Last Revised: 2013-10-01 by Aaron Gulack
84012>>>>>>>/// @See
84012>>>>>>>///
84012>>>>>>>/// @Syntax OUTPUT_INT_FILE for {FileNumber} to {variable}
84012>>>>>>>/// @Param FileNumber           The file number
84012>>>>>>>/// @Param variable                     Path of the file being output to
84012>>>>>>>///
84012>>>>>>>///@Example
84012>>>>>>>/// OUTPUT_INT_FILE for Customer.File_Number to "C:\Temp\Customer.int"
84012>>>>>>>
84012>>>>>>>//=============================================================================
84012>>>>>>>/// @Name        SQL_ERROR_MESSAGE
84012>>>>>>>/// @Description This command is used to get an error message
84012>>>>>>>/// from a given SQL statement. If the given statement is executed with
84012>>>>>>>/// no errors, the variable specified with this command will be blank.
84012>>>>>>>/// Otherwise the message will be stored in the given variable. Note that
84012>>>>>>>/// unless specified, strings have a size limit of 80 characters, so using
84012>>>>>>>/// a variant can ensure the full message is retrieved.
84012>>>>>>>///
84012>>>>>>>/// @Assumptions
84012>>>>>>>/// @Status      Public
84012>>>>>>>/// @Drivers     All
84012>>>>>>>/// @VersionNote Last Revised: 2013-10-01 by Aaron Gulack
84012>>>>>>>/// @See         SQL_ERROR_MESSAGE2
84012>>>>>>>///
84012>>>>>>>/// @Syntax SQL_ERROR_MESSAGE {variable}
84012>>>>>>>/// @Param variable                     Variable to hold the error message
84012>>>>>>>///
84012>>>>>>>/// @Example
84012>>>>>>>/// SQL_ERROR_MESSAGE sError
84012>>>>>>>
84012>>>>>>>Function MertechInc_SQL_ERROR_MESSAGE Global Returns String
84014>>>>>>>    Local String sMessage
84014>>>>>>>
84014>>>>>>>    Get MertechInc_Pre_Size_String 0 to sMessage
84015>>>>>>>    Call_Driver 0 MertechInc_DriverName Function CALLDRV_SQL_ERROR_MESSAGE CALLBACK 0 PASSING MertechInc_Blank sMessage 0 RESULT MertechInc_iRet
84020>>>>>>>
84020>>>>>>>    Function_Return sMessage
84021>>>>>>>End_Function
84022>>>>>>>
84022>>>>>>>//=============================================================================
84022>>>>>>>/// @Name        SQL_ERROR_MESSAGE2
84022>>>>>>>/// @Description This command is used to get the last error message used
84022>>>>>>>/// for the specified server. This can be useful once a transaction has
84022>>>>>>>/// already been completed and any error messages need to be retrieved.
84022>>>>>>>///
84022>>>>>>>/// @Assumptions
84022>>>>>>>/// @Status      Public
84022>>>>>>>/// @Drivers     All
84022>>>>>>>/// @VersionNote Last Revised: 2013-10-01 by Aaron Gulack
84022>>>>>>>/// @See         SQL_ERROR_MESSAGE SQL_ERROR_MESSAGE2
84022>>>>>>>///
84022>>>>>>>/// @Syntax SQL_ERROR_MESSAGE2 of {server} to {variable}
84022>>>>>>>/// @Param server                       Name of the server
84022>>>>>>>/// @Param variable                     Variable to hold the error message
84022>>>>>>>///
84022>>>>>>>/// @Example
84022>>>>>>>/// SQL_ERROR_MESSAGE2 of "localhost" to sError
84022>>>>>>>
84022>>>>>>>Function MertechInc_SQL_ERROR_MESSAGE2 Global String sServer Returns String
84024>>>>>>>    Local String sMessage
84024>>>>>>>
84024>>>>>>>    Get MertechInc_Pre_Size_String 800 to sMessage
84025>>>>>>>    Call_Driver 0 MertechInc_DriverName Function CALLDRV_SQL_ERROR_MESSAGE2 CALLBACK 0 PASSING sServer sMessage 0 RESULT MertechInc_iRet
84030>>>>>>>
84030>>>>>>>    Function_Return sMessage
84031>>>>>>>End_Function
84032>>>>>>>
84032>>>>>>>//=============================================================================
84032>>>>>>>/// @Name        MERTECH_WARNING_MESSAGE
84032>>>>>>>/// @Description When restructuring a table, i.e. Structure_Start, a warning
84032>>>>>>>/// message will appear to confirm the restructure before it is executed.
84032>>>>>>>/// This command is used to disable or enable that warning message. All that
84032>>>>>>>/// is passed is either the constant "Enabled" or "Disabled". By default,
84032>>>>>>>/// this message is enabled.
84032>>>>>>>///
84032>>>>>>>/// @Assumptions
84032>>>>>>>/// @Status      Public
84032>>>>>>>/// @Drivers     All
84032>>>>>>>/// @VersionNote Last Revised: 2013-10-01 by Aaron Gulack
84032>>>>>>>///
84032>>>>>>>/// @Syntax MERTECH_WARNING_MESSAGE {Enabled|Disabled}
84032>>>>>>>/// @Param Enabled                      Enables the restructure warning
84032>>>>>>>/// @Param Disabled                     Disables the restructure warning
84032>>>>>>>///
84032>>>>>>>/// @Example
84032>>>>>>>/// Move Customer.File_Number to hFile
84032>>>>>>>/// MERTECH_WARNING_MESSAGE Disabled
84032>>>>>>>///
84032>>>>>>>/// Structure_Start hFile
84032>>>>>>>///     Set_Attribute DF_FILE_OEM_TRANSLATION of hFile to True
84032>>>>>>>/// Structure_End hFile
84032>>>>>>>
84032>>>>>>>//=============================================================================
84032>>>>>>>/// @Name        DISABLE_SELECT_COLUMNS_ERRORS
84032>>>>>>>/// @Description When using SELECT_COLUMNS_FIND to limit the number of columns
84032>>>>>>>/// to fetch, the framework might still ask for columns that you do not need.
84032>>>>>>>/// As a result you'll end up getting runtime errors you do not want to see.
84032>>>>>>>/// This command gives you the ability to stop reporting errors for querying
84032>>>>>>>/// for data from columns that are not part of the query.
84032>>>>>>>///
84032>>>>>>>/// DISABLED_SELECT_COLUMNS_ERRORS DISABLED will disable the errors, use
84032>>>>>>>/// ENABLED to turn the error messages back on.
84032>>>>>>>///
84032>>>>>>>/// By default triggering error messages on unknown columns is ENABLED
84032>>>>>>>///
84032>>>>>>>/// @Assumptions
84032>>>>>>>/// @Status      Public
84032>>>>>>>/// @Drivers     All
84032>>>>>>>/// @VersionNote Last Revised: 2014-04-28 by Wil van Antwerpen
84032>>>>>>>/// @See         SELECT_COLUMNS_FIND RESET_FETCH_FIELDS
84032>>>>>>>///
84032>>>>>>>/// @Example
84032>>>>>>>/// Open Customer
84032>>>>>>>/// RESET_FETCH_FIELDS  CUSTOMER DF_FETCH_FALSE
84032>>>>>>>/// SELECT_COLUMNS_FIND CUSTOMER CUSTOMER_NUMBER NAME
84032>>>>>>>/// DISABLE_SELECT_COLUMNS_ERRORS DISABLED
84032>>>>>>>///
84032>>>>>>>/// Clear Customer
84032>>>>>>>/// Repeat
84032>>>>>>>///    Find Gt Customer by Index.1
84032>>>>>>>///    If (Found) Showln Customer.Customer_Number '-' Customer.Name
84032>>>>>>>/// Until (Not(Found))
84032>>>>>>>///
84032>>>>>>>/// RESET_FETCH_FIELDS Customer DF_FETCH_TRUE
84032>>>>>>>///
84032>>>>>>>/// @Syntax DISABLE_SELECT_COLUMNS_ERRORS {ENABLED|DISABLED}
84032>>>>>>>
