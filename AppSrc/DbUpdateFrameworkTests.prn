91317>>>>>     
91317>>>>>    // Same as SqlColumnChange but instead of passing a filelist number; pass the table name as a string. 
91317>>>>>    // The fourth & fifth arguments are optional, depending on the iDataType
91317>>>>>    // passed. For e.g. a DF_ASCII the iLen must be passed.                     // Optional: // Optional:  
91317>>>>>    Function SqlColumnChangeByTableName String sTableName String sColumnName Integer iDataType Integer iLen Integer iDec Returns Boolean
91319>>>>>        Integer iColumn iDbType iLength iDecimals
91319>>>>>        String sDriverID sStmt sAlterTable sAlterColumn sVal sDataType sRetval sLengthAndDecimals sNotNull
91319>>>>>        Boolean bExists bOK bFixed
91319>>>>>        Handle hTable
91319>>>>>        
91319>>>>>        Get psDriverID to sDriverID
91320>>>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
91321>>>>>        If (bOK = False) Begin
91323>>>>>            Function_Return False
91324>>>>>        End
91324>>>>>>
91324>>>>>        
91324>>>>>        Get UtilTableNameToHandle sTableName to hTable 
91325>>>>>        If (hTable = 0) Begin
91327>>>>>            Get NextFreeFilelistSlot to hTable
91328>>>>>        End
91328>>>>>>
91328>>>>>        Get SQLUtilColumnExists sTableName sColumnName to bExists
91329>>>>>        If (bExists = True) Begin
91331>>>>>            Function_Return False
91332>>>>>        End
91332>>>>>>
91332>>>>>
91332>>>>>        If (num_arguments > 3) Begin
91334>>>>>            Move iLen to iLength
91335>>>>>        End                     
91335>>>>>>
91335>>>>>        If (num_arguments > 4) Begin
91337>>>>>            Move iDec to iDecimals
91338>>>>>        End                
91338>>>>>>
91338>>>>>        
91338>>>>>        Get piDbType to iDbType
91339>>>>>        Get UtilColumnTypeToString sDriverID iDbType iDataType to sDataType
91340>>>>>        
91340>>>>>        Move False to Err   
91341>>>>>        Get _SqlProperTableName sTableName    to sTableName
91342>>>>>        Get _SqlFindKeyWord CI_SQLAlterTable  to sAlterTable
91343>>>>>        Get _SqlFindKeyWord CI_SQLAlterColumn to sAlterColumn
91344>>>>>        Get SQLUtilDefaultNullValue sDriverID iDbType iDataType to sNotNull
91345>>>>>
91345>>>>>        Get UtilColumnTypeFixed sDriverID iDbType iDataType to bFixed
91346>>>>>        If (bFixed = False) Begin
91348>>>>>            Get _SqlFormatLengthAndDecimalAsString iLength iDecimals to sLengthAndDecimals
91349>>>>>        End
91349>>>>>>
91349>>>>>        
91349>>>>>        Move (sAlterTable * sTableName * sAlterColumn * sColumnName * sDataType + sLengthAndDecimals * sNotNull) to sStmt
91350>>>>>        Send SqlUtilExecuteQuery sStmt sDriverID
91351>>>>>    
91351>>>>>        // We also need to remove the cache-file since the table has been changed
91351>>>>>        Get UtilDeleteCacheFile sTableName to bOK
91352>>>>>    
91352>>>>>        Function_Return (Err = False)    
91353>>>>>    End_Function    
91354>>>>>    
91354>>>>>    Function SqlColumnDefaultValue Handle hTable Integer iColumn String sValue Returns Boolean
91356>>>>>        Boolean bOK bErr bIsSQLDriver
91356>>>>>        String sDriverID
91356>>>>>        
91356>>>>>        Get psDriverID to sDriverID
91357>>>>>        Get IsSQLDriver sDriverID to bIsSQLDriver
91358>>>>>        If (bIsSQLDriver = False) Begin
91360>>>>>            Function_Return False
91361>>>>>        End
91361>>>>>>
91361>>>>>
91361>>>>>        Move Err to bErr
91362>>>>>        Move False to bErr                                      
91363>>>>>        
91363>>>>>        // There seems to be a problem with the ODBC_DRV driver that sometimes
91363>>>>>        // inserts randomly character(10) and spaces, so we correct from that here:
91363>>>>>        Move (Replaces(Character(10), Trim(sValue), "")) to sValue                   
91364>>>>>        
91364>>>>>        Set_Attribute DF_FIELD_DEFAULT_VALUE of hTable iColumn to sValue
91367>>>>>        Move (not(Err)) to bOK
91368>>>>>        Move bErr to Err
91369>>>>>        
91369>>>>>        Function_Return bOK
91370>>>>>    End_Function
91371>>>>>    
91371>>>>>    Function SqlColumnNullable Handle hTable Integer iColumn Boolean bNullable Returns Boolean
91373>>>>>        Boolean bOK bErr bCurrentState bOpen bIsSQLDriver
91373>>>>>        String sDriverID
91373>>>>>        
91373>>>>>        Get psDriverID to sDriverID
91374>>>>>        Get IsSQLDriver sDriverID to bIsSQLDriver
91375>>>>>        If (bIsSQLDriver = False) Begin
91377>>>>>            Function_Return False
91378>>>>>        End
91378>>>>>>
91378>>>>>        
91378>>>>>        Move Err to bErr
91379>>>>>        Move False to bErr
91380>>>>>        Get_Attribute DF_FIELD_NULL_ALLOWED of hTable iColumn to bCurrentState
91383>>>>>        If (bNullable = bCurrentState) Begin
91385>>>>>            Function_Return True
91386>>>>>        End                     
91386>>>>>>
91386>>>>>        
91386>>>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpen
91389>>>>>        If (bOpen = False) Begin                       
91391>>>>>            Get AutoConnectionIDLogin to bOK
91392>>>>>            Send Ignore_Error of Error_Object_Id DFERR_CANT_OPEN_DATA_FILE
91393>>>>>            Send Ignore_Error of Error_Object_Id DFERR_CANT_OPEN_INTERMEDIATE_FILE
91394>>>>>            Send Ignore_Error of Error_Object_Id CLIERR_GENERAL_ERROR
91395>>>>>            Open hTable
91397>>>>>            Send Trap_Error of Error_Object_Id DFERR_CANT_OPEN_DATA_FILE
91398>>>>>            Send Trap_Error of Error_Object_Id DFERR_CANT_OPEN_INTERMEDIATE_FILE
91399>>>>>            Send Trap_Error of Error_Object_Id CLIERR_GENERAL_ERROR
91400>>>>>            Get_Attribute DF_FILE_OPENED of hTable to bOpen
91403>>>>>        End
91403>>>>>>
91403>>>>>        If (bOpen = True) Begin
91405>>>>>            Structure_Start hTable sDriverID
91406>>>>>                Set_Attribute DF_FIELD_NULL_ALLOWED of hTable iColumn to bNullable
91409>>>>>            Structure_End hTable
91411>>>>>        End
91411>>>>>>
91411>>>>>
91411>>>>>        Move (not(Err)) to bOK
91412>>>>>        Move bErr to Err
91413>>>>>        
91413>>>>>        Function_Return bOK
91414>>>>>    End_Function
