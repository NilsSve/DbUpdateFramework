97277>>>>>    
97277>>>>>    // The normal connection string looks something like this;
97277>>>>>    // SERVER=.\SQLEXPRESS; DATABASE=OrderEntry; TRUSTED_CONNECTION=Yes; ,0
97277>>>>>    // ...and the full connection string looks like this;
97277>>>>>    // DFConnectionId OrderEntry, SERVER=.\SQLEXPRESS; DATABASE=OrderEntry; TRUSTED_CONNECTION=Yes; ,0
97277>>>>>    Function psFullConnectionString Returns String
97279>>>>>        String sConnectionID sConnectionString
97279>>>>>        If (ghoSQLConnectionHandler = 0) Begin
97281>>>>>            Error DFERR_PROGRAM "ghoSQLConnectionHandler = 0! This indicates that NO ConnectionID has been setup by the programmer."
97282>>>>>>
97282>>>>>            Function_Return
97283>>>>>        End                                                                   
97283>>>>>>
97283>>>>>        Get psConnectionID     of ghoSQLConnectionHandler to sConnectionID                       
97284>>>>>        Move (Trim(sConnectionID)) to sConnectionID
97285>>>>>        Get psConnectionString of ghoSQLConnectionHandler to sConnectionString
97286>>>>>        Function_Return (CS_SQLConnectionIDText * sConnectionID + "," * String(sConnectionString))
97287>>>>>    End_Function
