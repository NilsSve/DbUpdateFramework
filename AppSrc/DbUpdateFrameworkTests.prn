86587>>>>>>>>>>>
86587>>>>>>>>>>>
86587>>>>>>>>>>>// Courtesy Of Vincent Oorsprong
86587>>>>>>>>>>>Function vConvertFileDateTime Global Dword dwLowDateTime Dword dwHighDateTime Returns String
86589>>>>>>>>>>>  String  sftTime sSystemTime sFormattedTime sFormattedDate
86589>>>>>>>>>>>  Pointer lpsftTime lpsSystemTime lpsFormattedTime lpsFormattedDate
86589>>>>>>>>>>>  Integer iSuccess iLenCcTime iDataLength iLenCcDate
86589>>>>>>>>>>>
86589>>>>>>>>>>>  ZeroType vFileTime  To sftTime
86590>>>>>>>>>>>  Put dwLowDateTime  To sftTime At vFileTime.dwLowDateTime
86591>>>>>>>>>>>  Put dwHighDateTime To sftTime At vFileTime.dwHighDateTime
86592>>>>>>>>>>>  GetAddress Of sftTime To lpsftTime
86593>>>>>>>>>>>
86593>>>>>>>>>>>  ZeroType vSystemTime To sSystemTime
86594>>>>>>>>>>>  GetAddress Of sSystemTime To lpsSystemTime
86595>>>>>>>>>>>
86595>>>>>>>>>>>  Moveint (vWin32_FileTimeToSystemTime (lpsftTime, lpsSystemTime)) To iSuccess
86596>>>>>>>>>>>>
86596>>>>>>>>>>>  If iSuccess Eq DfTrue Begin
86598>>>>>>>>>>>    ZeroString 255 To sFormattedTime
86599>>>>>>>>>>>    GetAddress Of sFormattedTime To lpsFormattedTime
86600>>>>>>>>>>>    Length sFormattedTime To iLenCcTime
86601>>>>>>>>>>>>
86601>>>>>>>>>>>    Moveint (vWin32_GetTimeFormat (LOCALE_USER_DEFAULT, 0, lpsSystemTime, 0, ;                             lpsFormattedTime, iLenCcTime)) To iDataLength
86602>>>>>>>>>>>>
86602>>>>>>>>>>>    ZeroString 255 To sFormattedDate
86603>>>>>>>>>>>    GetAddress Of sFormattedDate To lpsFormattedDate
86604>>>>>>>>>>>    Length sFormattedDate To iLenCcDate
86605>>>>>>>>>>>>
86605>>>>>>>>>>>    Moveint (vWin32_GetDateFormat (LOCALE_USER_DEFAULT, 0, lpsSystemTime, 0, ;                             lpsFormattedDate, iLenCcDate)) To iDataLength
86606>>>>>>>>>>>>
86606>>>>>>>>>>>    Function_Return (Cstring (sFormattedDate)  * Cstring (sFormattedTime))
86607>>>>>>>>>>>  End // iSuccess
86607>>>>>>>>>>>>
86607>>>>>>>>>>>End_Function // vConvertFileDateTime
86608>>>>>>>>>>>
86608>>>>>>>>>>>
86608>>>>>>>>>>>// **WvA Removed, See the cFileSet class for an alternative
86608>>>>>>>>>>>//Procedure DoBrowseDir String sFilePath
86608>>>>>>>>>>>//End_Procedure // DoBrowseDir
86608>>>>>>>>>>>
86608>>>>>>>>>>>// **WvA:
86608>>>>>>>>>>>// A windows replacement for the standard function FileExists.
86608>>>>>>>>>>>// This version will also return (true) for a file when it is open by an application.
86608>>>>>>>>>>>// Note that you can apply normal windows mask-signs in the filename such as * and ?
86608>>>>>>>>>>>// Example: Get vFilePathExists "C:\config.sy?"
86608>>>>>>>>>>>// This will return true if you have a file matching these conditions. (aka config.sys)
86608>>>>>>>>>>>Function vFilePathExists Global String sFilePathMask Returns Integer
86610>>>>>>>>>>>  String  sWin32FindData
86610>>>>>>>>>>>  String  sDirSep
86610>>>>>>>>>>>  Pointer lpsFilePathMask lpsWin32FindData
86610>>>>>>>>>>>  Handle  hFindFile
86610>>>>>>>>>>>  Integer iVoid
86610>>>>>>>>>>>
86610>>>>>>>>>>>  Move vINVALID_HANDLE_VALUE To hFindFile
86611>>>>>>>>>>>  Move (ToANSI(trim(sFilePathMask))) To sFilePathMask
86612>>>>>>>>>>>  
86612>>>>>>>>>>>  If (length(sFilePathMask)>0) Begin
86614>>>>>>>>>>>    // 2014-09-29 NGS Remove any trailing dir separators, as they make the function fail.
86614>>>>>>>>>>>    Move (sysconf(SYSCONF_DIR_SEPARATOR)) to sDirSep
86615>>>>>>>>>>>    While (Right(sFilePathMask, 1) = sDirSep)
86619>>>>>>>>>>>      Move (Left(sFilePathMask, Length(sFilePathMask) -1)) to sFilePathMask
86620>>>>>>>>>>>    Loop
86621>>>>>>>>>>>>
86621>>>>>>>>>>>    
86621>>>>>>>>>>>    GetAddress Of sFilePathMask To lpsFilePathMask
86622>>>>>>>>>>>    ZeroType vWin32_Find_Data To sWin32FindData
86623>>>>>>>>>>>    GetAddress Of sWin32FindData To lpswin32FindData
86624>>>>>>>>>>>    Move (vWin32_FindFirstFile (lpsFilePathMask, lpsWin32FindData)) To hFindFile
86625>>>>>>>>>>>    Move (vWin32_FindClose (hFindFile)) To iVoid
86626>>>>>>>>>>>  End
86626>>>>>>>>>>>>
86626>>>>>>>>>>>  Function_Return (hFindFile <> vINVALID_HANDLE_VALUE)
86627>>>>>>>>>>>End_Function // vFilePathExists
86628>>>>>>>>>>>
86628>>>>>>>>>>>
86628>>>>>>>>>>>// **WvA
86628>>>>>>>>>>>// Formats a foldername by first trimming it and after that by sticking a
86628>>>>>>>>>>>// directory separator (/\) to the end if it doesn't have one there already.
86628>>>>>>>>>>>// The folder may contain a drive letter or UNC encoding.
86628>>>>>>>>>>>Function vFolderFormat Global String sFolderName Returns String
86630>>>>>>>>>>>  String sDirSep
86630>>>>>>>>>>>  Move (sysconf(SYSCONF_DIR_SEPARATOR)) To sDirSep  // normally \ (backslash)
86631>>>>>>>>>>>  Move (Trim(sFolderName)) To sFolderName
86632>>>>>>>>>>>  If (Right(sFolderName,1)<>sDirSep) Begin
86634>>>>>>>>>>>    Move (sFolderName+sDirSep) To sFolderName
86635>>>>>>>>>>>  End
86635>>>>>>>>>>>>
86635>>>>>>>>>>>  Function_Return sFolderName
86636>>>>>>>>>>>End_Function // vFolderFormat
86637>>>>>>>>>>>//
86637>>>>>>>>>>>// Returns the amount of files in the folder (if it exists)
86637>>>>>>>>>>>// Returns -1 if folder doesn't exist.
86637>>>>>>>>>>>// The files "." and ".." are not counted.
86637>>>>>>>>>>>//
86637>>>>>>>>>>>Function vFolderFileCount Global String sFolderName Returns Integer
86639>>>>>>>>>>>  Boolean bFound
86639>>>>>>>>>>>  Handle  hFindFile
86639>>>>>>>>>>>  Integer iCount  iVoid
86639>>>>>>>>>>>  Integer iSuccess
86639>>>>>>>>>>>  Pointer lpsFolderName lpsWin32FindData
86639>>>>>>>>>>>  String  sWin32FindData
86639>>>>>>>>>>>  String  sFileName
86639>>>>>>>>>>>  
86639>>>>>>>>>>>  Move -1 To iCount
86640>>>>>>>>>>>  Get vFolderFormat sFolderName To sFolderName
86641>>>>>>>>>>>  Move (sFolderName+"*") To sFolderName // match any filename in the folder
86642>>>>>>>>>>>  GetAddress Of sFolderName To lpsFolderName
86643>>>>>>>>>>>  ZeroType vWin32_Find_Data To sWin32FindData
86644>>>>>>>>>>>  GetAddress Of sWin32FindData To lpswin32FindData
86645>>>>>>>>>>>  Move (vWin32_FindFirstFile (lpsFolderName, lpsWin32FindData)) To hFindFile
86646>>>>>>>>>>>  Move (hFindFile<>vINVALID_HANDLE_VALUE) To bFound
86647>>>>>>>>>>>  If (bFound) Move 0 To iCount
86650>>>>>>>>>>>  While (bFound)
86654>>>>>>>>>>>    Increment iCount
86655>>>>>>>>>>>    GetBuff_String From sWin32FindData At vWin32_Find_Data.cFileName To sFileName
86656>>>>>>>>>>>    If (sFileName="." or sFileName="..") Decrement iCount
86659>>>>>>>>>>>    Move (vWin32_FindNextFile(hFindFile, lpsWin32FindData)) To iSuccess
86660>>>>>>>>>>>    Move (iSuccess<>0) To bFound
86661>>>>>>>>>>>  Loop
86662>>>>>>>>>>>>
86662>>>>>>>>>>>  Move (vWin32_FindClose (hFindFile)) To iVoid
86663>>>>>>>>>>>  Function_Return iCount
86664>>>>>>>>>>>End_Function // vFolderFileCount
86665>>>>>>>>>>>   
86665>>>>>>>>>>>
86665>>>>>>>>>>>//
86665>>>>>>>>>>>// Gets the parent path of the currently supplied path
86665>>>>>>>>>>>// Returns "" when we are at the root folder.
86665>>>>>>>>>>>//
86665>>>>>>>>>>>Function vParentPath Global String sPath Returns String
86667>>>>>>>>>>>  String sStrip
86667>>>>>>>>>>>  
86667>>>>>>>>>>>  If (Right(sPath,1)="\") Begin
86669>>>>>>>>>>>    Move (Left(sPath,Length(sPath)-1)) To sPath
86670>>>>>>>>>>>  End
86670>>>>>>>>>>>>
86670>>>>>>>>>>>  If (Pos("\",sPath)) Begin
86672>>>>>>>>>>>    Move (StringFromRightOfChar(sPath,"\")) To sStrip
86673>>>>>>>>>>>    Move (Replace(sStrip,sPath,"")) To sPath
86674>>>>>>>>>>>  End
86674>>>>>>>>>>>>
86674>>>>>>>>>>>  Else Begin
86675>>>>>>>>>>>    Move "" To sPath
86676>>>>>>>>>>>  End
86676>>>>>>>>>>>>
86676>>>>>>>>>>>  Function_Return sPath
86677>>>>>>>>>>>End_Function // vParentPath
86678>>>>>>>>>>>
86678>>>>>>>>>>>// Create the folder, including intermediate directories.
86678>>>>>>>>>>>// Don't panic if the folder already exists.
86678>>>>>>>>>>>// Michael Mullan June 2009.
86678>>>>>>>>>>>Function vshCreateDirectoryEX Global String sNewFolder Returns Integer
86680>>>>>>>>>>>  String  sFolder sSA
86680>>>>>>>>>>>  Pointer lpsFolder lpsSecurity_Attributes
86680>>>>>>>>>>>  Integer iRetval bFolderCreated bInheritHandle
86680>>>>>>>>>>>  Move (False) to bFolderCreated
86681>>>>>>>>>>>  // fill string variable with null characters
86681>>>>>>>>>>>  ZeroType vtSecurity_attributes to sSA
86682>>>>>>>>>>>  // null MAX_PATH chars into var (make space)
86682>>>>>>>>>>>  Move (Repeat(Character(0), vMAX_PATH)) to sFolder
86683>>>>>>>>>>>  If (sNewFolder <> "") Begin
86685>>>>>>>>>>>    Move dfTrue to  bInheritHandle
86686>>>>>>>>>>>    // Setting this to NULL is already done by the zerotype command
86686>>>>>>>>>>>    // Move NULL   To  lpDescriptor
86686>>>>>>>>>>>    Put (length(sSA))   to sSA At vtSecurity_attributes.nLength
86687>>>>>>>>>>>    //Put lpDescriptor To sSA at vtSecurity_attributes.lpDescriptor
86687>>>>>>>>>>>    Put bInheritHandle to sSA At vtSecurity_attributes.bInheritHandle
86688>>>>>>>>>>>    GetAddress of sSA to lpsSecurity_Attributes
86689>>>>>>>>>>>    //
86689>>>>>>>>>>>    Move sNewFolder to sFolder
86690>>>>>>>>>>>    GetAddress of sFolder to lpsFolder
86691>>>>>>>>>>>    Move (vWin32_SHCreateDirectoryEx(0,lpsFolder, lpsSecurity_Attributes)) to bFolderCreated
86692>>>>>>>>>>>  End
86692>>>>>>>>>>>>
86692>>>>>>>>>>> 
86692>>>>>>>>>>>  If (bFolderCreated <> 0) Begin
86694>>>>>>>>>>>    Move 1 to iRetVal
86695>>>>>>>>>>>   
86695>>>>>>>>>>>    If (bFolderCreated = 161 ) Error DFERR_OPERATOR ("Path " + sNewFolder + " is Not Valid (ERROR_BAD_PATHNAME)")
86698>>>>>>>>>>>    Else If (bFolderCreated = 206 ) Error DFERR_OPERATOR ("Path " + sNewFolder + " is Not Valid (ERROR_FILENAME_EXCED_RANGE)")
86702>>>>>>>>>>>    Else If (bFolderCreated = 3   ) Error DFERR_OPERATOR ("Path " + sNewFolder + " is Not Valid (ERROR_PATH_NOT_FOUND)")
86706>>>>>>>>>>>    Else If (bFolderCreated = 80  ) Move 0 to iRetval // "ERROR_FILE_EXISTS"     not really an error
86710>>>>>>>>>>>    Else If (bFolderCreated = 183 ) Move 0 to iRetval //  "ERROR_ALREADY_EXISTS"     not really an error
86714>>>>>>>>>>>    Else If (bFolderCreated = 1223) Error DFERR_OPERATOR ("Path " + sNewFolder + " is Not Valid (ERROR_CANCELLED)")
86718>>>>>>>>>>>    Else Error DFERR_OPERATOR ("Folder Creation Error # " + String(bfoldercreated) + "\n" + sNewFolder + "(FILE_CREATION_ERROR)")
86720>>>>>>>>>>>  End
86720>>>>>>>>>>>>
86720>>>>>>>>>>>  Function_Return iRetVal
86721>>>>>>>>>>>End_Function // vshCreateDirectoryEX
