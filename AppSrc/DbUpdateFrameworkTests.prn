85057>>>// *************************************************************************
85057>>>//  Public message. This is the default message. It is expected that you will
85057>>>//   create your own message to override this
85057>>>// *************************************************************************
85057>>>
85057>>>Procedure Activate_About
85060>>>   Send DoAbout "" "" "" "" ""
85061>>>End_Procedure
85062>>>
85062>>>// *************************************************************************
85062>>>//  Public message. It is expected that you will send this message (most
85062>>>//  likely from Activate_About. This creates an about object, activates it
85062>>>//  and destroys it when done. It is not exepected that you will augment this.
85062>>>// *************************************************************************
85062>>>// Sample usage:
85062>>>//   The first two params will automatically be filled from the application settings if not provided.
85062>>>//   Send DoAbout "" "" ("Copyright: 2013" * psCompany(ghoApplication)) "Created by: Your Name" "YourAppBitmap.bmp" "Internet: http://www.YourWebAddress.com" "E-mail: mailto:support@YourEmailAddress.com" "Some other description of choice" "9th param" "and last param"
85062>>>
85062>>>Procedure DoAbout String sTitle String sVersion String sCopyRight String sAuthor String sBitmap ;                  String sParam6 String sParam7 String sParam8 String sParam9 String sParam10
85065>>>        Integer hoObj hoMain iArgs
85065>>>        String sValue
85065>>>
85065>>>        // Create object
85065>>>        Object About is an AboutDialog
85067>>>            // Uncomment these two lines if you would like to have a resizable About object.
85067>>>//            Set Border_Style to Border_Thick
85067>>>//            Set peAnchors to anAll
85067>>>
85067>>>            // Add checking for the number of arguments passed to avoid runtime errors
85067>>>            // if one of them is not passed. This makes the interface
85067>>>            // more flexible.
85067>>>            Move num_arguments to iArgs
85068>>>
85068>>>            // If no title is passed use the label of the main panel (if a main panel exists).
85068>>>            If (iArgs > 0 and sTitle = "") Begin
85070>>>                Get Main_Window of Desktop to hoMain
85071>>>                If hoMain Get Label of hoMain to sValue
85074>>>            End
85074>>>>
85074>>>            Else If (iArgs > 0 and sTitle <> "") Begin
85077>>>                Move sTitle to sValue
85078>>>            End
85078>>>>
85078>>>            Else If (iArgs = 0) Begin
85081>>>                Get Main_Window of Desktop to hoMain
85082>>>                If hoMain Get Label of hoMain to sValue
85085>>>            End
85085>>>>
85085>>>
85085>>>            If (sValue <> "") Send Add_LineLn sValue
85088>>>            Move "" to sValue
85089>>>
85089>>>            // If the passed sVersion value is blank, the info will be retrieved from the cApplication object.
85089>>>            // For this to work the Project Properties Version must have been set in the Studio.
85089>>>            If (iArgs < 2) Begin
85091>>>                Move "" to sValue
85092>>>            End
85092>>>>
85092>>>            Else Begin
85093>>>                Move sVersion to sValue
85094>>>            End
85094>>>>
85094>>>            Set Version to sValue
85095>>>
85095>>>            If (iArgs > 2 and sCopyRight <> "") Send Add_LineLn sCopyRight
85098>>>
85098>>>            // If only the five "standard" params were passed we don't add an extra linefeed;
85098>>>            // else we do.
85098>>>            If (iArgs > 3 and iArgs < 6 and sAuthor <> "") Begin
85100>>>                Send Add_Line sAuthor
85101>>>            End
85101>>>>
85101>>>            Else If (iArgs > 5 and sAuthor <> "") Begin
85104>>>                Send Add_LineLn sAuthor
85105>>>            End
85105>>>>
85105>>>
85105>>>            // Square bitmaps of 80x80 works best
85105>>>            If (iArgs > 4 and sBitmap <> "") Begin
85107>>>               Set Logo to sBitMap
85108>>>            End
85108>>>>
85108>>>
85108>>>            // Here starts handling of the five optional params:
85108>>>            If (iArgs = 6 and sParam6  <> "") Begin
85110>>>                Send Add_Line sParam6
85111>>>            End
85111>>>>
85111>>>            Else If (iArgs > 6 and sParam6  <> "") Begin
85114>>>                Send Add_LineLn sParam6
85115>>>            End
85115>>>>
85115>>>
85115>>>            If (iArgs = 7 and sParam7  <> "") Begin
85117>>>                Send Add_Line sParam7
85118>>>            End
85118>>>>
85118>>>            Else If (iArgs > 7 and sParam7  <> "") Begin
85121>>>                Send Add_LineLn sParam7
85122>>>            End
85122>>>>
85122>>>
85122>>>            If (iArgs = 8 and sParam8  <> "") Begin
85124>>>                Send Add_Line sParam8
85125>>>            End
85125>>>>
85125>>>            Else If (iArgs > 8 and sParam8  <> "") Begin
85128>>>                Send Add_LineLn sParam8
85129>>>            End
85129>>>>
85129>>>
85129>>>            If (iArgs = 9 and sParam9  <> "") Begin
85131>>>                Send Add_Line sParam9
85132>>>            End
85132>>>>
85132>>>            Else If (iArgs > 9 and sParam9  <> "") Begin
85135>>>                Send Add_LineLn sParam9
85136>>>            End
85136>>>>
85136>>>
85136>>>            If (iArgs = 10 and sParam10 <> "") Begin
85138>>>                Send Add_Line sParam10
85139>>>            End
85139>>>>
85139>>>
85139>>>            Move Self to hoObj
85140>>>        End_Object
85141>>>
85141>>>        Send Popup   of hoObj // Popup the about object
85142>>>        Send Destroy of hoObj // When done, it will be destroyed
85143>>>End_Procedure
