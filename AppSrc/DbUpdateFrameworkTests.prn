90403>>>>>>>    // *** Main Connection Message ***
90403>>>>>>>    // It will create a Connection ID for the passed driver. 
90403>>>>>>>    // It will also set the psDriverID & psConnectionID of this class.
90403>>>>>>>    Procedure CreateSQLConnection String sDriverID String sConnectionID String sServer String sDatabase Boolean bTrusted String sUserID String sPassword Boolean bSilent
90405>>>>>>>        Integer iResult
90405>>>>>>>        Handle hoCLI hoDriver
90405>>>>>>>        String sConnectionString sError  
90405>>>>>>>        Boolean bMertech bLoginSuccessful
90405>>>>>>>        
90405>>>>>>>        Get ConstructConnectionString sDriverID sServer sDatabase bTrusted sUserID sPassword to sConnectionString 
90406>>>>>>>        Get Create (RefClass(cDbUpdateDatabaseDriver)) to hoDriver
90407>>>>>>>        Set psDriverID of hoDriver to sDriverID
90408>>>>>>>        Get DbLogin of hoDriver sConnectionString sServer sDatabase bTrusted sUserID sPassword to bLoginSuccessful
90409>>>>>>>        If (bLoginSuccessful = False) Begin
90411>>>>>>>            Error DFERR_PROGRAM (CS_DUF_CannotLoginToServer * CS_DUF_ErrorText * String(sError) + "\nConnectionID = " * sConnectionID + "\nConnection String = " * sConnectionString)
90412>>>>>>>>
90412>>>>>>>        End
90412>>>>>>>>
90412>>>>>>>        Send Destroy of hoDriver 
90413>>>>>>>    
90413>>>>>>>    End_Procedure
90414>>>>>>>    
90414>>>>>>>    Function RedirectConnection String sOldConnection String sNewConnection Returns Integer
90416>>>>>>>        Integer iRetval
90416>>>>>>>        Handle hoCLI               
90416>>>>>>>        String sDriverID
90416>>>>>>>        
90416>>>>>>>        Get psDriverID to sDriverID
90417>>>>>>>        Get Create (Refclass(cCLIHandler)) to hoCLI
90418>>>>>>>        If (hoCLI <> 0) Begin
90420>>>>>>>            Set psDriverID of hoCLI to sDriverID
90421>>>>>>>            Get RedirectConnection of hoCLI sOldConnection sNewConnection to iRetval
90422>>>>>>>            Send Destroy of hoCLI
90423>>>>>>>        End
90423>>>>>>>>
90423>>>>>>>        
90423>>>>>>>        Function_Return iRetval
90424>>>>>>>    End_Function
90425>>>>>>>    
90425>>>>>>>    Procedure CreateConnParamsFromConnectionString String sDriverID String sConnectionString
90427>>>>>>>        Integer iResult
90427>>>>>>>        Handle hoCLI
90427>>>>>>>        String sServer sDatabase sUserID sPassword
90427>>>>>>>        tSQLConnection SQLConnection
90427>>>>>>>        tSQLConnection SQLConnection
90427>>>>>>>        
90427>>>>>>>        Set psDriverID to sDriverID
90428>>>>>>>        Get DeComposeConnectionString sDriverID sConnectionString to SQLConnection
90429>>>>>>>        Send CreateSQLConnection SQLConnection.sDriverID SQLConnection.sConnectionID SQLConnection.sServer;                                 SQLConnection.sDatabase SQLConnection.bTrusted SQLConnection.sUserID SQLConnection.sPassword SQLConnection.bTrusted
90430>>>>>>>    End_Procedure
90431>>>>>>>    
90431>>>>>>>    // This is needed when e.g. the connection id we have specified in the program code
90431>>>>>>>    // also exists in e.g. the MSSQLDRV.ini file (can either be local in the Data folder
90431>>>>>>>    // or the one in the DataFlex Bin folder.)
90431>>>>>>>    // We then need to delete the current one before creating a new one.
90431>>>>>>>    // This is because the parameters may differ between the program code and the
90431>>>>>>>    // MSSQLDRV.ini file in a deployed environment. Also DataFlex will generate an error
90431>>>>>>>    // when one tries to create a Connection ID that already exists.
90431>>>>>>>    Procedure RemoveExistingConnectionID String sDriverID String sConnectionID
90433>>>>>>>        Integer iResult iDriver iNumConn iConn
90433>>>>>>>        Handle hoCLI
90433>>>>>>>        String sID   
90433>>>>>>>        
90433>>>>>>>        If (sDriverID = "" or sConnectionID = "") Begin
90435>>>>>>>            Procedure_Return
90436>>>>>>>        End                 
90436>>>>>>>>
90436>>>>>>>        
90436>>>>>>>        Move 0 to iResult
90437>>>>>>>        Get Create U_cCLIHandler to hoCLI
90438>>>>>>>        If (hoCLI <> 0) Begin
90440>>>>>>>            Set psDriverID of hoCLI to sDriverID   
90441>>>>>>>            Get DriverIndex sDriverID to iDriver
90442>>>>>>>            Get_Attribute DF_DRIVER_NUMBER_CONNECTION_IDS of iDriver to iNumConn 
90445>>>>>>>            Decrement iNumConn
90446>>>>>>>            For iConn from 0 to iNumConn
90452>>>>>>>>
90452>>>>>>>                Get_Attribute DF_DRIVER_CONNECTION_ID of iDriver iConn to sID
90455>>>>>>>                If (Uppercase(sID) = Uppercase(sConnectionID)) Begin
90457>>>>>>>                    Get DeleteConnectionID of hoCLI sConnectionID -1 to iResult
90458>>>>>>>                End
90458>>>>>>>>
90458>>>>>>>            Loop
90459>>>>>>>>
90459>>>>>>>            Send Destroy of hoCLI
90460>>>>>>>        End
90460>>>>>>>>
90460>>>>>>>    
90460>>>>>>>    End_Procedure   
90461>>>>>>>    
90461>>>>>>>    Function ExistingConnectionSettings String sDriverID String sConnectionID Returns tSQLConnection
90463>>>>>>>        Integer iResult iDriver iNumConn iConn
90463>>>>>>>        Handle hoCLI
90463>>>>>>>        String sID sConnectionString sVal sDatabase
90463>>>>>>>        tSQLConnection SQLConnection
90463>>>>>>>        tSQLConnection SQLConnection
90463>>>>>>>        Boolean bTrusted
90463>>>>>>>        
90463>>>>>>>        Move 0 to iResult
90464>>>>>>>        Get Create U_cCLIHandler to hoCLI
90465>>>>>>>        If (hoCLI <> 0) Begin
90467>>>>>>>            Set psDriverID of hoCLI to sDriverID
90468>>>>>>>            Get DriverIndex sDriverID to iDriver
90469>>>>>>>            Get_Attribute DF_DRIVER_NUMBER_CONNECTION_IDS of iDriver to iNumConn 
90472>>>>>>>            Decrement iNumConn
90473>>>>>>>            For iConn from 0 to iNumConn
90479>>>>>>>>
90479>>>>>>>                Get_Attribute DF_DRIVER_CONNECTION_ID of iDriver iConn to sID
90482>>>>>>>                If (Uppercase(sID) = Uppercase(sConnectionID)) Begin                                             
90484>>>>>>>                    Move sDriverID                                                      to SQLConnection.sDriverID      // For completeness only...
90485>>>>>>>                    Get_Attribute DF_DRIVER_CONNECTION_ID of iDriver iConn              to SQLConnection.sConnectionID  // For completeness only...
90488>>>>>>>                    Get_Attribute DF_DRIVER_CONNECTION_ID_STRING of iDriver iConn       to sConnectionString
90491>>>>>>>                    Move sConnectionString                                              to SQLConnection.sConnectionString 
90492>>>>>>>                    Get_Attribute DF_DRIVER_CONNECTION_ID_OPTIONS of iDriver iConn      to SQLConnection.bSilentLogin
90495>>>>>>>                    Get ParseKeyWord sConnectionString (CS_SQLIniServerKeyword + "=")   to SQLConnection.sServer
90496>>>>>>>                    Get ParseKeyWord sConnectionString (CS_SQLIniDatabaseKeyword + "=") to SQLConnection.sDatabase
90497>>>>>>>                    Get ParseKeyWord sConnectionString (CS_SQLIniUIDKeyword + "=")      to SQLConnection.sUserID
90498>>>>>>>                    Get ParseKeyWord sConnectionString (CS_SQLIniPWDKeyword + "=")      to SQLConnection.sPassword
90499>>>>>>>                    
90499>>>>>>>                    Case Begin
90499>>>>>>>                        Case (sDriverID = MSSQLDRV_ID)
90501>>>>>>>                            Get ParseKeyWord sConnectionString (CS_SQLIniTrustedKeyword + "=") to sVal
90502>>>>>>>                            Move (If(Uppercase(sVal) = Uppercase(CS_SQLIniConnectionYes), True, False)) to bTrusted
90503>>>>>>>                            Move bTrusted                                               to SQLConnection.bTrusted
90504>>>>>>>                            Case Break
90505>>>>>>>                        Case (sDriverID = DB2_DRV_ID)
90508>>>>>>>                            Get ParseKeyWord sConnectionString (CS_SQLIniDSNKeyword + "=") to SQLConnection.sServer
90509>>>>>>>                            Case Break
90510>>>>>>>                        Case (sDriverID = ODBC_DRV_ID)
90513>>>>>>>                            Get ParseKeyWord sConnectionString (CS_SQLIniDSNKeyword + "=") to SQLConnection.sServer
90514>>>>>>>                            Case Break
90515>>>>>>>                        Case (sDriverID = SQLFLEX)
90518>>>>>>>                            Get ParseKeyWord sConnectionString (CS_SQLIniDSNKeyword + "=") to SQLConnection.sServer 
90519>>>>>>>                            Move (CS_SQLIniServerKeyword + "=" + SQLConnection.sServer)    to sConnectionString
90520>>>>>>>                            If (SQLConnection.bTrusted = True) Begin
90522>>>>>>>                                Move (sConnectionString + ";" + CS_SQLIniTrustedKeyword + "=" + CS_SQLIniConnectionYes) to sConnectionString
90523>>>>>>>                            End
90523>>>>>>>>
90523>>>>>>>                            Else Begin
90524>>>>>>>                                Get ParseKeyWord sConnectionString (CS_SQLIniUIDKeyword + "=")    to sVal
90525>>>>>>>                                Move (sConnectionString + ";" + CS_SQLIniUIDKeyword + "=" + sVal) to sConnectionString
90526>>>>>>>                                Get ParseKeyWord sConnectionString (CS_SQLIniPWDKeyword + "=")    to sVal
90527>>>>>>>                                Move (sConnectionString + ";" + CS_SQLIniPWDKeyword + "=" + sVal) to sConnectionString
90528>>>>>>>                            End
90528>>>>>>>>
90528>>>>>>>                            Move sConnectionString                                         to SQLConnection.sConnectionString
90529>>>>>>>                            Case Break
90530>>>>>>>                        Case (sDriverID = MDSMySQL)
90533>>>>>>>                            Get ParseKeyWord sConnectionString (CS_SQLIniDSNKeyword + "=") to SQLConnection.sServer 
90534>>>>>>>                            Move (CS_SQLIniServerKeyword + "=" + SQLConnection.sServer)    to sConnectionString
90535>>>>>>>                            If (SQLConnection.bTrusted = True) Begin
90537>>>>>>>                                Move (sConnectionString + ";" + CS_SQLIniTrustedKeyword + "=" + CS_SQLIniConnectionYes) to sConnectionString
90538>>>>>>>                            End
90538>>>>>>>>
90538>>>>>>>                            Else Begin
90539>>>>>>>                                Get ParseKeyWord sConnectionString (CS_SQLIniUIDKeyword + "=")    to sVal
90540>>>>>>>                                Move (sConnectionString + ";" + CS_SQLIniUIDKeyword + "=" + sVal) to sConnectionString
90541>>>>>>>                                Get ParseKeyWord sConnectionString (CS_SQLIniPWDKeyword + "=")    to sVal
90542>>>>>>>                                Move (sConnectionString + ";" + CS_SQLIniPWDKeyword + "=" + sVal) to sConnectionString
90543>>>>>>>                            End
90543>>>>>>>>
90543>>>>>>>                            Move sConnectionString                                         to SQLConnection.sConnectionString
90544>>>>>>>                            Case Break
90545>>>>>>>                        Case (sDriverID = MDSPgSQL)
90548>>>>>>>                            Get ParseKeyWord sConnectionString (CS_SQLIniDSNKeyword + "=") to SQLConnection.sServer 
90549>>>>>>>                            Move (CS_SQLIniServerKeyword + "=" + SQLConnection.sServer)    to sConnectionString
90550>>>>>>>                            If (SQLConnection.bTrusted = True) Begin
90552>>>>>>>                                Move (sConnectionString + ";" + CS_SQLIniTrustedKeyword + "=" + CS_SQLIniConnectionYes) to sConnectionString
90553>>>>>>>                            End
90553>>>>>>>>
90553>>>>>>>                            Else Begin
90554>>>>>>>                                Get ParseKeyWord sConnectionString (CS_SQLIniUIDKeyword + "=")    to sVal
90555>>>>>>>                                Move (sConnectionString + ";" + CS_SQLIniUIDKeyword + "=" + sVal) to sConnectionString
90556>>>>>>>                                Get ParseKeyWord sConnectionString (CS_SQLIniPWDKeyword + "=")    to sVal
90557>>>>>>>                                Move (sConnectionString + ";" + CS_SQLIniPWDKeyword + "=" + sVal) to sConnectionString
90558>>>>>>>                            End
90558>>>>>>>>
90558>>>>>>>                            Move sConnectionString                                                to SQLConnection.sConnectionString
90559>>>>>>>                            Case Break
90560>>>>>>>                        
90560>>>>>>>                        Case (sDriverID = ORAFLEX)
90563>>>>>>>                            Get ParseKeyWord sConnectionString (CS_SQLIniDSNKeyword + "=")      to SQLConnection.sServer 
90564>>>>>>>                            Move (CS_SQLIniServerKeyword + "=" + SQLConnection.sServer)         to sConnectionString
90565>>>>>>>                            Get ParseKeyWord sConnectionString (CS_SQLIniDatabaseKeyword + "=") to sDatabase
90566>>>>>>>                            If (sDatabase <> "" and (not(SQLConnection.sServer contains "/"))) Begin
90568>>>>>>>                                Move (SQLConnection.sServer + "/" + sDatabase)                  to SQLConnection.sServer
90569>>>>>>>                            End
90569>>>>>>>>
90569>>>>>>>                            If (SQLConnection.bTrusted = True) Begin
90571>>>>>>>                                Move (sConnectionString + ";" + CS_SQLIniTrustedKeyword + "=" + CS_SQLIniConnectionYes) to sConnectionString
90572>>>>>>>                            End
90572>>>>>>>>
90572>>>>>>>                            Else Begin
90573>>>>>>>                                Get ParseKeyWord sConnectionString (CS_SQLIniUIDKeyword + "=")    to sVal
90574>>>>>>>                                Move (sConnectionString + ";" + CS_SQLIniUIDKeyword + "=" + sVal) to sConnectionString
90575>>>>>>>                                Get ParseKeyWord sConnectionString (CS_SQLIniPWDKeyword + "=")    to sVal
90576>>>>>>>                                Move (sConnectionString + ";" + CS_SQLIniPWDKeyword + "=" + sVal) to sConnectionString
90577>>>>>>>                            End
90577>>>>>>>>
90577>>>>>>>                            Move sConnectionString                                         to SQLConnection.sConnectionString
90578>>>>>>>                            Case Break
90579>>>>>>>                        Case Else
90579>>>>>>>                            Error ("Wrong driver ID passed:" * sDriverID)
90580>>>>>>>>
90580>>>>>>>                            Case Break
90581>>>>>>>                    Case End                    
90581>>>>>>>                End
90581>>>>>>>>
90581>>>>>>>            Loop
90582>>>>>>>>
90582>>>>>>>            Send Destroy of hoCLI
90583>>>>>>>        End
90583>>>>>>>>
90583>>>>>>>        
90583>>>>>>>        Function_Return SQLConnection
90584>>>>>>>    End_Function
90585>>>>>>>    
90585>>>>>>>    Function DriverIndex String sDriverID Returns Integer
90587>>>>>>>        String  sCurrentDriver
90587>>>>>>>        Integer iNumberOfDrivers iDriver iCount iRetval
90587>>>>>>>        
90587>>>>>>>        Move 0 to iDriver
90588>>>>>>>        Get_Attribute DF_NUMBER_DRIVERS to iNumberOfDrivers
90591>>>>>>>        For iCount from 1 to iNumberOfDrivers
90597>>>>>>>>
90597>>>>>>>            Get_Attribute DF_DRIVER_NAME of iCount to sCurrentDriver
90600>>>>>>>            If ( Uppercase(sCurrentDriver) = Uppercase(sDriverID) ) Begin
90602>>>>>>>                Function_Return iCount
90603>>>>>>>            End
90603>>>>>>>>
90603>>>>>>>        Loop
90604>>>>>>>>
90604>>>>>>>        
90604>>>>>>>        // If driver not previously loaded; attempt to do so now.
90604>>>>>>>        If (iDriver = 0) Begin
90606>>>>>>>            Move 0 to LastErr
90607>>>>>>>            Load_Driver sDriverID   
90608>>>>>>>            // If driver could not be loaded.
90608>>>>>>>            If (LastErr = 4255) Begin
90610>>>>>>>                Move 0 to iCount
90611>>>>>>>            End
90611>>>>>>>>
90611>>>>>>>            Function_Return iCount
90612>>>>>>>        End
90612>>>>>>>>
90612>>>>>>>        Function_Return 0
90613>>>>>>>    End_Function
90614>>>>>>>        
90614>>>>>>>    // This will update connection settings of the cCLIHandler object with that passed struct values.
90614>>>>>>>    Procedure UpdateConnectionString tSQLConnection SQLConnection
90616>>>>>>>        String sRetval sDriverID sConnectionID sConnectionString sServer sDatabase sUserID sPassword
90616>>>>>>>        Boolean bTrusted bSilent  
90616>>>>>>>        Integer iConnOptions
90616>>>>>>>        
90616>>>>>>>        Move SQLConnection.sDriverID     to sDriverID
90617>>>>>>>        Move SQLConnection.sConnectionID to sConnectionID
90618>>>>>>>        Move SQLConnection.sServer       to sServer
90619>>>>>>>        Move SQLConnection.sDatabase     to sDatabase
90620>>>>>>>        Move SQLConnection.bTrusted      to bTrusted
90621>>>>>>>        Move SQLConnection.sUserID       to sUserID
90622>>>>>>>        Move SQLConnection.sPassword     to sPassword  
90623>>>>>>>        Move SQLConnection.bSilentLogin  to bSilent
90624>>>>>>>        
90624>>>>>>>        // Note that this message will first delete the current ConnectionID if it exists; which is needed by the cCLIHandler logic.
90624>>>>>>>        Send CreateSQLConnection sDriverID sConnectionID sServer sDatabase bTrusted sUserID sPassword bSilent
90625>>>>>>>        
90625>>>>>>>    End_Procedure
90626>>>>>>>
90626>>>>>>>    // Called when the object is constructed.
90626>>>>>>>    // It will check the psDriverID for a ConnectionID and save it
90626>>>>>>>    // as psConnectionID property. It is later used whenever a login to
90626>>>>>>>    // the database is needed.
90626>>>>>>>    Procedure AutoSetConnectionID
90628>>>>>>>        String sConnectionID sValue sDriverID sConnectionString
90628>>>>>>>        Integer iDriver iNumConn iConn iConnOptions iRetval
90628>>>>>>>        Handle hoCLI                 
90628>>>>>>>        Boolean bOK bSilent bMertechDriver
90628>>>>>>>        
90628>>>>>>>        Get pbSilentLogin      to bSilent
90629>>>>>>>        Get psConnectionID     to sConnectionID                            
90630>>>>>>>        Get psConnectionString to sConnectionString
90631>>>>>>>        // Get the driver Connection ID string & set the psConnectionString property.
90631>>>>>>>        Get psDriverID to sDriverID
90632>>>>>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
90633>>>>>>>        If (bOK = False) Begin
90635>>>>>>>            Procedure_Return              
90636>>>>>>>        End                 
90636>>>>>>>>
90636>>>>>>>        
90636>>>>>>>        // Mertech drivers can't use connection ID's.
90636>>>>>>>        Get IsMertechDriver sDriverID to bMertechDriver    
90637>>>>>>>        If (bMertechDriver = True) Begin         
90639>>>>>>>            // This ensures that the correct Server & Database attributes are set both for 
90639>>>>>>>            // embedded SQL calls and "normal" database commands like e.g. "Open".
90639>>>>>>>            Get _MertechSQLManagerHandle to hoCLI
90640>>>>>>>            Procedure_Return
90641>>>>>>>        End
90641>>>>>>>>
90641>>>>>>>        
90641>>>>>>>        Get DriverIndex sDriverID          to iDriver
90642>>>>>>>        // If driver not loaded; load it.
90642>>>>>>>        If (iDriver = 0) Begin
90644>>>>>>>            Load_Driver sDriverID
90645>>>>>>>            Get DriverIndex sDriverID      to iDriver
90646>>>>>>>        End                      
90646>>>>>>>>
90646>>>>>>>        // This shouldn't be possible; unless the driver.dll file is missing or something...
90646>>>>>>>        If (iDriver = 0) Begin
90648>>>>>>>            Error DFERR_PROGRAM ("The database driver could not be loaded! Connection to database failed." * sDriverID)
90649>>>>>>>>
90649>>>>>>>            Procedure_Return
90650>>>>>>>        End
90650>>>>>>>>
90650>>>>>>>
90650>>>>>>>        Get Create (RefClass(cCLIHandler)) to hoCLI
90651>>>>>>>        Set psDriverID of hoCLI            to sDriverID   
90652>>>>>>>        // Delete the connection first; in case it exists
90652>>>>>>>        Get DeleteConnectionID of hoCLI sConnectionID -1 to iRetval
90653>>>>>>>        Get CreateConnectionID of hoCLI sConnectionID sConnectionString bSilent to iRetval
90654>>>>>>>
90654>>>>>>>        Send Destroy of hoCLI 
90655>>>>>>>    End_Procedure
90656>>>>>>>
90656>>>>>>>    // Returns the handle of the Mertech SQL handler.
90656>>>>>>>    // It also ensures that the correct Server & Database attributes are set both for 
90656>>>>>>>    // embedded SQL calls and "normal" database commands like e.g. "Open".  
90656>>>>>>>    // Note: This does _not_ return a proper CLI handler handle as it is not in this class.
