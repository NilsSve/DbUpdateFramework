88946>>>>>>>        Move iSQLKeywordConstant to SQLKeywordArray[iSize].iSQLWord
88947>>>>>>>        Move iEN_dbType          to SQLKeywordArray[iSize].iSQLDbType
88948>>>>>>>        Move sSQLKeyword         to SQLKeywordArray[iSize].sSQLPhrase
88949>>>>>>>        
88949>>>>>>>        Set paSQLKeywordArray to SQLKeywordArray
88950>>>>>>>    End_Procedure  
88951>>>>>>>    
88951>>>>>>>    // Creates a struct array with all SQL keywords
88951>>>>>>>    // for all EN_xxx SQL back-ends. Various back-ends can
88951>>>>>>>    // have slightly different wording.
88951>>>>>>>    // If a new EN_dbTypexxx type is added; additions
88951>>>>>>>    // needs to be done for every keyword group below.
88951>>>>>>>    Procedure SetupSQLKeywordArray
88953>>>>>>>        tSQLKeyWords[] SQLKeywordArray SQLKeywordArraySorted
88953>>>>>>>        tSQLKeyWords[] SQLKeywordArray SQLKeywordArraySorted
88955>>>>>>>        
88955>>>>>>>        // This should only be called once; but in case it is
88955>>>>>>>        // we delete the array first.                        
88955>>>>>>>        Set paSQLKeywordArray to SQLKeywordArray 
88956>>>>>>>       
88956>>>>>>>        // ToDo: *** These SQL Key-words needs to be checked for other backends than MS-SQL! ***
88956>>>>>>>        //
88956>>>>>>>        Send Add_Element CI_SQLAlterTable EN_dbTypeMSSQL    "ALTER TABLE"
88957>>>>>>>        Send Add_Element CI_SQLAlterTable EN_dbTypeMySQL    "ALTER TABLE"
88958>>>>>>>        Send Add_Element CI_SQLAlterTable EN_dbTypeOracle   "ALTER TABLE"
88959>>>>>>>        Send Add_Element CI_SQLAlterTable EN_dbTypeDB2      "ALTER TABLE"
88960>>>>>>>        Send Add_Element CI_SQLAlterTable EN_dbTypePostgre  "ALTER TABLE"
88961>>>>>>>    
88961>>>>>>>        Send Add_Element CI_SQLAdd EN_dbTypeMSSQL           "ADD"
88962>>>>>>>        Send Add_Element CI_SQLAdd EN_dbTypeMySQL           "ADD"
88963>>>>>>>        Send Add_Element CI_SQLAdd EN_dbTypeOracle          "ADD"
88964>>>>>>>        Send Add_Element CI_SQLAdd EN_dbTypeDB2             "ADD"
88965>>>>>>>        Send Add_Element CI_SQLAdd EN_dbTypePostgre         "ADD"
88966>>>>>>>                                                                        
88966>>>>>>>        Send Add_Element CI_SQLUpdate EN_dbTypeMSSQL        "UPDATE"
88967>>>>>>>        Send Add_Element CI_SQLUpdate EN_dbTypeMySQL        "UPDATE"
88968>>>>>>>        Send Add_Element CI_SQLUpdate EN_dbTypeOracle       "UPDATE"
88969>>>>>>>        Send Add_Element CI_SQLUpdate EN_dbTypeDB2          "UPDATE"
88970>>>>>>>        Send Add_Element CI_SQLUpdate EN_dbTypePostgre      "UPDATE"
88971>>>>>>>                                                                        
88971>>>>>>>        Send Add_Element CI_SQLNotNull EN_dbTypeMSSQL       "NOT NULL"
88972>>>>>>>        Send Add_Element CI_SQLNotNull EN_dbTypeMySQL       "NOT NULL"
88973>>>>>>>        Send Add_Element CI_SQLNotNull EN_dbTypeOracle      "" // Seems like Oracle can't handle setting a new column to 'NOT NULL' if the table exists with data(!)
88974>>>>>>>        Send Add_Element CI_SQLNotNull EN_dbTypeDB2         "SET NOT NULL"
88975>>>>>>>        Send Add_Element CI_SQLNotNull EN_dbTypePostgre     "NOT NULL"
88976>>>>>>>                                                                        
88976>>>>>>>        Send Add_Element CI_SQLSet EN_dbTypeMSSQL           "SET"
88977>>>>>>>        Send Add_Element CI_SQLSet EN_dbTypeMySQL           "SET"
88978>>>>>>>        Send Add_Element CI_SQLSet EN_dbTypeOracle          "SET"
88979>>>>>>>        Send Add_Element CI_SQLSet EN_dbTypeDB2             "SET"
88980>>>>>>>        Send Add_Element CI_SQLSet EN_dbTypePostgre         "SET"
