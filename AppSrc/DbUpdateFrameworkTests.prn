92196>>>>>    // Returns a string array with all tables for the current database.
92196>>>>>    Function SqlUtilEnumerateTables String sDriverID Returns String[]
92198>>>>>        String[] sReturnArray sArray
92200>>>>>        String sServer sDatabase sConnectionString sSelect sSchema     
92200>>>>>        Integer iSize iCount
92200>>>>>        Boolean bOK
92200>>>>>
92200>>>>>        If (sDriverID = DATAFLEX_ID) Begin
92202>>>>>            Function_Return sArray        
92203>>>>>        End                       
92203>>>>>>
92203>>>>>        
92203>>>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
92204>>>>>        If (bOK = False) Begin
92206>>>>>            Function_Return sReturnArray
92207>>>>>        End    
92207>>>>>>
92207>>>>>        
92207>>>>>        Get psConnectionString to sConnectionString
92208>>>>>        Get psDatabase to sDatabase                               
92209>>>>>        Get psSchema   to sSchema                                                                              
92210>>>>>                                                                                                              
92210>>>>>        Case Begin
92210>>>>>            Case (sDriverID = MSSQLDRV_ID)
92212>>>>>                Get _SqlTableArrayDAW to sReturnArray
92213>>>>>                Case Break                                                            
92214>>>>>            
92214>>>>>            Case (sDriverID = DB2_DRV_ID)
92217>>>>>                Get _SqlTableArrayDAW to sReturnArray
92218>>>>>                Case Break
92219>>>>>            
92219>>>>>            Case (sDriverID = ODBC_DRV_ID)
92222>>>>>                Get _SqlTableArrayDAW to sReturnArray
92223>>>>>                Case Break
92224>>>>>            
92224>>>>>            Case (sDriverID = SQLFLEX)
92227>>>>>                Move ("SELECT TABLE_NAME FROM" * sDatabase + ".INFORMATION_SCHEMA.TABLES WHERE TABLE_TYPE != 'VIEW'") to sSelect
92228>>>>>                Get SqlEnumerateEsqlMertech sSelect to sReturnArray
92229>>>>>                Case Break
92230>>>>>            
92230>>>>>            Case (sDriverID = MDSMySQL)                                   
92233>>>>>                Move ("SELECT TABLE_NAME from INFORMATION_SCHEMA.TABLES where TABLE_SCHEMA = '" + sDatabase + "' and TABLE_TYPE = 'BASE TABLE' order by TABLE_NAME") to sSelect
92234>>>>>                Get SqlEnumerateEsqlMertech sSelect to sReturnArray
92235>>>>>                Case Break
92236>>>>>            
92236>>>>>            Case (sDriverID = MDSPgSQL)                                          
92239>>>>>                Move "select tablename, schemaname from pg_catalog.pg_tables order by tablename"  to sSelect
92240>>>>>                Get SqlEnumerateEsqlMertech sSelect "" to sReturnArray
92241>>>>>                Case Break            
92242>>>>>            
92242>>>>>            Case (sDriverID = ORAFLEX)                                          
92245>>>>>                Move "SELECT table_name from user_tables" to sSelect  
92246>>>>>                Get SqlEnumerateEsqlMertech sSelect to sArray
92247>>>>>                Move (SizeOfArray(sArray)) to iSize
92248>>>>>                Decrement iSize
92249>>>>>                For iCount from 0 to iSize
92255>>>>>>
92255>>>>>                    If (not(sArray[iCount] contains "$")) Begin
92257>>>>>                        Move sArray[iCount] to sReturnArray[SizeOfArray(sReturnArray)]
92258>>>>>                    End
92258>>>>>>
92258>>>>>                Loop
92259>>>>>>
92259>>>>>                Case Break            
92260>>>>>
92260>>>>>            Case Else     
92260>>>>>                Error DFERR_PROGRAM "Unsupported driver passed to SqlUtilEnumerateTables function."
92261>>>>>>
92261>>>>>                Case Break
92262>>>>>        Case End
92262>>>>>        
92262>>>>>        Function_Return sReturnArray
92263>>>>>    End_Function
