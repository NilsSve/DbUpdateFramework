86536>>>>>>>>>>>Function vGetWindowsDirectory Returns String
86539>>>>>>>>>>>  String  sDirectory
86539>>>>>>>>>>>  Pointer lpDirectory
86539>>>>>>>>>>>  Integer iVoid
86539>>>>>>>>>>>
86539>>>>>>>>>>>  ZeroString vMAX_PATH To sDirectory
86540>>>>>>>>>>>  GetAddress Of sDirectory To lpDirectory
86541>>>>>>>>>>>
86541>>>>>>>>>>>  Move (vWin32_GetWindowsDirectory(lpDirectory, vMAX_PATH)) To iVoid
86542>>>>>>>>>>>  Function_Return (CString(sDirectory))  // **WvA: Changed to CString()
86543>>>>>>>>>>>End_Function // vGetWindowsDirectory
86544>>>>>>>>>>>
86544>>>>>>>>>>>
86544>>>>>>>>>>>
86544>>>>>>>>>>>
86544>>>>>>>>>>>// Courtesy of Marco Kuipers
86544>>>>>>>>>>>Function vMakeTempFile Returns String
86547>>>>>>>>>>>    Integer iRetval
86547>>>>>>>>>>>    String  sTempPath sTempFileName sPrefixString
86547>>>>>>>>>>>    Pointer lpTempPath lpTempFileName lpPrefixString
86547>>>>>>>>>>>
86547>>>>>>>>>>>    Move (Repeat (Character (0), 255)) To sTempPath
86548>>>>>>>>>>>    GetAddress Of sTempPath To lpTempPath
86549>>>>>>>>>>>    Move (vWin32_GetTempPath (255, lpTempPath)) To iRetVal
86550>>>>>>>>>>>
86550>>>>>>>>>>>    If (sTempPath = "") Begin
86552>>>>>>>>>>>       Get_Current_Directory To sTempPath
86553>>>>>>>>>>>    End
86553>>>>>>>>>>>>
86553>>>>>>>>>>>    Move (pad(sTempPath,vMax_Path-14)) To sTempPath // *WvA: 28-04-2005 Quote from msdn: The string cannot be longer than MAX_PATH-14 characters.
86554>>>>>>>>>>>    Move (Repeat (Character (0), 255)) To sTempFileName
86555>>>>>>>>>>>    GetAddress Of sTempFileName To lpTempFileName
86556>>>>>>>>>>>    Move ("tmp"+character(0)) To sPrefixString // **WvA: 28-04-2005 Added a null
86557>>>>>>>>>>>    GetAddress Of sPrefixString To lpPrefixString
86558>>>>>>>>>>>    GetAddress Of sTempPath To lpTempPath
86559>>>>>>>>>>>    Move (vWin32_GetTempFileName (lpTempPath, lpPrefixString, 0, lpTempFileName)) To iRetval
86560>>>>>>>>>>>    If (iRetval = 0) Begin  // **WvA: 28-04-2005 Changed condition, the api call returns 0 if an error occurs
86562>>>>>>>>>>>        Move "" To sTempFileName
86563>>>>>>>>>>>    End
86563>>>>>>>>>>>>
86563>>>>>>>>>>>
86563>>>>>>>>>>>    Function_Return (Cstring(sTempFileName)) // **WvA: 28-04-2005 Cstring added
86564>>>>>>>>>>>End_Function // vMakeTempFile
86565>>>>>>>>>>>
86565>>>>>>>>>>>
86565>>>>>>>>>>>// This function creates a uniquely named temporary file in folder sPath
86565>>>>>>>>>>>// The file created will have a prefix based on the first 3 characters in sPrefix
86565>>>>>>>>>>>// Note that you will have to cleanup the tempfile yourself as the function
86565>>>>>>>>>>>// does not take care of that.
86565>>>>>>>>>>>Function vCreateTempFileInPath String sPath String sPrefix Returns String
86568>>>>>>>>>>>    String sTempFileName
86568>>>>>>>>>>>    Integer iCnt iRetVal
86568>>>>>>>>>>>    Pointer lpTempFileName
86568>>>>>>>>>>>    Pointer lpPath
86568>>>>>>>>>>>    Pointer lpPrefix
86568>>>>>>>>>>>
86568>>>>>>>>>>>    Move (ToAnsi(sPath)+Character(0))   To sPath
86569>>>>>>>>>>>    Move (ToAnsi(sPrefix)+Character(0)) To sPrefix
86570>>>>>>>>>>>    Move (pad("", vMAX_PATH)) To sTempFileName
86571>>>>>>>>>>>    GetAddress Of sTempFileName To lpTempFileName
86572>>>>>>>>>>>    GetAddress Of sPath         To lpPath
86573>>>>>>>>>>>    GetAddress Of sPrefix       To lpPrefix
86574>>>>>>>>>>>
86574>>>>>>>>>>>    Move (vWin32_GetTempFileName(lpPath, lpPrefix, 0, lpTempFileName)) To iRetVal
86575>>>>>>>>>>>    Move (Trim(Cstring(sTempFileName))) To sTempFileName
86576>>>>>>>>>>>    Function_Return sTempFileName
86577>>>>>>>>>>>End_Function // vCreateTempFileInPath
86578>>>>>>>>>>>
86578>>>>>>>>>>>//
86578>>>>>>>>>>>// Get a specific shell folder for example to get the desktop folder
86578>>>>>>>>>>>// simply call this function and pass it vCSIDL_DESKTOP
86578>>>>>>>>>>>//
