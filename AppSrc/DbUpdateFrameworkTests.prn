95660>>>>>                // If not df_exclusive mode, we use the "Open As" syntax.
95660>>>>>                If (iMode <> DF_EXCLUSIVE) Begin
95662>>>>>                    Open sTableName as hTable
95664>>>>>                End
95664>>>>>>
95664>>>>>                Else Begin
95665>>>>>                    Open hTable mode DF_Exclusive
95667>>>>>                End
95667>>>>>>
95667>>>>>                Case Break
95668>>>>>
95668>>>>>            Case (sDriverID = DATAFLEX_ID)
95671>>>>>                If (sTableName <> "" and iMode <> DF_EXCLUSIVE) Begin
95673>>>>>                    Open sTableName as hTable
95675>>>>>                End
95675>>>>>>
95675>>>>>                Else If (iMode = DF_EXCLUSIVE) Begin
95678>>>>>                    Open hTable mode DF_Exclusive
95680>>>>>                End
95680>>>>>>
95680>>>>>                Else Begin
