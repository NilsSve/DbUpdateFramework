87333>>>>>>>>>>>>>
87333>>>>>>>>>>>>>    Procedure SQLClose
87335>>>>>>>>>>>>>        Send FreeHandle
87336>>>>>>>>>>>>>    End_Procedure // SQLClose
87337>>>>>>>>>>>>>
87337>>>>>>>>>>>>>    Procedure HandleError Integer ihstmt Integer ihdbc String sDrvrId String sOriginMsg
87339>>>>>>>>>>>>>        Integer iErrHandle
87339>>>>>>>>>>>>>        Integer iErrNum
87339>>>>>>>>>>>>>        String  sLocationInfo
87339>>>>>>>>>>>>>
87339>>>>>>>>>>>>>        //*** Get the DataFlex statement identifier
87339>>>>>>>>>>>>>        Move Current_object to iErrHandle
87340>>>>>>>>>>>>>
87340>>>>>>>>>>>>>        //*** Determine error number
87340>>>>>>>>>>>>>        If (ihstmt = 0) ;            Move CLIERR_SQLINVALID_CLI_STMT_HANDLE to iErrNum
87343>>>>>>>>>>>>>        Else If (ihdbc = 0) ;            Move CLIERR_SQLINVALID_CLI_CONN_HANDLE to iErrNum
87347>>>>>>>>>>>>>        Else If (sDrvrId = "") ;            Move CLIERR_SQLINVALID_DRIVER_ID to iErrNum
87351>>>>>>>>>>>>>        Else ;            Move CLIERR_SQL_ERROR to iErrNum
87353>>>>>>>>>>>>>
87353>>>>>>>>>>>>>        //*** Create location information
87353>>>>>>>>>>>>>        Move "[" to sLocationInfo
87354>>>>>>>>>>>>>        If (sOriginMsg <> "") Begin
87356>>>>>>>>>>>>>            Move (Append(sLocationInfo, sOriginMsg)) to sLocationInfo
87357>>>>>>>>>>>>>            Move (Append(sLocationInfo, ", "))       to sLocationInfo
87358>>>>>>>>>>>>>        End
87358>>>>>>>>>>>>>>
87358>>>>>>>>>>>>>        Move (Append(sLocationInfo, "DataFlex hstmt = ")) to sLocationInfo
87359>>>>>>>>>>>>>        Move (Append(sLocationInfo, iErrHandle))          to sLocationInfo
87360>>>>>>>>>>>>>        Move (Append(sLocationInfo, "]"))                 to sLocationInfo
87361>>>>>>>>>>>>>
87361>>>>>>>>>>>>>        //*** Generate the error
87361>>>>>>>>>>>>>        Error iErrNum sLocationInfo
87362>>>>>>>>>>>>>>
87362>>>>>>>>>>>>>    End_Procedure
87363>>>>>>>>>>>>>    
87363>>>>>>>>>>>>>    Procedure StmtError Integer iErrNum String sErrText String sOriginMsg
87365>>>>>>>>>>>>>        Local Integer iErrHandle
87365>>>>>>>>>>>>>        Local String  sLocationInfo
87365>>>>>>>>>>>>>
87365>>>>>>>>>>>>>        //*** Get the DataFlex statement identifier
87365>>>>>>>>>>>>>        Move Current_object to iErrHandle
87366>>>>>>>>>>>>>
87366>>>>>>>>>>>>>
87366>>>>>>>>>>>>>        //*** Create location information
87366>>>>>>>>>>>>>        Move "[" to sLocationInfo
87367>>>>>>>>>>>>>        If (sOriginMsg <> "") Begin
87369>>>>>>>>>>>>>            Move (Append(sLocationInfo, sOriginMsg)) to sLocationInfo
87370>>>>>>>>>>>>>            Move (Append(sLocationInfo, ", "))       to sLocationInfo
87371>>>>>>>>>>>>>        End
87371>>>>>>>>>>>>>>
87371>>>>>>>>>>>>>        If (sErrtext <> "") Begin
87373>>>>>>>>>>>>>            Move (Append(sLocationInfo, sErrtext)) to sLocationInfo
87374>>>>>>>>>>>>>            Move (Append(sLocationInfo, ", "))     to sLocationInfo
87375>>>>>>>>>>>>>        End
87375>>>>>>>>>>>>>>
87375>>>>>>>>>>>>>        Move (Append(sLocationInfo, "DataFlex hstmt = ")) to sLocationInfo
87376>>>>>>>>>>>>>        Move (Append(sLocationInfo, iErrHandle))          to sLocationInfo
87377>>>>>>>>>>>>>        Move (Append(sLocationInfo, "]"))                 to sLocationInfo
87378>>>>>>>>>>>>>
87378>>>>>>>>>>>>>        //*** Generate the error
87378>>>>>>>>>>>>>        Error iErrNum sLocationInfo
87379>>>>>>>>>>>>>>
87379>>>>>>>>>>>>>    End_Procedure
87380>>>>>>>>>>>>>    
87380>>>>>>>>>>>>>    Procedure SQLIllegalAttribute String sErrText String sOriginMsg
87382>>>>>>>>>>>>>        Local Integer bReport
87382>>>>>>>>>>>>>
87382>>>>>>>>>>>>>        Get_Attribute DF_REPORT_UNSUPPORTED_ATTRIBUTES to bReport
87385>>>>>>>>>>>>>        If (bReport) ;            Send StmtError CLIERR_SQLINVALID_ATTRIBUTE sErrtext sOriginMsg
87388>>>>>>>>>>>>>    End_Procedure // SQLIllegalAttribute
87389>>>>>>>>>>>>>
87389>>>>>>>>>>>>>    Function SQLColumnValue Integer iCol Returns String
87391>>>>>>>>>>>>>        String sResult
87391>>>>>>>>>>>>>        Integer iCols
87391>>>>>>>>>>>>>        Integer iOrgDateFmt
87391>>>>>>>>>>>>>        Integer iOrgDateSep
87391>>>>>>>>>>>>>        String sType 
87391>>>>>>>>>>>>>
87391>>>>>>>>>>>>>        SQL_SET_CURRENT_CURSOR_STMT to (piCursorNum(Self))
87405>>>>>>>>>>>>>>
87405>>>>>>>>>>>>>        
87405>>>>>>>>>>>>>        SQL_GET_NUM_COLS to iCols
87415>>>>>>>>>>>>>>
87415>>>>>>>>>>>>>        If (iCol <= iCols) Begin
87417>>>>>>>>>>>>>            //DAC SQL Driver currently uses military format for the SQL getting of dates.
87417>>>>>>>>>>>>>            If (giSQLCompatibilityMode=SQL_DAC_HIGH_COMPATABILITY) Begin             
87419>>>>>>>>>>>>>                Get_Attribute DF_DATE_FORMAT to iOrgDateFmt
87422>>>>>>>>>>>>>                Get_Attribute DF_DATE_SEPARATOR to iOrgDateSep
87425>>>>>>>>>>>>>                Set_Attribute DF_DATE_FORMAT to DF_DATE_MILITARY
87428>>>>>>>>>>>>>                Set_Attribute DF_DATE_SEPARATOR to (Ascii('-'))
87431>>>>>>>>>>>>>            End 
87431>>>>>>>>>>>>>>
87431>>>>>>>>>>>>>            
87431>>>>>>>>>>>>>            //DAC SQL Driver cannot directly get TEXT fields into a result. 
87431>>>>>>>>>>>>>            If (giSQLCompatibilityMode=SQL_DAC_HIGH_COMPATABILITY) Begin             
87433>>>>>>>>>>>>>                SQL_GET_COL_ATTRIBUTE of iCol DFTYPE to sType
87450>>>>>>>>>>>>>>
87450>>>>>>>>>>>>>                If (sType=5) Move "" to sResult 
87453>>>>>>>>>>>>>                Else Begin 
87454>>>>>>>>>>>>>                    SQL_FETCH_COLUMN iCol into sResult
87459>>>>>>>>>>>>>                End
87459>>>>>>>>>>>>>>
87459>>>>>>>>>>>>>            End 
87459>>>>>>>>>>>>>>
87459>>>>>>>>>>>>>            Else Begin 
87460>>>>>>>>>>>>>               SQL_FETCH_COLUMN iCol into sResult 
87465>>>>>>>>>>>>>            End
87465>>>>>>>>>>>>>>
87465>>>>>>>>>>>>>            
87465>>>>>>>>>>>>>
87465>>>>>>>>>>>>>            If (giSQLCompatibilityMode=SQL_DAC_HIGH_COMPATABILITY) Begin             
87467>>>>>>>>>>>>>                Set_Attribute DF_DATE_FORMAT to iOrgDateFmt
87470>>>>>>>>>>>>>                Set_Attribute DF_DATE_SEPARATOR to iOrgDateSep
87473>>>>>>>>>>>>>            End 
87473>>>>>>>>>>>>>>
87473>>>>>>>>>>>>>
87473>>>>>>>>>>>>>            Function_Return sResult
87474>>>>>>>>>>>>>        End
87474>>>>>>>>>>>>>>
87474>>>>>>>>>>>>>        Else Send HandleError (phCLIHandle(Self)) (phCLIHandle(Parent(Self))) (psDriverID(Self)) "SQLColumnValue"
87476>>>>>>>>>>>>>    End_Function // SQLColumnValue
