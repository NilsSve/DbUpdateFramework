82144>>>>>>>>>use VDFBase.pkg
82144>>>>>>>>>
82144>>>>>>>>>Class cFormatter is an cObject
82145>>>>>>>>>
82145>>>>>>>>>    Procedure Construct_object
82147>>>>>>>>>        Integer iCh
82147>>>>>>>>>        forward send construct_object
82149>>>>>>>>>        Property String  psCurrencySymbol
82150>>>>>>>>>        Set psCurrencySymbol to (Default_Currency_Symbol())
82151>>>>>>>>>
82151>>>>>>>>>        Property string  psLeft
82152>>>>>>>>>        Property string  psright
82153>>>>>>>>>        Property integer pbThousandsSep
82154>>>>>>>>>        Property integer piPoints
82155>>>>>>>>>
82155>>>>>>>>>        Property string  psCurPosLeft
82156>>>>>>>>>        Property string  psCurPosright
82157>>>>>>>>>        Property integer pbCurPosThousandsSep
82158>>>>>>>>>        Property integer piCurPosPoints
82159>>>>>>>>>
82159>>>>>>>>>        Property string  psCurNegLeft
82160>>>>>>>>>        Property string  psCurNegright
82161>>>>>>>>>        Property integer pbCurNegThousandsSep
82162>>>>>>>>>        Property integer piCurNegPoints
82163>>>>>>>>>
82163>>>>>>>>>        Property string  psNumPosLeft
82164>>>>>>>>>        Property string  psNumPosright
82165>>>>>>>>>        Property integer pbNumPosThousandsSep
82166>>>>>>>>>        Property integer piNumPosPoints
82167>>>>>>>>>
82167>>>>>>>>>        Property string  psNumNegLeft
82168>>>>>>>>>        Property string  psNumNegright
82169>>>>>>>>>        Property integer pbNumNegThousandsSep
82170>>>>>>>>>        Property integer piNumNegPoints
82171>>>>>>>>>
82171>>>>>>>>>        Send SetFormat "$,#.##;($,#.##)" true  // currency
82172>>>>>>>>>        Send SetFormat  ",#.*"           false // numeric
82173>>>>>>>>>
82173>>>>>>>>>    end_procedure
82174>>>>>>>>>
82174>>>>>>>>>    // internal
82174>>>>>>>>>    // parse passed format string and set temporary properties with result
82174>>>>>>>>>    //
82174>>>>>>>>>    Procedure ParseFormat string sFmt
82176>>>>>>>>>
82176>>>>>>>>>        string sLeft sRight sDigit
82176>>>>>>>>>        integer bSep iPos i iDigits
82176>>>>>>>>>
82176>>>>>>>>>        // replace any literals. A "/" followed by anything.
82176>>>>>>>>>        // some literals are special. $ . , / #
82176>>>>>>>>>        Move (Replaces("/$",sFmt,Character(1)))    to sFmt
82177>>>>>>>>>        Move (Replaces("/.",sFmt,Character(2)))    to sFmt
82178>>>>>>>>>        Move (Replaces("/,",sFmt,Character(3)))    to sFmt
82179>>>>>>>>>        Move (Replaces("/"+"/",sFmt,Character(4))) to sFmt
82180>>>>>>>>>        Move (Replaces("/#",sFmt,Character(5)))    to sFmt
82181>>>>>>>>>        Move (Character(9)) to sDigit
82182>>>>>>>>>        Move (Replaces("#",sFmt,sDigit))           to sFmt
82183>>>>>>>>>        Move (Replaces("/",sFmt,""))               to sFmt // replace all others
82184>>>>>>>>>
82184>>>>>>>>>        Move (Pos(",",sFmt))                 to bSep // if we have any , we use thousand seps
82185>>>>>>>>>        If bSep Move (Replaces(",",sFmt,"")) to sFmt // remove all ,
82188>>>>>>>>>
82188>>>>>>>>>        Move (Replaces("$",sFmt,psCurrencySymbol(self))) to sFmt // replace any $ with currency symbol
82189>>>>>>>>>
82189>>>>>>>>>        Move (Pos(".",sFmt)) to iPos                 // position of decimal
82190>>>>>>>>>
82190>>>>>>>>>        // Move all the special literals back into place before parsing
82190>>>>>>>>>        Move (Replaces(Character(1),sFmt,"$")) to sFmt
82191>>>>>>>>>        Move (Replaces(Character(2),sFmt,".")) to sFmt
82192>>>>>>>>>        Move (Replaces(Character(3),sFmt,",")) to sFmt
82193>>>>>>>>>        Move (Replaces(Character(4),sFmt,"/")) to sFmt
82194>>>>>>>>>        Move (Replaces(Character(5),sFmt,"#")) to sFmt
82195>>>>>>>>>
82195>>>>>>>>>        If (iPos>0) Begin                      // if we have a decimanl point
82197>>>>>>>>>            Move 1 to i                        // look for first non # to right and count the #s
82198>>>>>>>>>            If (mid(sFmt,1,iPos+i)="*") Begin  // the "*" is special. It means as many as you want
82200>>>>>>>>>               Move -2 to iDigits
82201>>>>>>>>>               increment i
82202>>>>>>>>>            end
82202>>>>>>>>>>
82202>>>>>>>>>            While (mid(sFmt,1,iPos+i)=sDigit)
82206>>>>>>>>>                 Increment i
82207>>>>>>>>>            end
82208>>>>>>>>>>
82208>>>>>>>>>            Move (Mid(sFmt,255,iPos+i)) to sRight // everything to the right of the last # is format stuff
82209>>>>>>>>>            If (iDigits=0) Move (i-1) to iDigits
82212>>>>>>>>>            //
82212>>>>>>>>>            Move 1 to i                           // find the first non-# to the left of the point
82213>>>>>>>>>            While (mid(sFmt,1,iPos-i)=sDigit)     // everything to the left is format stuff
82217>>>>>>>>>                 increment i
82218>>>>>>>>>            end
82219>>>>>>>>>>
82219>>>>>>>>>            Move (left(sFmt,iPos-i)) to sLeft
82220>>>>>>>>>        end
82220>>>>>>>>>>
82220>>>>>>>>>        else begin                             // we have no decinal
82221>>>>>>>>>            Move 0 to iDigits                  // so points is none
82222>>>>>>>>>            Move (Pos(sDigit,sFmt)) to iPos    // find first #.
82223>>>>>>>>>            If (iPos=0) Begin                  // if none, entire string is left format stuff..wierd!
82225>>>>>>>>>                Move sFmt to sLeft
82226>>>>>>>>>                Move ""   to sRight
82227>>>>>>>>>            end
82227>>>>>>>>>>
82227>>>>>>>>>            else begin
82228>>>>>>>>>                Move (left(sFmt,iPos-1)) to sLeft // all char to left of first # is left format stuff
82229>>>>>>>>>                Move 1 to i
82230>>>>>>>>>                While (mid(sFmt,1,iPos+i)=sDigit) // find last #, all char to right is right format
82234>>>>>>>>>                    Increment i
82235>>>>>>>>>                end
82236>>>>>>>>>>
82236>>>>>>>>>                Move (Mid(sFmt,255,i+iPos)) to sRight
82237>>>>>>>>>            end
82237>>>>>>>>>>
82237>>>>>>>>>        end
82237>>>>>>>>>>
82237>>>>>>>>>        // set temporary format properties and exit
82237>>>>>>>>>        Set pbThousandsSep to bSep
82238>>>>>>>>>        set psLeft         to sLeft
82239>>>>>>>>>        set psRight        to sRight
82240>>>>>>>>>        Set piPoints       to iDigits
82241>>>>>>>>>     End_procedure
82242>>>>>>>>>
82242>>>>>>>>>    // Public: Sets a format string. Pass full format for Positve and negative in sFmt. Pass
82242>>>>>>>>>    //         bCurrency true is this is a currency format, false if a numeric format
82242>>>>>>>>>    //
82242>>>>>>>>>    //  e.g. Send SetFormat "$,#.##;($,#.##)" True
82242>>>>>>>>>    //
82242>>>>>>>>>    Procedure SetFormat string sFmt integer bCurrency
82244>>>>>>>>>        string sPos sNeg
82244>>>>>>>>>        integer iPos
82244>>>>>>>>>
82244>>>>>>>>>        Move (Pos(";",sFmt)) to iPos
82245>>>>>>>>>        If iPos begin
82247>>>>>>>>>            Move (left(sFmt,iPos-1))    to sPos
82248>>>>>>>>>            Move (mid(sFmt,255,iPos+1)) to sNeg
82249>>>>>>>>>        end
82249>>>>>>>>>>
82249>>>>>>>>>        else Begin
82250>>>>>>>>>            Move sFmt         to sPos
82251>>>>>>>>>            Move ("-" + sFmt) to sNeg
82252>>>>>>>>>        end
82252>>>>>>>>>>
82252>>>>>>>>>        Send ParseFormat sPos
82253>>>>>>>>>        If bCurrency begin
82255>>>>>>>>>            Set pbCurPosThousandsSep to (pbThousandsSep(self))
82256>>>>>>>>>            set psCurPosLeft         to (psLeft(self))
82257>>>>>>>>>            set psCurPosRight        to (psRight(self))
82258>>>>>>>>>            Set piCurPosPoints       to (piPoints(self))
82259>>>>>>>>>        End
82259>>>>>>>>>>
82259>>>>>>>>>        else Begin
82260>>>>>>>>>            Set pbNumPosThousandsSep to (pbThousandsSep(self))
82261>>>>>>>>>            set psNumPosLeft         to (psLeft(self))
82262>>>>>>>>>            set psNumPosRight        to (psRight(self))
82263>>>>>>>>>            Set piNumPosPoints       to (piPoints(self))
82264>>>>>>>>>        end
82264>>>>>>>>>>
82264>>>>>>>>>
82264>>>>>>>>>        Send ParseFormat sNeg
82265>>>>>>>>>        If bCurrency begin
82267>>>>>>>>>            Set pbCurNegThousandsSep to (pbThousandsSep(self))
82268>>>>>>>>>            set psCurNegLeft         to (psLeft(self))
82269>>>>>>>>>            set psCurNegRight        to (psRight(self))
82270>>>>>>>>>            Set piCurNegPoints       to (piPoints(self))
82271>>>>>>>>>        End
82271>>>>>>>>>>
82271>>>>>>>>>        else Begin
82272>>>>>>>>>            Set pbNumNegThousandsSep to (pbThousandsSep(self))
82273>>>>>>>>>            set psNumNegLeft         to (psLeft(self))
82274>>>>>>>>>            set psNumNegRight        to (psRight(self))
82275>>>>>>>>>            Set piNumNegPoints       to (piPoints(self))
82276>>>>>>>>>        end
82276>>>>>>>>>>
82276>>>>>>>>>    End_procedure
82277>>>>>>>>>
82277>>>>>>>>>    // low level formatting. Pass parameters
82277>>>>>>>>>    Function Format_Num number nNumber integer iPoints integer bSep ;                       string sPrefix string sSuffix returns string
82279>>>>>>>>>        string  sLeft sRight sNumber sSep sDec
82279>>>>>>>>>        integer bIsNegative iDec iLen iCh
82279>>>>>>>>>
82279>>>>>>>>>        Get_Attribute DF_DECIMAL_SEPARATOR to iCh
82282>>>>>>>>>        Move (Character(iCh)) to sDec
82283>>>>>>>>>
82283>>>>>>>>>        Move (abs(nNumber)) to sNumber
82284>>>>>>>>>        Move (Pos(sDec,sNumber)) to iDec
82285>>>>>>>>>        Move (If(iDec=0, sNumber, left(sNumber,iDec-1))) to sLeft
82286>>>>>>>>>        Move (If(iDec=0, "", mid(sNumber,255,iDec+1)))   to sRight
82287>>>>>>>>>        // format for decimal separator
82287>>>>>>>>>        If (iPoints>=0) ; // if -2, leave it alone, it should not be -1            Move (left(sRight+repeat("0",iPoints),iPoints)) to sRight
82290>>>>>>>>>
82290>>>>>>>>>        // format for thousand sep.
82290>>>>>>>>>        If bSep Begin
82292>>>>>>>>>            Get_Attribute DF_THOUSANDS_SEPARATOR to iCh
82295>>>>>>>>>            Move (Character(iCh)) to sSep
82296>>>>>>>>>            Move (Length(sLeft)) to iLen
82297>>>>>>>>>            While (iLen>3)
82301>>>>>>>>>                Move (insert(sSep,sLeft,iLen-2)) to sLeft
82302>>>>>>>>>                Move (iLen-3) to iLen
82303>>>>>>>>>            End
82304>>>>>>>>>>
82304>>>>>>>>>        End
82304>>>>>>>>>>
82304>>>>>>>>>        // if decimal points or -2 (allow anything) and there are points to show
82304>>>>>>>>>        If (iPoints>0 OR (iPoints=-2 AND sRight<>"")) ;            Move (sLeft + sDec + sright) to sLeft
82307>>>>>>>>>        Function_return (sPrefix + sLeft+ sSuffix)
82308>>>>>>>>>    End_Function
82309>>>>>>>>>
82309>>>>>>>>>    // Public: Format for currency
82309>>>>>>>>>    //
82309>>>>>>>>>    Function FormatCur number nNumber integer iPoints returns string
82311>>>>>>>>>        string  sLeft sRight
82311>>>>>>>>>        integer bSep
82311>>>>>>>>>        If (nNumber<0) Begin
82313>>>>>>>>>            get pbCurNegThousandsSep to bSep
82314>>>>>>>>>            get psCurNegLeft         to sLeft
82315>>>>>>>>>            get psCurNegRight        to sRight
82316>>>>>>>>>            If (iPoints=-1) get piCurNegPoints       to iPoints
82319>>>>>>>>>        end
82319>>>>>>>>>>
82319>>>>>>>>>        Else Begin
82320>>>>>>>>>            get pbCurPosThousandsSep to bSep
82321>>>>>>>>>            get psCurPosLeft         to sLeft
82322>>>>>>>>>            get psCurPosRight        to sRight
82323>>>>>>>>>            If (iPoints=-1) get piCurPosPoints       to iPoints
82326>>>>>>>>>        end
82326>>>>>>>>>>
82326>>>>>>>>>        Function_return (Format_Num(self, nNumber,iPoints,bSep,sLeft,sRight))
82327>>>>>>>>>    End_function
82328>>>>>>>>>
82328>>>>>>>>>    // Public: Format for numeric
82328>>>>>>>>>    //
82328>>>>>>>>>    Function FormatNum number nNumber integer iPoints returns string
82330>>>>>>>>>        string  sLeft sRight
82330>>>>>>>>>        integer bSep
82330>>>>>>>>>        If (nNumber<0) Begin
82332>>>>>>>>>            get pbNumNegThousandsSep to bSep
82333>>>>>>>>>            get psNumNegLeft         to sLeft
82334>>>>>>>>>            get psNumNegRight        to sRight
82335>>>>>>>>>            If (iPoints=-1) get piNumNegPoints       to iPoints
82338>>>>>>>>>        end
82338>>>>>>>>>>
82338>>>>>>>>>        Else Begin
82339>>>>>>>>>            get pbNumPosThousandsSep to bSep
82340>>>>>>>>>            get psNumPosLeft         to sLeft
82341>>>>>>>>>            get psNumPosRight        to sRight
82342>>>>>>>>>            If (iPoints=-1) get piNumPosPoints       to iPoints
82345>>>>>>>>>        end
82345>>>>>>>>>>
82345>>>>>>>>>        Function_return (Format_Num(self, nNumber,iPoints,bSep,sLeft,sRight))
82346>>>>>>>>>    End_function
82347>>>>>>>>>
82347>>>>>>>>>
82347>>>>>>>>>    // Public: Format passing format string
82347>>>>>>>>>    //
82347>>>>>>>>>    Function FormatVal number nNumber string sFmt returns string
82349>>>>>>>>>        integer iPos bIsNeg
82349>>>>>>>>>        string  sLeft sRight
82349>>>>>>>>>        integer iPoints bSep
82349>>>>>>>>>        Move (nNumber<0) to bIsNeg
82350>>>>>>>>>        Move (Pos(";",sFmt)) to iPos
82351>>>>>>>>>        Case Begin
82351>>>>>>>>>            Case (iPos and Not(bIsNeg))      Move (left(sFmt,iPos-1))    to sFmt
82354>>>>>>>>>            Case (iPos and bIsNeg)           Move (mid(sFmt,255,iPos+1)) to sFmt
82358>>>>>>>>>            Case (not(iPos) and not(bIsNeg)) Move sFmt                   to sFmt
82362>>>>>>>>>            Case else                        Move ("-" + sFmt)           to sFmt
82364>>>>>>>>>        case end
82364>>>>>>>>>        Send ParseFormat sFmt
82365>>>>>>>>>        get pbThousandsSep to bSep
82366>>>>>>>>>        get psLeft         to sLeft
82367>>>>>>>>>        get psRight        to sRight
82368>>>>>>>>>        get piPoints       to iPoints
82369>>>>>>>>>        Function_return (Format_Num(self, nNumber,iPoints,bSep,sLeft,sRight))
82370>>>>>>>>>    end_function
82371>>>>>>>>>
82371>>>>>>>>>End_Class
