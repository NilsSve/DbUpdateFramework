84327>>>>>Struct tWinMemoryStatusEx
84327>>>>>    UInteger dwLength
84327>>>>>    UInteger dwMemoryLoad
84327>>>>>    UBigInt ullTotalPhys
84327>>>>>    UBigInt ullAvailPhys
84327>>>>>    UBigInt ullTotalPageFile
84327>>>>>    UBigInt ullAvailPageFile
84327>>>>>    UBigInt ullTotalVirtual
84327>>>>>    UBigInt ullAvailVirtual
84327>>>>>    UBigInt ullAvailExtendedVirtual
