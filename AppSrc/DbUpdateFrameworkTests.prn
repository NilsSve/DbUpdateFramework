85377>>>>>    // called after list is created and active. Load Data, seed list, select start column, etc.
85377>>>>>    Procedure LoadData
85379>>>>>        Handle hoInvokingObject hoDataSource hoInitialColumn
85379>>>>>        Integer iUpdateColumn iRows iInitialColumn iInitialOrder
85379>>>>>        Integer eUpdateMode
85379>>>>>        Boolean bAutoSeed bAutoColumn bCancel bSubFocus bAutoOrder 
85379>>>>>        
85379>>>>>        Get phoDataSource to hoDataSource
85380>>>>>        Get peUpdateMode to eUpdateMode
85381>>>>>        Get phoInvokingObject to hoInvokingObject
85382>>>>>        Get pbAutoSeed to bAutoSeed
85383>>>>>        Get piInitialColumn to iInitialColumn
85384>>>>>        Get piUpdateColumn to iUpdateColumn
85385>>>>>        Get RowCount of hoDataSource to iRows
85386>>>>>        
85386>>>>>        // We need an initial column. if you specified an initial column that will get used for the start column
85386>>>>>        // and the initial sort order. If you did not, which is typical, it will use the update column
85386>>>>>        If (iInitialColumn=-1) Begin
85388>>>>>            Move iUpdateColumn to iInitialColumn
85389>>>>>        End
85389>>>>>>
85389>>>>>        If (iInitialColumn>=0) Begin
85391>>>>>            Get ColumnObject iInitialColumn to hoInitialColumn
85392>>>>>            Set pbVisible of hoInitialColumn to True // initial column should be visible
85393>>>>>        End
85393>>>>>>
85393>>>>>        Send OnSeedData // find a good starting place for the row
85394>>>>>        Get pbFocusSubItems to bSubFocus
85395>>>>>        If bSubFocus Begin
85397>>>>>            // if column focus, which is normal, go to initialcolumn       
85397>>>>>            If hoInitialColumn Begin
85399>>>>>                Get MoveToColumnObject hoInitialColumn to bCancel
85400>>>>>            End
85400>>>>>>
85400>>>>>            Else Begin
85401>>>>>                Send MoveToFirstEnterableColumn
85402>>>>>            End
85402>>>>>>
85402>>>>>        End
85402>>>>>>
85402>>>>>
85402>>>>>    End_Procedure
85403>>>>>    
85403>>>>>    // This is only called in a successful close
