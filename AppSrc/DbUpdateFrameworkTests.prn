89376>>>>>>>>>    // *** Generalized messages to Get & Set values of the ini file.
89376>>>>>>>>>    // Sets a value in the program's ini file (write)
89376>>>>>>>>>    // Pass a section name, the value name parameter and the value itself to be written.
89376>>>>>>>>>    Procedure Set IniFileValue String sSection String sValueName String sValue
89378>>>>>>>>>        String sIniFile sPath
