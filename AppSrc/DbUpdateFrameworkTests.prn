95715>>>>>    Function UtilEnumerateOverlapFields Integer hTable Integer iField Returns String[]
95717>>>>>        String  sRetval sColumnName
95717>>>>>        String[] sOverlapFieldsArray
95718>>>>>        Integer iType iColumn iColumns 
95718>>>>>        Boolean bOpen bOverlap
95718>>>>>        
95718>>>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpen
95721>>>>>        If (bOpen = False) Begin
95723>>>>>            Open hTable
95725>>>>>        End
95725>>>>>>
95725>>>>>        
95725>>>>>        Move "" to sRetval
95726>>>>>        
95726>>>>>        Get_Attribute DF_FILE_NUMBER_FIELDS of hTable to iColumns
95729>>>>>        
95729>>>>>        for iColumn from 0 to iColumns
95735>>>>>>
95735>>>>>            Get_Attribute DF_FIELD_TYPE of hTable iColumn to iType
95738>>>>>            If (iField <> iColumn and iType <> DF_OVERLAP) Begin
95740>>>>>                Get_Attribute DF_FIELD_OVERLAP of hTable iField iColumn to bOverlap
95743>>>>>                If (bOverlap) Begin
95745>>>>>                    If (sRetval <> "") Begin
95747>>>>>                        Append sRetval ","
95748>>>>>                    End
95748>>>>>>
95748>>>>>                    Append sRetval iColumn
95749>>>>>                End
95749>>>>>>
95749>>>>>            End
95749>>>>>>
95749>>>>>        Loop
95750>>>>>>
95750>>>>>        
95750>>>>>        If (bOpen = False) Begin
95752>>>>>            Close hTable
95753>>>>>        End    
95753>>>>>>
95753>>>>>        
95753>>>>>        Move (StrSplitToArray(sRetval, ",")) to sOverlapFieldsArray
95754>>>>>        
95754>>>>>        Function_Return sOverlapFieldsArray
95755>>>>>    End_Function
