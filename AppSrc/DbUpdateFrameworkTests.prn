85846>>>>>>>    String sTableCharacterFormat
85846>>>>>>>    Boolean bUseDummyZeroDate   
85846>>>>>>>    Integer iFileDummyUpdateColumn // Init value to -1 if not exists (value can be in range 1 - number of columns)  
85846>>>>>>>    Integer iFileBlockSize         // Init value to -1 if not exists  
85846>>>>>>>    Integer iFileMaxRowsFetched    // Init value to -1 if not exists  
85846>>>>>>>    Integer iFileGetRidAfterCreate // Init value to -1. But is boolean! 
85846>>>>>>>    Integer iFileJitBinding        // Init value to -1. But is boolean!  
85846>>>>>>>    String sRefindAfterSave        // Yes or No (how to handle?) 
85846>>>>>>>    String sSystemFile             // Yes or No (how to handle?) 
85846>>>>>>>    String sFileIndexTablespace  
85846>>>>>>>    String sFileLongTablespace
85846>>>>>>>    String sTableTablespace
85846>>>>>>>End_Struct           
