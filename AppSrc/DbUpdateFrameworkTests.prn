94843>>>>>    Function ApiIndexChangeUppercase Handle hTable Integer iIndex Integer iSegment Boolean bUppercase Returns Boolean
94845>>>>>        Integer iCase
94845>>>>>        Boolean bOK
94845>>>>>        
94845>>>>>        If (bUppercase = True) Begin
94847>>>>>            Move DF_CASE_IGNORED to iCase
94848>>>>>        End                                                                       
94848>>>>>>
94848>>>>>        Else Begin
94849>>>>>            Move DF_CASE_USED to iCase    
94850>>>>>        End
94850>>>>>>
94850>>>>>
94850>>>>>        Get AutoConnectionIDLogin to bOK
94851>>>>>        Move False to Err
94852>>>>>        Open hTable Mode DF_EXCLUSIVE
94854>>>>>        Structure_Start hTable
94855>>>>>            Set_Attribute DF_INDEX_SEGMENT_CASE of hTable iIndex iSegment to iCase   
94858>>>>>        Structure_End hTable
94860>>>>>        
94860>>>>>        Function_Return (Err = False)
94861>>>>>    End_Function
94862>>>>>
94862>>>>>    // To delete an index
94862>>>>>    Function ApiIndexRemove Handle hTable Integer iIndex Returns Boolean
94864>>>>>        Integer iTableNo iNumSegments
94864>>>>>        String sDriverID
94864>>>>>        Boolean bOK
94864>>>>>        
94864>>>>>        Get AutoConnectionIDLogin to bOK
94865>>>>>        Move False to Err
94866>>>>>        Move hTable to iTableNo
94867>>>>>        Open hTable Mode DF_EXCLUSIVE
94869>>>>>        Get_Attribute DF_FILE_DRIVER of hTable to sDriverID
94872>>>>>        
94872>>>>>        // Check to see if the index exists or not...
94872>>>>>        Get_Attribute DF_INDEX_NUMBER_SEGMENTS of hTable iIndex to iNumSegments
94875>>>>>        If (iNumSegments = 0) Begin
94877>>>>>            Function_Return False
94878>>>>>        End
94878>>>>>>
94878>>>>>        
94878>>>>>        Structure_Start hTable sDriverID
94879>>>>>            Send Ignore_Error of Error_Object_Id DFERR_BAD_PARAMETER
94880>>>>>            Delete_Index iTableNo iIndex
94881>>>>>            Send Trap_Error of Error_Object_Id DFERR_BAD_PARAMETER
94882>>>>>        Structure_End hTable DF_STRUCTEND_OPT_NONE
94884>>>>>
94884>>>>>        Function_Return (Err = False)
94885>>>>>    End_Function
94886>>>>>    
94886>>>>>    // Checks if a field name exists in a table definition
94886>>>>>    // Returns True if it does
94886>>>>>    // Sample:
94886>>>>>    //   Get UtilColumnExists MyTable.File_Number "MyColumnName" to iExists
94886>>>>>    Function UtilColumnExists Handle hTable String sFieldName Returns Boolean
94888>>>>>        Integer iNumColumns iColumn
94888>>>>>        String sColumn
94888>>>>>        Boolean bExists bOK
94888>>>>>    
94888>>>>>        Get AutoConnectionIDLogin to bOK
94889>>>>>        Send Ignore_Error of Error_Object_Id DFERR_CANT_OPEN_DATA_FILE
94890>>>>>        Open hTable                       
94892>>>>>        Send Trap_Error   of Error_Object_Id DFERR_CANT_OPEN_DATA_FILE
94893>>>>>        If (Found = False) Begin
94895>>>>>            Function_Return False
94896>>>>>        End                      
94896>>>>>>
94896>>>>>        
94896>>>>>        Move False to bExists  
94897>>>>>        Get_Attribute DF_FILE_NUMBER_FIELDS of hTable to iNumColumns
94900>>>>>        for iColumn from 1 to iNumColumns
94906>>>>>>
94906>>>>>            Get_Attribute DF_FIELD_NAME of hTable iColumn to sColumn
94909>>>>>            If (Uppercase(sFieldName) = Uppercase(sColumn)) Begin
94911>>>>>                Move iNumColumns to iColumn
94912>>>>>                Move True to bExists
94913>>>>>            End
94913>>>>>>
94913>>>>>        Loop
94914>>>>>>
94914>>>>>        Close hTable
94915>>>>>    
94915>>>>>        Function_Return bExists
94916>>>>>    End_Function
94917>>>>>    
94917>>>>>    // Checks if the current psConnectionID is logged in; if not
94917>>>>>    // attempts to make a login. 
94917>>>>>    // Because
94917>>>>>    // Returns True if already logged in or the new login was successful.
94917>>>>>    Function AutoConnectionIDLogin Returns Boolean
94919>>>>>        String sConnectionID sConnectionString sDriverID
94919>>>>>        Boolean bExists bOK bDAWDriver
94919>>>>>        Handle hoCLI hoDriver                                    
94919>>>>>        Integer iRetval
94919>>>>>        tSQLConnection SQLConnection
94919>>>>>        tSQLConnection SQLConnection
94919>>>>>        
94919>>>>>        Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
94920>>>>>        Move SQLConnection.sDriverID                  to sDriverID      
94921>>>>>        Move SQLConnection.sConnectionString          to sConnectionString
94922>>>>>        Get IsDAWSQLDriver sDriverID to bOK
94923>>>>>        If (bOK = False) Begin                         
94925>>>>>            Get _MertechSQLManagerHandle to hoCLI
94926>>>>>            Get Create (RefClass(cDbUpdateDatabaseDriver)) to hoDriver
94927>>>>>            Set psDriverID of hoDriver to SQLConnection.sDriverID
94928>>>>>            Get DbLogin    of hoDriver sConnectionString SQLConnection.sServer SQLConnection.sDatabase SQLConnection.bTrusted SQLConnection.sUserID SQLConnection.sPassword to bOK
94929>>>>>            Send Destroy   of hoDriver
94930>>>>>            Function_Return False
94931>>>>>        End                      
94931>>>>>>
94931>>>>>        
94931>>>>>        Move SQLConnection.sConnectionID to sConnectionID
94932>>>>>        
94932>>>>>        Get IsConnectionID sConnectionID sDriverID to bExists
94933>>>>>        If (bExists = False) Begin
94935>>>>>            // We always start by deleting the current connection - if any - because the
94935>>>>>            // login details my have changed.
94935>>>>>            Get phoCLIHandler to hoCLI   
94936>>>>>            Set psDriverID    of hoCLI to sDriverID
94937>>>>>            Get DeleteConnectionID of hoCLI sConnectionID -1 to iRetval
94938>>>>>            Get UtilCreateConnectionID sConnectionID to bOk
94939>>>>>            If (bOk = False) Begin
94941>>>>>                Error DFERR_PROGRAM ("The Connection ID:" * sConnectionID * "could not be created and therefor the table can't be changed.")
94942>>>>>>
94942>>>>>                Function_Return False
94943>>>>>            End
94943>>>>>>
94943>>>>>            Move bOK to bExists
94944>>>>>        End
94944>>>>>>
94944>>>>>        
94944>>>>>        Function_Return (bExists = True)
94945>>>>>    End_Function
94946>>>>>    
94946>>>>>    // *** Utility Messages ***
94946>>>>>    // 
94946>>>>>    //
94946>>>>>    // To add a value to the CodeMast & CodeType tables. Pass; a) bCodeType if it is CodeType that should be updated. 
94946>>>>>    // Else it is CodeMast. b) sTypeValue; either to be added If bCodeType = True, or it will be used to find the correct 
94946>>>>>    // CodeType record. c) sValue1 and d) sValue2 is the CodeType Description & Comment, or CodeMast Type and Code values.
94946>>>>>    Function UtilCodeMasterAddValue Boolean bCodeType String sTypeValue String sValue2 String sValue3 Returns Boolean
94948>>>>>        Boolean bError bFound
94948>>>>>        
94948>>>>>        Move False to Err
94949>>>>>        Open CodeMast
94951>>>>>        Open CodeType
94953>>>>>        
94953>>>>>        If (bCodeType = True) Begin
94955>>>>>            Clear CodeType
94956>>>>>            Move sTypeValue to CODETYPE.Type 
94957>>>>>            Find eq CODETYPE.Type
94958>>>>>>
94958>>>>>            Move (Found = True) to bFound
94959>>>>>            If (bFound = True) Begin
94961>>>>>                Reread CodeType
94965>>>>>            End
94965>>>>>>
94965>>>>>            If (bFound = False) Begin
94967>>>>>                Clear CodeType
94968>>>>>            End       
94968>>>>>>
94968>>>>>                Move sTypeValue to CODETYPE.Type 
94969>>>>>                Move sValue2    to CODETYPE.Description
94970>>>>>                Move sValue3    to CODETYPE.Comment
94971>>>>>                SaveRecord CODETYPE
94972>>>>>            If (bFound = True) Begin
94974>>>>>                Unlock
94975>>>>>>
94975>>>>>            End
94975>>>>>>
94975>>>>>        End
94975>>>>>>
94975>>>>>        
94975>>>>>        If (bCodeType = False) Begin
94977>>>>>            Clear CODEMAST
94978>>>>>            Move sTypeValue to CODEMAST.Type
94979>>>>>            Move sValue2    to CODEMAST.Code  
94980>>>>>            Find eq CODEMAST.Code
94981>>>>>>
94981>>>>>            Move (Found = True) to bFound
94982>>>>>            If (bFound = True) Begin
94984>>>>>                Reread CODEMAST
94988>>>>>            End
94988>>>>>>
94988>>>>>            If (bFound = False) Begin
94990>>>>>                Clear CODEMAST
94991>>>>>            End   
94991>>>>>>
94991>>>>>                Move sTypeValue to CODEMAST.Type
94992>>>>>                Move sValue2    to CODEMAST.Code  
94993>>>>>                Move sValue3    to CODEMAST.Description
94994>>>>>                SaveRecord CODEMAST
94995>>>>>            If (bFound = True) Begin
94997>>>>>            Unlock
94998>>>>>>
94998>>>>>            End
94998>>>>>>
94998>>>>>        End
94998>>>>>>
94998>>>>>        
94998>>>>>        Close CodeMast
94999>>>>>        Close CodeType
95000>>>>>        
95000>>>>>        Function_Return (Err = False)
95001>>>>>    End_Function
95002>>>>>
95002>>>>>    // Changes values in CodeType & CodeMast - From type value To type value. It first changes the type value in 
95002>>>>>    // CodeType and then spins through all CodeMast records to change all related records.
95002>>>>>    Function UtilCodeMasterChangeValue String sFromValue String sToValue Returns Boolean
95004>>>>>        Boolean bFound
95004>>>>>        
95004>>>>>        Move False to Err
95005>>>>>        Open CodeMast
95007>>>>>        Open CodeType
95009>>>>>        
95009>>>>>        Clear CodeType
95010>>>>>        Move sFromValue to CODETYPE.Type
95011>>>>>        Find eq CODETYPE.Type
95012>>>>>>
95012>>>>>        If (Found = True) Begin
95014>>>>>            Reread CODETYPE
95018>>>>>                Move sToValue to CODETYPE.Type
95019>>>>>                SaveRecord CODETYPE
95020>>>>>            Unlock                 
95021>>>>>>
95021>>>>>        End
95021>>>>>>
95021>>>>>            
95021>>>>>        Clear CODEMAST
95022>>>>>        Find gt CODEMAST by Recnum
95023>>>>>>
95023>>>>>        While (Found = True)
95027>>>>>            Move (Trim(Uppercase(CODEMAST.Type) = Trim(Uppercase(sFromValue)))) to bFound
95028>>>>>            If (bFound = True) Begin
95030>>>>>                Reread CODEMAST
95034>>>>>                    Move sToValue to CODEMAST.Type
95035>>>>>                    SaveRecord CODEMAST
95036>>>>>                Unlock
95037>>>>>>
95037>>>>>            End
95037>>>>>>
95037>>>>>            Find gt CODEMAST by Recnum
95038>>>>>>
95038>>>>>        Loop
95039>>>>>>
95039>>>>>        
95039>>>>>        Close CodeMast
95040>>>>>        Close CodeType
95041>>>>>        
95041>>>>>        Function_Return (Err = False)
95042>>>>>    End_Function
95043>>>>>    
95043>>>>>    // Removes a value from CodeMast. Pass the sTypeValue and the sValue2 to remove.
95043>>>>>    Function UtilCodeMasterRemoveValue String sTypeValue String sValue2 Returns Boolean
95045>>>>>        Boolean bError bFound
95045>>>>>        
95045>>>>>        Move False to Err
95046>>>>>        Open CodeMast
95048>>>>>        
95048>>>>>        Clear CODEMAST
95049>>>>>        Move sTypeValue to CODEMAST.Type
95050>>>>>        Move sValue2    to CODEMAST.Code  
95051>>>>>        Find eq CODEMAST.Code
95052>>>>>>
95052>>>>>        Move (Found = True) to bFound
95053>>>>>        If (bFound = True) Begin
95055>>>>>            Delete CODEMAST
95056>>>>>        End
95056>>>>>>
95056>>>>>        
95056>>>>>        Close CodeMast
95057>>>>>        
95057>>>>>        Function_Return (Err = False)
95058>>>>>    End_Function
95059>>>>>
95059>>>>>    // Note:
95059>>>>>    // The DF_FILE_TABLE_NAME attribute holds the name of the table at the back end. Depending on the back end, table 
95059>>>>>    // names may be case sensitive, contain spaces or other special characters. This attribute is used to determine a table's 
95059>>>>>    // back end name when using Embedded SQL. Since Embedded SQL works on the back end directly, the back end's name must be used. 
95059>>>>>    // In most cases the back end name will be the same as the table name used in DataFlex.
95059>>>>>    // To do the opposite; To get the file handle from a table name string use the UtilTableNameToHandle function.
95059>>>>>    Function UtilTableHandleToString Handle hTable Returns String
95061>>>>>        String sTableName
95061>>>>>        Boolean bOpen bExists bRecnum bOK
95061>>>>>        
95061>>>>>        Get UtilTableNumberIsInUse hTable to bExists
95062>>>>>        If (bExists = False) Begin
95064>>>>>            Move True to Err
95065>>>>>            Function_Return ""
95066>>>>>        End
95066>>>>>>
95066>>>>>
95066>>>>>        Set Error_Report_Mode to DUF_ERROR_NO_REPORT
95067>>>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpen
95070>>>>>        If (bOpen = False) Begin                       
95072>>>>>            Get AutoConnectionIDLogin to bOK
95073>>>>>            Send Ignore_Error of Error_Object_Id DFERR_CANT_OPEN_DATA_FILE
95074>>>>>            Send Ignore_Error of Error_Object_Id DFERR_CANT_OPEN_INTERMEDIATE_FILE
95075>>>>>            Send Ignore_Error of Error_Object_Id CLIERR_GENERAL_ERROR
95076>>>>>            Open hTable
95078>>>>>            Send Trap_Error of Error_Object_Id DFERR_CANT_OPEN_DATA_FILE
95079>>>>>            Send Trap_Error of Error_Object_Id DFERR_CANT_OPEN_INTERMEDIATE_FILE
95080>>>>>            Send Trap_Error of Error_Object_Id CLIERR_GENERAL_ERROR
95081>>>>>            Get_Attribute DF_FILE_OPENED of hTable to bOpen
95084>>>>>        End
95084>>>>>>
95084>>>>>        If (bOpen = True) Begin
95086>>>>>            Send Ignore_Error of Error_Object_Id DFERR_UNSUPPORTED_ATTRIBUTE 
95087>>>>>            Get_Attribute DF_FILE_TABLE_NAME of hTable to sTableName 
95090>>>>>            // If blank it is an embedded table:
95090>>>>>            If (sTableName = "") Begin
95092>>>>>                Get_Attribute DF_FILE_LOGICAL_NAME of hTable to sTableName 
95095>>>>>                Move 0 to LastErr
95096>>>>>                Move False to Err
95097>>>>>            End
95097>>>>>>
95097>>>>>            Send Trap_Error of Error_Object_Id DFERR_UNSUPPORTED_ATTRIBUTE
95098>>>>>        End
95098>>>>>>
95098>>>>>        Set Error_Report_Mode to DUF_ERROR_REPORT
95099>>>>>            
95099>>>>>        Function_Return sTableName
95100>>>>>    End_Function
95101>>>>>    
95101>>>>>    // Returns the filenumber for the passed Table name from Filelist.cfg.
95101>>>>>    // Returns 0 if unsuccessful.
95101>>>>>    // To do the opposite; To get the string value from a table handle string use the UtilTableHandleToString function.
95101>>>>>    Function UtilTableNameToHandle String sTableName Returns Integer
95103>>>>>        String sValue sPrefixTableName sDriverID
95103>>>>>        Handle hTable hRetval
95103>>>>>        
95103>>>>>        Get psDriverID to sDriverID 
95104>>>>>        If (sDriverID <> DATAFLEX_ID and not(sTableName contains ":")) Begin
95106>>>>>            Move (sDriverID + ":" + sTableName) to sPrefixTableName
95107>>>>>        End
95107>>>>>>
95107>>>>>        Move 0 to hTable 
95108>>>>>        Move 0 to hRetval
95109>>>>>        Repeat 
95109>>>>>>
95109>>>>>            Get_Attribute DF_FILE_NEXT_USED of hTable to hTable
95112>>>>>            If (hTable <> 0) Begin
95114>>>>>                Get_Attribute DF_FILE_ROOT_NAME of hTable to sValue
95117>>>>>                If (Uppercase(sValue) = Uppercase(sTableName) or Uppercase(sValue) = Uppercase(sPrefixTableName)) Begin
95119>>>>>                    Move hTable to hRetval
95120>>>>>                    Move 0 to hTable
95121>>>>>                End
95121>>>>>>
95121>>>>>            End
95121>>>>>>
95121>>>>>        Until (hTable = 0)
95123>>>>>        
95123>>>>>        Function_Return hRetval
95124>>>>>    End_Function
95125>>>>>        
95125>>>>>    // Check if the file exists in the Data folder,
95125>>>>>    // else creates it from memory as it has been compiled into the program as a resource:
95125>>>>>    Function UtilCheckCreateIfFileExists String sFileName String sResourceName Boolean bDataFile Returns Boolean
95127>>>>>        String sPath sDataPath
95127>>>>>        Boolean bExists
95127>>>>>    
95127>>>>>        Get psDataPathFirstPart to sPath
95128>>>>>        Move (sPath + sFileName) to sFileName
95129>>>>>        Get vFilePathExists sFileName to bExists
95130>>>>>    
95130>>>>>        If (bExists = False) Begin
95132>>>>>            // Read from memory & create file on disk.
95132>>>>>            Send SqlUtilCreateFileFromMemory sResourceName sFileName
95133>>>>>            Get vFilePathExists sFileName to bExists
95134>>>>>        End     
95134>>>>>>
95134>>>>>        Function_Return bExists
95135>>>>>    End_Function
95136>>>>>    
95136>>>>>    // To convert between a data type string name and its integer constant declaration. E.g."VarChar" -> SQL_VarChar
95136>>>>>    // The reciprocal function of UtilColumnTypeToInteger.              
95136>>>>>    Function UtilColumnTypeToInteger String sDriverID Integer iDbType String sDataType Returns Integer
95138>>>>>        tColumnType RetvalType  
95138>>>>>        tColumnType RetvalType  
95138>>>>>        
95138>>>>>        Get _UtilColumnType sDriverID iDbType 0 sDataType False to RetvalType
95139>>>>>        Function_Return RetvalType.iType
95140>>>>>    End_Function
95141>>>>>    
95141>>>>>    // To convert between an integer data type constant and its string value. E.g. SQL_VarChar -> "VarChar".
95141>>>>>    // The reciprocal function of UtilColumnTypeToString.              
95141>>>>>    Function UtilColumnTypeToString String sDriverID Integer iDbType Integer iDataType Returns String
95143>>>>>        tColumnType RetvalType  
95143>>>>>        tColumnType RetvalType  
95143>>>>>        String sValue
95143>>>>>        
