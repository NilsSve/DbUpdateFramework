84526>>>>>
84526>>>>>    //****************************************************************************
84526>>>>>    // If workspaces are used, we will send the message EnumerateWorkspaceData
84526>>>>>    // To the workspace object passing the an object and message To send back
84526>>>>>    // To this object. It is expected that the workspace object will send this
84526>>>>>    // message for every line Of information it wants displayed (passing the
84526>>>>>    // information To be displayed
84526>>>>>    //****************************************************************************
84526>>>>>    Register_Procedure EnumerateWorkspaceData Integer hObjId Integer hmMessId
84526>>>>>
84526>>>>>    Procedure Show_ServicePack
84528>>>>>        String sKey sVersion sDataFlex
84528>>>>>        Handle hoRegistry
84528>>>>>        Boolean bExists bOpened
84528>>>>>
84528>>>>>        Move "DataFlex"        to sDataFlex
84529>>>>>
84529>>>>>        Get Create U_cRegistry to hoRegistry
84530>>>>>        Set phRootKey of hoRegistry to HKEY_LOCAL_MACHINE
84531>>>>>        Set pfAccessRights of hoRegistry to KEY_READ
84532>>>>>        Get KeyExists of hoRegistry "SOFTWARE\Wow6432Node" to bExists
84533>>>>>
84533>>>>>        If (bExists) Begin
84535>>>>>            Move ("SOFTWARE\Wow6432Node\Data Access Worldwide\" + sDataFlex + "\" + SysConf (SYSCONF_DATAFLEX_REV)) to sKey
84536>>>>>        End
84536>>>>>>
84536>>>>>        Else Begin
84537>>>>>            Move ("SOFTWARE\Data Access Worldwide\"             + sDataFlex + "\" + SysConf (SYSCONF_DATAFLEX_REV)) to sKey
84538>>>>>        End
84538>>>>>>
84538>>>>>        Get KeyExists of hoRegistry sKey to bExists
84539>>>>>        If (bExists) Begin
84541>>>>>            Get OpenKey of hoRegistry sKey to bOpened
84542>>>>>            If (bOpened) Begin
84544>>>>>                Get ValueExists of hoRegistry "CurrentVersionDescription" to bExists
84545>>>>>                If (bExists) Begin
84547>>>>>                    Get ReadString of hoRegistry "CurrentVersionDescription" to sVersion
84548>>>>>                End
84548>>>>>>
84548>>>>>                Send CloseKey of hoRegistry
84549>>>>>            End
84549>>>>>>
84549>>>>>        End
84549>>>>>>
84549>>>>>        Send Destroy of hoRegistry
84550>>>>>
84550>>>>>        If (sVersion <> "") Begin
84552>>>>>           Send AppendTextLn sVersion
84553>>>>>           Send AppendTextLn ""
84554>>>>>        End
84554>>>>>>
84554>>>>>    End_Procedure
84555>>>>>
84555>>>>>    Procedure Show_WorkspaceInformation
84557>>>>>        Integer hoWorkspace
84557>>>>>
84557>>>>>        If (ghoApplication <> 0) Begin
84559>>>>>            Get phoWorkspace of ghoApplication to hoWorkspace
84560>>>>>            If (hoWorkspace <> 0) Begin
84562>>>>>                Send EnumerateWorkspaceData of hoWorkspace Self msg_AppendTextLn
84563>>>>>            End
84563>>>>>>
84563>>>>>        End
84563>>>>>>
84563>>>>>    End_Procedure
84564>>>>>
84564>>>>>    //****************************************************************************
84564>>>>>    // If connection ids are used, we will send the message EnumerateConnections
84564>>>>>    // to the connection manager object passing the an object and message to send 
84564>>>>>    // back to this object. It is expected that the connection manager object will 
84564>>>>>    // send this message for every line Of information it wants displayed (passing 
84564>>>>>    // the information To be displayed
84564>>>>>    //****************************************************************************
84564>>>>>    Register_Procedure EnumerateConnections Integer hObjId Integer hmMessId
84564>>>>>
84564>>>>>    Procedure Show_ConnectionIdInformation
84566>>>>>        If (ghoConnection > 0) Begin
84568>>>>>            Send EnumerateConnections of ghoConnection Self (RefProc(AppendTextLn))
84569>>>>>            Send AppendTextLn ""
84570>>>>>        End
84570>>>>>>
84570>>>>>    End_Procedure
84571>>>>>
