91154>>>>>        
91154>>>>>        Get psDriverID to sDriverID
91155>>>>>        Get SqlUtilCheckIfTableNameExists sTableName sDriverID to bExists
91156>>>>>        If (bExists = True) Begin
91158>>>>>            Function_Return False
91159>>>>>        End                      
91159>>>>>>
91159>>>>>        
91159>>>>>        Get psDataPathFirstPart to sPath
91160>>>>>        Get vFilePathExists (sPath + String(sTableName) + ".int") to bExists
91161>>>>>        If (bExists = True) Begin
91163>>>>>            // ToDo: What should we do if an .int file already exists?
91163>>>>>        End
91163>>>>>>
91163>>>>>        
91163>>>>>        Get piDbType to iDbType
91164>>>>>        Get _SqlProperTableName sTableName to sTableName
91165>>>>>        Get _SqlFindKeyWord CI_SQLCreateTable iDbType to sCreateTable
91166>>>>>        Move (sCreateTable * String(sTableName) * "(Dummy Decimal(2,0))") to sSQLString
91167>>>>>        
91167>>>>>        Move False to Err               
91168>>>>>        Send SqlUtilExecuteQuery sSQLString sDriverID
91169>>>>>    
91169>>>>>        Function_Return (Err = False)
91170>>>>>    End_Function       
91171>>>>>    
91171>>>>>    // First deletes the data cache file and then drops the passed SQL table. 
91171>>>>>    // Note: The table needs to exist in filelist.cfg, and it must be possible to open it,
91171>>>>>    //       else try using the SqlTableRemoveByTableName message.    
91171>>>>>    Function SqlTableRemove Integer hTable Returns Boolean
91173>>>>>        String sSQLString sPath sDropTable sTableName sDriverID 
91173>>>>>        Integer iRetval iDbType
91173>>>>>        Boolean bExists bMertechDriver bOK
91173>>>>>        
91173>>>>>        Get psDriverID to sDriverID   
91174>>>>>        Get IsMertechDriver sDriverID to bMertechDriver
91175>>>>>        Get UtilTableHandleToString hTable to sTableName
91176>>>>>        Get SqlUtilCheckIfTableNameExists sTableName sDriverID to bExists
91177>>>>>        If (bExists = False) Begin
91179>>>>>            Function_Return False
91180>>>>>        End                      
91180>>>>>>
91180>>>>>        
91180>>>>>        Get psDataPathFirstPart to sPath               
91181>>>>>        Get UtilDeleteCacheFile sTableName to iRetval
91182>>>>>            
91182>>>>>        Get piDbType to iDbType
91183>>>>>        Get _SqlProperTableName sTableName to sTableName
91184>>>>>        Get _SqlFindKeyWord CI_SQLDropTable iDbType to sDropTable
91185>>>>>        Move (sDropTable * String(sTableName)) to sSQLString
91186>>>>>        
91186>>>>>        Move False to Err               
91187>>>>>        Send SqlUtilExecuteQuery sSQLString sDriverID
91188>>>>>    
91188>>>>>        // We also need to remove the cache-file since the table has been changed
91188>>>>>        Get UtilDeleteCacheFile sTableName to bOK
91189>>>>>    
91189>>>>>        Function_Return (Err = False)
91190>>>>>    End_Function 
91191>>>>>    
91191>>>>>    // First deletes the data cache file and then drops the passed data table. 
91191>>>>>    Function SqlTableRemoveByTableName String sTableName Returns Boolean
91193>>>>>        String sSQLString sPath sDropTable sVal sSchema sDriverID 
91193>>>>>        Integer iRetval iDbType
91193>>>>>        Boolean bMertechDriver bOK
91193>>>>>        
91193>>>>>        Get psDriverID to sDriverID
91194>>>>>        Get IsMertechDriver sDriverID to bMertechDriver
91195>>>>>        Get psDataPathFirstPart to sPath               
91196>>>>>        Get UtilDeleteCacheFile sTableName to iRetval
91197>>>>>        
91197>>>>>        Get piDbType to iDbType
91198>>>>>        Get _SqlFindKeyWord CI_SQLDropTable iDbType to sDropTable 
91199>>>>>        Get psSchema to sSchema
91200>>>>>        If (sSchema = "") Begin
91202>>>>>            Get _SqlFindKeyWord CI_SQLDBO to sSchema 
91203>>>>>        End
91203>>>>>>
91203>>>>>        Move (Uppercase(sTableName)) to sVal
91204>>>>>        If (not(sVal contains (sSchema + "."))) Begin    
91206>>>>>            Move (Lowercase(sSchema) + "." + sTableName) to sTableName
91207>>>>>        End    
91207>>>>>>
91207>>>>>        Move (sDropTable * String(sTableName)) to sSQLString
91208>>>>>        
91208>>>>>        Move False to Err               
91209>>>>>        Send SqlUtilExecuteQuery sSQLString sDriverID
91210>>>>>    
91210>>>>>        // We also need to remove the cache-file since the table has been changed
91210>>>>>        Get UtilDeleteCacheFile sTableName to bOK
91211>>>>>    
91211>>>>>        Function_Return (Err = False)
91212>>>>>    End_Function 
91213>>>>>
91213>>>>>    // *** Sql View Messages ***
91213>>>>>
91213>>>>>    // First deletes the data cache file and then drops the passed Sql data view. 
91213>>>>>    Function SqlViewRemove String sDataView Returns Boolean
91215>>>>>        String sDriverID sSQLString sPath sDropViewKeyWord 
91215>>>>>        Integer iRetval                                
91215>>>>>        Boolean bMertechDriver bOK
91215>>>>>        
91215>>>>>        Get psDriverID to sDriverID
91216>>>>>        Get IsMertechDriver sDriverID to bMertechDriver
91217>>>>>        Get UtilDeleteCacheFile sDataView to iRetval
91218>>>>>        
91218>>>>>        Get _SqlFindKeyWord CI_SQLDropView to sDropViewKeyWord
91219>>>>>        Move (sDropViewKeyWord * String(sDataView)) to sSQLString
91220>>>>>        Set psSQLStatementString to sSQLString 
91221>>>>>        
91221>>>>>        // As we don't check if the view exist or not, it might happen
91221>>>>>        // that it doesn't and that would through an error, so guard for that eventuality (just ignore it).
91221>>>>>        Move False to Err 
91222>>>>>        Set Error_Report_Mode to DUF_ERROR_NO_REPORT
91223>>>>>        Send SqlUtilExecuteQuery sSQLString sDriverID
91224>>>>>        Set Error_Report_Mode to DUF_ERROR_REPORT
91225>>>>>        Move 0 to LastErr
91226>>>>>        
91226>>>>>        // We also need to remove the cache-file since the table has been changed
91226>>>>>        Get UtilDeleteCacheFile sDataView to bOK
91227>>>>>    
91227>>>>>        Function_Return (Err = False)
91228>>>>>    End_Function
91229>>>>>    
91229>>>>>    // *** Sql Column Messages ***
91229>>>>>    //
91229>>>>>    // Sample: Get SqlColumnAdd MyTable.File_Number "NewColumnName" True "InitValue" DF_ASCII 35  
91229>>>>>    Function SqlColumnAdd Integer hTable String sColumnName Integer iDataType Integer iLen Integer iDec Boolean bInitVal String sColVal Returns Boolean
91231>>>>>        Integer iColumn iDbType iLength iDecimals
91231>>>>>        String sStmt sAlterTable sAddColumn sModifyColumn sVal sDataType sLengthAndDecimals sColumnValue
91231>>>>>        String sTableName sDriverID sUpdate sSet sNoCountOn
91231>>>>>        Boolean bExists bOK bInitializeValue 
91231>>>>>        
91231>>>>>        Get psDriverID to sDriverID
91232>>>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
91233>>>>>        If (bOK = False) Begin   
91235>>>>>            Function_Return False
91236>>>>>        End              
91236>>>>>>
91236>>>>>        
91236>>>>>        Get UtilTableHandleToString hTable to sTableName
91237>>>>>        If (sTableName = "") Begin
91239>>>>>            Function_Return False    
91240>>>>>        End  
91240>>>>>>
91240>>>>>        
91240>>>>>        If (num_arguments > 4) Begin
91242>>>>>            Move iDec     to iDecimals
91243>>>>>            Move bInitVal to bInitializeValue                                      
91244>>>>>            Move sColVal  to sColumnValue
91245>>>>>        End                       
91245>>>>>>
91245>>>>>        
91245>>>>>        Get SqlColumnAddByTableName sTableName sColumnName iDataType iLen iDecimals bInitializeValue sColumnValue to bOK
91246>>>>>        
91246>>>>>        Function_Return (bOK = True)    
91247>>>>>    End_Function  
91248>>>>>    
91248>>>>>    // Sample: Get SqlColumnAddByTableName "MyTable" "NewColumnName" DF_ASCII 35 0 True "InitValue" 
91248>>>>>    Function SqlColumnAddByTableName String sTableName String sColumnName Integer iDataType Integer iLen Integer iDec Boolean bInitVal String sColVal Returns Boolean
91250>>>>>        Integer iColumn iDbType iLength iDecimals iDriver
91250>>>>>        String sStmt sAlterTable sAddColumn sModifyColumn sVal sDataType sLengthAndDecimals sColumnValue
91250>>>>>        String sDriverID sUpdate sSet sNoCountOn sNotNull
91250>>>>>        Boolean bExists bOK bInitializeValue bRetval bFixed bDriverIgnoreErrorState
91250>>>>>        Handle hTable 
91250>>>>>        
91250>>>>>        Get psDriverID to sDriverID
91251>>>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
91252>>>>>        If (bOK = False) Begin   
91254>>>>>            Function_Return False
91255>>>>>        End              
91255>>>>>>
91255>>>>>        
91255>>>>>        Get UtilTableNameToHandle sTableName to hTable
91256>>>>>        If (hTable = 0) Begin
91258>>>>>            Get NextFreeFilelistSlot to hTable
91259>>>>>        End
91259>>>>>>
91259>>>>>        
91259>>>>>        Get piDbType to iDbType
91260>>>>>        // If a field/column already exists; we just ignore the request to not add unneccesary errors to the log.
91260>>>>>        Get _SqlFindColumnName sTableName sColumnName to sVal
91261>>>>>        If (Uppercase(sVal) = Uppercase(sColumnName)) Begin
91263>>>>>            Function_Return False
91264>>>>>        End
91264>>>>>>
91264>>>>>
91264>>>>>        Get DriverIndex sDriverID to iDriver
91265>>>>>        Get_Attribute DF_DRIVER_IGNORE_WARNINGS of iDriver to bDriverIgnoreErrorState
91268>>>>>        Set_Attribute DF_DRIVER_IGNORE_WARNINGS of iDriver to True
91271>>>>>
91271>>>>>        Get UtilColumnTypeToString sDriverID iDbType iDataType to sDataType
91272>>>>>        Move iLen to iLength
91273>>>>>        Move iDec to iDecimals                           
91274>>>>>        If (num_arguments > 6) Begin
91276>>>>>            Move bInitVal to bInitializeValue
91277>>>>>            Move sColVal  to sColumnValue
91278>>>>>        End
91278>>>>>>
91278>>>>>        
91278>>>>>        Get _SqlProperTableName sTableName   to sTableName
91279>>>>>        Get _SqlFindKeyWord CI_SQLAlterTable to sAlterTable
91280>>>>>        Get _SqlFindKeyWord CI_SQLAdd        to sAddColumn
91281>>>>>        Get SQLUtilDefaultNullValue sDriverID iDbType iDataType to sNotNull
91282>>>>>        
91282>>>>>        Get UtilColumnTypeFixed sDriverID iDbType iDataType to bFixed
91283>>>>>        If (bFixed = False) Begin
91285>>>>>            Get _SqlFormatLengthAndDecimalAsString iLength iDecimals to sLengthAndDecimals
91286>>>>>        End
91286>>>>>>
91286>>>>>        Move (sAlterTable * sTableName * sAddColumn * sColumnName * sDataType + sLengthAndDecimals * sNotNull) to sStmt 
91287>>>>>        
91287>>>>>        Move False to Err              
91288>>>>>        Send SqlUtilExecuteQuery sStmt sDriverID 
91289>>>>>        
91289>>>>>        If (bInitializeValue = True and Err = False) Begin
91291>>>>>            Get _SqlFindKeyWord CI_SQLUpdate       to sUpdate
91292>>>>>            Get _SqlFindKeyWord CI_SQLSet          to sSet
91293>>>>>            Get _SqlFindKeyWord CI_SQLSetNoCountOn to sNoCountOn
91294>>>>>            Move (sNoCountOn * sUpdate * sTableName * sSet * sColumnName + "='" + sColumnValue + "'") to sStmt
91295>>>>>            Send SqlUtilExecuteQuery sStmt sDriverID
91296>>>>>        End
91296>>>>>>
91296>>>>>
91296>>>>>        If (Err = False) Begin
91298>>>>>            Get SqlUtilAdjustAuxFiles hTable sTableName sColumnName to bOK
91299>>>>>        End
91299>>>>>>
91299>>>>>        
91299>>>>>        Move (not(Err)) to bRetval 
91300>>>>>        
91300>>>>>        // We also need to remove the cache-file since the table has been changed
91300>>>>>        Get UtilDeleteCacheFile sTableName to bOK
91301>>>>>        Set_Attribute DF_DRIVER_IGNORE_WARNINGS of iDriver to bDriverIgnoreErrorState
91304>>>>>    
91304>>>>>        Function_Return bRetval
91305>>>>>    End_Function  
91306>>>>>    
91306>>>>>    // The fourth & fifth arguments are optional, depending on the iDataType
91306>>>>>    // passed. For e.g. a DF_ASCII the iLen must be passed.                     // Optional: // Optional:  
91306>>>>>    Function SqlColumnChange Handle hTable String sColumnName Integer iDataType Integer iLen Integer iDec Returns Boolean
91308>>>>>        Integer iColumn iDbType iLength iDecimals
91308>>>>>        String sDriverID sStmt sAlterTable sAlterColumn sVal sDataType sRetval sLengthAndDecimals sTableName sNotNull
91308>>>>>        Boolean bExists bOK bFixed
91308>>>>>        
91308>>>>>        Get psDriverID to sDriverID
91309>>>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
91310>>>>>        If (bOK = False) Begin
91312>>>>>            Function_Return False
91313>>>>>        End
91313>>>>>>
91313>>>>>        
91313>>>>>        Get UtilTableHandleToString hTable to sTableName  
91314>>>>>        Get SqlColumnChangeByTableName sTableName sColumnName iDataType iLen iDec to bOK
91315>>>>>
91315>>>>>        Function_Return (Err = False)    
