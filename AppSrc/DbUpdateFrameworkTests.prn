82561>>>>>>>    //***
82561>>>>>>>    //*** Function: ExtractList
82561>>>>>>>    //*** Purpose : Extract the list from the out connect string.
82561>>>>>>>    //***
82561>>>>>>>
82561>>>>>>>    Function ExtractList String sOutConnStr Integer hoStore Returns Integer
82563>>>>>>>        Local String  sItem
82563>>>>>>>        Local Integer iStart
82563>>>>>>>        Local Integer iEnd
82563>>>>>>>
82563>>>>>>>        If (hoStore = 0) ;            Move Current_object To hoStore
82566>>>>>>>
82566>>>>>>>        Send Delete_Data To hoStore
82567>>>>>>>        Move (Pos("{", sOutConnStr)) To iStart
82568>>>>>>>        While (iStart > 0)
82572>>>>>>>            Move (Right(sOutConnStr, Length(sOutConnStr) - iStart)) To sOutConnStr
82573>>>>>>>            If (Left(sOutConnStr, 1) = "}") ;                Move 0 To iStart
82576>>>>>>>            Else Begin
82577>>>>>>>                Move (Pos(",", sOutConnStr)) To iStart
82578>>>>>>>                Move (Pos("}", sOutConnStr)) To iEnd
82579>>>>>>>                If ((iStart = 0) Or (iEnd < iStart)) ;                    Move iEnd To iStart
82582>>>>>>>
82582>>>>>>>                If (iStart > 0) ;                    Set Value Of hoStore Item (Item_Count(Current_Object)) To (Left(sOutConnStr, iStart - 1))
82585>>>>>>>
82585>>>>>>>                If (iStart = iEnd) ;                    Move 0 To iStart
82588>>>>>>>            End
82588>>>>>>>>
82588>>>>>>>        Loop
82589>>>>>>>>
82589>>>>>>>
82589>>>>>>>        Function_Return (Item_Count(hoStore))
82590>>>>>>>    End_Procedure // ExtractList
82591>>>>>>>
82591>>>>>>>
82591>>>>>>>
82591>>>>>>>    //***
82591>>>>>>>    //*** Function: BrowseConnect
82591>>>>>>>    //*** Purpose : Call the driver's browse connect function
82591>>>>>>>    //***
82591>>>>>>>
82591>>>>>>>    Function BrowseConnect String sInConnStr Returns String
82593>>>>>>>        Local String  sDriver
82593>>>>>>>        Local String  sOutConnStr
82593>>>>>>>        Local Integer iArg
82593>>>>>>>        Local Integer iRetval
82593>>>>>>>
82593>>>>>>>        Get psDriverID To sDriver
82594>>>>>>>        If (sDriver <> "") Begin
82596>>>>>>>            Move (Repeat(" ", 8192)) To sOutConnStr
82597>>>>>>>            Call_Driver 0 sDRiver Function CLI_BROWSECONNECT Callback 0 Passing sInConnStr sOutConnStr iArg Result iRetval
82602>>>>>>>        End
82602>>>>>>>>
82602>>>>>>>
82602>>>>>>>        Function_Return sOutConnStr
82603>>>>>>>    End_Function// BrowseConnect
82604>>>>>>>
82604>>>>>>>
82604>>>>>>>    Function BrowseConnectLocal String sInConnStr Returns String
82606>>>>>>>        Local String  sDriver
82606>>>>>>>        Local String  sOutConnStr
82606>>>>>>>        Local Integer iArg
82606>>>>>>>        Local Integer iRetval
82606>>>>>>>        
82606>>>>>>>        Move 1 to iArg // Browses only local
82607>>>>>>>
82607>>>>>>>        Get psDriverID to sDriver
82608>>>>>>>        If (sDriver <> "") Begin
82610>>>>>>>            Move (Repeat(" ", 8192)) to sOutConnStr
82611>>>>>>>            Call_Driver 0 sDRiver Function CLI_BROWSECONNECT Callback 0 Passing sInConnStr sOutConnStr iArg Result iRetval
82616>>>>>>>        End
82616>>>>>>>>
82616>>>>>>>
82616>>>>>>>        Function_Return sOutConnStr
82617>>>>>>>    End_Function// BrowseConnect
82618>>>>>>>
82618>>>>>>>
82618>>>>>>>    Function DriverIndex String sDriver Returns Integer
82620>>>>>>>    
82620>>>>>>>        Local String  sCurrentDriver
82620>>>>>>>        Local Integer iNumberOfDrivers iDriver iCount
82620>>>>>>>    
82620>>>>>>>        Move 0 to iDriver
82621>>>>>>>    
82621>>>>>>>        Get_Attribute DF_NUMBER_DRIVERS to iNumberOfDrivers
82624>>>>>>>        For iCount from 1 to iNumberOfDrivers
82630>>>>>>>>
82630>>>>>>>    
82630>>>>>>>            Get_Attribute DF_DRIVER_NAME of iCount to sCurrentDriver
82633>>>>>>>            If ( Uppercase(sCurrentDriver) = Uppercase(sDriver) ) Begin
82635>>>>>>>                Move iCount to iDriver
82636>>>>>>>            End
82636>>>>>>>>
82636>>>>>>>        Loop
82637>>>>>>>>
82637>>>>>>>    
82637>>>>>>>        Function_Return iDriver
82638>>>>>>>    
82638>>>>>>>    End_Function 
82639>>>>>>>
82639>>>>>>>    Function EnumerateServersNetworkOrLocal Integer iNetworkLocal  Returns Integer
82641>>>>>>>        
82641>>>>>>>        Local String  sServerList
82641>>>>>>>        Local Integer iNumServers
82641>>>>>>>        Local Integer iDriver
82641>>>>>>>        Local Integer iClientVersion
82641>>>>>>>        Local String  sDriver
82641>>>>>>>        
82641>>>>>>>        Get DriverIndex MSSQLDRV_ID to iDriver
82642>>>>>>>
82642>>>>>>>        If (iDriver) Begin
82644>>>>>>>                
82644>>>>>>>            Get_Attribute DF_DRIVER_SQLSERVER_CLIENT_VERSION of iDriver to iClientVersion
82647>>>>>>>            
82647>>>>>>>            Case Begin
82647>>>>>>>    
82647>>>>>>>                Case (iClientVersion = SQLSERVER2016CLIENT)
82649>>>>>>>                    Move SQLSERVER2016DRVRSTR to sDriver
82650>>>>>>>                    Case Break
82651>>>>>>>    
82651>>>>>>>                Case (iClientVersion = SQLSERVER2014CLIENT)
82654>>>>>>>                    Move SQLSERVER2014DRVRSTR to sDriver
82655>>>>>>>                    Case Break
82656>>>>>>>            
82656>>>>>>>                Case (iClientVersion = SQLSERVER2012CLIENT)
82659>>>>>>>                    Move SQLSERVER2012DRVRSTR to sDriver
82660>>>>>>>                    Case Break
82661>>>>>>>    
82661>>>>>>>                Case (iClientVersion = SQLSERVER2008CLIENT)
82664>>>>>>>                    Move SQLSERVER2008DRVRSTR to sDriver
82665>>>>>>>                    Case Break
82666>>>>>>>    
82666>>>>>>>                Case (iClientVersion = SQLSERVER2005CLIENT)
82669>>>>>>>                    Move SQLSERVER2005DRVRSTR to sDriver
82670>>>>>>>                    Case Break
82671>>>>>>>            
82671>>>>>>>                Case (iClientVersion = SQLSERVER2000CLIENT)
82674>>>>>>>                    Move SQLSERVER2000DRVRSTR to sDriver
82675>>>>>>>                    Case Break
82676>>>>>>>            
82676>>>>>>>                Case Else
82676>>>>>>>                    Move SQLSERVER2000DRVRSTR to sDriver
82677>>>>>>>            
82677>>>>>>>            Case End
82677>>>>>>>    
82677>>>>>>>            Move ("DRIVER={" + sDriver + "};") to sDriver
82678>>>>>>>            If (iNetworkLocal = 0) Begin
82680>>>>>>>                Get BrowseConnect sDriver to sServerList
82681>>>>>>>            End
82681>>>>>>>>
82681>>>>>>>            Else Begin
82682>>>>>>>                Get BrowseConnectLocal sDriver to sServerList
82683>>>>>>>            End
82683>>>>>>>>
82683>>>>>>>            Get ExtractList sServerList Current_object to iNumServers
82684>>>>>>>        End
82684>>>>>>>>
82684>>>>>>>        
82684>>>>>>>        Function_Return iNumServers
82685>>>>>>>        
82685>>>>>>>    End_Function
82686>>>>>>>
82686>>>>>>>    //***
82686>>>>>>>    //*** Procedure: EnumerateServers
82686>>>>>>>    //*** Purpose  : Enumerate the available SQL Server database servers
82686>>>>>>>    //***            This function will return all SQL Server instances on the network. 
82686>>>>>>>    //***            This may take a long time. 
82686>>>>>>>    //***            To enumerate only local SQL Server instances use EnumerateServersLocal 
82686>>>>>>>    Function EnumerateServers Returns Integer
82688>>>>>>>
82688>>>>>>>        Local Integer iNumServers
82688>>>>>>>        Local Integer iNetworkLocal
82688>>>>>>>        
82688>>>>>>>        Move 0 to iNetworkLocal // 0 = enumerate network servers
82689>>>>>>>        
82689>>>>>>>        Get EnumerateServersNetworkOrLocal iNetworkLocal to iNumServers
82690>>>>>>>        
82690>>>>>>>        Function_Return iNumServers
82691>>>>>>>        
82691>>>>>>>    End_Function
82692>>>>>>>
82692>>>>>>>
82692>>>>>>>    //***
82692>>>>>>>    //*** Procedure: EnumerateServersLocal
82692>>>>>>>    //*** Purpose  : Enumerate the available SQL Server database servers
82692>>>>>>>    //***            This function will return only return SQL Server instance on the local machine
82692>>>>>>>    //***            To enumerate all SQL Server instances in a network use EnumerateServers
82692>>>>>>>    Function EnumerateServersLocal Returns Integer
82694>>>>>>>
82694>>>>>>>        Local Integer iNumServers
82694>>>>>>>        Local Integer iNetworkLocal
82694>>>>>>>        
82694>>>>>>>        Move 1 to iNetworkLocal // 1 = enumerate local servers
82695>>>>>>>        
82695>>>>>>>        Get EnumerateServersNetworkOrLocal iNetworkLocal to iNumServers
82696>>>>>>>        
82696>>>>>>>        Function_Return iNumServers
82697>>>>>>>        
82697>>>>>>>    End_Function
82698>>>>>>>
82698>>>>>>>    
82698>>>>>>>
82698>>>>>>>    //***
82698>>>>>>>    //*** Function: EnumerateDatabases
82698>>>>>>>    //*** Purpose : Enumerate database in a given server.
82698>>>>>>>    //***
82698>>>>>>>
82698>>>>>>>    Function EnumerateDatabases String sServer String sUser String sPassWord Returns Integer
82700>>>>>>>        Local Integer hoSQL
82700>>>>>>>        Local String  sConnect
82700>>>>>>>        Local String  sDatabase
82700>>>>>>>        Local Integer hdbc
82700>>>>>>>        Local Integer hstmt
82700>>>>>>>        Local Integer iFetchResult
82700>>>>>>>
82700>>>>>>>        If (Num_Arguments < 3) ;            Move "" To sPassWord
82703>>>>>>>        If (Num_Arguments < 2) ;            Move "" To sUser
82706>>>>>>>
82706>>>>>>>        If (sUser <> "") ;            Move ("SERVER=" + Trim(sServer) + ";UID=" + Trim(sUser) + ";PWD=" + Trim(sPassword) + ";") To sConnect
82709>>>>>>>        Else ;            Move ("SERVER=" + Trim(sServer) + ";Trusted_Connection=yes") To sConnect
82711>>>>>>>
82711>>>>>>>        Object oEnumDBSQLmanager Is A cSQLHandleManager
82713>>>>>>>            Move Current_Object To hoSQL
82714>>>>>>>        End_Object // oEnumDBSQLManager
82715>>>>>>>
82715>>>>>>>        If (hoSQL <> 0) Begin
82717>>>>>>>            Get SQLConnect Of hoSQL "MSSQLDRV" sConnect To hdbc
82718>>>>>>>            If (hdbc <> 0) Begin
82720>>>>>>>                Get SQLOpen Of hdbc To hstmt
82721>>>>>>>                If (hstmt <> 0) Begin
82723>>>>>>>                    //*** We could do a direct select on the sysdatabases table but we use
82723>>>>>>>                    //*** the stored procedure sp_database instead. SQL Server recommends this
82723>>>>>>>                    //*** approach in case meta data might change, the stored procedure will
82723>>>>>>>                    //*** stay the same.
82723>>>>>>>                    Send SQLSetProcedureName To hstmt "sp_databases"
82724>>>>>>>                    Send SQLCall To hstmt
82725>>>>>>>                    Repeat
82725>>>>>>>>
82725>>>>>>>                        Get SQLFetch Of hstmt To iFetchResult
82726>>>>>>>                        If (iFetchResult <> 0) Begin
82728>>>>>>>                            Get SQLColumnValue Of hstmt 1 To sDatabase
82729>>>>>>>                            Set Value Item (Item_Count(Current_Object)) To sDatabase
82730>>>>>>>                        End
82730>>>>>>>>
82730>>>>>>>                    Until (iFetchResult = 0)
82732>>>>>>>
82732>>>>>>>                    Send SQLClose To hstmt
82733>>>>>>>                End
82733>>>>>>>>
82733>>>>>>>                Send SQLDisconnect To hdbc
82734>>>>>>>            End
82734>>>>>>>>
82734>>>>>>>        End
82734>>>>>>>>
82734>>>>>>>        Send Destroy_Object To hoSQL
82735>>>>>>>
82735>>>>>>>        Function_return (Item_Count(Current_Object))
82736>>>>>>>    End_Function // EnumerateDatabases
82737>>>>>>>
82737>>>>>>>
82737>>>>>>>    Function SqlServerClientVersionName Integer iClientVersion  Returns String
82739>>>>>>>        
82739>>>>>>>        Local String  sSqlServerClientVersionName
82739>>>>>>>        
82739>>>>>>>            
82739>>>>>>>        Case Begin
82739>>>>>>>
82739>>>>>>>            Case (iClientVersion = SQLSERVER2016CLIENT)
82741>>>>>>>                Move SQLSERVER2016CLIENTNAME to sSqlServerClientVersionName
82742>>>>>>>                Case Break
82743>>>>>>>
82743>>>>>>>            Case (iClientVersion = SQLSERVER2014CLIENT)
82746>>>>>>>                Move SQLSERVER2014CLIENTNAME to sSqlServerClientVersionName
82747>>>>>>>                Case Break
82748>>>>>>>        
82748>>>>>>>            Case (iClientVersion = SQLSERVER2012CLIENT)
82751>>>>>>>                Move SQLSERVER2012CLIENTNAME to sSqlServerClientVersionName
82752>>>>>>>                Case Break
82753>>>>>>>
82753>>>>>>>            Case (iClientVersion = SQLSERVER2008CLIENT)
82756>>>>>>>                Move SQLSERVER2008CLIENTNAME to sSqlServerClientVersionName
82757>>>>>>>                Case Break
82758>>>>>>>
82758>>>>>>>            Case (iClientVersion = SQLSERVER2005CLIENT)
82761>>>>>>>                Move SQLSERVER2005CLIENTNAME to sSqlServerClientVersionName
82762>>>>>>>                Case Break
82763>>>>>>>        
82763>>>>>>>            Case (iClientVersion = SQLSERVER2000CLIENT)
82766>>>>>>>                Move SQLSERVER2000CLIENTNAME to sSqlServerClientVersionName
82767>>>>>>>                Case Break
82768>>>>>>>        
82768>>>>>>>            Case Else
82768>>>>>>>                Move SQLSERVERUNKNOWNCLIENTNAME to sSqlServerClientVersionName
82769>>>>>>>        
82769>>>>>>>        Case End
82769>>>>>>>    
82769>>>>>>>        
82769>>>>>>>        Function_Return sSqlServerClientVersionName
82770>>>>>>>        
82770>>>>>>>    End_Function
82771>>>>>>>
82771>>>>>>>
82771>>>>>>>End_Class // cMSSQLHandler
