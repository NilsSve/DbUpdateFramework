94415>>>>>    // Removes the passed table name completely from disk, filelist (& Sql Server if an Sql-driver)
94415>>>>>    Function ApiTableRemove Handle hTable Returns Boolean
94417>>>>>        String sTableName sDriverID  
94417>>>>>        Boolean bOk     
94417>>>>>        String sDataPath
94417>>>>>        
94417>>>>>        Get AutoConnectionIDLogin to bOK
94418>>>>>        Move False to Err 
94419>>>>>        Get psDriverID to sDriverID
94420>>>>>        Get UtilTableHandleToString hTable sDriverID to sTableName
94421>>>>>        If (sTableName = "") Begin
94423>>>>>            Function_Return False
94424>>>>>        End                      
94424>>>>>>
94424>>>>>        
94424>>>>>        Send Ignore_Error of Error_Object_Id DFERR_CANT_DELETE_FILE
94425>>>>>        Delete_db sTableName 
94426>>>>>        Send Trap_Error of Error_Object_Id DFERR_CANT_DELETE_FILE 
94427>>>>>        
94427>>>>>        If (sDriverID <> DATAFLEX_ID) Begin
94429>>>>>            Get SqlTableRemoveByTableName sDriverID sTableName to bOk   
94430>>>>>            Get psDataPathFirstPart to sDataPath
94431>>>>>            Get vDeleteFile (sDataPath + sTableName + ".int") to bOk
94432>>>>>        End
94432>>>>>>
94432>>>>>        // Also remove table from filelist.cfg in case the physical file didn't exist.  
94432>>>>>        If (hTable <> 0) Begin
94434>>>>>            Set_Attribute DF_FILE_ROOT_NAME     of hTable to ""
94437>>>>>            Set_Attribute DF_FILE_DISPLAY_NAME  of hTable to ""
94440>>>>>            Set_Attribute DF_FILE_LOGICAL_NAME  of hTable to ""  
94443>>>>>        End
94443>>>>>>
94443>>>>>        
94443>>>>>        Function_Return (hTable <> 0)
94444>>>>>    End_Function
