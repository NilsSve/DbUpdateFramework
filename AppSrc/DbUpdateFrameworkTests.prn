81237>>>                    Send Insert CR_LF
81238>>>
81238>>>                    For i from 0 to (SizeOfArray(Constraints)-1)
81244>>>>
81244>>>                        If (iCurrentDDFile<>Constraints[i].iFile) Begin
81246>>>                            Send Insert CR_LF
81247>>>                            Move Constraints[i].iFile to iCurrentDDFile
81248>>>                            If (Constraints[i].iFile<>iMain) Begin
81250>>>                                Get Which_Data_Set of hoDD Constraints[i].iFile to hoDDOther
81251>>>                            End
81251>>>>
81251>>>                            Else Begin
81252>>>                                Move hoDD to hoDDOther
81253>>>                            End
81253>>>>
81253>>>                            Send Insert  ("Constraints from ")
81254>>>                            
81254>>>                            If (hoDDOther) Begin
81256>>>                                Send Insert  (Object_Label(hoDDOther))
81257>>>                            End
81257>>>>
81257>>>                            Else Begin
81258>>>                                // not sure this could ever happen
81258>>>                                Send Insert  ("unknown. No DDO for file "+String(Constraints[i].iFile))
81259>>>                            End
81259>>>>
81259>>>                            
81259>>>                            If (hoDD<>hoDDOther) Begin
81261>>>                                Send Insert " (inherited)"
81262>>>                            End
81262>>>>
81262>>>                            
81262>>>                            Send Insert CR_LF
81263>>>                        End
81263>>>>
81263>>>                        
81263>>>                        
81263>>>                        Send Insert ("  " +String(i+1) + " Type=")
81264>>>                        Case Begin
81264>>>                            Case (Constraints[i].eType=CONST_VALUE) Send Insert "CONST_VALUE"
81267>>>                            Case (Constraints[i].eType=CONST_CHILD) Send Insert "CONST_CHILD"
81271>>>                            Case (Constraints[i].eType=CONST_FIELD) Send Insert "CONST_FIELD"
81275>>>                            Case (Constraints[i].eType=CONST_EXP) Send Insert "CONST_EXP"
81279>>>                            Case (Constraints[i].eType=CONST_RELATES) Send Insert "CONST_RELATES"
81283>>>                        Case End
81283>>>                        
81283>>>                        If (Constraints[i].eType=CONST_VALUE or Constraints[i].eType=CONST_FIELD) Begin
81285>>>                            Send Insert " mode="
81286>>>                            Case Begin
81286>>>                                Case (Constraints[i].eMODE=CONST_LT) Send Insert "LT"
81289>>>                                Case (Constraints[i].eMODE=CONST_LE) Send Insert "LE"
81293>>>                                Case (Constraints[i].eMODE=CONST_EQ) Send Insert "EQ"
81297>>>                                Case (Constraints[i].eMODE=CONST_GE) Send Insert "GE"
81301>>>                                Case (Constraints[i].eMODE=CONST_GT) Send Insert "GT"
81305>>>                                Case (Constraints[i].eMODE=CONST_NE) Send Insert "NE"
81309>>>                                Case (Constraints[i].eMODE=CONST_Matches) Send Insert "matches"
81313>>>                                Case (Constraints[i].eMODE=CONST_Contains) Send Insert "contains"
81317>>>                                Case (Constraints[i].eMODE=CONST_MatchesJumpIn) Send Insert "matches_JumpIn"
81321>>>                            Case End
81321>>>                        End
81321>>>>
81321>>>                        If (Constraints[i].eType<>CONST_EXP) Begin
81323>>>                            Send Insert (" File.Field=" + String(Constraints[i].iFile))
81324>>>                            Send Insert ("."  + String(Constraints[i].iField))
81325>>>                            Send Insert (" (" + FormatFileFieldName(Self,Constraints[i].iFile,Constraints[i].iField)+")")
81326>>>                        End
81326>>>>
