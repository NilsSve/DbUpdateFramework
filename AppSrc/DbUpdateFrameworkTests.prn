85259>>>>>    // finds the target seed value in the updatecolumn. If we autoseed and there is a
85259>>>>>    // seed value (psSeedValue), attempt to find GE that value, else move to first row
85259>>>>>    // Suitable for augmentation
85259>>>>>    Procedure OnSeedData
85261>>>>>        Integer iUpdateColumn iSortColumn
85261>>>>>        Boolean bSeed bAuto
85261>>>>>        String sValue
85261>>>>>        Handle hoCol
85261>>>>>
85261>>>>>        Get piUpdateColumn to iUpdateColumn
85262>>>>>        Get psSeedValue to sValue
85263>>>>>        Get pbAutoSeed to bSeed
85264>>>>>        Get piSortColumn to iSortColumn
85265>>>>>        Get pbAutoOrdering to bAuto
85266>>>>>        // if not yet sorted and this is auto ordering we will
85266>>>>>        // sort the data for the search column. We do this to make the
85266>>>>>        // column search GE logic work properly. 
85266>>>>>        If (bSeed and bAuto and iUpdateColumn<>-1 and iSortColumn<>iUpdateColumn) Begin
85268>>>>>            Get ColumnObject iUpdateColumn to hoCol
85269>>>>>            Send SortGridByColumn hoCol False
85270>>>>>        End
85270>>>>>>
85270>>>>>
85270>>>>>        If (bSeed and sValue<>"" and iUpdateColumn<>-1) Begin
85272>>>>>            Send RequestFindColumnValue iUpdateColumn sValue True 0  
85273>>>>>        End
85273>>>>>>
85273>>>>>        Else Begin
85274>>>>>            Send MovetoFirstRow
85275>>>>>        End
85275>>>>>>
85275>>>>>
85275>>>>>    End_Function
