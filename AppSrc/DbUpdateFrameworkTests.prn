84985>>>>>
84985>>>>>    Procedure Set Version String sVersion
84987>>>>>        Handle hoVersionInfo
84987>>>>>        Boolean bIncluded
84987>>>>>        Integer iMajor iMinor iRelease iBuild
84987>>>>>        Date dCompileDate
84987>>>>>
84987>>>>>        If (sVersion = "") Begin
84989>>>>>            // This automatically shows the program version of the program, if available.
84989>>>>>            // It will be displayed as the second item in the edit object.
84989>>>>>            If (ghoApplication <> 0) Begin
84991>>>>>                Get phoVersionInfo of ghoApplication to hoVersionInfo
84992>>>>>                If (hoVersionInfo <> 0) Begin
84994>>>>>                    Get pbIncluded of hoVersionInfo to bIncluded
84995>>>>>                    If (bIncluded) Begin
84997>>>>>                        Get piVersionMajor of hoVersionInfo to iMajor
84998>>>>>                        Get piVersionMinor of hoVersionInfo to iMinor
84999>>>>>                        Get piVersionRelease of hoVersionInfo to iRelease
85000>>>>>                        Get piVersionBuild of hoVersionInfo to iBuild
85001>>>>>                        Move (SFormat (C_$VERSION + ": %1.%2.%3.%4", iMajor, iMinor, iRelease, iBuild)) to sVersion
85002>>>>>                    End
85002>>>>>>
85002>>>>>                End
85002>>>>>>
85002>>>>>            End
85002>>>>>>
85002>>>>>        End
85002>>>>>>
85002>>>>>
85002>>>>>        // Display the compiled date as the next row in the edit object, after the program version.
85002>>>>>        Get GetCompileDate to dCompileDate
85003>>>>>        If (sVersion <> "") Begin
85005>>>>>            Send Add_Lineln (sVersion + (Character(13)) + C_$Compile_Date * String(dCompileDate))
85006>>>>>        End
85006>>>>>>
85006>>>>>    End_Procedure
85007>>>>>
85007>>>>>    Function GetCompileDate Returns Date
85009>>>>>        Date dCompileDate
85009>>>>>        String sAppFilename sData sCompileDate
85009>>>>>        Integer iChannel iPos iDateFormat
85009>>>>>
85009>>>>>        // Get full path to the current running executable
85009>>>>>        Get GetApplicationFileName of ghoApplication to sAppFilename
85010>>>>>
85010>>>>>        //Read the current file  up to where the data we're interesting in is (this was hand calced and so could vary)
85010>>>>>        Get Seq_Open_Input_Channel ("binary:" * sAppFilename) to iChannel
85011>>>>>        Read_Block channel iChannel sData (8 * 1024)    // First 8K is .exe header skip it
85013>>>>>        Read_Block channel iChannel sData 75            // The compile information we're interested in
85015>>>>>        Send Seq_Close_Channel iChannel
85016>>>>>
85016>>>>>        // The data is padded with Character(0)s. Strip them out
85016>>>>>        Move (CString(sData)) to sData
85017>>>>>
85017>>>>>        // The compile date is after the first ", ", so string parsing is required
85017>>>>>        Move (Pos(", ", sData)) to iPos
85018>>>>>        Move (Mid(sData, 10, (iPos + 2) ))  to sCompileDate // In US format
85019>>>>>        // If the current date format is non US, we need to temporary
85019>>>>>        // change the format and then move the string to the date variable.
85019>>>>>        Get_Attribute DF_DATE_FORMAT        to iDateFormat
85022>>>>>        Set_Attribute DF_DATE_FORMAT        to DF_DATE_USA
85025>>>>>        Move (Date(sCompileDate))           to dCompileDate
85026>>>>>        Set_Attribute DF_DATE_FORMAT        to iDateFormat // Reset date format
85029>>>>>
85029>>>>>        Function_Return dCompileDate
85030>>>>>    End_Function
85031>>>>>
