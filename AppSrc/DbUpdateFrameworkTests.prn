89214>>>>>>>>>>>Class cDbUpdateORAFLEXDriver is a cDbUpdateGenericDatabaseDriver
89215>>>>>>>>>>>    Function DbLogin String sConnectionString String sServer String sDatabase Boolean bTrusted String sUserID String sPassword Returns Boolean
89217>>>>>>>>>>>        Boolean bLoginSuccessful
89217>>>>>>>>>>>        String sDriverID sErrorMsg
89217>>>>>>>>>>>        String sVal
89217>>>>>>>>>>>        Integer iPos
89217>>>>>>>>>>>
89217>>>>>>>>>>>        Get psDriverID to sDriverID
89218>>>>>>>>>>>        Move (Pos("/", sServer)) to iPos
89219>>>>>>>>>>>        If (iPos = 0) Begin
89221>>>>>>>>>>>            If (sDatabase <> "") Begin
89223>>>>>>>>>>>                Move (sServer + "/" + sDatabase) to sServer        
89224>>>>>>>>>>>            End
89224>>>>>>>>>>>>
89224>>>>>>>>>>>        End
89224>>>>>>>>>>>>
89224>>>>>>>>>>>        // For the Mertech driver, using the Err indicator is the sanctioned way
89224>>>>>>>>>>>        Move False to Err
89225>>>>>>>>>>>        // For Oracle I don't believe "Trusted" doesn't exist.
89225>>>>>>>>>>>        Login sServer sUserId sPassword sDriverID
89227>>>>>>>>>>>        
89227>>>>>>>>>>>        Move (not(Err)) to bLoginSuccessful
89228>>>>>>>>>>>        Function_Return bLoginSuccessful
89229>>>>>>>>>>>    End_Function
89230>>>>>>>>>>>End_Class
