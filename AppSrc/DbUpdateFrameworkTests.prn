83027>>>>>>>//=============================================================================
83027>>>>>>>/// @Name        DF_FILE_OEM_TRANSLATION
83027>>>>>>>/// @Description There are two sets of code pages used in windows, ANSI and
83027>>>>>>>/// OEM. ANSI is what is commonly used now, but some data still uses the OEM
83027>>>>>>>/// code pages. When migrating data, this attribute is used to determine whether
83027>>>>>>>/// the OEM data will be translated to ANSI during the migration. For example,
83027>>>>>>>/// migrating passwords with special characters may call for different code pages.
83027>>>>>>>/// Setting this attribute to true will convert the OEM data to ANSI, setting it
83027>>>>>>>/// to false will not.
83027>>>>>>>///
83027>>>>>>>/// @Assumptions
83027>>>>>>>/// @Status      Public
83027>>>>>>>/// @Drivers     All
83027>>>>>>>/// @VersionNote Last Revised: 2013-08-15 by Aaron Gulack
83027>>>>>>>/// @See
83027>>>>>>>/// @INTOPT
83027>>>>>>>///
83027>>>>>>>/// @Syntax Set_Attribute DF_FILE_OEM_TRANSLATION of {FileNumber} to {variable}
83027>>>>>>>/// @Syntax Get_Attribute DF_FILE_OEM_TRANSLATION of {FileNumber} to {variable}
83027>>>>>>>/// @Param  FileNumber            Number of the file
83027>>>>>>>/// @Param  variable              Indicates if OEM data will be converted to ANSI. True converts it, false does not.
83027>>>>>>>/// @Example
83027>>>>>>>/// open Customer
83027>>>>>>>///
83027>>>>>>>/// Handle hFile
83027>>>>>>>/// Boolean bTranslate
83027>>>>>>>///
83027>>>>>>>/// Move Customer.File_Number to hFile
83027>>>>>>>///
83027>>>>>>>/// Structure_Start hFile
83027>>>>>>>///     Set_Attribute DF_FILE_OEM_TRANSLATION of hFile to True
83027>>>>>>>///     Get_Attribute DF_FILE_OEM_TRANSLATION of hFile to bTranslate
83027>>>>>>>/// Structure_End hFile
83027>>>>>>>Define DF_FILE_OEM_TRANSLATION                      For (DF_FILE_RECORD_REREAD+51)
83027>>>>>>>
83027>>>>>>>//=============================================================================
83027>>>>>>>/// @Name        DF_FILE_EPOCH_YEAR
83027>>>>>>>/// @Description When dealing with two-digit years, an epoch year must be used
83027>>>>>>>/// to determine which century the date is referring to. For example if the
83027>>>>>>>/// epoch year is set to 30, then any two digit year greater than 30 will be
83027>>>>>>>/// considered in the 20th Century, anything less than or equal to 30 will be
83027>>>>>>>/// considered in the 21st Century.  This attribute is used to turn on or off
83027>>>>>>>/// this feature. To use this feature, set this attribute to whatever the epoch
83027>>>>>>>/// year is expected to be. To disable this feature, set this attribute to 0
83027>>>>>>>/// or false. Note that setting this attribute must be done at table creation
83027>>>>>>>/// or inside of a Structure_Start.
83027>>>>>>>///
83027>>>>>>>/// @Assumptions
83027>>>>>>>/// @Status      Public
83027>>>>>>>/// @Drivers     All
83027>>>>>>>/// @VersionNote Last Revised: 2013-08-15 by Aaron Gulack
83027>>>>>>>/// @See
83027>>>>>>>/// @INTOPT      EPOCH_YEAR
83027>>>>>>>///
83027>>>>>>>/// @Syntax Set_Attribute DF_FILE_EPOCH_YEAR of {FileNumber} to {variable}
83027>>>>>>>/// @Syntax Get_Attribute DF_FILE_EPOCH_YEAR of {FileNumber} to {variable}
83027>>>>>>>/// @Param  FileNumber            Number of the file
83027>>>>>>>/// @Param  variable              Indicates what the epoch year is. 0 to disable
83027>>>>>>>/// @Example
83027>>>>>>>/// open Customer
83027>>>>>>>///
83027>>>>>>>/// Handle hFile
83027>>>>>>>/// Boolean bEpoch
83027>>>>>>>///
83027>>>>>>>/// Move Customer.File_Number to hFile
83027>>>>>>>///
83027>>>>>>>/// Structure_Start hFile
83027>>>>>>>///     Set_Attribute DF_FILE_EPOCH_YEAR of hFile to 30
83027>>>>>>>///     Get_Attribute DF_FILE_EPOCH_YEAR of hFile to bEpoch
83027>>>>>>>/// Structure_End hFile
83027>>>>>>>Define DF_FILE_EPOCH_YEAR                           For (DF_FILE_RECORD_REREAD+53)
83027>>>>>>>
83027>>>>>>>Define DF_FILE_USE_ROWCOUNT_IN_TRANSACTIONS         For 628
83027>>>>>>>Define DF_FILE_ICF_STATUS                           For 630
