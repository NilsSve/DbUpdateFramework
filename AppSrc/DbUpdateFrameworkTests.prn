94461>>>>>    Function ApiTableRename Integer hTable String sRootName String sDisplayName String sLogicalName Returns Boolean
94463>>>>>        String sPhysicalName sDataPath sDriverID
94463>>>>>        Boolean bOK bExists
94463>>>>>        Integer iRetval
94463>>>>>        
94463>>>>>        Move False to Err
