84076>>>>>>>/// @Assumptions
84076>>>>>>>/// @Status      Public
84076>>>>>>>/// @Drivers     ORAFlex, PgFlex
84076>>>>>>>/// @VersionNote Last Revised: 2013-10-09 by Aaron Gulack
84076>>>>>>>/// @See                 SET_DEFAULT_TABLESPACE GET_DEFAULT_TABLESPACE SET_DEFAULT_INDEX_TABLESPACE
84076>>>>>>>///
84076>>>>>>>/// @Syntax GET_DEFAULT_INDEX_TABLESPACE to {variable}
84076>>>>>>>/// @Param variable                     Variable to hold the default index table space name.
84076>>>>>>>///
84076>>>>>>>/// @Example
84076>>>>>>>/// GET_DEFAULT_INDEX_TABLESPACE to sTableSpace
84076>>>>>>>
84076>>>>>>>//=============================================================================
84076>>>>>>>/// @Name        ENABLE_SCRIPTING
84076>>>>>>>/// @Description Scripting is used for testing and preparation. This
84076>>>>>>>/// command allows structural changes to be compiled and tested without
84076>>>>>>>/// actually making any of the changes. Any table restructuring done
84076>>>>>>>/// between this command and DISABLE_SCRIPTING will not actually be
84076>>>>>>>/// committed but will instead create a mock INT file. The script and
84076>>>>>>>/// INT file can then be retrieved and examined for testing purposes.
84076>>>>>>>///
84076>>>>>>>/// @Assumptions
84076>>>>>>>/// @Status      Public
84076>>>>>>>/// @Drivers     All
84076>>>>>>>/// @VersionNote Last Revised: 2013-10-09 by Aaron Gulack
84076>>>>>>>/// @See                 DISABLE_SCRIPTING GET_SQL_SCRIPT_CHUNK GET_INT_CHUNK
84076>>>>>>>///
84076>>>>>>>/// @Syntax ENABLE_SCRIPTING
84076>>>>>>>///
84076>>>>>>>/// @Example
84076>>>>>>>/// ENABLE_SCRIPTING
84076>>>>>>>///     //Table restructuring would go here
84076>>>>>>>/// DISABLE_SCRIPTING
84076>>>>>>>///
84076>>>>>>>/// GET_SQL_SCRIPT_CHUNK OFFSET 0 to sChunk sLength
84076>>>>>>>/// Showln sChunk
84076>>>>>>>
84076>>>>>>>//=============================================================================
84076>>>>>>>/// @Name        DISABLE_SCRIPTING
84076>>>>>>>/// @Description This command ends any scripting started by ENABLE_SCRIPTING.
84076>>>>>>>/// The mock INT file and script can then be retrieved and examined.
84076>>>>>>>///
84076>>>>>>>/// @Assumptions
84076>>>>>>>/// @Status      Public
84076>>>>>>>/// @Drivers     All
84076>>>>>>>/// @VersionNote Last Revised: 2010-12-13 By Marcelo Nachbar
84076>>>>>>>/// @See                 ENABLE_SCRIPTING  GET_SQL_SCRIPT_CHUNK GET_INT_CHUNK
84076>>>>>>>///
84076>>>>>>>/// @Syntax DISABLE_SCRIPTING
84076>>>>>>>///
84076>>>>>>>/// @Example
84076>>>>>>>/// ENABLE_SCRIPTING
84076>>>>>>>///     //Table restructuring would go here
84076>>>>>>>/// DISABLE_SCRIPTING
84076>>>>>>>///
84076>>>>>>>/// GET_SQL_SCRIPT_CHUNK OFFSET 0 to sChunk sLength
84076>>>>>>>/// Showln sChunk
84076>>>>>>>
84076>>>>>>>Function MertechInc_GET_RESTRUCTURE_SCRIPT Global Integer iLong Integer iOffset Returns String
84078>>>>>>>    Local Integer iChuck_Size
84078>>>>>>>    Local String sChunk
84078>>>>>>>
84078>>>>>>>    //Get current Chuck size and pre size string
84078>>>>>>>    Call_Driver 0 MertechInc_DriverName Function CALLDRV_CHUNK_SIZE CALLBACK 0 PASSING iChuck_Size MertechInc_Blank 1 RESULT MertechInc_iRet
84083>>>>>>>    Get MertechInc_Pre_Size_String iChuck_Size to sChunk
84084>>>>>>>
84084>>>>>>>    //Get data
84084>>>>>>>    Call_Driver 0 MertechInc_DriverName Function CALLDRV_RESTRUCTURE_SCRIPT CALLBACK 0 PASSING sChunk iOffset iLong RESULT MertechInc_iRet
84089>>>>>>>
84089>>>>>>>    // Replace insert a CR before any LF character
84089>>>>>>>    Move (Replaces(Character(10), sChunk, Character(13)+Character(10))) to sChunk
84090>>>>>>>
84090>>>>>>>    Function_Return sChunk
84091>>>>>>>End_Function
84092>>>>>>>
84092>>>>>>>
84092>>>>>>>//=============================================================================
84092>>>>>>>/// @Name        GET_SQL_SCRIPT_CHUNK
84092>>>>>>>/// @Description This command returns a chunk of the script generated
84092>>>>>>>/// from the restructuring done inside of ENABLE_SCRIPTING and
84092>>>>>>>/// DISABLE_SCRIPTING. Since some scripts can be very large, the script
84092>>>>>>>/// can be looped through, grabbing chunks at a time.
84092>>>>>>>///
84092>>>>>>>/// @Assumptions
84092>>>>>>>/// @Status      Public
84092>>>>>>>/// @Drivers     All
84092>>>>>>>/// @VersionNote Last Revised: 2013-10-09 by Aaron Gulack
84092>>>>>>>/// @See                 ENABLE_SCRIPTING DISABLE_SCRIPTING GET_INT_CHUNK
84092>>>>>>>///
84092>>>>>>>/// @Syntax GET_SQL_SCRIPT_CHUNK OFFSET {offset} to {variable} [{length}]
84092>>>>>>>/// @Param offset                       Specifies the offset to start at for the chunk
84092>>>>>>>/// @Param variable                     Variable to hold the chunk
84092>>>>>>>/// @Param length                       Length of chunk returned (optional)
84092>>>>>>>///
84092>>>>>>>/// @Example
84092>>>>>>>/// ENABLE_SCRIPTING
84092>>>>>>>///     //Table restructuring would go here
84092>>>>>>>/// DISABLE_SCRIPTING
84092>>>>>>>///
84092>>>>>>>/// GET_SQL_SCRIPT_CHUNK OFFSET 0 to sChunk sLength
84092>>>>>>>/// Showln sChunk
84092>>>>>>>
84092>>>>>>>//=============================================================================
84092>>>>>>>/// @Name        GET_INT_CHUNK
84092>>>>>>>/// @Description This command returns a chunk of the INT file generated
84092>>>>>>>/// from the restructuring done inside of ENABLE_SCRIPTING and
84092>>>>>>>/// DISABLE_SCRIPTING. Since some INT files can be very large, the file
84092>>>>>>>/// can be looped through, grabbing chunks at a time.
84092>>>>>>>///
84092>>>>>>>/// @Assumptions
84092>>>>>>>/// @Status      Public
84092>>>>>>>/// @Drivers     All
84092>>>>>>>/// @VersionNote Last Revised: 2013-10-09 by Aaron Gulack
84092>>>>>>>/// @See                 ENABLE_SCRIPTING DISABLE_SCRIPTING GET_SQL_SCRIPT_CHUNK
84092>>>>>>>///
84092>>>>>>>/// @Syntax GET_INT_CHUNK OFFSET {offset} to {variable} [{length}]
84092>>>>>>>/// @Param offset                       Specifies the offset to start at for the chunk
84092>>>>>>>/// @Param variable                     Variable to hold the chunk
84092>>>>>>>/// @Param length                       Length of chunk returned (optional)
84092>>>>>>>///
84092>>>>>>>/// @Example
84092>>>>>>>/// ENABLE_SCRIPTING
84092>>>>>>>///     //Table restructuring would go here
84092>>>>>>>/// DISABLE_SCRIPTING
84092>>>>>>>///
84092>>>>>>>/// GET_INT_CHUNK OFFSET 0 to sChunk sLength
84092>>>>>>>/// Showln sChunk
84092>>>>>>>
84092>>>>>>>//=============================================================================
84092>>>>>>>/// @Name        REPORT_STMT
84092>>>>>>>/// @Description This command is an alternative to DataFlex's "Report"
84092>>>>>>>/// command. This allows embedded SQL to be used to fetch data instead of
84092>>>>>>>/// standard table queries.. All of the finds, for example, normally found
84092>>>>>>>/// in "Report" are replaced by SQL_FETCH_NEXT_ROW.
84092>>>>>>>///
84092>>>>>>>/// @Assumptions
84092>>>>>>>/// @Status      Public
84092>>>>>>>/// @Drivers     n/a
84092>>>>>>>/// @VersionNote Last Revised: 2013-10-09 by Aaron Gulack
84092>>>>>>>/// @See
84092>>>>>>>///
84092>>>>>>>/// @Syntax See DataFlex / Visual DataFlex documentation
84092>>>>>>>///
84092>>>>>>>/// @Example
84092>>>>>>>/// /Header
84092>>>>>>>/// __/__/____                                                        Page ___.
84092>>>>>>>///                 MERTECH DATA SYSTEMS, INC. - NOT FOR RESALE
84092>>>>>>>///
84092>>>>>>>/// ID   NAME
84092>>>>>>>///
84092>>>>>>>/// /Body
84092>>>>>>>/// ____ _________________________
84092>>>>>>>/// /Total
84092>>>>>>>/// Records printed = _______.
84092>>>>>>>/// /*
84092>>>>>>>///
84092>>>>>>>///
84092>>>>>>>/// OPEN SALESP
84092>>>>>>>/// direct_output "con:"
84092>>>>>>>/// // Write the complete SELECT statement to retrieve the expected records from your REPORT
84092>>>>>>>/// // Must include the expression to qualify the required records and specify the order by as well
84092>>>>>>>///
84092>>>>>>>/// sql_set_stmt of salesp to "select recnum, id, name from SALESP where recnum > 5 order by id"
84092>>>>>>>/// sql_prepare_stmt of salesp
84092>>>>>>>/// sql_bindcolumns_stmt of salesp to salesp.recnum salesp.id salesp.name
84092>>>>>>>/// sql_execute_stmt of salesp
84092>>>>>>>///
84092>>>>>>>/// Report_stmt SALESP By Index.1
84092>>>>>>>///
84092>>>>>>>/// Section Header
84092>>>>>>>///     Sysdate Header.1
84092>>>>>>>///     Move PageCount to Header.2
84092>>>>>>>///     output header
84092>>>>>>>///
84092>>>>>>>/// Section Body
84092>>>>>>>///     Print Salesp.id   to Body.1
84092>>>>>>>///     Print Salesp.name to Body.2
84092>>>>>>>///     output body
84092>>>>>>>/// Section Total
84092>>>>>>>///
84092>>>>>>>/// Return
84092>>>>>>>/// ReportEnd
84092>>>>>>>
84092>>>>>>>//=============================================================================
84092>>>>>>>/// @Name        GET_SERVER_CFG
84092>>>>>>>/// @Description This command, when passed a valid server name, returns
84092>>>>>>>/// the a value for the specified attribute. See the list below for an
84092>>>>>>>/// explanation of each attribute.
84092>>>>>>>///
84092>>>>>>>/// SERVER_REVISION    Returns the major version, to the left of the decimal, of the server
84092>>>>>>>/// SUPPORT_DESC       Returns 1 if Server supports descending index segments
84092>>>>>>>/// SUPPORT_CASE       Returns 1 if Server supports case insensitive index segments
84092>>>>>>>/// SERVER_VERSION     Returns the full version of the server
84092>>>>>>>/// SERVER_ENCODING    Returns the Server Encoding
84092>>>>>>>/// CONNECTION_ACTIVE  Returns 1 if the connection to the server is active
84092>>>>>>>/// CITEXT_SUPPORT     Returns 1 if Server supports citext, a PostgreSQL data type
84092>>>>>>>///
84092>>>>>>>/// @Assumptions
84092>>>>>>>/// @Status      Internal
84092>>>>>>>/// @Drivers     All
84092>>>>>>>/// @VersionNote Last Revised: 2013-10-02 by Aaron Gulack
84092>>>>>>>/// @See
84092>>>>>>>///
84092>>>>>>>/// @Syntax GET_SERVER_CFG {constant} of {server} to {variable}
84092>>>>>>>/// @Param constant                     SERVER_REVISION,SERVER_MIN_REVISION,SUPPORT_DESC,SUPPORT_CASE,SERVER_VERSION,SERVER_ENCODING,CONNECTION_ACTIVE
84092>>>>>>>/// @Param server                       Name of the server being checked
84092>>>>>>>/// @Param variable                     Variable to hold the returned value
84092>>>>>>>///
84092>>>>>>>/// @Example
84092>>>>>>>/// GET_SERVER_CFG SERVER_VERSION of "localhost" to sVersion
84092>>>>>>>
84092>>>>>>>Function MertechInc_GET_SERVER_CFG Global String sServer Integer iAttribute Returns String
84094>>>>>>>    Local String sReturnValue
84094>>>>>>>
84094>>>>>>>    Get MertechInc_Pre_Size_String 512 to sReturnValue
84095>>>>>>>
84095>>>>>>>    Call_Driver 0 MertechInc_DriverName Function CALLDRV_GET_SERVER_CFG CALLBACK 0 PASSING sServer sReturnValue iAttribute RESULT MertechInc_iRet
84100>>>>>>>
84100>>>>>>>    //If iAttribute = SERVER_VERSION or SERVER_ENCODING then return sReturnValue
84100>>>>>>>    //else we need to return MertechInc_iRet
84100>>>>>>>    If ((iAttribute = 4) or (iAttribute = 5)) Function_Return sReturnValue
84103>>>>>>>    Else                                      Function_Return MertechInc_iRet
84105>>>>>>>End_Function
84106>>>>>>>
