83027>>>>>>>/// @INTOPT SERVER_NAME {string}
83027>>>>>>>///
83027>>>>>>>/// @Syntax Get_Attribute DF_FILE_SERVER_NAME of {FileNumber} to {variable}
83027>>>>>>>/// @Syntax Set_Attribute DF_FILE_SERVER_NAME of {FileNumber} to {variable}
