84766>>>>>        Send Show_Current_Directory
84767>>>>>
84767>>>>>        // This is already shown in the workspace details,
84767>>>>>        // unless no workspace object is present:
84767>>>>>        If (ghoApplication = 0) Begin
84769>>>>>            Send Show_Filelist_Name
84770>>>>>        End
84770>>>>>>
84770>>>>>
84770>>>>>        If (ghoApplication <> 0) Begin
84772>>>>>            Send AppendTextLn ""
84773>>>>>            Send Show_EnterAsTab
84774>>>>>        End
84774>>>>>>
84774>>>>>
