95623>>>>>                Move (SQLFLEX + ":\\" + SQLConnection.sServer + "\" + SQLConnection.sDatabase + SQLConnection.sSchema + "*" + sTableNameOrg) to sTableName
95624>>>>>                // If not df_exclusive mode, we use the "Open As" syntax.
