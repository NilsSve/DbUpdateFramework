81497>>>                        Move (If(Validate_Field(hDD,iItem),"N","Y")) to sFrnVld
81498>>>                        //              Print (Item_Entry_MSG(hRB, iItem))
81498>>>                        //              Print (Item_Exit_MSG(hRB, iItem))
81498>>>                        //              Print (Item_Validate_MSG(hRB, iItem))
81498>>>                        Move (Field_Current_Value(hDD, iItem)) to sVal
81499>>>                        Move (sFormat("%1 %2   %3   %4     %5", sFieldName, sChanged, sVld, sFrnVld, sVal)) to sLine
81500>>>                        Send Insert sLine
81501>>>                        Send Insert CR_LF
81502>>>                    Loop
