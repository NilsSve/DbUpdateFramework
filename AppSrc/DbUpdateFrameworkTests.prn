84464>>>>>    Procedure Show_Date_Format
84466>>>>>        Integer iDateFormat
84466>>>>>        String sDateFormat
84466>>>>>
84466>>>>>        Get_Attribute DF_DATE_FORMAT to iDateFormat
84469>>>>>        Case Begin
84469>>>>>            Case (iDateFormat = DF_DATE_USA)
84471>>>>>                Move C_$USA To sDateFormat
84472>>>>>                Case Break
84473>>>>>            Case (iDateFormat = DF_DATE_EUROPEAN)
84476>>>>>                Move C_$European To sDateFormat
84477>>>>>                Case Break
84478>>>>>            Case (iDateFormat = DF_DATE_MILITARY)
84481>>>>>                Move C_$Military To sDateFormat
84482>>>>>                Case Break
84483>>>>>            Case Else
84483>>>>>                Move C_$UnknownDateType To sDateFormat
84484>>>>>                Case Break
84485>>>>>        Case End
84485>>>>>
84485>>>>>        Send AppendTextLn (SFormat (C_$DateFormat, sDateformat))
84486>>>>>    End_Procedure
84487>>>>>
84487>>>>>    // 2013-08-14 NGS
84487>>>>>    // Unformatted numeric values shown doesn't look good. These looks much better.
84487>>>>>    Procedure Show_Systemresources
84489>>>>>        tWinMemoryStatusEx MemoryStatusInfo
84489>>>>>        tWinMemoryStatusEx MemoryStatusInfo
84489>>>>>        Integer iRetval
84489>>>>>        Number nValue
84489>>>>>        String sValue
84489>>>>>
84489>>>>>        Move (SizeOfType (tWinMemoryStatusEx)) to MemoryStatusInfo.dwLength
84490>>>>>        Move (GlobalMemoryStatusEx (AddressOf (MemoryStatusInfo))) to iRetval
84491>>>>>        If (iRetval = 0) Begin
84493>>>>>            Move (ShowLastError ()) to iRetval
84494>>>>>            Procedure_Return
84495>>>>>        End
84495>>>>>>
84495>>>>>
84495>>>>>        Send AppendTextLn ""
84496>>>>>        Move MemoryStatusInfo.ullTotalPhys to nValue
84497>>>>>
84497>>>>>        // Show memory in Gigabytes:
84497>>>>>        Move (nValue/1024/1024/1024) to nValue
84498>>>>>        Move (Round(nValue)) to nValue
84499>>>>>        Get FormatNumber nValue 2 to sValue
84500>>>>>        Send AppendTextLn (SFormat (C_$AvailableMemory, (sValue * "GB")))
84501>>>>>        Send AppendTextLn (SFormat (C_$MemoryUtilization, String(MemoryStatusInfo.dwMemoryLoad) * "%"))
84502>>>>>
84502>>>>>//        Send AppendTextLn (SFormat (C_$AvailablePhysicalMemory, Real (MemoryStatusInfo.ullAvailPhys) / Real (MemoryStatusInfo.ullTotalPhys) * 100.0))
84502>>>>>        Move (Real(MemoryStatusInfo.ullAvailPhys) / Real(MemoryStatusInfo.ullTotalPhys) * 100.0) to nValue
84503>>>>>        Move (Round(nValue)) to nValue
84504>>>>>        Get FormatNumber nValue 0 to sValue
84505>>>>>        Send AppendTextLn (SFormat (C_$AvailablePhysicalMemory, (sValue * "%")))
84506>>>>>
84506>>>>>//        Send AppendTextLn (SFormat (C_$AvailablePagefileSpace, Real (MemoryStatusInfo.ullAvailPageFile) / Real (MemoryStatusInfo.ullTotalPageFile) * 100.0))
84506>>>>>        Move (Real(MemoryStatusInfo.ullAvailPageFile) / Real(MemoryStatusInfo.ullTotalPageFile) * 100.0) to nValue
84507>>>>>        Move (Round(nValue)) to nValue
84508>>>>>        Get FormatNumber nValue 0 to sValue
84509>>>>>        Send AppendTextLn (SFormat (C_$AvailablePagefileSpace, (sValue * "%")))
84510>>>>>
84510>>>>>//        Send AppendTextLn (SFormat (C_$AvailableVirtualMemory, Real (MemoryStatusInfo.ullAvailVirtual) / Real (MemoryStatusInfo.ullTotalVirtual) * 100.0))
84510>>>>>        Move (Real(MemoryStatusInfo.ullAvailVirtual) / Real(MemoryStatusInfo.ullTotalVirtual) * 100.0) to nValue
84511>>>>>        Move (Round(nValue)) to nValue
84512>>>>>        Get FormatNumber nValue 0 to sValue
84513>>>>>        Send AppendTextLn (SFormat (C_$AvailableVirtualMemory, (sValue * "%")))
84514>>>>>
84514>>>>>        // Add an empty row after the memory information:
84514>>>>>        Send AppendTextLn ""
84515>>>>>    End_Procedure
