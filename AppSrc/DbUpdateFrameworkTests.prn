95565>>>>>        Move SQLConnection.sConnectionString to sConnection
95566>>>>>        Move SQLConnection.sSchema to sSchema
95567>>>>>        If (sSchema = "") Begin 
95569>>>>>            Get _SqlFindKeyWord CI_SQLDBO to sSchema 
95570>>>>>        End
95570>>>>>>
95570>>>>>
95570>>>>>        // We need to remove the ".int" part of the table name because
95570>>>>>        // the table name after the "#" in the connection syntax below wants the
95570>>>>>        // "bare" table name without any extension.
95570>>>>>        If (sDriverID <> DATAFLEX_ID) Begin
95572>>>>>            If (Lowercase(sTableName) contains ".int") Begin
95574>>>>>                Get ParseFileExtension sTableName to sExt
95575>>>>>                Move (Replace(("." + sExt), sTableName, "")) to sTableNameShort
95576>>>>>            End                                                                
95576>>>>>>
95576>>>>>            Else Begin
95577>>>>>                Move sTableName to sTableNameShort  
95578>>>>>                Move (Append(sTableName, ".int")) to sTableName
95579>>>>>            End   
95579>>>>>>
95579>>>>>            If (bMertechDriver = False) Begin
95581>>>>>                Move (sDriverID + ":" + sSchema + "#" + sTableNameShort + "@" + sConnection + "|options|intfile=" + sTableName) to sConnection
95582>>>>>                Move sConnection to sTableName
95583>>>>>            End
95583>>>>>>
95583>>>>>        End
95583>>>>>>
95583>>>>>
95583>>>>>        Send Ignore_Error of Error_Object_Id CLIERR_LOGIN_UNSUCCESSFUL
95584>>>>>        Send Ignore_Error of Error_Info_Object DFERR_FILE_ACCESS_VIOLATION 
95585>>>>>        If (hTable = 0) Begin
95587>>>>>            Get NextFreeFilelistSlot to hTable
95588>>>>>        End
95588>>>>>>
95588>>>>>
95588>>>>>        Case Begin
95588>>>>>            Case (sDriverID = MSSQLDRV_ID)
95590>>>>>                // If not df_exclusive mode, we use the "Open As" syntax.
95590>>>>>                If (iMode <> DF_EXCLUSIVE) Begin
95592>>>>>                    Open sTableName as hTable
95594>>>>>                End
95594>>>>>>
95594>>>>>                Else Begin
95595>>>>>                    Open hTable mode DF_Exclusive
95597>>>>>                End
95597>>>>>>
95597>>>>>                Case Break
95598>>>>>
95598>>>>>            Case (sDriverID = DB2_DRV_ID)
95601>>>>>                // If not df_exclusive mode, we use the "Open As" syntax.
