98162>>>>>>>        Move (hi(abs(wParam))) to iDelta           // number of click units
98163>>>>>>>        If (wParam<0) Begin
98165>>>>>>>            Move (-iDelta) to iDelta     // can be up or down
98166>>>>>>>        End
98166>>>>>>>>
98166>>>>>>>        Get  piWheelDelta to iWheelDelta           // Current accumulated micro clicks
98167>>>>>>>        Move (iWheelDelta+iDelta) to iWheelDelta
98168>>>>>>>        // C_WHEELDATA is 120 as defined by MS as the delta to react to. Once click is usually 120
98168>>>>>>>        Move (iWheelDelta/C_WHEELDELTA) to iClicks // Number of clicks to react to
98169>>>>>>>        Set  piWheelDelta to (mod(iWheelDelta,C_WHEELDELTA)) // remainder unused microclicks
98170>>>>>>>        // If we have enough Clicks send OnMouseWheel
98170>>>>>>>        If (iClicks<>0) Begin
98172>>>>>>>            Send OnMouseWheel iClicks iKeys
98173>>>>>>>        End
98173>>>>>>>>
98173>>>>>>>        // tell windows that we've handled the event.    
98173>>>>>>>        Set Windows_Override_State to True    
98174>>>>>>>    End_Procedure
98175>>>>>>>
98175>>>>>>>
98175>>>>>>>    // should be sent by DF message OnWMMouseWheel , which is sent by WM_MOUSEWHEEL
98175>>>>>>>    Procedure OnMouseWheel Integer iClicks Integer iKey
98177>>>>>>>        Integer iLineScrollUnit
98177>>>>>>>        Get piLineScrollUnit to iLineScrollUnit
98178>>>>>>>        Send VScroll (-iClicks*iLineScrollUnit*2) // (If(iClicks>0,False,True)) (abs(iClicks))
98179>>>>>>>    End_Procedure
98180>>>>>>>
98180>>>>>>>    // should be sent by WM_VSCROLL
98180>>>>>>>    Procedure SetVScrollbox Integer iType Integer iNewPos
98182>>>>>>>        Boolean bOk
98182>>>>>>>        tWinScrollInfo ScrollInfo
98182>>>>>>>        tWinScrollInfo ScrollInfo
98182>>>>>>>        Integer iLineScrollUnit
98182>>>>>>>        Get piLineScrollUnit to iLineScrollUnit
98183>>>>>>>        Get GetScrollBarInfo True (&ScrollInfo) to bOk
98184>>>>>>>        If bOk Begin 
98186>>>>>>>            
98186>>>>>>>            Case Begin
98186>>>>>>>                Case (iType=SB_PAGEDOWN) 
98188>>>>>>>                    Send VScroll ScrollInfo.nPage
98189>>>>>>>                    Case Break
98190>>>>>>>                    
98190>>>>>>>                Case (iType=SB_PAGEUP) 
98193>>>>>>>                    Send VScroll (-ScrollInfo.nPage)
98194>>>>>>>                    Case Break
98195>>>>>>>                    
98195>>>>>>>                Case (iType=SB_LINEDOWN) 
98198>>>>>>>                    Send VScroll iLineScrollUnit
98199>>>>>>>                    Case Break
98200>>>>>>>                    
98200>>>>>>>                Case (iType=SB_LINEUP) 
98203>>>>>>>                    Send VScroll (-iLineScrollUnit)
98204>>>>>>>                    Case Break
98205>>>>>>>    
98205>>>>>>>                Case (iType=SB_BOTTOM) 
98208>>>>>>>                    Send VScroll (ScrollInfo.nMax-ScrollInfo.nPos)
98209>>>>>>>                    Case Break
98210>>>>>>>    
98210>>>>>>>                Case (iType=SB_Top) 
98213>>>>>>>                    Send VScroll (-ScrollInfo.nPos)
98214>>>>>>>                    Case Break
98215>>>>>>>                    
98215>>>>>>>                Case (iType=SB_THUMBPOSITION) 
98218>>>>>>>                    Case Break
98219>>>>>>>    
98219>>>>>>>                Case (iType=SB_THUMBTRACK) 
98222>>>>>>>                    Send VScroll (ScrollInfo.nTrackPos-ScrollInfo.nPos)
98223>>>>>>>                    Case Break
98224>>>>>>>            Case End
98224>>>>>>>        End
98224>>>>>>>>
98224>>>>>>>    End_Procedure
98225>>>>>>>    
98225>>>>>>>    // should be sent by WM_HSCROLL
98225>>>>>>>    Procedure SetHScrollbox Integer iType Integer iNewPos
98227>>>>>>>        Boolean bOk
98227>>>>>>>        tWinScrollInfo ScrollInfo
98227>>>>>>>        tWinScrollInfo ScrollInfo
98227>>>>>>>        Integer iLineScrollUnit
98227>>>>>>>        Get piLineScrollUnit to iLineScrollUnit
98228>>>>>>>        Get GetScrollBarInfo False (&ScrollInfo) to bOk
98229>>>>>>>        If bOk Begin 
98231>>>>>>>            
98231>>>>>>>            Case Begin
98231>>>>>>>                Case (iType=SB_PAGEDOWN) 
98233>>>>>>>                    Send hScroll ScrollInfo.nPage
98234>>>>>>>                    Case Break
98235>>>>>>>                    
98235>>>>>>>                Case (iType=SB_PAGEUP) 
98238>>>>>>>                    Send hScroll (-ScrollInfo.nPage)
98239>>>>>>>                    Case Break
98240>>>>>>>                    
98240>>>>>>>                Case (iType=SB_LINEDOWN) 
98243>>>>>>>                    Send hScroll iLineScrollUnit
98244>>>>>>>                    Case Break
98245>>>>>>>                    
98245>>>>>>>                Case (iType=SB_LINEUP) 
98248>>>>>>>                    Send hScroll (-iLineScrollUnit)
98249>>>>>>>                    Case Break
98250>>>>>>>    
98250>>>>>>>                Case (iType=SB_BOTTOM) 
98253>>>>>>>                    Send hScroll (ScrollInfo.nMax-ScrollInfo.nPos)
98254>>>>>>>                    Case Break
98255>>>>>>>    
98255>>>>>>>                Case (iType=SB_Top) 
98258>>>>>>>                    Send hScroll (-ScrollInfo.nPos)
98259>>>>>>>                    Case Break
98260>>>>>>>                    
98260>>>>>>>                Case (iType=SB_THUMBPOSITION) 
98263>>>>>>>                    Case Break
98264>>>>>>>    
98264>>>>>>>                Case (iType=SB_THUMBTRACK) 
98267>>>>>>>                    Send hScroll (ScrollInfo.nTrackPos-ScrollInfo.nPos)
98268>>>>>>>                    Case Break
98269>>>>>>>            Case End
98269>>>>>>>        End
98269>>>>>>>>
98269>>>>>>>    End_Procedure
98270>>>>>>>    
98270>>>>>>>    
98270>>>>>>>    // this calls SetScrollInfo with proper info
98270>>>>>>>    Procedure SetScrollBarInfo Boolean bVert Integer iRangeMin Integer iRangeMax Integer iPageSize
98272>>>>>>>        tWinScrollInfo ScrollInfo
98272>>>>>>>        tWinScrollInfo ScrollInfo
98272>>>>>>>        Integer iVoid
98272>>>>>>>        Handle hWnd
98272>>>>>>>        Boolean bShow
98272>>>>>>>
98272>>>>>>>        Delegate Get Window_Handle to hWnd
98274>>>>>>>        If (hWnd <> 0) Begin        
98276>>>>>>>            Move (SizeOfType (tWinScrollInfo)) to ScrollInfo.cbSize
98277>>>>>>>             
98277>>>>>>>            Move (SIF_RANGE ior SIF_POS ior SIF_PAGE ) to ScrollInfo.fMask
98278>>>>>>>            Get pbShowDisabledScrollBar to bShow
98279>>>>>>>            If bShow Begin
98281>>>>>>>                Move (ScrollInfo.fMask ior SIF_DISABLENOSCROLL) to ScrollInfo.fMask
98282>>>>>>>            End
98282>>>>>>>>
98282>>>>>>>            Move iRangeMin to ScrollInfo.nMin
98283>>>>>>>            Move iRangeMax to ScrollInfo.nMax
98284>>>>>>>            Move iPageSize to ScrollInfo.nPage
98285>>>>>>>            Move 0 to ScrollInfo.nPos
98286>>>>>>>            Move (SetScrollInfo (hWnd, If(bVert,SB_VERT,SB_HORZ), AddressOf (ScrollInfo), True)) to iVoid
98287>>>>>>>
98287>>>>>>>        End
98287>>>>>>>>
98287>>>>>>>    End_Procedure // 
98288>>>>>>>    
98288>>>>>>>    // this wraps GetScrollInfo
98288>>>>>>>    Function GetScrollBarInfo Boolean bVert tWinScrollInfo ByRef ScrollInfo Returns Boolean
98290>>>>>>>        Boolean bOk
98290>>>>>>>        Handle hWnd
98290>>>>>>>
98290>>>>>>>        Delegate Get Window_Handle to hWnd
98292>>>>>>>        If (hWnd <> 0) Begin        
98294>>>>>>>            Move (SizeOfType (tWinScrollInfo)) to ScrollInfo.cbSize
98295>>>>>>>            Move (SIF_ALL) to ScrollInfo.fMask
98296>>>>>>>            Move (GetScrollInfo (hWnd, If(bVert,SB_VERT,SB_HORZ), AddressOf (ScrollInfo))) to bOk
98297>>>>>>>        End
98297>>>>>>>>
98297>>>>>>>        Function_Return bOk
98298>>>>>>>    End_Function
98299>>>>>>>
98299>>>>>>>    // this wraps SetScrollPos
98299>>>>>>>    Procedure SetScrollBarPosInfo Boolean bVert Integer iPos
98301>>>>>>>        Integer iVoid
98301>>>>>>>        Handle hWnd
98301>>>>>>>
98301>>>>>>>        Delegate Get Window_Handle to hWnd
98303>>>>>>>        If (hWnd <> 0) Begin        
98305>>>>>>>            Move (SetScrollPos(hWnd, If(bVert,SB_VERT,SB_HORZ), iPos, True)) to iVoid
98306>>>>>>>        End
98306>>>>>>>>
98306>>>>>>>    End_Procedure
98307>>>>>>>
98307>>>>>>>    // scrolling containers don't do anhcors. However, this gets called every time the parent's
98307>>>>>>>    // guiSize changes. We can use that to scroll or resize the scrolling client as needed.
98307>>>>>>>    Procedure DoapplyAnchors Integer Arg1 Integer Arg2
98309>>>>>>>         Send ScrollClientArea
98310>>>>>>>    End_Procedure
98311>>>>>>>
98311>>>>>>>    // augment to handle the scrolling area initialization.
98311>>>>>>>    Procedure Add_Focus Handle hoParent
98313>>>>>>>        Forward Send Add_Focus hoParent
98315>>>>>>>        // at this the scrolling container and client area should both be paged. 
98315>>>>>>>        // child objects ae also paged with initial anchors applied
98315>>>>>>>        Send CalculateAutoScrollMinimums
98316>>>>>>>    End_Procedure
98317>>>>>>>    
98317>>>>>>>    Procedure Page Integer iPage
98319>>>>>>>        Forward Send Page iPage
98321>>>>>>>        If iPage Begin
98323>>>>>>>            // at this the scrolling container and client area should both be paged
98323>>>>>>>            // but the child controls are not paged. We don't want scrollbars when
98323>>>>>>>            // the child items are paged (else they may get anchored oddly) 
98323>>>>>>>            // Prior to 19.0 these were set in Add_focus which meant that the child objects were
98323>>>>>>>            // already paged with scrollbars present. This would result in scrollbars appearing
98323>>>>>>>            // before they were really needed. This should be more accurate
98323>>>>>>>            Send SetScrollBarInfo True 0 0 0
98324>>>>>>>            Send SetScrollBarInfo False 0 0 0
98325>>>>>>>        End
98325>>>>>>>>
98325>>>>>>>    End_Procedure
98326>>>>>>>
98326>>>>>>>    // determine scrolling minimums and set the client area as required.
98326>>>>>>>    
98326>>>>>>>    Procedure CalculateAutoScrollMinimums
98328>>>>>>>        Integer iMinX iMinY iSiz iLoc iMargin
98328>>>>>>>        Integer iAutoMinX iAutoMinY
98328>>>>>>>        Boolean bAutoScroll
98328>>>>>>>        Handle hoNext hoFirst
98328>>>>>>>        
98328>>>>>>>        Get pbAutoScroll to bAutoScroll
98329>>>>>>>        Get piAutoScrollMinX to iAutoMinX
98330>>>>>>>        Get piAutoScrollMinY to iAutoMinY
98331>>>>>>>        Get DialogToGui iAutoMinY iAutoMinX to iSiz
98332>>>>>>>        Move (Hi(iSiz)) to iAutoMinY
98333>>>>>>>        Move (Low(iSiz)) to iAutoMinX
98334>>>>>>>        Set piMinimumHeight to iAutoMinY
98335>>>>>>>        Set piMinimumWidth to iAutoMinX
98336>>>>>>>        
98336>>>>>>>        If (bAutoScroll and (iAutoMinX=0 or iAutoMinY=0)) Begin
98338>>>>>>>        
98338>>>>>>>            Get Next_Level to hoFirst
98339>>>>>>>            Move hoFirst to hoNext
98340>>>>>>>            If (hoFirst) Begin
98342>>>>>>>                Repeat
98342>>>>>>>>
98342>>>>>>>                    Get GuiWindowSize of hoNext to iSiz
98343>>>>>>>                    Get GuiLocation of hoNext to iLoc
98344>>>>>>>                    Move (Hi(iLoc)+Hi(iSiz) max iMinY) to iMinY
98345>>>>>>>                    Move (Low(iLoc)+Low(iSiz) max iMinX) to iMinx
98346>>>>>>>                    Get Next_Focus of hoNext to hoNext
98347>>>>>>>                Until (hoNext=0 or hoNext=hoFirst)
98349>>>>>>>
98349>>>>>>>                If (iAutoMinY=0) Begin
98351>>>>>>>                    Get piAutoScrollMarginY to iMargin
98352>>>>>>>                    Set piMinimumHeight to (iMinY+iMargin)
98353>>>>>>>                End
98353>>>>>>>>
98353>>>>>>>
98353>>>>>>>                If (iAutoMinX=0) Begin
98355>>>>>>>                    Get piAutoScrollMarginX to iMargin
98356>>>>>>>                    Set piMinimumWidth to (iMinX+iMargin)
98357>>>>>>>
98357>>>>>>>                End
98357>>>>>>>>
98357>>>>>>>            End
98357>>>>>>>>
98357>>>>>>>        End
98357>>>>>>>>
98357>>>>>>>        
98357>>>>>>>        // before setting the client area, unset all anchors so DoApplyAnchors will not do anything
98357>>>>>>>        Broadcast Set pbAnchorCreated to False
98359>>>>>>>        Send ScrollClientArea
98360>>>>>>>        // after the scroll set up, reinitialize all anchors.
98360>>>>>>>        Broadcast Send DoCreateAnchors
98362>>>>>>>    End_Procedure
98363>>>>>>>    
98363>>>>>>>    // Scroll the client area and adjust the client area size as needed. This does all the
98363>>>>>>>    // work of scrolling.
98363>>>>>>>    
98363>>>>>>>    Procedure ScrollClientArea
98365>>>>>>>        Integer iSiz
98365>>>>>>>        Integer iHeight iHCur iHCuriDelta iOrig iRange bOk
98365>>>>>>>        Integer iWidth iWCur iWDelta iWOrig
98365>>>>>>>        Integer iSzY iSzX iLocX iLocY
98365>>>>>>>        
98365>>>>>>>        Delegate Get GuiClientSize to iSiz
98367>>>>>>>        Move (Hi(iSiz)) to iHeight
98368>>>>>>>        Move (Low(iSiz)) to iWidth
98369>>>>>>>
98369>>>>>>>        // Vertical scrolling
98369>>>>>>>        
98369>>>>>>>        Get piMinimumHeight to iOrig
98370>>>>>>>        Get piMinimumWidth to iWOrig
98371>>>>>>>        
98371>>>>>>>        If (iOrig<>0 or iWOrig<>0) Begin
98373>>>>>>>        
98373>>>>>>>            If (iOrig<>0) Begin
98375>>>>>>>                Get piCurrentVertScrolled to iHCur
98376>>>>>>>                // If the size got bigger and we've scrolled, we want to scroll up        
98376>>>>>>>                If (iHCur<>0 and (iHCur+iHeight>iOrig)) Begin
98378>>>>>>>                    Move (iOrig-iHeight max 0) to iHCur
98379>>>>>>>                    Set piCurrentVertScrolled to iHCur
98380>>>>>>>                End
98380>>>>>>>>
98380>>>>>>>                If (iHCur<>0 or iOrig>iHeight) Begin
98382>>>>>>>                    Send SetScrollBarInfo True 0 iOrig (iHeight min iOrig)
98383>>>>>>>                    Send SetScrollBarPosInfo True iHCur 
98384>>>>>>>                End
98384>>>>>>>>
98384>>>>>>>                Else Begin
98385>>>>>>>                    Send SetScrollBarInfo True 0 0 0 //iOrig (iHeight min iOrig)
98386>>>>>>>                End
98386>>>>>>>>
98386>>>>>>>            End
98386>>>>>>>>
98386>>>>>>>                
98386>>>>>>>            // Horiz scrolling
98386>>>>>>>            
98386>>>>>>>            Get piCurrentHorzScrolled to iWCur
98387>>>>>>>    //        If (iWCur<>0) Begin
98387>>>>>>>                // If the size got bigger and we've scrolled, we want to scroll left        
98387>>>>>>>                If (iWCur<>0 and (iWCur+iWidth>iWOrig)) Begin
98389>>>>>>>                    Move (iWOrig-iWidth max 0) to iWCur
98390>>>>>>>                    Set piCurrentHorzScrolled to iWCur
98391>>>>>>>                End
98391>>>>>>>>
98391>>>>>>>                If (iWCur<>0 or iWOrig>iWidth) Begin
98393>>>>>>>                    Send SetScrollBarInfo False 0 iWOrig (iWidth min iWOrig)
98394>>>>>>>                    Send SetScrollBarPosInfo False iWCur 
98395>>>>>>>                End
98395>>>>>>>>
98395>>>>>>>                Else Begin
98396>>>>>>>                    Send SetScrollBarInfo False 0 0 0 
98397>>>>>>>                End
98397>>>>>>>>
98397>>>>>>>    //        End
98397>>>>>>>        End
98397>>>>>>>>
98397>>>>>>>        
98397>>>>>>>        // this could change depending on scrollbars appearing or not    
98397>>>>>>>        Delegate Get GuiClientSize to iSiz
98399>>>>>>>        
98399>>>>>>>        // size of container is the the minimum allowed size (if scrolling is needed)
98399>>>>>>>        // or it is the actual size of the container (if scrolling not needed and it is bigger)
98399>>>>>>>        // This is required to make anchors work sensibly 
98399>>>>>>>        Move (hi(iSiz) max iOrig) to iSzY
98400>>>>>>>        Move (low(iSiz) max iWOrig) to iSzX
98401>>>>>>>        Move (-iHCur) to iLocY
98402>>>>>>>        Move (-iWCur) to iLocX
98403>>>>>>>
98403>>>>>>>        // Allow chance to make modifications
98403>>>>>>>        Send AdjustSizesLocs (&iSzY) (&iSzX) (&iLocY) (&iLocX)
98404>>>>>>>
98404>>>>>>>        Set GuiSize to iSzY iSzX
98405>>>>>>>        // if we've scrolled, we need to reposition the container
98405>>>>>>>        Set GuiLocation to iLocY iLocX  
98406>>>>>>>    End_Procedure
98407>>>>>>>
98407>>>>>>>    // note that scrolling never changes the size of the scrolling client.
98407>>>>>>>    // this way, it does not interfere with anchors.
98407>>>>>>>    
98407>>>>>>>    Procedure VScroll Integer iDelta
98409>>>>>>>        Integer iHeight iCur iOrig iSiz 
98409>>>>>>>        Delegate Get GuiClientSize to iSiz
98411>>>>>>>        Move (hi(iSiz)) to iHeight
98412>>>>>>>        Get piCurrentVertScrolled to iCur
98413>>>>>>>        Get piMinimumHeight to iOrig
98414>>>>>>>        If (iOrig=0 or  Hi(iSiz)>=iOrig) Begin
98416>>>>>>>            Procedure_Return
98417>>>>>>>        End
98417>>>>>>>>
98417>>>>>>>        // make sure delta is within range  
98417>>>>>>>        If (iDelta+iCur<0) Begin
98419>>>>>>>            Move (-iCur) to iDelta
98420>>>>>>>        End
98420>>>>>>>>
98420>>>>>>>        Else If (iDelta+iCur>iOrig - iHeight) Begin
98423>>>>>>>            Move (iOrig - iHeight - iCur) to iDelta
98424>>>>>>>        End
98424>>>>>>>>
98424>>>>>>>        If (iDelta=0) Procedure_Return
98427>>>>>>>        
98427>>>>>>>        Move (iCur + iDelta) to iCur 
98428>>>>>>>        Set piCurrentVertScrolled to iCur 
98429>>>>>>>        Send SetScrollBarPosInfo True iCur 
98430>>>>>>>        Get GuiLocation to iSiz
98431>>>>>>>        Set GuiLocation to (cast(hi(iSiz),Short)-iDelta) (cast(low(iSiz),Short))
98432>>>>>>>        Send ScrollClientArea
98433>>>>>>>    End_Procedure
98434>>>>>>>    
98434>>>>>>>    
98434>>>>>>>    Procedure HScroll Integer iDelta
98436>>>>>>>        Integer iHeight iCur iOrig iSiz
98436>>>>>>>        Delegate Get GuiClientSize to iSiz
98438>>>>>>>        Move (low(iSiz)) to iHeight
98439>>>>>>>        Get piCurrentHorzScrolled to iCur
98440>>>>>>>        Get piMinimumWidth to iOrig
98441>>>>>>>        If (iOrig=0 or  low(iSiz)>=iOrig) Begin
98443>>>>>>>            Procedure_Return
98444>>>>>>>        End
98444>>>>>>>>
98444>>>>>>>        If (iDelta+iCur<0) Begin
98446>>>>>>>            Move (-iCur) to iDelta
98447>>>>>>>        End
98447>>>>>>>>
98447>>>>>>>        Else If (iDelta+iCur>iOrig - iHeight) Begin
98450>>>>>>>            Move (iOrig - iHeight - iCur) to iDelta
98451>>>>>>>        End
98451>>>>>>>>
98451>>>>>>>        If (iDelta=0) Procedure_Return
98454>>>>>>>        
98454>>>>>>>        Move (iCur + iDelta) to iCur 
98455>>>>>>>        Set piCurrentHorzScrolled to iCur 
98456>>>>>>>        Send SetScrollBarPosInfo False iCur 
98457>>>>>>>        Get GuiLocation to iSiz
98458>>>>>>>        Set GuiLocation to (cast(hi(iSiz),Short)) (cast(low(iSiz),Short) -iDelta)
98459>>>>>>>        Send ScrollClientArea
98460>>>>>>>    End_Procedure
98461>>>>>>>    
98461>>>>>>>    // make sure client is a 0,0
98461>>>>>>>    Procedure ScrollHome
98463>>>>>>>        Send SetVScrollbox SB_TOP 0
98464>>>>>>>        Send SetHScrollbox SB_TOP 0
98465>>>>>>>    End_Procedure
98466>>>>>>>
98466>>>>>>>    // get relative GUI location of this object to the parent one passed.
98466>>>>>>>    Procedure LocationRelativeTo Handle hoContainer Handle hoControl Integer ByRef iLocY Integer ByRef iLocX
98468>>>>>>>        Integer ivoid
98468>>>>>>>        tWinRect Rect0 Rect1
98468>>>>>>>        tWinRect Rect0 Rect1
98468>>>>>>>        Move (GetWindowRect(window_handle(hoContainer),addressof(Rect0))) to ivoid
98469>>>>>>>        Move (GetWindowRect(window_handle(hoControl),addressof(Rect1))) to ivoid
98470>>>>>>>        Move ((Rect1.top) - (Rect0.top)) to iLocY
98471>>>>>>>        Move ((rect1.left) - (rect0.left)) to iLocX
98472>>>>>>>    End_Procedure
98473>>>>>>>    
98473>>>>>>>    // This scrolls this object into visual range. 
98473>>>>>>>    Procedure ScrollObjectInRange Handle hoControl
98475>>>>>>>        Handle hoScrollingContainer
98475>>>>>>>        Integer iCurrentVertScrolled iCurrentHorzScrolled
98475>>>>>>>        Integer iViewHeight iViewWidth
98475>>>>>>>        Integer iRelLocHeight iRelLocWidth
98475>>>>>>>        Integer iSize iControlHeight iControlWidth
98475>>>>>>>        Integer iScroll
98475>>>>>>>        Integer iMarginX iMarginY
98475>>>>>>>        Integer iScrollingContainerWindowSize iScrollingContainerClientSize
98475>>>>>>>        
98475>>>>>>>        Get piAutoScrollMarginX to iMarginX
98476>>>>>>>        Get piAutoScrollMarginY to iMarginY
98477>>>>>>>        
98477>>>>>>>        // the scrolling container 
98477>>>>>>>        Move Self to hoScrollingContainer
98478>>>>>>>        // the amount the SC is currently scrolled
98478>>>>>>>        Get piCurrentVertScrolled of hoScrollingContainer to iCurrentVertScrolled
98479>>>>>>>        Get piCurrentHorzScrolled of hoScrollingContainer to iCurrentHorzScrolled
98480>>>>>>>        
98480>>>>>>>        // size of view's client area (this is the viewport area)
98480>>>>>>>        Get GuiClientSize of (Parent(hoScrollingContainer)) to iSize
98481>>>>>>>        Move (hi(iSize)) to iViewHeight
98482>>>>>>>        Move (low(iSize)) to iViewWidth
98483>>>>>>>        
98483>>>>>>>        // get this object's location relative to the scrolling container
98483>>>>>>>        Send LocationRelativeTo hoScrollingContainer hoControl (&iRelLocHeight) (&iRelLocWidth)
98484>>>>>>>
98484>>>>>>>        // we expect that the client size is the window size but just in case
98484>>>>>>>        Get GuiWindowSize of hoScrollingContainer to iScrollingContainerWindowSize
98485>>>>>>>        Get GuiClientSize of hoScrollingContainer to iScrollingContainerClientSize
98486>>>>>>>        Move (iRelLocHeight - (Hi(iScrollingContainerWindowSize)-Hi(iScrollingContainerClientSize))) to iRelLocHeight 
98487>>>>>>>        Move (iRelLocWidth - (Low(iScrollingContainerWindowSize)-Low(iScrollingContainerClientSize))) to iRelLocWidth
98488>>>>>>>        
98488>>>>>>>        // the outer size of the control object
98488>>>>>>>        Get GUIWindowSize of hoControl to iSize
98489>>>>>>>        Move (hi(iSize)) to iControlHeight
98490>>>>>>>        Move (low(iSize)) to iControlWidth
98491>>>>>>>        
98491>>>>>>>        // the general idea is to make the control fully visible but to scroll as little as possible.
98491>>>>>>>
98491>>>>>>>        // Vertical Scroll
98491>>>>>>>        
98491>>>>>>>        // Vertical Scroll down
98491>>>>>>>        // if the bottom of the control plus a bottom margin does not fit make it fit at the bottom
98491>>>>>>>        If (iRelLocHeight + iControlHeight + iMarginY - iCurrentVertScrolled >iViewHeight) Begin
98493>>>>>>>           
98493>>>>>>>           // set scroll amount so that the bottom of the control is visible  
98493>>>>>>>           Move (iRelLocHeight + iControlHeight + iMarginY - iCurrentVertScrolled - iViewHeight ) to iScroll
98494>>>>>>>           
98494>>>>>>>           // See if this amount, scrolls the top out of range. If so just scroll enough so that the
98494>>>>>>>           // top of the object appears at the bottom 
98494>>>>>>>           If (iRelLocHeight - iCurrentVertScrolled < iScroll) Begin
98496>>>>>>>               Move (iRelLocHeight + iMarginY  - iCurrentVertScrolled - iViewHeight  ) to iScroll
98497>>>>>>>           End
98497>>>>>>>>
98497>>>>>>>           // if the scroll amnt is negative it's best to just keep it where it is.
98497>>>>>>>           If (iScroll>0) Begin
98499>>>>>>>                Send VScroll of hoScrollingContainer iScroll
98500>>>>>>>           End
98500>>>>>>>>
98500>>>>>>>        End
98500>>>>>>>>
98500>>>>>>>        // else vertical scroll up 
98500>>>>>>>        // We scroll if the top of the object is not visible.  
98500>>>>>>>        Else If (iRelLocHeight + iMarginY < iCurrentVertScrolled) Begin
98503>>>>>>>            // if we scroll we will scroll enough to see the top of the object.
98503>>>>>>>            Move (iRelLocHeight -iMarginY - iCurrentVertScrolled ) to iScroll
98504>>>>>>>            If (iScroll<0) Begin
98506>>>>>>>                Send VScroll of hoScrollingContainer (iScroll max (-iCurrentVertScrolled))
98507>>>>>>>            End
98507>>>>>>>>
98507>>>>>>>        End
98507>>>>>>>>
98507>>>>>>>
98507>>>>>>>        // Horizonal Scroll
98507>>>>>>>        
98507>>>>>>>        // if the right side of the control does not fit, scroll it so it fits
98507>>>>>>>        If (iRelLocWidth + iControlWidth + iMarginX - iCurrentHorzScrolled >iViewWidth) Begin
98509>>>>>>>           Move (iRelLocWidth + iControlWidth + iMarginX - iCurrentHorzScrolled - iViewWidth ) to iScroll
98510>>>>>>>           If (iRelLocWidth - iCurrentHorzScrolled - iScroll<0) Begin
98512>>>>>>>               Move (iRelLocWidth  - iCurrentHorzScrolled - iMarginX ) to iScroll
98513>>>>>>>           End
98513>>>>>>>>
98513>>>>>>>           If (iScroll>0) Begin
98515>>>>>>>                Send HScroll of hoScrollingContainer iScroll
98516>>>>>>>           End
98516>>>>>>>>
98516>>>>>>>        End
98516>>>>>>>>
98516>>>>>>>        If (iRelLocWidth - iMarginX  - iCurrentHorzScrolled <0) Begin
98518>>>>>>>            // if this can fit by moving all the way to left, do so.
98518>>>>>>>            If (iRelLocWidth + iControlWidth + iMarginX <= iViewWidth) Begin
98520>>>>>>>                Move (-iCurrentHorzScrolled) to iScroll
98521>>>>>>>            End
98521>>>>>>>>
98521>>>>>>>            Else Begin
98522>>>>>>>                Move (iRelLocWidth - iCurrentHorzScrolled - iMarginX) to iScroll
98523>>>>>>>            End
98523>>>>>>>>
98523>>>>>>>            If (iScroll<0) Begin
98525>>>>>>>                Send HScroll of hoScrollingContainer (iScroll max (-iCurrentHorzScrolled))
98526>>>>>>>            End
98526>>>>>>>>
98526>>>>>>>        End
98526>>>>>>>>
98526>>>>>>>
98526>>>>>>>
98526>>>>>>>    End_Procedure
98527>>>>>>>
98527>>>>>>>    // when we receive this message, we might need to scroll to bring the new focus in to view.
98527>>>>>>>    Procedure NotifyFocusSetInContainer Handle hoControl
98529>>>>>>>        Boolean bScrollOnFocus
98529>>>>>>>        Get pbAutoScrollFocus to bScrollOnFocus
98530>>>>>>>        If bScrollOnFocus Begin
98532>>>>>>>            Send ScrollObjectInRange hoControl
98533>>>>>>>        End
98533>>>>>>>>
