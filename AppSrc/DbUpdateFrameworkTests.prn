95268>>>>>    // Returns a struct array with the default column types for the SQL back-end and how they
95268>>>>>    // are mapped to the standard DataFlex data types. 
95268>>>>>    // The DataFlex data types are: "ASCII", "BINARY", "DATE", "DATETIME", "NUMERIC" and "TEXT".
95268>>>>>    Function UtilDefaultSqlTypeMappings String sDriverID Integer iDbType Returns tColumnType
95270>>>>>        tColumnType[] ColumnTypeArray
95270>>>>>        tColumnType[] ColumnTypeArray
95271>>>>>        String sDataType
95271>>>>>        Integer iDataType iDriverID iCount
95271>>>>>        
95271>>>>>        Move 0 to iCount
95272>>>>>        Get DriverIndex sDriverID to iDriverID
95273>>>>>
95273>>>>>        // DF_ASCII       
95273>>>>>        If (sDriverID = ODBC_DRV_ID) Begin
95275>>>>>            Get_Attribute DF_DRIVER_MAP_DFASCII_TO_ODBCTYPE of iDriverID to iDataType
95278>>>>>        End                                                             
95278>>>>>>
95278>>>>>        Else Begin
95279>>>>>            Get_Attribute DF_DRIVER_MAP_DFASCII_TO_SQLTYPE  of iDriverID to iDataType 
95282>>>>>        End
95282>>>>>>
95282>>>>>        Move DF_ASCII    to ColumnTypeArray[iCount].iDataFlexType
95283>>>>>        Move "ASCII"     to ColumnTypeArray[iCount].sDataFlexType  
95284>>>>>        Get UtilColumnTypeToString sDriverID iDbType iDataType to sDataType
95285>>>>>        Move sDataType   to ColumnTypeArray[iCount].sType
95286>>>>>        Move iDataType   to ColumnTypeArray[iCount].iType
95287>>>>>        Increment iCount
95288>>>>>        
95288>>>>>        // DF_BINARY 
95288>>>>>        If (sDriverID = ODBC_DRV_ID) Begin
95290>>>>>            Get_Attribute DF_DRIVER_MAP_DFBINARY_TO_ODBCTYPE of iDriverID to iDataType
95293>>>>>        End                                                                          
95293>>>>>>
95293>>>>>        Else Begin
95294>>>>>            Get_Attribute DF_DRIVER_MAP_DFBINARY_TO_SQLTYPE  of iDriverID to iDataType
95297>>>>>        End
95297>>>>>>
95297>>>>>        Move DF_BINARY   to ColumnTypeArray[iCount].iDataFlexType
95298>>>>>        Move "Binary"    to ColumnTypeArray[iCount].sDataFlexType  
95299>>>>>        Get UtilColumnTypeToString sDriverID iDbType iDataType to sDataType
95300>>>>>        Move sDataType   to ColumnTypeArray[iCount].sType
95301>>>>>        Move iDataType   to ColumnTypeArray[iCount].iType
95302>>>>>        Increment iCount
95303>>>>>        
95303>>>>>        // DF_DATE
95303>>>>>        If (sDriverID = ODBC_DRV_ID) Begin
95305>>>>>            Get_Attribute DF_DRIVER_MAP_DFDATE_TO_ODBCTYPE of iDriverID to iDataType
95308>>>>>        End                                                                          
95308>>>>>>
95308>>>>>        Else Begin
95309>>>>>            Get_Attribute DF_DRIVER_MAP_DFDATE_TO_SQLTYPE  of iDriverID to iDataType
95312>>>>>        End
95312>>>>>>
95312>>>>>        Move DF_DATE     to ColumnTypeArray[iCount].iDataFlexType
95313>>>>>        Move "Date"      to ColumnTypeArray[iCount].sDataFlexType  
95314>>>>>        Get UtilColumnTypeToString sDriverID iDbType iDataType to sDataType
95315>>>>>        Move sDataType   to ColumnTypeArray[iCount].sType
95316>>>>>        Move iDataType   to ColumnTypeArray[iCount].iType
95317>>>>>        Increment iCount
95318>>>>>        
95318>>>>>        // DF_DATETIME
95318>>>>>        If (sDriverID = ODBC_DRV_ID) Begin
95320>>>>>            Get_Attribute DF_DRIVER_MAP_DFDATETIME_TO_ODBCTYPE of iDriverID to iDataType
95323>>>>>        End                                                                          
95323>>>>>>
95323>>>>>        Else Begin
95324>>>>>            Get_Attribute DF_DRIVER_MAP_DFDATETIME_TO_SQLTYPE  of iDriverID to iDataType
95327>>>>>        End
95327>>>>>>
95327>>>>>        Move DF_DATETIME to ColumnTypeArray[iCount].iDataFlexType
95328>>>>>        Move "DateTime"  to ColumnTypeArray[iCount].sDataFlexType  
95329>>>>>        Get UtilColumnTypeToString sDriverID iDbType iDataType to sDataType
95330>>>>>        Move sDataType   to ColumnTypeArray[iCount].sType
95331>>>>>        Move iDataType   to ColumnTypeArray[iCount].iType
95332>>>>>        Increment iCount
95333>>>>>
95333>>>>>        // DF_NUMERIC
95333>>>>>        // *** Why is there no DF_DRIVER_MAP available for BCD/Numeric??? ***
95333>>>>>        // DF_BCD can in SQL be either of "SmallInt", "Int", or "Numeric", but
95333>>>>>        // we make them here all "Numeric"...
95333>>>>>//        If (sDriverID = ODBC_DRV_ID) Begin
95333>>>>>//            Get_Attribute DF_DRIVER_MAP_DFDATE_TO_ODBCTYPE of iDriverID to iDataType
95333>>>>>//        End                                                                          
95333>>>>>//        Else Begin
95333>>>>>//            Get_Attribute DF_DRIVER_MAP_DFDATE_TO_SQLTYPE  of iDriverID to iDataType
95333>>>>>//        End                        
95333>>>>>        Move DF_BCD      to ColumnTypeArray[iCount].iDataFlexType
95334>>>>>        Move "Numeric"   to ColumnTypeArray[iCount].sDataFlexType
95335>>>>>        Move "Numeric"   to ColumnTypeArray[iCount].sType
95336>>>>>        Move SQL_NUMERIC to ColumnTypeArray[iCount].iType
95337>>>>>
95337>>>>>        // DF_TEXT
95337>>>>>        If (sDriverID = ODBC_DRV_ID) Begin
95339>>>>>            Get_Attribute DF_DRIVER_MAP_DFTEXT_TO_ODBCTYPE of iDriverID to iDataType
95342>>>>>        End                                                                          
95342>>>>>>
95342>>>>>        Else Begin
95343>>>>>            Get_Attribute DF_DRIVER_MAP_DFTEXT_TO_SQLTYPE  of iDriverID to iDataType
95346>>>>>        End
95346>>>>>>
95346>>>>>        Move DF_TEXT     to ColumnTypeArray[iCount].iDataFlexType
95347>>>>>        Move "Text"      to ColumnTypeArray[iCount].sDataFlexType  
95348>>>>>        Get UtilColumnTypeToString sDriverID iDbType iDataType to sDataType
95349>>>>>        Move sDataType   to ColumnTypeArray[iCount].sType
95350>>>>>        Move iDataType   to ColumnTypeArray[iCount].iType
95351>>>>>        Increment iCount
95352>>>>>        
95352>>>>>        Function_Return ColumnTypeArray
95353>>>>>    End_Function
