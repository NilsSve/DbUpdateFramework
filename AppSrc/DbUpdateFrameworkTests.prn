81228>>>                 Procedure ShowDDOConstraints Handle hoDD
81231>>>                    Integer i j iMain iCurrentDDFile
81231>>>                    tConstraintDef[] Constraints
81231>>>                    tConstraintDef[] Constraints
81232>>>                    String sFilter 
81232>>>                    Handle hoDDOther
