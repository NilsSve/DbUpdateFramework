92830>>>>>    Function SQLUtilTableIsViewType String sDriverID Handle hTable Returns Boolean
92832>>>>>        Boolean bViewTableType bOpen bMertechDriver bOK
92832>>>>>        Integer hoSQLHandler
92832>>>>>        Integer iTableCount iNumTables iPos iTableIndex
92832>>>>>        String sTableName sOwner sTableType sLogin sEnumTableName sEnumSchemaName sCurrent_Login
92832>>>>>        Handle hoCliHandler  
92832>>>>>        tSQLConnection SQLConnection
92832>>>>>        tSQLConnection SQLConnection
92832>>>>>        
92832>>>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpen
92835>>>>>        If (bOpen = False) Begin  
92837>>>>>            Get AutoConnectionIDLogin to bOK
92838>>>>>            Open hTable
92840>>>>>        End
92840>>>>>>
92840>>>>>        
92840>>>>>        Get pSQLConnection to SQLConnection   
92841>>>>>        Get phoCLIHandler to hoCliHandler
92842>>>>>        Set psDriverID of hoCliHandler to sDriverID
92843>>>>>        
92843>>>>>        Get_Attribute DF_FILE_ROOT_NAME of hTable to sTableName 
92846>>>>>        Get _TableNameOnly sTableName to sTableName             
92847>>>>>        Get_Attribute DF_FILE_OWNER     of hTable to sOwner
92850>>>>>        Get EnumerateTables of hoCliHandler SQLConnection.sConnectionString to iNumTables
92851>>>>>        
92851>>>>>        For iTableCount from 1 to iNumTables
92857>>>>>>
92857>>>>>            Get TableName  of hoCliHandler iTableCount to sEnumTableName
92858>>>>>            Get SchemaName of hoCliHandler iTableCount to sEnumSchemaName
92859>>>>>            If ((Uppercase(sEnumTableName)  = Uppercase(sTableName)) and (Uppercase(sEnumSchemaName) = Uppercase(sOwner))) Begin
92861>>>>>                Get TableType of hoCliHandler iTableCount to sTableType
92862>>>>>                Move iNumTables to iTableCount // We're done.
92863>>>>>            End
92863>>>>>>
92863>>>>>        Loop
92864>>>>>>
92864>>>>>        
92864>>>>>        Move (sTableType = "VIEW") to bViewTableType
92865>>>>>        If (bOpen = False) Begin
92867>>>>>            Close hTable
92868>>>>>        End
92868>>>>>>
92868>>>>>        
92868>>>>>        Function_Return bViewTableType
92869>>>>>    End_Function
