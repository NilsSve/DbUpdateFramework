100434>>>                    
100434>>>                    Property Integer piSortOrder 0 // Property gets set by the radio group object.
100436>>>                    
100436>>>                    // Custom array sort function.
100436>>>                    // iSortOrder = 0 -> Filelist number order
100436>>>                    // iSortOrder = 1 -> Logical name order
100436>>>                    // iSortOrder = 2 -> Root name order                                             
100436>>>                    // iSortOrder = 3 -> Display name order
100436>>>                    Function CompareSortFilelist tFilelistDUF FilelistDUF1 tFilelistDUF FilelistDUF2 Returns Integer
100439>>>                        Integer iSortOrder 
100439>>>                        
100439>>>                        Get piSortOrder to iSortOrder
100440>>>                        
100440>>>                        Case Begin
100440>>>                            Case (iSortOrder = 0)    
100442>>>                                If (FilelistDUF1.iFileNumber  > FilelistDUF2.iFileNumber) Begin
100444>>>                                    Function_Return (GT)
100445>>>                                End
100445>>>>
100445>>>                                If (FilelistDUF1.iFileNumber  < FilelistDUF2.iFileNumber) Begin
100447>>>                                    Function_Return (LT)
100448>>>                                End                    
100448>>>>
100448>>>                                Function_Return (EQ)
100449>>>                            Case (iSortOrder = 1)
100452>>>                                If (Uppercase(FilelistDUF1.sLogicalName) > Uppercase(FilelistDUF2.sLogicalName)) Begin
100454>>>                                    Function_Return (GT)
100455>>>                                End
100455>>>>
100455>>>                                If (Uppercase(FilelistDUF1.sLogicalName) < Uppercase(FilelistDUF2.sLogicalName)) Begin
100457>>>                                    Function_Return (LT)
100458>>>                                End                    
100458>>>>
100458>>>                                Function_Return (EQ)
