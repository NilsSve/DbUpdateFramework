79926>>>
79926>>>Class cCJSkinFramework is a cCJComSkinFramework
79927>>>    
79927>>>    Procedure Construct_Object
79929>>>        Forward Send Construct_Object
79931>>>        
79931>>>        Property String psSkinFile ""
79932>>>        Property String psSkinIni ""
79933>>>        Property Boolean pbLoadPreference False
79934>>>        
79934>>>        Set peAutoCreate to acAutoCreate
79935>>>        
79935>>>        Move Self to ghoSkinFramework
79936>>>    End_Procedure
79937>>>    
79937>>>    // return the default skin path, which is the programs directory.
79937>>>    // This requires an application object.
79937>>>    // If you want to different skin path, override this.
79937>>>    Function SkinPath Returns String
79939>>>        String sPath sPaths
79939>>>        Handle hoWorkspace
79939>>>        If ghoApplication Begin
79941>>>            Get phoWorkspace of ghoApplication to hoWorkspace
79942>>>            Get psProgramPath of hoWorkspace to sPaths
79943>>>            Get PathAtIndex of hoWorkspace sPaths 1 to sPath
79944>>>        End
79944>>>>
79944>>>        Else Begin
79945>>>            Error DFERR_PROGRAM C_$ApplicationObjectNotCreated
79946>>>>
79946>>>        End
79946>>>>
79946>>>        Function_Return sPath
79947>>>    End_Function
79948>>>    
79948>>>    // Returns the Qualified name of psSkinFile. If the file is already qualified it just
79948>>>    // returns itself. If it is not, it uses SkinPath to get the path.
79948>>>    Function SkinQFile Returns String
79950>>>        String sFile sPath sSep
79950>>>        Boolean bQualified
79950>>>        Get psSkinFile to sFile
79951>>>        If not (IsFileNameQualified(sFile)) Begin
79953>>>            Get SkinPath to sPath
79954>>>            Move (SysConf(SYSCONF_DIR_SEPARATOR)) to sSep
79955>>>            Move (sPath - sSep - sFile) to sFile
79956>>>        End
79956>>>>
79956>>>        Function_Return sFile
79957>>>    End_Function
79958>>>        
79958>>>    // defines the default VDF window class mapping.    
79958>>>    Procedure OnAddVDFWindowClasses
79960>>>        Send ComAddWindowClass "DFlistbox"               "ListBox"
79961>>>        Send ComAddWindowClass "DFentry"                 "Edit"
79962>>>        Send ComAddWindowClass "DFtextbox"               "Edit"
79963>>>        Send ComAddWindowClass "DFRichEditCtrl"          "Edit"
79964>>>        Send ComAddWindowClass "DFcombobox"              "ComboBox"
79965>>>        Send ComAddWindowClass "DFformlist"              "Edit"
79966>>>        Send ComAddWindowClass "DFFormListHeader"        "SysHeader32"
79967>>>        Send ComAddWindowClass "DFbutton"                "Button"
79968>>>        Send ComAddWindowClass "HPromptBtn"              "Button"
79969>>>        Send ComAddWindowClass "Hspinbtn"                "msctls_updown32"
79970>>>        Send ComAddWindowClass "DFSysTabControl32"       "SysTabControl32"
79971>>>        Send ComAddWindowClass "DFMDIClient"             "MDIClient" 
79972>>>        Send ComAddWindowClass "DFedit"                  "edit"
79973>>>        Send ComAddWindowClass "DFlistedit"              "edit"
79974>>>        Send ComAddWindowClass "DFscrollbar"             "scrollbar"
79975>>>        Send ComAddWindowClass "DFgroup"                 "Button"
79976>>>        Send ComAddWindowClass "DFComboGrid"             "ComboBox"
79977>>>        // External class
79977>>>        Send ComAddWindowClass "cVdfAnimation"           "SysAnimate32"
79978>>>        Send ComAddWindowClass "cVdfProgressBar"         "msctls_progress32"
79979>>>        Send ComAddWindowClass "cVdfStatusBar"           "msctls_statusbar32"
79980>>>        Send ComAddWindowClass "cVdfToolbar"             "ToolbarWindow32"
79981>>>        Send ComAddWindowClass "cObsoleteVdfProgressBar" "msctls_progress32"
79982>>>        Send ComAddWindowClass "cVdfTrackBar"            "msctls_trackbar32"
79983>>>        Send ComAddWindowClass "cObsoleteBasicStatusBar" "msctls_statusbar32"
79984>>>        Send ComAddWindowClass "cVdfTreeView"            "SysTreeView32"
79985>>>    End_Procedure
79986>>>    
79986>>>    // Used to support developer designed class mappings (e.g. COM controls)
79986>>>    Procedure OnAddCustomWindowClasses
79988>>>    End_Procedure
79989>>>
79989>>>    // called when object is created during end_construct_object.
79989>>>    Procedure OnCreate
79991>>>        Integer iOpts
79991>>>        Boolean bUseWindowsFont
79991>>>        Forward Send OnCreate
79993>>>        
79993>>>        // if we are using the windows fonts we will disable the apply metrics which
79993>>>        // never really looked good anyway. This test only exists or legacy purposes
79993>>>        Get pbUseWindowsFont of Desktop to bUseWindowsFont
79994>>>        If bUseWindowsFont Begin
79996>>>            Get ComApplyOptions to iOpts
79997>>>            Set ComApplyOptions to (RemoveBitValue(xtpSkinApplyMetrics, iOpts))
79998>>>        End
79998>>>>
79998>>>
79998>>>        // this works around a CJ issue where skins applied to other threads causes an exception upon close down. 
79998>>>        // We saw this with our mssql driver but it could occur elsewhere. This has been reported in the CJ newsgroup
79998>>>        // and this was the suggested workaround.
79998>>>        Set ComAutoApplyNewThreads to False
79999>>>
79999>>>        Send OnAddVDFWindowClasses
80000>>>        Send OnAddCustomWindowClasses
80001>>>        
80001>>>        // if preferences are used, it will set psSkinFile and psSkinIni
80001>>>        If (pbLoadPreference(Self)) Begin
80003>>>            Send LoadSkinPreference
80004>>>        End
80004>>>>
80004>>>        // if a skin file name exists, we apply the skin.    
80004>>>        If (psSkinFile(Self)<>"") Begin
80006>>>            Send ApplySkin
80007>>>        End        
80007>>>>
80007>>>    End_Procedure
80008>>>    
80008>>>    // called by framework as part of application exit.
80008>>>    Procedure Broadcast_Notify_Exit_Application
80010>>>        Send Notify_Exit_Application
80011>>>    End_Procedure // Notify_Exit_Application
80012>>>
80012>>>    Procedure Notify_Exit_Application
80014>>>        If (pbLoadPreference(Self)) Begin
80016>>>            Send SaveSkinPreference
80017>>>        End
80017>>>>
80017>>>    End_Procedure
80018>>>
80018>>>    Procedure NotifyPreApplySkin
80020>>>        Broadcast Send OnPreApplySkin of Desktop True       
80022>>>    End_Procedure
80023>>>
80023>>>    Procedure NotifyPostApplySkin
80025>>>        Broadcast Send OnPostApplySkin of Desktop True       
80027>>>    End_Procedure
80028>>>    
80028>>>    // returns an array of all skins in the path. If path is "", use the default path.
80028>>>    // If the default path is used, returns the file names as relative names, else use full path.
80028>>>    Function EnumerateSkins String sPath Boolean bRecursive Returns tSkinInformation[]
80030>>>        tSkinInformation[] Skins
80030>>>        tSkinInformation[] Skins
80031>>>        String sSkinName sSkinFile sDefaultPath sSep
80031>>>        Variant vSkinDescriptions vSkinDescription vSkinIniFile
80031>>>        Handle hSkinDescriptions hSkinDescription hSkinIniFile
80031>>>        Integer iSkinsCount iSkinFilesCount iNumSkins iNumSkinFiles iArrayItem
80031>>>        Integer iPos iDfltLen
80031>>>        Boolean bUseRelativePath
80031>>>        
80031>>>        Move (SysConf(SYSCONF_DIR_SEPARATOR)) to sSep
80032>>>        
80032>>>        Get SkinPath to sDefaultPath
80033>>>        If (sPath="") Begin
80035>>>            Move sDefaultPath to sPath
80036>>>        End
80036>>>>
80036>>>        Move (Uppercase(sDefaultPath)) to sDefaultPath
80037>>>        Move (Length(sDefaultPath)) to iDfltLen
80038>>>        Move (sDefaultPath=Uppercase(sPath)) to bUseRelativePath
80039>>>
80039>>>        Get ComEnumerateSkinDirectory sPath bRecursive to vSkinDescriptions
80040>>>        If (not(IsNullComObject(vSkinDescriptions))) Begin
80042>>>
80042>>>            Get Create U_cCJSkinDescriptions to hSkinDescriptions
80043>>>            Get Create U_cCJSkinDescription to hSkinDescription
80044>>>            Get Create U_cCJSkinIniFile to hSkinIniFile
80045>>>            
80045>>>            Set pvComObject of hSkinDescriptions to vSkinDescriptions
80046>>>            Get ComCount of hSkinDescriptions to iNumSkinFiles
80047>>>            
80047>>>            For iSkinFilesCount from 0 to (iNumSkinFiles-1)
80053>>>>
80053>>>                Get ComSkin of hSkinDescriptions iSkinFilesCount to vSkinDescription
80054>>>                Set pvComObject of hSkinDescription to vSkinDescription
80055>>>
80055>>>                Get ComCount of hSkinDescription to iNumSkins
80056>>>                    
80056>>>                For iSkinsCount from 0 to (iNumSkins-1)
80062>>>>
80062>>>                    Get ComIniFile of hSkinDescription iSkinsCount to vSkinIniFile
80063>>>                    Set pvComObject of hSkinIniFile to vSkinIniFile
80064>>>
80064>>>                    Get ComName of hSkinDescription to Skins[iArrayItem].sName
80065>>>                    Get ComPath of hSkinDescription to sSkinFile
80066>>>                    If bUseRelativePath Begin
80068>>>                        Move (pos(sDefaultPath,uppercase(sSkinFile))) to iPos
80069>>>                        If iPos Begin
80071>>>                            Move (Remove(sSkinFile,iPos,iDfltLen)) to sSkinFile   
80072>>>                            While (Left(sSkinFile,1)=sSep)
80076>>>                                Move (Remove(sSkinFile,1,1)) to sSkinFile   
80077>>>                            Loop                         
80078>>>>
80078>>>                        End
80078>>>>
80078>>>                    End
80078>>>>
80078>>>                    Move sSkinFile to Skins[iArrayItem].sSkinfile
80079>>>                    Get ComIniFileName of hSkinIniFile to Skins[iArrayItem].sSkinIni
80080>>>
80080>>>                    Increment iArrayItem
80081>>>                Loop
80082>>>>
80082>>>            Loop
80083>>>>
80083>>>                            
80083>>>            Send Destroy of hSkinDescriptions
80084>>>            Send Destroy of hSkinDescription
80085>>>            Send Destroy of hSkinIniFile
80086>>>                
80086>>>        End
80086>>>>
80086>>>        Function_Return Skins
80087>>>    End_Function 
80088>>>    
80088>>>    // Save the skin preference. This requires an application object.
80088>>>    // Only do this if the application object allows it. 
80088>>>    // This is called during startup if pbLoadPreference is True
80088>>>    // Suitable for override
80088>>>    Procedure SaveSkinPreference 
80090>>>        String sSkin sIni
80090>>>        If ghoApplication Begin
80092>>>            If (pbPreserveEnvironment(ghoApplication)) Begin
80094>>>                Get psSkinFile to sSkin
80095>>>                Get psSkinIni to sIni
80096>>>                Send WriteString of ghoApplication "Preferences" "SkinFile" sSkin
80097>>>                Send WriteString of ghoApplication "Preferences" "SkinIni" sIni
80098>>>            End
80098>>>>
80098>>>        End
80098>>>>
80098>>>        Else Begin
80099>>>            Error DFERR_PROGRAM C_$ApplicationObjectNotCreated
80100>>>>
80100>>>        End
80100>>>>
80100>>>    End_Procedure
80101>>>
80101>>>    // Load the skin preference. This requires an application object.
80101>>>    // Only do this if the application object allows it. 
80101>>>    // This is called during startup if pbLoadPreference is True
80101>>>    // Suitable for override
80101>>>    Procedure LoadSkinPreference 
80103>>>        String sSkin sIni
80103>>>        Boolean bExists
80103>>>        If ghoApplication Begin
80105>>>            If (pbPreserveEnvironment(ghoApplication)) Begin
80107>>>                Get ValueExists of ghoApplication "Preferences" "SkinFile" to bExists
80108>>>                If bExists Begin
80110>>>                    Get ReadString of ghoApplication "Preferences" "SkinFile" "" to sSkin
80111>>>                    Get ReadString of ghoApplication "Preferences" "SkinIni" "" to sIni
80112>>>                    Set psSkinFile to sSkin
80113>>>                    Set psSkinIni to sIni
80114>>>                End
80114>>>>
80114>>>            End
80114>>>>
80114>>>        End
80114>>>>
80114>>>        Else Begin
80115>>>            Error DFERR_PROGRAM C_$ApplicationObjectNotCreated
80116>>>>
80116>>>        End
80116>>>>
80116>>>    End_Procedure
80117>>>
80117>>>    // Can be called to apply the current skin.
80117>>>    Procedure ApplySkin
80119>>>        Boolean bOk
80119>>>        String sSkin sIni
80119>>>        If (IsComObjectCreated(Self)) Begin
80121>>>            Get SkinQFile to sSkin
80122>>>            Get psSkinIni to sIni
80123>>>            
80123>>>            Send NotifyPreApplySkin
80124>>>            // when skins are used we don't want to use built in Visual Styles
80124>>>            Send EnableVisualStyles of Desktop (sSkin="")
80125>>>            Get ComLoadSkin sSkin sIni to bOK
80126>>>            If (sSkin<>"" and not(bOk)) Begin
80128>>>                // if not ok, no skin was appied. Enable visual styles
80128>>>                Send EnableVisualStyles of Desktop True
80129>>>            End
80129>>>>
80129>>>            Send NotifyPostApplySkin
80130>>>        End
80130>>>>
80130>>>    End_Procedure
80131>>>
80131>>>
80131>>>End_Class
