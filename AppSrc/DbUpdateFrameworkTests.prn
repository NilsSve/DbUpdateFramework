86722>>>>>>>>>>>Function vWin32_APIFileSize Global string sFileName returns integer
86724>>>>>>>>>>>     dWord dwFileSizeHigh dwFileSizeLow
86724>>>>>>>>>>>     integer iFileSize iVoid
86724>>>>>>>>>>>     handle hFindFile
86724>>>>>>>>>>>     pointer lpsFilePath lpsWin32FindData
86724>>>>>>>>>>>     string sWin32FindData
86724>>>>>>>>>>>
86724>>>>>>>>>>>     GetAddress of sFileName to lpsFilePath
86725>>>>>>>>>>>
86725>>>>>>>>>>>     ZeroType vWin32_Find_Data to sWin32FindData
86726>>>>>>>>>>>     GetAddress of sWin32FindData to lpsWin32FindData
86727>>>>>>>>>>>
86727>>>>>>>>>>>     move (vWin32_FindFirstFile (lpsFilePath, lpsWin32FindData)) to hFindFile
86728>>>>>>>>>>>     if (hFindFile<>vINVALID_HANDLE_VALUE) begin
86730>>>>>>>>>>>         GetBuff From sWin32FindData At vWin32_Find_Data.nFileSizeHigh To dwFileSizeHigh
86731>>>>>>>>>>>         GetBuff From sWin32FindData At vWin32_Find_Data.nFileSizeLow To dwFileSizeLow
86732>>>>>>>>>>>     end
86732>>>>>>>>>>>>
86732>>>>>>>>>>>     move (vWin32_FindClose (hFindFile)) to iVoid
86733>>>>>>>>>>>
86733>>>>>>>>>>>     moveInt ((dwFileSizeHigh * vMaxDword) + dwFileSizeLow) to iFileSize
86734>>>>>>>>>>>>
86734>>>>>>>>>>>
86734>>>>>>>>>>>     function_return iFileSize
86735>>>>>>>>>>>End_Function  // vWin32_APIFileSize
