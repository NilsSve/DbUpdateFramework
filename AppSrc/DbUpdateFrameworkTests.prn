93102>>>>>    // To enumerate SQL database resources with ESQL and return the result as a string array,
93102>>>>>    // for DAW drivers.
93102>>>>>    // Returns: A string array.
93102>>>>>    Function SqlEnumerateEsqlDAW String sStmt Integer iColumn Returns String[]
93104>>>>>        String[] sReturnArray
93105>>>>>        String sValue sPrevious
93105>>>>>        Handle hoSQLHandler hoSQLConnect hstmt
93105>>>>>        Integer iFetchResult iRows
93105>>>>>        tSQLConnection SQLConnection
93105>>>>>        tSQLConnection SQLConnection
93105>>>>>        
93105>>>>>        Get phoSQLManager to hoSQLHandler
93106>>>>>                
93106>>>>>        If (hoSQLHandler <> 0) Begin 
93108>>>>>            Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
93109>>>>>            Get SQLConnect of hoSQLHandler SQLConnection.sDriverID SQLConnection.sConnectionString to hoSQLConnect
93110>>>>>            
93110>>>>>            If (hoSQLConnect <> 0) Begin   
93112>>>>>                Get SQLOpen of hoSQLConnect to hstmt
93113>>>>>                If (hstmt <> 0) Begin                                   
93115>>>>>                    Send SqlExecDirect of hstmt sStmt                                             
93116>>>>>                    Get SqlStmtAttribute of hstmt SqlSTMTATTRIB_ROWCOUNT to iRows 
93117>>>>>                    Repeat
93117>>>>>>
93117>>>>>                        Get SQLFetch of hstmt to iFetchResult
93118>>>>>                        If (iFetchResult <> 0) Begin
93120>>>>>                            Get SQLColumnValue of hstmt iColumn to sValue
93121>>>>>                            If (sValue <> sPrevious) Begin
93123>>>>>                                Move (Trim(sValue)) to sReturnArray[SizeOfArray(sReturnArray)
93124>>>>>                            End
93124>>>>>>
93124>>>>>                            Move sValue to sPrevious
93125>>>>>                        End
93125>>>>>>
93125>>>>>                    Until (iFetchResult = 0)
93127>>>>>                    Send SQLClose of hstmt
93128>>>>>                End
93128>>>>>>
93128>>>>>                Send SQLDisconnect of hoSQLConnect    
93129>>>>>            End
93129>>>>>>
93129>>>>>        End
93129>>>>>>
93129>>>>>    
93129>>>>>        Function_Return sReturnArray
93130>>>>>    End_Function   
