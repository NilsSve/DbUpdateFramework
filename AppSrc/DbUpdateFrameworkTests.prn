95354>>>>>    Function UtilDeleteCacheFile String sTableName Returns Boolean
95356>>>>>        String sDataPath sDriverID
95356>>>>>        Boolean bMertechDriver bOK  
95356>>>>>        Integer iPos
95356>>>>>        
95356>>>>>        If (sTableName contains ".") Begin
95358>>>>>            Move (Pos(".", sTableName)) to iPos
95359>>>>>            Move (Mid(sTableName, 999, (iPos +1))) to sTableName    
95360>>>>>        End                                                     
95360>>>>>>
95360>>>>>        
95360>>>>>        Get psDriverID to sDriverID
95361>>>>>        Get psDataPathFirstPart to sDataPath 
95362>>>>>        Get IsMertechDriver sDriverID to bMertechDriver
95363>>>>>        // First delete the cache file:
95363>>>>>        If (bMertechDriver = False) Begin
95365>>>>>            Get vDeleteFile (sDataPath + sTableName + ".cch") to bOK
95366>>>>>        End 
95366>>>>>>
95366>>>>>        Else Begin
