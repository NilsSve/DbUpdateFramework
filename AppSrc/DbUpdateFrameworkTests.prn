80399>
80399>        Procedure DisplayTabWorkspace
80402>            Variant vTab vPaintManager
80402>            Handle hoTab hoPaintManager  hoOptions
80402>            Integer iSize
80402>            
80402>            If (not(IsComObjectCreated(Self))) Procedure_Return
80405>            
80405>            Get OptionsObject to hoOptions
80406>            
80406>            // Create the tab workspace object. It will get created for the Client_Area so
80406>            // each view will be displayd on a separate tab-page (instead of the standard VDF MDI-interface)
80406>            Get Create (RefClass(cCJTabWorkspace)) to hoTab
80407>            Get ComShowTabWorkspace True to vTab
80408>            // Connect the CodeJock side to the DataFlex proxy object.
80408>            Set pvComObject  of hoTab to vTab
80409>            
80409>            Set ComFlags of hoTab to xtpWorkspaceShowCloseTab
80410>            Send ComEnableGroups of hoTab
80411>            
80411>            // Create a paint manager object that is needed to set some
80411>            // of the tab-workspace properties.
80411>            Get Create (RefClass(cCJTabPaintManager)) to hoPaintManager
80412>            Get ComPaintManager of hoTab          to vPaintManager
80413>            Set pvComObject     of hoPaintManager to vPaintManager
80414>            // This will truncate the middle part of long items
80414>            Set ComDrawTextPathEllipsis of hoPaintManager to True
80415>            Set ComLayout               of hoPaintManager to xtpTabLayoutMultiRow  
80416>
80416>//#IF (Required_RT_Version < 19)
80416>//            Move 16 to iSize
80416>//            Send ComSetIconSize         of hoOptions False iSize iSize  // Set icon size for Toolbar buttons.
80416>//            Move 24 to iSize
80416>//            Send ComSetIconSize         of hoPaintManager  iSize iSize  // Set icon size for Tab-workspace.
80416>//#ELSE            
80416>            Get Create (RefClass(cCJPaintManager)) to hoPaintManager
80417>            Get ComPaintManager of hoPaintManager  to vPaintManager
80418>            Set pvComObject     of hoPaintManager  to vPaintManager
80419>            Set ComAutoResizeIcons of hoPaintManager to True
80420>//#ENDIF
80420>            Send Destroy of hoPaintManager
80421>            Send ComRecalcLayout
80422>            Send Destroy of hoTab
80423>        End_Procedure
