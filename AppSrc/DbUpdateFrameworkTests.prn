94488>>>>>            Move (sDriverID + ":" + sRootName) to sRootName
94489>>>>>        End
94489>>>>>>
94489>>>>>
94489>>>>>        Set_Attribute DF_FILE_ROOT_NAME     of hTable to sRootName
94492>>>>>        Set_Attribute DF_FILE_DISPLAY_NAME  of hTable to sDisplayName
94495>>>>>        Set_Attribute DF_FILE_LOGICAL_NAME  of hTable to sLogicalName
94498>>>>>        
94498>>>>>        // We need a short break here before attempting to delete the physical file or Windows
94498>>>>>        // might report "File in use..." and the deletion will fail.
94498>>>>>        Sleep 2
94499>>>>>        If (sDriverID = DATAFLEX_ID) Begin                    
94501>>>>>            Get vDeleteFile (sDataPath + sPhysicalName + ".*") to bOK
94502>>>>>        End
