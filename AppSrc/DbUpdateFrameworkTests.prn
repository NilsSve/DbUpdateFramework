94515>>>>>    // *** Field/Column Level Functions: ***
94515>>>>>    //
94515>>>>>    // Adds a column name to the passed table number.
94515>>>>>    // Note: Types must be the standard DF_ASCII, DF_DATE etcetera and _cannot_ be any of the SQL_xxx types.
94515>>>>>    Function ApiColumnAdd Handle hTable String sFieldName Integer iType Integer iLength Integer iPrecision Returns Boolean
94517>>>>>        Integer iColumn iCount iFile
94517>>>>>        Boolean bExists bOK  
94517>>>>>        String sDdSrcPath sTableName
94517>>>>>    
94517>>>>>        Get UtilColumnExists hTable sFieldName to bExists
94518>>>>>        If (bExists = True) Begin
94520>>>>>            Function_Return False
94521>>>>>        End  
94521>>>>>>
94521>>>>>        If (iPrecision > 0) Begin
94523>>>>>            Move (iLength + iPrecision) to iLength
94524>>>>>        End
94524>>>>>>
94524>>>>>        
94524>>>>>        Get AutoConnectionIDLogin to bOK
94525>>>>>        Move False to Err   
94526>>>>>        // Structure_start will change the value of hTable...
94526>>>>>        Move hTable to iFile
94527>>>>>        Open iFile Mode DF_EXCLUSIVE
94529>>>>>        
94529>>>>>        Structure_Start iFile
94530>>>>>            Move 0 to iColumn
94531>>>>>            Create_Field hTable At iColumn
94532>>>>>            Set_Attribute DF_FIELD_NAME      of iFile iColumn to sFieldName
94535>>>>>            Set_Attribute DF_FIELD_TYPE      of iFile iColumn to iType
94538>>>>>            Set_Attribute DF_FIELD_LENGTH    of iFile iColumn to iLength
94541>>>>>            Set_Attribute DF_FIELD_PRECISION of iFile iColumn to iPrecision
94544>>>>>        Structure_End iFile
94546>>>>>        
94546>>>>>        // If in development environment; create .fd file:
94546>>>>>        Open hTable
94548>>>>>        Get psDdSrcPath of (phoWorkspace(ghoApplication)) to sDDSrcPath
94549>>>>>        Get CountOfPaths of (phoWorkspace(ghoApplication)) sDDSrcPath to iCount
94550>>>>>        If (iCount > 1) Begin
94552>>>>>            Get PathAtIndex of (phoWorkspace(ghoApplication)) sDDSrcPath 1 to sDDSrcPath    
94553>>>>>        End 
94553>>>>>>
94553>>>>>        Get vFolderExists sDDSrcPath to bExists
94554>>>>>        If (bExists = True) Begin                                   
94556>>>>>            Get vFolderFormat sDDSrcPath to sDDSrcPath 
94557>>>>>            Get_Attribute DF_FILE_ROOT_NAME of hTable to sTableName
94560>>>>>            Get _TableNameOnly sTableName to sTableName 
94561>>>>>            Output_Aux_File DF_AUX_FILE_FD for hTable to (sDDSrcPath + sTableName + ".fd")
94563>>>>>        End
94563>>>>>>
94563>>>>>        Close hTable
94564>>>>>
94564>>>>>        Function_Return (Err = False)
94565>>>>>    End_Function  
