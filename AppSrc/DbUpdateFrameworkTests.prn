88941>>>>>>>    Procedure Add_Element Integer iSQLKeywordConstant Integer iEN_dbType String sSQLKeyword
88943>>>>>>>        tSQLKeyWords[] SQLKeywordArray 
88943>>>>>>>        tSQLKeyWords[] SQLKeywordArray 
88944>>>>>>>        Integer iSize
88944>>>>>>>        
