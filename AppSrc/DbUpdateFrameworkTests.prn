94471>>>>>        Close hTable  
94472>>>>>        If (sDriverID = DATAFLEX_ID) Begin                    
94474>>>>>            Get vFilePathExists (sDataPath + sRootName + ".dat") to bExists
94475>>>>>            If (bExists = True) Begin
94477>>>>>                If (Uppercase(sPhysicalName) = Uppercase(sRootName)) Begin
94479>>>>>                    Function_Return False
94480>>>>>                End
94480>>>>>>
94480>>>>>
94480>>>>>                // ToDo: How do we handle this when the library has been imported into 
94480>>>>>                // the cDbUpdateVersion Class?
94480>>>>>                // Get YesNo_Box ("The table:\n" + (sDataPath + sPhysicalName) + "\nis to be renamed to:\n" + (sDataPath + sRootName) + "\nBut the destination already exists. Overwrite?") to iRetval
94480>>>>>                If (iRetval <> MBR_Yes) Begin
94482>>>>>                    Function_Return False
94483>>>>>                End                      
94483>>>>>>
94483>>>>>            End                                           
94483>>>>>>
94483>>>>>            Copy_db (sDataPath + sPhysicalName) to (sDataPath + sRootName) 
94486>>>>>        End
94486>>>>>>
