92649>>>>>    // Removes all driver identifications (e.g. "MSSQLDRV;MyTable" or "MyTable.MSSQLDRV"
92649>>>>>    // from the passed filelist.
92649>>>>>    // Returns the number of tables affected.
92649>>>>>    Function SqlUtilFilelistRemoveDriverInfo String sFilelist Returns Integer
92651>>>>>        String sCurrentFileList sRootName sDisplayName sLogicalName sVal
92651>>>>>        Integer iRetval
92651>>>>>        Handle hTable
92651>>>>>        
92651>>>>>        // We first save the current filelist as the passed filelist name
92651>>>>>        // may come from another workspace, to restore it when we're ready.
92651>>>>>        Get_Attribute DF_FILELIST_NAME to sCurrentFileList
92654>>>>>        Set_Attribute DF_FILELIST_NAME to sFilelist
92657>>>>>        Move 0 to hTable
92658>>>>>        Move 0 to iRetval
92659>>>>>        
92659>>>>>        Repeat
92659>>>>>>
92659>>>>>            Get_Attribute DF_FILE_NEXT_USED of hTable to hTable
92662>>>>>            If (hTable <> 0) Begin
92664>>>>>                Get_Attribute DF_FILE_ROOT_NAME    of hTable to sRootName
92667>>>>>                Get_Attribute DF_FILE_DISPLAY_NAME of hTable to sDisplayName
92670>>>>>                Get_Attribute DF_FILE_LOGICAL_NAME of hTable to sLogicalName
92673>>>>>                Move (Uppercase(sRootName)) to sVal
92674>>>>>                If (sVal contains MSSQLDRV_ID or sVal contains DB2_DRV_ID or sVal contains ODBC_DRV_ID) Begin
92676>>>>>                    // Prefixes:
92676>>>>>                    Move (Replace((MSSQLDRV_ID + ":"), sRootName, "")) to sRootName
92677>>>>>                    Move (Replace((DB2_DRV_ID  + ":"), sRootName, "")) to sRootName
92678>>>>>                    Move (Replace((ODBC_DRV_ID + ":"), sRootName, "")) to sRootName
92679>>>>>                    // Suffixes:
92679>>>>>                    Move (Replace(("." + MSSQLDRV_ID), sRootName, "")) to sRootName
92680>>>>>                    Move (Replace(("." + DB2_DRV_ID),  sRootName, "")) to sRootName
92681>>>>>                    Move (Replace(("." + ODBC_DRV_ID), sRootName, "")) to sRootName
92682>>>>>                    
92682>>>>>                    // Change Filelist entry:
92682>>>>>                    Set_Attribute DF_FILE_ROOT_NAME of hTable          to sRootName
92685>>>>>
92685>>>>>                    Move (Lowercase(sDisplayName)) to sVal
92686>>>>>                    If (sVal contains "dbo.") Begin
92688>>>>>                        Move (Replace("dbo.", sDisplayName, ""))       to sDisplayName
92689>>>>>                        
92689>>>>>                        // Change Filelist entry:
92689>>>>>                        Set_Attribute DF_FILE_DISPLAY_NAME of hTable   to sDisplayName
92692>>>>>                    End
92692>>>>>>
92692>>>>>                    Increment iRetval
92693>>>>>                End
92693>>>>>>
92693>>>>>            End
92693>>>>>>
92693>>>>>        Until (hTable = 0)
92695>>>>>        
92695>>>>>        Set_Attribute DF_FILELIST_NAME to sCurrentFileList
92698>>>>>        
92698>>>>>        Function_Return iRetval
92699>>>>>    End_Function
92700>>>>>    
92700>>>>>    // To open all Sql based tables in Filelist.cfg
92700>>>>>    Procedure SqlUtilOpenAllTables
92702>>>>>        Handle hTable
92702>>>>>        String sRoot sDriverID
92702>>>>>        Boolean bOK
92702>>>>>        
92702>>>>>        Move 0 to hTable
92703>>>>>        Move "" to sDriverID
92704>>>>>        Get AutoConnectionIDLogin to bOK
92705>>>>>        
92705>>>>>        Repeat
92705>>>>>>
92705>>>>>            Get_Attribute DF_FILE_NEXT_USED of hTable to hTable
92708>>>>>            If (hTable > 0) Begin     
92710>>>>>                Get_Attribute DF_FILE_DRIVER of hTable to sDriverID
92713>>>>>                If (sDriverID = MSSQLDRV_ID or sDriverID = DB2_DRV_ID or sDriverID = ODBC_DRV_ID) Begin
