90012>>>>>>>    End_Function
90013>>>>>>>    
90013>>>>>>>    Procedure Set psConnectionID String sValue
90015>>>>>>>        tSQLConnection SQLConnection                                       
90015>>>>>>>        tSQLConnection SQLConnection                                       
90015>>>>>>>        Integer iIndex
90015>>>>>>>        
90015>>>>>>>        Get Private.pSQLConnection to SQLConnection
90016>>>>>>>        If (SQLConnection.sConnectionID = "") Begin
90018>>>>>>>            Move sValue to SQLConnection.sConnectionID
90019>>>>>>>        End
90019>>>>>>>>
90019>>>>>>>        
90019>>>>>>>        // Else we might want to change the current connection ID
90019>>>>>>>        Else If (SQLConnection.sConnectionID <> "" and SQLConnection.sConnectionID <> sValue) Begin   
90022>>>>>>>            Move False to Err
90023>>>>>>>            Logout SQLConnection.sDriverID  
90024>>>>>>>            // This will also make a login to the new server.
90024>>>>>>>            Get SQLIniFileConnectionID of (phoSQLConnectionIniFile(Self)) sValue to SQLConnection
90025>>>>>>>        End
90025>>>>>>>>
90025>>>>>>>        Set pSQLConnection to SQLConnection
90026>>>>>>>    End_Procedure
