95233>>>>>    Function SQLUtilDefaultNullValue String sDriverID Integer iDbType Integer iDataType Returns String
95235>>>>>        String sNotNull sRetval sDefaultValue
95235>>>>>        Boolean bOK
95235>>>>>        
95235>>>>>        Get IsSQLDriver sDriverID to bOK
95236>>>>>        If (bOK = False) Begin
95238>>>>>            Function_Return ""
95239>>>>>        End                   
95239>>>>>>
95239>>>>>        
95239>>>>>        Get UtilDataTypeDefaultValue sDriverID iDbType iDataType to sDefaultValue
95240>>>>>        Get _SqlFindKeyWord CI_SQLNotNull to sNotNull
95241>>>>>        
95241>>>>>        Case Begin
95241>>>>>            Case (iDbType = EN_dbTypeMSSQL)
95243>>>>>                Move ("DEFAULT" * String(sDefaultValue) * String(sNotNull)) to sRetval
95244>>>>>                Case Break
95245>>>>>            Case (iDbType = EN_dbTypeMySQL)
95248>>>>>                Move (String(sNotNull) * "DEFAULT" * String(sDefaultValue)) to sRetval
95249>>>>>                Case Break
95250>>>>>            Case (iDbType = EN_dbTypePostgre)
95253>>>>>                Move (String(sNotNull) * "DEFAULT" * String(sDefaultValue)) to sRetval
95254>>>>>                Case Break
95255>>>>>            Case (iDbType = EN_dbTypeDB2)
95258>>>>>                Move (String(sNotNull))                                     to sRetval
95259>>>>>                Case Break
95260>>>>>            
95260>>>>>            // Seems like Oracle can't handle setting a new column to 'NOT NULL' if the table exists with data(!)
95260>>>>>            // ToDo: We need to look deeper into how Oracle handles NULL
95260>>>>>            Case (iDbType = EN_dbTypeOracle)
95263>>>>>                Move  ""                                                    to sRetval
95264>>>>>                Case Break                                              
95265>>>>>
95265>>>>>            Case Else
95265>>>>>                Move  ""                                                    to sRetval
95266>>>>>        Case End        
95266>>>>>        
95266>>>>>        Function_Return sRetval
95267>>>>>    End_Function
