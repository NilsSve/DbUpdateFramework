83027>>>>>>>    Define MertechInc_Variables_Defined
83027>>>>>>>
83027>>>>>>>    Indicator MertechInc_bThereIsBinding
83027>>>>>>>
83027>>>>>>>    Integer MertechInc_FileNumber      //Replaces _SAVEFILENUMBER# and FILENUMBER
83027>>>>>>>    Integer MertechInc_iArg            //Replaces _LLONG#
83027>>>>>>>    Integer MertechInc_iCallBack       //Replaces _CALLBACK#
83027>>>>>>>    Integer MertechInc_iCount          //General loop limit integer
83027>>>>>>>    Integer MertechInc_iDecSep         //Holds the decimal seperator
83027>>>>>>>    Integer MertechInc_iFunction       //Replaces _FID#    ??? check is this is need when tidy is complete
83027>>>>>>>    Integer MertechInc_iLoop           //General loop integer
83027>>>>>>>    Integer Mertech_iMySQLParam        //Replaces _ALL_PAR_POS#
83027>>>>>>>    Integer MertechInc_iParamCount     //Replaces _NPAR#
83027>>>>>>>    Integer MertechInc_iRet            //Replaces _RET#
83027>>>>>>>    Integer MertechInc_iSaveCount      //Replaces _NPOS#
83027>>>>>>>    Integer MertechInc_iWork           //General work integer
83027>>>>>>>    Integer MertechInc_iWork2
83027>>>>>>>
83027>>>>>>>    String MertechInc_Blank            //Replaces _BLANK#
83027>>>>>>>    String MertechInc_DriverName       //Replaces _DRIVERNAME#
83027>>>>>>>    String MertechInc_sArg1 255        //Replaces _ARG1#
83027>>>>>>>    String MertechInc_sArg2 255        //Replaces _ARG2#
83027>>>>>>>    String MertechInc_sWork 255        //General work string
83027>>>>>>>
83027>>>>>>>    String MertechInc_CurrentDriver    //Keep the current driver name
83027>>>>>>>    //Global string are created pre-filled with spaces. We need an empty string
83027>>>>>>>    Move "" to MertechInc_Blank
83028>>>>>>>    Move "" to MertechInc_CurrentDriver
