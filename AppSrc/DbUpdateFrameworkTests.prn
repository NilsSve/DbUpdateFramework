96944>>>>>    // For debugging purposes. To print Sql statements as they are build...
96944>>>>>    Procedure DebugPrint String sStmt String sFileName
96946>>>>>        Integer iCh
96946>>>>>        Get Seq_Append_Output_Channel sFileName to iCh
96947>>>>>            Write channel iCh sStmt  
96949>>>>>        Send Seq_Close_Channel iCh
96950>>>>>    End_Procedure
96951>>>>>        
96951>>>>>    // Returns the integer number for the passed Driver ID that is 
96951>>>>>    // needed by some database API calls.
96951>>>>>    Function DriverIndex String sDriverID Returns Integer
96953>>>>>        String  sCurrentDriver
96953>>>>>        Integer iNumberOfDrivers iDriver iCount
96953>>>>>    
96953>>>>>        Move 0 to iDriver
96954>>>>>    
96954>>>>>        Get_Attribute DF_NUMBER_DRIVERS to iNumberOfDrivers
96957>>>>>        for iCount from 1 to iNumberOfDrivers
96963>>>>>>
96963>>>>>    
96963>>>>>            Get_Attribute DF_DRIVER_NAME of iCount to sCurrentDriver
96966>>>>>            If ( Uppercase(sCurrentDriver) = Uppercase(sDriverID) ) Begin
96968>>>>>                Move iCount to iDriver
96969>>>>>            End
96969>>>>>>
96969>>>>>        Loop
96970>>>>>>
96970>>>>>        
96970>>>>>        // In case it was not found, it wasn't loaded so we do that now.
96970>>>>>        If (iDriver = 0) Begin
96972>>>>>            Move False to Err
96973>>>>>            Load_Driver sDriverID
96974>>>>>            If (Err = False) Begin
96976>>>>>                Move 1 to iDriver
96977>>>>>            End
96977>>>>>>
96977>>>>>        End
96977>>>>>>
96977>>>>>    
96977>>>>>        Function_Return iDriver
96978>>>>>    End_Function 
96979>>>>>    
96979>>>>>    // Scans to see if all tables can be opened exclusivly. I.e. that nobody else is running the application.
96979>>>>>    // Returns: False if nobody else is running
96979>>>>>    //          True if at least one table is open by another process (e.g. another user is running the application) 
96979>>>>>    // N.B! Only works for Embedded DataFlex Tables! It will _not_ work for Sql tables because; these
96979>>>>>    //      tables are not locked as DataFlex tables are.
96979>>>>>    Function IsDatabaseInUse Returns Boolean
96981>>>>>        Handle  hTable
96981>>>>>        Integer iTemp
96981>>>>>        String  sRootName sOrgOpenPath sOrgFileList
96981>>>>>        Boolean bOpen bErr bAlias bOK bIsSQLTable
96981>>>>>
96981>>>>>        Get AutoConnectionIDLogin to bOK
96982>>>>>        Move 0 to hTable
96983>>>>>        Get_Attribute DF_FILE_NEXT_USED of hTable to hTable
96986>>>>>        Move False to bErr
96987>>>>>        Send Ignore_Error of Error_Object_Id DFERR_FILE_ACCESS_VIOLATION
96988>>>>>
96988>>>>>        Repeat
96988>>>>>>
96988>>>>>            Get_Attribute DF_FILE_ROOT_NAME of hTable to sRootName
96991>>>>>            
96991>>>>>            // This test is only applicable for DataFlex embedded tables; so skip test if driver based table.
96991>>>>>            Get UtilTableIsSQLByRootName sRootName to bIsSQLTable
96992>>>>>            Move False to bOpen
96993>>>>>            
96993>>>>>            // Don't bother about FlexErrs (Table 50)
96993>>>>>            If (bIsSQLTable = False and hTable <> 0 and hTable <> 50) Begin
96995>>>>>                Set Error_Report_Mode to DUF_ERROR_NO_REPORT
96996>>>>>                Open hTable 
96998>>>>>                Get_Attribute DF_FILE_OPENED of hTable to bOpen
97001>>>>>                Set Error_Report_Mode to DUF_ERROR_REPORT
97002>>>>>                If (bOpen = True) Begin                        
97004>>>>>                    // We cannot open an Alias file exclusive as it will generate an error (4177 - "File in use")
97004>>>>>                    Get UtilTableIsAlias hTable to bAlias
97005>>>>>                    If (bAlias = False) Begin
97007>>>>>                        Open hTable mode DF_EXCLUSIVE   
97009>>>>>                        Get_Attribute DF_FILE_OPENED of hTable to bOpen
97012>>>>>                        If (bOpen = False) Begin
97014>>>>>                            Move True to bErr
97015>>>>>                        End
97015>>>>>>
97015>>>>>                    End
97015>>>>>>
97015>>>>>                End
97015>>>>>>
97015>>>>>            End
97015>>>>>>
97015>>>>>            Get_Attribute DF_FILE_NEXT_USED of hTable to hTable
97018>>>>>            If (bOpen = False) Break
97021>>>>>        Until (not(hTable))
97023>>>>>
97023>>>>>        Send Trap_Error of Error_Object_Id DFERR_FILE_ACCESS_VIOLATION
97024>>>>>        Move False to Err
97025>>>>>        
97025>>>>>        Function_Return bErr
97026>>>>>    End_Function  
97027>>>>>    
97027>>>>>    // Checks if the passed connection id exists in the CLI interface.
97027>>>>>    // This might be needed by API-methods when a connection id is to be used and
97027>>>>>    // the connection id hasn't been established with the driver's CLI interface.
97027>>>>>    // NOTE: Only applicable for DAW drivers.
97027>>>>>    Function IsConnectionID String sConnectionID String sDriverID Returns Boolean
97029>>>>>        String sID 
97029>>>>>        Integer iDriver iNumConn iCount
97029>>>>>        Handle hoCLI                                            
97029>>>>>        Boolean bOK
97029>>>>>        
97029>>>>>        Get IsDAWSQLDriver sDriverID to bOK
97030>>>>>        If (bOK = False) Begin
97032>>>>>            Error DFERR_PROGRAM "Connection ID's can only be used with DAW drivers (not Mertech)."
97033>>>>>>
97033>>>>>            Function_Return False
97034>>>>>        End
97034>>>>>>
97034>>>>>        
97034>>>>>        Move False to bOK
97035>>>>>        Get phoCLIHandler to hoCLI 
97036>>>>>        If (hoCLI <> 0) Begin
97038>>>>>            Set psDriverID of hoCLI to sDriverID
97039>>>>>            Get DriverIndex of hoCLI sDriverID to iDriver
97040>>>>>            
97040>>>>>            // If driver not loaded; load it.
97040>>>>>            If (iDriver = 0) Begin
97042>>>>>                Load_Driver sDriverID
97043>>>>>                Get DriverIndex sDriverID to iDriver
97044>>>>>            End                      
97044>>>>>>
97044>>>>>            If (iDriver <> 0) Begin
97046>>>>>                Get_Attribute DF_DRIVER_NUMBER_CONNECTION_IDS of iDriver to iNumConn
97049>>>>>                Decrement iNumConn
97050>>>>>                For iCount from 0 to iNumConn
97056>>>>>>
97056>>>>>                    Get_Attribute DF_DRIVER_CONNECTION_ID of iDriver iCount to sID
97059>>>>>                    If (sID = sConnectionID) Move True to bOK
97062>>>>>                Loop
97063>>>>>>
97063>>>>>            End
97063>>>>>>
97063>>>>>        End
97063>>>>>>
97063>>>>>        
97063>>>>>        Function_Return bOK
97064>>>>>    End_Function                   
97065>>>>>    
97065>>>>>    Function IsDAWSQLDriver String sDriverID Returns Boolean
97067>>>>>        Boolean bOK
97067>>>>>        Move (sDriverID = MSSQLDRV_ID or sDriverID = DB2_DRV_ID or sDriverID = ODBC_DRV_ID) to bOK
97068>>>>>        Function_Return bOK
97069>>>>>    End_Function
97070>>>>>
97070>>>>>    Function IsMertechDriver String sDriverID Returns Boolean
97072>>>>>        Boolean bOK
97072>>>>>        Move False to bOK
97073>>>>>        Move (sDriverID = SQLFLEX or sDriverID = ORAFLEX or sDriverID = MDSPgSQL or sDriverID = MDSMySQL) to bOK
97074>>>>>        Function_Return bOK
97075>>>>>    End_Function
97076>>>>>            
97076>>>>>    Function IsMSSQLDriver Returns Boolean
97078>>>>>        Handle ho
97078>>>>>        Integer iDriverIndex
97078>>>>>        
97078>>>>>        Get DriverIndex MSSQLDRV_ID to iDriverIndex
97079>>>>>        
97079>>>>>        Function_Return (iDriverIndex <> 0)
97080>>>>>    End_Function
97081>>>>>        
97081>>>>>    // Similar to _SqlCheckCurrentDriver but generates no error and it doesn't 
97081>>>>>    // attempt to load the driver.
97081>>>>>    // Returns true if the passed driver is SQL based.        
97081>>>>>    Function IsSQLDriver String sDriverID Returns Boolean
97083>>>>>        Boolean bOK                         
97083>>>>>        Integer iDriver
97083>>>>>        
97083>>>>>        Get IsDAWSQLDriver sDriverID to bOK
97084>>>>>
97084>>>>>        If (bOK = False) Begin
97086>>>>>            Get IsMertechDriver sDriverID to bOK
97087>>>>>        End                                     
97087>>>>>>
97087>>>>>
97087>>>>>        Function_Return bOK
97088>>>>>    End_Function
97089>>>>>            
97089>>>>>    // *** Error Handler ***
97089>>>>>    //
97089>>>>>    // Note: If the cDbUpdateHandler & cDbUpdateVersion classes are used this error handler is _not_
97089>>>>>    //       used. Instead the Error_Report in the cDbUpdateHandler i used.
97089>>>>>    Procedure Error_Report Integer iErrorNumber Integer iErrorLine String sErrorText
97091>>>>>        String sText
97091>>>>>        Integer iSize iErrorMode
97091>>>>>        tSqlErrorArray aSqlErrorArray
97091>>>>>        tSqlErrorArray aSqlErrorArray
97091>>>>>        
97091>>>>>        If (pbProcessingError(Self)) Begin
97093>>>>>            Procedure_Return
97094>>>>>        End 
97094>>>>>>
97094>>>>>        
97094>>>>>        Get Error_Report_Mode to iErrorMode
97095>>>>>        If (iErrorMode = DUF_ERROR_NO_REPORT) Begin
97097>>>>>            Procedure_Return
97098>>>>>        End
97098>>>>>>
97098>>>>>
97098>>>>>        Set pbProcessingError to True
97099>>>>>        Set pbSqlError to True
97100>>>>>        Get paSqlErrorArray      to aSqlErrorArray
97101>>>>>        Move (SizeOfArray(aSqlErrorArray.sSqlErrorArray)) to iSize
97102>>>>>        Move sErrorText          to aSqlErrorArray.sSqlErrorArray[iSize]
97103>>>>>        Get psSQLStatementString to aSqlErrorArray.sSqlStatementArray[iSize]
97104>>>>>        Move iErrorNumber        to aSqlErrorArray.iSqlErrorArray[iSize]
97105>>>>>        Set paSqlErrorArray      to aSqlErrorArray
97106>>>>>        Set pbProcessingError to False
97107>>>>>    End_Procedure
97108>>>>>
97108>>>>>    // *** Miscellanous Helper Functions ***
97108>>>>>    //
97108>>>>>    // Helper function. Takes a DF_FILE_XXXX_NAME value as parameter and 
97108>>>>>    // returns the table name only; stripped of any path or filename extension.
97108>>>>>    Function _TableNameOnly String sName Returns String
97110>>>>>        String sPath sExt
97110>>>>>        
97110>>>>>        Get ParseFolderName sName to sPath
97111>>>>>        If (sPath <> "") Begin
97113>>>>>            Move (Replace(sPath, sName, "")) to sName
97114>>>>>        End                                                  
97114>>>>>>
97114>>>>>        Get ParseFileExtension sName to sExt
97115>>>>>        If (sExt <> "") Begin
97117>>>>>            Move (Replace(("." + sExt), sName, "")) to sName
97118>>>>>        End
97118>>>>>>
97118>>>>>        
97118>>>>>        Function_Return sName
97119>>>>>    End_Function
97120>>>>>
97120>>>>>    // Returns the first datapath found in the psDataPath property.
97120>>>>>    // The returned path always ends with a "\"
97120>>>>>    Function psDataPathFirstPart Returns String
97122>>>>>        String sDataPath
97122>>>>>        Integer iCount
97122>>>>>        
97122>>>>>        Get psDataPath of (phoWorkspace(ghoApplication)) to sDataPath
97123>>>>>        Get CountOfPaths of (phoWorkspace(ghoApplication)) sDataPath to iCount
97124>>>>>        If (iCount > 1) Begin
97126>>>>>            Get PathAtIndex of (phoWorkspace(ghoApplication)) sDataPath 1 to sDataPath    
97127>>>>>        End             
97127>>>>>>
97127>>>>>        If (sDataPath <> "") Begin
97129>>>>>            Get vFolderFormat sDataPath to sDataPath
97130>>>>>        End
97130>>>>>>
97130>>>>>        
97130>>>>>        Function_Return sDataPath
97131>>>>>    End_Function
97132>>>>>        
