82779>>>>>>>    //***
82779>>>>>>>    //*** Procedure: SeedDataSources
82779>>>>>>>    //*** Purpose  : Reset the datasource list to the beginning
82779>>>>>>>    //***
82779>>>>>>>
82779>>>>>>>    Procedure SeedDataSources
82781>>>>>>>        Local String  sDriver
82781>>>>>>>        Local String  sVoid
82781>>>>>>>        Local Integer iRetval
82781>>>>>>>
82781>>>>>>>        Get psDriverID To sDriver
82782>>>>>>>        If (sDriver <> "") ;            Call_Driver 0 sDRiver Function CLI_INITDATASOURCES Callback 0 Passing sVoid sVoid SQL_FETCH_ALL Result iRetval
82789>>>>>>>    End_Procedure // SeedDataSources
82790>>>>>>>
82790>>>>>>>
82790>>>>>>>
82790>>>>>>>    //***
82790>>>>>>>    //*** Function: DataSources
82790>>>>>>>    //*** Purpose : Call the driver's data sources function
82790>>>>>>>    //***
82790>>>>>>>
82790>>>>>>>    Function DataSources Returns String
82792>>>>>>>        Local String  sDriver
82792>>>>>>>        Local String  sDataSource
82792>>>>>>>        Local String  sDescription
82792>>>>>>>        Local Integer iLength
82792>>>>>>>        Local Integer iRetval
82792>>>>>>>
82792>>>>>>>        Get psDriverID To sDriver
82793>>>>>>>        If (sDriver <> "") Begin
82795>>>>>>>            Move 8192 To iLength
82796>>>>>>>            Move (Repeat(" ", iLength)) To sDataSource
82797>>>>>>>            Move (Repeat(" ", iLength)) To sDescription
82798>>>>>>>            Call_Driver 0 sDRiver Function CLI_DATASOURCES Callback 0 Passing sDataSource sDescription iLength Result iRetval
82803>>>>>>>        End
82803>>>>>>>>
82803>>>>>>>
82803>>>>>>>        If (sDataSource <> "" Or sDescription <> "") ;            Function_Return (sDataSource + "," +  sDescription)
82806>>>>>>>        Else ;            Function_Return ""
82808>>>>>>>    End_Function// DataSources
82809>>>>>>>
82809>>>>>>>End_Class // cODBCHandler
