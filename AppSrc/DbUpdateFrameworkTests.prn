89793>>>>>>>>>    // Short connection string used when writing to ini-file. This is to be compatible with DF19 DFConnId.ini files that uses this short format.
89793>>>>>>>>>    Function ConstructShortConnectionString String sDriverID String sServer String sDatabase Returns String
89795>>>>>>>>>        String sConnect 
89795>>>>>>>>>        
89795>>>>>>>>>        Case Begin
89795>>>>>>>>>            Case (sDriverID = MSSQLDRV_ID or sDriverID = SQLFLEX)
89797>>>>>>>>>                Move (sConnect * CS_SQLIniServerKeyword + "=" + sServer) to sConnect
89798>>>>>>>>>                If (sDatabase <> "") Begin
89800>>>>>>>>>                    Move (sConnect * ";" + CS_SQLIniDatabaseKeyword + "=" + sDatabase) to sConnect
89801>>>>>>>>>                End
89801>>>>>>>>>>
89801>>>>>>>>>                Case Break
89802>>>>>>>>>
89802>>>>>>>>>            Case (sDriverID = ODBC_DRV_ID)
89805>>>>>>>>>                Move (sConnect * CS_SQLIniDSNKeyword + "=" + sServer) to sConnect
89806>>>>>>>>>                If (sDatabase <> "") Begin
89808>>>>>>>>>                    Move (sConnect * ";" + CS_SQLIniDatabaseKeyword + "=" + sDatabase) to sConnect
89809>>>>>>>>>                End
89809>>>>>>>>>>
89809>>>>>>>>>                Case Break
89810>>>>>>>>>
89810>>>>>>>>>            Case (sDriverID = DB2_DRV_ID)
89813>>>>>>>>>                Move (sConnect * CS_SQLIniDSNKeyword + "=" + sServer) to sConnect
89814>>>>>>>>>                If (sDatabase <> "") Begin
89816>>>>>>>>>                    Move (sConnect * ";" + CS_SQLIniDatabaseKeyword + "=" + sDatabase) to sConnect
89817>>>>>>>>>                End
89817>>>>>>>>>>
89817>>>>>>>>>                Case Break
89818>>>>>>>>>            
89818>>>>>>>>>            Case (sDriverID = ORAFLEX)
89821>>>>>>>>>                Move (sConnect * CS_SQLIniDSNKeyword + "=" + sServer) to sConnect
89822>>>>>>>>>                If (sDatabase <> "") Begin
89824>>>>>>>>>                    Move (sConnect * ";" + CS_SQLIniDatabaseKeyword + "=" + sDatabase) to sConnect
89825>>>>>>>>>                End
89825>>>>>>>>>>
89825>>>>>>>>>                Case Break
89826>>>>>>>>>
89826>>>>>>>>>            Case (sDriverID = MDSPgSQL)
89829>>>>>>>>>                Move (sConnect * CS_SQLIniDSNKeyword + "=" + sServer) to sConnect
89830>>>>>>>>>                If (sDatabase <> "") Begin
89832>>>>>>>>>                    Move (sConnect * ";" + CS_SQLIniDatabaseKeyword + "=" + sDatabase) to sConnect
89833>>>>>>>>>                End
89833>>>>>>>>>>
89833>>>>>>>>>                Case Break
89834>>>>>>>>>
89834>>>>>>>>>            Case (sDriverID = MDSMySQL)
89837>>>>>>>>>                Move (sConnect * CS_SQLIniDSNKeyword + "=" + sServer) to sConnect
89838>>>>>>>>>                If (sDatabase <> "") Begin
89840>>>>>>>>>                    Move (sConnect * ";" +CS_SQLIniDatabaseKeyword + "=" + sDatabase) to sConnect
89841>>>>>>>>>                End
89841>>>>>>>>>>
89841>>>>>>>>>                Case Break
89842>>>>>>>>>
89842>>>>>>>>>            Case (sDriverID = DATAFLEX_ID)    // Dummy stub.
89845>>>>>>>>>                Break
89846>>>>>>>>>
89846>>>>>>>>>            Case Else
89846>>>>>>>>>                Move "" to sConnect
89847>>>>>>>>>        Case End
89847>>>>>>>>>
89847>>>>>>>>>        Function_Return sConnect
