89761>>>>>>>>>>Function ParseKeyWord String sConnect String sKeyWord Returns String
89763>>>>>>>>>>    Integer iStart iEnd
89763>>>>>>>>>>    String sRetval
89763>>>>>>>>>>
89763>>>>>>>>>>    Move (Trim(sConnect)) to sConnect
89764>>>>>>>>>>    Move (Pos(Uppercase(sKeyWord), Uppercase(sConnect)))  to iStart
89765>>>>>>>>>>    If (iStart = 0) Begin
89767>>>>>>>>>>        Function_Return ""
89768>>>>>>>>>>    End
89768>>>>>>>>>>>
89768>>>>>>>>>>    Move (Left(sConnect, (iStart -1 + Length(sKeyWord)))) to sRetval
89769>>>>>>>>>>    Move (Replace(sRetval, sConnect, "")) to sRetval 
89770>>>>>>>>>>    If (sKeyWord = Uppercase(CS_SQLConnectionIDText)) Begin
89772>>>>>>>>>>        Move (Pos(",", sRetval))          to iEnd
89773>>>>>>>>>>    End
89773>>>>>>>>>>>
89773>>>>>>>>>>    Else Begin
89774>>>>>>>>>>        Move (Pos(";", sRetval))          to iEnd
89775>>>>>>>>>>    End                                          
89775>>>>>>>>>>>
89775>>>>>>>>>>    If (iEnd = 0 and (sRetval contains ",")) Begin
89777>>>>>>>>>>        Move (Pos(",", sRetval))          to iEnd 
89778>>>>>>>>>>        Decrement iEnd
89779>>>>>>>>>>    End
89779>>>>>>>>>>>
89779>>>>>>>>>>    If (iEnd <> 0) Begin
89781>>>>>>>>>>        Move (Left(sRetval, (iEnd -1)))   to sRetval
89782>>>>>>>>>>    End
89782>>>>>>>>>>>
89782>>>>>>>>>>    Move (Replace("=", sRetval, ""))      to sRetval
89783>>>>>>>>>>
89783>>>>>>>>>>    Function_Return (Trim(sRetval))
89784>>>>>>>>>>End_Function
