91429>>>>>    // Drop column by its table name as a string.
91429>>>>>    Function SqlColumnRemoveByTableName String sTableName String sColumnName Returns Boolean
91431>>>>>        Integer iColumn iDbType iDriver
91431>>>>>        String sDriverID sStmt sAlterTable sDropColumn sVal 
91431>>>>>        Boolean bExists bOK bRetval bDriverIgnoreErrorState
91431>>>>>        Handle hTable 
91431>>>>>        
91431>>>>>        Get psDriverID to sDriverID
91432>>>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
91433>>>>>        If (bOK = False) Begin
91435>>>>>            Function_Return False
91436>>>>>        End
91436>>>>>>
91436>>>>>
91436>>>>>        Get DriverIndex sDriverID to iDriver
91437>>>>>        Get_Attribute DF_DRIVER_IGNORE_WARNINGS of iDriver to bDriverIgnoreErrorState
91440>>>>>        Set_Attribute DF_DRIVER_IGNORE_WARNINGS of iDriver to True
91443>>>>>        
91443>>>>>        Get UtilTableNameToHandle sTableName to hTable
91444>>>>>        If (hTable <> 0) Begin
91446>>>>>            Get SQLUtilColumnExists sTableName sColumnName to bExists
91447>>>>>            If (bExists = False) Begin
91449>>>>>                Set_Attribute DF_DRIVER_IGNORE_WARNINGS of iDriver to bDriverIgnoreErrorState
91452>>>>>                Function_Return False
91453>>>>>            End
91453>>>>>>
91453>>>>>        End
91453>>>>>>
91453>>>>>
91453>>>>>        Get piDbType to iDbType
91454>>>>>        If (iDbType = EN_DbTypeMSSQL) Begin
91456>>>>>            Get _SqlUtilRemoveTableColumnMSSQL sTableName sColumnName to bOK
91457>>>>>            Get UtilDeleteCacheFile sTableName to bOK
91458>>>>>            Set_Attribute DF_DRIVER_IGNORE_WARNINGS of iDriver to bDriverIgnoreErrorState
91461>>>>>            Function_Return bOK
91462>>>>>        End
91462>>>>>>
91462>>>>>        
91462>>>>>        Move False to Err   
91463>>>>>        Get _SqlProperTableName sTableName    to sTableName
91464>>>>>        Get _SqlFindKeyWord CI_SQLAlterTable  to sAlterTable
91465>>>>>        Get _SqlFindKeyWord CI_SQLDropColumn  to sDropColumn   
91466>>>>>        
91466>>>>>        Move (sAlterTable * sTableName * sDropColumn * sColumnName) to sStmt
91467>>>>>        Send SqlUtilExecuteQuery sStmt sDriverID
91468>>>>>        Move (not(Err)) to bRetval
91469>>>>>    
91469>>>>>        // We also need to remove the cache-file since the table has been changed
91469>>>>>        Get UtilDeleteCacheFile sTableName to bOK
91470>>>>>        Set_Attribute DF_DRIVER_IGNORE_WARNINGS of iDriver to bDriverIgnoreErrorState
91473>>>>>    
91473>>>>>        Function_Return bRetval
91474>>>>>    End_Function    
91475>>>>>    
91475>>>>>    // Rename a field/column by table handle (filelist number)
91475>>>>>    Function SqlColumnRename Integer hTable String sColumnName String sNewColumnName Returns Boolean
91477>>>>>        Integer iColumn idbType
91477>>>>>        String sDriverID sTableName sStmt sAlterTable sRenameColumn sVal sColumnKeyWord
91477>>>>>        Boolean bExists bOK
91477>>>>>        
91477>>>>>        Get psDriverID to sDriverID
91478>>>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
91479>>>>>        If (bOK = False) Begin
91481>>>>>            Function_Return False
91482>>>>>        End
91482>>>>>>
91482>>>>>        
91482>>>>>        Get UtilTableHandleToString hTable to sTableName   
91483>>>>>        Get SqlColumnRenameByTableName sTableName sColumnName sNewColumnName to bOK
91484>>>>>
91484>>>>>        Function_Return (Err = False)    
91485>>>>>    End_Function    
91486>>>>>    
91486>>>>>    // Rename a field/column by table name.
91486>>>>>    Function SqlColumnRenameByTableName String sTableName String sColumnName String sNewColumnName Returns Boolean
91488>>>>>        Integer iColumn iDbType iDataType
91488>>>>>        String sDriverID sStmt sAlterTable sRenameColumn sVal sColumnKeyWord sOrgTableName sDatabase sDataType
91488>>>>>        Boolean bExists bOK bRetval                                        
91488>>>>>        Handle hTable
91488>>>>>        
91488>>>>>        Move sTableName to sOrgTableName
91489>>>>>        Get psDriverID to sDriverID
91490>>>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
91491>>>>>        If (bOK = False) Begin
91493>>>>>            Function_Return False
91494>>>>>        End
91494>>>>>>
91494>>>>>        
91494>>>>>        Get _SqlFindColumnName sTableName sColumnName to sVal
91495>>>>>        If (sVal = "") Begin
91497>>>>>            Function_Return False
91498>>>>>        End                          
91498>>>>>>
91498>>>>>        
91498>>>>>        Get piDbType to iDbType
91499>>>>>        Get _SqlFindKeyWord CI_SQLColumn       to sColumnKeyWord
91500>>>>>        Get _SqlProperTableName sTableName     to sTableName
91501>>>>>        Get _SqlFindKeyWord CI_SQLAlterTable   to sAlterTable
91502>>>>>        Get _SqlFindKeyWord CI_SQLRenameColumn to sRenameColumn
91503>>>>>        
91503>>>>>        Case Begin
91503>>>>>            Case (iDbType = EN_dbTypeMSSQL) 
91505>>>>>                Move (sRenameColumn * "'" + sTableName + "." + sColumnName + "'," * "'" + sNewColumnName + "'," * "'" + sColumnKeyWord + "'") to sStmt
91506>>>>>                Case Break
91507>>>>>            // Alter table "SYS"."Customer" rename column "Comments" to "NewColumnName"    
91507>>>>>            Case (iDbType = EN_dbTypeOracle) 
91510>>>>>                Move (sAlterTable * '"' + sTableName + '"' * sRenameColumn * '"' + sColumnName + '"' * "TO" * '"' + sNewColumnName + '"') to sStmt
91511>>>>>                Case Break  
91512>>>>>            // ALTER TABLE Schema.TableName RENAME COLUMN "deptnumb" TO "deptnum"
91512>>>>>            Case (iDbType = EN_dbTypeDB2)
91515>>>>>                Move (sAlterTable *  sTableName * sRenameColumn * '"' + sColumnName + '"' * "TO" * '"' + sNewColumnName + '"') to sStmt
91516>>>>>                Case Break
91517>>>>>            // ALTER TABLE "Customer" RENAME COLUMN "Comments" TO "NewColumnName"
91517>>>>>            Case (iDbType = EN_dbTypePostgre) 
91520>>>>>                Move sOrgTableName to sTableName
91521>>>>>                Move (sAlterTable * '"' + sTableName + '"' * sRenameColumn * '"' + sColumnName + '"' * "TO" * '"' + sNewColumnName + '"') to sStmt
91522>>>>>                Case Break  
91523>>>>>            Case (iDbType = EN_dbTypeMySQL)
91526>>>>>                // ALTER TABLE orderentry.customer CHANGE Comments NewColumnName text // Note: The last token is the column type!
91526>>>>>                Move sOrgTableName to sTableName
91527>>>>>                Get psDatabase to sDatabase 
91528>>>>>                Get UtilTableNameToHandle sTableName to hTable
91529>>>>>                If (hTable = 0) Begin
91531>>>>>                    Get UtilTableOpen hTable sTableName DF_SHARE to bOK
91532>>>>>                    If (bOK = False) Begin
91534>>>>>                        Function_Return False 
91535>>>>>                    End
91535>>>>>>
91535>>>>>                    Get NextFreeFilelistSlot to hTable
91536>>>>>                End
91536>>>>>>
91536>>>>>                Else Begin
91537>>>>>                    Open hTable
91539>>>>>                End          
91539>>>>>>
91539>>>>>                Get SQLColumnType sDriverID hTable sTableName sColumnName to iDataType
91540>>>>>                Get UtilColumnTypeToString sDriverID iDbType iDataType    to sDataType
91541>>>>>                Move (sAlterTable * sDatabase + "." + sTableName * sRenameColumn * sColumnName * sNewColumnName * sDataType) to sStmt
91542>>>>>                Case Break  
91543>>>>>            Case Else 
91543>>>>>                Move (sAlterTable * "'" + sTableName + "'" * sRenameColumn * "'" + sTableName + "." + sColumnName + "'" * "TO" * "'" + sNewColumnName + "'") to sStmt
91544>>>>>        Case End
91544>>>>>        
91544>>>>>        Move False to Err   
91545>>>>>        Send SqlUtilExecuteQuery sStmt sDriverID
91546>>>>>        Move (Err = False) to bRetval
91547>>>>>        // We also need to remove the cache-file since the table has been changed
91547>>>>>        Get UtilDeleteCacheFile sTableName to bOK
91548>>>>>    
91548>>>>>        Function_Return bRetval
91549>>>>>    End_Function    
91550>>>>>
91550>>>>>    Function SqlColumnType String sDriverID Handle hTable String sTableName String sColumnName Returns Integer
91552>>>>>        Handle hoSQLHandler hSQLConnect hStmt
91552>>>>>        Boolean bMertechDriver                                     
91552>>>>>        Integer iNumCols iCount iSQLType iDataType
91552>>>>>        String sValue 
91552>>>>>        
91552>>>>>        Get IsMertechDriver sDriverID to bMertechDriver
91553>>>>>        If (bMertechDriver = False) Begin
91555>>>>>            Get phoSQLManager to hoSQLHandler
91556>>>>>        End                                  
91556>>>>>>
91556>>>>>        Else Begin
91557>>>>>            Get _MertechSQLManagerHandle to hoSQLHandler
91558>>>>>        End                                    
91558>>>>>>
91558>>>>>        
91558>>>>>        Get SQLFileConnect of hoSQLHandler hTable to hSQLConnect
91559>>>>>        If (hSQLConnect <> 0) Begin
91561>>>>>            Get SQLOpen of hSQLConnect to hStmt
91562>>>>>            If (hStmt <> 0) Begin
91564>>>>>                Send SQLExecDirect of hStmt ("select * from" * sTableName)
91565>>>>>        
91565>>>>>                Get SQLStmtAttribute of hStmt SQLSTMTATTRIB_COLUMNCOUNT to iNumCols
91566>>>>>                For iCount from 1 to iNumCols
91572>>>>>>
91572>>>>>                    Get SQLColAttribute of hStmt iCount SQLCOLATTRIB_LABEL to sValue
91573>>>>>                    If (Lowercase(sValue) = Lowercase(sColumnName)) Begin
91575>>>>>                        Get SQLColAttribute of hStmt iCount SQLCOLATTRIB_SQLTYPE to iDataType
91576>>>>>                        Move iNumCols to iCount // We're out of here
91577>>>>>                    End
91577>>>>>>
91577>>>>>                Loop                                                
91578>>>>>>
91578>>>>>                
91578>>>>>                Send SQLClose of hStmt
91579>>>>>            End
91579>>>>>>
91579>>>>>            Send SQLDisconnect of hSQLConnect    
91580>>>>>        End
91580>>>>>>
91580>>>>>        
91580>>>>>        Function_Return iDataType
91581>>>>>    End_Function
91582>>>>>        
91582>>>>>    
91582>>>>>    // *** SQL Utility Messages ***
91582>>>>>    // They are not geared at making database changes.
91582>>>>>    //
91582>>>>>
91582>>>>>    // Will create an SQL table with the passed sTableName & sColumnName as Numeric 4.2 to keep
91582>>>>>    // the DbUpdateVersion database revision in.  
91582>>>>>    // Also pass the file number of the current (embedded?) table number used in development.
91582>>>>>    // It will first create the SQL Table & column, then create the .int file and change Filelist.cfg
91582>>>>>    Function SQLCreateDbVersionTable Handle hTable String sColumnName String sDriverID Returns Boolean
91584>>>>>        Boolean bOK bOpened
91584>>>>>        String sTableName sDataType sAlterTable sAddColumn sLengthAndDecimals sStmt sDropColumn
91584>>>>>        
91584>>>>>        Get_Attribute DF_FILE_ROOT_NAME of hTable to sTableName
91587>>>>>        Get _TableNameOnly sTableName to sTableName   
91588>>>>>        If (sTableName = "") Begin
91590>>>>>            Function_Return False
91591>>>>>        End 
91591>>>>>>
91591>>>>>        
91591>>>>>        // This just creates the table and a "dummy" column.
91591>>>>>        Get SqlTableCreate hTable sDriverID to bOK
91592>>>>>        If (bOK = False) Begin
91594>>>>>            Function_Return False 
91595>>>>>        End                      
91595>>>>>>
91595>>>>>        
91595>>>>>        Close hTable
91596>>>>>        Move False to Err
91597>>>>>        
91597>>>>>        Get _SqlFindKeyWord CI_SQLAlterTable to sAlterTable
91598>>>>>        Get _SqlFindKeyWord CI_SQLAdd        to sAddColumn
91599>>>>>        Move "Decimal" to sDataType
91600>>>>>        Get _SqlFormatLengthAndDecimalAsString 4 2 to sLengthAndDecimals
91601>>>>>        
91601>>>>>        // Adds the "sColumnName" passed to the function
91601>>>>>        Move (sAlterTable * sTableName * sAddColumn * sColumnName * sDataType + sLengthAndDecimals) to sStmt 
91602>>>>>        Send SqlUtilExecuteQuery sStmt sDriverID
91603>>>>>        
91603>>>>>        // Now we can delete the dummy column:
91603>>>>>        Get SqlColumnRemoveByTableName sTableName "Dummy" to bOK
91604>>>>>        
91604>>>>>        // Finally, we attach to the newly created table.
91604>>>>>        If (Err = False) Begin    
91606>>>>>            Get ApiTableAttachToSQL hTable True to bOK
91607>>>>>        End
91607>>>>>>
91607>>>>>        Open hTable                                                  
91609>>>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpened
91612>>>>>        
91612>>>>>        Function_Return (Err = False and bOK = True and bOpened = True)
91613>>>>>    End_Function
91614>>>>>    
91614>>>>>    // Checks if a column/field name exists in a SQL table definition
91614>>>>>    // Returns True if it does
91614>>>>>    // Sample:
91614>>>>>    //   Get SQLUtilColumnExists "MySQLTable" "MyColumnName" to bExists
91614>>>>>    Function SQLUtilColumnExists String sTableName String sFieldName Returns Boolean
91616>>>>>        Integer iNumColumns iColumn
91616>>>>>        String sColumn sDriverID
91616>>>>>        String[] sColumnsArray
91617>>>>>        Boolean bExists bOK
91617>>>>>    
91617>>>>>        Move False to bExists  
91618>>>>>        Get AutoConnectionIDLogin to bOK
91619>>>>>        Get psDriverID to sDriverID
91620>>>>>        
91620>>>>>        Get SqlUtilEnumerateColumns sDriverID sTableName to sColumnsArray
91621>>>>>        Move (SizeOfArray(sColumnsArray)) to iNumColumns
91622>>>>>        Decrement iNumColumns
91623>>>>>        For iColumn from 0 to iNumColumns
91629>>>>>>
91629>>>>>            Move sColumnsArray[iColumn] to sColumn
91630>>>>>            If (Uppercase(sFieldName) = Uppercase(sColumn)) Begin
91632>>>>>                Move True to bExists
91633>>>>>                Move iNumColumns to iColumn // We're out of here
91634>>>>>            End
91634>>>>>>
91634>>>>>        Loop
91635>>>>>>
91635>>>>>    
91635>>>>>        Function_Return bExists
91636>>>>>    End_Function
91637>>>>>    
91637>>>>>    Function SQLUtilConvertColumnTypesToSQL2008 Handle hTable Returns Boolean
91639>>>>>        Integer iNumColumns iColumn iDFType iNativeType
91639>>>>>        Boolean bOpened bOK
91639>>>>>        String sColumnName sNativeTypeName
91639>>>>>        
91639>>>>>        Get AutoConnectionIDLogin to bOK
91640>>>>>        Open hTable Mode DF_EXCLUSIVE
91642>>>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpened
91645>>>>>        If (bOpened = False) Begin
91647>>>>>            Error DFERR_PROGRAM ("Function SQLUtilConvertColumnTypesToSQL2008; Could not open table" * String(hTable))
91648>>>>>>
91648>>>>>            Function_Return False 
91649>>>>>        End
91649>>>>>>
91649>>>>>        
91649>>>>>        Move False to Err                               
91650>>>>>        
91650>>>>>        Structure_Start hTable
91651>>>>>            Get_Attribute DF_FILE_NUMBER_FIELDS of hTable to iNumColumns
91654>>>>>        
91654>>>>>            For iColumn from 1 to iNumColumns
91660>>>>>>
91660>>>>>                Get_Attribute DF_FIELD_TYPE             of hTable iColumn to iDfType
91663>>>>>                Get_Attribute DF_FIELD_NAME             of hTable iColumn to sColumnName
91666>>>>>                Get_Attribute DF_FIELD_NATIVE_TYPE      of hTable iColumn to iNativeType
91669>>>>>                Get_Attribute DF_FIELD_NATIVE_TYPE_Name of hTable iColumn to sNativeTypeName
91672>>>>>                
91672>>>>>                Case Begin
91672>>>>>                    Case (iDFType = DF_DATE) 
91674>>>>>                        If (iNativeType = SQL_TYPE_TIMESTAMP) Begin
91676>>>>>                            // Convert datetime to date
91676>>>>>                            Set_Attribute DF_FIELD_NATIVE_TYPE of hTable iColumn to SQL_TYPE_DATE
91679>>>>>                        End
91679>>>>>>
91679>>>>>                        Case Break
91680>>>>>                    Case (iDFType = DF_DATETIME) 
91683>>>>>                        If (iNativeType = SQL_TYPE_TIMESTAMP) Begin
91685>>>>>                            // Convert datetime to datetime2
91685>>>>>                            Set_Attribute DF_FIELD_NATIVE_TYPE of hTable iColumn to SQL_TYPE_TIMESTAMP2
91688>>>>>                        End
91688>>>>>>
91688>>>>>                        Case Break
91689>>>>>                    Case (iDFType = DF_ASCII) 
91692>>>>>                        If (iNativeType = SQL_CHAR) Begin
91694>>>>>                            // Convert char to varchar
91694>>>>>                            Set_Attribute DF_FIELD_NATIVE_TYPE of hTable iColumn to SQL_VARCHAR
91697>>>>>                        End
91697>>>>>>
91697>>>>>                        Case Break
91698>>>>>                    Case (iDFType = DF_TEXT) 
91701>>>>>                        If (iNativeType = SQL_LONGVARCHAR) Begin 
91703>>>>>                            // Convert text to varchar(max)
91703>>>>>                            Set_Attribute DF_FIELD_NATIVE_TYPE of hTable iColumn to SQL_VARCHAR
91706>>>>>                        End
91706>>>>>>
91706>>>>>                        Case Break
91707>>>>>                    Case (iDFType = DF_BINARY) 
91710>>>>>                        If (iNativeType = SQL_LONGVARBINARY) Begin
91712>>>>>                            // Convert image to varbinary(max)
91712>>>>>                            Set_Attribute DF_FIELD_NATIVE_TYPE of hTable iColumn to SQL_VARBINARY
91715>>>>>                        End
91715>>>>>>
91715>>>>>                        Case Break
91716>>>>>                Case End
91716>>>>>            Loop
91717>>>>>>
91717>>>>>        Structure_End hTable
91719>>>>>    
91719>>>>>        Function_Return (Err = False)    
91720>>>>>    End_Function  
91721>>>>>    
91721>>>>>    // Does three things with auxilirary files;
91721>>>>>    // 1) Deletes the cache file in the first Data folder of the psDataPath property as the table at the SQL end has been changed.
91721>>>>>    // 2) Adds the sColumnName to the TableName.tag file in the first Data folder of the psDataPath property
91721>>>>>    // 3) Creates a new TableName.fd file if the DdSrc folder is available (if this is a development environment)
91721>>>>>    Function SqlUtilAdjustAuxFiles Handle hTable String sTableName String sColumnName Returns Boolean
91723>>>>>        String sDataPath sDDSrcPath sVal sDriverID
91723>>>>>        Boolean bOK bExists bMertechDriver
91723>>>>>        Integer iCount iItems iCh iPos
91723>>>>>        
91723>>>>>        // If table name equals e.g. "dbo.MyTable" we need to remove the prefix.
91723>>>>>        If (sTableName contains ".") Begin
91725>>>>>            Move (Pos(".", sTableName)) to iPos
91726>>>>>            Move (Mid(sTableName, 999, (iPos +1))) to sTableName    
91727>>>>>        End                                                     
91727>>>>>>
91727>>>>>        
91727>>>>>        Get psDriverID to sDriverID
91728>>>>>        Get psDataPathFirstPart to sDataPath 
91729>>>>>        Get vFolderExists sDataPath to bOK
91730>>>>>        If (bOK = False) Begin
91732>>>>>            Error DFERR_PROGRAM "Function SqlUtilAdjustAuxFiles; psDataPath not found!"
91733>>>>>>
91733>>>>>            Function_Return False    
91734>>>>>        End                      
91734>>>>>>
91734>>>>>        
91734>>>>>        Get IsMertechDriver sDriverID to bMertechDriver
91735>>>>>        // First delete the cache file:
91735>>>>>        Get UtilDeleteCacheFile sTableName to bOK
91736>>>>>            
91736>>>>>        Get Seq_New_Channel to iCh  
91737>>>>>        If (iCh = DF_SEQ_CHANNEL_NOT_AVAILABLE) Begin
91739>>>>>            Function_Return False
91740>>>>>        End                      
91740>>>>>>
91740>>>>>        
91740>>>>>        Get vFilePathExists (sDataPath + sTableName + ".tag") to bExists
91741>>>>>        If (bExists = False) Begin
91743>>>>>            Function_Return False
91744>>>>>        End                      
91744>>>>>>
91744>>>>>        
91744>>>>>        // Add the new column name to the .tag file: 
91744>>>>>        Append_Output channel iCh (sDataPath + sTableName + ".tag")
91746>>>>>            Writeln channel iCh sColumnName
91749>>>>>        Close_Output
91750>>>>>        
91750>>>>>        // If in development environment; output new .fd file:
91750>>>>>        Get psDdSrcPath of (phoWorkspace(ghoApplication)) to sDDSrcPath
91751>>>>>        Get CountOfPaths of (phoWorkspace(ghoApplication)) sDDSrcPath to iCount
91752>>>>>        If (iCount > 1) Begin
91754>>>>>            Get PathAtIndex of (phoWorkspace(ghoApplication)) sDDSrcPath 1 to sDDSrcPath    
91755>>>>>        End 
91755>>>>>>
91755>>>>>        Get vFolderExists sDDSrcPath to bExists
91756>>>>>        If (bExists = True) Begin                                   
91758>>>>>            Get vFolderFormat sDDSrcPath to sDDSrcPath  
91759>>>>>            Move False to Err 
91760>>>>>            Get AutoConnectionIDLogin to bOK
91761>>>>>            If (hTable <> 0) Begin
91763>>>>>                Open hTable
91765>>>>>            End 
91765>>>>>>
91765>>>>>            Else Begin
91766>>>>>                Get UtilTableOpen hTable sTableName DF_SHARE to bOK
91767>>>>>            End
91767>>>>>>
91767>>>>>                
91767>>>>>            Get_Attribute DF_FILE_OPENED of hTable to bOK
91770>>>>>            If (bOK = True) Begin
91772>>>>>                Output_Aux_File DF_AUX_FILE_FD for hTable to (sDDSrcPath + sTableName + ".fd")
91774>>>>>            End
91774>>>>>>
91774>>>>>            If (Err = True) Begin
91776>>>>>                Move False to bOK
91777>>>>>            End
91777>>>>>>
91777>>>>>        End
91777>>>>>>
91777>>>>>        
91777>>>>>        Function_Return (bOK = True)
91778>>>>>    End_Function  
91779>>>>>    
91779>>>>>    // The table must already exist in the filelist for this function to work.
91779>>>>>    // It creates a rudimentary .int file in the first Data folder of the psDataPath property.
91779>>>>>    Function SqlUtilCreateIntFile Handle hTable String sDriverID String sConnectionID Boolean bAnsi Boolean bSysFile Returns Boolean
91781>>>>>        Boolean bOK bExists bUseConnectionID bMertech
91781>>>>>        String sDataPath sRootName sPhysicalFileName sConnectionString sDatabaseName sSchemaName sANSI_OEM
91781>>>>>        String[] sIndexArray
91782>>>>>        Integer iCount iCh iSize
91782>>>>>        
91782>>>>>        Move (Trim(sConnectionID) <> "") to bUseConnectionID
91783>>>>>        Get psConnectionString to sConnectionString
91784>>>>>
91784>>>>>        Move CS_ANSI_Txt to sANSI_OEM
91785>>>>>        If (bANSI = False) Begin
91787>>>>>            Move CS_OEM_Txt to sANSI_OEM
91788>>>>>        End
91788>>>>>>
91788>>>>>        
91788>>>>>        Get psDataPathFirstPart to sDataPath
91789>>>>>        Get vFolderExists sDataPath to bOK
91790>>>>>        If (bOK = False) Begin
91792>>>>>            Error DFERR_PROGRAM "Function SqlUtilCreateIntFile; psDataPath not found!"
91793>>>>>>
91793>>>>>            Function_Return False    
91794>>>>>        End                      
91794>>>>>>
91794>>>>>        Get vFolderFormat sDataPath to sDataPath 
91795>>>>>
91795>>>>>        Get_Attribute DF_FILE_ROOT_NAME of hTable to sRootName
91798>>>>>        Get _TableNameOnly sRootName to sDatabaseName
91799>>>>>        Move sDatabaseName to sPhysicalFileName
91800>>>>>        Move (sPhysicalFileName + ".int") to sPhysicalFileName
91801>>>>>
91801>>>>>        Get IsMertechDriver sDriverID to bMertech
91802>>>>>        If (bMertech = True) Begin       
91804>>>>>            // This should not be called here. Instead it is called by the SqlUtilUpdateIntFile!
91804>>>>>            // Else it will create an error in the error log (although it won't do anything...)
91804>>>>>            // Get _MertechSqlUtilCreateIntFile hTable sDataPath sPhysicalFileName to bOK
91804>>>>>            Function_Return (bOK = True)
91805>>>>>        End
91805>>>>>>
91805>>>>>        
91805>>>>>        Get psSchema hTable to sSchemaName
91806>>>>>        If (sSchemaName = "") Begin   
91808>>>>>            Get _SqlFindKeyWord CI_SQLDBO to sSchemaName
91809>>>>>        End
91809>>>>>>
91809>>>>>
91809>>>>>        // If the .int file already exists; we rename it to "FileName" + ".bak"
91809>>>>>        Get vFilePathExists (sDataPath + sPhysicalFileName) to bExists
91810>>>>>        If (bExists = True) Begin            
91812>>>>>            Get vRenameFile (sDataPath + sPhysicalFileName) (sDataPath + sPhysicalFileName + ".bak") to bOK 
91813>>>>>        End
91813>>>>>>
91813>>>>>        
91813>>>>>        Get UtilDeleteCacheFile sRootName to bOK
91814>>>>>        Get SqlUtilEnumerateIndexes sRootName sDriverID to sIndexArray
91815>>>>>        
91815>>>>>        Get Seq_Open_Output_Channel (sDataPath + sPhysicalFileName) to iCh
91816>>>>>            Writeln channel iCh CS_DRIVER_NAME     " " sDriverID 
91821>>>>>            If (bUseConnectionID = True) Begin
91823>>>>>                Writeln channel iCh CS_SERVER_NAME " " CS_DFCONNID "=" sConnectionID
91830>>>>>            End 
91830>>>>>>
91830>>>>>            Else Begin
91831>>>>>                Writeln channel iCh CS_SERVER_NAME " " CS_SERVER "=" sConnectionString
91838>>>>>            End                                                      
91838>>>>>>
91838>>>>>            Writeln channel iCh CS_DATABASE_NAME          " " sDatabaseName
91843>>>>>            Writeln channel iCh CS_SCHEMA_NAME            " " (Lowercase(sSchemaName))
91848>>>>>            // There seems to be a new order how these are set from DF19.
91848>>>>>            If (bSysFile = True) Begin
91850>>>>>                Writeln channel iCh CS_RECNUM_TABLE       " " "NO"
91855>>>>>            End 
91855>>>>>>
91855>>>>>            Writeln channel iCh CS_TABLE_CHARACTER_FORMAT " " sANSI_OEM
91860>>>>>            Writeln channel iCh CS_USE_DUMMY_ZERO_DATE    " " "YES" // ToDo: We maybe need to paramerize this setting?  
91865>>>>>            If (bSysFile = True) Begin
91867>>>>>                Writeln channel iCh CS_SYSTEM_FILE        " " "YES" 
91872>>>>>            End  
91872>>>>>>
91872>>>>>            
91872>>>>>            If (bSysFile = False) Begin
91874>>>>>                Move (SizeOfArray(sIndexArray)) to iSize  
91875>>>>>                Move (SortArray(sIndexArray)) to sIndexArray
91876>>>>>                If (iSize > 0) Begin
91878>>>>>                    Writeln channel iCh (CS_PRIMARY_INDEX * String("0"))
91881>>>>>                    Writeln channel iCh // Just an empty line
91883>>>>>                End
91883>>>>>>
91883>>>>>                Decrement iSize                              
91884>>>>>                For iCount from 0 to iSize
91890>>>>>>
91890>>>>>                    Writeln channel iCh (CS_INDEX_NUMBER * String(iCount))
91893>>>>>                    Writeln channel iCh (CS_INDEX_NAME   * String(sIndexArray[iCount]))
91896>>>>>                    Writeln channel iCh
91898>>>>>                Loop
91899>>>>>>
91899>>>>>            End
91899>>>>>>
91899>>>>>        Send Seq_Close_Channel iCh 
91900>>>>>        
91900>>>>>        // Wait a sec for Windows to finish writing the file:
91900>>>>>        Sleep 1
91901>>>>>        
91901>>>>>        Function_Return (bOK = True)
91902>>>>>    End_Function
91903>>>>>    
91903>>>>>    // Message for changing .int files to use connection ID's
91903>>>>>    //
91903>>>>>    // Changes all ".int" files for the passed sDataPath to use a sConnectionID,
91903>>>>>    // OR changes an existing connection id to a new id.
91903>>>>>    // Pass the full path to the data folder and the name of the connection id (string value). 
91903>>>>>    // Pass a True for the bShowResult parameter to show work in progress (showln's).
91903>>>>>    Procedure SqlUtilChangeIntFilesToConnectionIDs String sDataPath String sConnectionID Boolean bShowResult
91905>>>>>        String sFileName sDriverID sDriverFile sConnectionString
91905>>>>>        String[] sFilesData
91906>>>>>        Boolean bExists bOK                               
91906>>>>>        Integer iSize iCount
91906>>>>>        
91906>>>>>        Get SqlUtilEnumerateIntFiles sDataPath to sFilesData
91907>>>>>        Move (SizeOfArray(sFilesData))    to iSize
91908>>>>>        If (iSize = 0) Begin
91910>>>>>            Send Info_Box "No .int files found! Nothing was changed."
91911>>>>>            Procedure_Return
91912>>>>>        End                                                          
91912>>>>>>
91912>>>>>        
91912>>>>>        Move (Trim(sConnectionID)) to sConnectionID
91913>>>>>        Get vFolderFormat sDataPath to sDataPath
91914>>>>>        Decrement iSize
91915>>>>>        For iCount from 0 to iSize
91921>>>>>>
91921>>>>>            Move sFilesData[iCount] to sFileName                                   
91922>>>>>            // This makes sure that we also can change an existing connection id to something new:
91922>>>>>            Get UtilChangeSourceCodeLine (sDataPath + sFileName) CS_SERVER_NAME (CS_SERVER_NAME * CS_DFCONNID + "=" + sConnectionID) bShowResult to bOK 
91923>>>>>        Loop                      
91924>>>>>>
91924>>>>>        
91924>>>>>        Get psDriverID to sDriverID
91925>>>>>        
91925>>>>>         // Finally also change the driver file e.g. MSSQLDRV.int file in the Data folder in case it has a "DFconnectionID xxxxID,SERVER..."
91925>>>>>        Move "" to sFileName
91926>>>>>        If (sDriverID = MSSQLDRV_ID) Begin
91928>>>>>            Move "MSSQLDrv.int" to sFileName
91929>>>>>        End                 
91929>>>>>>
91929>>>>>        If (sDriverID = DB2_DRV_ID) Begin
91931>>>>>            Move "DB2_Drv.int" to sFileName
91932>>>>>        End                                
91932>>>>>>
91932>>>>>        If (sDriverID = ODBC_DRV_ID) Begin
91934>>>>>            Move "ODBC_Drv.int" to sFileName
91935>>>>>        End                                 
91935>>>>>>
91935>>>>>        If (sFileName <> "") Begin     
91937>>>>>            Move "" to sDriverFile
91938>>>>>            Get_File_Path sFileName to sDriverFile
91939>>>>>            If (sDriverFile <> "") Begin                        
91941>>>>>                Get psConnectionString to sConnectionString
91942>>>>>                Get UtilChangeSourceCodeLine sDriverFile CS_SQLConnectionIDText (CS_SQLConnectionIDText * String(sConnectionID) + "," * String(sConnectionString) * String(",0")) bShowResult to bOK
91943>>>>>            End
91943>>>>>>
91943>>>>>        End
91943>>>>>>
91943>>>>>    End_Procedure
91944>>>>>
91944>>>>>    // Checks if the database exists in SQL. Returns = True if it does.
91944>>>>>    Function SqlUtilCheckIfDatabaseExists String sDatabase Returns Boolean
91946>>>>>        String[] sDatabaseArray
91947>>>>>        String sVal sServer sDriverID
91947>>>>>        Integer iCount iSize iPos
91947>>>>>        Boolean bExists            
91947>>>>>        tSQLConnection SQLConnection
91947>>>>>        tSQLConnection SQLConnection
91947>>>>>        
91947>>>>>        Move False to bExists                              
91948>>>>>        Get psDriverID to sDriverID
91949>>>>>        // DB2 doesn't need to have a "Database" name, so we always return True.
91949>>>>>        If (sDriverID = DB2_DRV_ID) Begin
91951>>>>>            Function_Return bExists
91952>>>>>        End                     
91952>>>>>>
91952>>>>>        
91952>>>>>        Get SqlUtilEnumerateDatabases sDriverID to sDatabaseArray
91953>>>>>        If (SizeOfArray(sDatabaseArray) = 0) Begin
91955>>>>>            Function_Return False
91956>>>>>        End
91956>>>>>>
91956>>>>>        
91956>>>>>        Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
91957>>>>>        Get ParseKeyWord SQLConnection.sConnectionString (CS_SQLIniDSNKeyword + "=") to sServer
91958>>>>>        If (sServer contains "/") Begin
91960>>>>>            Move (Pos("/", sServer)) to iPos
91961>>>>>            Move (Mid(sServer, 999, (iPos +1)))                        to sDatabase
91962>>>>>        End
91962>>>>>>
91962>>>>>        
91962>>>>>        Move (SizeOfArray(sDatabaseArray)) to iSize
91963>>>>>        Decrement iSize
91964>>>>>        For iCount from 0 to iSize
91970>>>>>>
91970>>>>>            Move sDatabaseArray[iCount] to sVal
91971>>>>>            If (Uppercase(sVal) = Uppercase(sDatabase)) Begin
91973>>>>>                Move True to bExists
91974>>>>>            End
91974>>>>>>
91974>>>>>        Loop
91975>>>>>>
91975>>>>>        
91975>>>>>        Function_Return bExists
91976>>>>>    End_Function
91977>>>>>        
91977>>>>>    // Checks if a table exists as an SQL table. Returns = True if it does.
