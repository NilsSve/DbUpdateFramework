91123>>>>>        
91123>>>>>        // This must be after copying data...    
91123>>>>>        If (Err = False) Begin
91125>>>>>            Set_Attribute DF_FILE_ROOT_NAME    of hTable to sRootName
91128>>>>>            Set_Attribute DF_FILE_DISPLAY_NAME of hTable to sDisplayName
91131>>>>>        End
91131>>>>>>
91131>>>>>        Move (not(Err)) to bOK
91132>>>>>        
91132>>>>>        Function_Return (bOK = True)
91133>>>>>    End_Function                 
91134>>>>>    
91134>>>>>    // Creates an SQL Table at the SQL end by its filelist number;
91134>>>>>    // Also creates a 'DUMMY' column because SQL doesn't like to create a table with no columns!  
91134>>>>>    Function SqlTableCreate Integer hTable Returns Boolean
91136>>>>>        String sTableName sSQLString sPath sVal sCreateTable sDriverID
91136>>>>>        Integer iRetval iDbType                      
91136>>>>>        Boolean bExists bOK
91136>>>>>        
91136>>>>>        Get psDriverID to sDriverID       
91137>>>>>        Get UtilTableHandleToString hTable to sTableName
91138>>>>>        Get SqlUtilCheckIfTableNameExists sTableName sDriverID to bExists
91139>>>>>        If (bExists = True) Begin
91141>>>>>            Function_Return False
91142>>>>>        End                      
91142>>>>>>
91142>>>>>        
91142>>>>>        Get psDataPathFirstPart to sPath
91143>>>>>        Get vFilePathExists (sPath + String(sTableName) + ".int") to bExists
91144>>>>>        
91144>>>>>        Get piDbType to iDbType
91145>>>>>        Get _SqlProperTableName sTableName to sTableName
91146>>>>>        Get _SqlFindKeyWord CI_SQLCreateTable iDbType to sCreateTable
91147>>>>>        Move (sCreateTable * String(sTableName) * "(Dummy Decimal(2,0))") to sSQLString
91148>>>>>        
91148>>>>>        Move False to Err               
91149>>>>>        Send SqlUtilExecuteQuery sSQLString sDriverID
91150>>>>>    
91150>>>>>        Function_Return (Err = False)
91151>>>>>    End_Function       
91152>>>>>    
91152>>>>>    // Same as SqlTableCreate but creates an SQL Table at the SQL end by a table name;
91152>>>>>    // Also creates a 'DUMMY' column because SQL doesn't like to create a table with no columns!  
91152>>>>>    Function SqlTableCreateByTableName String sTableName  Returns Boolean
91154>>>>>        String sSQLString sPath sVal sCreateTable sDriverID
91154>>>>>        Integer iRetval iDbType                      
