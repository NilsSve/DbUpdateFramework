93514>>>>>
93514>>>>>    // We might have a split Sql script where the info about which database to use is
93514>>>>>    // put on top of the Sql script, we then need to save it to be able to retrieve it later and
93514>>>>>    // insert it for scriplets to come after the first one.
93514>>>>>    Function _SqlFormatStatement String sStmt Returns String
93516>>>>>        String sUseDatabase sTmp sUseKeyWord sCreateViewKeyWord sDBOKeyWord sNoCountKeyWord sDriverID
93516>>>>>        Integer iStart iEnd iDbType
93516>>>>>        Boolean bOK
93516>>>>>        
93516>>>>>        Get piDbType to iDbType 
93517>>>>>        Get psDriverID to sDriverID
93518>>>>>        Get _SqlFindKeyWord CI_SQLUse          to sUseKeyWord  
93519>>>>>        Get _SqlFindKeyWord CI_SQLSetNoCountOn to sNoCountKeyWord
93520>>>>>        Get _SqlFindKeyWord CI_SQLCreateView   to sCreateViewKeyWord            
93521>>>>>        Get _SqlFindKeyWord CI_SQLDBO          to sDBOKeyWord 
93522>>>>>        Move (Replaces(" ", sStmt, "")) to sTmp
93523>>>>>        If (Uppercase(sTmp) contains (sUseKeyWord +"[")) Begin
93525>>>>>            Move (Pos("[", (Uppercase(sTmp)))) to iStart
93526>>>>>            Move (Pos("]", sTmp)) to iEnd
93527>>>>>            Move (Mid(sTmp, (iEnd -iStart +1), iStart)) to sUseDatabase
93528>>>>>            Move (sUseKeyWord * sUseDatabase + " ") to sUseDatabase
93529>>>>>            Set Private.psUseDatabase to sUseDatabase
93530>>>>>        End
93530>>>>>>
93530>>>>>        Else Begin   
93531>>>>>            Move (Uppercase(sStmt)) to sTmp
93532>>>>>
93532>>>>>            // A "Create View" statement _must_ be the very first words in a Sql statement.
93532>>>>>            If (not(sTmp contains sCreateViewKeyWord)) Begin
93534>>>>>                Get Private.psUseDatabase to sUseDatabase
93535>>>>>                Move (Insert(sUseDatabase, sStmt, 1)) to sStmt
93536>>>>>            End 
93536>>>>>>
93536>>>>>            
93536>>>>>            // This is a bit special to place here but was done so because it was easier that way.
93536>>>>>            // We will get an error when trying to create a view if it already exists.
93536>>>>>            // So to avoid such errors; we first remove it & then recreate it.
93536>>>>>            Else If (sTmp contains sCreateViewKeyWord) Begin 
93539>>>>>                // Make sure we only have one space between statements/words.  
93539>>>>>                Move (Replaces("  ", sTmp, " ")) to sTmp
93540>>>>>                Move (Replace(sCreateViewKeyWord, sTmp, "")) to sTmp
93541>>>>>                Move (Trim(sTmp)) to sTmp
93542>>>>>                Move (Pos(" ", sTmp)) to iEnd
93543>>>>>                Move (Left(sTmp, iEnd)) to sTmp
93544>>>>>                If ((not(sTmp contains ("[" + sDBOKeyWord + "]."))) and (not(sTmp contains (sDBOKeyWord + ".")))) Begin
93546>>>>>                    Move (sDBOKeyWord + "." + Trim(sTmp)) to sTmp
93547>>>>>                End  
93547>>>>>>
93547>>>>>                Move (Trim(sTmp)) to sTmp
93548>>>>>                // Remove data view as it already exists!
93548>>>>>                Get SqlViewRemove sDriverID sTmp to bOK
93549>>>>>            End
93549>>>>>>
93549>>>>>        End
93549>>>>>>
93549>>>>>
93549>>>>>        Function_Return sStmt    
93550>>>>>    End_Function
93551>>>>>    
93551>>>>>    // Returns the proper Sql language key word(s) for the passed SQL key-word constant
93551>>>>>    Function _SqlFindKeyWord Integer iSQLKeywordConstant Returns String
93553>>>>>        String sRetval         
93553>>>>>        Integer iDbType iSize iItem iIndex
93553>>>>>        tSQLKeyWords[] SQLKeywordArray 
93553>>>>>        tSQLKeyWords[] SQLKeywordArray 
93554>>>>>        tSQLKeyWords   SQLKeyWords
93554>>>>>        tSQLKeyWords   SQLKeyWords
93554>>>>>        
93554>>>>>        // Sql back-end type. E.g. MS-SQL, MySQL, Oracle, DB2...
93554>>>>>        Get piDbType to iDbType
93555>>>>>        Move iDbType             to SQLKeyWords.iSQLDbType
93556>>>>>        Move iSQLKeywordConstant to SQLKeyWords.iSQLWord
93557>>>>>         
93557>>>>>        Get paSQLKeywordArray to SQLKeywordArray
93558>>>>>        Move (SearchArray(SQLKeyWords, SQLKeywordArray, Self, RefFunc(CompareFindSQLKeyWords))) to iIndex
93559>>>>>        Move SQLKeywordArray[iIndex].sSQLPhrase to sRetval
93560>>>>>
93560>>>>>        Function_Return sRetval
93561>>>>>    End_Function
93562>>>>>    
93562>>>>>    // Function will "clean/sanitize" the script by removing all comments and blank lines.
93562>>>>>    Function _SqlUtilSanitizeScript tSQLScriptArray SqlScriptArray Returns tSQLScriptArray[] 
93564>>>>>        String[] sSQLScriptArray
93565>>>>>        String sText sLine sTmp sCommentStart sCommentEnd sDashComment
93565>>>>>        Integer iCh iSize iArgSize iPos iCount
93565>>>>>        Boolean bCommentStart bCommentEnd bDashComment
93565>>>>>        
93565>>>>>        Move False to bCommentStart
93566>>>>>        Move False to bCommentEnd 
93567>>>>>        Move False to bDashComment                                    
93568>>>>>        Move "/*"  to sCommentStart   // These are the standard comment start & stop tokens...
93569>>>>>        Move "*/"  to sCommentEnd
93570>>>>>        Move "--"  to sDashComment    // ...but a comment can also start with two dashes "--".
93571>>>>>
93571>>>>>        Move (SizeOfArray(SqlScriptArray.sSQLScriptArray)) to iSize
93572>>>>>        Decrement iSize
93573>>>>>        Move "" to sText  
93574>>>>>        
93574>>>>>        For iCount from 0 to iSize
93580>>>>>>
93580>>>>>            Move SqlScriptArray.sSQLScriptArray[iCount] to sLine
93581>>>>>            Move (Trim(sLine)) to sTmp
93582>>>>>            If (sTmp <> "") Begin
93584>>>>>                Move (Left(sTmp, 2) = sDashComment) to bDashComment
93585>>>>>                If (bCommentStart = False) Begin
93587>>>>>                    Move (Left(sTmp, 2) = sCommentStart) to bCommentStart
93588>>>>>                    If (bCommentStart = False) Begin
93590>>>>>                    End
93590>>>>>>
93590>>>>>                End
93590>>>>>>
93590>>>>>                Move (sTmp contains sCommentEnd) to bCommentEnd
93591>>>>>                If (bCommentEnd = True) Begin
93593>>>>>                    Move False to bCommentStart
93594>>>>>                End
93594>>>>>>
93594>>>>>                If (bDashComment = False and bCommentStart = False and bCommentEnd = False) Begin
93596>>>>>                    Move sLine to sSQLScriptArray[SizeOfArray(sSQLScriptArray)] 
93597>>>>>                End
93597>>>>>>
93597>>>>>            End
93597>>>>>>
93597>>>>>        Loop 
93598>>>>>>
93598>>>>>        
93598>>>>>        // Update the retval struct array:    
93598>>>>>        Move sSQLScriptArray to SqlScriptArray.sSQLScriptArray
93599>>>>>        Function_Return SqlScriptArray
93600>>>>>    End_Function
93601>>>>>
93601>>>>>    // *** Database API Functions: ***
93601>>>>>    // Instead of using Sql Scripts (ESQL), we can opt to use the DataFlex Database API's to 
93601>>>>>    // make changes/updates to the database.
93601>>>>>    //
93601>>>>>    //
93601>>>>>    // This might not do what you think - Here's what it does:
93601>>>>>    // It checks that the passed hTable TableName in filelist.cfg is exactly the same as at the SQL back-end.
93601>>>>>    // If that is True; it creates an .int file for it and changes Filelist.cfg to point
93601>>>>>    // to the SQL table.
93601>>>>>    // Typical usage for this function is when an entry exists in the Filelist for a table and the table
93601>>>>>    // already exists in SQL. 
93601>>>>>    // This is a bit fiddly as the DF_FILE_PHYSICAL_NAME attribute can only be set inside a 
93601>>>>>    // Structure_Start ... Structure_End operation when creating a NEW table. Thus it cannot be set when 
93601>>>>>    // restructuring an existing table.
93601>>>>>    Function ApiTableAttachToSQL Handle hTable Boolean bUseConnID Returns Boolean
93603>>>>>        Boolean bExists bOpened bOK bSystemFile bMertechDriver bUseConnectionID
93603>>>>>        String sDriverID sTableName sConnectionID sConnectionString sDisplayName sRootName sLogicalName sPhysicalName sSchema
93603>>>>>        Handle hToTable 
93603>>>>>        Integer iPos
93603>>>>>        
93603>>>>>        Move True to bUseConnectionID
93604>>>>>        If (num_arguments > 1) Begin
93606>>>>>            Move bUseConnID to bUseConnectionID
93607>>>>>        End                                    
93607>>>>>>
93607>>>>>        
93607>>>>>        Get psDriverID to sDriverID
93608>>>>>        // If the table doesn't exist on the SQL back-end we do nothing.
93608>>>>>        Get SqlUtilCheckIfTableHandleExists hTable sDriverID to bExists
93609>>>>>        If (bExists = False) Begin
93611>>>>>            Function_Return False
93612>>>>>        End
93612>>>>>>
93612>>>>>        
93612>>>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
93613>>>>>        If (bOK = False) Begin
93615>>>>>            Function_Return False
93616>>>>>        End
93616>>>>>>
93616>>>>>        
93616>>>>>        // Then we need to check that the function hasn't been called before; which in case
93616>>>>>        // we do nothing
93616>>>>>        Get SQLUtilTableIsAttached sDriverID hTable to bExists
93617>>>>>        If (bExists = True) Begin
93619>>>>>            Function_Return False
93620>>>>>        End
93620>>>>>>
93620>>>>>        
93620>>>>>        Get psConnectionID     to sConnectionID
93621>>>>>        Get psConnectionString to sConnectionString 
93622>>>>>        If (sConnectionID = "" or sConnectionString = "") Begin
93624>>>>>            Error DFERR_PROGRAM ("An SQL connection has NOT been setup correctly. Could not attach table:" * String(hTable) * "to SQL")
93625>>>>>>
93625>>>>>            Function_Return False
93626>>>>>        End                      
93626>>>>>>
93626>>>>>
93626>>>>>        Get psSchema to sSchema
93627>>>>>        If (sSchema = "") Begin
93629>>>>>            Get _SqlFindKeyWord CI_SQLDBO to sSchema  
93630>>>>>        End
93630>>>>>>
93630>>>>>
93630>>>>>        Get IsMertechDriver sDriverID to bMertechDriver
93631>>>>>        
93631>>>>>        // Mertech drivers don't use connection id's, so if the passed bUseConnectionID = True that
93631>>>>>        // was a programmer's error and we adjust for it here.
93631>>>>>        If (bMertechDriver = True) Begin
93633>>>>>            Move False to bUseConnectionID
93634>>>>>        End
93634>>>>>>
93634>>>>>            
93634>>>>>        // If we should use a connection id we need to check it exists; 
93634>>>>>        // else we create it before attempting creating the table
93634>>>>>        If (bUseConnectionID = True) Begin  
93636>>>>>            Get AutoConnectionIDLogin to bOK
93637>>>>>            If (bOk = False) Begin
93639>>>>>                Error DFERR_PROGRAM ("The Connection ID:" * sConnectionID * "could not be created and therefor the table can't be created.")
93640>>>>>>
93640>>>>>                Function_Return False
93641>>>>>            End
93641>>>>>>
93641>>>>>        End
93641>>>>>>
93641>>>>>            
93641>>>>>        Get_Attribute DF_FILE_ROOT_NAME of hTable to sRootName
93644>>>>>        Get _TableNameOnly sRootName to sRootName             
93645>>>>>        If (sRootName = "") Begin
93647>>>>>            Function_Return False
93648>>>>>        End
93648>>>>>>
93648>>>>>        Move (sRootName + ".int")                    to sPhysicalName       
93649>>>>>        Get_Attribute DF_FILE_LOGICAL_NAME of hTable to sLogicalName
93652>>>>>        Get_Attribute DF_FILE_DISPLAY_NAME of hTable to sDisplayName
93655>>>>>        If (sDisplayName contains ".") Begin
93657>>>>>            Move (Pos(".", sDisplayName)) to iPos  
93658>>>>>            Move (Mid(sDisplayName, 200 ,(iPos + 1))) to sDisplayName
93659>>>>>            Move (sSchema + "." + sDisplayName)       to sDisplayName
93660>>>>>        End
93660>>>>>>
93660>>>>>        If (not(Lowercase(sDisplayName) contains Lowercase(sSchema + "."))) Begin
93662>>>>>            Move (Lowercase(sSchema) + "." + sDisplayName) to sDisplayName
93663>>>>>        End
93663>>>>>>
93663>>>>>        
93663>>>>>        // ToDo: Needs to be revised. Should be able to connect to SQL without table already exist?
93663>>>>>        Open hTable Mode DF_EXCLUSIVE
93665>>>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpened
93668>>>>>        If (bOpened = False) Begin 
93670>>>>>            Error DFERR_PROGRAM ("Function ApiTableAttachToSQL - Could not open table number:" * String(hTable) * sLogicalName)
93671>>>>>>
93671>>>>>            Function_Return False
93672>>>>>        End                      
93672>>>>>>
93672>>>>>        
93672>>>>>        If (ghoProgressBar <> 0) Begin
93674>>>>>            Send DoAdvance of ghoProgressBar
93675>>>>>        End
93675>>>>>>
93675>>>>>        // Note: The hToTable will get changed by the Structure_xxx command...
93675>>>>>        Move hTable to hToTable 
93676>>>>>        Move False to Err       
93677>>>>>        
93677>>>>>        // We now create a stub .int file and after Structure_end and also change the Filelist.cfg,
93677>>>>>        // then we do a pseudo .int file change with the "SqlUtilUpdateIntFile" function. After that we have
93677>>>>>        // a proper and updated .int file.
93677>>>>>        Get_Attribute DF_FILE_IS_SYSTEM_FILE of hTable to bSystemFile  
93680>>>>>        Get SqlUtilCreateIntFile hTable sDriverID sConnectionID True bSystemFile to bOK
93681>>>>>        
93681>>>>>        Structure_Start hToTable sDriverID
93682>>>>>            If (bUseConnectionID = True) Begin  
93684>>>>>                Set_Attribute DF_FILE_LOGIN     of hToTable to (CS_DFCONNID + "=" + sConnectionID)
93687>>>>>            End
93687>>>>>>
93687>>>>>            Else Begin
93688>>>>>                Set_Attribute DF_FILE_LOGIN     of hToTable to sConnectionString
93691>>>>>            End
93691>>>>>>
93691>>>>>            Set_Attribute DF_FILE_OWNER         of hToTable to (Lowercase(sSchema))
93694>>>>>            // For unknown reason the above sometimes triggers an error and it doesn't help to try to trap the error; so we cheat...
93694>>>>>            Move False to Err
93695>>>>>            Move 0 to LastErr
93696>>>>>        Structure_End hToTable 
93698>>>>>        
93698>>>>>        Move (not(Err)) to bOK
93699>>>>>        If (bOK = True) Begin
93701>>>>>            // The attributes set above will always trigger an error
93701>>>>>            // We also adjust the Filelist entries
93701>>>>>            Set_Attribute DF_FILE_ROOT_NAME    of hTable to (sDriverID + ":" + sRootName)
93704>>>>>            Set_Attribute DF_FILE_LOGICAL_NAME of hTable to sLogicalName
93707>>>>>            Set_Attribute DF_FILE_DISPLAY_NAME of hTable to sDisplayName
93710>>>>>            
93710>>>>>            // This pseudo updates the .int file to make it up-to-date with the SQL back-end.
93710>>>>>            Get SqlUtilUpdateIntFile hTable to bOK
93711>>>>>        End
93711>>>>>>
93711>>>>>          
93711>>>>>        Function_Return (bOK = True)
93712>>>>>    End_Function
93713>>>>>    
93713>>>>>    // Sample usage:    
93713>>>>>    //    Get ApiTableChangeAttribute SysInfo.File_Number DF_FILE_IS_SYSTEM_FILE True to bOK
93713>>>>>    //    Get ApiTableChangeAttribute OrderHea.File_Number DF_FILE_REUSE_DELETED DF_FILE_DELETED_NOREUSE to bOK
93713>>>>>    Function ApiTableChangeAttribute Handle hTable Integer iAttribute Integer iValue Returns Boolean
93715>>>>>        Boolean bOK
93715>>>>>        
93715>>>>>        Get AutoConnectionIDLogin to bOK
93716>>>>>        Move False to Err
93717>>>>>        Open hTable Mode DF_EXCLUSIVE
93719>>>>>        Structure_Start hTable
93720>>>>>            Set_Attribute iAttribute of hTable to iValue
93723>>>>>        Structure_End hTable 
93725>>>>>
93725>>>>>        Function_Return (Err = False)
93726>>>>>    End_Function
93727>>>>>    
93727>>>>>    // To use a filelist slot for the passed FileName, TableName & DisplayName,
93727>>>>>    // or to change the filelist slot names.    
93727>>>>>    Function ApiTableChangeFileListSlot String sRootName String sLogicalName String sDisplayName Handle hTable String sDriverID Returns Boolean       
93729>>>>>        Move False to Err
93730>>>>>        Boolean bExists
93730>>>>>        
93730>>>>>        Move False to Err
93731>>>>>        Get UtilTableNumberIsInUse hTable to bExists
93732>>>>>        If (bExists = False) Begin
93734>>>>>            Function_Return False
93735>>>>>        End
93735>>>>>>
93735>>>>>
93735>>>>>        If (ghoProgressBar <> 0) Begin
93737>>>>>            Send DoAdvance of ghoProgressBar
93738>>>>>        End
93738>>>>>>
93738>>>>>        // If all strings are empty it means that we should remove this entry from filelist.
93738>>>>>        If (sRootName = "" and sLogicalName = "" and sDisplayName = "") Begin
93740>>>>>            Set_Attribute DF_FILE_ROOT_NAME     of hTable to ""
93743>>>>>            Set_Attribute DF_FILE_LOGICAL_NAME  of hTable to ""
93746>>>>>            Set_Attribute DF_FILE_DISPLAY_NAME  of hTable to ""
93749>>>>>            Function_Return (Err = False) // And we're done.
93750>>>>>        End
93750>>>>>>
93750>>>>>        
93750>>>>>        If (sDriverID <> DATAFLEX_ID) Begin
93752>>>>>            Set_Attribute DF_FILE_ROOT_NAME of hTable to (sDriverID + ":" + sRootName)
93755>>>>>        End 
93755>>>>>>
93755>>>>>        Else Begin
93756>>>>>            Set_Attribute DF_FILE_ROOT_NAME of hTable to sRootName
93759>>>>>        End
93759>>>>>>
93759>>>>>            
93759>>>>>        Set_Attribute DF_FILE_LOGICAL_NAME  of hTable to sLogicalName
93762>>>>>        
93762>>>>>        If (sDriverID <> DATAFLEX_ID and not(Uppercase(sDisplayName) contains "DBO.")) Begin
93764>>>>>            Set_Attribute DF_FILE_DISPLAY_NAME  of hTable to ("dbo." + sDisplayName)
93767>>>>>        End
93767>>>>>>
93767>>>>>        Else Begin
93768>>>>>            Set_Attribute DF_FILE_DISPLAY_NAME  of hTable to sDisplayName
93771>>>>>        End
93771>>>>>>
93771>>>>>        
93771>>>>>        Function_Return (Err = False)
93772>>>>>    End_Function
