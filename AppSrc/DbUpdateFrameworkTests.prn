85410>>>>>            Get GetIndexesForSelectedRows to SelRowsIndexes
85411>>>>>        End
85411>>>>>>
85411>>>>>        Else Begin
85412>>>>>            Get SelectedRow of hoDataSource to iRow
85413>>>>>            If (iRow<>-1) Begin
85415>>>>>                Move iRow to SelRowsIndexes[0]
85416>>>>>            End
85416>>>>>>
85416>>>>>        End
85416>>>>>>
85416>>>>>        
85416>>>>>        Set pbCanceled to False
85417>>>>>        Set pSelectedRows to SelRowsIndexes
85418>>>>>        
85418>>>>>        Get peUpdateMode to eUpdateMode
85419>>>>>        // if non-invoking there is by definition, no move value out
85419>>>>>        If (eUpdateMode<>umPromptNonInvoking) Begin
85421>>>>>            
85421>>>>>            If (eUpdateMode=umPromptValue) Begin
85423>>>>>                Send OnMoveValueOutByValue
85424>>>>>            End
85424>>>>>>
85424>>>>>            Else If (eUpdateMode=umPromptCustom) Begin
85427>>>>>                Send OnMoveValueOutByCustom
85428>>>>>            End
85428>>>>>>
85428>>>>>                Get phmPromptUpdateCallback to hmCallBack
85429>>>>>                If hmCallBack Begin
85431>>>>>                    Send hmCallBack of hoInvokingObject Self
85432>>>>>                End
85432>>>>>>
85432>>>>>        End
85432>>>>>>
85432>>>>>
85432>>>>>        Send Close_Panel
85433>>>>>    End_Procedure
