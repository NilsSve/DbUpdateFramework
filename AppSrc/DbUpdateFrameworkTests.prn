89131>>>>>>>>>>>Class cDbUpdateGenericDatabaseDriver is a cObject
89132>>>>>>>>>>>    Procedure Construct_Object
89134>>>>>>>>>>>        Forward Send Construct_Object
89136>>>>>>>>>>>        Property String psDriverID DATAFLEX_ID
89137>>>>>>>>>>>    End_Procedure 
89138>>>>>>>>>>>    
89138>>>>>>>>>>>    Function ServerKeyword Returns String
89140>>>>>>>>>>>        Function_Return CS_SQLIniDSNKeyword
89141>>>>>>>>>>>    End_Function
89142>>>>>>>>>>>    
89142>>>>>>>>>>>    Function ConstructConnectionString String sServer String sDatabase Boolean bTrusted String sUserID String sPassword Returns String
89144>>>>>>>>>>>        String sConnect
89144>>>>>>>>>>>        
89144>>>>>>>>>>>        Move (sConnect * ServerKeyword(Self) + "=" + sServer) to sConnect
89145>>>>>>>>>>>        If (sDatabase <> "") Begin
89147>>>>>>>>>>>            Move (sConnect * ";" + CS_SQLIniDatabaseKeyword + "=" + sDatabase) to sConnect
89148>>>>>>>>>>>        End
89148>>>>>>>>>>>>
89148>>>>>>>>>>>        If (bTrusted = True) Begin
89150>>>>>>>>>>>            Move (sConnect * ";" + CS_SQLIniTrustedKeyword + "=Yes") to sConnect
89151>>>>>>>>>>>        End
89151>>>>>>>>>>>>
89151>>>>>>>>>>>        Else Begin
89152>>>>>>>>>>>            Move (sConnect * ";" + CS_SQLIniUIDKeyword + "=" + sUserID * ";" + CS_SQLIniPWDKeyword + "=" + sPassword) to sConnect
89153>>>>>>>>>>>        End
89153>>>>>>>>>>>>
89153>>>>>>>>>>>        Function_Return sConnect
89154>>>>>>>>>>>    End_Function
89155>>>>>>>>>>>    
89155>>>>>>>>>>>    Function DbLogin String sConnectionString String sServer String sDatabase Boolean bTrusted String sUserID String sPassword Returns Boolean
89157>>>>>>>>>>>        Boolean bLoginSuccessful
89157>>>>>>>>>>>        String sDriverID 
89157>>>>>>>>>>>        
89157>>>>>>>>>>>        Get psDriverID to sDriverID
89158>>>>>>>>>>>        Move 0 to LastErr  // Do NOT use the Err flag, it will be set true by the login command although it is successful.
89159>>>>>>>>>>>        If (bTrusted = False) Begin
89161>>>>>>>>>>>            Login sServer sUserId sPassword sDriverID
89163>>>>>>>>>>>        End 
89163>>>>>>>>>>>>
89163>>>>>>>>>>>        Else Begin
89164>>>>>>>>>>>            Login sConnectionString "" "" sDriverID
89166>>>>>>>>>>>        End
89166>>>>>>>>>>>>
89166>>>>>>>>>>>        Move (LastErr = 0) to bLoginSuccessful
89167>>>>>>>>>>>        Function_Return bLoginSuccessful
89168>>>>>>>>>>>    End_Function
89169>>>>>>>>>>>End_Class
89170>>>>>>>>>>>
