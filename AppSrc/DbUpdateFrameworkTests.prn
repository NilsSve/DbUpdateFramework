85370>>>>>        Set pbNeedsNewOrdering to False
85371>>>>>
85371>>>>>        Get pbAutoSeed to bAutoSeed
85372>>>>>
85372>>>>>        If (eUpdateMode=umPromptValue) Begin // else not used here intentionally
85374>>>>>            Get Value of hoInvokingObject to sValue
85375>>>>>            Set psSeedValue to sValue
85376>>>>>        End
85376>>>>>>
