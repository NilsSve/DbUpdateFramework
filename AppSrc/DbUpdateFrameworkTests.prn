85861>>>>>>>>>>>Class cCryptographer is a cObject
85862>>>>>>>>>>>    
85862>>>>>>>>>>>    // Procedure : Construct_Object
85862>>>>>>>>>>>    // Purpose   : Object constructor
85862>>>>>>>>>>>    Procedure Construct_Object
85864>>>>>>>>>>>        Forward Send Construct_Object
85866>>>>>>>>>>>
85866>>>>>>>>>>>        Property String     psProvider  MS_ENHANCED_PROV
85867>>>>>>>>>>>        Property Integer    piProvider  PROV_RSA_FULL
85868>>>>>>>>>>>        Property Integer    piCipher    CALG_RC4
85869>>>>>>>>>>>        Property Integer    piHash      CALG_MD5
85870>>>>>>>>>>>        
85870>>>>>>>>>>>        // Private properties
85870>>>>>>>>>>>        Property Handle     Private_phProv
85871>>>>>>>>>>>    End_Procedure
85872>>>>>>>>>>>    
85872>>>>>>>>>>>    
85872>>>>>>>>>>>    // Function : AcquireContext
85872>>>>>>>>>>>    // Purpose  : Acquire key container handle
85872>>>>>>>>>>>    Function AcquireContext Returns Handle
85874>>>>>>>>>>>        Integer iProvider
85874>>>>>>>>>>>        String sProvider
85874>>>>>>>>>>>        Handle hProv
85874>>>>>>>>>>>        Boolean bOk
85874>>>>>>>>>>>        Address addrProv
85874>>>>>>>>>>>        
85874>>>>>>>>>>>        Move 0 to hProv
85875>>>>>>>>>>>        Get piProvider to iProvider
85876>>>>>>>>>>>        Get psProvider to sProvider
85877>>>>>>>>>>>        
85877>>>>>>>>>>>        //  Determine address to be passed as provider
85877>>>>>>>>>>>        If (Trim(sProvider) <> "") Begin
85879>>>>>>>>>>>            Move (AddressOf(sProvider)) to addrProv
85880>>>>>>>>>>>        End
85880>>>>>>>>>>>>
85880>>>>>>>>>>>        Else Begin
85881>>>>>>>>>>>            Move 0 to addrProv
85882>>>>>>>>>>>        End
85882>>>>>>>>>>>>
85882>>>>>>>>>>>        
85882>>>>>>>>>>>        //  Acquire Crypto Context
85882>>>>>>>>>>>        Move (CryptAcquireContext(AddressOf(hProv),0,addrProv,iProvider,CRYPT_VERIFYCONTEXT)) to bOk
85883>>>>>>>>>>>        If (not(bOk) or hProv = 0) Begin
85885>>>>>>>>>>>            Move (CryptAcquireContext(AddressOf(hProv),0,addrProv,iProvider,CRYPT_NEWKEYSET ior CRYPT_VERIFYCONTEXT)) to bOk
85886>>>>>>>>>>>        End
85886>>>>>>>>>>>>
85886>>>>>>>>>>>        
85886>>>>>>>>>>>        If (not(bOk) or hProv = 0) Begin
85888>>>>>>>>>>>            // Fallback to original
85888>>>>>>>>>>>            Move (CryptAcquireContext(AddressOf(hProv),0,addrProv,iProvider,0)) to bOk
85889>>>>>>>>>>>            
85889>>>>>>>>>>>            If (not(bOk) or hProv = 0) Begin
85891>>>>>>>>>>>                Move (CryptAcquireContext(AddressOf(hProv),0,addrProv,iProvider,CRYPT_NEWKEYSET)) to bOk
85892>>>>>>>>>>>            End
85892>>>>>>>>>>>>
85892>>>>>>>>>>>        End
85892>>>>>>>>>>>>
85892>>>>>>>>>>>        Set Private_phProv to hProv
85893>>>>>>>>>>>        
85893>>>>>>>>>>>        Function_Return hProv
85894>>>>>>>>>>>    End_Function
85895>>>>>>>>>>>    
85895>>>>>>>>>>>    // Function : ReleaseContext
85895>>>>>>>>>>>    // Purpose  : Releases key container handle
85895>>>>>>>>>>>    Function ReleaseContext Handle hProv Returns Boolean
85897>>>>>>>>>>>        Function_Return (CryptReleaseContext(hProv,0))
85898>>>>>>>>>>>    End_Function
85899>>>>>>>>>>>    
85899>>>>>>>>>>>    // Function : CreateHash
85899>>>>>>>>>>>    // Purpose  : Creates hash object
85899>>>>>>>>>>>    Function CreateHash Handle hProv Returns Handle
85901>>>>>>>>>>>        Integer iAlgorithm
85901>>>>>>>>>>>        Handle hHash
85901>>>>>>>>>>>        Boolean bOk
85901>>>>>>>>>>>        
85901>>>>>>>>>>>        Move 0 to hHash
85902>>>>>>>>>>>        Get piHash to iAlgorithm
85903>>>>>>>>>>>        Move (CryptCreateHash(hProv,iAlgorithm,0,0,AddressOf(hHash))) to bOk
85904>>>>>>>>>>>        
85904>>>>>>>>>>>        Function_Return hHash
85905>>>>>>>>>>>    End_Function
85906>>>>>>>>>>>    
85906>>>>>>>>>>>    // Function : DestroyHash
85906>>>>>>>>>>>    // Purpose  : Destroys the hash object
85906>>>>>>>>>>>    Function DestroyHash Handle hHash Returns Boolean
85908>>>>>>>>>>>        Function_Return (CryptDestroyHash(hHash))
85909>>>>>>>>>>>    End_Function
85910>>>>>>>>>>>    
85910>>>>>>>>>>>    // Function : HashData
85910>>>>>>>>>>>    // Purpose  : Adds data to hash object
85910>>>>>>>>>>>    Function HashData Handle hHash String sData Returns Boolean
85912>>>>>>>>>>>        Function_Return (CryptHashData(hHash,AddressOf(sData),Length(sData),0))
85913>>>>>>>>>>>    End_Function
85914>>>>>>>>>>>    
85914>>>>>>>>>>>    // Function : DeriveKey
85914>>>>>>>>>>>    // Purpose  : Generates session key
85914>>>>>>>>>>>    Function DeriveKey Handle hProv Handle hHash Returns Handle
85916>>>>>>>>>>>        Integer iAlgorithm
85916>>>>>>>>>>>        Handle hKey
85916>>>>>>>>>>>        Boolean bOk
85916>>>>>>>>>>>        
85916>>>>>>>>>>>        Move 0 to hKey
85917>>>>>>>>>>>        Get piCipher to iAlgorithm
85918>>>>>>>>>>>        Move (CryptDeriveKey(hProv,iAlgorithm,hHash,CRYPT_EXPORTABLE,AddressOf(hKey))) to bOk
85919>>>>>>>>>>>        
85919>>>>>>>>>>>        Function_Return hKey
85920>>>>>>>>>>>    End_Function
85921>>>>>>>>>>>    
85921>>>>>>>>>>>    // Function : ImportPlainTextKey
85921>>>>>>>>>>>    // Purpose  : Imports a plain text key
85921>>>>>>>>>>>    Function ImportPlainTextKey Handle hProv UChar[] ucaKey Returns Handle
85923>>>>>>>>>>>        tPLAINTEXTKEYBLOB blobhead
85923>>>>>>>>>>>        tPLAINTEXTKEYBLOB blobhead
85923>>>>>>>>>>>        Boolean   bSuccess
85923>>>>>>>>>>>        Handle    hKey
85923>>>>>>>>>>>        Integer   iHeadSize iKeySize
85923>>>>>>>>>>>        UChar[]   ucaKeyblob
85924>>>>>>>>>>>        Integer iVoid
85924>>>>>>>>>>>    
85924>>>>>>>>>>>        Move (SizeOfType(tPLAINTEXTKEYBLOB)) to iHeadSize
85925>>>>>>>>>>>        Move (SizeOfArray(ucaKey)) to iKeySize
85926>>>>>>>>>>>    
85926>>>>>>>>>>>        Move PLAINTEXTKEYBLOB to blobhead.hdr.bType
85927>>>>>>>>>>>        Move CUR_BLOB_VERSION   to blobhead.hdr.bVersion
85928>>>>>>>>>>>        Get piCipher            to blobhead.hdr.aiKeyAlg
85929>>>>>>>>>>>        Move iKeySize           to blobhead.dwKeySize
85930>>>>>>>>>>>    
85930>>>>>>>>>>>        Move (ResizeArray(ucaKeyblob, iHeadSize)) to ucaKeyblob
85931>>>>>>>>>>>        Move (CopyMemory(AddressOf(ucaKeyblob), AddressOf(blobhead), iHeadSize)) to iVoid
85932>>>>>>>>>>>        Move (AppendArray(ucaKeyblob, ucaKey)) to ucaKeyblob
85933>>>>>>>>>>>    
85933>>>>>>>>>>>        Move 0 to hKey
85934>>>>>>>>>>>        Move (CryptImportKey(hProv, AddressOf(ucaKeyblob), SizeOfArray(ucaKeyblob), 0, 0, AddressOf(hKey))) to bSuccess
85935>>>>>>>>>>>        If (not(bSuccess)) Begin 
85937>>>>>>>>>>>            Move (ShowLastError()) to iVoid
85938>>>>>>>>>>>        End
85938>>>>>>>>>>>>
85938>>>>>>>>>>>    
85938>>>>>>>>>>>        Function_Return hKey
85939>>>>>>>>>>>    End_Function
85940>>>>>>>>>>>
85940>>>>>>>>>>>    // Function : DestroyKey
85940>>>>>>>>>>>    // Purpose  : Destroys the key
85940>>>>>>>>>>>    Function DestroyKey Handle hKey Returns Boolean
85942>>>>>>>>>>>        Function_Return (CryptDestroyKey(hKey))
85943>>>>>>>>>>>    End_Function
85944>>>>>>>>>>>    
85944>>>>>>>>>>>    // Function : KeyParameter
85944>>>>>>>>>>>    // Purpose  : Retrieves key data
85944>>>>>>>>>>>    Function KeyParameter Handle hKey Integer iQuery Returns Integer
85946>>>>>>>>>>>        Integer iBuffer iLen
85946>>>>>>>>>>>        Boolean bOk
85946>>>>>>>>>>>        
85946>>>>>>>>>>>        Move (SizeOfType(Integer)) to iLen
85947>>>>>>>>>>>        Move (CryptGetKeyParam(hKey,iQuery,AddressOf(iBuffer),AddressOf(iLen),0)) to bOk
85948>>>>>>>>>>>        Function_Return iBuffer
85949>>>>>>>>>>>    End_Function
85950>>>>>>>>>>>    
85950>>>>>>>>>>>    // Function : HashValue
85950>>>>>>>>>>>    // Purpose  : Retrieves a hash value
85950>>>>>>>>>>>    Function HashValue Handle lhHash Returns String
85952>>>>>>>>>>>        Pointer lpSize
85952>>>>>>>>>>>        Pointer lpHash
85952>>>>>>>>>>>        String  lsSize
85952>>>>>>>>>>>        String  lsHash
85952>>>>>>>>>>>        Integer liResult
85952>>>>>>>>>>>
85952>>>>>>>>>>>        Move (Repeat(Character(0),4)) to lsSize
85953>>>>>>>>>>>        GetAddress of lsSize to lpSize
85954>>>>>>>>>>>
85954>>>>>>>>>>>        Move (CryptGetHashParam(lhHash,HP_HASHVAL,0,lpSize,0)) to liResult
85955>>>>>>>>>>>        If (liResult = 0) Function_Return ""
85958>>>>>>>>>>>
85958>>>>>>>>>>>        Move (Repeat(Character(0),BytesTodWord(lsSize,1))) to lsHash
85959>>>>>>>>>>>        GetAddress of lsHash to lpHash
85960>>>>>>>>>>>
85960>>>>>>>>>>>        Move (CryptGetHashParam(lhHash,HP_HASHVAL,lpHash,lpSize,0)) to liResult
85961>>>>>>>>>>>        If (liResult = 0) Function_Return ""
85964>>>>>>>>>>>
85964>>>>>>>>>>>        Function_Return lsHash
85965>>>>>>>>>>>    End_Function  // HashValue
85966>>>>>>>>>>>    
85966>>>>>>>>>>>            
85966>>>>>>>>>>>    // Function : Encrypt
85966>>>>>>>>>>>    // Purpose  : Encrypts data
85966>>>>>>>>>>>    Function Encrypt String sPassword String sData Returns String
85968>>>>>>>>>>>        Handle hProv hHash hKey
85968>>>>>>>>>>>        Integer iAlgorithm iDataLen iCipherLen iErr
85968>>>>>>>>>>>        Boolean bOk
85968>>>>>>>>>>>        
85968>>>>>>>>>>>        Get AcquireContext to hProv
85969>>>>>>>>>>>        If (hProv) Begin
85971>>>>>>>>>>>            Get CreateHash hProv to hHash
85972>>>>>>>>>>>            If (hHash) Begin
85974>>>>>>>>>>>                Get HashData hHash sPassword to bOk
85975>>>>>>>>>>>                If (bOk) Begin
85977>>>>>>>>>>>                    Get piCipher to iAlgorithm
85978>>>>>>>>>>>                    Get DeriveKey hProv hHash to hKey
85979>>>>>>>>>>>                End // If (bOk) Begin            
85979>>>>>>>>>>>>
85979>>>>>>>>>>>                Get DestroyHash hHash to bOk
85980>>>>>>>>>>>            End // If (hHash) Begin
85980>>>>>>>>>>>>
85980>>>>>>>>>>>            
85980>>>>>>>>>>>            If (hKey) Begin
85982>>>>>>>>>>>                //  First call to determine resulting data size
85982>>>>>>>>>>>                Move (Length(sData)) to iDataLen
85983>>>>>>>>>>>                Move (Length(sData)) to iCipherLen
85984>>>>>>>>>>>                Move (CryptEncrypt(hKey, 0, True, 0, 0, AddressOf(iCipherLen), iDataLen)) to bOk
85985>>>>>>>>>>>                
85985>>>>>>>>>>>                //  Reserve space in string
85985>>>>>>>>>>>                If (iDataLen < iCipherLen) Begin
85987>>>>>>>>>>>                    Move (sData + Repeat(" ", iCipherLen - iDataLen)) to sData
85988>>>>>>>>>>>                End
85988>>>>>>>>>>>>
85988>>>>>>>>>>>                
85988>>>>>>>>>>>                //  Call to really decrypt
85988>>>>>>>>>>>                Move (CryptEncrypt(hKey,0,True,0,AddressOf(sData),AddressOf(iDataLen),Length(sData))) to bOk
85989>>>>>>>>>>>                //If (not(bOk)) Begin
85989>>>>>>>>>>>                    //Move "" to sData
85989>>>>>>>>>>>                    //Move (GetLastError()) to iErr
85989>>>>>>>>>>>                //End
85989>>>>>>>>>>>                
85989>>>>>>>>>>>                Get DestroyKey hKey to bOk
85990>>>>>>>>>>>            End // If (hKey) Begin
85990>>>>>>>>>>>>
85990>>>>>>>>>>>            Get ReleaseContext hProv to bOk
85991>>>>>>>>>>>        End // If (hProv) Begin
85991>>>>>>>>>>>>
85991>>>>>>>>>>>        Function_Return sData
85992>>>>>>>>>>>    End_Function
85993>>>>>>>>>>>    
85993>>>>>>>>>>>    // Function : Decrypt
85993>>>>>>>>>>>    // Purpose  : Decrypts data
85993>>>>>>>>>>>    Function Decrypt String sPassword String sData Returns String
85995>>>>>>>>>>>        Handle hProv hHash hKey
85995>>>>>>>>>>>        Integer iAlgorithm iDataLen
85995>>>>>>>>>>>        Boolean bOk
85995>>>>>>>>>>>        
85995>>>>>>>>>>>        Get AcquireContext to hProv
85996>>>>>>>>>>>        If (hProv) Begin
85998>>>>>>>>>>>            Get CreateHash hProv to hHash
85999>>>>>>>>>>>            If (hHash) Begin
86001>>>>>>>>>>>                Get HashData hHash sPassword to bOk
86002>>>>>>>>>>>                If (bOk) Begin
86004>>>>>>>>>>>                    Get piCipher to iAlgorithm
86005>>>>>>>>>>>                    Get DeriveKey hProv hHash to hKey
86006>>>>>>>>>>>                End // If (bOk) Begin            
86006>>>>>>>>>>>>
86006>>>>>>>>>>>                Get DestroyHash hHash to bOk
86007>>>>>>>>>>>            End // If (hHash) Begin
86007>>>>>>>>>>>>
86007>>>>>>>>>>>            
86007>>>>>>>>>>>            If (hKey) Begin
86009>>>>>>>>>>>                Move (Length(sData)) to iDataLen
86010>>>>>>>>>>>                Move (CryptDecrypt(hKey,0,True,0,AddressOf(sData),AddressOf(iDataLen))) to bOk
86011>>>>>>>>>>>                //If (bOk = False) Move "" to sData
86011>>>>>>>>>>>                
86011>>>>>>>>>>>                //  Resulting dat can be shorter as the input string, in that case we shorten the result string
86011>>>>>>>>>>>                If (Length(sData) > iDataLen) Begin
86013>>>>>>>>>>>                    Move (Left(sData, iDataLen)) to sData
86014>>>>>>>>>>>                End
86014>>>>>>>>>>>>
86014>>>>>>>>>>>                
86014>>>>>>>>>>>                Get DestroyKey hKey to bOk
86015>>>>>>>>>>>            End // If (hKey) Begin
86015>>>>>>>>>>>>
86015>>>>>>>>>>>            Get ReleaseContext hProv to bOk
86016>>>>>>>>>>>        End // If (hProv) Begin
86016>>>>>>>>>>>>
86016>>>>>>>>>>>        Function_Return sData
86017>>>>>>>>>>>    End_Function
86018>>>>>>>>>>>    
86018>>>>>>>>>>>    //  Function : GenerateRandom
86018>>>>>>>>>>>    //  Purpose  : Generates random data.
86018>>>>>>>>>>>    Function GenerateRandom Integer iBytes Returns UChar[]
86020>>>>>>>>>>>        Handle hProv
86020>>>>>>>>>>>        UChar[] uaResult
86021>>>>>>>>>>>        Boolean bRes
86021>>>>>>>>>>>        
86021>>>>>>>>>>>        Get AcquireContext to hProv
86022>>>>>>>>>>>        
86022>>>>>>>>>>>        Move (ResizeArray(uaResult, iBytes)) to uaResult
86023>>>>>>>>>>>        Move (CryptGenRandom(hProv, iBytes, AddressOf(uaResult))) to bRes
86024>>>>>>>>>>>        
86024>>>>>>>>>>>        Get ReleaseContext hProv to bRes
86025>>>>>>>>>>>        
86025>>>>>>>>>>>        Function_Return uaResult
86026>>>>>>>>>>>    End_Function
86027>>>>>>>>>>>    
86027>>>>>>>>>>>    //  Function : GenerateRandomString
86027>>>>>>>>>>>    //  Purpose  : Generates random data and does a base64 encoding to properly present it as a string.
86027>>>>>>>>>>>    Function GenerateRandomString Integer iLenght Returns String
86029>>>>>>>>>>>        String sResult
86029>>>>>>>>>>>        UChar[] aData
86030>>>>>>>>>>>        Address pBase64
86030>>>>>>>>>>>        Integer iVoid
86030>>>>>>>>>>>
86030>>>>>>>>>>>        Get GenerateRandom iLenght to aData
86031>>>>>>>>>>>        
86031>>>>>>>>>>>        Move (Base64Encode(AddressOf(aData), iLenght)) to pBase64
86032>>>>>>>>>>>        Move pBase64 to sResult
86033>>>>>>>>>>>        Move (Free(pBase64)) to iVoid    
86034>>>>>>>>>>>        
86034>>>>>>>>>>>        Function_Return (Left(sResult, iLenght))
86035>>>>>>>>>>>    End_Function
86036>>>>>>>>>>>
86036>>>>>>>>>>>End_Class
86037>>>>>>>>>Use Base64Functions.pkg  
Including file: Base64Functions.pkg    (C:\Projects\DF18\DbUpdateFramework\AppSrc\Base64Functions.pkg)
86037>>>>>>>>>>>//> This package enables base64 encoding and decoding of strings:
86037>>>>>>>>>>>//>
86037>>>>>>>>>>>//>     Get EncodeString of oBase64Functions sValue to sValue
86037>>>>>>>>>>>//>     Get DecodeString of oBase64Functions sValue to sValue
86037>>>>>>>>>>>//>
86037>>>>>>>>>>>//> Remember to set the "max argument size" if dealing with very large
86037>>>>>>>>>>>//> strings.
86037>>>>>>>>>>>//>
86037>>>>>>>>>>>//> For 17.1 and later the functionality of this package is based on two functions (Base64Encode and
86037>>>>>>>>>>>//> Base64Decode) that are built into the runtime.
86037>>>>>>>>>>>//>
86037>>>>>>>>>>>//> But for versions up to and including 17.0 it's based on the vdfBase64.dll file that was obtained
86037>>>>>>>>>>>//> from DAE that have kindly allowed me to distribute it to other DF developers. Programs including
86037>>>>>>>>>>>//> this package will give off an error on start-up if vdfBase64.dll is not found in the /bin folder
86037>>>>>>>>>>>//> if the VDF runtime. You will find the DLL in the /programs folder of the StureApsPublicLib workspace
86037>>>>>>>>>>>
86037>>>>>>>>>>>Use VdfBase.pkg
86037>>>>>>>>>>>
86037>>>>>>>>>>>// Functions in vdfBase64.dll
86037>>>>>>>>>>>External_Function xxBase64Encode "vdfbase64Encode" vdfBase64.dll Pointer pBuffer Returns Integer
86038>>>>>>>>>>>External_Function xxBase64Decode "vdfbase64Decode" vdfBase64.dll Pointer pBuffer Returns Integer
86039>>>>>>>>>>>External_Function xxBase64Free   "vdfbase64Free"   vdfBase64.dll Pointer pBuffer Returns Integer
86040>>>>>>>>>>>
86040>>>>>>>>>>>// Structure
86040>>>>>>>>>>>Struct txxfBase64Buffer
86040>>>>>>>>>>>    Pointer pData
86040>>>>>>>>>>>    Integer iLength
86040>>>>>>>>>>>End_Struct 
86040>>>>>>>>>>>
86040>>>>>>>>>>>Global_Variable Integer oBase64Functions
86040>>>>>>>>>>>
86040>>>>>>>>>>>Object _oBase64Functions is a cObject
86042>>>>>>>>>>>    Move Self to oBase64Functions
86043>>>>>>>>>>>
86043>>>>>>>>>>>
86043>>>>>>>>>>>    Function EncodeString String sValue Returns String
86046>>>>>>>>>>>        Address pBase64
86046>>>>>>>>>>>        String sResult
86046>>>>>>>>>>>        Integer iVoid
86046>>>>>>>>>>>        Move (Base64Encode(AddressOf(sValue), Length(sValue))) to pBase64
86047>>>>>>>>>>>        Move pBase64 to sResult
86048>>>>>>>>>>>        Move (Free(pBase64)) to iVoid
86049>>>>>>>>>>>        Function_Return sResult
86050>>>>>>>>>>>    End_Function
86051>>>>>>>>>>>
86051>>>>>>>>>>>    Function DecodeString String sValue Returns String
86054>>>>>>>>>>>        Address pBinary
86054>>>>>>>>>>>        String sBinary
86054>>>>>>>>>>>        Integer iVoid iLen
86054>>>>>>>>>>>        Move (Base64Decode(AddressOf(sValue), &iLen)) to pBinary
86055>>>>>>>>>>>        Move (Repeat(Character(0), iLen)) to sBinary
86056>>>>>>>>>>>        Move (MemCopy(AddressOf(sBinary), pBinary, iLen)) to iVoid
86057>>>>>>>>>>>        Move (Free(pBinary)) to iVoid
86058>>>>>>>>>>>        Function_Return sBinary
86059>>>>>>>>>>>    End_Function
86060>>>>>>>>>>>
86060>>>>>>>>>>>End_Object
