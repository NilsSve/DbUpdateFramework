92763>>>>>    Function SqlUtilUpdateIntFile Integer hTable Returns Boolean           
92765>>>>>        String sOrgFormat sNewFormat sRootName sDatabaseName sPhysicalFileName sDriverID sDataPath         
92765>>>>>        Boolean bOpened bOK bMertech
92765>>>>>        
92765>>>>>        Move CS_OEM_Txt  to sOrgFormat
92766>>>>>        Move CS_ANSI_Txt to sNewFormat
92767>>>>>        Get AutoConnectionIDLogin to bOK
92768>>>>>        Send Ignore_Error of Error_Object_Id DFERR_MISSING_VALUE
92769>>>>>        Open hTable //Mode DF_EXCLUSIVE
92771>>>>>        Send Trap_Error of Error_Object_Id DFERR_MISSING_VALUE
92772>>>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpened
92775>>>>>        
92775>>>>>        // ToDo: What to do if we cannot open the table?!
92775>>>>>        If (bOpened = False) Begin
92777>>>>>            Function_Return False
92778>>>>>        End
92778>>>>>>
92778>>>>>        
92778>>>>>        Get psDriverID to sDriverID
92779>>>>>        Get IsMertechDriver sDriverID to bMertech
92780>>>>>        If (bMertech = True) Begin       
92782>>>>>            Get psDataPathFirstPart to sDataPath
92783>>>>>            Get vFolderExists sDataPath to bOK
92784>>>>>            If (bOK = False) Begin
92786>>>>>                Error DFERR_PROGRAM "Function SqlUtilUpdateIntFile; psDataPath not found!"
92787>>>>>>
92787>>>>>                Function_Return False    
92788>>>>>            End                      
92788>>>>>>
92788>>>>>            Get vFolderFormat sDataPath to sDataPath 
92789>>>>>            Get_Attribute DF_FILE_ROOT_NAME of hTable to sRootName
92792>>>>>            Get _TableNameOnly sRootName to sDatabaseName
92793>>>>>            Move sDatabaseName to sPhysicalFileName
92794>>>>>            Move (sPhysicalFileName + ".int") to sPhysicalFileName
92795>>>>>            Get _MertechSqlUtilCreateIntFile hTable sDataPath sPhysicalFileName to bOK
92796>>>>>            Function_Return (bOK = True)
92797>>>>>        End
92797>>>>>>
92797>>>>>        
92797>>>>>        Move False to Err
92798>>>>>        Get_Attribute DF_FILE_TABLE_CHARACTER_FORMAT of hTable to sOrgFormat
92801>>>>>        Move (Uppercase(sOrgFormat)) to sOrgFormat       
92802>>>>>        // Lets swap the OEM/ANSI format, just to make a change in Structure_Start below (and back),
92802>>>>>        // to "touch" the table so the driver feels there has been a change and updates the .int file.
92802>>>>>        Move (If(sOrgFormat = CS_OEM_Txt, CS_ANSI_Txt, CS_OEM_Txt)) to sNewFormat
92803>>>>>        
92803>>>>>        Structure_Start hTable
92804>>>>>            Set_Attribute DF_FILE_TABLE_CHARACTER_FORMAT of hTable to sNewFormat
92807>>>>>            Set_Attribute DF_FILE_TABLE_CHARACTER_FORMAT of hTable to sOrgFormat
92810>>>>>        Structure_End hTable (DF_STRUCTEND_OPT_IN_PLACE ior DF_STRUCTEND_OPT_FORCE)
92812>>>>>        
92812>>>>>        Function_Return (Err = False)
92813>>>>>    End_Function 
