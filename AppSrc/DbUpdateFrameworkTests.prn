84106>>>>>>>//=============================================================================
84106>>>>>>>/// @Name        SQL_OPEN_CURSOR_STMT
84106>>>>>>>/// @Description This command is used to create a new SQl Cursor. Once
84106>>>>>>>/// created, SQL_SET_CURRENT_CURSOR_STMT can be called to specify which
84106>>>>>>>/// cursor is to be used for a given SQL statement. Creating multiple
84106>>>>>>>/// cursors using this command allows multiple SQL statements to be
84106>>>>>>>/// opened at once. Optionally a different server can be specified for each
84106>>>>>>>/// cursor by passing the server name to this command as well. If no
84106>>>>>>>/// server is specified, the current server will be used. Note that it
84106>>>>>>>/// is important to close all cursors at the end using SQL_CLOSE_CURSOR_STMT.
84106>>>>>>>///
84106>>>>>>>/// @Assumptions
84106>>>>>>>/// @Status      Public
84106>>>>>>>/// @Drivers     All
84106>>>>>>>/// @VersionNote Last Revised: 2013-10-07 by Aaron Gulack
84106>>>>>>>/// @See                 SQL_CLOSE_CURSOR_STMT SQL_SET_CURRENT_CURSOR_STMT SQL_GET_CURRENT_CURSOR_STMT
84106>>>>>>>///
84106>>>>>>>/// @Syntax SQL_OPEN_CURSOR_STMT [of {server}] to {variable}
84106>>>>>>>/// @Param server                       Name of the server (optional)
84106>>>>>>>/// @Param variable                     Variable to hold the returned cursor handle
84106>>>>>>>///
84106>>>>>>>/// @Example
84106>>>>>>>///
84106>>>>>>>/// Integer iCursor1 iCursor2 iCustomer
84106>>>>>>>/// String  sName
84106>>>>>>>/// Number  nOrderTotal
84106>>>>>>>///
84106>>>>>>>/// SQL_OPEN_CURSOR_STMT to iCursor1
84106>>>>>>>/// SQL_SET_STMT         to "SELECT CUSTOMER_NUMBER,NAME FROM CUSTOMER "
84106>>>>>>>/// SQL_APPEND_STMT      to "ORDER BY NAME "
84106>>>>>>>/// SQL_PREPARE_STMT
84106>>>>>>>/// SQL_EXECUTE_STMT
84106>>>>>>>/// Repeat
84106>>>>>>>///     SQL_SET_CURRENT_CURSOR_STMT TO iCursor1
84106>>>>>>>///     SQL_FETCH_NEXT_ROW INTO iCustomer sName
84106>>>>>>>///     If (Found) Begin
84106>>>>>>>///        SQL_OPEN_CURSOR_STMT to iCursor2
84106>>>>>>>///        SQL_SET_STMT         to "SELECT SUM(ORDER_TOTAL) FROM ORDERHEA "
84106>>>>>>>///        SQL_APPEND_STMT      to ("WHERE CUSTOMER_NUMBER = " + Trim(iCustomer))
84106>>>>>>>///        SQL_PREPARE_STMT
84106>>>>>>>///        SQL_EXECUTE_STMT
84106>>>>>>>///        SQL_FETCH_NEXT_ROW INTO nOrderTotal
84106>>>>>>>///        If (Found and nOrderTotal > 0) Begin
84106>>>>>>>///            Showln "Customer : " iCustomer "-" sName " - Total: " nOrderTotal
84106>>>>>>>///        End
84106>>>>>>>///        SQL_CLOSE_CURSOR_STMT to Cursor2
84106>>>>>>>///
84106>>>>>>>///        Indicate Found True
84106>>>>>>>///     End
84106>>>>>>>/// Until (Not(Found))
84106>>>>>>>///
84106>>>>>>>/// SQL_CLOSE_CURSOR_STMT to Cursor1
84106>>>>>>>
84106>>>>>>>//=============================================================================
84106>>>>>>>/// @Name        SQL_CLOSE_CURSOR_STMT
84106>>>>>>>/// @Description This command closes the specified cursor that was created
84106>>>>>>>/// from SQL_OPEN_CURSOR_STMT. It is good practice to close all cursors
84106>>>>>>>/// once the statements associated with them are complete.
84106>>>>>>>///
84106>>>>>>>/// @Assumptions
84106>>>>>>>/// @Status      Public
84106>>>>>>>/// @Drivers     All
84106>>>>>>>/// @VersionNote Last Revised: 2013-10-07 by Aaron Gulack
84106>>>>>>>/// @See                 SQL_OPEN_CURSOR_STMT SQL_SET_CURRENT_CURSOR_STMT SQL_GET_CURRENT_CURSOR_STMT
84106>>>>>>>///
84106>>>>>>>/// @Syntax SQL_CLOSE_CURSOR_STMT [of {server}] to {variable}
84106>>>>>>>/// @Param server                       Name of the server (optional)
84106>>>>>>>/// @Param variable                     Cursor handle to close
84106>>>>>>>///
84106>>>>>>>/// @Example
84106>>>>>>>///
84106>>>>>>>/// SQL_OPEN_CURSOR_STMT to hCursor1
84106>>>>>>>///
84106>>>>>>>/// SQL_SET_STMT to "SELECT * FROM CUSTOMER WHERE STATUS = 'Active' "
84106>>>>>>>/// SQL_PREPARE_STMT
84106>>>>>>>/// SQL_EXECUTE_STMT
84106>>>>>>>///
84106>>>>>>>/// SQL_OPEN_CURSOR_STMT to hCursor2
84106>>>>>>>///
84106>>>>>>>/// SQL_SET_STMT to "SELECT * FROM CUSTOMER WHERE STATUS = 'Inactive' "
84106>>>>>>>/// SQL_PREPARE_STMT
84106>>>>>>>/// SQL_EXECUTE_STMT
84106>>>>>>>///
84106>>>>>>>/// Repeat
84106>>>>>>>///     SQL_SET_CURRENT_CURSOR_STMT to hCursor1
84106>>>>>>>///     SQL_FETCH_NEXT_ROW INTO  sID sFirstName sLastName
84106>>>>>>>///     If (Found) Begin
84106>>>>>>>///        Showln "Active : " sID "- " sFirstName sLastName
84106>>>>>>>///     End
84106>>>>>>>///
84106>>>>>>>///     SQL_SET_CURRENT_CURSOR_STMT to hCursor2
84106>>>>>>>///     SQL_FETCH_NEXT_ROW into sId sFirstName sLastName
84106>>>>>>>///     If (Found) Begin
84106>>>>>>>///         Showln "Inactive : " sID "- " sFirstName sLastName
84106>>>>>>>///     End
84106>>>>>>>/// Until (FindErr)
84106>>>>>>>///
84106>>>>>>>/// SQL_CLOSE_CURSOR_STMT to hCursor1
84106>>>>>>>/// SQL_CLOSE_CURSOR_STMT to hCursor2
84106>>>>>>>
84106>>>>>>>//=============================================================================
84106>>>>>>>/// @Name        SQL_SET_CURRENT_CURSOR_STMT
84106>>>>>>>/// @Description This command is used to open a cursor to be used for an
84106>>>>>>>/// SQl statement. The cursor must be created using the SQL_OPEN_CURSOR_STMT,
84106>>>>>>>/// but once it has been created, this command can easily switch between
84106>>>>>>>/// cursors as desired. Optionally a different server can be specified for each
84106>>>>>>>/// cursor by passing the server name to this command as well. If no
84106>>>>>>>/// server is specified, the current server will be used. Note that it
84106>>>>>>>/// is important to close all cursors at the end using SQL_CLOSE_CURSOR_STMT.
84106>>>>>>>///
84106>>>>>>>/// @Assumptions
84106>>>>>>>/// @Status      Public
84106>>>>>>>/// @Drivers     All
84106>>>>>>>/// @VersionNote Last Revised: 2013-10-07 by Aaron Gulack
84106>>>>>>>/// @See                 SQL_OPEN_CURSOR_STMT SQL_CLOSE_CURSOR_STMT SQL_GET_CURRENT_CURSOR_STMT
84106>>>>>>>///
84106>>>>>>>/// @Syntax SQL_SET_CURRENT_CURSOR_STMT [of {server}] to {variable}
84106>>>>>>>/// @Param server                       Name of the server (optional)
84106>>>>>>>/// @Param variable                     Cursor handle to use
84106>>>>>>>///
84106>>>>>>>/// @Example
84106>>>>>>>///
84106>>>>>>>/// SQL_OPEN_CURSOR_STMT to hCursor1
84106>>>>>>>///
84106>>>>>>>/// SQL_SET_STMT to "SELECT * FROM CUSTOMER WHERE STATUS = 'Active' "
84106>>>>>>>/// SQL_PREPARE_STMT
84106>>>>>>>/// SQL_EXECUTE_STMT
84106>>>>>>>///
84106>>>>>>>/// SQL_OPEN_CURSOR_STMT to hCursor2
84106>>>>>>>///
84106>>>>>>>/// SQL_SET_STMT to "SELECT * FROM CUSTOMER WHERE STATUS = 'Inactive' "
84106>>>>>>>/// SQL_PREPARE_STMT
84106>>>>>>>/// SQL_EXECUTE_STMT
84106>>>>>>>///
84106>>>>>>>/// Repeat
84106>>>>>>>///     SQL_SET_CURRENT_CURSOR_STMT to hCursor1
84106>>>>>>>///     SQL_FETCH_NEXT_ROW INTO  sID sFirstName sLastName
84106>>>>>>>///     If (Found) Begin
84106>>>>>>>///        Showln "Active : " sID "- " sFirstName sLastName
84106>>>>>>>///     End
84106>>>>>>>///
84106>>>>>>>///     SQL_SET_CURRENT_CURSOR_STMT to hCursor2
84106>>>>>>>///     SQL_FETCH_NEXT_ROW into sId sFirstName sLastName
84106>>>>>>>///     If (Found) Begin
84106>>>>>>>///         Showln "Inactive : " sID "- " sFirstName sLastName
84106>>>>>>>///     End
84106>>>>>>>/// Until (FindErr)
84106>>>>>>>///
84106>>>>>>>/// SQL_CLOSE_CURSOR_STMT to hCursor1
84106>>>>>>>/// SQL_CLOSE_CURSOR_STMT to hCursor2
84106>>>>>>>
84106>>>>>>>//=============================================================================
