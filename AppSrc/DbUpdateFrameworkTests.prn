82406>>>>>>>//*****************************************************************************
82406>>>>>>>//*** Class  : cDfbtrdrvHandler                                                  ***
82406>>>>>>>//*** Purpose: An instance of this class can be used as a broker object to  ***
82406>>>>>>>//***          call several Dfbtrdrv releated methods.                           ***
82406>>>>>>>//*****************************************************************************
82406>>>>>>>
82406>>>>>>>Class cDFBtrDrvHandler Is An Array
82407>>>>>>>
82407>>>>>>>    Procedure Construct_Object Integer iImage
82409>>>>>>>        Forward Send Construct_object iImage
82411>>>>>>>
82411>>>>>>>        Property String  psDriverID       Public "DFBTRDRV"
82412>>>>>>>    End_Procedure // Construct_Object
82413>>>>>>>
82413>>>>>>>
82413>>>>>>>
82413>>>>>>>    //***
82413>>>>>>>    //*** Function: CKRevsion
82413>>>>>>>    //*** Purpose : The revsion of a Dfbtrdrv Connectivity Kit
82413>>>>>>>    //***
82413>>>>>>>
82413>>>>>>>    Function CKRevision Returns String
82415>>>>>>>        Local String  sDriverID
82415>>>>>>>        Local String  sRevision
82415>>>>>>>        Local String  sVoid
82415>>>>>>>        Local Integer iRetval
82415>>>>>>>
82415>>>>>>>        // Ignore error 20491 DFBTRERR_INVALID_DRIVER_FUNCTION_CALL.
82415>>>>>>>        // This error would otherwise be raised when we have an older
82415>>>>>>>        // DFBTRDRV version that has no DFBTRFN_CKREVISION function
82415>>>>>>>        Send Ignore_error To Error_object_Id 20491
82416>>>>>>>        Get psDriverID To sDriverID
82417>>>>>>>        Move (Repeat(" ", 255)) To sRevision
82418>>>>>>>        Call_Driver 0 sDRiverID Function DFBTRFN_CKREVISION Callback 0 Passing sRevision sVoid 0 Result iRetval
82423>>>>>>>        Send Trap_Error To Error_object_Id 20491
82424>>>>>>>        If (Trim(sRevision) = "") Begin
82426>>>>>>>            // Unable to get the revision. return all zeroes.
82426>>>>>>>            Move "0.0.0.0" To sRevision
82427>>>>>>>        End
82427>>>>>>>>
82427>>>>>>>        Function_Return sRevision
82428>>>>>>>    End_Function // CKRevision
82429>>>>>>>
82429>>>>>>>    Function CkUsesUri Returns Integer
82431>>>>>>>        Local String  sDriverID
82431>>>>>>>        Local String  sVoid1
82431>>>>>>>        Local String  sVoid2
82431>>>>>>>        Local Integer iRetval
82431>>>>>>>
82431>>>>>>>        Get psDriverID To sDriverID
82432>>>>>>>
82432>>>>>>>        Move 0 To iRetval
82433>>>>>>>        // Ignore error 20491 DFBTRERR_INVALID_DRIVER_FUNCTION_CALL.
82433>>>>>>>        // This error would otherwise be raised when we have an older
82433>>>>>>>        // DFBTRDRV version that has no DFBTRFN_CKUSESURI function
82433>>>>>>>        Send Ignore_error To Error_object_Id 20491
82434>>>>>>>        Call_Driver 0 sDRiverID Function DFBTRFN_CKUSESURI Callback 0 Passing sVoid1 sVoid2 0 Result iRetval
82439>>>>>>>        Send Trap_Error To Error_object_Id 20491
82440>>>>>>>
82440>>>>>>>        Function_Return iRetval
82441>>>>>>>    End_Function // CKUsesUri
82442>>>>>>>
82442>>>>>>>
82442>>>>>>>
82442>>>>>>>    //***
82442>>>>>>>    //*** Function: ExtractPartFromRevsion
82442>>>>>>>    //*** Purpose : Extarct the Nth part of a a.b.c.d revsion string.
82442>>>>>>>    //***
82442>>>>>>>    //*** Returns : The part version number or -1 if there is no such part number.
82442>>>>>>>    //***
82442>>>>>>>
82442>>>>>>>    Function ExtractPartFromRevision Integer iPartNum String sRevision Returns Integer
82444>>>>>>>        Local Integer iPartRev
82444>>>>>>>        Local Integer iCurrentPart
82444>>>>>>>        Local Integer iSeparatorPos
82444>>>>>>>
82444>>>>>>>        If (iPartNum > 4) ;            Function_Return -1
82447>>>>>>>
82447>>>>>>>        Move 0 To iCurrentPart
82448>>>>>>>        Repeat
82448>>>>>>>>
82448>>>>>>>            Move (Pos(".", sRevision)) To iSeparatorPos
82449>>>>>>>            If (iSeparatorPos > 0) Begin
82451>>>>>>>                Move (Left(sRevision, iSeparatorPos - 1)) To iPartRev
82452>>>>>>>                Move (Right(sRevision, Length(sRevision) - iSeparatorPos)) To sRevision
82453>>>>>>>                Increment iCurrentPart
82454>>>>>>>            End
82454>>>>>>>>
82454>>>>>>>            Else If (sRevision <> "") Begin
82457>>>>>>>                Move sRevision To iPartRev
82458>>>>>>>                Move "" To sRevision
82459>>>>>>>                Increment iCurrentPart
82460>>>>>>>            End
82460>>>>>>>>
82460>>>>>>>            Else ;                Move -1 To iPartRev
82462>>>>>>>        Until (iCurrentPart >= iPartNum Or iPartRev = -1)
82464>>>>>>>
82464>>>>>>>        Function_Return iPartRev
82465>>>>>>>    End_Function // EcxtractPartFromRevision
82466>>>>>>>
82466>>>>>>>
82466>>>>>>>
82466>>>>>>>    //***
82466>>>>>>>    //*** Function: CKMajorRevision
82466>>>>>>>    //*** Purpose : Returns the major revision of the CK
82466>>>>>>>    //***
82466>>>>>>>
82466>>>>>>>    Function CKMajorRevision Returns Integer
82468>>>>>>>        Function_Return (ExtractPartFromRevision (Current_Object, 1, CKRevision(Current_Object)))
82469>>>>>>>    End_Function // CKMajorRevision
82470>>>>>>>
82470>>>>>>>
82470>>>>>>>
82470>>>>>>>    //***
82470>>>>>>>    //*** Function: CKMinorRevision
82470>>>>>>>    //*** Purpose : Returns the minor revision of the CK
82470>>>>>>>    //***
82470>>>>>>>
82470>>>>>>>    Function CKMinorRevision Returns Integer
82472>>>>>>>        Function_Return (ExtractPartFromRevision (Current_Object, 2, CKRevision(Current_Object)))
82473>>>>>>>    End_Function // CKMinorRevision
82474>>>>>>>
82474>>>>>>>
82474>>>>>>>
82474>>>>>>>    //***
82474>>>>>>>    //*** Function: CKReleaseRevision
82474>>>>>>>    //*** Purpose : Returns the release revision of the CK
82474>>>>>>>    //***
82474>>>>>>>
82474>>>>>>>    Function CKReleaseRevision Returns Integer
82476>>>>>>>        Function_Return (ExtractPartFromRevision (Current_Object, 3, CKRevision(Current_Object)))
82477>>>>>>>    End_Function // CKReleaseRevision
82478>>>>>>>
82478>>>>>>>
82478>>>>>>>
82478>>>>>>>    //***
82478>>>>>>>    //*** Function: CKBuildRevision
82478>>>>>>>    //*** Purpose : Returns the major revision of the CK
82478>>>>>>>    //***
82478>>>>>>>
82478>>>>>>>    Function CKBuildRevision Returns Integer
82480>>>>>>>        Function_Return (ExtractPartFromRevision (Current_Object, 4, CKRevision(Current_Object)))
82481>>>>>>>    End_Function // CKBuildRevision
82482>>>>>>>
82482>>>>>>>
82482>>>>>>>
82482>>>>>>>    //***
82482>>>>>>>    //*** Function: IsMinimalRevision
82482>>>>>>>    //*** Purpose : Determines if the CK conforms to a passed minimal revsion.
82482>>>>>>>    //***
82482>>>>>>>
82482>>>>>>>    Function IsMinimalRevision Integer iMajor Integer iMinor Integer iRelease Integer iBuild Returns Integer
82484>>>>>>>        If (iMajor < CKMajorRevision(Current_object)) ;            Function_return (TRUE)
82487>>>>>>>        Else If (iMajor = CKMajorRevision(Current_object)) Begin
82490>>>>>>>            If (iMinor < CKMinorRevision(Current_object)) ;                Function_return (TRUE)
82493>>>>>>>            Else If (iMinor = CKMinorRevision(Current_object)) Begin
82496>>>>>>>                If (iRelease < CKReleaseRevision(Current_object)) ;                    Function_return (TRUE)
82499>>>>>>>                Else If (iRelease = CKReleaseRevision(Current_object) And iBuild <= CKBuildRevision(Current_object)) ;                    Function_return (TRUE)
82503>>>>>>>            End
82503>>>>>>>>
82503>>>>>>>        End
82503>>>>>>>>
82503>>>>>>>
82503>>>>>>>        Function_Return (FALSE)
82504>>>>>>>    End_Function // IsMinimalRevision
82505>>>>>>>
82505>>>>>>>    //   Functions to query the Pervasive.SQL version:
82505>>>>>>>    //       PSQLRequesterVersionInfo    Integer iFileNum Returns String
82505>>>>>>>    //       PSQLLocalEngineVersionInfo  Integer iFileNum Returns String
82505>>>>>>>    //       PSQLServerEngineVersionInfo Integer iFileNum Returns String
82505>>>>>>>    //
82505>>>>>>>    //   All 3 functions return the version of a Pervasive.SQL component
82505>>>>>>>    //   in the following format:
82505>>>>>>>    //       <version>.<revision>.<type>
82505>>>>>>>    //   possible values for <type>:
82505>>>>>>>    //       9 for 32-bit Windows workstation/workgroup engine or Linux
82505>>>>>>>    //         server using Workgroup authentication mode
82505>>>>>>>    //       C for client cache engine
82505>>>>>>>    //       D for DOS workstation
82505>>>>>>>    //       N for client Requester
82505>>>>>>>    //       S for NetWare server
82505>>>>>>>    //       T for 32-bit Windows server engine
82505>>>>>>>    //       U for Linux server using PAM or BTPASSWD authentication
82505>>>>>>>    //
82505>>>>>>>    //   example:
82505>>>>>>>    //       8.50.T
82505>>>>>>>    //   will be returned for a Pervasive.SQL 8.5 Server Engine running on
82505>>>>>>>    //   32-bits Windows server.
82505>>>>>>>    //
82505>>>>>>>    //   The FileNumber parameter must specify an opened table or 0.
82505>>>>>>>    //   For PSQLServerEngineVersionInfo the FileNumber can not be 0.
82505>>>>>>>    //
82505>>>>>>>    //   If the version information is not available or can not be obtained
82505>>>>>>>    //   the functions will return "0.0.0"
82505>>>>>>>
82505>>>>>>>
82505>>>>>>>    //***
82505>>>>>>>    //*** Function: PSQLRequesterVersionInfo
82505>>>>>>>    //*** Purpose : Returns the version information of the
82505>>>>>>>    //***           Pervasive.SQL Client requester.
82505>>>>>>>
82505>>>>>>>    Function PSQLRequesterVersionInfo Integer iFileNum Returns String
82507>>>>>>>
82507>>>>>>>        Local String  sDriverID
82507>>>>>>>        Local String  sVersion
82507>>>>>>>        Local String  sVoid
82507>>>>>>>        Local Integer iRetval
82507>>>>>>>
82507>>>>>>>        // Ignore error 20491 DFBTRERR_INVALID_DRIVER_FUNCTION_CALL.
82507>>>>>>>        // This error would otherwise be raised when we have an older
82507>>>>>>>        // DFBTRDRV version that has no DFBTRFN_CKREVISION function
82507>>>>>>>        Send Ignore_error To Error_object_Id 20491
82508>>>>>>>        Get psDriverID To sDriverID
82509>>>>>>>        Move (Repeat(" ", 255)) To sVersion
82510>>>>>>>        Call_Driver iFileNum sDRiverID Function DFBTRFN_PSQLREQUESTERVERSIONINFO Callback 0 Passing sVersion sVoid 0 Result iRetval
82515>>>>>>>        Send Trap_Error To Error_object_Id 20491
82516>>>>>>>        If (Trim(sVersion) = "") Begin
82518>>>>>>>            // Unable to get the revision. return all zeroes.
82518>>>>>>>            Move "0.0.0" To sVersion
82519>>>>>>>        End
82519>>>>>>>>
82519>>>>>>>        Function_Return sVersion
82520>>>>>>>    End_Function //  PSQLRequesterVersion
82521>>>>>>>
82521>>>>>>>    //***
82521>>>>>>>    //*** Function: PSQLLocalEngineVersionInfo
82521>>>>>>>    //*** Purpose : Returns the version information of the
82521>>>>>>>    //***           Pervasive.SQL Local Engine
82521>>>>>>>
82521>>>>>>>    Function PSQLLocalEngineVersionInfo Integer iFileNum Returns String
82523>>>>>>>
82523>>>>>>>        Local String  sDriverID
82523>>>>>>>        Local String  sVersion
82523>>>>>>>        Local String  sVoid
82523>>>>>>>        Local Integer iRetval
82523>>>>>>>
82523>>>>>>>        // Ignore error 20491 DFBTRERR_INVALID_DRIVER_FUNCTION_CALL.
82523>>>>>>>        // This error would otherwise be raised when we have an older
82523>>>>>>>        // DFBTRDRV version that has no DFBTRFN_CKREVISION function
82523>>>>>>>        Send Ignore_error To Error_object_Id 20491
82524>>>>>>>        Get psDriverID To sDriverID
82525>>>>>>>        Move (Repeat(" ", 255)) To sVersion
82526>>>>>>>        Call_Driver iFileNum sDRiverID Function DFBTRFN_PSQLLOCALENGINEVERSIONINFO Callback 0 Passing sVersion sVoid 0 Result iRetval
82531>>>>>>>        Send Trap_Error To Error_object_Id 20491
82532>>>>>>>        If (Trim(sVersion) = "") Begin
82534>>>>>>>            // Unable to get the revision. return all zeroes.
82534>>>>>>>            Move "0.0.0" To sVersion
82535>>>>>>>        End
82535>>>>>>>>
82535>>>>>>>        Function_Return sVersion
82536>>>>>>>    End_Function //  PSQLLocalEngineVersion
82537>>>>>>>
82537>>>>>>>    //***
82537>>>>>>>    //*** Function: PSQLServerEngineVersionInfo
82537>>>>>>>    //*** Purpose : Returns the version information of the
82537>>>>>>>    //***           Pervasive.SQL Server Engine
82537>>>>>>>
82537>>>>>>>    Function PSQLServerEngineVersionInfo Integer iFileNum Returns String
82539>>>>>>>
82539>>>>>>>        Local String  sDriverID
82539>>>>>>>        Local String  sVersion
82539>>>>>>>        Local String  sVoid
82539>>>>>>>        Local Integer iRetval
82539>>>>>>>
82539>>>>>>>        // Ignore error 20491 DFBTRERR_INVALID_DRIVER_FUNCTION_CALL.
82539>>>>>>>        // This error would otherwise be raised when we have an older
82539>>>>>>>        // DFBTRDRV version that has no DFBTRFN_CKREVISION function
82539>>>>>>>        Send Ignore_error To Error_object_Id 20491
82540>>>>>>>        Get psDriverID To sDriverID
82541>>>>>>>        Move (Repeat(" ", 255)) To sVersion
82542>>>>>>>        Call_Driver iFileNum sDRiverID Function DFBTRFN_PSQLSERVERENGINEVERSIONINFO Callback 0 Passing sVersion sVoid 0 Result iRetval
82547>>>>>>>        Send Trap_Error To Error_object_Id 20491
82548>>>>>>>        If (Trim(sVersion) = "") Begin
82550>>>>>>>            // Unable to get the revision. return all zeroes.
82550>>>>>>>            Move "0.0.0" To sVersion
82551>>>>>>>        End
82551>>>>>>>>
82551>>>>>>>        Function_Return sVersion
82552>>>>>>>    End_Function //  PSQLServerEngineVersion
82553>>>>>>>
82553>>>>>>>End_Class // cDfbtrdrvHandler
