83027>>>>>>>/// @Name        DF_FIELD_NATIVE_NAME
83027>>>>>>>/// @Description This attribute is used to get the name of the desired column
83027>>>>>>>/// on the SQL backend. Currently this attribute is ReadOnly and so setting
83027>>>>>>>/// or modifying a column name cannot be done using this attribute.  In most
83027>>>>>>>/// cases, the field name on the SQL backend will be the same as the Dataflex name.
83027>>>>>>>///
83027>>>>>>>/// This is a ReadOnly attribute.
83027>>>>>>>///
83027>>>>>>>/// @Assumptions
83027>>>>>>>/// @Status      Public
83027>>>>>>>/// @Drivers     All
83027>>>>>>>/// @VersionNote Last Revised: 2013-08-09 by Aaron Gulack
83027>>>>>>>/// @See
83027>>>>>>>/// @INTOPT
83027>>>>>>>///
83027>>>>>>>/// @Syntax Get_Attribute DF_FIELD_NATIVE_NAME of {FileNumber} {FieldNumber} to {variable}
83027>>>>>>>/// @Param  FileNumber          Number of the file
83027>>>>>>>/// @Param  FieldNumber                 Number of the Field
83027>>>>>>>/// @Param  variable                    String containing the name of the field
83027>>>>>>>/// @Example
83027>>>>>>>/// Open Customer
83027>>>>>>>///
83027>>>>>>>/// String sName
83027>>>>>>>///
83027>>>>>>>/// Get_Attribute DF_FIELD_NATIVE_NAME of Customer.File_Number 3 to sName
83027>>>>>>>Define DF_FIELD_NATIVE_NAME                         For (DF_FIELD_NATIVE_LENGTH+9)
83027>>>>>>>
83027>>>>>>>//=============================================================================
83027>>>>>>>/// @Name        DF_FIELD_NULL
83027>>>>>>>/// @Description Use this attribute to get or set whether a column in a table will
83027>>>>>>>/// allow null values. When set to true, the column accepts null values. Setting
83027>>>>>>>/// this attribute to false will keep it from accepting null values. Although,
83027>>>>>>>/// getting the value of this attribute can be done at anytime, setting it must
83027>>>>>>>/// be done in a Structure_Start or during table creation.
83027>>>>>>>///
83027>>>>>>>/// @Assumptions
83027>>>>>>>/// @Status      Public
83027>>>>>>>/// @Drivers     All
83027>>>>>>>/// @VersionNote Last Revised: 2013-08-09 by Aaron Gulack
83027>>>>>>>/// @See
83027>>>>>>>/// @INTOPT
83027>>>>>>>///
83027>>>>>>>/// @Syntax Get_Attribute DF_FIELD_NULL of {FileNumber} {FieldNumber} to {variable}
83027>>>>>>>/// @Syntax Set_Attribute DF_FIELD_NULL of {FileNumber} {FieldNumber} to {variable}
83027>>>>>>>/// @Param  FileNumber          Number of the file
83027>>>>>>>/// @Param  FieldNumber                 Number of the Field
83027>>>>>>>/// @Param  variable                    Boolean variable
83027>>>>>>>/// @Example
83027>>>>>>>/// Open Customer
83027>>>>>>>/// Handle hFile
83027>>>>>>>/// Integer iColumn
83027>>>>>>>/// Boolean bAllowNull
83027>>>>>>>///
83027>>>>>>>/// Move Customer.File_Number to hFile
83027>>>>>>>/// Move 3 to iColumn
83027>>>>>>>///
83027>>>>>>>/// Structure_Start hFile "ORA_DRV"
83027>>>>>>>///    Set_Attribute DF_FIELD_NULL of hFile iColumn to True
83027>>>>>>>/// Structure_End hFile
83027>>>>>>>///
83027>>>>>>>/// Get_Attribute DF_FIELD_NULL of hFile iColumn to bAllowNull
83027>>>>>>>Define DF_FIELD_NULL                                For (DF_FIELD_NATIVE_LENGTH+10)
83027>>>>>>>
83027>>>>>>>
83027>>>>>>>//=============================================================================
83027>>>>>>>/// @Name        DF_FIELD_NATIVE_TYPE
83027>>>>>>>/// @Description Use this attribute to get or set the Native type for a specific
83027>>>>>>>/// field in a table.  The native type refers to the data type of the field on the
83027>>>>>>>/// SQL backend. Setting this attribute can only be done during table creation or
83027>>>>>>>/// inside of a Structure_Start. When setting this attribute, it is good practice
83027>>>>>>>/// to use the constants mentioned below instead of the integers. For a list of
83027>>>>>>>/// these constants, refer to the sections: "Oracle Data Types", "MySQL Data Types",
83027>>>>>>>/// "PostgreSQL Data Types", and "SQL Server Data Types" included in this document.
83027>>>>>>>/// Note that when getting the value for this attribute, an integer will be returned
83027>>>>>>>/// so these lists of constants can again prove useful.
83027>>>>>>>///
83027>>>>>>>/// @Assumptions
83027>>>>>>>/// @Status      Public
83027>>>>>>>/// @Drivers     All
83027>>>>>>>/// @VersionNote Last Revised: 2013-08-09 by Aaron Gulack
83027>>>>>>>/// @See
83027>>>>>>>/// @INTOPT      FIELD_TYPE
83027>>>>>>>///
83027>>>>>>>/// @Syntax Set_Attribute DF_FIELD_NATIVE_TYPE of {FileNumber} {FieldNumber} to {variable}
83027>>>>>>>/// @Syntax Get_Attribute DF_FIELD_NATIVE_TYPE of {FileNumber} {FieldNumber} to {variable}
83027>>>>>>>/// @Param  FileNumber          Number of the file
83027>>>>>>>/// @Param  FieldNumber         Number of the field
83027>>>>>>>/// @Param  variable                    variable for the native data type
83027>>>>>>>/// @Example
83027>>>>>>>/// open Customer
83027>>>>>>>///
83027>>>>>>>/// Integer iColumn iType
83027>>>>>>>/// Handle hFile
83027>>>>>>>///
83027>>>>>>>/// Move Customer.File_Number to hFile
83027>>>>>>>/// Structure_Start hFile
83027>>>>>>>///     Set_Attribute DF_FIELD_NATIVE_TYPE of hFile iColumn to "eSQLServer_DATE"
83027>>>>>>>///     Get_Attribute DF_FIELD_NATIVE_TYPE of hFile iColumn to iType
83027>>>>>>>///     Structure_End hFile
83027>>>>>>>Define DF_FIELD_NATIVE_TYPE                         For (DF_FIELD_NATIVE_LENGTH+12)
83027>>>>>>>
83027>>>>>>>// Currently Unsupported Attribute (readOnly used by DataFlex 18.0 Studio)
83027>>>>>>>Define DF_FIELD_NATIVE_TYPE_NAME                    For 711
83027>>>>>>>
83027>>>>>>>// Currently Unsupported Attribute
83027>>>>>>>Define DF_FIELD_NATIVE_OFFSET                       For (DF_FIELD_NATIVE_LENGTH+14)
83027>>>>>>>
83027>>>>>>>//=============================================================================
83027>>>>>>>/// @Name        DF_FIELD_AUTO_INCREMENT
83027>>>>>>>/// @Description Auto incrementing is a technique used in Dataflex usually for
83027>>>>>>>/// fields that are set as the unique identifier. Instead of generating a value
83027>>>>>>>/// or manually inserting data into the column, when a field auto increments,
83027>>>>>>>/// the value of the field increases by one (usually) with each record.  This
83027>>>>>>>/// field is used to get or set whether the field uses this technique or not.
83027>>>>>>>/// The attribute, however, can only be set inside of a Structure_Start or during
83027>>>>>>>/// table creation. Getting the attribute's value can be done at anytime. The
83027>>>>>>>/// value is stored as a boolean, either true or false.
83027>>>>>>>///
83027>>>>>>>/// @Assumptions
83027>>>>>>>/// @Status      Public
83027>>>>>>>/// @Drivers     All
83027>>>>>>>/// @VersionNote Last Revised: 2013-08-12 by Aaron Gulack
83027>>>>>>>/// @See
83027>>>>>>>/// @INTOPT      FIELD_AUTOINCREMENT_TYPE
83027>>>>>>>///
83027>>>>>>>/// @Syntax Set_Attribute DF_FIELD_AUTO_INCREMENT of {FileNumber} {FieldNumber} to {variable}
83027>>>>>>>/// @Syntax Get_Attribute DF_FIELD_AUTO_INCREMENT of {FileNumber} {FieldNumber} to {variable}
83027>>>>>>>/// @Param  FileNumber          Number of the file
83027>>>>>>>/// @Param  FieldNumber         Number of the field
83027>>>>>>>/// @Param  variable                    Boolean variable indicating if the field auto increments.
83027>>>>>>>/// @Example
83027>>>>>>>/// open Customer
83027>>>>>>>///
83027>>>>>>>/// Integer iColumn
83027>>>>>>>/// Boolean bIncrement
83027>>>>>>>/// Handle hFile
83027>>>>>>>///
83027>>>>>>>/// Move Customer.File_Number to hFile
83027>>>>>>>///
83027>>>>>>>/// Structure_Start hFile
83027>>>>>>>///     Set_Attribute DF_FIELD_AUTO_INCREMENT of hFile iColumn to True
83027>>>>>>>///     Get_Attribute DF_FIELD_AUTO_INCREMENT of hFile iColumn to bIncrement
83027>>>>>>>///     Structure_End hFile
83027>>>>>>>Define DF_FIELD_AUTO_INCREMENT                      For (DF_FIELD_NATIVE_LENGTH+16)
83027>>>>>>>
83027>>>>>>>//Currently Unsupported Attribute
83027>>>>>>>Define DF_FIELD_GENERATE_ALWAYS                     For (DF_FIELD_NATIVE_LENGTH+18)
83027>>>>>>>
83027>>>>>>>// Currently Unsupported Attribute
83027>>>>>>>Define DF_FIELD_SEND_LONG_DATA                      For 702
83027>>>>>>>
83027>>>>>>>//=============================================================================
83027>>>>>>>/// @Name        DF_INDEX_NATIVE_CREATED
83027>>>>>>>/// @Description Use this attribute to verify if the index that maps to the DataFlex
83027>>>>>>>/// index was created correctly at the SQL backend
