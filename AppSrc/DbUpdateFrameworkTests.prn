93298>>>>>        End
93298>>>>>>
93298>>>>>
93298>>>>>        Get psDriverID to sDriverID
93299>>>>>        Get piDbType   to iDbType
93300>>>>>        If (iDbType = EN_dbTypeOracle) Begin
93302>>>>>            Get psUserID to sSchema
93303>>>>>            // Not sure about this uppercasing but it seems like Oracle wants that?
93303>>>>>            Move (Uppercase(sSchema)) to sSchema
93304>>>>>            Move ('"' + sSchema + '"."' + sTableName + '"') to sTableName
93305>>>>>            Function_Return sTableName
93306>>>>>        End 
93306>>>>>>
93306>>>>>        If (iDbType = EN_DbTypeMySQL) Begin
93308>>>>>            Get psDatabase to sVal
93309>>>>>            Move (sVal + "." + sTableName) to sTableName
93310>>>>>            Function_Return sTableName
93311>>>>>        End 
93311>>>>>>
93311>>>>>        If (iDbType = EN_DbTypePostgre) Begin
93313>>>>>            Move ('"' + sTableName + '"') to sTableName
93314>>>>>            Function_Return sTableName
93315>>>>>        End
93315>>>>>>
93315>>>>>        
93315>>>>>        Get psSchema to sSchema   
93316>>>>>        If (sSchema = "") Begin
93318>>>>>            Get _SqlFindKeyWord CI_SQLDBO to sSchema
93319>>>>>        End
93319>>>>>>
93319>>>>>
93319>>>>>        Move (Uppercase(sTableName)) to sVal
93320>>>>>        If (not(sVal contains (sSchema + "."))) Begin  
93322>>>>>            If (iDbType = EN_dbTypeDB2) Begin
93324>>>>>                Move (Lowercase(sSchema) + "." + sTableName) to sTableName
93325>>>>>            End 
93325>>>>>>
93325>>>>>            Else Begin
93326>>>>>                Move (sSchema + "." + sTableName) to sTableName
93327>>>>>            End
93327>>>>>>
93327>>>>>        End    
93327>>>>>>
93327>>>>>
93327>>>>>        Function_Return sTableName
93328>>>>>    End_Function
