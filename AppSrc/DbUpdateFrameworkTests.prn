89445>>>>>>>>>    Function SQLIniFileDeleteAllConnections Returns Boolean
89447>>>>>>>>>        Integer iCount 
89447>>>>>>>>>        Boolean bExists 
89447>>>>>>>>>        String sSection
89447>>>>>>>>>        
89447>>>>>>>>>        Move False to Err
89448>>>>>>>>>        Move 1 to iCount
89449>>>>>>>>>        Get psIniSectionName to sSection
89450>>>>>>>>>        Get SectionExists (CS_SQLIniSectionName + String(iCount)) to bExists
89451>>>>>>>>>        While (bExists = True)
89455>>>>>>>>>            Send DeleteSection (CS_SQLIniSectionName + String(iCount))
89456>>>>>>>>>            Increment iCount
89457>>>>>>>>>            Get SectionExists (CS_SQLIniSectionName + String(iCount)) to bExists
89458>>>>>>>>>        Loop
89459>>>>>>>>>>
89459>>>>>>>>>        Function_Return (Err = False)
89460>>>>>>>>>    End_Function
89461>>>>>>>>>    
89461>>>>>>>>>    Function SQLIniFileDeleteConnection Integer iItem Returns Boolean
89463>>>>>>>>>        Integer iCount 
89463>>>>>>>>>        String sSection 
89463>>>>>>>>>        Boolean bExists
89463>>>>>>>>>        
89463>>>>>>>>>        Move False to Err
89464>>>>>>>>>        Move 1 to iCount
89465>>>>>>>>>        Get psIniSectionName to sSection
89466>>>>>>>>>        Get KeyExists sSection CS_SQLIniConnectionIdKeyword to bExists
89467>>>>>>>>>        While (bExists = True)
89471>>>>>>>>>            If (iCount = iItem) Begin   
89473>>>>>>>>>                Send DeleteSection sSection
89474>>>>>>>>>//                Set IniFileValue sSection (CS_SQLIniSectionName + String(iCount)) to ""
89474>>>>>>>>>                Move 9999 to iCount // Just some ridiculously high number to get out of the loop as we're done.
89475>>>>>>>>>            End
89475>>>>>>>>>>
89475>>>>>>>>>            Increment iCount
89476>>>>>>>>>            Get KeyExists sSection (CS_SQLIniSectionName + String(iCount)) to bExists
89477>>>>>>>>>        Loop
89478>>>>>>>>>>
89478>>>>>>>>>        
89478>>>>>>>>>        Function_Return (Err = False)
89479>>>>>>>>>    End_Function
89480>>>>>>>>>    
89480>>>>>>>>>    // Returns all connection details for the passed Connection ID as a tSQLConnection
89480>>>>>>>>>    // If it fails the returned struct member SQLConnection.bError = True. 
89480>>>>>>>>>    Function SQLIniFileConnectionID String sConnectionID Returns tSQLConnection
89482>>>>>>>>>        tSQLConnection[] SQLConnectionsArray
89482>>>>>>>>>        tSQLConnection[] SQLConnectionsArray
89483>>>>>>>>>        tSQLConnection   SQLConnection
89483>>>>>>>>>        tSQLConnection   SQLConnection
89483>>>>>>>>>        Integer iIndex
89483>>>>>>>>>        
89483>>>>>>>>>        Get SQLIniFileConnectionIDIndex sConnectionID to iIndex
89484>>>>>>>>>        If (iIndex = -1) Begin
89486>>>>>>>>>            Move True to SQLConnection.bError
89487>>>>>>>>>            Function_Return SQLConnection
89488>>>>>>>>>        End
89488>>>>>>>>>>
89488>>>>>>>>>
89488>>>>>>>>>        Get SQLIniFileReadConnections to SQLConnectionsArray
89489>>>>>>>>>        Move SQLConnectionsArray[iIndex -1] to SQLConnection
89490>>>>>>>>>        
89490>>>>>>>>>        Function_Return SQLConnection    
89491>>>>>>>>>    End_Function
89492>>>>>>>>>            
89492>>>>>>>>>    // Returns -1 if the passed connection ID was not found, else the item number.
89492>>>>>>>>>    Function SQLIniFileConnectionIDIndex String sConnectionID Returns Integer
89494>>>>>>>>>        tSQLConnection[] SQLConnectionsArray
89494>>>>>>>>>        tSQLConnection[] SQLConnectionsArray
89495>>>>>>>>>        Integer iRetval iCount iSize
89495>>>>>>>>>        String sValue
89495>>>>>>>>>        Boolean bExists
89495>>>>>>>>>        
89495>>>>>>>>>        Move -1 to iRetval
89496>>>>>>>>>
89496>>>>>>>>>        Get SQLIniFileReadConnections to SQLConnectionsArray
89497>>>>>>>>>        Move (SizeOfArray(SQLConnectionsArray)) to iSize
89498>>>>>>>>>        Decrement iSize
89499>>>>>>>>>        For iCount from 0 to iSize
89505>>>>>>>>>>
89505>>>>>>>>>            Move SQLConnectionsArray[iCount].sConnectionID to sValue 
89506>>>>>>>>>            Move (Uppercase(sValue) = Uppercase(sConnectionID)) to bExists
89507>>>>>>>>>            If (bExists) Begin
89509>>>>>>>>>                Move (iCount + 1) to iRetval // The [ConnectionX] keys are one-based (starts at 1) but the loop starts at zero.
89510>>>>>>>>>                Move iSize to iCount         // We're done!
89511>>>>>>>>>            End
89511>>>>>>>>>>
89511>>>>>>>>>        Loop
89512>>>>>>>>>>
89512>>>>>>>>>                
89512>>>>>>>>>        Function_Return iRetval
89513>>>>>>>>>    End_Function       
89514>>>>>>>>>    
89514>>>>>>>>>    // Checks if the passed sConnectionID exists more than once in the passed struct array.
89514>>>>>>>>>    // Used to check that ConnectionID's are unique.
89514>>>>>>>>>    Function IsConnectionIDDuplicate String sConnectionID Returns Boolean
89516>>>>>>>>>        Integer iCount iSize iItems
89516>>>>>>>>>        String sValue
89516>>>>>>>>>        Boolean bExists                                   
89516>>>>>>>>>        tSQLConnection[] SQLConnectionsArray 
89516>>>>>>>>>        tSQLConnection[] SQLConnectionsArray 
89517>>>>>>>>>        
89517>>>>>>>>>        Move 0 to iItems                     
89518>>>>>>>>>        Get SQLIniFileReadConnections to SQLConnectionsArray
89519>>>>>>>>>        Move (SizeOfArray(SQLConnectionsArray)) to iSize
89520>>>>>>>>>        Decrement iSize
89521>>>>>>>>>        For iCount from 0 to iSize
89527>>>>>>>>>>
89527>>>>>>>>>            Move SQLConnectionsArray[iCount].sConnectionID to sValue 
89528>>>>>>>>>            Move (sValue = sConnectionID) to bExists
89529>>>>>>>>>            If (bExists) Begin
89531>>>>>>>>>                Increment iItems
89532>>>>>>>>>            End
89532>>>>>>>>>>
89532>>>>>>>>>        Loop
89533>>>>>>>>>>
89533>>>>>>>>>                
89533>>>>>>>>>        Function_Return (iItems > 1)
89534>>>>>>>>>    End_Function       
89535>>>>>>>>>    
89535>>>>>>>>>    // To update the SQLConnections.ini file with a new default Connection ID.
89535>>>>>>>>>    Function SQLIniFileSetDefaultConnection String sConnectionID Returns Boolean
89537>>>>>>>>>        Boolean bRetval bOK
89537>>>>>>>>>        Integer iItem iSize iCount
89537>>>>>>>>>        tSQLConnection[] SQLConnectionsArray
89537>>>>>>>>>        tSQLConnection[] SQLConnectionsArray
89538>>>>>>>>>        tSQLConnection SQLConnection
89538>>>>>>>>>        tSQLConnection SQLConnection
89538>>>>>>>>>        String sConnectionString
89538>>>>>>>>>        
89538>>>>>>>>>        Move False to Err     
89539>>>>>>>>>        Get psConnectionString to sConnectionString             
89540>>>>>>>>>        
89540>>>>>>>>>        Get SQLIniFileReadConnections to SQLConnectionsArray
89541>>>>>>>>>        Move (SizeOfArray(SQLConnectionsArray)) to iSize
89542>>>>>>>>>        Decrement iSize
89543>>>>>>>>>        // Set all current connection to inactive.
89543>>>>>>>>>        For iCount from 0 to iSize
89549>>>>>>>>>>
89549>>>>>>>>>            Move False to SQLConnectionsArray[iCount].bEnabled
89550>>>>>>>>>        Loop                                              
89551>>>>>>>>>>
89551>>>>>>>>>        
89551>>>>>>>>>        Get SQLIniFileConnectionID sConnectionID to SQLConnection
89552>>>>>>>>>        Move True              to SQLConnection.bEnabled
89553>>>>>>>>>        Move sConnectionString to SQLConnection.sConnectionString
89554>>>>>>>>>        Move (InsertInArray(SQLConnectionsArray, 0, SQLConnection)) to SQLConnectionsArray
89555>>>>>>>>>        Get SQLIniFileWriteConnections SQLConnectionsArray to bOK
89556>>>>>>>>>        
89556>>>>>>>>>        Function_Return (bOK = True)
89557>>>>>>>>>    End_Function
89558>>>>>>>>>    
89558>>>>>>>>>    // Used for updating an existing connection with new data.
89558>>>>>>>>>    // Returns True if successful.
89558>>>>>>>>>    Function SQLIniFileUpdateConnection tSQLConnection SQLConnection Returns Boolean
89560>>>>>>>>>        Boolean bRetval bOK
89560>>>>>>>>>        Integer iItem iSize iCount
89560>>>>>>>>>        tSQLConnection[] SQLConnectionsArray
89560>>>>>>>>>        tSQLConnection[] SQLConnectionsArray
89561>>>>>>>>>        
89561>>>>>>>>>        Move False to Err           
89562>>>>>>>>>        Move -1 to iItem  
89563>>>>>>>>>        Get SQLIniFileReadConnections to SQLConnectionsArray
89564>>>>>>>>>        Move (SizeOfArray(SQLConnectionsArray)) to iSize
89565>>>>>>>>>        Decrement iSize
89566>>>>>>>>>        // Set all current connection to inactive.
89566>>>>>>>>>        For iCount from 0 to iSize
89572>>>>>>>>>>
89572>>>>>>>>>            Move False to SQLConnectionsArray[iCount].bEnabled 
89573>>>>>>>>>            If (SQLConnectionsArray[iCount].sConnectionID = SQLConnection.sConnectionID) Begin
89575>>>>>>>>>                Move iCount to iItem
89576>>>>>>>>>            End
89576>>>>>>>>>>
89576>>>>>>>>>        Loop                                              
89577>>>>>>>>>>
89577>>>>>>>>>        
89577>>>>>>>>>        If (iItem <> -1) Begin
89579>>>>>>>>>            Move True to SQLConnection.bEnabled
89580>>>>>>>>>            Move SQLConnection to SQLConnectionsArray[iItem]
89581>>>>>>>>>            Get SQLIniFileWriteConnections SQLConnectionsArray to bOK
89582>>>>>>>>>        End
89582>>>>>>>>>>
89582>>>>>>>>>        
89582>>>>>>>>>        Function_Return (bOK = True)
89583>>>>>>>>>    End_Function
89584>>>>>>>>>    
89584>>>>>>>>>    Function SQLIniFileReadConnections Returns tSQLConnection[]
89586>>>>>>>>>        tSQLConnection[] SQLConnectionsArray
89586>>>>>>>>>        tSQLConnection[] SQLConnectionsArray
89587>>>>>>>>>        String sSection sValue
89587>>>>>>>>>        Integer iCount
89587>>>>>>>>>        Boolean bExists bEnabled
89587>>>>>>>>>        
89587>>>>>>>>>        Get psIniSectionName to sSection
89588>>>>>>>>>        Get SectionExists sSection to bExists
89589>>>>>>>>>        If (bExists = False) Begin   
89591>>>>>>>>>            Function_Return SQLConnectionsArray
89592>>>>>>>>>        End                                  
89592>>>>>>>>>>
89592>>>>>>>>>        Get SectionExists CS_SQLIniConnectionSection to bExists
89593>>>>>>>>>        If (bExists = True) Begin
89595>>>>>>>>>            Error DFERR_PROGRAM "Sorry, the format for the SQLConnections.ini file has been changed and this file has the old format that is no longer valid and thus cannot be read. You need to re-enter your connection(s)."
89596>>>>>>>>>>
89596>>>>>>>>>        End
89596>>>>>>>>>>
89596>>>>>>>>>                
89596>>>>>>>>>        Move 1 to iCount // The section name "[ConnectionXX]" starts with "1"
89597>>>>>>>>>        Get SectionExists (CS_SQLIniSectionName + String(iCount)) to bExists 
89598>>>>>>>>>        
89598>>>>>>>>>        While (bExists = True)
89602>>>>>>>>>            // We always put the enabled/active connection at the top
89602>>>>>>>>>            Move (iCount = 1) to bEnabled
89603>>>>>>>>>            Move bEnabled to SQLConnectionsArray[iCount].bEnabled
89604>>>>>>>>>            
89604>>>>>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniConnectionIdKeyword ""        to SQLConnectionsArray[iCount].sConnectionID
89605>>>>>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniDriverKeyword       ""        to SQLConnectionsArray[iCount].sDriverID
89606>>>>>>>>>
89606>>>>>>>>>            // The iDbType might be missing from the ini-file. This is e.g. the case when a DAW Managed Connection "DFConnId.ini" file is read.
89606>>>>>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniDbTypeKeyword       "99"      to sValue
89607>>>>>>>>>            If (sValue = "99") Begin
89609>>>>>>>>>                Get SqlUtilDbTypeFromDriver SQLConnectionsArray[iCount].sDriverID to sValue
89610>>>>>>>>>            End
89610>>>>>>>>>>
89610>>>>>>>>>            Move sValue                                                                                     to SQLConnectionsArray[iCount].iDbType
89611>>>>>>>>>
89611>>>>>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniConnectionKeyWord   ""        to SQLConnectionsArray[iCount].sConnectionString
89612>>>>>>>>>            Get ParseKeyWord SQLConnectionsArray[iCount].sConnectionString (CS_SQLIniServerKeyword + "=")   to SQLConnectionsArray[iCount].sServer
89613>>>>>>>>>            If (SQLConnectionsArray[iCount].sServer = "") Begin
89615>>>>>>>>>                Get ParseKeyWord SQLConnectionsArray[iCount].sConnectionString (CS_SQLIniDSNKeyword +"=")   to SQLConnectionsArray[iCount].sServer
89616>>>>>>>>>            End
89616>>>>>>>>>>
89616>>>>>>>>>            Get ParseKeyWord SQLConnectionsArray[iCount].sConnectionString (CS_SQLIniDatabaseKeyword + "=") to SQLConnectionsArray[iCount].sDatabase
89617>>>>>>>>>
89617>>>>>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniTrustedKeyword      ""        to sValue
89618>>>>>>>>>            Move (If(Uppercase(sValue) = "YES", True, False))                                               to SQLConnectionsArray[iCount].bTrusted
89619>>>>>>>>>
89619>>>>>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniUIDKeyword          ""        to SQLConnectionsArray[iCount].sUserID
89620>>>>>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniDFPWDKeyword        ""        to sValue
89621>>>>>>>>>            If (pbDFConnId(Self) = False and sValue <> "") Begin
89623>>>>>>>>>                Get DecryptPassword sValue to sValue    
89624>>>>>>>>>            End
89624>>>>>>>>>>
89624>>>>>>>>>            Move sValue                                                                                     to SQLConnectionsArray[iCount].sPassword
89625>>>>>>>>>            
89625>>>>>>>>>            // Here we reconstruct the connection string to be complete with all params;
89625>>>>>>>>>            Get ConstructConnectionString SQLConnectionsArray[iCount].sDriverID SQLConnectionsArray[iCount].sServer SQLConnectionsArray[iCount].sDatabase ;                                          SQLConnectionsArray[iCount].bTrusted SQLConnectionsArray[iCount].sUserID SQLConnectionsArray[iCount].sPassword ;                                          to SQLConnectionsArray[iCount].sConnectionString    
89626>>>>>>>>>            
89626>>>>>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniSchemaKeyword          ""     to SQLConnectionsArray[iCount].sSchema
89627>>>>>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniBaseTableSpaceKeyword  ""     to SQLConnectionsArray[iCount].sBaseTableSpace
89628>>>>>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniLongTableSpaceKeyword  ""     to SQLConnectionsArray[iCount].sLongTableSpace
89629>>>>>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniIndexTableSpaceKeyword ""     to SQLConnectionsArray[iCount].sIndexTableSpace
89630>>>>>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniSilentLoginKeyword     ""     to SQLConnectionsArray[iCount].bSilentLogin  
89631>>>>>>>>>//            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniDisabledKeyword        ""     to SQLConnectionsArray[iCount].bDisabled
89631>>>>>>>>>
89631>>>>>>>>>            Increment iCount
89632>>>>>>>>>            Get SectionExists (CS_SQLIniSectionName + String(iCount)) to bExists
89633>>>>>>>>>        Loop
89634>>>>>>>>>>
89634>>>>>>>>>        
89634>>>>>>>>>        // Lastly, we remove the very first array item as it is empty (we started at 1 because that is the first [Connection#])
89634>>>>>>>>>        If (SizeOfArray(SQLConnectionsArray) > 0) Begin
89636>>>>>>>>>            Move (RemoveFromArray(SQLConnectionsArray, 0)) to SQLConnectionsArray
89637>>>>>>>>>        End
89637>>>>>>>>>>
89637>>>>>>>>>        
89637>>>>>>>>>        Function_Return SQLConnectionsArray
89638>>>>>>>>>    End_Function 
89639>>>>>>>>>        
89639>>>>>>>>>    Function SQLIniFileWriteConnections tSQLConnection[] SQLConnectionsArray Returns Boolean
89641>>>>>>>>>        Integer iCount iSize iItem
89641>>>>>>>>>        Boolean bIsOneActive bEnabled bExists bOK
89641>>>>>>>>>        String sConnectionString sSection sValue
89641>>>>>>>>>        
89641>>>>>>>>>        // First we need to _remove_ all current connections in the ini-file, we
89641>>>>>>>>>        // do that by setting their values to "".
89641>>>>>>>>>        Move 0 to iCount  
89642>>>>>>>>>        Get SQLIniFileDeleteAllConnections to bOK
89643>>>>>>>>>        If (bOK = False) Begin
89645>>>>>>>>>            Function_Return False
89646>>>>>>>>>        End                 
89646>>>>>>>>>>
89646>>>>>>>>>        
89646>>>>>>>>>        Move False to Err
89647>>>>>>>>>        Get psIniSectionName to sSection                                                          
89648>>>>>>>>>        // Sorting will make sure we have the active connection record as the first connection item in the ini-file.
89648>>>>>>>>>        Move (SortArray(SQLConnectionsArray, Self, (RefFunc(SortActiveFirst)))) to SQLConnectionsArray
89649>>>>>>>>>        Move (SizeOfArray(SQLConnectionsArray)) to iSize
89650>>>>>>>>>        Decrement iSize       
89651>>>>>>>>>        
89651>>>>>>>>>        For iCount from 0 to iSize
89657>>>>>>>>>>
89657>>>>>>>>>            // DF 19 compatible settings:
89657>>>>>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniConnectionIdKeyword   to SQLConnectionsArray[iCount].sConnectionID
89658>>>>>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniDriverKeyword         to SQLConnectionsArray[iCount].sDriverID
89659>>>>>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniUIDKeyword            to SQLConnectionsArray[iCount].sUserID
89660>>>>>>>>>            
89660>>>>>>>>>            Move SQLConnectionsArray[iCount].sPassword to sValue
89661>>>>>>>>>            If (pbDFConnId(Self) = False and sValue <> "") Begin
89663>>>>>>>>>                Get EncryptPassword sValue to sValue    
89664>>>>>>>>>            End
89664>>>>>>>>>>
