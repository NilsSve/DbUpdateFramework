100838>    // All of the code below are methods and augmentations which makes this work well as a test program. This:
100838>    // 1. Supports an auto-activate feature where all dialogs in the view and report menu are activated upon startup
100838>    // 2. forces the panel to resize if it is not large enough to accomodate all of the views.
100838>    // This code was placed directly in the testproject template and, therefore, directly in the .src file so
100838>    // a developer can easily modify this to fit their own needs. It is not expected that these techniques would
100838>    // get used in actual deployed projects.
100838>
100838>    // special test component code to activate all views and reports. For testing we assume
100838>    // that you want to see everything.
100838>
100838>    Procedure AutoActivate
100841>        Handle hoMenu
100841>
100841>        // this activates all views from the view menu
100841>        Get phoViewMenu to hoMenu
100842>        If hoMenu Begin
100844>           Broadcast Send Execute of hoMenu
100846>        End
100846>
100846>        // this activates all views from the report view menu
100846>        Get phoReportMenu to hoMenu
100847>        If hoMenu Begin
100849>           Broadcast Send Execute of hoMenu
100851>        End
100851>    End_Procedure
100852>
100852>    // This checks all views within the client area to make sure that they fit within
100852>    // the client area. If not we will adjust the main panel so everything fits. This
100852>    // can only be done after the objects are all activated.
100852>
100852>    Procedure MakeGoodPanelSize
100855>        Handle hoView hoClient
100855>        Integer iSize iLoc iHeight iWidth iOldHeight iOldWidth 
100855>        Integer iLeft iTop iRight iBottom
100855>        Get Client_Id to hoClient
100856>        If hoClient Begin
100858>            
100858>            // if not using commandbars or for some reason they are not created yet we
100858>            // will use whatever the client size is
100858>            If (ghoCommandBars=0 or not(IsComObjectCreated(ghoCommandBars))) Begin
100860>                Get GuiSize of hoClient to iSize  // starting size of client area
100861>                Move (Hi(iSize)) to iOldHeight
100862>                Move (Low(iSize)) to iOldWidth
100863>            End
100863>            Else Begin
100864>               // if commandbars are created, the actual size of the client area must be obtained
100864>               // from the commandbar 
100864>               Send ComGetClientRect of ghoCommandBars (&iLeft) (&iTop) (&iRight) (&iBottom)
100865>               Move (iRight-iLeft) to iOldWidth
100866>               Move (iBottom-iTop) to iOldHeight
100867>            End
100867>            
100867>            Move iOldHeight to iHeight
100868>            Move iOldWidth to iWidth
100869>            
100869>            // for each mdi client see if it fits, keep track of largest size needed
100869>            Get Next_Mdi_Dialog of hoClient True to hoView // find first
100870>            While (hoView)
100874>                Get GuiWindowSize of hoView to iSize    // size of view
100875>                Get GuiLocation of hoView to iLoc // location of view
100876>                Move (hi(iSize)+hi(iLoc)+10 max iHeight)  to iHeight // max height needed (+10 pixels is small border)
100877>                Move (low(iSize)+low(iLoc)+10 max iWidth) to iWidth  // max width needed
100878>                Get Next_Mdi_Dialog of hoClient False to hoView // find next view
100879>            Loop
100880>            Move (iHeight-iOldHeight  max 0) to iHeight // get delta compared to old size. We want delta
100881>            Move (iWidth-iOldWidth max 0) to iWidth     // only if the new size is bigger (i.e., > 0)
100882>            If  (iHeight>0 or iWidth>0) Begin
100884>                Get GuiSize to iSize // now add the delta to the panel size
100885>                Set GuiSize to (hi(iSize)+iHeight) (low(iSize)+iWidth)
100886>                Send Adjust_Logicals // adjust from gui to regular size
100887>            End
100887>        End
100887>    End_Procedure
100888>    
100888>    // Note that we have overriden the cHtmlHelp "GetHelpFile" function
100888>    // in the oHtmlHelp object, so we need to explitetly send the message
100888>    // to that object.
100888>    Procedure ShowProgramHelp
100891>        Send DoDisplayKeyword of oHtmlHelp "cDbUpdateFunctionLibrary"
100892>    End_Procedure
100893>
100893>    On_Key Key_F1 Send ShowProgramHelp
