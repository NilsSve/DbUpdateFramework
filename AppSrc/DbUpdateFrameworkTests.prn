92725>>>>>    // This function allows you to put an Sql script in a CM Image. It makes it easier to
92725>>>>>    // copy and paste between a DataFlex program and an Sql Editor.
92725>>>>>    Function SqlUtilLoadImageFile String sFileName Returns String
92727>>>>>        Integer iChannel iPos
92727>>>>>        String sTextValue sLine sPath
92727>>>>>        Boolean bSeqEof
92727>>>>>        
92727>>>>>        Move "" to sTextValue        
92728>>>>>        Get ParseFolderName sFileName to sPath
92729>>>>>        If (Trim(sPath) = "") Begin
92731>>>>>            Get psDataPathFirstPart to sPath
92732>>>>>            Move (sPath + sFileName) to sFileName
92733>>>>>        End
92733>>>>>>
92733>>>>>        
92733>>>>>        Get Seq_New_Channel to iChannel
92734>>>>>        If (iChannel = DF_SEQ_CHANNEL_NOT_AVAILABLE) Begin
92736>>>>>            Error DFERR_PROGRAM "No channel available..."
92737>>>>>>
92737>>>>>        End
92737>>>>>>
92737>>>>>        Else Begin        
92738>>>>>            Direct_Input channel iChannel sFileName
92740>>>>>            Move (SeqEof) to bSeqEof
92741>>>>>            If (bSeqEof = True) Begin
92743>>>>>                Send Seq_Release_Channel iChannel 
92744>>>>>                Set psSQLStatementString to ""  
92745>>>>>                Error DFERR_PROGRAM ("The Sql script file:\n" + sFileName + "\nCould not be found.")
92746>>>>>>
92746>>>>>                Function_Return "" 
92747>>>>>            End
92747>>>>>>
92747>>>>>    
92747>>>>>            While (not(bSeqEof))
92751>>>>>                Readln channel iChannel sLine 
92753>>>>>                Move (Pos("/", sLine)) to iPos
92754>>>>>                Move (SeqEol) to bSeqEof
92755>>>>>                If (not(bSeqEof) and iPos <> 1) Begin
92757>>>>>                    Move (sTextValue + sLine + Character(13)) to sTextValue
92758>>>>>                End
92758>>>>>>
92758>>>>>            Loop
92759>>>>>>
92759>>>>>            Send Seq_Release_Channel iChannel
92760>>>>>        End
92760>>>>>>
92760>>>>>        
92760>>>>>        Set psSQLStatementString to sTextValue
92761>>>>>        Function_Return sTextValue
92762>>>>>    End_Function  
