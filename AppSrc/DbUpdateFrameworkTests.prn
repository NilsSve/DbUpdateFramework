93814>>>>>    
93814>>>>>    Procedure ApiTableConvertALLToSQL 
93816>>>>>        Integer[] iTablesArray                 
93817>>>>>        Integer iSize iCount                     
93817>>>>>        Boolean bUseConnectionID bToANSI bRecnum bCopyData bOK
93817>>>>>        String sDriverID
93817>>>>>        
93817>>>>>        Get psDriverID to sDriverID   
93818>>>>>        Get pbUseConnectionID to bUseConnectionID
93819>>>>>        Get pbToANSI          to bToANSI
93820>>>>>        Get pbRecnum          to bRecnum
93821>>>>>        Get pbCopyData        to bCopyData
93822>>>>>        
93822>>>>>        Get _AllTablesToConvert to iTablesArray
93823>>>>>        Move (SizeOfArray(iTablesArray)) to iSize
93824>>>>>        Decrement iSize
93825>>>>>        For iCount from 0 to iSize
93831>>>>>>
93831>>>>>            Get ApiTableConvertToSQL_Ex iTablesArray[iCount] sDriverID bUseConnectionID bToANSI bRecnum bCopyData to bOK
93832>>>>>        Loop
93833>>>>>>
93833>>>>>    
93833>>>>>    End_Procedure
93834>>>>>    
93834>>>>>    Function _AllTablesToConvert Returns Integer[]
93836>>>>>        Integer[] iTableConvertExceptions iTablesArray
93838>>>>>        Handle hTable
93838>>>>>        Integer iIndex   
93838>>>>>        String sTableName
93838>>>>>        
93838>>>>>        // a) Get the exception table array the developer has specified
93838>>>>>        Get piTableConvertExceptions to iTableConvertExceptions        
93839>>>>>        
93839>>>>>        // b) Add CodeMast, CodeType & DbVersion to exceptions
93839>>>>>        Repeat 
93839>>>>>>
93839>>>>>            Get_Attribute DF_FILE_NEXT_USED of hTable to hTable
93842>>>>>            If (hTable > 0 and hTable <> 50) Begin // 50 = Flexerrs.
93844>>>>>                Get_Attribute DF_FILE_LOGICAL_NAME of hTable to sTableName
93847>>>>>                If (Uppercase(sTableName) = "CODEMAST" or Uppercase(sTableName) = "CODETYPE" or Uppercase(sTableName) = "DBVERSION") Begin
93849>>>>>                    Move (SearchArray(hTable, iTableConvertExceptions)) to iIndex
93850>>>>>                    If (iIndex = -1) Begin
93852>>>>>                        Move hTable to iTableConvertExceptions[SizeOfArray(iTableConvertExceptions)]
93853>>>>>                    End
93853>>>>>>
93853>>>>>                End
93853>>>>>>
93853>>>>>            End
93853>>>>>>
93853>>>>>        Until (hTable = 0) 
93855>>>>>        
93855>>>>>        Move 0 to hTable
93856>>>>>        
93856>>>>>        // c) Spin through filelist.cfg and add all tables except those from the exception array, to the return array.
93856>>>>>        Repeat 
93856>>>>>>
93856>>>>>            Get_Attribute DF_FILE_NEXT_USED of hTable to hTable
93859>>>>>            If (hTable > 0 and hTable <> 50) Begin // 50 = Flexerrs.
93861>>>>>                Move (SearchArray(hTable, iTableConvertExceptions)) to iIndex
93862>>>>>                If (iIndex = -1) Begin
93864>>>>>                    Move hTable to iTablesArray[SizeOfArray(iTablesArray)]    
93865>>>>>                End
93865>>>>>>
93865>>>>>            End
93865>>>>>>
93865>>>>>        Until (hTable = 0) 
93867>>>>>        
93867>>>>>        Function_Return iTablesArray
93868>>>>>    End_Function
93869>>>>>        
93869>>>>>    Function ApiTableConvertToSQL_Ex Handle hTable String sDriverID Boolean bUseConnectionID Boolean bToAnsi Boolean bRecnum Boolean bCopyData Returns Boolean
93871>>>>>        Handle hToTable
93871>>>>>        Boolean bOK bExists bOpened bMertechDriver bDAWDriver
93871>>>>>        String sPhysicalName sRootName sDisplayName sEmpty sConnectionID sConnectionString
93871>>>>>        String sDBOKeyWord sANSI_OEM sSchema sBaseTableSpace sLongTableSpace sIndexTableSpace sDatabase
93871>>>>>        tSQLConnection SQLConnection
93871>>>>>        tSQLConnection SQLConnection
93871>>>>>        
93871>>>>>        If (ghoProgressBar <> 0) Begin
93873>>>>>            Send DoAdvance of ghoProgressBar
93874>>>>>        End
93874>>>>>>
93874>>>>>
93874>>>>>        Get SqlUtilCheckIfTableHandleExists hTable sDriverID to bExists
93875>>>>>        If (bExists = True) Begin
93877>>>>>            // ToDo: Should we do an "auto - attach" ??
93877>>>>>            // If table already exists on the SQL back-end - check if
93877>>>>>            // the filelist entry has a driver prefix; else attach it.
93877>>>>>//            Get UtilIsFilelistEntryDriverBased hTable sDriverID to bExists
93877>>>>>//            If (bExists = False) Begin
93877>>>>>//                Get ApiTableAttachToSQL hTable True to bOK
93877>>>>>//            End
93877>>>>>            Function_Return False
93878>>>>>        End                      
93878>>>>>>
93878>>>>>        
93878>>>>>        Move CS_ANSI_Txt to sANSI_OEM
93879>>>>>        If (bToAnsi = False) Begin
93881>>>>>            Move CS_OEM_Txt to sANSI_OEM
93882>>>>>        End                                       
93882>>>>>>
93882>>>>>        
93882>>>>>        Get IsDAWSQLDriver sDriverID to bDAWDriver
93883>>>>>        // Mertech drivers don't use Connection ID's; so if bUseConnectionID was
93883>>>>>        // passed as True, we adjust for that here.
93883>>>>>        Get IsMertechDriver sDriverID to bMertechDriver
93884>>>>>        If (bMertechDriver = True and bUseConnectionID = True) Begin
93886>>>>>            Move False to bUseConnectionID
93887>>>>>        End  
93887>>>>>>
93887>>>>>
93887>>>>>        Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection  
93888>>>>>        Move SQLConnection.sSchema           to sSchema
93889>>>>>        If (sSchema = "") Begin
93891>>>>>            Get _SqlFindKeyWord CI_SQLDBO    to sSchema  
93892>>>>>            Move (Lowercase(sSchema))        to sSchema      
93893>>>>>        End
93893>>>>>>
93893>>>>>
93893>>>>>        If (sDriverID = ORAFLEX) Begin
93895>>>>>            Move SQLConnection.sUserID       to sSchema
93896>>>>>        End
93896>>>>>>
93896>>>>>
93896>>>>>        Move SQLConnection.sDatabase         to sDatabase   
93897>>>>>        Move SQLConnection.sConnectionID     to sConnectionID
93898>>>>>        Move SQLConnection.sConnectionString to sConnectionString 
93899>>>>>        If (sConnectionID = "" or sConnectionString = "") Begin
93901>>>>>            Error DFERR_PROGRAM ("The SQL connection info has NOT been setup. Could not convert table:" * String(hTable) * "to SQL")
93902>>>>>>
93902>>>>>            Function_Return False
93903>>>>>        End  
93903>>>>>>
93903>>>>>        
93903>>>>>        Get AutoConnectionIDLogin to bOK
93904>>>>>        Open hTable
93906>>>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpened
93909>>>>>        If (bOpened = False) Begin 
93911>>>>>            Error DFERR_PROGRAM ("Could not open table number:" * String(hTable))
93912>>>>>>
93912>>>>>            Function_Return False
93913>>>>>        End                      
93913>>>>>>
93913>>>>>        Move 0 to hToTable
93914>>>>>        
93914>>>>>        Get_Attribute DF_FILE_DISPLAY_NAME of hTable to sDisplayName
93917>>>>>        Get_Attribute DF_FILE_ROOT_NAME    of hTable to sRootName
93920>>>>>        Get _TableNameOnly sRootName                 to sRootName
93921>>>>>        Move (sRootName + ".int")                    to sPhysicalName
93922>>>>>        
93922>>>>>        Case Begin   
93922>>>>>            Case (sDriverID = MSSQLDRV_ID)
93924>>>>>                Case Break
93925>>>>>            Case (sDriverID = ODBC_DRV_ID)
93928>>>>>                Case Break
93929>>>>>            Case (sDriverID = DB2_DRV_ID)
93932>>>>>                Move SQLConnection.sBaseTableSpace  to sBaseTableSpace
93933>>>>>                Move SQLConnection.sLongTableSpace  to sLongTableSpace
93934>>>>>                Move SQLConnection.sIndexTableSpace to sIndexTableSpace
93935>>>>>                Case Break
93936>>>>>            Case (sDriverID = ORAFLEX)
93939>>>>>                Move SQLConnection.sBaseTableSpace  to sBaseTableSpace
93940>>>>>                Move SQLConnection.sIndexTableSpace to sIndexTableSpace
93941>>>>>                Case Break
93942>>>>>            Case (sDriverID = MDSMySQL) 
93945>>>>>                Case Break
93946>>>>>            Case (sDriverID = MDSPgSQL)
93949>>>>>                Move SQLConnection.sBaseTableSpace  to sBaseTableSpace
93950>>>>>                Move SQLConnection.sIndexTableSpace to sIndexTableSpace
93951>>>>>                Case Break  
93952>>>>>            Case (sDriverID = DATAFLEX_ID)
93955>>>>>                Case Break
93956>>>>>            Case Else
93956>>>>>                Error DFERR_PROGRAM "Wrong database driver passed to the 'ApiTableConvertToSQL_Ex' function."
93957>>>>>>
93957>>>>>                Case Break
93958>>>>>        Case End
93958>>>>>        
93958>>>>>        Move False to Err   
93959>>>>>
93959>>>>>        If (bMertechDriver = True) Begin  
93961>>>>>            // Note: This function also sets the Err flag.
93961>>>>>            Get _MertechApiTableConvertToSQL hTable sRootName sDatabase sDriverID sBaseTableSpace sIndexTableSpace bCopyData to bOK
93962>>>>>        End
93962>>>>>>
93962>>>>>
93962>>>>>        If (bMertechDriver = False) Begin
93964>>>>>            Structure_Start hToTable sDriverID
93965>>>>>                Structure_Copy hTable to hToTable
93966>>>>>                
93966>>>>>                Set_Attribute DF_FILE_PHYSICAL_NAME of hToTable to sPhysicalName  
93969>>>>>
93969>>>>>                If (sDriverID <> DATAFLEX_ID) Begin
93971>>>>>                    If (bUseConnectionID = True) Begin
93973>>>>>                        Set_Attribute DF_FILE_LOGIN     of hToTable to (CS_DFCONNID + "=" + sConnectionID)
93976>>>>>                    End
93976>>>>>>
93976>>>>>                    Else Begin
93977>>>>>                        Set_Attribute DF_FILE_LOGIN     of hToTable to sConnectionString
93980>>>>>                    End
93980>>>>>>
93980>>>>>                    
93980>>>>>                    Set_Attribute DF_FILE_TABLE_CHARACTER_FORMAT   of hToTable to sANSI_OEM
93983>>>>>                    Set_Attribute DF_FILE_RECNUM_TABLE             of hToTable to bRecnum
93986>>>>>                    
93986>>>>>                    If (sSchema <> "") Begin
93988>>>>>                        Set_Attribute DF_FILE_OWNER                of hToTable to sSchema
93991>>>>>                    End
93991>>>>>>
93991>>>>>        
93991>>>>>                    If (sDriverID = DB2_DRV_ID) Begin                           
93993>>>>>                        If (sLongTableSpace <> "") Begin
93995>>>>>                            Set_Attribute DF_FILE_LONG_TABLESPACE  of hToTable to sLongTableSpace
93998>>>>>                        End
93998>>>>>>
93998>>>>>                        If (sBaseTableSpace <> "") Begin
94000>>>>>                            Set_Attribute DF_FILE_TABLE_TABLESPACE of hToTable to sBaseTableSpace
94003>>>>>                        End
94003>>>>>>
94003>>>>>                        If (sIndexTableSpace <> "") Begin
94005>>>>>                            Set_Attribute DF_FILE_INDEX_TABLESPACE of hToTable to sIndexTableSpace
94008>>>>>                        End
94008>>>>>>
94008>>>>>                    End   
94008>>>>>>
94008>>>>>                End 
94008>>>>>>
94008>>>>>                       
94008>>>>>            Structure_End hToTable        
94010>>>>>        End
94010>>>>>>
94010>>>>>        
94010>>>>>        Move (not(Err)) to bOK
94011>>>>>        If (bOK = True and bCopyData = True and bMertechDriver = False) Begin
94013>>>>>            Get ApiTableCopyData hTable sPhysicalName sRootName sDriverID to bOK
94014>>>>>        End
94014>>>>>>
94014>>>>>
94014>>>>>        If (bMertechDriver = True) Begin
94016>>>>>            Open hTable
94018>>>>>        End
94018>>>>>>
94018>>>>>        
94018>>>>>        // This must be after copying data...    
94018>>>>>        If (Err = False) Begin
94020>>>>>            Set_Attribute DF_FILE_ROOT_NAME of hTable to (sDriverID + ":" + sRootName)
94023>>>>>            // We also adjust the display name by prefixing it by the schema name;
94023>>>>>            If (not(Lowercase(sDisplayName) contains Lowercase(sSchema + "."))) Begin
94025>>>>>                // The max length for the display_name is 31 characters...
94025>>>>>                If (Length(sSchema + "." + sDisplayName) < 31) Begin
94027>>>>>                    Set_Attribute DF_FILE_DISPLAY_NAME of hTable to (Lowercase(sSchema) + "." + sDisplayName)
94030>>>>>                End
94030>>>>>>
94030>>>>>            End
94030>>>>>>
94030>>>>>        End
94030>>>>>>
94030>>>>>        
94030>>>>>        Move (not(Err)) to bOK
94031>>>>>        Function_Return (bOK = True)
94032>>>>>    End_Function                 
94033>>>>>    
94033>>>>>    // Calls a driver function directly to copy data from one table to another (table structures needs to be the same).
94033>>>>>    // It will first drop all indicies, copy the data and then recreate indicies. 
94033>>>>>    // An error log file with the sRootname + ".err" will be created in the Data folder.
94033>>>>>    Function ApiTableCopyData Integer hFromTable String sPhysicalName String sRootName String sDriverID Returns Boolean
94035>>>>>        Boolean bOpened bOK
94035>>>>>        Integer hToTable iIndex iCount iRetval iVoid iOrgFreq
94035>>>>>        String sErrorFile sEmpty sPath
94035>>>>>        
94035>>>>>        Get_Attribute DF_FILE_NEXT_EMPTY of 0 to hToTable
94038>>>>>        Get AutoConnectionIDLogin to bOK
94039>>>>>        If (sDriverID = DATAFLEX_ID) Begin
94041>>>>>            Send IncreaseSortBufferSize  
94042>>>>>//            Send SetAllIndexesToBatch hToTable
94042>>>>>        End                          
94042>>>>>>
94042>>>>>
94042>>>>>        Move False to Err
94043>>>>>        Open sPhysicalName as hToTable
94045>>>>>        Get_Attribute DF_FILE_OPENED of hToTable to bOpened
94048>>>>>        If (bOpened = False) Begin
94050>>>>>            Function_Return False
94051>>>>>        End                      
94051>>>>>>
94051>>>>>        
94051>>>>>        Move "" to sEmpty 
94052>>>>>        Move False to Err   
94053>>>>>        Move True to bOK       
94054>>>>>        
94054>>>>>        Get_Attribute DF_RUNTIME_PROGRESS_FREQUENCY to iOrgFreq
94057>>>>>        Set_Attribute DF_RUNTIME_PROGRESS_FREQUENCY to 10        
94060>>>>>        If (sDriverID <> DATAFLEX_ID) Begin
94062>>>>>            // Remove all indices to speed up copying of data:
94062>>>>>            Call_Driver hToTable sDriverID Function CLI_DROPINDICES Callback Self Passing sEmpty sEmpty iVoid Result iRetval
94067>>>>>            If (iRetval <> 0) Begin
94069>>>>>                Error DFERR_PROGRAM ("Failed dropping indices for table:" * sRootName)
94070>>>>>>
94070>>>>>                Function_Return False
94071>>>>>            End
94071>>>>>>
94071>>>>>        End
94071>>>>>>
94071>>>>>        
94071>>>>>        Move (sRootName + ".err") to sErrorFile  
94072>>>>>        Move 0 to iIndex           
94073>>>>>        Move False to Err   
94074>>>>>        
94074>>>>>        Copy_Records hFromTable to hToTable using 0 Callback Self
94077>>>>>                  
94077>>>>>        If (Err = False) Begin             
94079>>>>>            Get psHome of (phoWorkspace(ghoApplication)) to sPath  
94080>>>>>            Get vDeleteFile (sPath + sErrorFile) to iRetval
94081>>>>>        End                                                          
94081>>>>>>
94081>>>>>        
94081>>>>>        If (sDriverID <> DATAFLEX_ID) Begin
94083>>>>>            // Recreate indices:
94083>>>>>            Call_Driver hToTable sDriverID Function CLI_CREATEINDICES Callback Self Passing sEmpty sEmpty iVoid Result iRetval
94088>>>>>        End
94088>>>>>>
94088>>>>>        
94088>>>>>        Close hToTable
94089>>>>>        Set_Attribute DF_RUNTIME_PROGRESS_FREQUENCY to iOrgFreq
94092>>>>>        
94092>>>>>        If (bOK = True) Begin
94094>>>>>            Move (not(Err)) to bOK
94095>>>>>        End
94095>>>>>>
94095>>>>>        
94095>>>>>        If (ghoStatusPanel <> 0) Begin
94097>>>>>            Set Message_Text of ghoStatusPanel to ""
94098>>>>>            Set Action_Text  of ghoStatusPanel to ""
94099>>>>>        End
94099>>>>>>
94099>>>>>        
94099>>>>>        Function_Return (bOK = True)
94100>>>>>    End_Function 
94101>>>>>
94101>>>>>    Procedure IncreaseSortBufferSize
94103>>>>>        String sNull
94103>>>>>        Integer iSortBufferSize
94103>>>>>        Boolean bBufferSet
94103>>>>>    
94103>>>>>        Move "" to sNull
94104>>>>>        Move (1024 * 128) to iSortBufferSize
94105>>>>>        Call_Driver 0 DATAFLEX_ID Function FLEX_SET_MAX_SORT_BUFFER Callback Self Passing sNull sNull iSortBufferSize Result bBufferSet
94110>>>>>    
94110>>>>>    End_Procedure     
94111>>>>>    
94111>>>>>    Procedure SetAllIndexesToBatch Handle hTable
94113>>>>>        Integer iLastIndex iIndex iNumSegments iIndexType
94113>>>>>        String sTable
94113>>>>>    
94113>>>>>        If (hTable > 0) Begin
94115>>>>>            Close hTable
94116>>>>>            Open hTable Mode DF_EXCLUSIVE
94118>>>>>            Get_Attribute DF_FILE_LAST_INDEX_NUMBER of hTable to iLastIndex
94121>>>>>            for iIndex from 1 to iLastIndex
94127>>>>>>
94127>>>>>                Get_Attribute DF_INDEX_NUMBER_SEGMENTS of hTable iIndex to iNumSegments
94130>>>>>                If (iNumSegments > 0) Begin
94132>>>>>                    Set_Attribute DF_INDEX_TYPE of hTable iIndex to DF_INDEX_TYPE_BATCH
94135>>>>>                End
94135>>>>>>
94135>>>>>            Loop
94136>>>>>>
94136>>>>>            Close hTable
94137>>>>>        End
94137>>>>>>
94137>>>>>    End_Procedure 
94138>>>>>    
94138>>>>>
94138>>>>>    // The bANSI parameter's default value = True, meaning a table in ANSI format will be created.
94138>>>>>    // i.e. DF_FILE_TABLE_CHARACTER_FORMAT {"OEM"|"ANSI"}
94138>>>>>    Function ApiTableCreate Handle hTable String sRoot String sDisplay String sTableName Boolean bUseConnectionID Boolean bANSI Boolean bRecnum Returns Boolean
94140>>>>>        Handle hFile
94140>>>>>        String sConnectionID sPhysicalFile sANSI_OEM sVal sSchema sOriginalDriverID sDriverID
94140>>>>>        Integer iColumn 
94140>>>>>        Boolean bOk bExists bMertechDriver
94140>>>>>        tSQLConnection SQLConnection
94140>>>>>        tSQLConnection SQLConnection
94140>>>>>
94140>>>>>        If (ghoProgressBar <> 0) Begin
94142>>>>>            Send DoAdvance of ghoProgressBar
94143>>>>>        End
94143>>>>>>
94143>>>>>        
94143>>>>>        // First check if the passed filenumber already exists; in case we do nothing
94143>>>>>        Get UtilTableNumberIsInUse hTable to bOk
94144>>>>>        If (bOk = True) Begin
94146>>>>>            Function_Return False
94147>>>>>        End
94147>>>>>>
94147>>>>>        
94147>>>>>        Get psDriverID to sDriverID
94148>>>>>        // If this is a SQL based driver we also check if the table exists
94148>>>>>        // in the SQL back end; in case we do nothing.
94148>>>>>        Get IsSQLDriver sDriverID to bOk
94149>>>>>        If (bOk = True) Begin
94151>>>>>            Get SqlUtilCheckIfTableHandleExists hTable sDriverID to bExists
94152>>>>>            If (bExists = True) Begin
94154>>>>>                Function_Return False
94155>>>>>            End                      
94155>>>>>>
94155>>>>>        
94155>>>>>            // Get all connection properties
94155>>>>>            Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection  
94156>>>>>            Move SQLConnection.sSchema to sSchema
94157>>>>>            If (sSchema = "") Begin
94159>>>>>                Get _SqlFindKeyWord CI_SQLDBO to sSchema  
94160>>>>>            End
94160>>>>>>
94160>>>>>        End
94160>>>>>>
94160>>>>>        
94160>>>>>        Move CS_ANSI_Txt to sANSI_OEM
94161>>>>>        If (num_arguments > 6) Begin
94163>>>>>            If (bANSI = False) Begin
94165>>>>>                Move CS_OEM_Txt to sANSI_OEM
94166>>>>>            End
94166>>>>>>
94166>>>>>        End  
94166>>>>>>
94166>>>>>        
94166>>>>>        // Mertech drivers don't use connection id's, so if the passed bUseConnectionID = True that
94166>>>>>        // is a programmer's error and we auto-correct for it here.
94166>>>>>        // This is also a bit messy. If a Mertech driver is used and we want to create a new table,
94166>>>>>        // we first need to create it as embedded (DataFlex) and then convert it to SQL (!)
94166>>>>>        // So we set the driver ID temporarily to "DataFlex" to get the table created as embedded and later
94166>>>>>        // set it back and use a Mertech function to convert it to SQL.
94166>>>>>        Get IsMertechDriver sDriverID to bMertechDriver
94167>>>>>        If (bMertechDriver = True) Begin
94169>>>>>            If (bUseConnectionID = True) Begin
94171>>>>>                Move False to bUseConnectionID
94172>>>>>            End
94172>>>>>>
94172>>>>>            Move sDriverID to sOriginalDriverID
94173>>>>>            Move DATAFLEX_ID to sDriverID
94174>>>>>        End
94174>>>>>>
94174>>>>>            
94174>>>>>        Move False to Err
94175>>>>>        If (sDriverID = DATAFLEX_ID) Begin
94177>>>>>            Move sRoot to sPhysicalFile 
94178>>>>>        End
94178>>>>>>
94178>>>>>        
94178>>>>>        If (sDriverID <> DATAFLEX_ID) Begin 
94180>>>>>            Move SQLConnection.sConnectionID to sConnectionID
94181>>>>>            
94181>>>>>            // If DAW driver and we should use a connection id we need to
94181>>>>>            // check if the connection ID exists; else we create it before attempting creating the table
94181>>>>>            If (bMertechDriver = False and bUseConnectionID = True) Begin
94183>>>>>                Get IsConnectionID sConnectionID sDriverID to bExists
94184>>>>>                If (bExists = False) Begin
94186>>>>>                    Get UtilCreateConnectionID sConnectionID to bOk
94187>>>>>                    If (bOk = False) Begin
94189>>>>>                        Error DFERR_PROGRAM ("The Connection ID:" * sConnectionID * "could not be created and therefor the table can't be created.")
94190>>>>>>
94190>>>>>                        Function_Return False
