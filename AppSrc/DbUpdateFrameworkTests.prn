92890>>>>>    
92890>>>>>    // *** Helper Functions ***
92890>>>>>    // They all start with an underscore: "_" in the function name.
92890>>>>>    //
92890>>>>>    // Reads a SQL script file that has been compiled into the .exe program as a resource.
92890>>>>>    // Pass: The memory resource reference and a boolean True if you want to create the file on disk (in the Home folder).
92890>>>>>    // Returns: A tSQLScriptArray Struct with the Sql script as an uChar Array will be returned along with the a bError boolean.
92890>>>>>    Function SqlUtilReadResource String sMemFileName Returns tSQLScriptArray
92892>>>>>        Integer iChannel iArgumentSize iOut iChunk iPointer iCount iSize
92892>>>>>        Number nByteCount
92892>>>>>        String sCharacter sSQLScript 
92892>>>>>        Boolean bSeqEof
92892>>>>>        tSQLScriptArray SqlScriptArray
92892>>>>>        tSQLScriptArray SqlScriptArray
92892>>>>>        UChar[] uCharData
92893>>>>>        
92893>>>>>        Move False to Err
92894>>>>>        Get Seq_New_Channel to iChannel
92895>>>>>        If (iChannel = DF_SEQ_CHANNEL_NOT_AVAILABLE) Begin
92897>>>>>            Error DFERR_PROGRAM 'No channel available...'
92898>>>>>>
92898>>>>>            Move True to SqlScriptArray.bError
92899>>>>>            Function_Return SqlScriptArray
92900>>>>>        End                    
92900>>>>>>
92900>>>>>        
92900>>>>>        // First decide the size of the script
92900>>>>>        Direct_Input channel iChannel ("Resource: " + sMemFileName)
92902>>>>>        Read_Block channel iChannel uCharData -1 // -1 means that all data should be read.
92904>>>>>        Close_Input channel iChannel
92906>>>>>
92906>>>>>        Move (SizeOfArray(uCharData)) to nByteCount 
92907>>>>>        If (nByteCount  < 1) Begin
92909>>>>>            Send Seq_Release_Channel iChannel  
92910>>>>>            Move True to SqlScriptArray.bError
92911>>>>>            Function_Return SqlScriptArray
92912>>>>>        End
92912>>>>>>
92912>>>>>        
92912>>>>>        // If necessary change the string argument_size
92912>>>>>        Get_Argument_Size to iArgumentSize
92913>>>>>        If (nByteCount >= iArgumentSize) Begin
92915>>>>>            Move (nByteCount + 2048) to nByteCount
92916>>>>>            Set_Argument_Size nByteCount // Set new argument size just a bit higher than "needed" for overhead margin.
92917>>>>>>
92917>>>>>            Move True          to SqlScriptArray.bArgumentSizeChanged
92918>>>>>            Move iArgumentSize to SqlScriptArray.iOrgArgumentSize
92919>>>>>        End                         
92919>>>>>>
92919>>>>>        Else Begin
92920>>>>>            Move False to SqlScriptArray.bArgumentSizeChanged
92921>>>>>        End
92921>>>>>>
92921>>>>>        
92921>>>>>        // Read the script file from memory line-by-line
92921>>>>>        Direct_Input channel iChannel ("Resource: " + sMemFileName) 
92923>>>>>            Move 0 to iCount
92924>>>>>            Repeat
92924>>>>>>
92924>>>>>                Readln channel iChannel sSQLScript
92926>>>>>                Move sSQLScript to SqlScriptArray.sSQLScriptArray[iCount]
92927>>>>>                Increment iCount
92928>>>>>            Until (SeqEof = True)
92930>>>>>        Close_Input channel iChannel
92932>>>>>        Send Seq_Release_Channel iChannel 
92933>>>>>        
92933>>>>>        // Finally "sanitize" the script by removing all comments.
92933>>>>>        Get _SqlUtilSanitizeScript SqlScriptArray to SqlScriptArray  
92934>>>>>
92934>>>>>        Function_Return SqlScriptArray
92935>>>>>    End_Function 
92936>>>>>    
92936>>>>>    Function SqlUtilExecuteEmbeddedScript tSQLScriptArray SQLScriptArray String sDriverID Boolean bCreateScriptFile String sMemFileName Boolean bShowProgr Returns Boolean
92938>>>>>        String sSQLVal sStmt sCR sDebugFileName sTmp sGOKeyWord sNoCountKeyWord sMessage sExportFile
92938>>>>>        Handle hoSql hoSQLConnect hoStmt hoError
92938>>>>>        Integer i iMsgs iFetchResult iResultCount iRows iRowType iCount iChunkCounter iChunkMax iPos iOut iNextSet iMessage
92938>>>>>        String[] sMsg aSQLQueryMessages
92940>>>>>        DateTime dtQueryExecStart dtQueryExecEnd
92940>>>>>        TimeSpan tsQuery
92940>>>>>        tSqlErrorArray aSqlErrorArray  
92940>>>>>        tSqlErrorArray aSqlErrorArray  
92940>>>>>        tSQLConnection SQLConnection
92940>>>>>        tSQLConnection SQLConnection
92940>>>>>        Boolean bOK bMertechDriver bShowProgress
92940>>>>>        
92940>>>>>        If (num_arguments > 4) Begin
92942>>>>>            Move bShowProgr to bShowProgress
92943>>>>>        End
92943>>>>>>
92943>>>>>        Get IsMertechDriver sDriverID to bMertechDriver
92944>>>>>        If (bMertechDriver = False) Begin
92946>>>>>            Get phoSQLManager to hoSql
92947>>>>>        End 
92947>>>>>>
92947>>>>>        Else Begin
92948>>>>>            Get _MertechSQLManagerHandle to hoSql
92949>>>>>        End
92949>>>>>>
92949>>>>>            
92949>>>>>        Get _SqlFindKeyWord CI_SQLGO to sGOKeyWord
92950>>>>>        // There seems to be a problem to pass strings when their value gets really big, aka
92950>>>>>        // above the argument_size level. It isn't clear when these problems starts but sooner
92950>>>>>        // or later SqlExecDirect stops working correctly with no error messages!
92950>>>>>        // To guard from this we set a max number of lines (iChunkMax) that can be processed
92950>>>>>        // at a time. Testing with the Create Chinook Database script; 500 seems like a number that works fine. 
92950>>>>>        // A bonus of this is that it turns out that it is actually faster to run in chunks!
92950>>>>>        Get piChunkMax to iChunkMax    
92951>>>>>        Move 0 to iChunkCounter                                 
92952>>>>>        Move "" to sStmt   
92953>>>>>
92953>>>>>        Get _SqlFindKeyWord CI_SQLSetNoCountOn to sNoCountKeyWord
92954>>>>>        Move (Character(13) + Character(10)) to sCR
92955>>>>>
92955>>>>>        Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
92956>>>>>        
92956>>>>>        If (bMertechDriver = True) Begin
92958>>>>>            Get _MertechSQLConnect sDriverID SQLConnection.sServer SQLConnection.sUserID SQLConnection.sPassword to hoSQLConnect
92959>>>>>        End
92959>>>>>>
92959>>>>>        If (bMertechDriver = False) Begin
92961>>>>>            Get phoSQLManager  to hoSQL
92962>>>>>            Send SqlSetConnect of hoSQL sDriverID SQLConnection.sConnectionString
92963>>>>>            Get SqlConnect     of hoSQL "" "" to hoSQLConnect
92964>>>>>        End
92964>>>>>>
92964>>>>>
92964>>>>>        If (hoSQLConnect <> 0) Begin 
92966>>>>>            Move False to Err
92967>>>>>            Get SqlOpen of hoSQLConnect to hoStmt
92968>>>>>            If (hoStmt <> 0) Begin
92970>>>>>
92970>>>>>                // If the embedded resource should be written as a script file to disk:
92970>>>>>                If (bCreateScriptFile = True) Begin
92972>>>>>                    Get psHome of (phoWorkspace(ghoApplication)) to sExportFile
92973>>>>>                    Get vFolderFormat sExportFile to sExportFile
92974>>>>>                    Move (sExportFile + sMemFileName) to sExportFile
92975>>>>>                    Get Seq_New_Channel to iOut 
92976>>>>>                    If (iOut <> DF_SEQ_CHANNEL_NOT_AVAILABLE) Begin
92978>>>>>                        Direct_Output channel iOut sExportFile  
92980>>>>>                    End
92980>>>>>>
92980>>>>>                End
92980>>>>>>
92980>>>>>        
92980>>>>>                // Record starting date/time stamp
92980>>>>>                Move (CurrentDateTime()) to dtQueryExecStart
92981>>>>>                // Turn on error handling if enabled
92981>>>>>                If (pbHandleQueryErrors(Self)) Begin
92983>>>>>                    Set pbSqlError to False  
92984>>>>>                    Set paSqlErrorArray to aSqlErrorArray
92985>>>>>                    Move Error_Object_Id to hoError
92986>>>>>                    Move Self to Error_Object_Id
92987>>>>>                End                                                    
92987>>>>>>
92987>>>>>                
92987>>>>>                Move (SizeOfArray(SQLScriptArray.sSQLScriptArray)) to iRows  
92988>>>>>                Decrement iRows
92989>>>>>                Move (sNoCountKeyWord + sCR) to sStmt
92990>>>>>
92990>>>>>                For iCount from 0 to iRows   
92996>>>>>>
92996>>>>>                    Move (SQLScriptArray.sSQLScriptArray[iCount]) to sSQLVal
92997>>>>>                    
92997>>>>>                    If (Uppercase(sSQLVal) <> sGOKeyWord) Begin
92999>>>>>                        If (sSQLVal <> "") Begin
93001>>>>>                            Move (sSQLVal + sCR) to sSQLVal
93002>>>>>                        End
93002>>>>>>
93002>>>>>                        Move (Append(sStmt, (sSQLVal))) to sStmt
93003>>>>>                    End
93003>>>>>>
93003>>>>>                    
93003>>>>>                    // - Each time we encounter a "GO" statement we execute it,
93003>>>>>                    // or if at the very end of the script.
93003>>>>>                    If (Uppercase(sSQLVal) = sGOKeyWord or iChunkCounter >= iChunkMax or iCount = iRows) Begin 
93005>>>>>                        
93005>>>>>                        // - It turns out it can be at least 10 times faster to execute SQL statements in chunks,
93005>>>>>                        // instead of all in one go. 
93005>>>>>                        Send SqlExecDirect of hoStmt sStmt 
93006>>>>>                        
93006>>>>>                        If (bCreateScriptFile = True) Begin
93008>>>>>                            Write channel iOut sStmt
93010>>>>>                        End
93010>>>>>>
93010>>>>>                        Move "" to sStmt   
93011>>>>>                        Move 0 to iChunkCounter
93012>>>>>                    End
93012>>>>>>
93012>>>>>                    Increment iChunkCounter
93013>>>>>                Loop
93014>>>>>>
93014>>>>>                       
93014>>>>>                Repeat
93014>>>>>>
93014>>>>>                    If (pbHandleQueryErrors(Self)) Begin
93016>>>>>                        Move hoError to Error_Object_Id
93017>>>>>                    End
93017>>>>>>
93017>>>>>                    Move (CurrentDateTime()) to dtQueryExecEnd  
93018>>>>>                    
93018>>>>>                    Send _SqlColumnInfo hoStmt
93019>>>>>                    Get SqlStmtAttribute of hoStmt SqlSTMTATTRIB_ROWCOUNT to iRows
93020>>>>>                    Get SqlStmtAttribute of hoStmt SqlSTMTATTRIB_ROWCOUNT_TYPE to iRowType
93021>>>>>                    Get SqlStmtAttribute of hoStmt SqlSTMTATTRIB_NUMMESSAGES to iMsgs
93022>>>>>                    Set piRows    to iRows
93023>>>>>                    Set piRowType to iRowType
93024>>>>>                   
93024>>>>>                    If (iMsgs <> 0) Begin
93026>>>>>                        If (ghoDbUpdateHandler > 0) Begin
93028>>>>>                            Get paSQLQueryMessages of ghoDbUpdateHandler to aSQLQueryMessages
93029>>>>>                        End
93029>>>>>>
93029>>>>>                        For i from 1 to iMsgs
93035>>>>>>
93035>>>>>                            Get SqlGetMessage of hoStmt i to sMessage     
93036>>>>>                            Get RemoveComponentIdentifier of hoStmt sMessage to sMessage   
93037>>>>>                            If (bShowProgress = True) Begin
93039>>>>>                                If (Active_State(ghoStatusPanel)) Begin
93041>>>>>                                    Send Update_StatusPanel of ghoStatusPanel (Sformat("  SQLGetMessage iMessage %1 returned [%2]", iMessage, sMessage))
93042>>>>>                                End                                                   
93042>>>>>>
93042>>>>>                                Else Begin
93043>>>>>                                    Showln (Sformat("  SQLGetMessage iMessage %1 returned [%2]", iMessage, sMessage))
93045>>>>>                                End
93045>>>>>>
93045>>>>>                            End
93045>>>>>>
93045>>>>>                            Move sMessage to sMsg[SizeOfArray(sMsg)]
93046>>>>>                            Move sMessage to aSQLQueryMessages[SizeOfArray(aSQLQueryMessages)]
93047>>>>>                        Loop   
93048>>>>>>
93048>>>>>                    
93048>>>>>                    
93048>>>>>                        If (ghoDbUpdateHandler > 0) Begin
93050>>>>>                            Set paSQLQueryMessages of ghoDbUpdateHandler to aSQLQueryMessages
93051>>>>>                        End
93051>>>>>>
93051>>>>>                        Set paQueryMessages to sMsg
93052>>>>>                    End
93052>>>>>>
93052>>>>>
93052>>>>>                    Get SQLNextResultSet of hoStmt to iNextSet
93053>>>>>                Until (iNextSet = 0)
93055>>>>>                
93055>>>>>                Move (CurrentDateTime()) to dtQueryExecEnd
93056>>>>>            End 
93056>>>>>>
93056>>>>>            
93056>>>>>            Move (dtQueryExecEnd - dtQueryExecStart) to tsQuery
93057>>>>>            Set ptsQueryExec to tsQuery  
93058>>>>>            Send SqlClose of hoStmt
93059>>>>>
93059>>>>>            If (bCreateScriptFile = True) Begin
93061>>>>>                Close_Output channel iOut
93063>>>>>                Send Seq_Release_Channel iOut
93064>>>>>            End
93064>>>>>>
93064>>>>>        End
93064>>>>>>
93064>>>>>        Send SqlDisconnect of hoSQLConnect
93065>>>>>
93065>>>>>        Function_Return (hoSQLConnect <> 0 and Err = False)
93066>>>>>    End_Function
93067>>>>>        
93067>>>>>    // Returns the index for the passed sTableName
93067>>>>>    // Returns >= 0 if successful. It is e.g. needed to get the SchemaName for a table.
93067>>>>>    Function _SqlUtilEnumerateTableIndex String sTableName String sDriverID Returns Integer
93069>>>>>        Integer iIndex iSize iCount
93069>>>>>        String[] sTablesArray
93070>>>>>        String sVal sConnectionString
93070>>>>>        
93070>>>>>        Move -1 to iIndex            
93071>>>>>        Get psConnectionString to sConnectionString
93072>>>>>        Get SqlUtilEnumerateTables sDriverID to sTablesArray
93073>>>>>        Move (SizeOfArray(sTablesArray)) to iSize
93074>>>>>        Decrement iSize
93075>>>>>        For iCount from 0 to iSize
93081>>>>>>
93081>>>>>            Move sTablesArray[iCount] to sVal
93082>>>>>            If (Uppercase(sVal) = Uppercase(sTableName)) Begin
93084>>>>>                Move iCount to iIndex // We found it!
93085>>>>>                Move iSize to iCount  // End the loop    
93086>>>>>            End
93086>>>>>>
93086>>>>>        Loop                  
93087>>>>>>
93087>>>>>        
93087>>>>>        Function_Return iIndex
93088>>>>>    End_Function
