89393>>>>>>>>>    // Sort function that first sorts on bEnabled & then on the connection string.
89393>>>>>>>>>    Function SortActiveFirst tSQLConnection SQLConnectionRow1 tSQLConnection SQLConnectionRow2 Returns Integer
89395>>>>>>>>>        Integer iCheckboxCol
89395>>>>>>>>>        If (SQLConnectionRow1.bEnabled > SQLConnectionRow2.bEnabled) Begin
89397>>>>>>>>>            Function_Return (LT)
89398>>>>>>>>>        End
89398>>>>>>>>>>
89398>>>>>>>>>        If (SQLConnectionRow1.bEnabled < SQLConnectionRow2.bEnabled) Begin
89400>>>>>>>>>            Function_Return (GT) 
89401>>>>>>>>>        End
89401>>>>>>>>>>
89401>>>>>>>>>
89401>>>>>>>>>        If (SQLConnectionRow1.sConnectionID < SQLConnectionRow2.sConnectionID) Begin
89403>>>>>>>>>            Function_Return (LT)
89404>>>>>>>>>        End
89404>>>>>>>>>>
89404>>>>>>>>>        If (SQLConnectionRow1.sConnectionID > SQLConnectionRow2.sConnectionID) Begin
89406>>>>>>>>>            Function_Return (GT) 
89407>>>>>>>>>        End
89407>>>>>>>>>>
89407>>>>>>>>>
89407>>>>>>>>>        If (SQLConnectionRow1.iDbType < SQLConnectionRow2.iDbType) Begin
89409>>>>>>>>>            Function_Return (LT)
89410>>>>>>>>>        End
89410>>>>>>>>>>
89410>>>>>>>>>        If (SQLConnectionRow1.iDbType > SQLConnectionRow2.iDbType) Begin
89412>>>>>>>>>            Function_Return (GT) 
89413>>>>>>>>>        End
89413>>>>>>>>>>
89413>>>>>>>>>
89413>>>>>>>>>        If (SQLConnectionRow1.sServer < SQLConnectionRow2.sServer) Begin
89415>>>>>>>>>            Function_Return (LT)
89416>>>>>>>>>        End
89416>>>>>>>>>>
89416>>>>>>>>>        If (SQLConnectionRow1.sServer > SQLConnectionRow2.sServer) Begin
89418>>>>>>>>>            Function_Return (GT) 
89419>>>>>>>>>        End
89419>>>>>>>>>>
89419>>>>>>>>>
89419>>>>>>>>>        If (SQLConnectionRow1.sDatabase < SQLConnectionRow2.sDatabase) Begin
89421>>>>>>>>>            Function_Return (LT)
89422>>>>>>>>>        End
89422>>>>>>>>>>
89422>>>>>>>>>        If (SQLConnectionRow1.sDatabase > SQLConnectionRow2.sDatabase) Begin
89424>>>>>>>>>            Function_Return (GT) 
89425>>>>>>>>>        End
89425>>>>>>>>>>
89425>>>>>>>>>
89425>>>>>>>>>        If (SQLConnectionRow1.sDriverID < SQLConnectionRow2.sDriverID) Begin
89427>>>>>>>>>            Function_Return (LT)
89428>>>>>>>>>        End
89428>>>>>>>>>>
89428>>>>>>>>>        If (SQLConnectionRow1.sDriverID > SQLConnectionRow2.sDriverID) Begin
89430>>>>>>>>>            Function_Return (GT) 
89431>>>>>>>>>        End
89431>>>>>>>>>>
89431>>>>>>>>>
89431>>>>>>>>>        If (SQLConnectionRow1.sConnectionString < SQLConnectionRow2.sConnectionString) Begin
89433>>>>>>>>>            Function_Return (LT)
89434>>>>>>>>>        End
89434>>>>>>>>>>
89434>>>>>>>>>        If (SQLConnectionRow1.sConnectionString > SQLConnectionRow2.sConnectionString) Begin
89436>>>>>>>>>            Function_Return (GT) 
89437>>>>>>>>>        End
89437>>>>>>>>>>
89437>>>>>>>>>
89437>>>>>>>>>        Function_Return (EQ)
89438>>>>>>>>>    End_Function
