96817>>>>>    // Internal usage. Use the UtilColumnTypeXXX functions instead.
96817>>>>>    Function _UtilColumnType String sDriverID Integer iDbType Integer iType String sType Boolean bIntegerInputType Returns tColumnType
96819>>>>>        Integer iValue iSize iCount iStart
96819>>>>>        tColumnType[] ColumnTypeArray   
96819>>>>>        tColumnType[] ColumnTypeArray   
96820>>>>>        tColumnType RetvalType 
96820>>>>>        tColumnType RetvalType 
96820>>>>>        String sValue
96820>>>>>        
96820>>>>>        Move "Undefined" to RetvalType.sType 
96821>>>>>        Move -1999       to RetvalType.iType
96822>>>>>        
96822>>>>>        Move 0 to iStart
96823>>>>>        Move (Uppercase(sType)) to sType            
96824>>>>>        
96824>>>>>        If (iType <= -1500) Begin
96826>>>>>            Move EN_dbTypeDataFlex to iDbType
96827>>>>>            Move DATAFLEX_ID       to sDriverID
96828>>>>>        End
96828>>>>>>
96828>>>>>
96828>>>>>        Get UtilEnumerateColumnTypes sDriverID iDbType to ColumnTypeArray
96829>>>>>        
96829>>>>>        Move (SizeOfArray(ColumnTypeArray)) to iSize 
96830>>>>>        Decrement iSize
96831>>>>>        
96831>>>>>        for iCount from iStart to iSize
96837>>>>>>
96837>>>>>            Move ColumnTypeArray[iCount].iType to iValue
96838>>>>>            Move ColumnTypeArray[iCount].sType to sValue 
96839>>>>>            If (bIntegerInputType = True) Begin
96841>>>>>                If (iValue = iType) Begin
96843>>>>>                    Move ColumnTypeArray[iCount].sType          to RetvalType.sType  
96844>>>>>                    Move iType                                  to RetvalType.iType
96845>>>>>                    Move ColumnTypeArray[iCount].sDataFlexType  to RetvalType.sDataFlexType
96846>>>>>                    Move ColumnTypeArray[iCount].iDataFlexType  to RetvalType.iDataFlexType
96847>>>>>                    Move ColumnTypeArray[iCount].sPrecision     to RetvalType.sPrecision
96848>>>>>                    Move ColumnTypeArray[iCount].bFixedSize     to RetvalType.bFixedSize
96849>>>>>                    Move iSize to iCount // We're done!
96850>>>>>                End
96850>>>>>>
96850>>>>>            End
96850>>>>>>
96850>>>>>            Else Begin
96851>>>>>                Move (Uppercase(sValue)) to sValue
96852>>>>>                If (sValue = sType) Begin
96854>>>>>                    Move sType                                  to RetvalType.sType
96855>>>>>                    Move ColumnTypeArray[iCount].iType          to RetvalType.iType 
96856>>>>>                    Move ColumnTypeArray[iCount].sDataFlexType  to RetvalType.sDataFlexType
96857>>>>>                    Move ColumnTypeArray[iCount].iDataFlexType  to RetvalType.iDataFlexType
96858>>>>>                    Move ColumnTypeArray[iCount].sPrecision     to RetvalType.sPrecision
96859>>>>>                    Move ColumnTypeArray[iCount].bFixedSize     to RetvalType.bFixedSize
96860>>>>>                    Move iSize to iCount // We're done!
96861>>>>>                End
96861>>>>>>
96861>>>>>            End
96861>>>>>>
96861>>>>>        Loop
96862>>>>>>
96862>>>>>        
96862>>>>>        Function_Return RetvalType
96863>>>>>    End_Function
96864>>>>>    
96864>>>>>    // *** Miscellaneous other functions ***
96864>>>>>    // Some of which can be used by both "Sqlxxx" and "Apixxx" functions.
96864>>>>>    //
96864>>>>>    
96864>>>>>    // Callback functionality used when e.g. calling driver functions directly.
96864>>>>>    Function Callback String sCallback_Text Integer iCallback_Type Returns Integer
96866>>>>>        Integer iRetval iPos iPerc
96866>>>>>        String sVal1 sVal2 
96866>>>>>        Number nReady nTotal 
96866>>>>>        
96866>>>>>        Send DoAdvance of ghoProgressBar           
96867>>>>>        
96867>>>>>        If (sCallback_Text contains "Copy records") Begin
96869>>>>>            Move CS_SQLCopyingData to sCallback_Text
96870>>>>>        End                                        
96870>>>>>>
96870>>>>>        If (sCallback_Text contains "Dropping index" or sCallback_Text contains "Temporary delete of all indices of table") Begin
96872>>>>>            Move (Replace("Dropping index", sCallback_Text, CS_SQLDeletingIndex)) to sCallback_Text 
96873>>>>>            Move (Replace("Temporary delete of all indices of table", sCallback_Text, CS_SQLDeletingIndex)) to sCallback_Text
96874>>>>>        End
96874>>>>>>
96874>>>>>        If (sCallback_Text contains "Creating index") Begin
96876>>>>>            Move (Replace("Creating index", sCallback_Text, CS_SQLCreatingIndex)) to sCallback_Text
96877>>>>>        End                                               
96877>>>>>>
96877>>>>>        
96877>>>>>        Case Begin
96877>>>>>            Case (iCallback_Type = DF_Message_Text) 
96879>>>>>                Set Message_Text of ghoStatusPanel to sCallback_Text  
96880>>>>>                Set Action_Text  of ghoStatusPanel to ""
96881>>>>>                Case Break
96882>>>>>            Case (iCallback_Type = DF_Message_Heading_1) 
96885>>>>>                Set Message_Text of ghoStatusPanel to sCallback_Text 
96886>>>>>                Set Action_Text  of ghoStatusPanel to ""
96887>>>>>                Case Break
96888>>>>>            Case (iCallback_Type = DF_Message_Heading_2) 
96891>>>>>                Set Message_Text of ghoStatusPanel to sCallback_Text 
96892>>>>>                Set Action_Text  of ghoStatusPanel to ""
96893>>>>>                Case Break
96894>>>>>            Case (iCallback_Type = DF_Message_Heading_3) 
96897>>>>>                Set Message_Text of ghoStatusPanel to sCallback_Text 
96898>>>>>                Set Action_Text  of ghoStatusPanel to ""
96899>>>>>                Case Break
96900>>>>>            Case (iCallback_Type = DF_Message_Heading_4) 
96903>>>>>                Set Message_Text of ghoStatusPanel to sCallback_Text 
96904>>>>>                Set Action_Text  of ghoStatusPanel to ""
96905>>>>>                Case Break
96906>>>>>            Case (iCallback_Type = DF_Message_Heading_5) 
96909>>>>>                Set Message_Text of ghoStatusPanel to sCallback_Text 
96910>>>>>                Set Action_Text  of ghoStatusPanel to ""
96911>>>>>                Case Break
96912>>>>>            Case (iCallback_Type = DF_Message_Warning) 
96915>>>>>                Send None
96916>>>>>                Case Break
96917>>>>>            Case (iCallback_Type = DF_Message_Progress_Title) 
96920>>>>>                Set Message_Text of ghoStatusPanel to sCallback_Text 
96921>>>>>                Set Action_Text  of ghoStatusPanel to ""
96922>>>>>                Case Break
96923>>>>>            Case (iCallback_Type = DF_Message_Progress_Value) 
96926>>>>>                //*** Interpret numbers
96926>>>>>                Move (Left(sCallback_Text, (Pos(",", sCallback_Text) - 1)))                       to nReady
96927>>>>>                Move (Right(sCallback_Text, (Length(sCallback_Text) - Pos(",", sCallback_Text)))) to nTotal
96928>>>>>                Move ((nReady / nTotal) * 100)                                                    to iPerc
96929>>>>>                Set Action_Text of ghoStatusPanel to (String(iPerc) * String("% (Total:") * String(nTotal) + ")")
96930>>>>>                Case Break
96931>>>>>            Case Else
96931>>>>>                Set Message_Text to ""
96932>>>>>                Set Action_Text  to ""    
96933>>>>>        Case End
96933>>>>>
96933>>>>>        Send ProcessEvents of ghoStatusPanel
96934>>>>>        Function_Return False
96935>>>>>    End_Function
96936>>>>>    
