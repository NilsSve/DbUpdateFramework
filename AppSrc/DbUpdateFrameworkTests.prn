92267>>>>>        Boolean bOK
92267>>>>>        
92267>>>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
92268>>>>>        If (bOK = False) Begin
92270>>>>>            Error DFERR_PROGRAM ("Unsupported driver. A list of table columns could not be retrieved for:" * sDriverID + ".")
92271>>>>>>
92271>>>>>            Function_Return sReturnArray
92272>>>>>        End   
92272>>>>>>
92272>>>>>       
92272>>>>>        Get psConnectionString to sConnectionString  
92273>>>>>        Get psSchema to sSchema
92274>>>>>        
92274>>>>>        Case Begin
92274>>>>>            Case (sDriverID = MSSQLDRV_ID)    
92276>>>>>                Move ("select name from sys.columns where [object_id] = object_id('dbo." + sTableName + "')") to sSelect
92277>>>>>                Get SqlEnumerateEsqlDAW sSelect 1 to sReturnArray
92278>>>>>                Case Break
92279>>>>>
92279>>>>>            Case (sDriverID = DB2_DRV_ID) 
92282>>>>>                Move ("SELECT colname from syscat.columns WHERE tabschema = '" + sSchema + "'" * "AND tabname = '" + sTableName + "'") to sSelect  
92283>>>>>                Get SqlEnumerateEsqlDAW sSelect 1 to sReturnArray
92284>>>>>                Case Break
92285>>>>>
92285>>>>>            Case (sDriverID = SQLFLEX)
92288>>>>>                Move ("select name from sys.columns where [object_id] = object_id('dbo." + sTableName + "')") to sSelect
92289>>>>>                Get SqlEnumerateEsqlMertech sSelect 1 to sReturnArray
92290>>>>>                Case Break
92291>>>>>            
92291>>>>>            Case (sDriverID = MDSMySQL) 
92294>>>>>                Move ("SHOW COLUMNS FROM" * sTableName) to sSelect
92295>>>>>                Get SqlEnumerateEsqlMertech sSelect 1 to sReturnArray
92296>>>>>                Case Break
92297>>>>>            
92297>>>>>            Case (sDriverID = MDSPgSQL) 
92300>>>>>                Move ("select column_name, data_type, character_maximum_length from INFORMATION_SCHEMA.COLUMNS where table_name = '" +sTableName + "'") to sSelect
92301>>>>>                Get SqlEnumerateEsqlMertech sSelect 1 to sReturnArray
92302>>>>>                Case Break            
92303>>>>>            
92303>>>>>            Case (sDriverID = ORAFLEX) 
92306>>>>>                Move ("SELECT column_name from user_tab_cols WHERE table_name = '" + sTableName + "'") to sSelect
92307>>>>>                Get SqlEnumerateEsqlMertech sSelect 1 to sReturnArray
92308>>>>>                Case Break
92309>>>>>                            
92309>>>>>            Case Else     
92309>>>>>                Error DFERR_PROGRAM "Unsupported driver passed to SqlUtilEnumerateColumns function."
92310>>>>>>
92310>>>>>                Case Break
92311>>>>>        Case End
92311>>>>>        
92311>>>>>        Function_Return sReturnArray
92312>>>>>    End_Function  
