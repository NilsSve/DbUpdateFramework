95636>>>>>                // If not df_exclusive mode, we use the "Open As" syntax.
95636>>>>>                If (iMode <> DF_EXCLUSIVE) Begin
95638>>>>>                    Open sTableName as hTable
95640>>>>>                End
95640>>>>>>
95640>>>>>                Else Begin
95641>>>>>                    Open hTable mode DF_Exclusive
95643>>>>>                End
95643>>>>>>
95643>>>>>                Case Break
95644>>>>>
95644>>>>>            Case (sDriverID = MDSPgSQL)
95647>>>>>                // PgFlex: Open "mdspgsql:\\<serverName>\<database>*<schema>*<tableName>=<numberFieds>" as table 
95647>>>>>                Move (MDSPgSQL + ":\\" + SQLConnection.sServer + "\" + SQLConnection.sDatabase + "*" + SQLConnection.sSchema + "*" + sTableNameOrg) to sTableName
95648>>>>>                // If not df_exclusive mode, we use the "Open As" syntax.
95648>>>>>                If (iMode <> DF_EXCLUSIVE) Begin
95650>>>>>                    Open sTableName as hTable
95652>>>>>                End
95652>>>>>>
95652>>>>>                Else Begin
95653>>>>>                    Open hTable mode DF_Exclusive
95655>>>>>                End
95655>>>>>>
95655>>>>>                Case Break
