89859>>>>>>>>>    // Returns the full path of the Application (no trailing "\")
89859>>>>>>>>>    Function ApplicationPath Returns String
89861>>>>>>>>>        String sApplicationFileName sPath
89861>>>>>>>>>        Integer iNumChars iRetval
89861>>>>>>>>>
89861>>>>>>>>>        Move (Repeat(Character(0), 1024))    to sApplicationFileName
89862>>>>>>>>>        Move (GetModuleFileName(0, AddressOf(sApplicationFileName), 1024)) to iNumChars
89863>>>>>>>>>        Move (CString(sApplicationFileName)) to sApplicationFileName
89864>>>>>>>>>        Move (PathRemoveFileSpec(AddressOf(sApplicationFileName))) to iRetval
89865>>>>>>>>>        Move (CString(sApplicationFileName)) to sPath
89866>>>>>>>>>
89866>>>>>>>>>        Function_Return sPath
89867>>>>>>>>>    End_Function
