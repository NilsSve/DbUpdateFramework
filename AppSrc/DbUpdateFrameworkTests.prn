88918>>>>>>>    // Custom array find function. It compares both the iSQLWord & iSQLDbType params.
88918>>>>>>>    Function CompareFindSQLKeyWords tSQLKeyWords SQLKeywords1 tSQLKeyWords SQLKeywords2 Returns Integer
88920>>>>>>>        If (SQLKeywords1.iSQLWord = SQLKeywords2.iSQLWord and SQLKeywords1.iSQLDbType = SQLKeywords2.iSQLDbType) Begin
88922>>>>>>>            Function_Return (EQ)
88923>>>>>>>        End
88923>>>>>>>>
88923>>>>>>>        Function_Return (NE)
88924>>>>>>>    End_Function
88925>>>>>>>    
88925>>>>>>>    // Custom array sort function. It compares both the iSQLWord & iSQLDbType params.
88925>>>>>>>    Function CompareSortSQLKeyWords tSQLKeyWords SQLKeywords1 tSQLKeyWords SQLKeywords2 Returns Integer
88927>>>>>>>        If (SQLKeywords1.iSQLWord   < SQLKeywords2.iSQLWord) Begin
88929>>>>>>>            Function_Return (LT)
88930>>>>>>>        End
88930>>>>>>>>
88930>>>>>>>        If (SQLKeywords1.iSQLWord   > SQLKeywords2.iSQLWord) Begin
88932>>>>>>>            Function_Return (GT)
88933>>>>>>>        End
88933>>>>>>>>
88933>>>>>>>        If (SQLKeywords1.iSQLDbType < SQLKeywords2.iSQLDbType) Begin
88935>>>>>>>            Function_Return (LT)
88936>>>>>>>        End
88936>>>>>>>>
88936>>>>>>>        If (SQLKeywords1.iSQLDbType > SQLKeywords2.iSQLDbType) Begin
88938>>>>>>>            Function_Return (GT)
88939>>>>>>>        End
88939>>>>>>>>
88939>>>>>>>
88939>>>>>>>        Function_Return (EQ)    
88940>>>>>>>    End_Function
