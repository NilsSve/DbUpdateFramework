98548>>>>>>>    Function ParentView Returns Handle
98550>>>>>>>        Function_Return (Parent(Parent(Self)))
98551>>>>>>>    End_Function
98552>>>>>>>    
98552>>>>>>>    Procedure AdjustTabWorkspaceView Integer ByRef iHeight Integer ByRef iWidth Integer ByRef iLocY Integer ByRef iLocX
98554>>>>>>>        Integer iSize iMax iDiff
98554>>>>>>>        Handle hoView
98554>>>>>>>        Boolean bCenter bModal
98554>>>>>>>        Get ParentView to hoView
98555>>>>>>>        Get Block_Mouse_State of hoView to bModal
98556>>>>>>>        If not bModal Begin
98558>>>>>>>            Get CenterTabWorkspaceView to bCenter
98559>>>>>>>            Get GuiSize of hoView to iSize
98560>>>>>>>            Get piMaxSize of hoView to iMax
98561>>>>>>>            Get DialogToGui (Hi(iMax)) (Low(iMax)) to iMax
98562>>>>>>>            If (Low(iMax) and Low(iMax)<=Low(isize)) Begin
98564>>>>>>>                If bCenter Begin
98566>>>>>>>                    Move ((Low(iSize)-Low(iMax))/2) to iLocX
98567>>>>>>>                End
98567>>>>>>>>
98567>>>>>>>                Move (Low(iMax)) to iWidth
98568>>>>>>>            End
98568>>>>>>>>
98568>>>>>>>            If (Hi(iMax) and Hi(iMax)<=Hi(iSize)) Begin
98570>>>>>>>                If bCenter Begin
98572>>>>>>>                    Move ((Hi(iSize)-Hi(iMax))/2) to iLocY
98573>>>>>>>                    Move (iLocy min 25) to  iLocY
98574>>>>>>>                End
98574>>>>>>>>
98574>>>>>>>                Move (Hi(imax)) to iHeight
98575>>>>>>>            End
98575>>>>>>>>
98575>>>>>>>        End
98575>>>>>>>>
98575>>>>>>>    End_Procedure
98576>>>>>>>
98576>>>>>>>    // Automatically determine if this is a scrolling tabbed workspace view
98576>>>>>>>    // If determines this by checking pbAutoSetTabWorkspaceView is set (it can be
98576>>>>>>>    // set to stop this), if we have a global commandbar object and we are using tabbed
98576>>>>>>>    // workspaces. We also make sure that the expected view object is a framework view class
98576>>>>>>>    // This should almost always yield the right answer.
98576>>>>>>>    // This is called by the scrolling container's end_constructor
98576>>>>>>>    Procedure AutoSetTabWorkspaceView
98578>>>>>>>        Boolean bTabView bIsView bAutoSetTabWorkspaceView
98578>>>>>>>        Handle hoParent
98578>>>>>>>        Integer iSize
98578>>>>>>>        Get pbAutoSetTabWorkspaceView to bAutoSetTabWorkspaceView  
98579>>>>>>>        If (ghoCommandBars and bAutoSetTabWorkspaceView) Begin
98581>>>>>>>            Get pbTabbedWorkspaces of ghoCommandBars to bTabView
98582>>>>>>>            // not that pbTabbedWorkspaces is a designtime only property. You can not
98582>>>>>>>            // change this after the commandbar is paged.
98582>>>>>>>            If (bTabView) Begin
98584>>>>>>>                Get ParentView to hoParent
98585>>>>>>>                Get IsObjectOfClass of hoParent (RefClass(MdiDialog)) to bIsView
98586>>>>>>>                If (bIsView) Begin
98588>>>>>>>                    // set this as a tab workspace view
98588>>>>>>>                    Set pbTabWorkspaceView to True
98589>>>>>>>                    // when tab workspaces are enabled we always enable auto-scrolling
98589>>>>>>>                    // when tab workspaces are not enabled, pbScroll is whatever it is
98589>>>>>>>                    Set pbAutoScroll to True
98590>>>>>>>                    
98590>>>>>>>//                    // if piMaxSize is not set, we will do it for you by setting it
98590>>>>>>>//                    // to the current size.
98590>>>>>>>//                    Get piMaxSize of hoParent to iSize
98590>>>>>>>//                    If (iSize=0) Begin
98590>>>>>>>//                        Get Size of hoParent to iSize
98590>>>>>>>//                        Set piMaxSize of hoParent to (Hi(iSize)) (Low(iSize))
98590>>>>>>>//                    End
98590>>>>>>>                End
98590>>>>>>>>
98590>>>>>>>            End
98590>>>>>>>>
98590>>>>>>>        End
98590>>>>>>>>
98590>>>>>>>    End_Procedure
98591>>>>>>>
98591>>>>>>>End_Class
98592>>>>>>>
98592>>>>>>>// Container scrolling class support. Nothing in here is public
98592>>>>>>>Class cScrollingContainerMixin is a Mixin
98593>>>>>>>
98593>>>>>>>    Procedure Define_cScrollingContainerMixin
98595>>>>>>>        Forward Set Border_Style to Border_None
98597>>>>>>>        Set pbSizeToClientArea to False // scrollbars and clientsize do not mix
98598>>>>>>>        Forward Set peAnchors to anAll
98600>>>>>>>
98600>>>>>>>        // forcing scrollbars right away seems to make painting better
98600>>>>>>>        Set Window_Style WS_HSCROLL to True
98601>>>>>>>        Set Window_Style WS_VSCROLL to True
98602>>>>>>>
98602>>>>>>>        Property Handle phoScrollingClientArea 0
98603>>>>>>>    End_Procedure
98604>>>>>>>    
98604>>>>>>>    // if anchors are changed, it will not work. We won't let that happen
98604>>>>>>>    Procedure Set peAnchors Integer eAnchors
98606>>>>>>>    End_Procedure
98607>>>>>>>
98607>>>>>>>    // if a border style is set, it will not work. We won't let that happen
98607>>>>>>>    Procedure Set Border_Style Integer eStyle
98609>>>>>>>    End_Procedure
98610>>>>>>>
98610>>>>>>>    // redirect scrollbar events and wheel events to the scrolling client area
98610>>>>>>>    Procedure OnWmMouseWheel Integer wParam Integer lParam
98612>>>>>>>        Handle hoClient
98612>>>>>>>        Get phoScrollingClientArea to hoClient
98613>>>>>>>        If hoClient Begin
98615>>>>>>>           Send OnMouseWheel of hoClient wParam lParam
98616>>>>>>>        End
98616>>>>>>>>
98616>>>>>>>    End_Procedure
98617>>>>>>>
98617>>>>>>>    // should be sent by WM_VSCROLL
98617>>>>>>>    Procedure SetVScrollbox Integer iType Integer iNewPos
98619>>>>>>>        Handle hoClient
98619>>>>>>>        Get phoScrollingClientArea to hoClient
98620>>>>>>>        If hoClient Begin
98622>>>>>>>           Send SetVScrollbox of hoClient iType iNewPos
98623>>>>>>>        End
98623>>>>>>>>
98623>>>>>>>    End_Procedure
98624>>>>>>>
98624>>>>>>>    // should be sent by WM_HSCROLL
98624>>>>>>>    Procedure SetHScrollbox Integer iType Integer iNewPos
98626>>>>>>>        Handle hoClient
98626>>>>>>>        Get phoScrollingClientArea to hoClient
98627>>>>>>>        If hoClient Begin
98629>>>>>>>           Send SetHScrollbox of hoClient iType iNewPos
98630>>>>>>>        End
98630>>>>>>>>
98630>>>>>>>    End_Procedure
98631>>>>>>>
98631>>>>>>>    // augmented to adjust its size to the size of the parent client area.
98631>>>>>>>    // After this is set, anchors will handle any further resizing.
98631>>>>>>>    Procedure Page Integer iState
98633>>>>>>>        Integer iSiz iHeight iWidth
98633>>>>>>>        Integer iTop iBottom iLeft iRight iFontSize
98633>>>>>>>        Boolean bGroup
98633>>>>>>>        Handle hoClient
98633>>>>>>>        If (iState =1) Begin
98635>>>>>>>            Delegate Get Window_Style BS_GROUPBOX to bGroup
98637>>>>>>>            // We have special code to support groups because they
98637>>>>>>>            // draw a border inside of the client rectangle
98637>>>>>>>            If bGroup Begin
98639>>>>>>>                Get Physical_FontSize to iFontSize
98640>>>>>>>                Move (Hi(iFontSize)) to iTop
98641>>>>>>>                Move 2 to iLeft
98642>>>>>>>                Move 2 to iRight
98643>>>>>>>                Move 2 to iBottom
98644>>>>>>>            End
98644>>>>>>>>
98644>>>>>>>            // We use GetContainerClientSize instead of GuiClientSize because
98644>>>>>>>            // GetContainerClientSize has a special augmentation in tab pages that
98644>>>>>>>            // makes anchors work properly with unpaged tab-pages
98644>>>>>>>            Delegate Get GetContainerClientSize to iSiz
98646>>>>>>>            Set GuiSize to (Hi(iSiz)-(iTop+iBottom)) (Low(iSiz)-(iLeft+iRight))
98647>>>>>>>            Set GuiLocation to iTop iLeft
98648>>>>>>>            Send Adjust_Logicals
98649>>>>>>>        End
98649>>>>>>>>
98649>>>>>>>        Forward Send Page iState
98651>>>>>>>    End_Procedure
98652>>>>>>>    
98652>>>>>>>    Procedure End_Construct_Object 
98654>>>>>>>        Handle hoClient
98654>>>>>>>        Forward Send End_Construct_Object
98656>>>>>>>        Get phoScrollingClientArea to hoClient
98657>>>>>>>        If (hoClient) Begin
98659>>>>>>>            Send AutoSetTabWorkspaceView of hoClient
98660>>>>>>>        End
98660>>>>>>>>
98660>>>>>>>    End_Procedure
98661>>>>>>>
98661>>>>>>>End_Class
