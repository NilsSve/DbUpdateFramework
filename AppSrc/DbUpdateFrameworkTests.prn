83027>>>>>>>/// @Name        DF_FILE_TABLESPACE_NAME
83027>>>>>>>/// @Description A tablespace is a container of segments (objects that have an
83027>>>>>>>/// allotted amount of space), i.e. tables and indexes. This attribute is
83027>>>>>>>/// used to get or set the name of the tablespace being used for the data tables.
83027>>>>>>>/// To set or get the tablespace name for indexes, use the DF_FILE_INDEXTABLESPACE_NAME
83027>>>>>>>/// attribute. Setting the tablespace name can only be done during a Structure_Start
83027>>>>>>>/// (during table creation).  Getting the name, however can be done at
83027>>>>>>>/// anytime.  Note that when setting the tablespace name, it must be set to an
83027>>>>>>>/// already existing tablespace, this attribute does not create the tablespace itself.
83027>>>>>>>/// Even though MYSQL uses tablespaces, this this attribute is only supported
83027>>>>>>>/// in Oracle and PostgreSQL.
83027>>>>>>>///
83027>>>>>>>/// @Assumptions
83027>>>>>>>/// @Status      Public
83027>>>>>>>/// @Drivers     ORAFlex PGFlex
83027>>>>>>>/// @VersionNote Last Revised: 2013-07-25 by Aaron Gulack
83027>>>>>>>/// @See         DF_FILE_INDEXTABLESPACE_NAME
83027>>>>>>>/// @INTOPT
83027>>>>>>>///
83027>>>>>>>/// @Syntax Get_Attribute DF_FILE_TABLESPACE_NAME of {FileNumber} to {variable}
83027>>>>>>>/// @Syntax Set_Attribute DF_FILE_TABLESPACE_NAME of {FileNumber} to {variable}
83027>>>>>>>/// @Param  FileNumber            Number of the file
83027>>>>>>>/// @Param  variable              Name of the Tablespace.
83027>>>>>>>/// @Example
83027>>>>>>>/// Handle hFile
83027>>>>>>>/// move 0 to hFile
83027>>>>>>>/// Structure_Start hFile "ORA_DRV"
83027>>>>>>>///     Set_Attribute DF_FILE_TABLESPACE_NAME      of hFile To "USERS"
83027>>>>>>>///     Set_Attribute DF_FILE_INDEXTABLESPACE_NAME of hFile To "INDXS"
83027>>>>>>>///
83027>>>>>>>///             // More table creation here
83027>>>>>>>///
83027>>>>>>>/// Structure_End hFile DF_STRUCTEND_OPT_NONE "." 0
83027>>>>>>>Define DF_FILE_TABLESPACE_NAME                      For (DF_FILE_RECORD_REREAD+14)
83027>>>>>>>
83027>>>>>>>// TODO: This is probably deprecated. Investigate.
83027>>>>>>>Define DF_FETCH_FIELDNUMBER                         For (DF_FILE_RECORD_REREAD+15)
83027>>>>>>>
83027>>>>>>>//=============================================================================
83027>>>>>>>/// @Name        DF_FILE_INDEXTABLESPACE_NAME
83027>>>>>>>/// @Description This attribute is used to get or set the name of the tablespace
83027>>>>>>>/// being used for the index segment of a database. For a description of tablespaces,
83027>>>>>>>/// see the description above for DF_FILE_TABLESPACE_NAME. Similar to the Tablespace
83027>>>>>>>/// name attribute, setting the index tablespace name can only be done during creation
83027>>>>>>>/// and must use an already existing tablespace as the variable. This attribute is
83027>>>>>>>/// only available for Oracle and Postgre.
83027>>>>>>>///
