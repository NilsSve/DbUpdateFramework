95603>>>>>                    Open sTableName as hTable
95605>>>>>                End
95605>>>>>>
95605>>>>>                Else Begin
95606>>>>>                    Open hTable mode DF_Exclusive
95608>>>>>                End
95608>>>>>>
95608>>>>>                Case Break
95609>>>>>
95609>>>>>            Case (sDriverID = ODBC_DRV_ID)
95612>>>>>                // If not df_exclusive mode, we use the "Open As" syntax.
95612>>>>>                If (iMode <> DF_EXCLUSIVE) Begin
95614>>>>>                    Open sTableName as hTable
95616>>>>>                End
95616>>>>>>
