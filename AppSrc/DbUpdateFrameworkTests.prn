86467>>>>>>>>>>>
86467>>>>>>>>>>>  // Courtesy Of Steve Walter
86467>>>>>>>>>>>  // Requires Windows 2000 and up according to msdn but it was
86467>>>>>>>>>>>  //  in fact available before that as an unpublished API call
86467>>>>>>>>>>>  //  a little google search shows that this was already available
86467>>>>>>>>>>>  //  in windows 95 and NT
86467>>>>>>>>>>>  //
86467>>>>>>>>>>>  // The format is controlled by the dialog interface.
86467>>>>>>>>>>>  // That is, the user must click the OK button To actually Begin the format
86467>>>>>>>>>>>  // the format cannot be started programmatically.
86467>>>>>>>>>>>  // An alternative to this functionality would be to use a controlpanel
86467>>>>>>>>>>>  //  http://www.vdf-guidance.com/ContribPage.asp?Page=PKGCLSDFCPLAPP&ContribRecId=93
86467>>>>>>>>>>>  //
86467>>>>>>>>>>>  // hWnd = The windows handle of the object from which the format Function
86467>>>>>>>>>>>  //        is called.
86467>>>>>>>>>>>  // To Get this,
86467>>>>>>>>>>>  //          use:  Get Window_Handle Of <object>
86467>>>>>>>>>>>  //          For instance, in this app, we're going to use the Report_Panel:
86467>>>>>>>>>>>  //                  Get Window_Handle Of (Report_Panel(Main(Self))) To hWind
86467>>>>>>>>>>>  //
86467>>>>>>>>>>>  // sDrive = The drive letter. At this moment only A and B are valid
86467>>>>>>>>>>>  //
86467>>>>>>>>>>>  // iOptions = Format options.
86467>>>>>>>>>>>  //  SHFMT_OPT_DEFAULT = Quick format
86467>>>>>>>>>>>  //  SHFMT_OPT_FULL    = Full Format
86467>>>>>>>>>>>  //  SHFMT_OPT_SYSONLY = System only
86467>>>>>>>>>>>  //  3                 = Full format with system. (unsupported)
86467>>>>>>>>>>>  //
86467>>>>>>>>>>>  // Return Values:
86467>>>>>>>>>>>  //  SHFMT_ERROR    = Error on format or no drive specified.
86467>>>>>>>>>>>  //  SHFMT_CANCEL   = Format cancelled by user.
86467>>>>>>>>>>>  //  SHFMT_NOFORMAT = Drive is not formatable.
86467>>>>>>>>>>>  //
86467>>>>>>>>>>>  //
86467>>>>>>>>>>>  // *** ATTENTION: This function has been disabled as it doesn't
86467>>>>>>>>>>>  //                seem to work, i must have made a silly mistake
86467>>>>>>>>>>>  //                somewhere.
86467>>>>>>>>>>>  //
86467>>>>>>>>>>>  Function sfoFormatDisk String sDrive Integer iOptions Returns DWORD
86469>>>>>>>>>>>    Handle   hWnd
86469>>>>>>>>>>>    Integer  iObj
86469>>>>>>>>>>>    DWORD    dwReturnVal
86469>>>>>>>>>>>    Integer iDrive
86469>>>>>>>>>>>
86469>>>>>>>>>>>    Function_Return (1) // STOP HERE
86470>>>>>>>>>>>    
86470>>>>>>>>>>>    Move (Trim(sDrive)) To sDrive
86471>>>>>>>>>>>    If ( sDrive <> '' ) Begin
86473>>>>>>>>>>>      If ( sDrive Contains ':' ) Move (Replace(':',sDrive,'')) To sDrive
86476>>>>>>>>>>>      If (Not( 'AB' Contains sDrive )) Function_Return (SHFMT_NOFORMAT)
86479>>>>>>>>>>>      If ( sDrive = 'A' ) Move 0 To iDrive
86482>>>>>>>>>>>      Else If ( sDrive = 'B' ) Move 1 To iDrive
86486>>>>>>>>>>>      // Window_Handle Of Desktop equals to 0
86486>>>>>>>>>>>      
86486>>>>>>>>>>>      Get focus Of desktop To iObj
86487>>>>>>>>>>>      If (iObj>desktop) ;          Get Container_Handle Of iObj To hWnd
86490>>>>>>>>>>>      While (hWnd=0 And iObj<>Desktop)
86494>>>>>>>>>>>          Get Parent Of iObj To iObj
86495>>>>>>>>>>>          Get Container_Handle Of iObj To hWnd
86496>>>>>>>>>>>      End
86497>>>>>>>>>>>>
86497>>>>>>>>>>>                      
86497>>>>>>>>>>>      //Showln "hWnd = " hWnd " iDrive " iDrive " iOptions " iOptions
86497>>>>>>>>>>>      Move (vWin32_ShFormatDrive(hWnd, iDrive, SHFMT_ID_DEFAULT, iOptions)) To dwReturnVal
86498>>>>>>>>>>>    End
86498>>>>>>>>>>>>
86498>>>>>>>>>>>    Else Begin
86499>>>>>>>>>>>      Move (SHFMT_ERROR) To dwReturnVal
86500>>>>>>>>>>>    End
86500>>>>>>>>>>>>
86500>>>>>>>>>>>    Function_Return dwReturnVal
86501>>>>>>>>>>>  End_Function // sfoFormatDisk
86502>>>>>>>>>>> 
86502>>>>>>>>>>>  //Example:
86502>>>>>>>>>>>  // Get sfoFormatDisk 'A' 0 To dReturnVal    // Formats drive A in QuickFormat
86502>>>>>>>>>>>  //                                          mode.
86502>>>>>>>>>>>  
86502>>>>>>>>>>>End_Class // cShellFileOperations
86503>>>>>>>>>>>
