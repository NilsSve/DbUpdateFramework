80904>>>
80904>>>    Procedure Insert String sVal
80906>>>        Handle hWnd
80906>>>        String sEditValue
80906>>>        
80906>>>        Get Window_Handle to hWnd
80907>>>        If (hWnd <> 0) Begin
80909>>>            Send AppendText sVal
80910>>>        End
80910>>>>
80910>>>        Else Begin
80911>>>            Get psEditValue to sEditValue
80912>>>            Move (sEditValue + sVal) to sEditValue
80913>>>            Set psEditValue to sEditValue
80914>>>        End
80914>>>>
80914>>>    End_Procedure
80915>>>End_Class
