81328>>>                            Send Insert (" Other File.Field="  + String(Constraints[i].iOtherFile))
81329>>>                            Send Insert ("."  + String(Constraints[i].iOtherField))
81330>>>                            Send Insert (" (" + FormatFileFieldName(Self,Constraints[i].iOtherFile,Constraints[i].iOtherField)+")")
81331>>>                        End
81331>>>>
