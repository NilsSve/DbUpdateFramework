82554>>>>>>>Define SQL_VARBINARYMAX         for   (-203) //SQL server varbinary(max) type */
82554>>>>>>>Define SQL_TYPE_MONEY           for   (-204) //SQL server money type */
82554>>>>>>>Define SQL_TYPE_SMALLMONEY      for   (-205) //SQL server smallmoney type */
82554>>>>>>>Define SQL_TYPE_SMALLDATETIME   for   (-206) //SQL server smalldatetype type */
