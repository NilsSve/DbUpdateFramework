84583>>>>>    
84583>>>>>    Function IsDAWSQLDriver String sDriverID Returns Boolean
84585>>>>>        Boolean bOK
84585>>>>>        Move (sDriverID = MSSQLDRV_ID or sDriverID = DB2_DRV_ID or sDriverID = ODBC_DRV_ID) to bOK
84586>>>>>        Function_Return bOK
84587>>>>>    End_Function
84588>>>>>
84588>>>>>    Function IsMertechDriver String sDriverID Returns Boolean
84590>>>>>        Boolean bOK   
84590>>>>>        Move (sDriverID = SQLFLEX or sDriverID = ORAFLEX or sDriverID = MDSPgSQL or sDriverID = MySQLFlex) to bOK
84591>>>>>        Function_Return bOK
84592>>>>>    End_Function
84593>>>>>
84593>>>>>    //***
84593>>>>>    //*** BW
84593>>>>>    //*** Procedure: Show_Drivers
84593>>>>>    //*** Purpose  : Show loaded database drivers
84593>>>>>    //***
84593>>>>>
84593>>>>>    Procedure Show_Drivers
84595>>>>>        String sDriverID sVersion sClient sMertechSQLFlexVersion sValue
84595>>>>>        Integer iNumberOfDrivers iDriver iClient iUsersMax iSerialNo iNumServers iCount
84595>>>>>        Handle hoCLIHandler hoBtrvHandler
84595>>>>>        Boolean bStudioLicense bIsDAWDriver bIsMertechDriver
84595>>>>>
84595>>>>>        Move False to bStudioLicense
84596>>>>>
84596>>>>>        Get Create U_cCLIHandler      to hoCLIHandler
84597>>>>>        Get Create U_cDFBtrDrvHandler to hoBtrvHandler 
84598>>>>>
84598>>>>>        // For testing purposes:        
84598>>>>>//        Send Ignore_Error of Error_Object_Id DFERR_CANT_LOAD_DLL
84598>>>>>//        Load_Driver MSSQLDRV_ID
84598>>>>>//        Load_Driver ODBC_DRV_ID
84598>>>>>//        Load_Driver DB2_DRV_ID
84598>>>>>//        Send Trap_Error of Error_Object_Id DFERR_CANT_LOAD_DLL
84598>>>>>//
84598>>>>>//        #IFDEF DUF_Use_Mertech_Drivers  
84598>>>>>//            Send Ignore_Error of Error_Object_Id DFERR_CANT_LOAD_DLL
84598>>>>>//            Load_Driver SQLFLEX 
84598>>>>>//            Load_Driver MDSPgSQL
84598>>>>>//            Load_Driver MDSMySQL
84598>>>>>//            Load_Driver ORAFLEX
84598>>>>>//            Send Trap_Error of Error_Object_Id DFERR_CANT_LOAD_DLL
84598>>>>>//        #ENDIF
84598>>>>>        Move False to Err
84599>>>>>        
84599>>>>>        // Loop through all loaded drivers.
84599>>>>>        Get_Attribute DF_NUMBER_DRIVERS to iNumberOfDrivers
84602>>>>>        If (iNumberOfDrivers > 1) Begin
84604>>>>>            Send AppendTextLn ""
84605>>>>>        End
84605>>>>>>
84605>>>>>        For iDriver from 1 to iNumberOfDrivers           
84611>>>>>>
84611>>>>>            // For some weird reason it can happen that - when using Mertech drivers - that the driver index
84611>>>>>            // was increased in the CLI array, but it has no value. In that case a "Bad parameter..." error
84611>>>>>            // would be thrown, so we safeguard from that here.
84611>>>>>            Send Ignore_Error of Error_Object_Id DFERR_BAD_PARAMETER
84612>>>>>            Get_Attribute DF_DRIVER_NAME of iDriver to sDriverID
84615>>>>>            Send Trap_Error of Error_Object_Id DFERR_BAD_PARAMETER
84616>>>>>            Get IsDAWSQLDriver sDriverID to bIsDAWDriver
84617>>>>>            Get IsMertechDriver sDriverID to bIsMertechDriver
84618>>>>>
84618>>>>>            If (sDriverID = DFBTRDRV_ID or bIsDAWDriver = True or bIsMertechDriver = True) Begin
84620>>>>>
84620>>>>>                // Pervasive/Btrieve database
84620>>>>>                If (sDriverID = DFBTRDRV_ID) Begin
84622>>>>>                    Get CKRevision of hoBtrvHandler to sVersion
84623>>>>>                    Get PSQLLocalEngineVersionInfo of hoBtrvHandler 0 to sClient
84624>>>>>                    If (sClient <> "0.0.0") Begin
84626>>>>>                        Send AppendTextLn (SFormat (C_$Pervasive_Local_Engine_Version, sClient))
84627>>>>>                    End
84627>>>>>>
84627>>>>>                    Get PSQLServerEngineVersionInfo of hoBtrvHandler 0 to sClient
84628>>>>>                    If (sClient <> "0.0.0") Begin
84630>>>>>                        Send AppendTextLn (SFormat (C_$Pervasive_Server_Engine_Version, sClient))
84631>>>>>                    End
84631>>>>>>
84631>>>>>                End
84631>>>>>>
84631>>>>>
84631>>>>>                Else Begin
84632>>>>>                    Set psDriverID of hoCLIHandler to sDriverID 
84633>>>>>                    Move 0 to iNumServers
84634>>>>>                    If (sDriverID <> DATAFLEX_ID) Begin
84636>>>>>                        Get_Attribute DF_DRIVER_NUMBER_SERVERS of iDriver to iNumServers
84639>>>>>                    End
84639>>>>>>
84639>>>>>                    
84639>>>>>                    If (bIsDAWDriver = True) Begin
84641>>>>>                        If (sDriverID = MSSQLDRV_ID) Begin
84643>>>>>                            // This info is only available for the MS SQL driver:
84643>>>>>                            Get_Attribute DF_DRIVER_SQLSERVER_CLIENT_VERSION of iDriver to iClient
84646>>>>>                            If (iClient = 13) Move C_$SQLSERVER2016DRVRSTR              to sClient
84649>>>>>                            If (iClient = 12) Move C_$SQLSERVER2014DRVRSTR              to sClient
84652>>>>>                            If (iClient = 11) Move C_$SQL_Server_Native_Client_11_0     to sClient
84655>>>>>                            If (iClient = 10) Move C_$SQL_Server_Native_Client_10_0     to sClient
84658>>>>>                            If (iClient = 9)  Move C_$SQL_Native_Client                 to sClient
84661>>>>>                            If (iClient = 8)  Move C_$SQL_Server_SQL_Server_2000_client to sClient
84664>>>>>                            If (sClient <> "") Begin
84666>>>>>                                Move ("    " + sClient) to sClient
84667>>>>>                            End
84667>>>>>>
84667>>>>>                        End
84667>>>>>>
84667>>>>>                    
84667>>>>>                        Get CKRevision of hoCLIHandler to sVersion 
84668>>>>>                    End
84668>>>>>>
84668>>>>>                    
84668>>>>>                    If (bIsMertechDriver = True) Begin
84670>>>>>                        GET_DRIVER_REVISION to sVersion
84683>>>>>>
84683>>>>>                    End
84683>>>>>>
84683>>>>>                    
84683>>>>>                    // If the serialnumber is = 0, it means that the
84683>>>>>                    // Studio licens is in use and there is no
84683>>>>>                    // number of max users defined because the driver is
84683>>>>>                    // relying on the info from the VDF license.
84683>>>>>                    If (bStudioLicense = False) Begin
84685>>>>>                        Get SerialNumber of hoCLIHandler to iSerialNo
84686>>>>>                        Move (iSerialNo = 0) to bStudioLicense
84687>>>>>                    End
84687>>>>>>
84687>>>>>                End
84687>>>>>>
84687>>>>>                Send AppendTextLn (SFormat (C_$DatabaseDriver, (sDriverID * "-" * (C_$Version + ": " + sVersion))))
84688>>>>>                If (iNumServers <> 0) Begin
84690>>>>>                    For iCount from 1 to iNumServers
84696>>>>>>
84696>>>>>                        Get_Attribute DF_DRIVER_SERVER_NAME of iDriver iCount to sValue 
84699>>>>>                        Send AppendTextLn ("    " + "Server/DSN:" * sValue)
84700>>>>>                    Loop
84701>>>>>>
84701>>>>>                End
84701>>>>>>
84701>>>>>                If (sClient <> "" and sDriverID = MSSQLDRV_ID) Begin
84703>>>>>                    Send AppendTextLn sClient
84704>>>>>                End  
84704>>>>>>
84704>>>>>            End
84704>>>>>>
84704>>>>>        Loop
84705>>>>>>
84705>>>>>
84705>>>>>        Send AppendTextLn ""
84706>>>>>        If (bStudioLicense = False) Begin
84708>>>>>            Get MaxUsers of hoCLIHandler to iUsersMax 
84709>>>>>            Send AppendTextLn (SFormat (C_$Max_DbDriver_Licensed_User_Count, iUsersMax))
84710>>>>>        End
84710>>>>>>
84710>>>>>        Else Begin
84711>>>>>            Send AppendTextLn C_$VDF_Studio_License_Text
84712>>>>>        End
84712>>>>>>
84712>>>>>        Send Destroy of hoCLIHandler
84713>>>>>        Send Destroy of hoBtrvHandler
84714>>>>>    End_Procedure
84715>>>>>
84715>>>>>    Procedure Show_HelpFile
84717>>>>>        String sHelpFile
84717>>>>>        Integer eHelpType
84717>>>>>
84717>>>>>        If (ghoApplication <> 0) Begin
84719>>>>>            Get peHelpType Of ghoApplication To eHelpType
84720>>>>>            If (eHelpType = htHtmlHelp and ghoHtmlHelp) Begin
84722>>>>>                Get GetHelpFile Of ghoHtmlHelp To sHelpFile
84723>>>>>            End
84723>>>>>>
84723>>>>>            Else If (eHelpType = htWinHelp and Help_object_id) Begin
84726>>>>>                Get Help_filename Of Help_object_id To sHelpFile
84727>>>>>            End
84727>>>>>>
84727>>>>>            Else Begin
84728>>>>>                Move C_$ThereIsNoHelpfileDefined To sHelpFile
84729>>>>>            End
84729>>>>>>
84729>>>>>
84729>>>>>            Send AppendTextLn (SFormat (C_$HelpFile, sHelpFile))
84730>>>>>        End
84730>>>>>>
84730>>>>>    End_Procedure
84731>>>>>
84731>>>>>    Procedure Show_EnterAsTab
84733>>>>>        Boolean bEnterKeyAsTabKey
84733>>>>>        String sText
84733>>>>>
84733>>>>>        If (ghoApplication <> 0) Begin
84735>>>>>            Get pbEnterKeyAsTabKey Of ghoApplication To bEnterKeyAsTabKey
84736>>>>>            If (bEnterKeyAsTabKey) Begin
84738>>>>>                Move "True" To sText
84739>>>>>            End
84739>>>>>>
84739>>>>>            Else Begin
84740>>>>>                Move "False" To sText
84741>>>>>            End
84741>>>>>>
84741>>>>>            Send AppendTextLn (SFormat (C_$EnterKeyNavForward, sText))
84742>>>>>        End
84742>>>>>>
84742>>>>>    End_Procedure
