97822>>>>>    // Returns the handle of the Mertech SQL handler.
97822>>>>>    // It also ensures that the correct Server & Database attributes are set both for 
97822>>>>>    // embedded SQL calls and "normal" database commands like e.g. "Open".
97822>>>>>    Function _MertechSQLManagerHandle Returns Handle
97824>>>>>        Handle hoSQLHandler
97824>>>>>        String sDriverID sServer sDatabase
97824>>>>>        
97824>>>>>        Move 0 to hoSQLHandler
97825>>>>>        Get psDriverID to sDriverID       
97826>>>>>        Get psServer   to sServer
97827>>>>>        Get psDatabase to sDatabase
97828>>>>>        // This command is used to set the server to be used when opening tables   
97828>>>>>        SET_CURRENT_SQL_SERVER            to sServer  
97847>>>>>>
97847>>>>>        // This command is used to specify which server to use for embedded SQL statements,
97847>>>>>        // but it has been constructed rather studidly as only constants and not variables
97847>>>>>        // are allowed...
97847>>>>>        If (sDriverID = MDSPgSQL) Begin
97849>>>>>            SET_CURRENT_SQL_SERVER_CONNECTION of MDSPgSQL to sServer
97865>>>>>        End
97865>>>>>>
97865>>>>>        If (sDriverID = MDSMySQL) Begin
97867>>>>>            SET_CURRENT_SQL_SERVER_CONNECTION of MDSMySQL to sServer
97883>>>>>        End
97883>>>>>>
