92027>>>>>    // Enumerate SQL Servers. 
92027>>>>>    // Pass a driver id. Returns a string array.                     
92027>>>>>    // The iDataSourceType (iDatSrcType) parameter is optional and is for the ODBC driver only.
92027>>>>>    // Note: Returns servers for MSSQLDRV; else data-sources on the machine.
92027>>>>>    Function SqlUtilEnumerateServers String sDriverID Integer iDatSrcType Returns String[]
92029>>>>>        String[] sReturnArray
92030>>>>>        Handle hoSQLHandler
92030>>>>>        String sServer
92030>>>>>        Integer iCount iNumItems iDataSourceType
92030>>>>>        Boolean bOK
92030>>>>>        
92030>>>>>        If (num_arguments > 1) Begin
92032>>>>>            Move iDatSrcType to iDataSourceType
92033>>>>>        End                                    
92033>>>>>>
92033>>>>>        
92033>>>>>        Case Begin
92033>>>>>            Case (sDriverID = MSSQLDRV_ID) 
92035>>>>>                Get phoMSSQLHandler to hoSQLHandler
92036>>>>>                    Get EnumerateServersLocal of hoSQLHandler to iNumItems
92037>>>>>                    If (iNumItems = 0) Begin
92039>>>>>                        Get EnumerateServers of hoSQLHandler to iNumItems
92040>>>>>                    End            
92040>>>>>>
92040>>>>>                For iCount from 0 to (iNumItems - 1)
92046>>>>>>
92046>>>>>                    Get String_Value of hoSQLHandler item iCount to sServer
92047>>>>>                    Move (Trim(sServer)) to sReturnArray[iCount]
92048>>>>>                Loop
92049>>>>>>
92049>>>>>                Case Break 
92050>>>>>    
92050>>>>>            Case (sDriverID = DB2_DRV_ID) 
92053>>>>>                Get phoDB2SQLHandler to hoSQLHandler
92054>>>>>                Send SeedDataSources of hoSQLHandler          
92055>>>>>                Move 0 to iCount
92056>>>>>                Repeat
92056>>>>>>
92056>>>>>                    Get DataSources of hoSQLHandler to sServer
92057>>>>>                    If (sServer <> "") Begin   
92059>>>>>                        Move (Replace(",", sServer, "")) to sServer
92060>>>>>                        Move sServer to sReturnArray[iCount]
92061>>>>>                    End
92061>>>>>>
92061>>>>>                    Increment iCount    
92062>>>>>                Until (sServer = "")
92064>>>>>                Case Break
92065>>>>>    
92065>>>>>            Case (sDriverID = ODBC_DRV_ID) 
92068>>>>>                Get phoODBCSQLHandler to hoSQLHandler
92069>>>>>                Set DataSourceType of hoSQLHandler to iDataSourceType       
92070>>>>>                Move 0 to iCount
92071>>>>>                Repeat
92071>>>>>>
92071>>>>>                    Get DataSources of hoSQLHandler to sServer
92072>>>>>                    If (sServer <> "") Begin   
92074>>>>>                        Move (Replace(",", sServer, ", ")) to sServer
92075>>>>>                        Move sServer to sReturnArray[iCount]
92076>>>>>                    End
92076>>>>>>
92076>>>>>                    Increment iCount    
92077>>>>>                Until (sServer = "")
92079>>>>>                Case Break    
92080>>>>>            
92080>>>>>            Case (sDriverID = SQLFLEX)  
92083>>>>>                Get _MertechEnumerateSQLFlexServers to sReturnArray
92084>>>>>                Case Break
92085>>>>>            
92085>>>>>            Case (sDriverID = ORAFLEX)          
92088>>>>>                Get _MertechEnumerateORAFLEXServers to sReturnArray
92089>>>>>                Case Break
92090>>>>>            
92090>>>>>            // There appearantly is no way to enumerate servers for this backend.
92090>>>>>            Case (sDriverID = MDSPgSQL)
92093>>>>>                Move "localhost" to sReturnArray[0]
92094>>>>>                Case Break
92095>>>>>            
92095>>>>>            // There appearantly is no way to enumerate servers for this backend.
92095>>>>>            Case (sDriverID = MDSMySQL)
92098>>>>>                Move "localhost" to sReturnArray[0]
92099>>>>>                Case Break
92100>>>>>            
92100>>>>>            Case Else
92100>>>>>                Error DFERR_PROGRAM "Unsupported DriverID passed to SqlUtilEnumerateServers function"
92101>>>>>>
92101>>>>>        Case End
92101>>>>>
92101>>>>>        Function_Return sReturnArray
92102>>>>>    End_Function
92103>>>>>    
92103>>>>>    // Returns all databases as a string array for the passed driver id.
92103>>>>>    Function SqlUtilEnumerateDatabases String sDriverID Returns String[]
92105>>>>>        String[] sReturnArray                                                    
92106>>>>>        String sUserID sPassword 
92106>>>>>        Boolean bOK
92106>>>>>        
92106>>>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
92107>>>>>        If (bOK = False) Begin
92109>>>>>            Function_Return sReturnArray
92110>>>>>        End    
92110>>>>>>
92110>>>>>        
92110>>>>>        Case Begin
92110>>>>>            Case (sDriverID = MSSQLDRV_ID)
92112>>>>>                Get _SqlDatabasesArrayMSSQL to sReturnArray
92113>>>>>                Case Break                                                            
92114>>>>>            Case (sDriverID = DB2_DRV_ID)
92117>>>>>                Get _SqlDatabasesArrayDB2 to sReturnArray
92118>>>>>                Case Break
92119>>>>>
92119>>>>>            // Enumeration of ODBC databases should be irrelevant as the database
92119>>>>>            // should have been specified when the ODBC source was setup with the ODBC manager.
92119>>>>>            Case (sDriverID = ODBC_DRV_ID)
92122>>>>>                Case Break
92123>>>>>
92123>>>>>            Case (sDriverID = SQLFLEX)
92126>>>>>                Get SqlProcedureArrayMertech "sp_databases" "" to sReturnArray
92127>>>>>                Case Break
92128>>>>>
92128>>>>>            Case (sDriverID = MDSPgSQL)
92131>>>>>                Get SqlEnumerateEsqlMertech "SELECT datname FROM pg_database" to sReturnArray
92132>>>>>                Case Break
92133>>>>>                 
92133>>>>>            Case (sDriverID = MDSMySQL)
92136>>>>>                Get SqlEnumerateEsqlMertech "show databases" to sReturnArray
92137>>>>>                Case Break 
92138>>>>>            
92138>>>>>            Case (sDriverID = ORAFLEX)  
92141>>>>>                Get SqlEnumerateEsqlMertech "SELECT NAME FROM v$database" to sReturnArray
92142>>>>>                Case Break
92143>>>>>
92143>>>>>            Case Else
92143>>>>>                Error DFERR_PROGRAM "Unsupported DriverID passed to SqlUtilEnumerateDatabases function"
92144>>>>>>
92144>>>>>        Case End  
92144>>>>>        
92144>>>>>        Function_Return sReturnArray
92145>>>>>    End_Function
