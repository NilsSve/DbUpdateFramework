85612>>>    Function SqlUtilUpdateIntFile Integer hTable Returns Boolean           
85614>>>        String sOrgFormat sNewFormat sRootName sDatabaseName sPhysicalFileName sDriverID sDataPath         
85614>>>        Boolean bOpened bOK bMertech
85614>>>        
85614>>>        Move CS_OEM_Txt  to sOrgFormat
85615>>>        Move CS_ANSI_Txt to sNewFormat
85616>>>        Get AutoConnectionIDLogin to bOK
85617>>>        Send Ignore_Error of Error_Object_Id DFERR_MISSING_VALUE
85618>>>        Open hTable //Mode DF_EXCLUSIVE
85620>>>        Send Trap_Error of Error_Object_Id DFERR_MISSING_VALUE
85621>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpened
85624>>>        
85624>>>        // ToDo: What to do if we cannot open the table?!
85624>>>        If (bOpened = False) Begin
85626>>>            Function_Return False
85627>>>        End
85627>>>>
85627>>>        
85627>>>        Get psDriverID to sDriverID
85628>>>        Get IsMertechDriver sDriverID to bMertech
85629>>>        If (bMertech = True) Begin       
85631>>>            Get psDataPathFirstPart to sDataPath
85632>>>            Get vFolderExists sDataPath to bOK
85633>>>            If (bOK = False) Begin
85635>>>                Error DFERR_PROGRAM "Function SqlUtilUpdateIntFile; psDataPath not found!"
85636>>>>
85636>>>                Function_Return False    
85637>>>            End                      
85637>>>>
85637>>>            Get vFolderFormat sDataPath to sDataPath 
85638>>>            Get_Attribute DF_FILE_ROOT_NAME of hTable to sRootName
85641>>>            Get _TableNameOnly sRootName to sDatabaseName
85642>>>            Move sDatabaseName to sPhysicalFileName
85643>>>            Move (sPhysicalFileName + ".int") to sPhysicalFileName
85644>>>            Get _MertechSqlUtilCreateIntFile hTable sDataPath sPhysicalFileName to bOK
85645>>>            Function_Return (bOK = True)
85646>>>        End
85646>>>>
85646>>>        
85646>>>        Move False to Err
85647>>>        Get_Attribute DF_FILE_TABLE_CHARACTER_FORMAT of hTable to sOrgFormat
85650>>>        Move (Uppercase(sOrgFormat)) to sOrgFormat       
85651>>>        // Lets swap the OEM/ANSI format, just to make a change in Structure_Start below (and back),
85651>>>        // to "touch" the table so the driver feels there has been a change and updates the .int file.
85651>>>        Move (If(sOrgFormat = CS_OEM_Txt, CS_ANSI_Txt, CS_OEM_Txt)) to sNewFormat
85652>>>        
85652>>>        Structure_Start hTable
85653>>>            Set_Attribute DF_FILE_TABLE_CHARACTER_FORMAT of hTable to sNewFormat
85656>>>            Set_Attribute DF_FILE_TABLE_CHARACTER_FORMAT of hTable to sOrgFormat
85659>>>        Structure_End hTable (DF_STRUCTEND_OPT_IN_PLACE ior DF_STRUCTEND_OPT_FORCE)
85661>>>        
85661>>>        Function_Return (Err = False)
85662>>>    End_Function 
85663>>>    
85663>>>    // Checks if the passed Table;
85663>>>    // 1) Already has a Filelist entry that points to SQL and
85663>>>    // 2) It has an .int file. 
85663>>>    // If both is True it should already be connected to SQL
85663>>>    Function SQLUtilTableIsAttached String sDriverID Handle hTable Returns Boolean
85665>>>        Boolean bExists bRootName
85665>>>        String sRootName sDataPath
85665>>>        Integer iCount
85665>>>        
85665>>>        Get_Attribute DF_FILE_ROOT_NAME of hTable to sRootName
85668>>>        Move (sRootName contains sDriverID) to bRootName
85669>>>        
85669>>>        Get psDataPathFirstPart to sDataPath
85670>>>        Get vFolderExists sDataPath to bExists
85671>>>        If (bExists = False) Begin
85673>>>            // If the path doesn't exist it cannot have an .int file and we're done, although it shouldn't happen.
85673>>>            Function_Return False
85674>>>        End                      
85674>>>>
85674>>>        
85674>>>        Get vFolderFormat sDataPath to sDataPath         
85675>>>        Get _TableNameOnly sRootName to sRootName
85676>>>        Get vFilePathExists (sDataPath + sRootName + ".int") to bExists
85677>>>
85677>>>        Function_Return (bRootName = True and bExists = True)
85678>>>    End_Function       
85679>>>    
85679>>>    Function SQLUtilTableIsViewType String sDriverID Handle hTable Returns Boolean
85681>>>        Boolean bViewTableType bOpen bMertechDriver bOK
85681>>>        Integer hoSQLHandler
85681>>>        Integer iTableCount iNumTables iPos iTableIndex
85681>>>        String sTableName sOwner sTableType sLogin sEnumTableName sEnumSchemaName sCurrent_Login
85681>>>        Handle hoCliHandler  
85681>>>        tSQLConnection SQLConnection
85681>>>        tSQLConnection SQLConnection
85681>>>        
85681>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpen
85684>>>        If (bOpen = False) Begin  
85686>>>            Get AutoConnectionIDLogin to bOK
85687>>>            Open hTable
85689>>>        End
85689>>>>
85689>>>        
85689>>>        Get pSQLConnection to SQLConnection   
85690>>>        Get phoCLIHandler to hoCliHandler
85691>>>        Set psDriverID of hoCliHandler to sDriverID
85692>>>        
85692>>>        Get_Attribute DF_FILE_ROOT_NAME of hTable to sTableName 
85695>>>        Get _TableNameOnly sTableName to sTableName             
85696>>>        Get_Attribute DF_FILE_OWNER     of hTable to sOwner
85699>>>        Get EnumerateTables of hoCliHandler SQLConnection.sConnectionString to iNumTables
85700>>>        
85700>>>        For iTableCount from 1 to iNumTables
85706>>>>
85706>>>            Get TableName  of hoCliHandler iTableCount to sEnumTableName
85707>>>            Get SchemaName of hoCliHandler iTableCount to sEnumSchemaName
85708>>>            If ((Uppercase(sEnumTableName)  = Uppercase(sTableName)) and (Uppercase(sEnumSchemaName) = Uppercase(sOwner))) Begin
85710>>>                Get TableType of hoCliHandler iTableCount to sTableType
85711>>>                Move iNumTables to iTableCount // We're done.
85712>>>            End
85712>>>>
85712>>>        Loop
85713>>>>
85713>>>        
85713>>>        Move (sTableType = "VIEW") to bViewTableType
85714>>>        If (bOpen = False) Begin
85716>>>            Close hTable
85717>>>        End
85717>>>>
85717>>>        
85717>>>        Function_Return bViewTableType
85718>>>    End_Function
85719>>>    
85719>>>    // *** DbType conversion routines - Converts between string/integer and driver ID values ***
85719>>>    //
85719>>>    // SQL utility function that returns a database type (string) constant
85719>>>    // corresponding to the passed iDbType.
85719>>>    Function SqlUtilDbTypeToString Integer iDbType Returns String
85721>>>        String sRetval
85721>>>        Get SqlUtilDbTypeToString of (phoSQLConnectionIniFile(ghoSQLConnectionHandler)) iDbType to sRetval
85722>>>        Function_Return sRetval
85723>>>    End_Function    
85724>>>    
85724>>>    // SQL utility function that returns a database type constant (integer)
85724>>>    // corresponding to the passed sDbType string constant.
85724>>>    Function SqlUtilDbTypeToInteger String sDbType Returns Integer
85726>>>        Integer iRetval            
85726>>>        Get SqlUtilDbTypeToInteger of (phoSQLConnectionIniFile(ghoSQLConnectionHandler)) sDbType to iRetval
85727>>>        Function_Return iRetval
85728>>>    End_Function    
85729>>>    
85729>>>    // Pass an integer DbType and function returns the database type integer as a string value.
85729>>>    // Used e.g. when reading a connection ini-file to display the database type in
85729>>>    // the SQL Connection program's grid.
85729>>>    Function SqlUtilDbTypeIntegerToStringConstant Integer iDbType Returns String
85731>>>        String sRetval   
85731>>>        Get SqlUtilDbTypeIntegerToStringConstant of (phoSQLConnectionIniFile(ghoSQLConnectionHandler)) iDbType to sRetval
85732>>>        Function_Return sRetval
85733>>>    End_Function    
85734>>>
85734>>>    // Pass a driver name as a string and the function will return
85734>>>    // a dbType as an integer. Obviously for the ODBC_DRV this doesn't
85734>>>    // quite work and always returns "MS SQL Server"
85734>>>    Function SqlUtilDbTypeFromDriver String sDriverID Returns Integer     
85736>>>        Integer iRetval
85736>>>        Get SqlUtilDbTypeFromDriver of (phoSQLConnectionIniFile(ghoSQLConnectionHandler)) sDriverID to iRetval
85737>>>        Function_Return iRetval
85738>>>    End_Function    
85739>>>    
85739>>>    // *** Helper Functions ***
85739>>>    // They all start with an underscore: "_" in the function name.
85739>>>    //
85739>>>    // Reads a SQL script file that has been compiled into the .exe program as a resource.
85739>>>    // Pass: The memory resource reference and a boolean True if you want to create the file on disk (in the Home folder).
85739>>>    // Returns: A tSQLScriptArray Struct with the Sql script as an uChar Array will be returned along with the a bError boolean.
85739>>>    Function SqlUtilReadResource String sMemFileName Returns tSQLScriptArray
85741>>>        Integer iChannel iArgumentSize iOut iChunk iPointer iCount iSize
85741>>>        Number nByteCount
85741>>>        String sCharacter sSQLScript 
85741>>>        Boolean bSeqEof
85741>>>        tSQLScriptArray SqlScriptArray
85741>>>        tSQLScriptArray SqlScriptArray
85741>>>        UChar[] uCharData
85742>>>        
85742>>>        Move False to Err
85743>>>        Get Seq_New_Channel to iChannel
85744>>>        If (iChannel = DF_SEQ_CHANNEL_NOT_AVAILABLE) Begin
85746>>>            Error DFERR_PROGRAM 'No channel available...'
85747>>>>
85747>>>            Move True to SqlScriptArray.bError
85748>>>            Function_Return SqlScriptArray
85749>>>        End                    
85749>>>>
85749>>>        
85749>>>        // First decide the size of the script
85749>>>        Direct_Input channel iChannel ("Resource: " + sMemFileName)
85751>>>        Read_Block channel iChannel uCharData -1 // -1 means that all data should be read.
85753>>>        Close_Input channel iChannel
85755>>>
85755>>>        Move (SizeOfArray(uCharData)) to nByteCount 
85756>>>        If (nByteCount  < 1) Begin
85758>>>            Send Seq_Release_Channel iChannel  
85759>>>            Move True to SqlScriptArray.bError
85760>>>            Function_Return SqlScriptArray
85761>>>        End
85761>>>>
85761>>>        
85761>>>        // If necessary change the string argument_size
85761>>>        Get_Argument_Size to iArgumentSize
85762>>>        If (nByteCount >= iArgumentSize) Begin
85764>>>            Move (nByteCount + 2048) to nByteCount
85765>>>            Set_Argument_Size nByteCount // Set new argument size just a bit higher than "needed" for overhead margin.
85766>>>>
85766>>>            Move True          to SqlScriptArray.bArgumentSizeChanged
85767>>>            Move iArgumentSize to SqlScriptArray.iOrgArgumentSize
85768>>>        End                         
85768>>>>
85768>>>        Else Begin
85769>>>            Move False to SqlScriptArray.bArgumentSizeChanged
85770>>>        End
85770>>>>
85770>>>        
85770>>>        // Read the script file from memory line-by-line
85770>>>        Direct_Input channel iChannel ("Resource: " + sMemFileName) 
85772>>>            Move 0 to iCount
85773>>>            Repeat
85773>>>>
85773>>>                Readln channel iChannel sSQLScript
85775>>>                Move sSQLScript to SqlScriptArray.sSQLScriptArray[iCount]
85776>>>                Increment iCount
85777>>>            Until (SeqEof = True)
85779>>>        Close_Input channel iChannel
85781>>>        Send Seq_Release_Channel iChannel 
85782>>>        
85782>>>        // Finally "sanitize" the script by removing all comments.
85782>>>        Get _SqlUtilSanitizeScript SqlScriptArray to SqlScriptArray  
85783>>>
85783>>>        Function_Return SqlScriptArray
85784>>>    End_Function 
85785>>>    
85785>>>    Function SqlUtilExecuteEmbeddedScript tSQLScriptArray SQLScriptArray String sDriverID Boolean bCreateScriptFile String sMemFileName Boolean bShowProgr Returns Boolean
85787>>>        String sSQLVal sStmt sCR sDebugFileName sTmp sGOKeyWord sNoCountKeyWord sMessage sExportFile
85787>>>        Handle hoSql hoSQLConnect hoStmt hoError
85787>>>        Integer i iMsgs iFetchResult iResultCount iRows iRowType iCount iChunkCounter iChunkMax iPos iOut iNextSet iMessage
85787>>>        String[] sMsg aSQLQueryMessages
85789>>>        DateTime dtQueryExecStart dtQueryExecEnd
85789>>>        TimeSpan tsQuery
85789>>>        tSqlErrorArray aSqlErrorArray  
85789>>>        tSqlErrorArray aSqlErrorArray  
85789>>>        tSQLConnection SQLConnection
85789>>>        tSQLConnection SQLConnection
85789>>>        Boolean bOK bMertechDriver bShowProgress
85789>>>        
85789>>>        If (num_arguments > 4) Begin
85791>>>            Move bShowProgr to bShowProgress
85792>>>        End
85792>>>>
85792>>>        Get IsMertechDriver sDriverID to bMertechDriver
85793>>>        If (bMertechDriver = False) Begin
85795>>>            Get phoSQLManager to hoSql
85796>>>        End 
85796>>>>
85796>>>        Else Begin
85797>>>            Get _MertechSQLManagerHandle to hoSql
85798>>>        End
85798>>>>
85798>>>            
85798>>>        Get _SqlFindKeyWord CI_SQLGO to sGOKeyWord
85799>>>        // There seems to be a problem to pass strings when their value gets really big, aka
85799>>>        // above the argument_size level. It isn't clear when these problems starts but sooner
85799>>>        // or later SqlExecDirect stops working correctly with no error messages!
85799>>>        // To guard from this we set a max number of lines (iChunkMax) that can be processed
85799>>>        // at a time. Testing with the Create Chinook Database script; 500 seems like a number that works fine. 
85799>>>        // A bonus of this is that it turns out that it is actually faster to run in chunks!
85799>>>        Get piChunkMax to iChunkMax    
85800>>>        Move 0 to iChunkCounter                                 
85801>>>        Move "" to sStmt   
85802>>>
85802>>>        Get _SqlFindKeyWord CI_SQLSetNoCountOn to sNoCountKeyWord
85803>>>        Move (Character(13) + Character(10)) to sCR
85804>>>
85804>>>        Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
85805>>>        
85805>>>        If (bMertechDriver = True) Begin
85807>>>            Get _MertechSQLConnect sDriverID SQLConnection.sServer SQLConnection.sUserID SQLConnection.sPassword to hoSQLConnect
85808>>>        End
85808>>>>
85808>>>        If (bMertechDriver = False) Begin
85810>>>            Get phoSQLManager  to hoSQL
85811>>>            Send SqlSetConnect of hoSQL sDriverID SQLConnection.sConnectionString
85812>>>            Get SqlConnect     of hoSQL "" "" to hoSQLConnect
85813>>>        End
85813>>>>
85813>>>
85813>>>        If (hoSQLConnect <> 0) Begin 
85815>>>            Move False to Err
85816>>>            Get SqlOpen of hoSQLConnect to hoStmt
85817>>>            If (hoStmt <> 0) Begin
85819>>>
85819>>>                // If the embedded resource should be written as a script file to disk:
85819>>>                If (bCreateScriptFile = True) Begin
85821>>>                    Get psHome of (phoWorkspace(ghoApplication)) to sExportFile
85822>>>                    Get vFolderFormat sExportFile to sExportFile
85823>>>                    Move (sExportFile + sMemFileName) to sExportFile
85824>>>                    Get Seq_New_Channel to iOut 
85825>>>                    If (iOut <> DF_SEQ_CHANNEL_NOT_AVAILABLE) Begin
85827>>>                        Direct_Output channel iOut sExportFile  
85829>>>                    End
85829>>>>
85829>>>                End
85829>>>>
85829>>>        
85829>>>                // Record starting date/time stamp
85829>>>                Move (CurrentDateTime()) to dtQueryExecStart
85830>>>                // Turn on error handling if enabled
85830>>>                If (pbHandleQueryErrors(Self)) Begin
85832>>>                    Set pbSqlError to False  
85833>>>                    Set paSqlErrorArray to aSqlErrorArray
85834>>>                    Move Error_Object_Id to hoError
85835>>>                    Move Self to Error_Object_Id
85836>>>                End                                                    
85836>>>>
85836>>>                
85836>>>                Move (SizeOfArray(SQLScriptArray.sSQLScriptArray)) to iRows  
85837>>>                Decrement iRows
85838>>>                Move (sNoCountKeyWord + sCR) to sStmt
85839>>>
85839>>>                For iCount from 0 to iRows   
85845>>>>
85845>>>                    Move (SQLScriptArray.sSQLScriptArray[iCount]) to sSQLVal
85846>>>                    
85846>>>                    If (Uppercase(sSQLVal) <> sGOKeyWord) Begin
85848>>>                        If (sSQLVal <> "") Begin
85850>>>                            Move (sSQLVal + sCR) to sSQLVal
85851>>>                        End
85851>>>>
85851>>>                        Move (Append(sStmt, (sSQLVal))) to sStmt
85852>>>                    End
85852>>>>
85852>>>                    
85852>>>                    // - Each time we encounter a "GO" statement we execute it,
85852>>>                    // or if at the very end of the script.
85852>>>                    If (Uppercase(sSQLVal) = sGOKeyWord or iChunkCounter >= iChunkMax or iCount = iRows) Begin 
85854>>>                        
85854>>>                        // - It turns out it can be at least 10 times faster to execute SQL statements in chunks,
85854>>>                        // instead of all in one go. 
85854>>>                        Send SqlExecDirect of hoStmt sStmt 
85855>>>                        
85855>>>                        If (bCreateScriptFile = True) Begin
85857>>>                            Write channel iOut sStmt
85859>>>                        End
85859>>>>
85859>>>                        Move "" to sStmt   
85860>>>                        Move 0 to iChunkCounter
85861>>>                    End
85861>>>>
85861>>>                    Increment iChunkCounter
85862>>>                Loop
85863>>>>
85863>>>                       
85863>>>                Repeat
85863>>>>
85863>>>                    If (pbHandleQueryErrors(Self)) Begin
85865>>>                        Move hoError to Error_Object_Id
85866>>>                    End
85866>>>>
85866>>>                    Move (CurrentDateTime()) to dtQueryExecEnd  
85867>>>                    
85867>>>                    Send _SqlColumnInfo hoStmt
85868>>>                    Get SqlStmtAttribute of hoStmt SqlSTMTATTRIB_ROWCOUNT to iRows
85869>>>                    Get SqlStmtAttribute of hoStmt SqlSTMTATTRIB_ROWCOUNT_TYPE to iRowType
85870>>>                    Get SqlStmtAttribute of hoStmt SqlSTMTATTRIB_NUMMESSAGES to iMsgs
85871>>>                    Set piRows    to iRows
85872>>>                    Set piRowType to iRowType
85873>>>                   
85873>>>                    If (iMsgs <> 0) Begin
85875>>>                        If (ghoDbUpdateHandler > 0) Begin
85877>>>                            Get paSQLQueryMessages of ghoDbUpdateHandler to aSQLQueryMessages
85878>>>                        End
85878>>>>
85878>>>                        For i from 1 to iMsgs
85884>>>>
85884>>>                            Get SqlGetMessage of hoStmt i to sMessage     
85885>>>                            Get RemoveComponentIdentifier of hoStmt sMessage to sMessage   
85886>>>                            If (bShowProgress = True) Begin
85888>>>                                If (Active_State(ghoStatusPanel)) Begin
85890>>>                                    Send Update_StatusPanel of ghoStatusPanel (Sformat("  SQLGetMessage iMessage %1 returned [%2]", iMessage, sMessage))
85891>>>                                End                                                   
85891>>>>
85891>>>                                Else Begin
85892>>>                                    Showln (Sformat("  SQLGetMessage iMessage %1 returned [%2]", iMessage, sMessage))
85894>>>                                End
85894>>>>
85894>>>                            End
85894>>>>
85894>>>                            Move sMessage to sMsg[SizeOfArray(sMsg)]
85895>>>                            Move sMessage to aSQLQueryMessages[SizeOfArray(aSQLQueryMessages)]
85896>>>                        Loop   
85897>>>>
85897>>>                    
85897>>>                    
85897>>>                        If (ghoDbUpdateHandler > 0) Begin
85899>>>                            Set paSQLQueryMessages of ghoDbUpdateHandler to aSQLQueryMessages
85900>>>                        End
85900>>>>
85900>>>                        Set paQueryMessages to sMsg
85901>>>                    End
85901>>>>
85901>>>
85901>>>                    Get SQLNextResultSet of hoStmt to iNextSet
85902>>>                Until (iNextSet = 0)
85904>>>                
85904>>>                Move (CurrentDateTime()) to dtQueryExecEnd
85905>>>            End 
85905>>>>
85905>>>            
85905>>>            Move (dtQueryExecEnd - dtQueryExecStart) to tsQuery
85906>>>            Set ptsQueryExec to tsQuery  
85907>>>            Send SqlClose of hoStmt
85908>>>
85908>>>            If (bCreateScriptFile = True) Begin
85910>>>                Close_Output channel iOut
85912>>>                Send Seq_Release_Channel iOut
85913>>>            End
85913>>>>
85913>>>        End
85913>>>>
85913>>>        Send SqlDisconnect of hoSQLConnect
85914>>>
85914>>>        Function_Return (hoSQLConnect <> 0 and Err = False)
85915>>>    End_Function
85916>>>        
85916>>>    // Returns the index for the passed sTableName
85916>>>    // Returns >= 0 if successful. It is e.g. needed to get the SchemaName for a table.
85916>>>    Function _SqlUtilEnumerateTableIndex String sTableName String sDriverID Returns Integer
85918>>>        Integer iIndex iSize iCount
85918>>>        String[] sTablesArray
85919>>>        String sVal sConnectionString
85919>>>        
85919>>>        Move -1 to iIndex            
85920>>>        Get psConnectionString to sConnectionString
85921>>>        Get SqlUtilEnumerateTables sDriverID to sTablesArray
85922>>>        Move (SizeOfArray(sTablesArray)) to iSize
85923>>>        Decrement iSize
85924>>>        For iCount from 0 to iSize
85930>>>>
85930>>>            Move sTablesArray[iCount] to sVal
85931>>>            If (Uppercase(sVal) = Uppercase(sTableName)) Begin
85933>>>                Move iCount to iIndex // We found it!
85934>>>                Move iSize to iCount  // End the loop    
85935>>>            End
85935>>>>
85935>>>        Loop                  
85936>>>>
85936>>>        
85936>>>        Function_Return iIndex
85937>>>    End_Function
85938>>>
85938>>>    // Helper function that builds a string like;
85938>>>    // "SELECT name from [Master].[sys].[databases] where name"
85938>>>    Function _SqlSelectFromWhereName Returns String
85940>>>        String sRetval sSelect sName sFrom sMaster sSys sDatabases sWhere sDBO
85940>>>        
85940>>>        Get _SqlFindKeyWord CI_SQLSelect       to sSelect
85941>>>        Get _SqlFindKeyWord CI_SQLName         to sName                             
85942>>>        Get _SqlFindKeyWord CI_SQLDBO          to sDBO
85943>>>        Get _SqlFindKeyWord CI_SQLFrom         to sFrom
85944>>>        Get _SqlFindKeyWord CI_SQLMaster       to sMaster
85945>>>        Get _SqlFindKeyWord CI_SQLSys          to sSys
85946>>>        Get _SqlFindKeyWord CI_SQLDatabases    to sDatabases
85947>>>        Get _SqlFindKeyWord CI_SQLWhere        to sWhere
85948>>>        Move (sSelect * sName * sFrom * "[" + sMaster + "].[" + sDBO + "].[" + sSys + sDatabases + "]" * sWhere * sName) to sRetval
85949>>>        Function_Return sRetval
85950>>>    End_Function  
85951>>>    
85951>>>    // To enumerate SQL database resources with ESQL and return the result as a string array,
85951>>>    // for DAW drivers.
85951>>>    // Returns: A string array.
85951>>>    Function SqlEnumerateEsqlDAW String sStmt Integer iColumn Returns String[]
85953>>>        String[] sReturnArray
85954>>>        String sValue sPrevious
85954>>>        Handle hoSQLHandler hoSQLConnect hstmt
85954>>>        Integer iFetchResult iRows
85954>>>        tSQLConnection SQLConnection
85954>>>        tSQLConnection SQLConnection
85954>>>        
85954>>>        Get phoSQLManager to hoSQLHandler
85955>>>                
85955>>>        If (hoSQLHandler <> 0) Begin 
85957>>>            Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
85958>>>            Get SQLConnect of hoSQLHandler SQLConnection.sDriverID SQLConnection.sConnectionString to hoSQLConnect
85959>>>            
85959>>>            If (hoSQLConnect <> 0) Begin   
85961>>>                Get SQLOpen of hoSQLConnect to hstmt
85962>>>                If (hstmt <> 0) Begin                                   
85964>>>                    Send SqlExecDirect of hstmt sStmt                                             
85965>>>                    Get SqlStmtAttribute of hstmt SqlSTMTATTRIB_ROWCOUNT to iRows 
85966>>>                    Repeat
85966>>>>
85966>>>                        Get SQLFetch of hstmt to iFetchResult
85967>>>                        If (iFetchResult <> 0) Begin
85969>>>                            Get SQLColumnValue of hstmt iColumn to sValue
85970>>>                            If (sValue <> sPrevious) Begin
85972>>>                                Move (Trim(sValue)) to sReturnArray[SizeOfArray(sReturnArray)
85973>>>                            End
85973>>>>
85973>>>                            Move sValue to sPrevious
85974>>>                        End
85974>>>>
85974>>>                    Until (iFetchResult = 0)
85976>>>                    Send SQLClose of hstmt
85977>>>                End
85977>>>>
85977>>>                Send SQLDisconnect of hoSQLConnect    
85978>>>            End
85978>>>>
85978>>>        End
85978>>>>
85978>>>    
85978>>>        Function_Return sReturnArray
85979>>>    End_Function   
85980>>>
85980>>>    // To enumerate SQL database resources with ESQL and return the result as a string array,
85980>>>    // for Mertech drivers.
