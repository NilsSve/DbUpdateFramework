80832>>>>>>>    // Save the skin preference. This requires an application object.
80832>>>>>>>    // Only do this if the application object allows it. 
80832>>>>>>>    // This is called during startup if pbLoadPreference is True
80832>>>>>>>    // Suitable for override
80832>>>>>>>    Procedure SaveSkinPreference 
80834>>>>>>>        String sSkin sIni
80834>>>>>>>        If ghoApplication Begin
80836>>>>>>>            If (pbPreserveEnvironment(ghoApplication)) Begin
80838>>>>>>>                Get psSkinFile to sSkin
80839>>>>>>>                Get psSkinIni to sIni
80840>>>>>>>                Send WriteString of ghoApplication "Preferences" "SkinFile" sSkin
80841>>>>>>>                Send WriteString of ghoApplication "Preferences" "SkinIni" sIni
80842>>>>>>>            End
80842>>>>>>>>
80842>>>>>>>        End
80842>>>>>>>>
80842>>>>>>>        Else Begin
80843>>>>>>>            Error DFERR_PROGRAM C_$ApplicationObjectNotCreated
80844>>>>>>>>
80844>>>>>>>        End
80844>>>>>>>>
80844>>>>>>>    End_Procedure
80845>>>>>>>
80845>>>>>>>    // Load the skin preference. This requires an application object.
80845>>>>>>>    // Only do this if the application object allows it. 
80845>>>>>>>    // This is called during startup if pbLoadPreference is True
80845>>>>>>>    // Suitable for override
80845>>>>>>>    Procedure LoadSkinPreference 
80847>>>>>>>        String sSkin sIni
80847>>>>>>>        Boolean bExists
80847>>>>>>>        If ghoApplication Begin
80849>>>>>>>            If (pbPreserveEnvironment(ghoApplication)) Begin
80851>>>>>>>                Get ValueExists of ghoApplication "Preferences" "SkinFile" to bExists
80852>>>>>>>                If bExists Begin
80854>>>>>>>                    Get ReadString of ghoApplication "Preferences" "SkinFile" "" to sSkin
80855>>>>>>>                    Get ReadString of ghoApplication "Preferences" "SkinIni" "" to sIni
80856>>>>>>>                    Set psSkinFile to sSkin
80857>>>>>>>                    Set psSkinIni to sIni
80858>>>>>>>                End
80858>>>>>>>>
80858>>>>>>>            End
80858>>>>>>>>
80858>>>>>>>        End
80858>>>>>>>>
80858>>>>>>>        Else Begin
80859>>>>>>>            Error DFERR_PROGRAM C_$ApplicationObjectNotCreated
80860>>>>>>>>
80860>>>>>>>        End
80860>>>>>>>>
80860>>>>>>>    End_Procedure
80861>>>>>>>
80861>>>>>>>    // Can be called to apply the current skin.
80861>>>>>>>    Procedure ApplySkin
80863>>>>>>>        Boolean bOk
80863>>>>>>>        String sSkin sIni
80863>>>>>>>        If (IsComObjectCreated(Self)) Begin
80865>>>>>>>            Get SkinQFile to sSkin
80866>>>>>>>            Get psSkinIni to sIni
80867>>>>>>>            
80867>>>>>>>            Send NotifyPreApplySkin
80868>>>>>>>            // when skins are used we don't want to use built in Visual Styles
80868>>>>>>>            Send EnableVisualStyles of Desktop (sSkin="")
80869>>>>>>>            Get ComLoadSkin sSkin sIni to bOK
80870>>>>>>>            If (sSkin<>"" and not(bOk)) Begin
80872>>>>>>>                // if not ok, no skin was appied. Enable visual styles
80872>>>>>>>                Send EnableVisualStyles of Desktop True
80873>>>>>>>            End
80873>>>>>>>>
80873>>>>>>>            Send NotifyPostApplySkin
80874>>>>>>>        End
80874>>>>>>>>
80874>>>>>>>    End_Procedure
80875>>>>>>>
80875>>>>>>>
80875>>>>>>>End_Class
