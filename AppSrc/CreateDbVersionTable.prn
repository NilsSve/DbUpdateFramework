84793>>>    // Checks if the database exists in SQL. Returns = True if it does.
84793>>>    Function SqlUtilCheckIfDatabaseExists String sDatabase Returns Boolean
84795>>>        String[] sDatabaseArray
84796>>>        String sVal sServer sDriverID
84796>>>        Integer iCount iSize iPos
84796>>>        Boolean bExists            
84796>>>        tSQLConnection SQLConnection
84796>>>        tSQLConnection SQLConnection
84796>>>        
84796>>>        Move False to bExists                              
84797>>>        Get psDriverID to sDriverID
84798>>>        // DB2 doesn't need to have a "Database" name, so we always return True.
84798>>>        If (sDriverID = DB2_DRV_ID) Begin
84800>>>            Function_Return bExists
84801>>>        End                     
84801>>>>
84801>>>        
84801>>>        Get SqlUtilEnumerateDatabases sDriverID to sDatabaseArray
84802>>>        If (SizeOfArray(sDatabaseArray) = 0) Begin
84804>>>            Function_Return False
84805>>>        End
84805>>>>
84805>>>        
84805>>>        Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
84806>>>        Get ParseKeyWord SQLConnection.sConnectionString (CS_SQLIniDSNKeyword + "=") to sServer
84807>>>        If (sServer contains "/") Begin
84809>>>            Move (Pos("/", sServer)) to iPos
84810>>>            Move (Mid(sServer, 999, (iPos +1)))                        to sDatabase
84811>>>        End
84811>>>>
84811>>>        
84811>>>        Move (SizeOfArray(sDatabaseArray)) to iSize
84812>>>        Decrement iSize
84813>>>        For iCount from 0 to iSize
84819>>>>
84819>>>            Move sDatabaseArray[iCount] to sVal
84820>>>            If (Uppercase(sVal) = Uppercase(sDatabase)) Begin
84822>>>                Move True to bExists
84823>>>            End
84823>>>>
84823>>>        Loop
84824>>>>
84824>>>        
84824>>>        Function_Return bExists
84825>>>    End_Function
