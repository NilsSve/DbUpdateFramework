91811>>>>>    Procedure Show_Date_Format
91813>>>>>        Integer iDateFormat
91813>>>>>        String sDateFormat
91813>>>>>
91813>>>>>        Get_Attribute DF_DATE_FORMAT to iDateFormat
91816>>>>>        Case Begin
91816>>>>>            Case (iDateFormat = DF_DATE_USA)
91818>>>>>                Move C_$USA To sDateFormat
91819>>>>>                Case Break
91820>>>>>            Case (iDateFormat = DF_DATE_EUROPEAN)
91823>>>>>                Move C_$European To sDateFormat
91824>>>>>                Case Break
91825>>>>>            Case (iDateFormat = DF_DATE_MILITARY)
91828>>>>>                Move C_$Military To sDateFormat
91829>>>>>                Case Break
91830>>>>>            Case Else
91830>>>>>                Move C_$UnknownDateType To sDateFormat
91831>>>>>                Case Break
91832>>>>>        Case End
91832>>>>>
91832>>>>>        Send AppendTextLn (SFormat (C_$DateFormat, sDateformat))
91833>>>>>    End_Procedure
91834>>>>>
91834>>>>>    // 2013-08-14 NGS
91834>>>>>    // Unformatted numeric values shown doesn't look good. These looks much better.
91834>>>>>    Procedure Show_Systemresources
91836>>>>>        tWinMemoryStatusEx MemoryStatusInfo
91836>>>>>        tWinMemoryStatusEx MemoryStatusInfo
91836>>>>>        Integer iRetval
91836>>>>>        Number nValue
91836>>>>>        String sValue
91836>>>>>
91836>>>>>        Move (SizeOfType (tWinMemoryStatusEx)) to MemoryStatusInfo.dwLength
91837>>>>>        Move (GlobalMemoryStatusEx (AddressOf (MemoryStatusInfo))) to iRetval
91838>>>>>        If (iRetval = 0) Begin
91840>>>>>            Move (ShowLastError ()) to iRetval
91841>>>>>            Procedure_Return
91842>>>>>        End
91842>>>>>>
91842>>>>>
91842>>>>>        Send AppendTextLn ""
91843>>>>>        Move MemoryStatusInfo.ullTotalPhys to nValue
91844>>>>>
91844>>>>>        // Show memory in Gigabytes:
91844>>>>>        Move (nValue/1024/1024/1024) to nValue
91845>>>>>        Move (Round(nValue)) to nValue
91846>>>>>        Get FormatNumber nValue 2 to sValue
91847>>>>>        Send AppendTextLn (SFormat (C_$AvailableMemory, (sValue * "GB")))
91848>>>>>        Send AppendTextLn (SFormat (C_$MemoryUtilization, String(MemoryStatusInfo.dwMemoryLoad) * "%"))
91849>>>>>
91849>>>>>//        Send AppendTextLn (SFormat (C_$AvailablePhysicalMemory, Real (MemoryStatusInfo.ullAvailPhys) / Real (MemoryStatusInfo.ullTotalPhys) * 100.0))
91849>>>>>        Move (Real(MemoryStatusInfo.ullAvailPhys) / Real(MemoryStatusInfo.ullTotalPhys) * 100.0) to nValue
91850>>>>>        Move (Round(nValue)) to nValue
91851>>>>>        Get FormatNumber nValue 0 to sValue
91852>>>>>        Send AppendTextLn (SFormat (C_$AvailablePhysicalMemory, (sValue * "%")))
91853>>>>>
91853>>>>>//        Send AppendTextLn (SFormat (C_$AvailablePagefileSpace, Real (MemoryStatusInfo.ullAvailPageFile) / Real (MemoryStatusInfo.ullTotalPageFile) * 100.0))
91853>>>>>        Move (Real(MemoryStatusInfo.ullAvailPageFile) / Real(MemoryStatusInfo.ullTotalPageFile) * 100.0) to nValue
91854>>>>>        Move (Round(nValue)) to nValue
91855>>>>>        Get FormatNumber nValue 0 to sValue
91856>>>>>        Send AppendTextLn (SFormat (C_$AvailablePagefileSpace, (sValue * "%")))
91857>>>>>
91857>>>>>//        Send AppendTextLn (SFormat (C_$AvailableVirtualMemory, Real (MemoryStatusInfo.ullAvailVirtual) / Real (MemoryStatusInfo.ullTotalVirtual) * 100.0))
91857>>>>>        Move (Real(MemoryStatusInfo.ullAvailVirtual) / Real(MemoryStatusInfo.ullTotalVirtual) * 100.0) to nValue
91858>>>>>        Move (Round(nValue)) to nValue
91859>>>>>        Get FormatNumber nValue 0 to sValue
91860>>>>>        Send AppendTextLn (SFormat (C_$AvailableVirtualMemory, (sValue * "%")))
91861>>>>>
91861>>>>>        // Add an empty row after the memory information:
91861>>>>>        Send AppendTextLn ""
91862>>>>>    End_Procedure
91863>>>>>
