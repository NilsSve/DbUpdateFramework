90649>>>    Object oOK_btn is a Button
90651>>>        Set Size to 14 50
90652>>>        Set Location to 59 207
90653>>>        Set Label to "Add Now"
90654>>>        Set Status_Help to "Add to DataFlex Studios 'Tools' menu. The Studio version can be selected with the two spinforms. The COMManifestStudio program gets added to the Studios Tools menu. When selected from the Studio it will pass the current project name on the command line so that the current program's manifest file is automatically loaded by the COMManifestStudio program."
90655>>>        Set peAnchors to anTopRight
90656>>>
90656>>>        Procedure OnClick
90659>>>            Integer iRetval iMajorVersion iMinorVersion
90659>>>            String sText sStudioVersion
90659>>>            Get Value of oStudioMajorVersion_sf to iMajorVersion
90660>>>            Get Value of oStudioMinorVersion_sf to iMinorVersion
90661>>>            Move (String(iMajorVersion) + "." + String(iMinorVersion)) to sStudioVersion
90662>>>            Get AddProgramToStudioToolsMenu sStudioVersion to iRetval
90663>>>            Case Begin
90663>>>                Case (iRetval = cx_RegKeyAlreadyExist)
90665>>>                    Move ("The program already exists in the" * sStudioVersion * "DataFlex Studios Tools menu.") to sText
90666>>>                    Break
90667>>>                Case (iRetval = cx_RegKeyCreated)
90670>>>                    Move ("Success. The tool was added to the" * sStudioVersion *  "DataFlex Studios Tools menu.") to sText
90671>>>                    Break
90672>>>                Case (iRetval = cx_RegkeyFailed)
90675>>>                    Move "Failed. Could not create the registry key for adding the program to the DataFlex Studio's Tools menu." to sText
90676>>>                    Break
90677>>>                Case (iRetval = cx_RegKeyVDFKeyDoesNotExist)
90680>>>                    Move ("Could not find the Studio registry key. Is DataFlex Studio version" * sStudioVersion * "really installed on this machine?") to sText
90681>>>                    Break
90682>>>                Case (iRetval = CX_InstalledOkVdfUnder16)
90685>>>                    Move ("The program was added to the" * sStudioVersion * "Studios Tools menu successfully, but because you installed for an earlier version of the Studio than 16.0 you need to compile the program under that same VDF version, else the Studio can't start the program properly. (Sorry, just a 'feature' of earlier versions of the Studio)") to sText
90686>>>                    Break
90687>>>            Case End
90687>>>
90687>>>            Send Info_Box sText
90688>>>        End_Procedure
90689>>>    End_Object
