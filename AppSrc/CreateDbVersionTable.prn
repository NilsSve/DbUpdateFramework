85498>>>    // Removes all driver identifications (e.g. "MSSQLDRV;MyTable" or "MyTable.MSSQLDRV"
85498>>>    // from the passed filelist.
85498>>>    // Returns the number of tables affected.
85498>>>    Function SqlUtilFilelistRemoveDriverInfo String sFilelist Returns Integer
85500>>>        String sCurrentFileList sRootName sDisplayName sLogicalName sVal
85500>>>        Integer iRetval
85500>>>        Handle hTable
85500>>>        
85500>>>        // We first save the current filelist as the passed filelist name
85500>>>        // may come from another workspace, to restore it when we're ready.
85500>>>        Get_Attribute DF_FILELIST_NAME to sCurrentFileList
85503>>>        Set_Attribute DF_FILELIST_NAME to sFilelist
85506>>>        Move 0 to hTable
85507>>>        Move 0 to iRetval
85508>>>        
85508>>>        Repeat
85508>>>>
85508>>>            Get_Attribute DF_FILE_NEXT_USED of hTable to hTable
85511>>>            If (hTable <> 0) Begin
85513>>>                Get_Attribute DF_FILE_ROOT_NAME    of hTable to sRootName
85516>>>                Get_Attribute DF_FILE_DISPLAY_NAME of hTable to sDisplayName
85519>>>                Get_Attribute DF_FILE_LOGICAL_NAME of hTable to sLogicalName
85522>>>                Move (Uppercase(sRootName)) to sVal
85523>>>                If (sVal contains MSSQLDRV_ID or sVal contains DB2_DRV_ID or sVal contains ODBC_DRV_ID) Begin
85525>>>                    // Prefixes:
85525>>>                    Move (Replace((MSSQLDRV_ID + ":"), sRootName, "")) to sRootName
85526>>>                    Move (Replace((DB2_DRV_ID  + ":"), sRootName, "")) to sRootName
85527>>>                    Move (Replace((ODBC_DRV_ID + ":"), sRootName, "")) to sRootName
85528>>>                    // Suffixes:
85528>>>                    Move (Replace(("." + MSSQLDRV_ID), sRootName, "")) to sRootName
85529>>>                    Move (Replace(("." + DB2_DRV_ID),  sRootName, "")) to sRootName
85530>>>                    Move (Replace(("." + ODBC_DRV_ID), sRootName, "")) to sRootName
85531>>>                    
85531>>>                    // Change Filelist entry:
85531>>>                    Set_Attribute DF_FILE_ROOT_NAME of hTable          to sRootName
85534>>>
85534>>>                    Move (Lowercase(sDisplayName)) to sVal
85535>>>                    If (sVal contains "dbo.") Begin
85537>>>                        Move (Replace("dbo.", sDisplayName, ""))       to sDisplayName
85538>>>                        
85538>>>                        // Change Filelist entry:
85538>>>                        Set_Attribute DF_FILE_DISPLAY_NAME of hTable   to sDisplayName
85541>>>                    End
85541>>>>
85541>>>                    Increment iRetval
85542>>>                End
85542>>>>
85542>>>            End
85542>>>>
85542>>>        Until (hTable = 0)
85544>>>        
85544>>>        Set_Attribute DF_FILELIST_NAME to sCurrentFileList
85547>>>        
85547>>>        Function_Return iRetval
85548>>>    End_Function
