86304>>>        If (hoSQLHandler <> 0) Begin 
86306>>>            Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
86307>>>            Get SQLConnect of hoSQLHandler SQLConnection.sDriverID SQLConnection.sServer SQLConnection.sUserID SQLConnection.sPassword to hoSQLConnect
86308>>>            If (hoSQLConnect <> 0) Begin   
86310>>>                Get SQLOpen of hoSQLConnect to hStmt
86311>>>                If (hStmt <> 0) Begin
86313>>>                    Send SQLSetProcedureName of hStmt sStmt
86314>>>                    If (sArgument <> "") Begin
86316>>>                        Send SqlSetArgument  of hStmt 1 sArgument
86317>>>                    End
86317>>>>
