81493>>>>>>>//*****************************************************************************
81493>>>>>>>//*** Class  : cDfbtrdrvHandler                                                  ***
81493>>>>>>>//*** Purpose: An instance of this class can be used as a broker object to  ***
81493>>>>>>>//***          call several Dfbtrdrv releated methods.                           ***
81493>>>>>>>//*****************************************************************************
81493>>>>>>>
81493>>>>>>>Class cDFBtrDrvHandler Is An Array
81494>>>>>>>
81494>>>>>>>    Procedure Construct_Object Integer iImage
81496>>>>>>>        Forward Send Construct_object iImage
81498>>>>>>>
81498>>>>>>>        Property String  psDriverID       Public "DFBTRDRV"
81499>>>>>>>    End_Procedure // Construct_Object
81500>>>>>>>
81500>>>>>>>
81500>>>>>>>
81500>>>>>>>    //***
81500>>>>>>>    //*** Function: CKRevsion
81500>>>>>>>    //*** Purpose : The revsion of a Dfbtrdrv Connectivity Kit
81500>>>>>>>    //***
81500>>>>>>>
81500>>>>>>>    Function CKRevision Returns String
81502>>>>>>>        Local String  sDriverID
81502>>>>>>>        Local String  sRevision
81502>>>>>>>        Local String  sVoid
81502>>>>>>>        Local Integer iRetval
81502>>>>>>>
81502>>>>>>>        // Ignore error 20491 DFBTRERR_INVALID_DRIVER_FUNCTION_CALL.
81502>>>>>>>        // This error would otherwise be raised when we have an older
81502>>>>>>>        // DFBTRDRV version that has no DFBTRFN_CKREVISION function
81502>>>>>>>        Send Ignore_error To Error_object_Id 20491
81503>>>>>>>        Get psDriverID To sDriverID
81504>>>>>>>        Move (Repeat(" ", 255)) To sRevision
81505>>>>>>>        Call_Driver 0 sDRiverID Function DFBTRFN_CKREVISION Callback 0 Passing sRevision sVoid 0 Result iRetval
81510>>>>>>>        Send Trap_Error To Error_object_Id 20491
81511>>>>>>>        If (Trim(sRevision) = "") Begin
81513>>>>>>>            // Unable to get the revision. return all zeroes.
81513>>>>>>>            Move "0.0.0.0" To sRevision
81514>>>>>>>        End
81514>>>>>>>>
81514>>>>>>>        Function_Return sRevision
81515>>>>>>>    End_Function // CKRevision
81516>>>>>>>
81516>>>>>>>    Function CkUsesUri Returns Integer
81518>>>>>>>        Local String  sDriverID
81518>>>>>>>        Local String  sVoid1
81518>>>>>>>        Local String  sVoid2
81518>>>>>>>        Local Integer iRetval
81518>>>>>>>
81518>>>>>>>        Get psDriverID To sDriverID
81519>>>>>>>
81519>>>>>>>        Move 0 To iRetval
81520>>>>>>>        // Ignore error 20491 DFBTRERR_INVALID_DRIVER_FUNCTION_CALL.
81520>>>>>>>        // This error would otherwise be raised when we have an older
81520>>>>>>>        // DFBTRDRV version that has no DFBTRFN_CKUSESURI function
81520>>>>>>>        Send Ignore_error To Error_object_Id 20491
81521>>>>>>>        Call_Driver 0 sDRiverID Function DFBTRFN_CKUSESURI Callback 0 Passing sVoid1 sVoid2 0 Result iRetval
81526>>>>>>>        Send Trap_Error To Error_object_Id 20491
81527>>>>>>>
81527>>>>>>>        Function_Return iRetval
81528>>>>>>>    End_Function // CKUsesUri
81529>>>>>>>
81529>>>>>>>
81529>>>>>>>
81529>>>>>>>    //***
81529>>>>>>>    //*** Function: ExtractPartFromRevsion
81529>>>>>>>    //*** Purpose : Extarct the Nth part of a a.b.c.d revsion string.
81529>>>>>>>    //***
81529>>>>>>>    //*** Returns : The part version number or -1 if there is no such part number.
81529>>>>>>>    //***
81529>>>>>>>
81529>>>>>>>    Function ExtractPartFromRevision Integer iPartNum String sRevision Returns Integer
81531>>>>>>>        Local Integer iPartRev
81531>>>>>>>        Local Integer iCurrentPart
81531>>>>>>>        Local Integer iSeparatorPos
81531>>>>>>>
81531>>>>>>>        If (iPartNum > 4) ;            Function_Return -1
81534>>>>>>>
81534>>>>>>>        Move 0 To iCurrentPart
81535>>>>>>>        Repeat
81535>>>>>>>>
81535>>>>>>>            Move (Pos(".", sRevision)) To iSeparatorPos
81536>>>>>>>            If (iSeparatorPos > 0) Begin
81538>>>>>>>                Move (Left(sRevision, iSeparatorPos - 1)) To iPartRev
81539>>>>>>>                Move (Right(sRevision, Length(sRevision) - iSeparatorPos)) To sRevision
81540>>>>>>>                Increment iCurrentPart
81541>>>>>>>            End
81541>>>>>>>>
81541>>>>>>>            Else If (sRevision <> "") Begin
81544>>>>>>>                Move sRevision To iPartRev
81545>>>>>>>                Move "" To sRevision
81546>>>>>>>                Increment iCurrentPart
81547>>>>>>>            End
81547>>>>>>>>
81547>>>>>>>            Else ;                Move -1 To iPartRev
81549>>>>>>>        Until (iCurrentPart >= iPartNum Or iPartRev = -1)
81551>>>>>>>
81551>>>>>>>        Function_Return iPartRev
81552>>>>>>>    End_Function // EcxtractPartFromRevision
81553>>>>>>>
81553>>>>>>>
81553>>>>>>>
81553>>>>>>>    //***
81553>>>>>>>    //*** Function: CKMajorRevision
81553>>>>>>>    //*** Purpose : Returns the major revision of the CK
81553>>>>>>>    //***
81553>>>>>>>
81553>>>>>>>    Function CKMajorRevision Returns Integer
81555>>>>>>>        Function_Return (ExtractPartFromRevision (Current_Object, 1, CKRevision(Current_Object)))
81556>>>>>>>    End_Function // CKMajorRevision
81557>>>>>>>
81557>>>>>>>
81557>>>>>>>
81557>>>>>>>    //***
81557>>>>>>>    //*** Function: CKMinorRevision
81557>>>>>>>    //*** Purpose : Returns the minor revision of the CK
81557>>>>>>>    //***
81557>>>>>>>
81557>>>>>>>    Function CKMinorRevision Returns Integer
81559>>>>>>>        Function_Return (ExtractPartFromRevision (Current_Object, 2, CKRevision(Current_Object)))
81560>>>>>>>    End_Function // CKMinorRevision
81561>>>>>>>
81561>>>>>>>
81561>>>>>>>
81561>>>>>>>    //***
81561>>>>>>>    //*** Function: CKReleaseRevision
81561>>>>>>>    //*** Purpose : Returns the release revision of the CK
81561>>>>>>>    //***
81561>>>>>>>
81561>>>>>>>    Function CKReleaseRevision Returns Integer
81563>>>>>>>        Function_Return (ExtractPartFromRevision (Current_Object, 3, CKRevision(Current_Object)))
81564>>>>>>>    End_Function // CKReleaseRevision
81565>>>>>>>
81565>>>>>>>
81565>>>>>>>
81565>>>>>>>    //***
81565>>>>>>>    //*** Function: CKBuildRevision
81565>>>>>>>    //*** Purpose : Returns the major revision of the CK
81565>>>>>>>    //***
81565>>>>>>>
81565>>>>>>>    Function CKBuildRevision Returns Integer
81567>>>>>>>        Function_Return (ExtractPartFromRevision (Current_Object, 4, CKRevision(Current_Object)))
81568>>>>>>>    End_Function // CKBuildRevision
81569>>>>>>>
81569>>>>>>>
81569>>>>>>>
81569>>>>>>>    //***
81569>>>>>>>    //*** Function: IsMinimalRevision
81569>>>>>>>    //*** Purpose : Determines if the CK conforms to a passed minimal revsion.
81569>>>>>>>    //***
81569>>>>>>>
81569>>>>>>>    Function IsMinimalRevision Integer iMajor Integer iMinor Integer iRelease Integer iBuild Returns Integer
81571>>>>>>>        If (iMajor < CKMajorRevision(Current_object)) ;            Function_return (TRUE)
81574>>>>>>>        Else If (iMajor = CKMajorRevision(Current_object)) Begin
81577>>>>>>>            If (iMinor < CKMinorRevision(Current_object)) ;                Function_return (TRUE)
81580>>>>>>>            Else If (iMinor = CKMinorRevision(Current_object)) Begin
81583>>>>>>>                If (iRelease < CKReleaseRevision(Current_object)) ;                    Function_return (TRUE)
81586>>>>>>>                Else If (iRelease = CKReleaseRevision(Current_object) And iBuild <= CKBuildRevision(Current_object)) ;                    Function_return (TRUE)
81590>>>>>>>            End
81590>>>>>>>>
81590>>>>>>>        End
81590>>>>>>>>
81590>>>>>>>
81590>>>>>>>        Function_Return (FALSE)
81591>>>>>>>    End_Function // IsMinimalRevision
81592>>>>>>>
81592>>>>>>>    //   Functions to query the Pervasive.SQL version:
81592>>>>>>>    //       PSQLRequesterVersionInfo    Integer iFileNum Returns String
81592>>>>>>>    //       PSQLLocalEngineVersionInfo  Integer iFileNum Returns String
81592>>>>>>>    //       PSQLServerEngineVersionInfo Integer iFileNum Returns String
81592>>>>>>>    //
81592>>>>>>>    //   All 3 functions return the version of a Pervasive.SQL component
81592>>>>>>>    //   in the following format:
81592>>>>>>>    //       <version>.<revision>.<type>
81592>>>>>>>    //   possible values for <type>:
81592>>>>>>>    //       9 for 32-bit Windows workstation/workgroup engine or Linux
81592>>>>>>>    //         server using Workgroup authentication mode
81592>>>>>>>    //       C for client cache engine
81592>>>>>>>    //       D for DOS workstation
81592>>>>>>>    //       N for client Requester
81592>>>>>>>    //       S for NetWare server
81592>>>>>>>    //       T for 32-bit Windows server engine
81592>>>>>>>    //       U for Linux server using PAM or BTPASSWD authentication
81592>>>>>>>    //
81592>>>>>>>    //   example:
81592>>>>>>>    //       8.50.T
81592>>>>>>>    //   will be returned for a Pervasive.SQL 8.5 Server Engine running on
81592>>>>>>>    //   32-bits Windows server.
81592>>>>>>>    //
81592>>>>>>>    //   The FileNumber parameter must specify an opened table or 0.
81592>>>>>>>    //   For PSQLServerEngineVersionInfo the FileNumber can not be 0.
81592>>>>>>>    //
81592>>>>>>>    //   If the version information is not available or can not be obtained
81592>>>>>>>    //   the functions will return "0.0.0"
81592>>>>>>>
81592>>>>>>>
81592>>>>>>>    //***
81592>>>>>>>    //*** Function: PSQLRequesterVersionInfo
81592>>>>>>>    //*** Purpose : Returns the version information of the
81592>>>>>>>    //***           Pervasive.SQL Client requester.
81592>>>>>>>
81592>>>>>>>    Function PSQLRequesterVersionInfo Integer iFileNum Returns String
81594>>>>>>>
81594>>>>>>>        Local String  sDriverID
81594>>>>>>>        Local String  sVersion
81594>>>>>>>        Local String  sVoid
81594>>>>>>>        Local Integer iRetval
81594>>>>>>>
81594>>>>>>>        // Ignore error 20491 DFBTRERR_INVALID_DRIVER_FUNCTION_CALL.
81594>>>>>>>        // This error would otherwise be raised when we have an older
81594>>>>>>>        // DFBTRDRV version that has no DFBTRFN_CKREVISION function
81594>>>>>>>        Send Ignore_error To Error_object_Id 20491
81595>>>>>>>        Get psDriverID To sDriverID
81596>>>>>>>        Move (Repeat(" ", 255)) To sVersion
81597>>>>>>>        Call_Driver iFileNum sDRiverID Function DFBTRFN_PSQLREQUESTERVERSIONINFO Callback 0 Passing sVersion sVoid 0 Result iRetval
81602>>>>>>>        Send Trap_Error To Error_object_Id 20491
81603>>>>>>>        If (Trim(sVersion) = "") Begin
81605>>>>>>>            // Unable to get the revision. return all zeroes.
81605>>>>>>>            Move "0.0.0" To sVersion
81606>>>>>>>        End
81606>>>>>>>>
81606>>>>>>>        Function_Return sVersion
81607>>>>>>>    End_Function //  PSQLRequesterVersion
81608>>>>>>>
81608>>>>>>>    //***
81608>>>>>>>    //*** Function: PSQLLocalEngineVersionInfo
81608>>>>>>>    //*** Purpose : Returns the version information of the
81608>>>>>>>    //***           Pervasive.SQL Local Engine
81608>>>>>>>
81608>>>>>>>    Function PSQLLocalEngineVersionInfo Integer iFileNum Returns String
81610>>>>>>>
81610>>>>>>>        Local String  sDriverID
81610>>>>>>>        Local String  sVersion
81610>>>>>>>        Local String  sVoid
81610>>>>>>>        Local Integer iRetval
81610>>>>>>>
81610>>>>>>>        // Ignore error 20491 DFBTRERR_INVALID_DRIVER_FUNCTION_CALL.
81610>>>>>>>        // This error would otherwise be raised when we have an older
81610>>>>>>>        // DFBTRDRV version that has no DFBTRFN_CKREVISION function
81610>>>>>>>        Send Ignore_error To Error_object_Id 20491
81611>>>>>>>        Get psDriverID To sDriverID
81612>>>>>>>        Move (Repeat(" ", 255)) To sVersion
81613>>>>>>>        Call_Driver iFileNum sDRiverID Function DFBTRFN_PSQLLOCALENGINEVERSIONINFO Callback 0 Passing sVersion sVoid 0 Result iRetval
81618>>>>>>>        Send Trap_Error To Error_object_Id 20491
81619>>>>>>>        If (Trim(sVersion) = "") Begin
81621>>>>>>>            // Unable to get the revision. return all zeroes.
81621>>>>>>>            Move "0.0.0" To sVersion
81622>>>>>>>        End
81622>>>>>>>>
81622>>>>>>>        Function_Return sVersion
81623>>>>>>>    End_Function //  PSQLLocalEngineVersion
81624>>>>>>>
81624>>>>>>>    //***
81624>>>>>>>    //*** Function: PSQLServerEngineVersionInfo
81624>>>>>>>    //*** Purpose : Returns the version information of the
81624>>>>>>>    //***           Pervasive.SQL Server Engine
81624>>>>>>>
81624>>>>>>>    Function PSQLServerEngineVersionInfo Integer iFileNum Returns String
81626>>>>>>>
81626>>>>>>>        Local String  sDriverID
81626>>>>>>>        Local String  sVersion
81626>>>>>>>        Local String  sVoid
81626>>>>>>>        Local Integer iRetval
81626>>>>>>>
81626>>>>>>>        // Ignore error 20491 DFBTRERR_INVALID_DRIVER_FUNCTION_CALL.
81626>>>>>>>        // This error would otherwise be raised when we have an older
81626>>>>>>>        // DFBTRDRV version that has no DFBTRFN_CKREVISION function
81626>>>>>>>        Send Ignore_error To Error_object_Id 20491
81627>>>>>>>        Get psDriverID To sDriverID
81628>>>>>>>        Move (Repeat(" ", 255)) To sVersion
81629>>>>>>>        Call_Driver iFileNum sDRiverID Function DFBTRFN_PSQLSERVERENGINEVERSIONINFO Callback 0 Passing sVersion sVoid 0 Result iRetval
81634>>>>>>>        Send Trap_Error To Error_object_Id 20491
81635>>>>>>>        If (Trim(sVersion) = "") Begin
81637>>>>>>>            // Unable to get the revision. return all zeroes.
81637>>>>>>>            Move "0.0.0" To sVersion
81638>>>>>>>        End
81638>>>>>>>>
81638>>>>>>>        Function_Return sVersion
81639>>>>>>>    End_Function //  PSQLServerEngineVersion
