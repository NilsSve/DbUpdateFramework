82183>>>>>>>>>Class cDbUpdateORAFLEXDriver is a cDbUpdateGenericDatabaseDriver
82184>>>>>>>>>    Function DbLogin String sConnectionString String sServer String sDatabase Boolean bTrusted String sUserID String sPassword Returns Boolean
82186>>>>>>>>>        Boolean bLoginSuccessful
82186>>>>>>>>>        String sDriverID sErrorMsg
82186>>>>>>>>>        String sVal
82186>>>>>>>>>        Integer iPos
82186>>>>>>>>>
82186>>>>>>>>>        Get psDriverID to sDriverID
82187>>>>>>>>>        Move (Pos("/", sServer)) to iPos
82188>>>>>>>>>        If (iPos = 0) Begin
82190>>>>>>>>>            If (sDatabase <> "") Begin
82192>>>>>>>>>                Move (sServer + "/" + sDatabase) to sServer        
82193>>>>>>>>>            End
82193>>>>>>>>>>
82193>>>>>>>>>        End
82193>>>>>>>>>>
82193>>>>>>>>>        // For the Mertech driver, using the Err indicator is the sanctioned way
82193>>>>>>>>>        Move False to Err
82194>>>>>>>>>        // For Oracle I don't believe "Trusted" doesn't exist.
82194>>>>>>>>>        Login sServer sUserId sPassword sDriverID
82196>>>>>>>>>        
82196>>>>>>>>>        Move (not(Err)) to bLoginSuccessful
82197>>>>>>>>>        Function_Return bLoginSuccessful
82198>>>>>>>>>    End_Function
82199>>>>>>>>>End_Class
