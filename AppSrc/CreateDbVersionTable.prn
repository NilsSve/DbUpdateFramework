87310>>>    Function ApiTableRename Integer hTable String sRootName String sDisplayName String sLogicalName Returns Boolean
87312>>>        String sPhysicalName sDataPath sDriverID
87312>>>        Boolean bOK bExists
87312>>>        Integer iRetval
87312>>>        
87312>>>        Move False to Err
87313>>>        Get psDataPathFirstPart to sDataPath
87314>>>        Get_Attribute DF_FILE_PHYSICAL_NAME of hTable to sPhysicalName
87317>>>        
87317>>>        Get_Attribute DF_FILE_DRIVER of hTable to sDriverID
87320>>>        Close hTable  
87321>>>        If (sDriverID = DATAFLEX_ID) Begin                    
87323>>>            Get vFilePathExists (sDataPath + sRootName + ".dat") to bExists
87324>>>            If (bExists = True) Begin
87326>>>                If (Uppercase(sPhysicalName) = Uppercase(sRootName)) Begin
87328>>>                    Function_Return False
87329>>>                End
87329>>>>
87329>>>
87329>>>                // ToDo: How do we handle this when the library has been imported into 
87329>>>                // the cDbUpdateVersion Class?
87329>>>                // Get YesNo_Box ("The table:\n" + (sDataPath + sPhysicalName) + "\nis to be renamed to:\n" + (sDataPath + sRootName) + "\nBut the destination already exists. Overwrite?") to iRetval
87329>>>                If (iRetval <> MBR_Yes) Begin
87331>>>                    Function_Return False
87332>>>                End                      
87332>>>>
87332>>>            End                                           
87332>>>>
87332>>>            Copy_db (sDataPath + sPhysicalName) to (sDataPath + sRootName) 
87335>>>        End
87335>>>>
87335>>>        
87335>>>        If (sDriverID <> DATAFLEX_ID) Begin
87337>>>            Move (sDriverID + ":" + sRootName) to sRootName
87338>>>        End
87338>>>>
87338>>>
87338>>>        Set_Attribute DF_FILE_ROOT_NAME     of hTable to sRootName
87341>>>        Set_Attribute DF_FILE_DISPLAY_NAME  of hTable to sDisplayName
87344>>>        Set_Attribute DF_FILE_LOGICAL_NAME  of hTable to sLogicalName
87347>>>        
87347>>>        // We need a short break here before attempting to delete the physical file or Windows
87347>>>        // might report "File in use..." and the deletion will fail.
87347>>>        Sleep 2
87348>>>        If (sDriverID = DATAFLEX_ID) Begin                    
87350>>>            Get vDeleteFile (sDataPath + sPhysicalName + ".*") to bOK
87351>>>        End
87351>>>>
