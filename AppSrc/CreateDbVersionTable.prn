88219>>>
88219>>>    // Changes source code files.
88219>>>    // Pass a file name with full path and a value to search for, together with the value
88219>>>    // to change to. Can e.g. be used for changing all .int files from using a fixed server name,
88219>>>    // to use a Connection ID. 
88219>>>    // Sample: Get UtilChangeSourceCodeLine "C:\DataFlex 18.2 Examples\Order Entry\Data\Order.int" "SERVER_NAME SERVER=(local)\SQLEXPRESS1" "SERVER_NAME DFCONNID=ChinookDb"
88219>>>    // Pass "True" for the bShowResult if you want to see the result while it works. Showln will then be used for output
88219>>>    // Returns True if no errors occured. 
88219>>>    Function UtilChangeSourceCodeLine String sFileName String sChangeFrom String sChangeTo Boolean bShowResult Returns Boolean
88221>>>        Integer iCh iRow iItems iCount
88221>>>        String sValue sRow
88221>>>        String[] sFileArray
88222>>>        Boolean bExists
88222>>>    
88222>>>        Move False to Err
88223>>>        Move 0 to iRow
88224>>>    
88224>>>        Get vFilePathExists sFileName to bExists
88225>>>        If (bExists = False) Begin
88227>>>            If (bShowResult = True) Begin
88229>>>                Showln "File does not exist: " sFileName
88232>>>            End
88232>>>>
88232>>>            Function_Return False
88233>>>        End
88233>>>>
88233>>>    
88233>>>        Get Seq_Open_Input_Channel sFileName to iCh
88234>>>        If (iCh < 1) Begin
88236>>>            Function_Return False
88237>>>        End
88237>>>>
88237>>>        
88237>>>        If (bShowResult = True) Begin  
88239>>>            Showln ""
88241>>>            Showln "sFileName = " sFileName
88244>>>            Showln "sChangeFrom = " sChangeFrom " sChangeTo = " sChangeTo
88249>>>        End
88249>>>>
88249>>>        
88249>>>        While (not(SeqEof))
88253>>>            Readln channel iCh sRow
88255>>>            If (Uppercase(sRow) contains Uppercase(sChangeFrom)) Begin 
88257>>>                If (bShowResult = True) Begin
88259>>>                    Showln "Changed from: " sRow " to: " sChangeTo
88264>>>                End
88264>>>>
88264>>>                // Change the whole line to the new connection id:
88264>>>                Move sChangeTo to sRow
88265>>>                // Move (Replaces(sChangeFrom, sRow, sChangeTo)) to sValue
88265>>>            End
88265>>>>
88265>>>            Move sRow to sFileArray[iRow]
88266>>>            Increment iRow
88267>>>        End
88268>>>>
88268>>>        Send Seq_Close_Channel iCh
88269>>>        
88269>>>        Sleep 1 // Wait for Windows to close the file
88270>>>    
88270>>>        Get Seq_Open_Output_Channel sFileName to iCh
88271>>>        If (iCh < 1) Begin
88273>>>            Function_Return False
88274>>>        End
88274>>>>
88274>>>        Move (SizeOfArray(sFileArray)) to iItems
88275>>>        Decrement iItems
88276>>>    
88276>>>        For iCount from 0 to iItems
88282>>>>
88282>>>            Move sFileArray[iCount] to sValue
88283>>>            Writeln channel iCh sValue
88286>>>        Loop
88287>>>>
88287>>>        Send Seq_Close_Channel iCh
88288>>>    
88288>>>        Function_Return (Err = False)
88289>>>    End_Function
88290>>>    
88290>>>    // This might be needed by API-methods when a connection id is to be used and
88290>>>    // the connection ID hasn't been established with the driver's CLI interface.
88290>>>    // NOTE: Only applicable for DAW drivers, as Mertech drivers doesn't use connection ID's.
88290>>>    Function UtilCreateConnectionID String sConnectionID Returns Boolean
88292>>>        String sConnectionString sDriverID
