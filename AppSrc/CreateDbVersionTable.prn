82730>>>>>>>>Function ParseKeyWord String sConnect String sKeyWord Returns String
82732>>>>>>>>    Integer iStart iEnd
82732>>>>>>>>    String sRetval
82732>>>>>>>>
82732>>>>>>>>    Move (Trim(sConnect)) to sConnect
82733>>>>>>>>    Move (Pos(Uppercase(sKeyWord), Uppercase(sConnect)))  to iStart
82734>>>>>>>>    If (iStart = 0) Begin
82736>>>>>>>>        Function_Return ""
82737>>>>>>>>    End
82737>>>>>>>>>
82737>>>>>>>>    Move (Left(sConnect, (iStart -1 + Length(sKeyWord)))) to sRetval
82738>>>>>>>>    Move (Replace(sRetval, sConnect, "")) to sRetval 
82739>>>>>>>>    If (sKeyWord = Uppercase(CS_SQLConnectionIDText)) Begin
82741>>>>>>>>        Move (Pos(",", sRetval))          to iEnd
82742>>>>>>>>    End
82742>>>>>>>>>
82742>>>>>>>>    Else Begin
82743>>>>>>>>        Move (Pos(";", sRetval))          to iEnd
82744>>>>>>>>    End                                          
82744>>>>>>>>>
82744>>>>>>>>    If (iEnd = 0 and (sRetval contains ",")) Begin
82746>>>>>>>>        Move (Pos(",", sRetval))          to iEnd 
82747>>>>>>>>        Decrement iEnd
82748>>>>>>>>    End
82748>>>>>>>>>
82748>>>>>>>>    If (iEnd <> 0) Begin
82750>>>>>>>>        Move (Left(sRetval, (iEnd -1)))   to sRetval
82751>>>>>>>>    End
82751>>>>>>>>>
82751>>>>>>>>    Move (Replace("=", sRetval, ""))      to sRetval
82752>>>>>>>>
82752>>>>>>>>    Function_Return (Trim(sRetval))
82753>>>>>>>>End_Function
