84203>>>    Function SqlColumnDefaultValue Handle hTable Integer iColumn String sValue Returns Boolean
84205>>>        Boolean bOK bErr bIsSQLDriver
84205>>>        String sDriverID
84205>>>        
84205>>>        Get psDriverID to sDriverID
84206>>>        Get IsSQLDriver sDriverID to bIsSQLDriver
84207>>>        If (bIsSQLDriver = False) Begin
84209>>>            Function_Return False
84210>>>        End
84210>>>>
84210>>>
84210>>>        Move Err to bErr
84211>>>        Move False to bErr                                      
84212>>>        
84212>>>        // There seems to be a problem with the ODBC_DRV driver that sometimes
84212>>>        // inserts randomly character(10) and spaces, so we correct from that here:
84212>>>        Move (Replaces(Character(10), Trim(sValue), "")) to sValue                   
84213>>>        
84213>>>        Set_Attribute DF_FIELD_DEFAULT_VALUE of hTable iColumn to sValue
84216>>>        Move (not(Err)) to bOK
84217>>>        Move bErr to Err
84218>>>        
84218>>>        Function_Return bOK
84219>>>    End_Function
84220>>>    
84220>>>    Function SqlColumnNullable Handle hTable Integer iColumn Boolean bNullable Returns Boolean
84222>>>        Boolean bOK bErr bCurrentState bOpen bIsSQLDriver
84222>>>        String sDriverID
84222>>>        
84222>>>        Get psDriverID to sDriverID
84223>>>        Get IsSQLDriver sDriverID to bIsSQLDriver
84224>>>        If (bIsSQLDriver = False) Begin
84226>>>            Function_Return False
84227>>>        End
84227>>>>
84227>>>        
84227>>>        Move Err to bErr
84228>>>        Move False to bErr
84229>>>        Get_Attribute DF_FIELD_NULL_ALLOWED of hTable iColumn to bCurrentState
84232>>>        If (bNullable = bCurrentState) Begin
84234>>>            Function_Return True
84235>>>        End                     
84235>>>>
84235>>>        
84235>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpen
84238>>>        If (bOpen = False) Begin                       
84240>>>            Get AutoConnectionIDLogin to bOK
84241>>>            Send Ignore_Error of Error_Object_Id DFERR_CANT_OPEN_DATA_FILE
84242>>>            Send Ignore_Error of Error_Object_Id DFERR_CANT_OPEN_INTERMEDIATE_FILE
84243>>>            Send Ignore_Error of Error_Object_Id CLIERR_GENERAL_ERROR
84244>>>            Open hTable
84246>>>            Send Trap_Error of Error_Object_Id DFERR_CANT_OPEN_DATA_FILE
84247>>>            Send Trap_Error of Error_Object_Id DFERR_CANT_OPEN_INTERMEDIATE_FILE
84248>>>            Send Trap_Error of Error_Object_Id CLIERR_GENERAL_ERROR
84249>>>            Get_Attribute DF_FILE_OPENED of hTable to bOpen
84252>>>        End
84252>>>>
84252>>>        If (bOpen = True) Begin
84254>>>            Structure_Start hTable sDriverID
84255>>>                Set_Attribute DF_FIELD_NULL_ALLOWED of hTable iColumn to bNullable
84258>>>            Structure_End hTable
84260>>>        End
84260>>>>
84260>>>
84260>>>        Move (not(Err)) to bOK
84261>>>        Move bErr to Err
84262>>>        
84262>>>        Function_Return bOK
84263>>>    End_Function
84264>>>    
84264>>>    // Drop column by its table handle 
84264>>>    Function SqlColumnRemove Handle hTable String sColumnName Returns Boolean
84266>>>        Integer iColumn idbType
84266>>>        String sDriverID sStmt sAlterTable sDropColumn sVal sTableName 
84266>>>        Boolean bExists bOK
84266>>>        
84266>>>        Get psDriverID to sDriverID
84267>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
84268>>>        If (bOK = False) Begin
84270>>>            Function_Return False
84271>>>        End
84271>>>>
84271>>>        
84271>>>        Get UtilTableHandleToString hTable to sTableName
84272>>>        If (sTableName = "") Begin
84274>>>            Function_Return False
84275>>>        End  
84275>>>>
84275>>>        
84275>>>        Get SqlColumnRemoveByTableName sTableName sColumnName to bOK
84276>>>            
84276>>>        Function_Return (bOK = True)    
84277>>>    End_Function    
84278>>>    
84278>>>    // Drop column by its table name as a string.
84278>>>    Function SqlColumnRemoveByTableName String sTableName String sColumnName Returns Boolean
84280>>>        Integer iColumn iDbType iDriver
84280>>>        String sDriverID sStmt sAlterTable sDropColumn sVal 
84280>>>        Boolean bExists bOK bRetval bDriverIgnoreErrorState
84280>>>        Handle hTable 
84280>>>        
84280>>>        Get psDriverID to sDriverID
84281>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
84282>>>        If (bOK = False) Begin
84284>>>            Function_Return False
84285>>>        End
84285>>>>
84285>>>
84285>>>        Get DriverIndex sDriverID to iDriver
84286>>>        Get_Attribute DF_DRIVER_IGNORE_WARNINGS of iDriver to bDriverIgnoreErrorState
84289>>>        Set_Attribute DF_DRIVER_IGNORE_WARNINGS of iDriver to True
84292>>>        
84292>>>        Get UtilTableNameToHandle sTableName to hTable
84293>>>        If (hTable <> 0) Begin
84295>>>            Get SQLUtilColumnExists sTableName sColumnName to bExists
84296>>>            If (bExists = False) Begin
84298>>>                Set_Attribute DF_DRIVER_IGNORE_WARNINGS of iDriver to bDriverIgnoreErrorState
84301>>>                Function_Return False
84302>>>            End
84302>>>>
84302>>>        End
84302>>>>
84302>>>
84302>>>        Get piDbType to iDbType
84303>>>        If (iDbType = EN_DbTypeMSSQL) Begin
84305>>>            Get _SqlUtilRemoveTableColumnMSSQL sTableName sColumnName to bOK
84306>>>            Get UtilDeleteCacheFile sTableName to bOK
84307>>>            Set_Attribute DF_DRIVER_IGNORE_WARNINGS of iDriver to bDriverIgnoreErrorState
84310>>>            Function_Return bOK
84311>>>        End
84311>>>>
84311>>>        
84311>>>        Move False to Err   
84312>>>        Get _SqlProperTableName sTableName    to sTableName
84313>>>        Get _SqlFindKeyWord CI_SQLAlterTable  to sAlterTable
84314>>>        Get _SqlFindKeyWord CI_SQLDropColumn  to sDropColumn   
84315>>>        
84315>>>        Move (sAlterTable * sTableName * sDropColumn * sColumnName) to sStmt
84316>>>        Send SqlUtilExecuteQuery sStmt sDriverID
84317>>>        Move (not(Err)) to bRetval
84318>>>    
84318>>>        // We also need to remove the cache-file since the table has been changed
84318>>>        Get UtilDeleteCacheFile sTableName to bOK
84319>>>        Set_Attribute DF_DRIVER_IGNORE_WARNINGS of iDriver to bDriverIgnoreErrorState
84322>>>    
84322>>>        Function_Return bRetval
84323>>>    End_Function    
84324>>>    
84324>>>    // Rename a field/column by table handle (filelist number)
84324>>>    Function SqlColumnRename Integer hTable String sColumnName String sNewColumnName Returns Boolean
84326>>>        Integer iColumn idbType
84326>>>        String sDriverID sTableName sStmt sAlterTable sRenameColumn sVal sColumnKeyWord
84326>>>        Boolean bExists bOK
84326>>>        
84326>>>        Get psDriverID to sDriverID
84327>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
84328>>>        If (bOK = False) Begin
84330>>>            Function_Return False
84331>>>        End
84331>>>>
84331>>>        
84331>>>        Get UtilTableHandleToString hTable to sTableName   
84332>>>        Get SqlColumnRenameByTableName sTableName sColumnName sNewColumnName to bOK
84333>>>
84333>>>        Function_Return (Err = False)    
84334>>>    End_Function    
84335>>>    
84335>>>    // Rename a field/column by table name.
84335>>>    Function SqlColumnRenameByTableName String sTableName String sColumnName String sNewColumnName Returns Boolean
84337>>>        Integer iColumn iDbType iDataType
84337>>>        String sDriverID sStmt sAlterTable sRenameColumn sVal sColumnKeyWord sOrgTableName sDatabase sDataType
84337>>>        Boolean bExists bOK bRetval                                        
84337>>>        Handle hTable
84337>>>        
84337>>>        Move sTableName to sOrgTableName
84338>>>        Get psDriverID to sDriverID
84339>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
84340>>>        If (bOK = False) Begin
84342>>>            Function_Return False
84343>>>        End
84343>>>>
84343>>>        
84343>>>        Get _SqlFindColumnName sTableName sColumnName to sVal
84344>>>        If (sVal = "") Begin
84346>>>            Function_Return False
84347>>>        End                          
84347>>>>
84347>>>        
84347>>>        Get piDbType to iDbType
84348>>>        Get _SqlFindKeyWord CI_SQLColumn       to sColumnKeyWord
84349>>>        Get _SqlProperTableName sTableName     to sTableName
84350>>>        Get _SqlFindKeyWord CI_SQLAlterTable   to sAlterTable
84351>>>        Get _SqlFindKeyWord CI_SQLRenameColumn to sRenameColumn
84352>>>        
84352>>>        Case Begin
84352>>>            Case (iDbType = EN_dbTypeMSSQL) 
84354>>>                Move (sRenameColumn * "'" + sTableName + "." + sColumnName + "'," * "'" + sNewColumnName + "'," * "'" + sColumnKeyWord + "'") to sStmt
84355>>>                Case Break
84356>>>            // Alter table "SYS"."Customer" rename column "Comments" to "NewColumnName"    
84356>>>            Case (iDbType = EN_dbTypeOracle) 
84359>>>                Move (sAlterTable * '"' + sTableName + '"' * sRenameColumn * '"' + sColumnName + '"' * "TO" * '"' + sNewColumnName + '"') to sStmt
84360>>>                Case Break  
84361>>>            // ALTER TABLE Schema.TableName RENAME COLUMN "deptnumb" TO "deptnum"
84361>>>            Case (iDbType = EN_dbTypeDB2)
84364>>>                Move (sAlterTable *  sTableName * sRenameColumn * '"' + sColumnName + '"' * "TO" * '"' + sNewColumnName + '"') to sStmt
84365>>>                Case Break
84366>>>            // ALTER TABLE "Customer" RENAME COLUMN "Comments" TO "NewColumnName"
84366>>>            Case (iDbType = EN_dbTypePostgre) 
84369>>>                Move sOrgTableName to sTableName
84370>>>                Move (sAlterTable * '"' + sTableName + '"' * sRenameColumn * '"' + sColumnName + '"' * "TO" * '"' + sNewColumnName + '"') to sStmt
84371>>>                Case Break  
84372>>>            Case (iDbType = EN_dbTypeMySQL)
84375>>>                // ALTER TABLE orderentry.customer CHANGE Comments NewColumnName text // Note: The last token is the column type!
84375>>>                Move sOrgTableName to sTableName
84376>>>                Get psDatabase to sDatabase 
84377>>>                Get UtilTableNameToHandle sTableName to hTable
84378>>>                If (hTable = 0) Begin
84380>>>                    Get UtilTableOpen hTable sTableName DF_SHARE to bOK
84381>>>                    If (bOK = False) Begin
84383>>>                        Function_Return False 
84384>>>                    End
84384>>>>
84384>>>                    Get NextFreeFilelistSlot to hTable
84385>>>                End
84385>>>>
84385>>>                Else Begin
84386>>>                    Open hTable
84388>>>                End          
84388>>>>
84388>>>                Get SQLColumnType sDriverID hTable sTableName sColumnName to iDataType
84389>>>                Get UtilColumnTypeToString sDriverID iDbType iDataType    to sDataType
84390>>>                Move (sAlterTable * sDatabase + "." + sTableName * sRenameColumn * sColumnName * sNewColumnName * sDataType) to sStmt
84391>>>                Case Break  
84392>>>            Case Else 
84392>>>                Move (sAlterTable * "'" + sTableName + "'" * sRenameColumn * "'" + sTableName + "." + sColumnName + "'" * "TO" * "'" + sNewColumnName + "'") to sStmt
84393>>>        Case End
84393>>>        
84393>>>        Move False to Err   
84394>>>        Send SqlUtilExecuteQuery sStmt sDriverID
84395>>>        Move (Err = False) to bRetval
84396>>>        // We also need to remove the cache-file since the table has been changed
84396>>>        Get UtilDeleteCacheFile sTableName to bOK
84397>>>    
84397>>>        Function_Return bRetval
84398>>>    End_Function    
84399>>>
84399>>>    Function SqlColumnType String sDriverID Handle hTable String sTableName String sColumnName Returns Integer
84401>>>        Handle hoSQLHandler hSQLConnect hStmt
84401>>>        Boolean bMertechDriver                                     
84401>>>        Integer iNumCols iCount iSQLType iDataType
84401>>>        String sValue 
84401>>>        
84401>>>        Get IsMertechDriver sDriverID to bMertechDriver
84402>>>        If (bMertechDriver = False) Begin
84404>>>            Get phoSQLManager to hoSQLHandler
84405>>>        End                                  
84405>>>>
84405>>>        Else Begin
84406>>>            Get _MertechSQLManagerHandle to hoSQLHandler
84407>>>        End                                    
84407>>>>
84407>>>        
84407>>>        Get SQLFileConnect of hoSQLHandler hTable to hSQLConnect
84408>>>        If (hSQLConnect <> 0) Begin
84410>>>            Get SQLOpen of hSQLConnect to hStmt
84411>>>            If (hStmt <> 0) Begin
84413>>>                Send SQLExecDirect of hStmt ("select * from" * sTableName)
84414>>>        
84414>>>                Get SQLStmtAttribute of hStmt SQLSTMTATTRIB_COLUMNCOUNT to iNumCols
84415>>>                For iCount from 1 to iNumCols
84421>>>>
84421>>>                    Get SQLColAttribute of hStmt iCount SQLCOLATTRIB_LABEL to sValue
84422>>>                    If (Lowercase(sValue) = Lowercase(sColumnName)) Begin
84424>>>                        Get SQLColAttribute of hStmt iCount SQLCOLATTRIB_SQLTYPE to iDataType
84425>>>                        Move iNumCols to iCount // We're out of here
84426>>>                    End
84426>>>>
84426>>>                Loop                                                
84427>>>>
84427>>>                
84427>>>                Send SQLClose of hStmt
84428>>>            End
84428>>>>
84428>>>            Send SQLDisconnect of hSQLConnect    
84429>>>        End
84429>>>>
84429>>>        
84429>>>        Function_Return iDataType
84430>>>    End_Function
84431>>>        
84431>>>    
84431>>>    // *** SQL Utility Messages ***
84431>>>    // They are not geared at making database changes.
84431>>>    //
84431>>>
84431>>>    // Will create an SQL table with the passed sTableName & sColumnName as Numeric 4.2 to keep
84431>>>    // the DbUpdateVersion database revision in.  
84431>>>    // Also pass the file number of the current (embedded?) table number used in development.
84431>>>    // It will first create the SQL Table & column, then create the .int file and change Filelist.cfg
84431>>>    Function SQLCreateDbVersionTable Handle hTable String sColumnName String sDriverID Returns Boolean
84433>>>        Boolean bOK bOpened
84433>>>        String sTableName sDataType sAlterTable sAddColumn sLengthAndDecimals sStmt sDropColumn
84433>>>        
84433>>>        Get_Attribute DF_FILE_ROOT_NAME of hTable to sTableName
84436>>>        Get _TableNameOnly sTableName to sTableName   
84437>>>        If (sTableName = "") Begin
84439>>>            Function_Return False
84440>>>        End 
84440>>>>
84440>>>        
84440>>>        // This just creates the table and a "dummy" column.
84440>>>        Get SqlTableCreate hTable sDriverID to bOK
84441>>>        If (bOK = False) Begin
84443>>>            Function_Return False 
84444>>>        End                      
84444>>>>
84444>>>        
84444>>>        Close hTable
84445>>>        Move False to Err
84446>>>        
84446>>>        Get _SqlFindKeyWord CI_SQLAlterTable to sAlterTable
84447>>>        Get _SqlFindKeyWord CI_SQLAdd        to sAddColumn
84448>>>        Move "Decimal" to sDataType
84449>>>        Get _SqlFormatLengthAndDecimalAsString 4 2 to sLengthAndDecimals
84450>>>        
84450>>>        // Adds the "sColumnName" passed to the function
84450>>>        Move (sAlterTable * sTableName * sAddColumn * sColumnName * sDataType + sLengthAndDecimals) to sStmt 
84451>>>        Send SqlUtilExecuteQuery sStmt sDriverID
84452>>>        
84452>>>        // Now we can delete the dummy column:
84452>>>        Get SqlColumnRemoveByTableName sTableName "Dummy" to bOK
84453>>>        
84453>>>        // Finally, we attach to the newly created table.
84453>>>        If (Err = False) Begin    
84455>>>            Get ApiTableAttachToSQL hTable True to bOK
84456>>>        End
84456>>>>
84456>>>        Open hTable                                                  
84458>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpened
84461>>>        
84461>>>        Function_Return (Err = False and bOK = True and bOpened = True)
84462>>>    End_Function
84463>>>    
84463>>>    // Checks if a column/field name exists in a SQL table definition
84463>>>    // Returns True if it does
84463>>>    // Sample:
84463>>>    //   Get SQLUtilColumnExists "MySQLTable" "MyColumnName" to bExists
84463>>>    Function SQLUtilColumnExists String sTableName String sFieldName Returns Boolean
84465>>>        Integer iNumColumns iColumn
84465>>>        String sColumn sDriverID
84465>>>        String[] sColumnsArray
84466>>>        Boolean bExists bOK
84466>>>    
84466>>>        Move False to bExists  
84467>>>        Get AutoConnectionIDLogin to bOK
84468>>>        Get psDriverID to sDriverID
84469>>>        
84469>>>        Get SqlUtilEnumerateColumns sDriverID sTableName to sColumnsArray
84470>>>        Move (SizeOfArray(sColumnsArray)) to iNumColumns
84471>>>        Decrement iNumColumns
84472>>>        For iColumn from 0 to iNumColumns
84478>>>>
84478>>>            Move sColumnsArray[iColumn] to sColumn
84479>>>            If (Uppercase(sFieldName) = Uppercase(sColumn)) Begin
84481>>>                Move True to bExists
84482>>>                Move iNumColumns to iColumn // We're out of here
84483>>>            End
84483>>>>
84483>>>        Loop
84484>>>>
84484>>>    
84484>>>        Function_Return bExists
84485>>>    End_Function
84486>>>    
84486>>>    Function SQLUtilConvertColumnTypesToSQL2008 Handle hTable Returns Boolean
84488>>>        Integer iNumColumns iColumn iDFType iNativeType
84488>>>        Boolean bOpened bOK
84488>>>        String sColumnName sNativeTypeName
84488>>>        
84488>>>        Get AutoConnectionIDLogin to bOK
84489>>>        Open hTable Mode DF_EXCLUSIVE
84491>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpened
84494>>>        If (bOpened = False) Begin
84496>>>            Error DFERR_PROGRAM ("Function SQLUtilConvertColumnTypesToSQL2008; Could not open table" * String(hTable))
84497>>>>
84497>>>            Function_Return False 
84498>>>        End
84498>>>>
84498>>>        
84498>>>        Move False to Err                               
84499>>>        
84499>>>        Structure_Start hTable
84500>>>            Get_Attribute DF_FILE_NUMBER_FIELDS of hTable to iNumColumns
84503>>>        
84503>>>            For iColumn from 1 to iNumColumns
84509>>>>
84509>>>                Get_Attribute DF_FIELD_TYPE             of hTable iColumn to iDfType
84512>>>                Get_Attribute DF_FIELD_NAME             of hTable iColumn to sColumnName
84515>>>                Get_Attribute DF_FIELD_NATIVE_TYPE      of hTable iColumn to iNativeType
84518>>>                Get_Attribute DF_FIELD_NATIVE_TYPE_Name of hTable iColumn to sNativeTypeName
84521>>>                
84521>>>                Case Begin
84521>>>                    Case (iDFType = DF_DATE) 
84523>>>                        If (iNativeType = SQL_TYPE_TIMESTAMP) Begin
84525>>>                            // Convert datetime to date
84525>>>                            Set_Attribute DF_FIELD_NATIVE_TYPE of hTable iColumn to SQL_TYPE_DATE
84528>>>                        End
84528>>>>
84528>>>                        Case Break
84529>>>                    Case (iDFType = DF_DATETIME) 
84532>>>                        If (iNativeType = SQL_TYPE_TIMESTAMP) Begin
84534>>>                            // Convert datetime to datetime2
84534>>>                            Set_Attribute DF_FIELD_NATIVE_TYPE of hTable iColumn to SQL_TYPE_TIMESTAMP2
84537>>>                        End
84537>>>>
84537>>>                        Case Break
84538>>>                    Case (iDFType = DF_ASCII) 
84541>>>                        If (iNativeType = SQL_CHAR) Begin
84543>>>                            // Convert char to varchar
84543>>>                            Set_Attribute DF_FIELD_NATIVE_TYPE of hTable iColumn to SQL_VARCHAR
84546>>>                        End
84546>>>>
84546>>>                        Case Break
84547>>>                    Case (iDFType = DF_TEXT) 
84550>>>                        If (iNativeType = SQL_LONGVARCHAR) Begin 
84552>>>                            // Convert text to varchar(max)
84552>>>                            Set_Attribute DF_FIELD_NATIVE_TYPE of hTable iColumn to SQL_VARCHAR
84555>>>                        End
84555>>>>
84555>>>                        Case Break
84556>>>                    Case (iDFType = DF_BINARY) 
84559>>>                        If (iNativeType = SQL_LONGVARBINARY) Begin
84561>>>                            // Convert image to varbinary(max)
84561>>>                            Set_Attribute DF_FIELD_NATIVE_TYPE of hTable iColumn to SQL_VARBINARY
84564>>>                        End
84564>>>>
84564>>>                        Case Break
84565>>>                Case End
84565>>>            Loop
84566>>>>
84566>>>        Structure_End hTable
84568>>>    
84568>>>        Function_Return (Err = False)    
84569>>>    End_Function  
84570>>>    
84570>>>    // Does three things with auxilirary files;
84570>>>    // 1) Deletes the cache file in the first Data folder of the psDataPath property as the table at the SQL end has been changed.
84570>>>    // 2) Adds the sColumnName to the TableName.tag file in the first Data folder of the psDataPath property
84570>>>    // 3) Creates a new TableName.fd file if the DdSrc folder is available (if this is a development environment)
84570>>>    Function SqlUtilAdjustAuxFiles Handle hTable String sTableName String sColumnName Returns Boolean
84572>>>        String sDataPath sDDSrcPath sVal sDriverID
84572>>>        Boolean bOK bExists bMertechDriver
84572>>>        Integer iCount iItems iCh iPos
84572>>>        
84572>>>        // If table name equals e.g. "dbo.MyTable" we need to remove the prefix.
84572>>>        If (sTableName contains ".") Begin
84574>>>            Move (Pos(".", sTableName)) to iPos
84575>>>            Move (Mid(sTableName, 999, (iPos +1))) to sTableName    
84576>>>        End                                                     
84576>>>>
84576>>>        
84576>>>        Get psDriverID to sDriverID
84577>>>        Get psDataPathFirstPart to sDataPath 
84578>>>        Get vFolderExists sDataPath to bOK
84579>>>        If (bOK = False) Begin
84581>>>            Error DFERR_PROGRAM "Function SqlUtilAdjustAuxFiles; psDataPath not found!"
84582>>>>
84582>>>            Function_Return False    
84583>>>        End                      
84583>>>>
84583>>>        
84583>>>        Get IsMertechDriver sDriverID to bMertechDriver
84584>>>        // First delete the cache file:
84584>>>        Get UtilDeleteCacheFile sTableName to bOK
84585>>>            
84585>>>        Get Seq_New_Channel to iCh  
84586>>>        If (iCh = DF_SEQ_CHANNEL_NOT_AVAILABLE) Begin
84588>>>            Function_Return False
84589>>>        End                      
84589>>>>
84589>>>        
84589>>>        Get vFilePathExists (sDataPath + sTableName + ".tag") to bExists
84590>>>        If (bExists = False) Begin
84592>>>            Function_Return False
84593>>>        End                      
84593>>>>
84593>>>        
84593>>>        // Add the new column name to the .tag file: 
84593>>>        Append_Output channel iCh (sDataPath + sTableName + ".tag")
84595>>>            Writeln channel iCh sColumnName
84598>>>        Close_Output
84599>>>        
84599>>>        // If in development environment; output new .fd file:
84599>>>        Get psDdSrcPath of (phoWorkspace(ghoApplication)) to sDDSrcPath
84600>>>        Get CountOfPaths of (phoWorkspace(ghoApplication)) sDDSrcPath to iCount
84601>>>        If (iCount > 1) Begin
84603>>>            Get PathAtIndex of (phoWorkspace(ghoApplication)) sDDSrcPath 1 to sDDSrcPath    
84604>>>        End 
84604>>>>
84604>>>        Get vFolderExists sDDSrcPath to bExists
84605>>>        If (bExists = True) Begin                                   
84607>>>            Get vFolderFormat sDDSrcPath to sDDSrcPath  
84608>>>            Move False to Err 
84609>>>            Get AutoConnectionIDLogin to bOK
84610>>>            If (hTable <> 0) Begin
84612>>>                Open hTable
84614>>>            End 
84614>>>>
84614>>>            Else Begin
84615>>>                Get UtilTableOpen hTable sTableName DF_SHARE to bOK
84616>>>            End
84616>>>>
84616>>>                
84616>>>            Get_Attribute DF_FILE_OPENED of hTable to bOK
84619>>>            If (bOK = True) Begin
84621>>>                Output_Aux_File DF_AUX_FILE_FD for hTable to (sDDSrcPath + sTableName + ".fd")
84623>>>            End
84623>>>>
84623>>>            If (Err = True) Begin
84625>>>                Move False to bOK
84626>>>            End
84626>>>>
84626>>>        End
84626>>>>
84626>>>        
84626>>>        Function_Return (bOK = True)
84627>>>    End_Function  
84628>>>    
84628>>>    // The table must already exist in the filelist for this function to work.
84628>>>    // It creates a rudimentary .int file in the first Data folder of the psDataPath property.
84628>>>    Function SqlUtilCreateIntFile Handle hTable String sDriverID String sConnectionID Boolean bAnsi Boolean bSysFile Returns Boolean
84630>>>        Boolean bOK bExists bUseConnectionID bMertech
84630>>>        String sDataPath sRootName sPhysicalFileName sConnectionString sDatabaseName sSchemaName sANSI_OEM
84630>>>        String[] sIndexArray
84631>>>        Integer iCount iCh iSize
84631>>>        
84631>>>        Move (Trim(sConnectionID) <> "") to bUseConnectionID
84632>>>        Get psConnectionString to sConnectionString
84633>>>
84633>>>        Move CS_ANSI_Txt to sANSI_OEM
84634>>>        If (bANSI = False) Begin
84636>>>            Move CS_OEM_Txt to sANSI_OEM
84637>>>        End
84637>>>>
84637>>>        
84637>>>        Get psDataPathFirstPart to sDataPath
84638>>>        Get vFolderExists sDataPath to bOK
84639>>>        If (bOK = False) Begin
84641>>>            Error DFERR_PROGRAM "Function SqlUtilCreateIntFile; psDataPath not found!"
84642>>>>
84642>>>            Function_Return False    
84643>>>        End                      
84643>>>>
84643>>>        Get vFolderFormat sDataPath to sDataPath 
84644>>>
84644>>>        Get_Attribute DF_FILE_ROOT_NAME of hTable to sRootName
84647>>>        Get _TableNameOnly sRootName to sDatabaseName
84648>>>        Move sDatabaseName to sPhysicalFileName
84649>>>        Move (sPhysicalFileName + ".int") to sPhysicalFileName
84650>>>
84650>>>        Get IsMertechDriver sDriverID to bMertech
84651>>>        If (bMertech = True) Begin       
84653>>>            // This should not be called here. Instead it is called by the SqlUtilUpdateIntFile!
84653>>>            // Else it will create an error in the error log (although it won't do anything...)
84653>>>            // Get _MertechSqlUtilCreateIntFile hTable sDataPath sPhysicalFileName to bOK
84653>>>            Function_Return (bOK = True)
84654>>>        End
84654>>>>
84654>>>        
84654>>>        Get psSchema hTable to sSchemaName
84655>>>        If (sSchemaName = "") Begin   
84657>>>            Get _SqlFindKeyWord CI_SQLDBO to sSchemaName
84658>>>        End
84658>>>>
84658>>>
84658>>>        // If the .int file already exists; we rename it to "FileName" + ".bak"
84658>>>        Get vFilePathExists (sDataPath + sPhysicalFileName) to bExists
84659>>>        If (bExists = True) Begin            
84661>>>            Get vRenameFile (sDataPath + sPhysicalFileName) (sDataPath + sPhysicalFileName + ".bak") to bOK 
84662>>>        End
84662>>>>
84662>>>        
84662>>>        Get UtilDeleteCacheFile sRootName to bOK
84663>>>        Get SqlUtilEnumerateIndexes sRootName sDriverID to sIndexArray
84664>>>        
84664>>>        Get Seq_Open_Output_Channel (sDataPath + sPhysicalFileName) to iCh
84665>>>            Writeln channel iCh CS_DRIVER_NAME     " " sDriverID 
84670>>>            If (bUseConnectionID = True) Begin
84672>>>                Writeln channel iCh CS_SERVER_NAME " " CS_DFCONNID "=" sConnectionID
84679>>>            End 
84679>>>>
84679>>>            Else Begin
84680>>>                Writeln channel iCh CS_SERVER_NAME " " CS_SERVER "=" sConnectionString
84687>>>            End                                                      
84687>>>>
84687>>>            Writeln channel iCh CS_DATABASE_NAME          " " sDatabaseName
84692>>>            Writeln channel iCh CS_SCHEMA_NAME            " " (Lowercase(sSchemaName))
84697>>>            // There seems to be a new order how these are set from DF19.
84697>>>            If (bSysFile = True) Begin
84699>>>                Writeln channel iCh CS_RECNUM_TABLE       " " "NO"
84704>>>            End 
84704>>>>
84704>>>            Writeln channel iCh CS_TABLE_CHARACTER_FORMAT " " sANSI_OEM
84709>>>            Writeln channel iCh CS_USE_DUMMY_ZERO_DATE    " " "YES" // ToDo: We maybe need to paramerize this setting?  
84714>>>            If (bSysFile = True) Begin
84716>>>                Writeln channel iCh CS_SYSTEM_FILE        " " "YES" 
84721>>>            End  
84721>>>>
84721>>>            
84721>>>            If (bSysFile = False) Begin
84723>>>                Move (SizeOfArray(sIndexArray)) to iSize  
84724>>>                Move (SortArray(sIndexArray)) to sIndexArray
84725>>>                If (iSize > 0) Begin
84727>>>                    Writeln channel iCh (CS_PRIMARY_INDEX * String("0"))
84730>>>                    Writeln channel iCh // Just an empty line
84732>>>                End
84732>>>>
84732>>>                Decrement iSize                              
84733>>>                For iCount from 0 to iSize
84739>>>>
84739>>>                    Writeln channel iCh (CS_INDEX_NUMBER * String(iCount))
84742>>>                    Writeln channel iCh (CS_INDEX_NAME   * String(sIndexArray[iCount]))
84745>>>                    Writeln channel iCh
84747>>>                Loop
84748>>>>
84748>>>            End
84748>>>>
84748>>>        Send Seq_Close_Channel iCh 
84749>>>        
84749>>>        // Wait a sec for Windows to finish writing the file:
84749>>>        Sleep 1
84750>>>        
84750>>>        Function_Return (bOK = True)
84751>>>    End_Function
84752>>>    
84752>>>    // Message for changing .int files to use connection ID's
84752>>>    //
84752>>>    // Changes all ".int" files for the passed sDataPath to use a sConnectionID,
84752>>>    // OR changes an existing connection id to a new id.
84752>>>    // Pass the full path to the data folder and the name of the connection id (string value). 
84752>>>    // Pass a True for the bShowResult parameter to show work in progress (showln's).
84752>>>    Procedure SqlUtilChangeIntFilesToConnectionIDs String sDataPath String sConnectionID Boolean bShowResult
84754>>>        String sFileName sDriverID sDriverFile sConnectionString
84754>>>        String[] sFilesData
84755>>>        Boolean bExists bOK                               
84755>>>        Integer iSize iCount
84755>>>        
84755>>>        Get SqlUtilEnumerateIntFiles sDataPath to sFilesData
84756>>>        Move (SizeOfArray(sFilesData))    to iSize
84757>>>        If (iSize = 0) Begin
84759>>>            Send Info_Box "No .int files found! Nothing was changed."
84760>>>            Procedure_Return
84761>>>        End                                                          
84761>>>>
84761>>>        
84761>>>        Move (Trim(sConnectionID)) to sConnectionID
84762>>>        Get vFolderFormat sDataPath to sDataPath
84763>>>        Decrement iSize
84764>>>        For iCount from 0 to iSize
84770>>>>
84770>>>            Move sFilesData[iCount] to sFileName                                   
84771>>>            // This makes sure that we also can change an existing connection id to something new:
84771>>>            Get UtilChangeSourceCodeLine (sDataPath + sFileName) CS_SERVER_NAME (CS_SERVER_NAME * CS_DFCONNID + "=" + sConnectionID) bShowResult to bOK 
84772>>>        Loop                      
84773>>>>
84773>>>        
84773>>>        Get psDriverID to sDriverID
84774>>>        
84774>>>         // Finally also change the driver file e.g. MSSQLDRV.int file in the Data folder in case it has a "DFconnectionID xxxxID,SERVER..."
84774>>>        Move "" to sFileName
84775>>>        If (sDriverID = MSSQLDRV_ID) Begin
84777>>>            Move "MSSQLDrv.int" to sFileName
84778>>>        End                 
84778>>>>
84778>>>        If (sDriverID = DB2_DRV_ID) Begin
84780>>>            Move "DB2_Drv.int" to sFileName
84781>>>        End                                
84781>>>>
84781>>>        If (sDriverID = ODBC_DRV_ID) Begin
84783>>>            Move "ODBC_Drv.int" to sFileName
84784>>>        End                                 
84784>>>>
84784>>>        If (sFileName <> "") Begin     
84786>>>            Move "" to sDriverFile
84787>>>            Get_File_Path sFileName to sDriverFile
84788>>>            If (sDriverFile <> "") Begin                        
84790>>>                Get psConnectionString to sConnectionString
84791>>>                Get UtilChangeSourceCodeLine sDriverFile CS_SQLConnectionIDText (CS_SQLConnectionIDText * String(sConnectionID) + "," * String(sConnectionString) * String(",0")) bShowResult to bOK
84792>>>            End
84792>>>>
84792>>>        End
84792>>>>
84792>>>    End_Procedure
