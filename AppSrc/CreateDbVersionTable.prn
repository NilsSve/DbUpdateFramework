87711>>>    // To delete an index
87711>>>    Function ApiIndexRemove Handle hTable Integer iIndex Returns Boolean
87713>>>        Integer iTableNo iNumSegments
87713>>>        String sDriverID
87713>>>        Boolean bOK
87713>>>        
87713>>>        Get AutoConnectionIDLogin to bOK
87714>>>        Move False to Err
87715>>>        Move hTable to iTableNo
87716>>>        Open hTable Mode DF_EXCLUSIVE
87718>>>        Get_Attribute DF_FILE_DRIVER of hTable to sDriverID
87721>>>        
87721>>>        // Check to see if the index exists or not...
87721>>>        Get_Attribute DF_INDEX_NUMBER_SEGMENTS of hTable iIndex to iNumSegments
87724>>>        If (iNumSegments = 0) Begin
87726>>>            Function_Return False
87727>>>        End
87727>>>>
87727>>>        
87727>>>        Structure_Start hTable sDriverID
87728>>>            Send Ignore_Error of Error_Object_Id DFERR_BAD_PARAMETER
87729>>>            Delete_Index iTableNo iIndex
87730>>>            Send Trap_Error of Error_Object_Id DFERR_BAD_PARAMETER
87731>>>        Structure_End hTable DF_STRUCTEND_OPT_NONE
87733>>>
87733>>>        Function_Return (Err = False)
87734>>>    End_Function
