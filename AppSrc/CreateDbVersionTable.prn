90701>>>
90701>>>    Function AddProgramToStudioToolsMenu String sStudioVersion Returns Integer
90704>>>        Boolean bOk bExists bOpen
90704>>>        String sKey sValue sProgramPath sProgram sProduct sStudioPath
90704>>>        Handle hoReg hoArray
90704>>>        Integer i iItems iCreated iRetval
90704>>>
90704>>>        Move False to bOk
90705>>>        Move (CS_StudioPath + (Trim(sStudioVersion)))  to sStudioPath
90706>>>        If (sStudioVersion > "17.1") Begin
90708>>>            Move (Replace("Visual ", sStudioPath, "")) to sStudioPath
90709>>>        End
90709>>>>
90709>>>
90709>>>        Get psProgramPath of (phoWorkspace(ghoApplication)) to sProgramPath
90710>>>        Get PathAtIndex of (phoWorkspace(ghoApplication)) sProgramPath 1 to sProgramPath
90711>>>        Get vFolderFormat sProgramPath to sProgramPath
90712>>>        Get psProduct     of (phoWorkspace(ghoApplication)) to sProduct
90713>>>        Get Module_Name to sProgram
90714>>>        Get Create U_cRegistry to hoReg
90715>>>        Set phRootKey of hoReg to HKEY_CURRENT_USER
90716>>>
90716>>>        // First check if the DataFlex version is installed
90716>>>        Get KeyExists of hoReg sStudioPath to bExists
90717>>>        If (bExists = False) Begin
90719>>>            Send Destroy of hoReg
90720>>>            Function_Return cx_RegKeyVDFKeyDoesNotExist
90721>>>        End
90721>>>>
90721>>>
90721>>>        // Then check if any tools have been installed in the Tools Menu.
90721>>>        // If no tools created yet, create the Tools registry key.
90721>>>        Move (sStudioPath + CS_StudioTools) to sStudioPath
90722>>>        Get KeyExists of hoReg sStudioPath to bExists
90723>>>        If (bExists = False) Begin
90725>>>            Set pfAccessRights of hoReg to KEY_ALL_ACCESS
90726>>>            Get CreateKey of hoReg sStudioPath to iCreated
90727>>>            If (iCreated <> 0) Begin
90729>>>                Move cx_RegkeyFailed to iRetval
90730>>>            End
90730>>>>
90730>>>            Else Begin
90731>>>                Move True to bExists
90732>>>            End
90732>>>>
90732>>>        End
90732>>>>
90732>>>
90732>>>        If (bExists = True) Begin
90734>>>            Get OpenKey of hoReg sStudioPath to bOk
90735>>>            If (bOk = True) Begin
90737>>>                Get Create U_Array to hoArray
90738>>>                Get GetSubkeys of hoReg hoArray to iItems
90739>>>                Decrement iItems
90740>>>                Move False to bExists
90741>>>                Set pfAccessRights of hoReg to KEY_READ
90742>>>                // Check if the key already exists:
90742>>>                For i from 0 to iItems
90748>>>>
90748>>>                    Get Value of hoArray item i to sKey
90749>>>                    Move (sStudioPath + "\" + sKey) to sKey
90750>>>                    Get OpenKey of hoReg sKey to bOpen
90751>>>                    If (bOpen = True) Begin
90753>>>                        Get ReadString of hoReg CS_Name to sValue
90754>>>                        If (sValue = sProduct) Move True to bExists
90757>>>                    End
90757>>>>
90757>>>                Loop
90758>>>>
90758>>>                Send Destroy of hoArray
90759>>>                If (bExists = False) Begin
90761>>>                    Set pfAccessRights of hoReg to KEY_ALL_ACCESS
90762>>>                    // We need to create the next key number:
90762>>>                    // The studio expect tools menu items to be numbered 1,2,3...n
90762>>>                    Increment iItems
90763>>>                    Increment iItems
90764>>>                    Get CreateKey of hoReg (sStudioPath + "\" + String(iItems)) to iCreated
90765>>>                    If (iCreated = 0) Begin
90767>>>                        Send WriteString of hoReg CS_Name sProduct
90768>>>                        // From DataFlex 16 and up the params for the Studio's Tools menu changed slightly:
90768>>>                        If (sStudioVersion >= "16.0") Begin
90770>>>                            Send WriteString of hoReg CS_Command (sProgramPath + sProgram)
90771>>>                            Send WriteString of hoReg CS_CommandLine (psTag(Self))
90772>>>                        End
90772>>>>
90772>>>                        Else Begin
90773>>>                            Send WriteString of hoReg CS_CommandLine ('"' + sProgramPath + sProgram + ".exe" + '"' * psTag(Self))
90774>>>                            Move CX_InstalledOkVdfUnder16 to iRetval
90775>>>                        End
90775>>>>
90775>>>                        Send WriteDword  of hoReg CS_Separator 1
90776>>>                        Move cx_RegKeyCreated to iRetval
90777>>>                    End
90777>>>>
90777>>>                    Else Begin
90778>>>                        Move cx_RegkeyFailed to iRetval
90779>>>                    End
90779>>>>
90779>>>                End
90779>>>>
90779>>>                Else Begin
90780>>>                    Move cx_RegKeyAlreadyExist to iRetval
90781>>>                End
90781>>>>
90781>>>                Send CloseKey of hoReg
90782>>>            End
90782>>>>
90782>>>        End
90782>>>>
90782>>>
90782>>>        Send Destroy of hoReg
90783>>>        Function_Return iRetval
90784>>>    End_Function
