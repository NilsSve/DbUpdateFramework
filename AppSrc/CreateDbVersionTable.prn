89938>>>            
89938>>>    // *** Error Handler ***
89938>>>    //
89938>>>    // Note: If the cDbUpdateHandler & cDbUpdateVersion classes are used this error handler is _not_
89938>>>    //       used. Instead the Error_Report in the cDbUpdateHandler i used.
89938>>>    Procedure Error_Report Integer iErrorNumber Integer iErrorLine String sErrorText
89940>>>        String sText
89940>>>        Integer iSize iErrorMode
89940>>>        tSqlErrorArray aSqlErrorArray
89940>>>        tSqlErrorArray aSqlErrorArray
89940>>>        
89940>>>        If (pbProcessingError(Self)) Begin
89942>>>            Procedure_Return
89943>>>        End 
89943>>>>
89943>>>        
89943>>>        Get Error_Report_Mode to iErrorMode
89944>>>        If (iErrorMode = DUF_ERROR_NO_REPORT) Begin
89946>>>            Procedure_Return
89947>>>        End
89947>>>>
89947>>>
89947>>>        Set pbProcessingError to True
89948>>>        Set pbSqlError to True
89949>>>        Get paSqlErrorArray      to aSqlErrorArray
89950>>>        Move (SizeOfArray(aSqlErrorArray.sSqlErrorArray)) to iSize
89951>>>        Move sErrorText          to aSqlErrorArray.sSqlErrorArray[iSize]
89952>>>        Get psSQLStatementString to aSqlErrorArray.sSqlStatementArray[iSize]
89953>>>        Move iErrorNumber        to aSqlErrorArray.iSqlErrorArray[iSize]
89954>>>        Set paSqlErrorArray      to aSqlErrorArray
89955>>>        Set pbProcessingError to False
89956>>>    End_Procedure
89957>>>
89957>>>    // *** Miscellanous Helper Functions ***
89957>>>    //
89957>>>    // Helper function. Takes a DF_FILE_XXXX_NAME value as parameter and 
89957>>>    // returns the table name only; stripped of any path or filename extension.
89957>>>    Function _TableNameOnly String sName Returns String
89959>>>        String sPath sExt
89959>>>        
89959>>>        Get ParseFolderName sName to sPath
89960>>>        If (sPath <> "") Begin
89962>>>            Move (Replace(sPath, sName, "")) to sName
89963>>>        End                                                  
89963>>>>
89963>>>        Get ParseFileExtension sName to sExt
89964>>>        If (sExt <> "") Begin
89966>>>            Move (Replace(("." + sExt), sName, "")) to sName
89967>>>        End
89967>>>>
89967>>>        
89967>>>        Function_Return sName
89968>>>    End_Function
