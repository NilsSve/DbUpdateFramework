83554>>>>>    Function DriverIndex String sDriverID Returns Integer
83556>>>>>        String  sCurrentDriver
83556>>>>>        Integer iNumberOfDrivers iDriver iCount iRetval
83556>>>>>        
83556>>>>>        Move 0 to iDriver
83557>>>>>        Get_Attribute DF_NUMBER_DRIVERS to iNumberOfDrivers
83560>>>>>        For iCount from 1 to iNumberOfDrivers
83566>>>>>>
83566>>>>>            Get_Attribute DF_DRIVER_NAME of iCount to sCurrentDriver
83569>>>>>            If ( Uppercase(sCurrentDriver) = Uppercase(sDriverID) ) Begin
83571>>>>>                Function_Return iCount
83572>>>>>            End
83572>>>>>>
83572>>>>>        Loop
83573>>>>>>
83573>>>>>        
83573>>>>>        // If driver not previously loaded; attempt to do so now.
83573>>>>>        If (iDriver = 0) Begin
83575>>>>>            Move 0 to LastErr
83576>>>>>            Load_Driver sDriverID   
83577>>>>>            // If driver could not be loaded.
83577>>>>>            If (LastErr = 4255) Begin
83579>>>>>                Move 0 to iCount
83580>>>>>            End
83580>>>>>>
83580>>>>>            Function_Return iCount
83581>>>>>        End
83581>>>>>>
83581>>>>>        Function_Return 0
83582>>>>>    End_Function
83583>>>>>        
83583>>>>>    // This will update connection settings of the cCLIHandler object with that passed struct values.
83583>>>>>    Procedure UpdateConnectionString tSQLConnection SQLConnection
83585>>>>>        String sRetval sDriverID sConnectionID sConnectionString sServer sDatabase sUserID sPassword
83585>>>>>        Boolean bTrusted bSilent  
83585>>>>>        Integer iConnOptions
83585>>>>>        
83585>>>>>        Move SQLConnection.sDriverID     to sDriverID
83586>>>>>        Move SQLConnection.sConnectionID to sConnectionID
83587>>>>>        Move SQLConnection.sServer       to sServer
83588>>>>>        Move SQLConnection.sDatabase     to sDatabase
83589>>>>>        Move SQLConnection.bTrusted      to bTrusted
83590>>>>>        Move SQLConnection.sUserID       to sUserID
83591>>>>>        Move SQLConnection.sPassword     to sPassword  
83592>>>>>        Move SQLConnection.bSilentLogin  to bSilent
83593>>>>>        
83593>>>>>        // Note that this message will first delete the current ConnectionID if it exists; which is needed by the cCLIHandler logic.
83593>>>>>        Send CreateSQLConnection sDriverID sConnectionID sServer sDatabase bTrusted sUserID sPassword bSilent
83594>>>>>        
83594>>>>>    End_Procedure
83595>>>>>
83595>>>>>    // Called when the object is constructed.
83595>>>>>    // It will check the psDriverID for a ConnectionID and save it
83595>>>>>    // as psConnectionID property. It is later used whenever a login to
83595>>>>>    // the database is needed.
83595>>>>>    Procedure AutoSetConnectionID
83597>>>>>        String sConnectionID sValue sDriverID sConnectionString
83597>>>>>        Integer iDriver iNumConn iConn iConnOptions iRetval
83597>>>>>        Handle hoCLI                 
83597>>>>>        Boolean bOK bSilent bMertechDriver
83597>>>>>        
83597>>>>>        Get pbSilentLogin      to bSilent
83598>>>>>        Get psConnectionID     to sConnectionID                            
83599>>>>>        Get psConnectionString to sConnectionString
83600>>>>>        // Get the driver Connection ID string & set the psConnectionString property.
83600>>>>>        Get psDriverID to sDriverID
83601>>>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
83602>>>>>        If (bOK = False) Begin
83604>>>>>            Procedure_Return              
83605>>>>>        End                 
83605>>>>>>
83605>>>>>        
83605>>>>>        // Mertech drivers can't use connection ID's.
83605>>>>>        Get IsMertechDriver sDriverID to bMertechDriver    
83606>>>>>        If (bMertechDriver = True) Begin         
83608>>>>>            // This ensures that the correct Server & Database attributes are set both for 
83608>>>>>            // embedded SQL calls and "normal" database commands like e.g. "Open".
83608>>>>>            Get _MertechSQLManagerHandle to hoCLI
83609>>>>>            Procedure_Return
83610>>>>>        End
83610>>>>>>
83610>>>>>        
83610>>>>>        Get DriverIndex sDriverID          to iDriver
83611>>>>>        // If driver not loaded; load it.
83611>>>>>        If (iDriver = 0) Begin
83613>>>>>            Load_Driver sDriverID
83614>>>>>            Get DriverIndex sDriverID      to iDriver
83615>>>>>        End                      
83615>>>>>>
83615>>>>>        // This shouldn't be possible; unless the driver.dll file is missing or something...
83615>>>>>        If (iDriver = 0) Begin
83617>>>>>            Error DFERR_PROGRAM ("The database driver could not be loaded! Connection to database failed." * sDriverID)
83618>>>>>>
83618>>>>>            Procedure_Return
83619>>>>>        End
83619>>>>>>
83619>>>>>
83619>>>>>        Get Create (RefClass(cCLIHandler)) to hoCLI
83620>>>>>        Set psDriverID of hoCLI            to sDriverID   
83621>>>>>        // Delete the connection first; in case it exists
83621>>>>>        Get DeleteConnectionID of hoCLI sConnectionID -1 to iRetval
83622>>>>>        Get CreateConnectionID of hoCLI sConnectionID sConnectionString bSilent to iRetval
83623>>>>>
83623>>>>>        Send Destroy of hoCLI 
83624>>>>>    End_Procedure
83625>>>>>
83625>>>>>    // Returns the handle of the Mertech SQL handler.
83625>>>>>    // It also ensures that the correct Server & Database attributes are set both for 
83625>>>>>    // embedded SQL calls and "normal" database commands like e.g. "Open".  
83625>>>>>    // Note: This does _not_ return a proper CLI handler handle as it is not in this class.
83625>>>>>    //       So the return value is of no use! But we don't need the handle for this class.
83625>>>>>    Function _MertechSQLManagerHandle Returns Handle
83627>>>>>        Handle hoSQLHandler
83627>>>>>        String sDriverID sServer sDatabase
83627>>>>>        
83627>>>>>        Move 0 to hoSQLHandler
83628>>>>>        Get psDriverID to sDriverID       
83629>>>>>        Get psServer   to sServer
83630>>>>>        Get psDatabase to sDatabase
83631>>>>>        
83631>>>>>        Function_Return hoSQLHandler
83632>>>>>    End_Function
