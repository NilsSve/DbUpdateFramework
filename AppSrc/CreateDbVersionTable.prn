92390>>>// *************************************************************************
92390>>>//  Public message. This is the default message. It is expected that you will
92390>>>//   create your own message to override this
92390>>>// *************************************************************************
92390>>>
92390>>>Procedure Activate_About
92393>>>   Send DoAbout "" "" "" "" ""
92394>>>End_Procedure
92395>>>
92395>>>// *************************************************************************
92395>>>//  Public message. It is expected that you will send this message (most
92395>>>//  likely from Activate_About. This creates an about object, activates it
92395>>>//  and destroys it when done. It is not exepected that you will augment this.
92395>>>// *************************************************************************
92395>>>// Sample usage:
92395>>>//   The first two params will automatically be filled from the application settings if not provided.
92395>>>//   Send DoAbout "" "" ("Copyright: 2013" * psCompany(ghoApplication)) "Created by: Your Name" "YourAppBitmap.bmp" "Internet: http://www.YourWebAddress.com" "E-mail: mailto:support@YourEmailAddress.com" "Some other description of choice" "9th param" "and last param"
92395>>>
92395>>>Procedure DoAbout String sTitle String sVersion String sCopyRight String sAuthor String sBitmap ;                  String sParam6 String sParam7 String sParam8 String sParam9 String sParam10
92398>>>        Integer hoObj hoMain iArgs
92398>>>        String sValue
92398>>>
92398>>>        // Create object
92398>>>        Object About is an AboutDialog
92400>>>            // Uncomment these two lines if you would like to have a resizable About object.
92400>>>//            Set Border_Style to Border_Thick
92400>>>//            Set peAnchors to anAll
92400>>>
92400>>>            // Add checking for the number of arguments passed to avoid runtime errors
92400>>>            // if one of them is not passed. This makes the interface
92400>>>            // more flexible.
92400>>>            Move num_arguments to iArgs
92401>>>
92401>>>            // If no title is passed use the label of the main panel (if a main panel exists).
92401>>>            If (iArgs > 0 and sTitle = "") Begin
92403>>>                Get Main_Window of Desktop to hoMain
92404>>>                If hoMain Get Label of hoMain to sValue
92407>>>            End
92407>>>>
92407>>>            Else If (iArgs > 0 and sTitle <> "") Begin
92410>>>                Move sTitle to sValue
92411>>>            End
92411>>>>
92411>>>            Else If (iArgs = 0) Begin
92414>>>                Get Main_Window of Desktop to hoMain
92415>>>                If hoMain Get Label of hoMain to sValue
92418>>>            End
92418>>>>
92418>>>
92418>>>            If (sValue <> "") Send Add_LineLn sValue
92421>>>            Move "" to sValue
92422>>>
92422>>>            // If the passed sVersion value is blank, the info will be retrieved from the cApplication object.
92422>>>            // For this to work the Project Properties Version must have been set in the Studio.
92422>>>            If (iArgs < 2) Begin
92424>>>                Move "" to sValue
92425>>>            End
92425>>>>
92425>>>            Else Begin
92426>>>                Move sVersion to sValue
92427>>>            End
92427>>>>
92427>>>            Set Version to sValue
92428>>>
92428>>>            If (iArgs > 2 and sCopyRight <> "") Send Add_LineLn sCopyRight
92431>>>
92431>>>            // If only the five "standard" params were passed we don't add an extra linefeed;
92431>>>            // else we do.
92431>>>            If (iArgs > 3 and iArgs < 6 and sAuthor <> "") Begin
92433>>>                Send Add_Line sAuthor
92434>>>            End
92434>>>>
92434>>>            Else If (iArgs > 5 and sAuthor <> "") Begin
92437>>>                Send Add_LineLn sAuthor
92438>>>            End
92438>>>>
92438>>>
92438>>>            // Square bitmaps of 80x80 works best
92438>>>            If (iArgs > 4 and sBitmap <> "") Begin
92440>>>               Set Logo to sBitMap
92441>>>            End
92441>>>>
92441>>>
92441>>>            // Here starts handling of the five optional params:
92441>>>            If (iArgs = 6 and sParam6  <> "") Begin
92443>>>                Send Add_Line sParam6
92444>>>            End
92444>>>>
92444>>>            Else If (iArgs > 6 and sParam6  <> "") Begin
92447>>>                Send Add_LineLn sParam6
92448>>>            End
92448>>>>
92448>>>
92448>>>            If (iArgs = 7 and sParam7  <> "") Begin
92450>>>                Send Add_Line sParam7
92451>>>            End
92451>>>>
92451>>>            Else If (iArgs > 7 and sParam7  <> "") Begin
92454>>>                Send Add_LineLn sParam7
92455>>>            End
92455>>>>
92455>>>
92455>>>            If (iArgs = 8 and sParam8  <> "") Begin
92457>>>                Send Add_Line sParam8
92458>>>            End
92458>>>>
92458>>>            Else If (iArgs > 8 and sParam8  <> "") Begin
92461>>>                Send Add_LineLn sParam8
92462>>>            End
92462>>>>
92462>>>
92462>>>            If (iArgs = 9 and sParam9  <> "") Begin
92464>>>                Send Add_Line sParam9
92465>>>            End
92465>>>>
92465>>>            Else If (iArgs > 9 and sParam9  <> "") Begin
92468>>>                Send Add_LineLn sParam9
92469>>>            End
92469>>>>
92469>>>
92469>>>            If (iArgs = 10 and sParam10 <> "") Begin
92471>>>                Send Add_Line sParam10
92472>>>            End
92472>>>>
92472>>>
92472>>>            Move Self to hoObj
92473>>>        End_Object
92474>>>
92474>>>        Send Popup   of hoObj // Popup the about object
92475>>>        Send Destroy of hoObj // When done, it will be destroyed
92476>>>End_Procedure
92477>    Procedure Activate_About
92480>        Send DoAbout "" "" ("Copyright 2016-2017" * psCompany(ghoApplication)) "Author: Nils G. Svedmyr" "DbUpdate.bmp" "E-mail: mailto:support@rdctools.com" "Web-site: www.rdctools.com"
92481>    End_Procedure
