81856>>>>>>>Struct tSQLConnection
81856>>>>>>>    Boolean bEnabled                // 1. There can only be one active/enabled connection at a time.
81856>>>>>>>    String sConnectionID            // 2. The name of the connection ID.      
81856>>>>>>>    Integer iDbType                 // 3. Database type; "MS-SQL Server", "DB2", "Oracle", "MySQL", "PostgreSQL"
81856>>>>>>>    String sDriverID                // 4. Name of the driver. E.g. "MSSQLDRV", "DB2_DRV" or "ODBC_DRV".
81856>>>>>>>    String sServer                  // 5. SQL Server/DSN/ODBC source name. (In DF19 this is the "sString" member of the tConnection struct.)
81856>>>>>>>    String sDatabase                // 6. SQL Database
81856>>>>>>>    String sConnectionString        // 7. Full connection string as is needed by e.g. the login command.
81856>>>>>>>    Boolean bTrusted                // 8. Trusted connection (then is UID & PWD not used)                
81856>>>>>>>    String sUserID                  // 9. User ID
81856>>>>>>>    String sPassword                // 10. Password
81856>>>>>>>    String sSchema                  // 11. DB2 (and perhaps ODBC specific)
81856>>>>>>>    String sBaseTableSpace          // 12. DB2 specific
81856>>>>>>>    String sLongTableSpace          // 13. DB2 specific
81856>>>>>>>    String sIndexTableSpace         // 14. DB2 specific 
81856>>>>>>>    Boolean bSilentLogin            // 15. True=Silent login. (i.e. don't show Database login dialog if database login to fails). Same as driver "Options" parameter.
81856>>>>>>>    Boolean bError                  // 16. Set to true on error.
81856>>>>>>>//    Boolean bDisabled               // 17. For compatability with DF19 Managed Connections only. Not used by DUF (Database Update Framework).
81856>>>>>>>//    Integer iDriverIndex            // 18. For compatability with DF19 Managed Connections only. Not used by DUF (Database Update Framework).
81856>>>>>>>End_Struct            
81856>>>>>
81856>>>>>Class cDbUpdateFunctionLibrary_Mixin is a Mixin 
81857>>>>>    Procedure CreateDbUpdateLibraryProperties
81859>>>>>        Handle hoSQLManagerMT
81859>>>>>        
81859>>>>>        // Error Reporting Related
81859>>>>>        // If DUF_ERROR_NO_REPORT errors are supressed (only ERR gets set)
81859>>>>>        Property Integer Error_Report_Mode DUF_ERROR_REPORT
81860>>>>>
81860>>>>>        Property String Private.psUseDatabase ""
81861>>>>>
81861>>>>>        Property Handle phoCLIHandler      (Create(Self,RefClass(cCLIHandler)))
81862>>>>>        Property Handle phoSQLManager      (Create(Self,RefClass(cSQLHandleManager))) 
81863>>>>>        
81863>>>>>        Property Handle phoSQLManagerMT
81864>>>>>        
81864>>>>>        Property Handle phoMSSQLHandler    (Create(Self,RefClass(cMSSQLHandler)))
81865>>>>>        Property Handle phoDB2SQLHandler   (Create(Self,RefClass(cDB2Handler)))
81866>>>>>        Property Handle phoODBCSQLHandler  (Create(Self,RefClass(cODBCHandler)))
81867>>>>>        Property Handle phoSQLConnectionHandler 0  
81868>>>>>        Property tSQLKeyWords[] paSQLKeywordArray
81869>>>>>        
81869>>>>>        Property Boolean pbHandleQueryErrors True 
81870>>>>>        
81870>>>>>        Property tSqlColumnNew[] paQueryColumns   
81871>>>>>        Property String[] paSQLFetchResults
81872>>>>>
81872>>>>>        // Error handling
81872>>>>>        Property Boolean pbSqlError False 
81873>>>>>        Property tSqlErrorArray paSqlErrorArray
81874>>>>>        Property Boolean pbProcessingError False
81875>>>>>
81875>>>>>        // Statistics on query
81875>>>>>        Property TimeSpan ptsTotalQueryTime
81876>>>>>        Property TimeSpan ptsQueryExec
81877>>>>>        Property TimeSpan ptsFetchResults
81878>>>>>        Property Integer piColumns 0
81879>>>>>        Property Integer piRows 0
81880>>>>>        Property Integer piRowType 0
81881>>>>>        Property String[] paQueryMessages  
81882>>>>>        Property String psSQLStatementString  
81883>>>>>        
81883>>>>>        Property Integer[] piTableConvertExceptions
81884>>>>>        
81884>>>>>        // How many SQL statements to send of to be executed when a really big
81884>>>>>        // SQL file has been compiled into the program. It is way faster to divide
81884>>>>>        // the statements in smaller chunks than to execute them all at the same time.
81884>>>>>        Property Integer piChunkMax 500  
81885>>>>>        
81885>>>>>        Send SetupSQLKeywordArray   
81886>>>>>    End_Procedure  
81887>>>>>    
81887>>>>>    // Custom array find function. It compares both the iSQLWord & iSQLDbType params.
81887>>>>>    Function CompareFindSQLKeyWords tSQLKeyWords SQLKeywords1 tSQLKeyWords SQLKeywords2 Returns Integer
81889>>>>>        If (SQLKeywords1.iSQLWord = SQLKeywords2.iSQLWord and SQLKeywords1.iSQLDbType = SQLKeywords2.iSQLDbType) Begin
81891>>>>>            Function_Return (EQ)
81892>>>>>        End
81892>>>>>>
81892>>>>>        Function_Return (NE)
81893>>>>>    End_Function
81894>>>>>    
81894>>>>>    // Custom array sort function. It compares both the iSQLWord & iSQLDbType params.
81894>>>>>    Function CompareSortSQLKeyWords tSQLKeyWords SQLKeywords1 tSQLKeyWords SQLKeywords2 Returns Integer
81896>>>>>        If (SQLKeywords1.iSQLWord   < SQLKeywords2.iSQLWord) Begin
81898>>>>>            Function_Return (LT)
81899>>>>>        End
81899>>>>>>
81899>>>>>        If (SQLKeywords1.iSQLWord   > SQLKeywords2.iSQLWord) Begin
81901>>>>>            Function_Return (GT)
81902>>>>>        End
81902>>>>>>
81902>>>>>        If (SQLKeywords1.iSQLDbType < SQLKeywords2.iSQLDbType) Begin
81904>>>>>            Function_Return (LT)
81905>>>>>        End
81905>>>>>>
81905>>>>>        If (SQLKeywords1.iSQLDbType > SQLKeywords2.iSQLDbType) Begin
81907>>>>>            Function_Return (GT)
81908>>>>>        End
81908>>>>>>
81908>>>>>
81908>>>>>        Function_Return (EQ)    
81909>>>>>    End_Function
81910>>>>>    
81910>>>>>    Procedure Add_Element Integer iSQLKeywordConstant Integer iEN_dbType String sSQLKeyword
81912>>>>>        tSQLKeyWords[] SQLKeywordArray 
81912>>>>>        tSQLKeyWords[] SQLKeywordArray 
81913>>>>>        Integer iSize
81913>>>>>        
81913>>>>>        Get paSQLKeywordArray to SQLKeywordArray 
81914>>>>>        Move (SizeOfArray(SQLKeywordArray)) to iSize
81915>>>>>        Move iSQLKeywordConstant to SQLKeywordArray[iSize].iSQLWord
81916>>>>>        Move iEN_dbType          to SQLKeywordArray[iSize].iSQLDbType
81917>>>>>        Move sSQLKeyword         to SQLKeywordArray[iSize].sSQLPhrase
81918>>>>>        
81918>>>>>        Set paSQLKeywordArray to SQLKeywordArray
81919>>>>>    End_Procedure  
81920>>>>>    
81920>>>>>    // Creates a struct array with all SQL keywords
81920>>>>>    // for all EN_xxx SQL back-ends. Various back-ends can
81920>>>>>    // have slightly different wording.
81920>>>>>    // If a new EN_dbTypexxx type is added; additions
81920>>>>>    // needs to be done for every keyword group below.
81920>>>>>    Procedure SetupSQLKeywordArray
81922>>>>>        tSQLKeyWords[] SQLKeywordArray SQLKeywordArraySorted
81922>>>>>        tSQLKeyWords[] SQLKeywordArray SQLKeywordArraySorted
81924>>>>>        
81924>>>>>        // This should only be called once; but in case it is
81924>>>>>        // we delete the array first.                        
81924>>>>>        Set paSQLKeywordArray to SQLKeywordArray 
81925>>>>>       
81925>>>>>        // ToDo: *** These SQL Key-words needs to be checked for other backends than MS-SQL! ***
81925>>>>>        //
81925>>>>>        Send Add_Element CI_SQLAlterTable EN_dbTypeMSSQL    "ALTER TABLE"
81926>>>>>        Send Add_Element CI_SQLAlterTable EN_dbTypeMySQL    "ALTER TABLE"
81927>>>>>        Send Add_Element CI_SQLAlterTable EN_dbTypeOracle   "ALTER TABLE"
81928>>>>>        Send Add_Element CI_SQLAlterTable EN_dbTypeDB2      "ALTER TABLE"
81929>>>>>        Send Add_Element CI_SQLAlterTable EN_dbTypePostgre  "ALTER TABLE"
