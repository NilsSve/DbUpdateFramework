83639>>>>>>
83639>>>>>
83639>>>>>        If (bOK = False) Begin        
83641>>>>>            Get IsMertechDriver sDriverID to bMertechDriver
83642>>>>>            If (bMertechDriver = True) Begin
83644>>>>>                Error DFERR_PROGRAM "Driver needs to be one of MSSQLDRV_ID, DB2_DRV_ID, ODBC_DRV_ID, SQLFLEX, ORAFLEX, MDSPgSQL or MDSMYSQL"
83645>>>>>>
83645>>>>>            End
83645>>>>>>
83645>>>>>            Else Begin
83646>>>>>                Error DFERR_PROGRAM "Driver needs to be one of MSSQLDRV_ID, DB2_DRV_ID or ODBC_DRV_ID"
83647>>>>>>
83647>>>>>            End
83647>>>>>>
83647>>>>>            Function_Return False
83648>>>>>        End
83648>>>>>>
83648>>>>>        
83648>>>>>        Function_Return True
83649>>>>>    End_Function
83650>>>>>            
83650>>>>>    Function IsDAWSQLDriver String sDriverID Returns Boolean
83652>>>>>        Boolean bOK
83652>>>>>        Move (sDriverID = MSSQLDRV_ID or sDriverID = DB2_DRV_ID or sDriverID = ODBC_DRV_ID) to bOK
83653>>>>>        Function_Return bOK
83654>>>>>    End_Function
83655>>>>>
83655>>>>>    Function IsMertechDriver String sDriverID Returns Boolean
83657>>>>>        Boolean bOK   
