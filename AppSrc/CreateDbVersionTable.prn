90486>>>
90486>>>    // Note: If the psDriverID + other connection properties are to be changed,
90486>>>    //       the psDriverID *must* be the first property that is changed!
90486>>>    //       Otherwise errors might be raised by the driver when e.g. the format
90486>>>    //       for a connection string has the wrong format for that driver.
90486>>>    Procedure Set psDriverID String sValue
90488>>>        Send Ignore_Error of Error_Object_Id DFERR_BAD_MESSAGE
90489>>>        Delegate Set psDriverID to sValue
90491>>>        Send Trap_Error of Error_Object_Id DFERR_BAD_MESSAGE
90492>>>        Set psDriverID of ghoSQLConnectionHandler to sValue
90493>>>    End_Procedure
90494>>>    
90494>>>    Function psDriverID Returns String
90496>>>        String sDriverID
90496>>>        
90496>>>        Send Ignore_Error of Error_Object_Id DFERR_BAD_MESSAGE
90497>>>        // This should get it from the parent object (when using the cDbUpdateHandler class)
90497>>>        Delegate Get psDriverID to sDriverID
90499>>>        Send Trap_Error of Error_Object_Id DFERR_BAD_MESSAGE
90500>>>        Move False to Err
90501>>>
90501>>>        // ...and in case it didn't use property of this class. Then the library is
90501>>>        // probably used as "utilites" from a special made program and
90501>>>        // the ghoSQLConnectionHandler must have been setup
90501>>>        If (sDriverID = "") Begin
90503>>>            Get psDriverID of ghoSQLConnectionHandler to sDriverID
90504>>>        End            
90504>>>>
90504>>>        Function_Return sDriverID
90505>>>    End_Function  
90506>>>    
90506>>>    Procedure Set piDbType Integer iValue
90508>>>        Send Ignore_Error of Error_Object_Id DFERR_BAD_MESSAGE
90509>>>        Delegate Set piDbType to iValue
90511>>>        Send Trap_Error of Error_Object_Id DFERR_BAD_MESSAGE
90512>>>        Set piDbType of ghoSQLConnectionHandler to iValue
90513>>>    End_Procedure
90514>>>    
90514>>>    Function piDbType Returns String
90516>>>        Integer iRetval
90516>>>        
90516>>>        Move False to Err
90517>>>        Send Ignore_Error of Error_Object_Id DFERR_BAD_MESSAGE
90518>>>        // This should get it from the parent object (when using the cDbUpdateHandler class)
90518>>>        Set Error_Report_Mode to DUF_ERROR_NO_REPORT
90519>>>        Delegate Get piDbType to iRetval
90521>>>        Set Error_Report_Mode to DUF_ERROR_REPORT
90522>>>        Send Trap_Error of Error_Object_Id DFERR_BAD_MESSAGE
90523>>>
90523>>>        // ...and in case it didn't use property of this class. Then the library is
90523>>>        // probably used as "utilites" from a special made program and
90523>>>        // the ghoSQLConnectionHandler must have been setup
90523>>>        If (Err = True) Begin
90525>>>            Get piDbType of ghoSQLConnectionHandler to iRetval
90526>>>        End            
90526>>>>
90526>>>
90526>>>        Move False to Err
90527>>>        Function_Return iRetval
90528>>>    End_Function  
90529>>>    
90529>>>    // When dropping columns on some SQL back-ends they doesn't reclaim the space taken up by the columns dropped. 
90529>>>    // For data types that are stored inline in the rows (int for example) it may even take up space on 
90529>>>    // the new rows added after the alter statement. to get around this you need to create a clustered 
90529>>>    // index on the table _or_ rebuild the clustered Index if it already has one. Rebuilding the index 
90529>>>    // can be done with a REBUILD command after modifying the table. But be warned this can be slow on very big tables.
90529>>>    //   ALTER TABLE MyTable
90529>>>    //       REBUILD
90529>>>    Function _SqlUtilRemoveTableColumnMSSQL String sTableName String sColumnName Returns Boolean
90531>>>        Boolean bOK  
90531>>>        
90531>>>        If (Trim(sTableName) = "" or Trim(sColumnName) = "") Begin
90533>>>            Function_Return False
90534>>>        End                             
90534>>>>
90534>>>        
90534>>>        SQLIncludeScriptFile ..\Scripts\DropConstraintAndColumnNameMSSQL.sql as DropConstraintAndColumnNameMSSQL.sql
90534>>>        Get _SqlUtilRemoveTableColumnByScript "DropConstraintAndColumnNameMSSQL.sql" sTableName sColumnName to bOK
90535>>>        
90535>>>        Function_Return (bOK = True)
90536>>>    End_Function
90537>>>
90537>>>
90537>>>    // *** Helper functions with compiled sql script code ***
90537>>>    //  
90537>>>    // When dropping columns SQL Sever does not reclaim the space taken up by the columns dropped. 
90537>>>    // For data types that are stored inline in the rows (int for example) it may even take up space on 
90537>>>    // the new rows added after the alter statement. To get around this you need to create a clustered 
90537>>>    // index on the table or rebuild the clustered Index if it already has one. Rebuilding the index 
90537>>>    // can be done with a REBUILD command after modifying the table. But be warned this can be slow on very big tables.
90537>>>    //   ALTER TABLE MyTable
90537>>>    //       REBUILD
90537>>>    Function _SqlUtilRemoveTableColumnByScript String sMemScriptFile String sTableName String sColumnName Returns Boolean
90539>>>        tSQLScriptArray SQLScriptArray                      
90539>>>        tSQLScriptArray SQLScriptArray                      
90539>>>        String sDriverID sVal
90539>>>        Boolean bOK  
90539>>>        Integer iSize iCount
90539>>>        
90539>>>        If (Trim(sTableName) = "" or Trim(sColumnName) = "") Begin
90541>>>            Function_Return False
90542>>>        End                             
90542>>>>
90542>>>        
90542>>>        Get psDriverID to sDriverID
90543>>>        Get SqlUtilReadResource sMemScriptFile to SQLScriptArray
90544>>>        If (SQLScriptArray.bError = True) Begin
90546>>>            Function_Return False
90547>>>        End                     
90547>>>>
90547>>>        
90547>>>        Move (SizeOfArray(SQLScriptArray.sSQLScriptArray)) to iSize
90548>>>        Decrement iSize
90549>>>        
90549>>>        for iCount from 0 to iSize   
90555>>>>
90555>>>            If (SQLScriptArray.sSQLScriptArray[iCount] contains "TABLE_NAME_XXX") Begin
90557>>>                Move (Replaces("TABLE_NAME_XXX",  SQLScriptArray.sSQLScriptArray[iCount], String(sTableName))) to SQLScriptArray.sSQLScriptArray[iCount]
90558>>>            End
90558>>>>
90558>>>            If (SQLScriptArray.sSQLScriptArray[iCount] contains "COLUMN_NAME_XXX") Begin
90560>>>                Move (Replaces("COLUMN_NAME_XXX", SQLScriptArray.sSQLScriptArray[iCount], String(sColumnName))) to SQLScriptArray.sSQLScriptArray[iCount]
90561>>>            End
90561>>>>
90561>>>        Loop
90562>>>>
90562>>>        
90562>>>        Get SqlUtilExecuteEmbeddedScript SQLScriptArray sDriverID False "" to bOK
90563>>>        
90563>>>        Function_Return (bOK = True)
90564>>>    End_Function
90565>>>    
90565>>>    // *** Helper functions for Mertech Drivers ***
90565>>>    // Created to not clutter up the standard function code with lots of #IFDEF's
90565>>>    // and commands that the Studio editor knows nothing about.
90565>>>    Function _MertechDeleteTDFile String sTableName Returns Integer
90567>>>        Integer iRetval
90567>>>        String sPath
90567>>>
90567>>>        If (sPath = "" or sTableName = "") Begin
90569>>>            Function_Return 0
90570>>>        End                              
90570>>>>
90570>>>        
90570>>>        Get vFolderFormat sPath to sPath
90571>>>        Get vDeleteFile (sPath + String(sTableName) + ".td") to iRetval
90572>>>        Function_Return iRetval
90573>>>    End_Function
90574>>>    
