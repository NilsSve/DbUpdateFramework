90838>        Procedure Prompt
90841>            String sValue sPath sFilelistName sFileMask 
90841>            Get Value to sValue       
90842>            
90842>            Move (Trim(sValue)) to sValue
90843>            If (sValue <> "") Begin
90845>                Get ParseFolderName sValue to sPath
90846>            End
90846>
90846>            Move "Filelist.cfg files (*.cfg)|*.cfg" to sFileMask
90847>            Get vSelect_File sFileMask "Please select a Filelist.cfg file" sPath to sFilelistName
90848>            If (sFilelistName <> "") Begin
90850>                Set Value to sFilelistName
90851>            End
90851>        End_Procedure
90852>        
90852>        Procedure OnChange
90855>            String sFilelistName sPath sOpenPath sDataPath sDdSrcPath sDataFolder                                    
90855>            Handle hTable  
90855>            Boolean bOK
90855>            
90855>            Get psOpenPath of ghoApplication to sOpenPath 
90856>            Get psDataPath of (phoWorkspace(ghoApplication)) to sDataPath
90857>            If (sOpenPath contains sDataPath) Begin
90859>                Move (Replace((sDataPath + "\;"), sOpenPath, "")) to sOpenPath
90860>            End                                                      
90860>            
90860>            Get Value to sFilelistName  
90861>            // This might be true if there was no .ws file on startup.
90861>            If (sFilelistName = "") Begin
90863>                Send Prompt  
90864>                Procedure_Return
90865>            End                 
90865>            Get ParseFolderName sFilelistName to sPath 
90866>            If (Right(sPath, 1) ="\") Begin
90868>                Move (Left(sPath, Length(sPath) -1)) to sPath
90869>            End 
90869>            If (sPath = "") Begin
90871>                Procedure_Return
90872>            End
90872>            Set_Directory sPath
90873>
90873>            Set_Attribute DF_OPEN_PATH to (sPath + ";" + sOpenPath)
90876>            Set_Attribute DF_FILELIST_NAME to sFilelistName   
90879>            // Change output folder so files are written to the correct Data folder.
90879>            // For some reason the psDataPath isn't used by default by the Structure_End command.
90879>            
90879>            Set psDataPath of (phoWorkspace(ghoApplication))  to sPath  
90880>            Set psFileList of (phoWorkspace(ghoApplication))  to sFilelistName 
90881>            
90881>            // We also need to output the .fd file if in development environment.
90881>            Get psDdSrcPath of (phoWorkspace(ghoApplication)) to sDdSrcPath
90882>            If (sDdSrcPath = "") Begin        
90884>                Get ExtractFileName of (phoWorkspace(ghoApplication)) sPath to sDataFolder
90885>                Move (Replace(sDataFolder, sPath, "DdSrc")) to sDdSrcPath
90886>                Set psDdSrcPath of (phoWorkspace(ghoApplication)) to sDdSrcPath
90887>            End
90887>            Move 0 to hTable
90888>            Get_Attribute DF_FILE_NEXT_EMPTY of hTable to hTable
90891>            Set Value of oTableNo_sf to hTable
90892>        End_Procedure  
90893>        
