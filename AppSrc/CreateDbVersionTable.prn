88117>>>    // Returns a struct array with the default column types for the SQL back-end and how they
88117>>>    // are mapped to the standard DataFlex data types. 
88117>>>    // The DataFlex data types are: "ASCII", "BINARY", "DATE", "DATETIME", "NUMERIC" and "TEXT".
88117>>>    Function UtilDefaultSqlTypeMappings String sDriverID Integer iDbType Returns tColumnType
88119>>>        tColumnType[] ColumnTypeArray
88119>>>        tColumnType[] ColumnTypeArray
88120>>>        String sDataType
88120>>>        Integer iDataType iDriverID iCount
88120>>>        
88120>>>        Move 0 to iCount
88121>>>        Get DriverIndex sDriverID to iDriverID
88122>>>
88122>>>        // DF_ASCII       
88122>>>        If (sDriverID = ODBC_DRV_ID) Begin
88124>>>            Get_Attribute DF_DRIVER_MAP_DFASCII_TO_ODBCTYPE of iDriverID to iDataType
88127>>>        End                                                             
88127>>>>
88127>>>        Else Begin
88128>>>            Get_Attribute DF_DRIVER_MAP_DFASCII_TO_SQLTYPE  of iDriverID to iDataType 
88131>>>        End
88131>>>>
88131>>>        Move DF_ASCII    to ColumnTypeArray[iCount].iDataFlexType
88132>>>        Move "ASCII"     to ColumnTypeArray[iCount].sDataFlexType  
88133>>>        Get UtilColumnTypeToString sDriverID iDbType iDataType to sDataType
88134>>>        Move sDataType   to ColumnTypeArray[iCount].sType
88135>>>        Move iDataType   to ColumnTypeArray[iCount].iType
88136>>>        Increment iCount
88137>>>        
88137>>>        // DF_BINARY 
88137>>>        If (sDriverID = ODBC_DRV_ID) Begin
88139>>>            Get_Attribute DF_DRIVER_MAP_DFBINARY_TO_ODBCTYPE of iDriverID to iDataType
88142>>>        End                                                                          
88142>>>>
88142>>>        Else Begin
88143>>>            Get_Attribute DF_DRIVER_MAP_DFBINARY_TO_SQLTYPE  of iDriverID to iDataType
88146>>>        End
88146>>>>
88146>>>        Move DF_BINARY   to ColumnTypeArray[iCount].iDataFlexType
88147>>>        Move "Binary"    to ColumnTypeArray[iCount].sDataFlexType  
88148>>>        Get UtilColumnTypeToString sDriverID iDbType iDataType to sDataType
88149>>>        Move sDataType   to ColumnTypeArray[iCount].sType
88150>>>        Move iDataType   to ColumnTypeArray[iCount].iType
88151>>>        Increment iCount
88152>>>        
88152>>>        // DF_DATE
88152>>>        If (sDriverID = ODBC_DRV_ID) Begin
88154>>>            Get_Attribute DF_DRIVER_MAP_DFDATE_TO_ODBCTYPE of iDriverID to iDataType
88157>>>        End                                                                          
88157>>>>
88157>>>        Else Begin
88158>>>            Get_Attribute DF_DRIVER_MAP_DFDATE_TO_SQLTYPE  of iDriverID to iDataType
88161>>>        End
88161>>>>
88161>>>        Move DF_DATE     to ColumnTypeArray[iCount].iDataFlexType
88162>>>        Move "Date"      to ColumnTypeArray[iCount].sDataFlexType  
88163>>>        Get UtilColumnTypeToString sDriverID iDbType iDataType to sDataType
88164>>>        Move sDataType   to ColumnTypeArray[iCount].sType
88165>>>        Move iDataType   to ColumnTypeArray[iCount].iType
88166>>>        Increment iCount
88167>>>        
88167>>>        // DF_DATETIME
88167>>>        If (sDriverID = ODBC_DRV_ID) Begin
88169>>>            Get_Attribute DF_DRIVER_MAP_DFDATETIME_TO_ODBCTYPE of iDriverID to iDataType
88172>>>        End                                                                          
88172>>>>
88172>>>        Else Begin
88173>>>            Get_Attribute DF_DRIVER_MAP_DFDATETIME_TO_SQLTYPE  of iDriverID to iDataType
88176>>>        End
88176>>>>
88176>>>        Move DF_DATETIME to ColumnTypeArray[iCount].iDataFlexType
88177>>>        Move "DateTime"  to ColumnTypeArray[iCount].sDataFlexType  
88178>>>        Get UtilColumnTypeToString sDriverID iDbType iDataType to sDataType
88179>>>        Move sDataType   to ColumnTypeArray[iCount].sType
88180>>>        Move iDataType   to ColumnTypeArray[iCount].iType
88181>>>        Increment iCount
88182>>>
88182>>>        // DF_NUMERIC
88182>>>        // *** Why is there no DF_DRIVER_MAP available for BCD/Numeric??? ***
88182>>>        // DF_BCD can in SQL be either of "SmallInt", "Int", or "Numeric", but
88182>>>        // we make them here all "Numeric"...
88182>>>//        If (sDriverID = ODBC_DRV_ID) Begin
88182>>>//            Get_Attribute DF_DRIVER_MAP_DFDATE_TO_ODBCTYPE of iDriverID to iDataType
88182>>>//        End                                                                          
88182>>>//        Else Begin
88182>>>//            Get_Attribute DF_DRIVER_MAP_DFDATE_TO_SQLTYPE  of iDriverID to iDataType
88182>>>//        End                        
88182>>>        Move DF_BCD      to ColumnTypeArray[iCount].iDataFlexType
88183>>>        Move "Numeric"   to ColumnTypeArray[iCount].sDataFlexType
88184>>>        Move "Numeric"   to ColumnTypeArray[iCount].sType
88185>>>        Move SQL_NUMERIC to ColumnTypeArray[iCount].iType
88186>>>
88186>>>        // DF_TEXT
88186>>>        If (sDriverID = ODBC_DRV_ID) Begin
88188>>>            Get_Attribute DF_DRIVER_MAP_DFTEXT_TO_ODBCTYPE of iDriverID to iDataType
88191>>>        End                                                                          
88191>>>>
88191>>>        Else Begin
88192>>>            Get_Attribute DF_DRIVER_MAP_DFTEXT_TO_SQLTYPE  of iDriverID to iDataType
88195>>>        End
88195>>>>
88195>>>        Move DF_TEXT     to ColumnTypeArray[iCount].iDataFlexType
88196>>>        Move "Text"      to ColumnTypeArray[iCount].sDataFlexType  
88197>>>        Get UtilColumnTypeToString sDriverID iDbType iDataType to sDataType
88198>>>        Move sDataType   to ColumnTypeArray[iCount].sType
88199>>>        Move iDataType   to ColumnTypeArray[iCount].iType
88200>>>        Increment iCount
88201>>>        
88201>>>        Function_Return ColumnTypeArray
88202>>>    End_Function
