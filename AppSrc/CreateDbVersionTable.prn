82828>>>>>>>    // Returns the full path of the Application (no trailing "\")
82828>>>>>>>    Function ApplicationPath Returns String
82830>>>>>>>        String sApplicationFileName sPath
82830>>>>>>>        Integer iNumChars iRetval
82830>>>>>>>
82830>>>>>>>        Move (Repeat(Character(0), 1024))    to sApplicationFileName
82831>>>>>>>        Move (GetModuleFileName(0, AddressOf(sApplicationFileName), 1024)) to iNumChars
82832>>>>>>>        Move (CString(sApplicationFileName)) to sApplicationFileName
82833>>>>>>>        Move (PathRemoveFileSpec(AddressOf(sApplicationFileName))) to iRetval
82834>>>>>>>        Move (CString(sApplicationFileName)) to sPath
82835>>>>>>>
82835>>>>>>>        Function_Return sPath
82836>>>>>>>    End_Function
