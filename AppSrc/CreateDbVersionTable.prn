85284>>>    Function SqlUtilEnumerateLoggedInUsers String sDriverID String sDatabase Returns tSQLLoggedInUser[]
85286>>>        tSQLLoggedInUser[] SQLLoggedInUser
85286>>>        tSQLLoggedInUser[] SQLLoggedInUser
85287>>>        String[] sUsers sPrograms
85289>>>        String sSelect 
85289>>>        Integer iSize iCount
85289>>>        
85289>>>        Case Begin
85289>>>            Case (sDriverID = MSSQLDRV_ID)
85291>>>                Move ("SELECT RTRIM(SP.nt_username) AS Inlog, RTRIM(SP.program_name) as Programma from master.dbo.sysprocesses SP INNER JOIN master.dbo.sysdatabases SD ON SP.dbid = SD.dbid WHERE (SP.nt_username <> '') and (SP.nt_username <> 'SYSTEM') and (SD.name = '" ;                + sDatabase + "') ORDER by Inlog") to sSelect
85292>>>                Get SqlEnumerateEsqlDAW sSelect 1 to sUsers
85293>>>                Get SqlEnumerateEsqlDAW sSelect 2 to sPrograms
85294>>>                Case Break
85295>>>            Case (sDriverID = SQLFLEX)
85298>>>                Move ("SELECT RTRIM(SP.nt_username) AS Inlog, RTRIM(SP.program_name) as Programma from master.dbo.sysprocesses SP INNER JOIN master.dbo.sysdatabases SD ON SP.dbid = SD.dbid WHERE (SP.nt_username <> '') and (SP.nt_username <> 'SYSTEM') and (SD.name = '" ;                + sDatabase + "') ORDER by Inlog") to sSelect
85299>>>                Get SqlEnumerateEsqlMertech sSelect 1 to sUsers
85300>>>                Get SqlEnumerateEsqlMertech sSelect 2 to sPrograms
85301>>>                Case Break                 
85302>>>            Case Else
85302>>>                Error DFERR_PROGRAM ("Not implemented yet for this driver (" + sDriverID + ")")
85303>>>>
85303>>>        Case End
85303>>>        
85303>>>        Move (SizeOfArray(sUsers)) to iSize
85304>>>        Decrement iSize
85305>>>        For iCount from 0 to iSize
85311>>>>
85311>>>            Move sUsers[iCount]    to SQLLoggedInUser[iCount].sUser
85312>>>            Move sPrograms[iCount] to SQLLoggedInUser[iCount].sProgram
85313>>>        Loop
85314>>>>
85314>>>        
85314>>>        Function_Return SQLLoggedInUser
85315>>>    End_Function 
85316>>>    
85316>>>    // Returns an array with all ".int" files for the passed sDataPath, _except_ for the driver .int files;
85316>>>    // "MSSQLDRV.int", "DB2_DRV.int" & "ODBC_DRV.int".
85316>>>    Function SqlUtilEnumerateIntFiles String sDataPath Returns String[]
85318>>>        String[] sFilesData
85319>>>        Boolean bExists
85319>>>        Integer iCh
85319>>>        String sFileName sExt
85319>>>        
85319>>>        Get vFolderExists sDataPath to bExists
85320>>>        If (bExists = True) Begin
85322>>>            Move (ToANSI(Trim(sDataPath))) to sDataPath
85323>>>            Move ("dir:" + sDataPath)      to sDataPath
85324>>>            Get Seq_New_Channel to iCh  // get free channel for input
85325>>>            Direct_Input channel iCh sDataPath
85327>>>                Repeat
85327>>>>
85327>>>                    Readln channel iCh sFileName
85329>>>                    Get ParseFileExtension sFileName to sExt
85330>>>                    If (Uppercase(sExt) = "INT") Begin
85332>>>                        If (not(Uppercase(sFileName) contains "MSSQLDRV" and Uppercase(sFileName) contains "DB2_DRV" and Uppercase(sFileName) contains "ODBC_DRV")) Begin
85334>>>                            Move sFileName to sFilesData[SizeOfArray(sFilesData)]
85335>>>                        End
85335>>>>
85335>>>                    End
85335>>>>
85335>>>                Until (SeqEof = True)
85337>>>            Close_Input channel iCh
85339>>>        End
85339>>>>
85339>>>        Function_Return sFilesData
85340>>>    End_Function                                  
85341>>>    
85341>>>    // Returns a handle to the SQL server associated with the passed driver ID.
85341>>>    // Pass e.g. the psServer property to determine the current connection server.
85341>>>    // Returns a handle to the database connection, or a zero (0) if it fails.
85341>>>    // This handle can be used to obtain attributes about the server, such as default
85341>>>    // column types.
85341>>>    Function SqlUtilDatabaseHandle String sDriverID String sServer Returns Handle
85343>>>        Handle hDatabase
85343>>>        Integer iDriver iServers iCount
85343>>>        String sValue
85343>>>        
85343>>>        If (sServer = "") Begin
85345>>>            Function_Return 0
85346>>>        End 
85346>>>>
85346>>>        
85346>>>        Get DriverIndex sDriverID to iDriver
85347>>>        If (iDriver = 0) Begin
85349>>>            Function_Return 0
85350>>>        End                  
85350>>>>
85350>>>        
85350>>>        Get_Attribute DF_DRIVER_NUMBER_SERVERS of iDriver to iServers
85353>>>        For iCount from 1 to iServers
85359>>>>
85359>>>            Get_Attribute DF_DRIVER_SERVER_NAME of iDriver iCount to sValue
85362>>>            If (Uppercase(sValue) contains Uppercase(sServer)) Begin
85364>>>                Get_Attribute DF_DATABASE_ID of iDriver iCount to hDatabase
85367>>>            End
85367>>>>
85367>>>        Loop
85368>>>>
85368>>>                
85368>>>        Function_Return hDatabase
85369>>>    End_Function
85370>>>
85370>>>    Procedure SqlUtilExecuteQuery String sStmt String sDriverID Boolean bShowProgr 
85372>>>        String sConnectionString sMessage
85372>>>        Handle hoSqlHandler hoSQLConnect hoStmt hoError
85372>>>        Integer i iMsgs iFetchResult iResultCount iRowType iRows iErr iMessage
85372>>>        String[] sMsg aSQLQueryMessages aSQLFetchResults
85375>>>        DateTime dtQueryExecStart dtQueryExecEnd dtFetchStart dtFetchEnd
85375>>>        TimeSpan tsQuery tsFetch
85375>>>        tSqlErrorArray aSqlErrorArray
85375>>>        tSqlErrorArray aSqlErrorArray
85375>>>        Boolean bOK bMertechDriver bShowProgress
85375>>>        tSQLConnection SQLConnection
85375>>>        tSQLConnection SQLConnection
85375>>>        
85375>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
85376>>>        If (bOK = False) Begin
85378>>>            Procedure_Return
85379>>>        End
85379>>>>
85379>>>        
85379>>>        If (num_arguments > 2) Begin
85381>>>            Move bShowProgr to bShowProgress
85382>>>        End
85382>>>>
85382>>>
85382>>>        Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
85383>>>        
85383>>>        Get IsMertechDriver sDriverID to bMertechDriver
85384>>>        If (bMertechDriver = True) Begin
85386>>>            Get _MertechSQLConnect sDriverID SQLConnection.sServer SQLConnection.sUserID SQLConnection.sPassword to hoSQLConnect
85387>>>        End
85387>>>>
85387>>>        If (bMertechDriver = False) Begin
85389>>>            Get phoSQLManager to hoSqlHandler
85390>>>            Send SqlSetConnect of hoSqlHandler sDriverID SQLConnection.sConnectionString
85391>>>            Get SqlConnect     of hoSqlHandler "" "" to hoSQLConnect
85392>>>        End
85392>>>>
85392>>>
85392>>>        If (hoSQLConnect <> 0) Begin
85394>>>            Get SqlOpen of hoSQLConnect to hoStmt
85395>>>            If (hoStmt <> 0) Begin
85397>>>                // record starting date/time stamp
85397>>>                Move (CurrentDateTime()) to dtQueryExecStart
85398>>>                // turn on error handling if enabled 
85398>>>                If (pbHandleQueryErrors(Self)) Begin
85400>>>                    Set pbSqlError to False 
85401>>>                    Set paSqlErrorArray to aSqlErrorArray
85402>>>                    Move Error_Object_Id to hoError
85403>>>                    Move Self to Error_Object_Id
85404>>>                End               
85404>>>>
85404>>>                
85404>>>                // Before we execute the statement; save it so we can display the faulty statement in the error log.
85404>>>                Set psSQLStatementString to sStmt
85405>>>                Send SqlExecDirect of hoStmt sStmt
85406>>>                
85406>>>                If (pbHandleQueryErrors(Self)) Begin
85408>>>                    Move hoError to Error_Object_Id
85409>>>                End       
85409>>>>
85409>>>                
85409>>>                Move 0 to iMsgs
85410>>>                // ToDo: There seems to be some issues with this code and Mertech drivers that makes
85410>>>                // the debugger crash in some cases like an error in the ESQL statement; so we exclude it for now.
85410>>>                If (bMertechDriver = False) Begin   
85412>>>                    Move Err to iErr
85413>>>                    Get SqlStmtAttribute of hoStmt SQLSTMTATTRIB_NUMMESSAGES   to iMsgs
85414>>>                    Get SqlStmtAttribute of hoStmt SqlSTMTATTRIB_ROWCOUNT      to iRows
85415>>>                    Get SqlStmtAttribute of hoStmt SqlSTMTATTRIB_ROWCOUNT_TYPE to iRowType
85416>>>                    Send _SqlColumnInfo hoStmt
85417>>>                    Send Ignore_Error of Error_Object_Id 12289    
85418>>>                    Set Error_Report_Mode to DUF_ERROR_NO_REPORT
85419>>>                    Repeat     
85419>>>>
85419>>>                        Get SqlFetch of hoStmt to iFetchResult
85420>>>                        If (iFetchResult <> 0) Begin
85422>>>                            Get SQLColumnValue of hoStmt 1 to aSQLFetchResults[SizeOfArray(aSQLFetchResults)]
85423>>>                        End
85423>>>>
85423>>>                    Until (iFetchResult = 0)
85425>>>                    Send Trap_Error of Error_Object_Id 12289    
85426>>>                    Set Error_Report_Mode to DUF_ERROR_REPORT 
85427>>>                    Move iErr to Err
85428>>>                    Set paSQLFetchResults to aSQLFetchResults
85429>>>                End 
85429>>>>
85429>>>                
85429>>>                Set piRows    to iRows
85430>>>                Set piRowType to iRowType
85431>>>                Move (CurrentDateTime()) to dtQueryExecEnd
85432>>>                Move (CurrentDateTime()) to dtFetchStart
85433>>>
85433>>>                If (iMsgs <> 0) Begin
85435>>>                    If (ghoDbUpdateHandler > 0) Begin
85437>>>                        Get paSQLQueryMessages of ghoDbUpdateHandler to aSQLQueryMessages
85438>>>                    End
85438>>>>
85438>>>                    For i from 1 to iMsgs
85444>>>>
85444>>>                        Get SqlGetMessage of hoStmt i to sMessage
85445>>>                        Get RemoveComponentIdentifier of hoStmt sMessage to sMessage
85446>>>                        If (bShowProgress = True) Begin
85448>>>                            If (Active_State(ghoStatusPanel)) Begin
85450>>>                                Send Update_StatusPanel of ghoStatusPanel (Sformat("  SQLGetMessage iMessage %1 returned [%2]",iMessage,sMessage))
85451>>>                            End                                                   
85451>>>>
85451>>>                            Else Begin
85452>>>                                Showln (Sformat("  SQLGetMessage iMessage %1 returned [%2]",iMessage,sMessage))
85454>>>                            End                                           
85454>>>>
85454>>>                        End
85454>>>>
85454>>>                        Move sMessage to sMsg[SizeOfArray(sMsg)]
85455>>>                        Move sMessage to aSQLQueryMessages[SizeOfArray(aSQLQueryMessages)]
85456>>>                    Loop
85457>>>>
85457>>>                    If (ghoDbUpdateHandler > 0) Begin
85459>>>                        Set paSQLQueryMessages of ghoDbUpdateHandler to aSQLQueryMessages
85460>>>                    End
85460>>>>
85460>>>                    Set paQueryMessages to sMsg  
85461>>>                End
85461>>>>
85461>>>                Move (CurrentDateTime()) to dtFetchEnd
85462>>>            End
85462>>>>
85462>>>            Move (dtQueryExecEnd - dtQueryExecStart) to tsQuery
85463>>>            Move (dtFetchStart - dtFetchEnd) to tsFetch
85464>>>            Set ptsQueryExec to tsQuery
85465>>>            Set ptsFetchResults to tsFetch
85466>>>            Send SqlClose of hoStmt
85467>>>        End
85467>>>>
85467>>>
85467>>>        Send SqlDisconnect of hoSQLConnect
85468>>>    End_Procedure
85469>>>
85469>>>    // *** Main message for executing an SQL script that has been compiled into the program as a resource ***
85469>>>    // Use the SQLIncludeScriptFile command to include an SQL script into the program.
85469>>>    // Returns False if no error occured.
85469>>>    Function SqlUtilExecuteResource String sMemFileName String sDriverID Boolean bCreateScriptFile Boolean bShowProgr Returns Boolean
85471>>>        Boolean bOK bShowProgress                               
85471>>>        tSQLScriptArray SQLScriptArray                      
85471>>>        tSQLScriptArray SQLScriptArray                      
85471>>>        Integer iOut iRows iCount
85471>>>        DateTime dtTotalQueryStart dtTotalQueryEnd
85471>>>        TimeSpan tsTotalTime  
85471>>>        String sMessage
85471>>>        
85471>>>        Move (CurrentDateTime()) to dtTotalQueryStart
85472>>>        Get SqlUtilReadResource sMemFileName to SQLScriptArray
85473>>>        If (SQLScriptArray.bError = True) Begin
85475>>>            Function_Return False
85476>>>        End
85476>>>>
85476>>>
85476>>>        If (num_arguments > 3) Begin
85478>>>            Move bShowProgr to bShowProgress
85479>>>        End
85479>>>>
85479>>>
85479>>>        Set Error_Report_Mode to DUF_ERROR_NO_REPORT
85480>>>        Get SqlUtilExecuteEmbeddedScript SQLScriptArray sDriverID bCreateScriptFile sMemFileName bShowProgress to bOK
85481>>>        Set Error_Report_Mode to DUF_ERROR_REPORT 
85482>>>        
85482>>>        If (SQLScriptArray.bArgumentSizeChanged = True) Begin
85484>>>            Set_Argument_Size SQLScriptArray.iOrgArgumentSize
85485>>>>
85485>>>        End
85485>>>>
85485>>>
85485>>>        Move (CurrentDateTime()) to dtTotalQueryEnd
85486>>>        Move (dtTotalQueryEnd - dtTotalQueryStart) to tsTotalTime
85487>>>        Set ptsTotalQueryTime to tsTotalTime
85488>>>        
85488>>>        Function_Return bOK
85489>>>    End_Procedure
