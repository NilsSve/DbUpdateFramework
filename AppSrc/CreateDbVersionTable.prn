82982>>>>>    Procedure Set psConnectionID String sValue
82984>>>>>        tSQLConnection SQLConnection                                       
82984>>>>>        tSQLConnection SQLConnection                                       
82984>>>>>        Integer iIndex
82984>>>>>        
82984>>>>>        Get Private.pSQLConnection to SQLConnection
82985>>>>>        If (SQLConnection.sConnectionID = "") Begin
82987>>>>>            Move sValue to SQLConnection.sConnectionID
82988>>>>>        End
82988>>>>>>
82988>>>>>        
82988>>>>>        // Else we might want to change the current connection ID
82988>>>>>        Else If (SQLConnection.sConnectionID <> "" and SQLConnection.sConnectionID <> sValue) Begin   
82991>>>>>            Move False to Err
82992>>>>>            Logout SQLConnection.sDriverID  
82993>>>>>            // This will also make a login to the new server.
82993>>>>>            Get SQLIniFileConnectionID of (phoSQLConnectionIniFile(Self)) sValue to SQLConnection
82994>>>>>        End
82994>>>>>>
82994>>>>>        Set pSQLConnection to SQLConnection
82995>>>>>    End_Procedure
