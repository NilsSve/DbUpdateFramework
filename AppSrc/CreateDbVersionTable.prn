85219>>>    // Returns a string array with all table names the passed table handle has relation ships with.
85219>>>    // The format of the array is "TableName.FieldName"
85219>>>    Function SqlUtilEnumerateRelations String sTableName String sDriverID Returns tSQLRelation[]
85221>>>        String[] sFileNameArray sFieldNameArray
85223>>>        tSQLRelation[] sRelationsArray
85223>>>        tSQLRelation[] sRelationsArray
85224>>>        String sServer sConnectionString sSelect sSchema sFileName sFieldName sVal
85224>>>        Boolean bOK  
85224>>>        Integer iCount iSize iLength iPos 
85224>>>        Integer iFileNumber iFieldNumber
85224>>>        
85224>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
85225>>>        If (bOK = False) Begin
85227>>>            Error DFERR_PROGRAM ("Unsupported driver. A list of table columns could not be retrieved for:" * sDriverID + ".")
85228>>>>
85228>>>            Function_Return sRelationsArray
85229>>>        End   
85229>>>>
85229>>>       
85229>>>        Get psConnectionString to sConnectionString  
85230>>>        Get psSchema to sSchema
85231>>>        
85231>>>        Case Begin
85231>>>            Case (sDriverID = MSSQLDRV_ID)    
85233>>>                Move ("SELECT object_name(parent_object_id), object_name(referenced_object_id), name from sys.foreign_keys WHERE parent_object_id = object_id( '" + sTableName + "')") to sSelect
85234>>>                Get SqlEnumerateEsqlDAW sSelect 2 to sFileNameArray
85235>>>                Get SqlEnumerateEsqlDAW sSelect 3 to sFieldNameArray
85236>>>                Case Break
85237>>>
85237>>>            Case (sDriverID = DB2_DRV_ID) 
85240>>>                Error "Not implemented yet! The select statement has not been finalized."
85241>>>>
85241>>>//                Move () to sSelect
85241>>>//                Get SqlEnumerateEsqlDAW sSelect 2 to sReturnArray
85241>>>//                Get SqlEnumerateEsqlDAW sSelect 3 to sFieldNameArray
85241>>>                Case Break
85242>>>
85242>>>            Case (sDriverID = SQLFLEX)
85245>>>                Error "Not implemented yet! The select statement has not been finalized."
85246>>>>
85246>>>//                Move () to sSelect
85246>>>//                Get SqlEnumerateEsqlMertech sSelect 2 to sReturnArray
85246>>>//                Get SqlEnumerateEsqlDAW sSelect 3 to sFieldNameArray
85246>>>                Case Break
85247>>>            
85247>>>            Case (sDriverID = MDSMySQL) 
85250>>>                Error "Not implemented yet! The select statement has not been finalized."
85251>>>>
85251>>>//                Move () to sSelect
85251>>>//                Get SqlEnumerateEsqlMertech sSelect 2 to sReturnArray
85251>>>//                Get SqlEnumerateEsqlDAW sSelect 3 to sFieldNameArray
85251>>>                Case Break
85252>>>            
85252>>>            Case (sDriverID = MDSPgSQL) 
85255>>>                Error "Not implemented yet! The select statement has not been finalized."
85256>>>>
85256>>>//                Move () to sSelect
85256>>>//                Get SqlEnumerateEsqlMertech sSelect 2 to sReturnArray
85256>>>//                Get SqlEnumerateEsqlDAW sSelect 3 to sFieldNameArray
85256>>>                Case Break            
85257>>>            
85257>>>            Case (sDriverID = ORAFLEX) 
85260>>>                Error "Not implemented yet! The select statement has not been finalized."
85261>>>>
85261>>>//                Move () to sSelect
85261>>>//                Get SqlEnumerateEsqlMertech sSelect to sReturnArray
85261>>>//                Get SqlEnumerateEsqlDAW sSelect 3 to sFieldNameArray
85261>>>                Case Break
85262>>>                            
85262>>>            Case Else     
85262>>>                Error DFERR_PROGRAM "Unsupported driver passed to the SqlUtilEnumerateRelations function."
85263>>>>
85263>>>                Case Break
85264>>>        Case End   
85264>>>        
85264>>>        Move (Length(sTableName)) to iLength
85265>>>        Move (iLength + 4)        to iLength // The related to field key has the format "FK_TableName + FieldName"
85266>>>        Move (SizeOfArray(sFileNameArray)) to iSize
85267>>>        Decrement iSize
85268>>>        For iCount from 0 to iSize
85274>>>>
85274>>>            If (Trim(sFileNameArray[iCount]) <> "") Begin
85276>>>                Move sFileNameArray[iCount]         to sFileName 
85277>>>                Move sFieldNameArray[iCount]        to sFieldName
85278>>>                Move (Mid(sFieldName, 99, iLength)) to sFieldName
85279>>>                Move sFileName  to sRelationsArray[iCount].sFileName
85280>>>                Move sFieldName to sRelationsArray[iCount].sFieldName
85281>>>            End
85281>>>>
85281>>>        Loop
85282>>>>
85282>>>        
85282>>>        Function_Return sRelationsArray
85283>>>    End_Function  
