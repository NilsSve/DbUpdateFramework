86142>>>    Function _SqlProperTableName String sTableName Returns String
86144>>>        String sVal sSchema sDriverID sValue
86144>>>        Handle hTable  
86144>>>        Integer iDbType
86144>>>        
86144>>>        If (Trim(sTableName) = "") Begin
86146>>>            Function_Return ""
86147>>>        End
86147>>>>
86147>>>
86147>>>        Get psDriverID to sDriverID
86148>>>        Get piDbType   to iDbType
86149>>>        If (iDbType = EN_dbTypeOracle) Begin
86151>>>            Get psUserID to sSchema
86152>>>            // Not sure about this uppercasing but it seems like Oracle wants that?
86152>>>            Move (Uppercase(sSchema)) to sSchema
86153>>>            Move ('"' + sSchema + '"."' + sTableName + '"') to sTableName
86154>>>            Function_Return sTableName
86155>>>        End 
86155>>>>
86155>>>        If (iDbType = EN_DbTypeMySQL) Begin
86157>>>            Get psDatabase to sVal
86158>>>            Move (sVal + "." + sTableName) to sTableName
86159>>>            Function_Return sTableName
86160>>>        End 
86160>>>>
86160>>>        If (iDbType = EN_DbTypePostgre) Begin
86162>>>            Move ('"' + sTableName + '"') to sTableName
86163>>>            Function_Return sTableName
86164>>>        End
86164>>>>
86164>>>        
86164>>>        Get psSchema to sSchema   
86165>>>        If (sSchema = "") Begin
86167>>>            Get _SqlFindKeyWord CI_SQLDBO to sSchema
86168>>>        End
86168>>>>
86168>>>
86168>>>        Move (Uppercase(sTableName)) to sVal
86169>>>        If (not(sVal contains (sSchema + "."))) Begin  
86171>>>            If (iDbType = EN_dbTypeDB2) Begin
86173>>>                Move (Lowercase(sSchema) + "." + sTableName) to sTableName
86174>>>            End 
86174>>>>
86174>>>            Else Begin
86175>>>                Move (sSchema + "." + sTableName) to sTableName
86176>>>            End
86176>>>>
86176>>>        End    
86176>>>>
86176>>>
86176>>>        Function_Return sTableName
86177>>>    End_Function
86178>>>    
86178>>>    // SQL column names can be case-sensitive. This function is used to check that
86178>>>    // the passed sFieldName has the correct spelling.                            
86178>>>    // Used with Embedded SQL statement calls.
86178>>>    // If the spelling or fieldname doesn't exist, the return value is "" (blank).
86178>>>    Function _SqlFindColumnName String sTableName String sColumnName Returns String
86180>>>        String sRetval sValue sConnectionString sDriverID 
86180>>>        String[] sColumnNamesArray
86181>>>        Integer iCount iColumns
86181>>>
86181>>>        Move "" to sRetval
86182>>>        Get psDriverID to sDriverID
86183>>>        Get SqlUtilEnumerateColumns sDriverID sTableName to sColumnNamesArray
86184>>>        Move (SizeOfArray(sColumnNamesArray)) to iColumns
86185>>>        Decrement iColumns
86186>>>        
86186>>>        For iCount from 0 to iColumns
86192>>>>
86192>>>            Move sColumnNamesArray[iCount] to sValue
86193>>>            If (Uppercase(sColumnName) = Uppercase(sValue)) Begin
86195>>>                Move sValue to sRetval
86196>>>                Move iColumns to iCount // We're done.
86197>>>            End
86197>>>>
86197>>>        Loop                           
86198>>>>
86198>>>        
86198>>>        Function_Return sRetval
86199>>>    End_Function
