88357>>>    
88357>>>    // Returns True if the passed hTable (filelist slot number) is an Alias table.
88357>>>    // An Alias file/table is a filelist number that share the same Physical filename
88357>>>    // but which Logical name is different.
88357>>>    // Note: If the table cannot be opened; the table is not considered to be an Alias.
88357>>>    Function UtilTableIsAlias Handle hTable Returns Boolean
88359>>>        String sPhysicalName sPhysicalNameCompare     
88359>>>        Boolean bOpened bOK
88359>>>        
88359>>>        Open hTable
88361>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpened
88364>>>        If (bOpened = False) Begin
88366>>>            Function_Return False
88367>>>        End                      
88367>>>>
88367>>>        
88367>>>        Get_Attribute DF_FILE_PHYSICAL_NAME of hTable to sPhysicalName 
88370>>>        Get _TableNameOnly sPhysicalName to sPhysicalName
88371>>>        Close hTable
88372>>>        
88372>>>        Move 0 to hTable
88373>>>        Repeat
88373>>>>
88373>>>            Get_Attribute DF_FILE_NEXT_USED of hTable to hTable
88376>>>            If (hTable > 0) Begin         
88378>>>                Open hTable
88380>>>                Get_Attribute DF_FILE_OPENED of hTable to bOpened
88383>>>                If (bOpened = True) Begin
88385>>>                    Get_Attribute DF_FILE_PHYSICAL_NAME of hTable to sPhysicalNameCompare 
88388>>>                    Close hTable
88389>>>                    Get _TableNameOnly sPhysicalNameCompare to sPhysicalNameCompare
88390>>>                    If (Uppercase(sPhysicalName) = Uppercase(sPhysicalNameCompare)) Begin
88392>>>                        Function_Return True
88393>>>                    End
88393>>>>
88393>>>                End
88393>>>>
88393>>>            End
88393>>>>
88393>>>        Until (hTable = 0)
88395>>>        
88395>>>        Function_Return False
88396>>>    End_Function
88397>>>    
88397>>>    // To Open a table with any driver.
88397>>>    // Note: If the driver is <> DATAFLEX_ID  - login credentials are used; it is then assumed 
88397>>>    //       that the proper login properties has been setup properly with the cSQLConnections object.
88397>>>    //
88397>>>    // If the open command fails the Err flag will be reset to false, at the end of the function!
88397>>>    // The found flag is still used to indicate if the open was successful or not. The function
88397>>>    // returns a True if successful (table could be opened).
88397>>>    //
88397>>>    // Using the "Open As" syntax with drivers means that we don't need to rely on .int file settings.
88397>>>    // This is good because with DFConnectionID's those credentials doesn't need to be available in
88397>>>    // the .int file (and probably aren't). As long as the login properties of this object have been
88397>>>    // set properly we can open the table.
88397>>>    //
88397>>>    // DAW Driver Syntax:
88397>>>    //  <CKId>:<Schema>#<Table>@<ConnectString>|<Filename>.int
88397>>>    //  Now the @<ConnectString> can be followed by a pipe character '|' followed by the name of the INT file.
88397>>>    //  Doing so, the driver will apply the information from the .INT file to the passed direct Open String.
88397>>>    //  Note that when an INT file has been passed, it will skip the keyword DRIVER_NAME, SERVER_NAME,
88397>>>    //  DATABASE_NAME and SCHEMA_NAME from the INT file because those are supposed to be supplied in the String already. 
88397>>>    //  Open mode; iMode = DF_SHARE or DF_EXCLUSIVE.
88397>>>    //
88397>>>    // DAW Driver Sample:
88397>>>    //   Open "MSSQLDRV:dbo#MyFile@SERVER=(local)\SQLEXPRESS;Trusted_Connection=yes;DATABASE=OrderEntry|options|intfile=MyFile.int"
88397>>>    //
88397>>>    // Mertech Driver Samples:
88397>>>    //   SQLFlex:   Open "sql_drv:\\<serverName>\<database>*<owner>*<tableName>=<numberFieds>" as table 
88397>>>    //   MySQLFlex: Open "mdsmysql:\\<serverName>\<database>*<tableName>=<numberFieds>" as table 
88397>>>    //   PgFlex:    Open "mdspgsql:\\<serverName>\<database>*<schema>*<tableName>=<numberFieds>" as table 
88397>>>    //   ORAFlex:   Open "ora_drv:\\<serverName>\<owner>*<tableName>=<numberFieds>" as table 
88397>>>    Function UtilTableOpen Integer hTable String sTableName Integer iMode Returns Boolean
88399>>>        String sDriverID sConnection sSchema sExt sTableNameShort sTableNameOrg
88399>>>        Boolean bOpen bMertechDriver
88399>>>        Integer iRetval              
88399>>>        tSQLConnection SQLConnection
88399>>>        tSQLConnection SQLConnection
88399>>>
88399>>>        Move sTableName to sTableNameOrg
88400>>>        If (hTable > 0 and Trim(sTableName) = "") Begin
88402>>>            Send Ignore_Error of Error_Object_Id 20529
88403>>>            Send Ignore_Error of Error_Object_Id DFERR_CANT_OPEN_DATA_FILE
88404>>>            Send Ignore_Error of Error_Object_Id CLIERR_CONNECTIONIDNOTFOUND
88405>>>            Open hTable
88407>>>            Send Trap_Error of Error_Object_Id 20529
88408>>>            Send Trap_Error of Error_Object_Id DFERR_CANT_OPEN_DATA_FILE
88409>>>            Send Trap_Error of Error_Object_Id CLIERR_CONNECTIONIDNOTFOUND
88410>>>            Function_Return (Found = True)
88411>>>        End
88411>>>>
88411>>>        
88411>>>        Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
88412>>>        Move SQLConnection.sDriverID to sDriverID
88413>>>        Get IsMertechDriver sDriverID to bMertechDriver
88414>>>        Move SQLConnection.sConnectionString to sConnection
88415>>>        Move SQLConnection.sSchema to sSchema
88416>>>        If (sSchema = "") Begin 
88418>>>            Get _SqlFindKeyWord CI_SQLDBO to sSchema 
88419>>>        End
88419>>>>
88419>>>
88419>>>        // We need to remove the ".int" part of the table name because
88419>>>        // the table name after the "#" in the connection syntax below wants the
88419>>>        // "bare" table name without any extension.
88419>>>        If (sDriverID <> DATAFLEX_ID) Begin
88421>>>            If (Lowercase(sTableName) contains ".int") Begin
88423>>>                Get ParseFileExtension sTableName to sExt
88424>>>                Move (Replace(("." + sExt), sTableName, "")) to sTableNameShort
88425>>>            End                                                                
88425>>>>
88425>>>            Else Begin
88426>>>                Move sTableName to sTableNameShort  
88427>>>                Move (Append(sTableName, ".int")) to sTableName
88428>>>            End   
88428>>>>
88428>>>            If (bMertechDriver = False) Begin
88430>>>                Move (sDriverID + ":" + sSchema + "#" + sTableNameShort + "@" + sConnection + "|options|intfile=" + sTableName) to sConnection
88431>>>                Move sConnection to sTableName
88432>>>            End
88432>>>>
88432>>>        End
88432>>>>
88432>>>
88432>>>        Send Ignore_Error of Error_Object_Id CLIERR_LOGIN_UNSUCCESSFUL
88433>>>        Send Ignore_Error of Error_Info_Object DFERR_FILE_ACCESS_VIOLATION 
88434>>>        If (hTable = 0) Begin
88436>>>            Get NextFreeFilelistSlot to hTable
88437>>>        End
88437>>>>
88437>>>
88437>>>        Case Begin
88437>>>            Case (sDriverID = MSSQLDRV_ID)
88439>>>                // If not df_exclusive mode, we use the "Open As" syntax.
88439>>>                If (iMode <> DF_EXCLUSIVE) Begin
88441>>>                    Open sTableName as hTable
88443>>>                End
88443>>>>
88443>>>                Else Begin
88444>>>                    Open hTable mode DF_Exclusive
88446>>>                End
88446>>>>
88446>>>                Case Break
88447>>>
88447>>>            Case (sDriverID = DB2_DRV_ID)
88450>>>                // If not df_exclusive mode, we use the "Open As" syntax.
88450>>>                If (iMode <> DF_EXCLUSIVE) Begin
88452>>>                    Open sTableName as hTable
88454>>>                End
88454>>>>
88454>>>                Else Begin
88455>>>                    Open hTable mode DF_Exclusive
88457>>>                End
88457>>>>
88457>>>                Case Break
88458>>>
88458>>>            Case (sDriverID = ODBC_DRV_ID)
88461>>>                // If not df_exclusive mode, we use the "Open As" syntax.
88461>>>                If (iMode <> DF_EXCLUSIVE) Begin
88463>>>                    Open sTableName as hTable
88465>>>                End
88465>>>>
88465>>>                Else Begin
88466>>>                    Open hTable mode DF_Exclusive
88468>>>                End
88468>>>>
88468>>>                Case Break 
88469>>>                
88469>>>            Case (sDriverID = SQLFLEX)                                                                               
88472>>>                // ToDo: What is the <owner>? Same as Schema?
88472>>>                // SQLFlex:   Open "sql_drv:\\<serverName>\<database>*<owner>*<tableName>=<numberFieds>" as table 
88472>>>                Move (SQLFLEX + ":\\" + SQLConnection.sServer + "\" + SQLConnection.sDatabase + SQLConnection.sSchema + "*" + sTableNameOrg) to sTableName
88473>>>                // If not df_exclusive mode, we use the "Open As" syntax.
88473>>>                If (iMode <> DF_EXCLUSIVE) Begin
88475>>>                    Open sTableName as hTable
88477>>>                End
88477>>>>
88477>>>                Else Begin
88478>>>                    Open hTable mode DF_Exclusive
88480>>>                End
88480>>>>
88480>>>                Case Break
88481>>>
88481>>>            Case (sDriverID = MDSMySQL)
88484>>>                // MySQLFlex: Open "mdsmysql:\\<serverName>\<database>*<tableName>=<numberFieds>" as table 
88484>>>                Move (MDSMySQL + ":\\" + SQLConnection.sServer + "\" + SQLConnection.sDatabase + "*" + sTableNameOrg) to sTableName
88485>>>                // If not df_exclusive mode, we use the "Open As" syntax.
88485>>>                If (iMode <> DF_EXCLUSIVE) Begin
88487>>>                    Open sTableName as hTable
88489>>>                End
88489>>>>
88489>>>                Else Begin
88490>>>                    Open hTable mode DF_Exclusive
88492>>>                End
88492>>>>
88492>>>                Case Break
88493>>>
88493>>>            Case (sDriverID = MDSPgSQL)
88496>>>                // PgFlex: Open "mdspgsql:\\<serverName>\<database>*<schema>*<tableName>=<numberFieds>" as table 
88496>>>                Move (MDSPgSQL + ":\\" + SQLConnection.sServer + "\" + SQLConnection.sDatabase + "*" + SQLConnection.sSchema + "*" + sTableNameOrg) to sTableName
88497>>>                // If not df_exclusive mode, we use the "Open As" syntax.
88497>>>                If (iMode <> DF_EXCLUSIVE) Begin
88499>>>                    Open sTableName as hTable
88501>>>                End
88501>>>>
88501>>>                Else Begin
88502>>>                    Open hTable mode DF_Exclusive
88504>>>                End
88504>>>>
88504>>>                Case Break
88505>>>
88505>>>            Case (sDriverID = ORAFLEX)
88508>>>                // ToDo: What is the <owner>? Same as Schema?
88508>>>                // ORAFlex: Open "ora_drv:\\<serverName>\<owner>*<tableName>=<numberFieds>" as table 
88508>>>                Move (ORAFLEX + ":\\" + SQLConnection.sServer + "\" + SQLConnection.sSchema + "*" + sTableName) to sTableName
88509>>>                // If not df_exclusive mode, we use the "Open As" syntax.
88509>>>                If (iMode <> DF_EXCLUSIVE) Begin
88511>>>                    Open sTableName as hTable
88513>>>                End
88513>>>>
88513>>>                Else Begin
88514>>>                    Open hTable mode DF_Exclusive
88516>>>                End
88516>>>>
88516>>>                Case Break
88517>>>
88517>>>            Case (sDriverID = DATAFLEX_ID)
88520>>>                If (sTableName <> "" and iMode <> DF_EXCLUSIVE) Begin
88522>>>                    Open sTableName as hTable
88524>>>                End
88524>>>>
88524>>>                Else If (iMode = DF_EXCLUSIVE) Begin
88527>>>                    Open hTable mode DF_Exclusive
88529>>>                End
88529>>>>
88529>>>                Else Begin
88530>>>                    Open hTable
88532>>>                End
88532>>>>
88532>>>                Case Break
88533>>>                
88533>>>            // ToDo: Logic needs to be expanded for Mertech drivers!
88533>>>
88533>>>            Case Else
88533>>>                Error DFERR_PROGRAM ("Invalid driver:" * sDriverID)
88534>>>>
88534>>>        Case End
88534>>>
88534>>>        Send Trap_Error of Error_Object_Id CLIERR_LOGIN_UNSUCCESSFUL 
88535>>>        Send Trap_Error of Error_Info_Object DFERR_FILE_ACCESS_VIOLATION
88536>>>        If (LastErr = CLIERR_LOGIN_UNSUCCESSFUL) Begin
88538>>>            Move False to Found
88539>>>        End
88539>>>>
88539>>>        // If open failed, the Err is set to true,
88539>>>        // but we don't want that because it could end our loop.
88539>>>        Move False to Err
88540>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpen
88543>>>
88543>>>        Function_Return bOpen
88544>>>    End_Function
88545>>>    
88545>>>    // Pass a table handle
88545>>>    // Returns True if the table exists in filelist.cfg.
88545>>>    Function UtilTableNumberIsInUse Handle hCheckTable Returns Boolean
88547>>>        Handle hTable
88547>>>        Boolean bFound
88547>>>        
88547>>>        Move False to bFound
88548>>>        Move 0 to hTable              
88549>>>        Repeat
88549>>>>
88549>>>            Get_Attribute DF_FILE_NEXT_USED of hTable to hTable
88552>>>            If (hTable > 0) Begin
88554>>>                If (hTable = hCheckTable) Begin
88556>>>                    Move True to bFound
88557>>>                End
88557>>>>
88557>>>            End
88557>>>>
88557>>>            If (bFound = True) Break
88560>>>        Until (hTable = 0)
88562>>>    
88562>>>        Function_Return (bFound = True)
88563>>>    End_Function
88564>>>    
88564>>>    Function UtilEnumerateOverlapFields Integer hTable Integer iField Returns String[]
88566>>>        String  sRetval sColumnName
88566>>>        String[] sOverlapFieldsArray
88567>>>        Integer iType iColumn iColumns 
88567>>>        Boolean bOpen bOverlap
88567>>>        
88567>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpen
88570>>>        If (bOpen = False) Begin
88572>>>            Open hTable
88574>>>        End
88574>>>>
88574>>>        
88574>>>        Move "" to sRetval
88575>>>        
88575>>>        Get_Attribute DF_FILE_NUMBER_FIELDS of hTable to iColumns
88578>>>        
88578>>>        for iColumn from 0 to iColumns
88584>>>>
88584>>>            Get_Attribute DF_FIELD_TYPE of hTable iColumn to iType
88587>>>            If (iField <> iColumn and iType <> DF_OVERLAP) Begin
88589>>>                Get_Attribute DF_FIELD_OVERLAP of hTable iField iColumn to bOverlap
88592>>>                If (bOverlap) Begin
88594>>>                    If (sRetval <> "") Begin
88596>>>                        Append sRetval ","
88597>>>                    End
88597>>>>
88597>>>                    Append sRetval iColumn
88598>>>                End
88598>>>>
88598>>>            End
88598>>>>
88598>>>        Loop
88599>>>>
88599>>>        
88599>>>        If (bOpen = False) Begin
88601>>>            Close hTable
88602>>>        End    
88602>>>>
88602>>>        
88602>>>        Move (StrSplitToArray(sRetval, ",")) to sOverlapFieldsArray
88603>>>        
88603>>>        Function_Return sOverlapFieldsArray
88604>>>    End_Function
88605>>>    
88605>>>    // Returns a struct array with all data types for the passed driver & dbtype.
88605>>>    Function UtilEnumerateColumnTypes String sDriverID Integer iDbType Returns tColumnType[]
88607>>>        tColumnType[] ColumnType               
88607>>>        tColumnType[] ColumnType               
88608>>>            
88608>>>        Case Begin
88608>>>            Case (iDbType = EN_dbTypeDataFlex)  
88610>>>                Get _UtilEnumerateDataFlexTypes to ColumnType
88611>>>                Case Break
88612>>>                
88612>>>            Case (iDbType = EN_DbTypeDB2)
88615>>>                Get _UtilEnumerateDB2Types to ColumnType
88616>>>                Case Break
88617>>>                
88617>>>            Case (iDbType = EN_DbTypeMSSQL)
88620>>>                Get _UtilEnumerateMSSQLTypes sDriverID to ColumnType
88621>>>                Case Break
88622>>>            
88622>>>            Case (sDriverID = MDSMySQL)            
88625>>>                Get _UtilEnumerateMySQLTypes to ColumnType
88626>>>                Case Break
88627>>>            
88627>>>            Case (sDriverID = ORAFLEX)
88630>>>                Get _UtilEnumerateOracleTypes to ColumnType
88631>>>                Case Break
88632>>>
88632>>>            Case (sDriverID = MDSPgSQL)   
88635>>>                Get _UtilEnumeratePostgreSQLTypes to ColumnType
88636>>>                Case Break
88637>>>        Case End
88637>>>        
88637>>>        Function_Return ColumnType
88638>>>    End_Function
