87192>>>    Function ApiTableMoveToFileSlot Integer iFromFileSlot Integer iToFileSlot String sDriverID Returns Boolean
87194>>>        Boolean bTmp bErr bOK 
87194>>>        String sTableName sDisplayName sFileName sDBOKeyWord sVal
87194>>>        
87194>>>        // We preserve the value of the Err flag, by saving its current state and resetting it before end of function.
87194>>>        Move Err to bTmp
87195>>>        Move False to Err
87196>>>        
87196>>>        Get AutoConnectionIDLogin to bOK
87197>>>        // First get the info for the current filelist slot:
87197>>>        Open iFromFileSlot                      
87199>>>        Get_Attribute DF_FILE_OPENED of iFromFileSlot to bOK
87202>>>        If (bOK = True) Begin
87204>>>            Get_Attribute DF_FILE_ROOT_NAME    of iFromFileSlot to sFileName
87207>>>            Get_Attribute DF_FILE_LOGICAL_NAME of iFromFileSlot to sTableName
87210>>>            Get_Attribute DF_FILE_DISPLAY_NAME of iFromFileSlot to sDisplayName
87213>>>            
87213>>>            //...then move it.
87213>>>            Set_Attribute DF_FILE_ROOT_NAME    of iToFileSlot to sFileName
87216>>>            Set_Attribute DF_FILE_LOGICAL_NAME of iToFileSlot to sTableName
87219>>>            Set_Attribute DF_FILE_DISPLAY_NAME of iToFileSlot to sDisplayName
87222>>>            
87222>>>            //...and finally remove the old filelist values.
87222>>>            Set_Attribute DF_FILE_ROOT_NAME    of iFromFileSlot to ""
87225>>>            Set_Attribute DF_FILE_LOGICAL_NAME of iFromFileSlot to ""
87228>>>            Set_Attribute DF_FILE_DISPLAY_NAME of iFromFileSlot to ""
87231>>>        End
87231>>>>
87231>>>        Close iFromFileSlot
87232>>>        
87232>>>        Move Err to bErr                     
87233>>>        Move bTmp to Err
87234>>>        Function_Return (bErr = False)
87235>>>    End_Function
