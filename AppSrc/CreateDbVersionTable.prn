84166>>>    // Same as SqlColumnChange but instead of passing a filelist number; pass the table name as a string. 
84166>>>    // The fourth & fifth arguments are optional, depending on the iDataType
84166>>>    // passed. For e.g. a DF_ASCII the iLen must be passed.                     // Optional: // Optional:  
84166>>>    Function SqlColumnChangeByTableName String sTableName String sColumnName Integer iDataType Integer iLen Integer iDec Returns Boolean
84168>>>        Integer iColumn iDbType iLength iDecimals
84168>>>        String sDriverID sStmt sAlterTable sAlterColumn sVal sDataType sRetval sLengthAndDecimals sNotNull
84168>>>        Boolean bExists bOK bFixed
84168>>>        Handle hTable
84168>>>        
84168>>>        Get psDriverID to sDriverID
84169>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
84170>>>        If (bOK = False) Begin
84172>>>            Function_Return False
84173>>>        End
84173>>>>
84173>>>        
84173>>>        Get UtilTableNameToHandle sTableName to hTable 
84174>>>        If (hTable = 0) Begin
84176>>>            Get NextFreeFilelistSlot to hTable
84177>>>        End
84177>>>>
84177>>>        Get SQLUtilColumnExists sTableName sColumnName to bExists
84178>>>        If (bExists = True) Begin
84180>>>            Function_Return False
84181>>>        End
84181>>>>
84181>>>
84181>>>        If (num_arguments > 3) Begin
84183>>>            Move iLen to iLength
84184>>>        End                     
84184>>>>
84184>>>        If (num_arguments > 4) Begin
84186>>>            Move iDec to iDecimals
84187>>>        End                
84187>>>>
84187>>>        
84187>>>        Get piDbType to iDbType
84188>>>        Get UtilColumnTypeToString sDriverID iDbType iDataType to sDataType
84189>>>        
84189>>>        Move False to Err   
84190>>>        Get _SqlProperTableName sTableName    to sTableName
84191>>>        Get _SqlFindKeyWord CI_SQLAlterTable  to sAlterTable
84192>>>        Get _SqlFindKeyWord CI_SQLAlterColumn to sAlterColumn
84193>>>        Get SQLUtilDefaultNullValue sDriverID iDbType iDataType to sNotNull
84194>>>
84194>>>        Get UtilColumnTypeFixed sDriverID iDbType iDataType to bFixed
84195>>>        If (bFixed = False) Begin
84197>>>            Get _SqlFormatLengthAndDecimalAsString iLength iDecimals to sLengthAndDecimals
84198>>>        End
84198>>>>
84198>>>        
84198>>>        Move (sAlterTable * sTableName * sAlterColumn * sColumnName * sDataType + sLengthAndDecimals * sNotNull) to sStmt
84199>>>        Send SqlUtilExecuteQuery sStmt sDriverID
84200>>>    
84200>>>        // We also need to remove the cache-file since the table has been changed
84200>>>        Get UtilDeleteCacheFile sTableName to bOK
84201>>>    
84201>>>        Function_Return (Err = False)    
84202>>>    End_Function    
