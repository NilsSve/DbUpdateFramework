91069>        Procedure OnClick
91072>            String sTableName sColumnName sInfoTxt1 sInfoTxt2 sDataType sFileList sDataPath
91072>            Integer iLength iDecimals iDataType iRetval iMin iMax 
91072>            Boolean bOK 
91072>            Handle hTable
91072>            
91072>            Get Value of oFileList_fm  to sFileList
91073>            Get Value of oTableName_fm to sTableName
91074>            Move (Trim(sTableName))    to sTableName
91075>            If (sTableName = "") Begin
91077>                Send Info_Box "You first need to enter a table name."
91078>                Procedure_Return
91079>            End
91079>            
91079>            Get psDataPath of (phoWorkspace(ghoApplication)) to sDataPath
91080>            Get vFolderFormat sDataPath to sDataPath
91081>            Set psDriverID                      of ghoDbUpdateFunctionLibrary to DATAFLEX_ID  
91082>            Get UtilTableNameToHandle of ghoDbUpdateFunctionLibrary sTableName to iRetval
91083>            If (iRetval <> 0) Begin
91085>                Send Info_Box ("Sorry, a table named: '" + sTableName + "' already exists in" * sFileList + "!")
91086>                Procedure_Return
91087>            End
91087>            
91087>            Get Value of oColumnName_fm      to sColumnName
91088>            Move (Trim(sColumnName))         to sColumnName
91089>            If (sColumnName = "") Begin
91091>                Send Info_Box "You need to enter a column name."
91092>                Procedure_Return
91093>            End
91093>            
91093>            Get Value        of oDataType_cf to sDataType    
91094>            Get SelectedType of oDataType_cf to iDataType   
91095>            Get Value        of oLength_sf   to iLength 
91096>            If (iLength < 1) Begin
91098>                Send Info_Box "You need to enter a proper length for the column"
91099>                Procedure_Return
91100>            End
91100>            Get Value of oDecimals_sf to iDecimals
91101>            
91101>            Get Value of oTableNo_sf  to hTable
91102>            Get Maximum_Position of oTableNo_sf to iMax
91103>            Get Minimum_Position of oTableNo_sf to iMin
91104>            If (hTable < iMin or hTable > iMax) Begin
91106>                Send Info_Box "The selected Filelist number must be in the range: 1-4095"
91107>                Procedure_Return
91108>            End
91108>            Get UtilTableNumberIsInUse of ghoDbUpdateFunctionLibrary hTable to bOK
91109>            If (bOK = True) Begin
91111>                Send Info_Box "The selected Filelist number exists and cannot be used to create a new table!"
91112>                Procedure_Return
91113>            End     
91113> 
91113>            // Reserved filelist numbers 48-50, 250-300
91113>            Move (hTable <> 48 and hTable <> 49 and hTable <> 50 and (hTable < 250 or hTable > 300)) to bOK
91114>            If (bOK = False) Begin
91116>                Send Info_Box "The selected Filelist number is in the range of reserved filelist numbers; 48-50 and 250-300"
91117>                Procedure_Return
91118>            End
91118>            
91118>            Get psToolTip1 to sInfoTxt1
91119>            Get psToolTip2 to sInfoTxt2
91120>            Get YesNo_Box (sInfoTxt1 + "\n\n" + sInfoTxt2 + "\n\nContinue?") to iRetval
91121>            If (iRetval <> MBR_Yes) Begin
91123>                Procedure_Return
91124>            End
91124>            
91124>            Send Cursor_Wait of Cursor_Control 
91125>            
91125>            Get ApiTableCreate of ghoDbUpdateFunctionLibrary hTable sTableName sTableName sTableName False False True to bOk
91126>            If (bOk = False) Begin
91128>                Send Info_Box "Sorry, it didn't work to create the table."
91129>                Procedure_Return
91130>            End        
91130>            
91130>            Get ApiTableChangeAttribute of ghoDbUpdateFunctionLibrary hTable DF_FILE_IS_SYSTEM_FILE True to bOK
91131>            Get ApiColumnAdd            of ghoDbUpdateFunctionLibrary hTable sColumnName iDataType iLength iDecimals to bOk 
91132>            If (bOK = True) Begin
91134>                Move ("Column '" + sColumnName + "'" * sDataType * String(iLength) + ", was successfully added to '" + sTableName + "'" * "(at filelist slot:" * String(hTable) + ")") to sInfoTxt1
91135>            End                                                      
91135>            Else Begin
91136>                Move ("The column could NOT be added. Either column" * sColumnName * "already exists or the Table name is incorrect?") to sInfoTxt1
91137>            End
91137>            Send Cursor_Ready of Cursor_Control 
91138>            Send Info_Box sInfoTxt1
91139>        End_Procedure
91140>    
91140>    End_Object
