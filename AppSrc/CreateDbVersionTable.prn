81003>>>>>>>    Procedure Page_Object Integer iState
81005>>>>>>>        Handle hWnd
81005>>>>>>>
81005>>>>>>>        Get Window_Handle To hWnd
81006>>>>>>>        If (hWnd=0 and iState) Begin
81008>>>>>>>            Set Window_Style To PBS_VERTICAL (private_pbVertical(self))
81009>>>>>>>            Set Window_Style To PBS_SMOOTH   (private_pbSmooth(self))
81010>>>>>>>            Forward Send Page_Object True
81012>>>>>>>        End
81012>>>>>>>>
81012>>>>>>>        Else Forward Send Page_Object iState
81015>>>>>>>     
81015>>>>>>>        // Handle tooltip support....
81015>>>>>>>        If (iState = 0) Begin
81017>>>>>>>            Send RequestDeleteToolTip
81018>>>>>>>        End 
81018>>>>>>>>
81018>>>>>>>        Else Begin
81019>>>>>>>            Send RequestAddToolTip
81020>>>>>>>        End
81020>>>>>>>>
81020>>>>>>>    End_Procedure
