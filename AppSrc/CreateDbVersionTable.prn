91873>>>>>
91873>>>>>    //****************************************************************************
91873>>>>>    // If workspaces are used, we will send the message EnumerateWorkspaceData
91873>>>>>    // To the workspace object passing the an object and message To send back
91873>>>>>    // To this object. It is expected that the workspace object will send this
91873>>>>>    // message for every line Of information it wants displayed (passing the
91873>>>>>    // information To be displayed
91873>>>>>    //****************************************************************************
91873>>>>>    Register_Procedure EnumerateWorkspaceData Integer hObjId Integer hmMessId
91873>>>>>
91873>>>>>    Procedure Show_ServicePack
91875>>>>>        String sKey sVersion sDataFlex
91875>>>>>        Handle hoRegistry
91875>>>>>        Boolean bExists bOpened
91875>>>>>
91875>>>>>        Move "DataFlex"        to sDataFlex
91876>>>>>
91876>>>>>        Get Create U_cRegistry to hoRegistry
91877>>>>>        Set phRootKey of hoRegistry to HKEY_LOCAL_MACHINE
91878>>>>>        Set pfAccessRights of hoRegistry to KEY_READ
91879>>>>>        Get KeyExists of hoRegistry "SOFTWARE\Wow6432Node" to bExists
91880>>>>>
91880>>>>>        If (bExists) Begin
91882>>>>>            Move ("SOFTWARE\Wow6432Node\Data Access Worldwide\" + sDataFlex + "\" + SysConf (SYSCONF_DATAFLEX_REV)) to sKey
91883>>>>>        End
91883>>>>>>
91883>>>>>        Else Begin
91884>>>>>            Move ("SOFTWARE\Data Access Worldwide\"             + sDataFlex + "\" + SysConf (SYSCONF_DATAFLEX_REV)) to sKey
91885>>>>>        End
91885>>>>>>
91885>>>>>        Get KeyExists of hoRegistry sKey to bExists
91886>>>>>        If (bExists) Begin
91888>>>>>            Get OpenKey of hoRegistry sKey to bOpened
91889>>>>>            If (bOpened) Begin
91891>>>>>                Get ValueExists of hoRegistry "CurrentVersionDescription" to bExists
91892>>>>>                If (bExists) Begin
91894>>>>>                    Get ReadString of hoRegistry "CurrentVersionDescription" to sVersion
91895>>>>>                End
91895>>>>>>
91895>>>>>                Send CloseKey of hoRegistry
91896>>>>>            End
91896>>>>>>
91896>>>>>        End
91896>>>>>>
91896>>>>>        Send Destroy of hoRegistry
91897>>>>>
91897>>>>>        If (sVersion <> "") Begin
91899>>>>>           Send AppendTextLn sVersion
91900>>>>>           Send AppendTextLn ""
91901>>>>>        End
91901>>>>>>
91901>>>>>    End_Procedure
91902>>>>>
91902>>>>>    Procedure Show_WorkspaceInformation
91904>>>>>        Integer hoWorkspace
91904>>>>>
91904>>>>>        If (ghoApplication <> 0) Begin
91906>>>>>            Get phoWorkspace of ghoApplication to hoWorkspace
91907>>>>>            If (hoWorkspace <> 0) Begin
91909>>>>>                Send EnumerateWorkspaceData of hoWorkspace Self msg_AppendTextLn
91910>>>>>            End
91910>>>>>>
91910>>>>>        End
91910>>>>>>
91910>>>>>    End_Procedure
91911>>>>>
91911>>>>>    //****************************************************************************
91911>>>>>    // If connection ids are used, we will send the message EnumerateConnections
91911>>>>>    // to the connection manager object passing the an object and message to send 
91911>>>>>    // back to this object. It is expected that the connection manager object will 
91911>>>>>    // send this message for every line Of information it wants displayed (passing 
91911>>>>>    // the information To be displayed
91911>>>>>    //****************************************************************************
91911>>>>>    Register_Procedure EnumerateConnections Integer hObjId Integer hmMessId
91911>>>>>
91911>>>>>    Procedure Show_ConnectionIdInformation
91913>>>>>        If (ghoConnection > 0) Begin
91915>>>>>            Send EnumerateConnections of ghoConnection Self (RefProc(AppendTextLn))
91916>>>>>            Send AppendTextLn ""
91917>>>>>        End
91917>>>>>>
91917>>>>>    End_Procedure
91918>>>>>
91918>>>>>    Function VersionStr Integer iVer Integer iRev Integer iBld Returns String
91920>>>>>        Function_Return (String (iVer) - "." - String (iRev) - "." - String (iBld))
91921>>>>>    End_Function
91922>>>>>
91922>>>>>    Procedure Show_Versions
91924>>>>>        Integer iVersion iRevision iBuild
91924>>>>>
91924>>>>>        Version_information iVersion iRevision iBuild
91926>>>>>
91926>>>>>        Send AppendTextLn (SFormat (C_$RuntimeVersion, VersionStr(self,iVersion,iRevision,iBuild) ))
91927>>>>>        Send AppendTextLn (SFormat (C_$PackageVersion, VersionStr(self,PKG_VERSION, PKG_REVISION, PKG_BUILD) ))
91928>>>>>        Send AppendTextLn (SFormat (C_$FMACVersion, VersionStr(self,FMAC_VERSION, FMAC_REVISION, FMAC_BUILD) ))
91929>>>>>    End_Procedure                                           
91930>>>>>    
91930>>>>>    Function IsDAWSQLDriver String sDriverID Returns Boolean
91932>>>>>        Boolean bOK
91932>>>>>        Move (sDriverID = MSSQLDRV_ID or sDriverID = DB2_DRV_ID or sDriverID = ODBC_DRV_ID) to bOK
91933>>>>>        Function_Return bOK
91934>>>>>    End_Function
91935>>>>>
91935>>>>>    Function IsMertechDriver String sDriverID Returns Boolean
91937>>>>>        Boolean bOK   
91937>>>>>        Function_Return bOK
91938>>>>>    End_Function
91939>>>>>
91939>>>>>    //***
91939>>>>>    //*** BW
91939>>>>>    //*** Procedure: Show_Drivers
91939>>>>>    //*** Purpose  : Show loaded database drivers
91939>>>>>    //***
91939>>>>>
91939>>>>>    Procedure Show_Drivers
91941>>>>>        String sDriverID sVersion sClient sMertechSQLFlexVersion sValue
91941>>>>>        Integer iNumberOfDrivers iDriver iClient iUsersMax iSerialNo iNumServers iCount
91941>>>>>        Handle hoCLIHandler hoBtrvHandler
91941>>>>>        Boolean bStudioLicense bIsDAWDriver bIsMertechDriver
91941>>>>>
91941>>>>>        Move False to bStudioLicense
91942>>>>>
91942>>>>>        Get Create U_cCLIHandler      to hoCLIHandler
91943>>>>>        Get Create U_cDFBtrDrvHandler to hoBtrvHandler 
91944>>>>>
91944>>>>>        // For testing purposes:        
91944>>>>>//        Send Ignore_Error of Error_Object_Id DFERR_CANT_LOAD_DLL
91944>>>>>//        Load_Driver MSSQLDRV_ID
91944>>>>>//        Load_Driver ODBC_DRV_ID
91944>>>>>//        Load_Driver DB2_DRV_ID
91944>>>>>//        Send Trap_Error of Error_Object_Id DFERR_CANT_LOAD_DLL
91944>>>>>//
91944>>>>>//        #IFDEF DUF_Use_Mertech_Drivers  
91944>>>>>//            Send Ignore_Error of Error_Object_Id DFERR_CANT_LOAD_DLL
91944>>>>>//            Load_Driver SQLFLEX 
91944>>>>>//            Load_Driver MDSPgSQL
91944>>>>>//            Load_Driver MDSMySQL
91944>>>>>//            Load_Driver ORAFLEX
91944>>>>>//            Send Trap_Error of Error_Object_Id DFERR_CANT_LOAD_DLL
91944>>>>>//        #ENDIF
91944>>>>>        Move False to Err
91945>>>>>        
91945>>>>>        // Loop through all loaded drivers.
91945>>>>>        Get_Attribute DF_NUMBER_DRIVERS to iNumberOfDrivers
91948>>>>>        If (iNumberOfDrivers > 1) Begin
91950>>>>>            Send AppendTextLn ""
91951>>>>>        End
91951>>>>>>
91951>>>>>        For iDriver from 1 to iNumberOfDrivers           
91957>>>>>>
91957>>>>>            // For some weird reason it can happen that - when using Mertech drivers - that the driver index
91957>>>>>            // was increased in the CLI array, but it has no value. In that case a "Bad parameter..." error
91957>>>>>            // would be thrown, so we safeguard from that here.
91957>>>>>            Send Ignore_Error of Error_Object_Id DFERR_BAD_PARAMETER
91958>>>>>            Get_Attribute DF_DRIVER_NAME of iDriver to sDriverID
91961>>>>>            Send Trap_Error of Error_Object_Id DFERR_BAD_PARAMETER
91962>>>>>            Get IsDAWSQLDriver sDriverID to bIsDAWDriver
91963>>>>>            Get IsMertechDriver sDriverID to bIsMertechDriver
91964>>>>>
91964>>>>>            If (sDriverID = DFBTRDRV_ID or bIsDAWDriver = True or bIsMertechDriver = True) Begin
91966>>>>>
91966>>>>>                // Pervasive/Btrieve database
91966>>>>>                If (sDriverID = DFBTRDRV_ID) Begin
91968>>>>>                    Get CKRevision of hoBtrvHandler to sVersion
91969>>>>>                    Get PSQLLocalEngineVersionInfo of hoBtrvHandler 0 to sClient
91970>>>>>                    If (sClient <> "0.0.0") Begin
91972>>>>>                        Send AppendTextLn (SFormat (C_$Pervasive_Local_Engine_Version, sClient))
91973>>>>>                    End
91973>>>>>>
91973>>>>>                    Get PSQLServerEngineVersionInfo of hoBtrvHandler 0 to sClient
91974>>>>>                    If (sClient <> "0.0.0") Begin
91976>>>>>                        Send AppendTextLn (SFormat (C_$Pervasive_Server_Engine_Version, sClient))
91977>>>>>                    End
91977>>>>>>
91977>>>>>                End
91977>>>>>>
91977>>>>>
91977>>>>>                Else Begin
91978>>>>>                    Set psDriverID of hoCLIHandler to sDriverID 
91979>>>>>                    Move 0 to iNumServers
91980>>>>>                    If (sDriverID <> DATAFLEX_ID) Begin
91982>>>>>                        Get_Attribute DF_DRIVER_NUMBER_SERVERS of iDriver to iNumServers
91985>>>>>                    End
91985>>>>>>
91985>>>>>                    
91985>>>>>                    If (bIsDAWDriver = True) Begin
91987>>>>>                        If (sDriverID = MSSQLDRV_ID) Begin
91989>>>>>                            // This info is only available for the MS SQL driver:
91989>>>>>                            Get_Attribute DF_DRIVER_SQLSERVER_CLIENT_VERSION of iDriver to iClient
91992>>>>>                            If (iClient = 13) Move C_$SQLSERVER2016DRVRSTR              to sClient
91995>>>>>                            If (iClient = 12) Move C_$SQLSERVER2014DRVRSTR              to sClient
91998>>>>>                            If (iClient = 11) Move C_$SQL_Server_Native_Client_11_0     to sClient
92001>>>>>                            If (iClient = 10) Move C_$SQL_Server_Native_Client_10_0     to sClient
92004>>>>>                            If (iClient = 9)  Move C_$SQL_Native_Client                 to sClient
92007>>>>>                            If (iClient = 8)  Move C_$SQL_Server_SQL_Server_2000_client to sClient
92010>>>>>                            If (sClient <> "") Begin
92012>>>>>                                Move ("    " + sClient) to sClient
92013>>>>>                            End
92013>>>>>>
92013>>>>>                        End
92013>>>>>>
92013>>>>>                    
92013>>>>>                        Get CKRevision of hoCLIHandler to sVersion 
92014>>>>>                    End
92014>>>>>>
92014>>>>>                    
92014>>>>>                    If (bIsMertechDriver = True) Begin
92016>>>>>                    End
92016>>>>>>
92016>>>>>                    
92016>>>>>                    // If the serialnumber is = 0, it means that the
92016>>>>>                    // Studio licens is in use and there is no
92016>>>>>                    // number of max users defined because the driver is
92016>>>>>                    // relying on the info from the VDF license.
92016>>>>>                    If (bStudioLicense = False) Begin
92018>>>>>                        Get SerialNumber of hoCLIHandler to iSerialNo
92019>>>>>                        Move (iSerialNo = 0) to bStudioLicense
92020>>>>>                    End
92020>>>>>>
92020>>>>>                End
92020>>>>>>
92020>>>>>                Send AppendTextLn (SFormat (C_$DatabaseDriver, (sDriverID * "-" * (C_$Version + ": " + sVersion))))
92021>>>>>                If (iNumServers <> 0) Begin
92023>>>>>                    For iCount from 1 to iNumServers
92029>>>>>>
92029>>>>>                        Get_Attribute DF_DRIVER_SERVER_NAME of iDriver iCount to sValue 
92032>>>>>                        Send AppendTextLn ("    " + "Server/DSN:" * sValue)
92033>>>>>                    Loop
92034>>>>>>
92034>>>>>                End
92034>>>>>>
92034>>>>>                If (sClient <> "" and sDriverID = MSSQLDRV_ID) Begin
92036>>>>>                    Send AppendTextLn sClient
92037>>>>>                End  
92037>>>>>>
92037>>>>>            End
92037>>>>>>
92037>>>>>        Loop
92038>>>>>>
92038>>>>>
92038>>>>>        Send AppendTextLn ""
92039>>>>>        If (bStudioLicense = False) Begin
92041>>>>>            Get MaxUsers of hoCLIHandler to iUsersMax 
92042>>>>>            Send AppendTextLn (SFormat (C_$Max_DbDriver_Licensed_User_Count, iUsersMax))
92043>>>>>        End
92043>>>>>>
92043>>>>>        Else Begin
92044>>>>>            Send AppendTextLn C_$VDF_Studio_License_Text
92045>>>>>        End
92045>>>>>>
92045>>>>>        Send Destroy of hoCLIHandler
92046>>>>>        Send Destroy of hoBtrvHandler
92047>>>>>    End_Procedure
92048>>>>>
92048>>>>>    Procedure Show_HelpFile
92050>>>>>        String sHelpFile
92050>>>>>        Integer eHelpType
92050>>>>>
92050>>>>>        If (ghoApplication <> 0) Begin
92052>>>>>            Get peHelpType Of ghoApplication To eHelpType
92053>>>>>            If (eHelpType = htHtmlHelp and ghoHtmlHelp) Begin
92055>>>>>                Get GetHelpFile Of ghoHtmlHelp To sHelpFile
92056>>>>>            End
92056>>>>>>
92056>>>>>            Else If (eHelpType = htWinHelp and Help_object_id) Begin
92059>>>>>                Get Help_filename Of Help_object_id To sHelpFile
92060>>>>>            End
92060>>>>>>
92060>>>>>            Else Begin
92061>>>>>                Move C_$ThereIsNoHelpfileDefined To sHelpFile
92062>>>>>            End
92062>>>>>>
92062>>>>>
92062>>>>>            Send AppendTextLn (SFormat (C_$HelpFile, sHelpFile))
92063>>>>>        End
92063>>>>>>
92063>>>>>    End_Procedure
92064>>>>>
