90126>>>    // The normal connection string looks something like this;
90126>>>    // SERVER=.\SQLEXPRESS; DATABASE=OrderEntry; TRUSTED_CONNECTION=Yes; ,0
90126>>>    // ...and the full connection string looks like this;
90126>>>    // DFConnectionId OrderEntry, SERVER=.\SQLEXPRESS; DATABASE=OrderEntry; TRUSTED_CONNECTION=Yes; ,0
90126>>>    Function psFullConnectionString Returns String
90128>>>        String sConnectionID sConnectionString
90128>>>        If (ghoSQLConnectionHandler = 0) Begin
90130>>>            Error DFERR_PROGRAM "ghoSQLConnectionHandler = 0! This indicates that NO ConnectionID has been setup by the programmer."
90131>>>>
90131>>>            Function_Return
90132>>>        End                                                                   
90132>>>>
90132>>>        Get psConnectionID     of ghoSQLConnectionHandler to sConnectionID                       
90133>>>        Move (Trim(sConnectionID)) to sConnectionID
90134>>>        Get psConnectionString of ghoSQLConnectionHandler to sConnectionString
90135>>>        Function_Return (CS_SQLConnectionIDText * sConnectionID + "," * String(sConnectionString))
90136>>>    End_Function
