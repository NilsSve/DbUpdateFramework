86745>>>        End
86745>>>>
86745>>>
86745>>>        Move SQLConnection.sDatabase         to sDatabase   
86746>>>        Move SQLConnection.sConnectionID     to sConnectionID
86747>>>        Move SQLConnection.sConnectionString to sConnectionString 
86748>>>        If (sConnectionID = "" or sConnectionString = "") Begin
86750>>>            Error DFERR_PROGRAM ("The SQL connection info has NOT been setup. Could not convert table:" * String(hTable) * "to SQL")
86751>>>>
86751>>>            Function_Return False
86752>>>        End  
86752>>>>
86752>>>        
86752>>>        Get AutoConnectionIDLogin to bOK
86753>>>        Open hTable
86755>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpened
86758>>>        If (bOpened = False) Begin 
86760>>>            Error DFERR_PROGRAM ("Could not open table number:" * String(hTable))
86761>>>>
86761>>>            Function_Return False
86762>>>        End                      
86762>>>>
86762>>>        Move 0 to hToTable
86763>>>        
86763>>>        Get_Attribute DF_FILE_DISPLAY_NAME of hTable to sDisplayName
86766>>>        Get_Attribute DF_FILE_ROOT_NAME    of hTable to sRootName
86769>>>        Get _TableNameOnly sRootName                 to sRootName
86770>>>        Move (sRootName + ".int")                    to sPhysicalName
86771>>>        
86771>>>        Case Begin   
86771>>>            Case (sDriverID = MSSQLDRV_ID)
86773>>>                Case Break
86774>>>            Case (sDriverID = ODBC_DRV_ID)
86777>>>                Case Break
86778>>>            Case (sDriverID = DB2_DRV_ID)
86781>>>                Move SQLConnection.sBaseTableSpace  to sBaseTableSpace
86782>>>                Move SQLConnection.sLongTableSpace  to sLongTableSpace
86783>>>                Move SQLConnection.sIndexTableSpace to sIndexTableSpace
86784>>>                Case Break
86785>>>            Case (sDriverID = ORAFLEX)
86788>>>                Move SQLConnection.sBaseTableSpace  to sBaseTableSpace
86789>>>                Move SQLConnection.sIndexTableSpace to sIndexTableSpace
86790>>>                Case Break
86791>>>            Case (sDriverID = MDSMySQL) 
86794>>>                Case Break
86795>>>            Case (sDriverID = MDSPgSQL)
86798>>>                Move SQLConnection.sBaseTableSpace  to sBaseTableSpace
86799>>>                Move SQLConnection.sIndexTableSpace to sIndexTableSpace
86800>>>                Case Break  
86801>>>            Case (sDriverID = DATAFLEX_ID)
86804>>>                Case Break
86805>>>            Case Else
86805>>>                Error DFERR_PROGRAM "Wrong database driver passed to the 'ApiTableConvertToSQL_Ex' function."
86806>>>>
86806>>>                Case Break
86807>>>        Case End
86807>>>        
86807>>>        Move False to Err   
86808>>>
86808>>>        If (bMertechDriver = True) Begin  
86810>>>            // Note: This function also sets the Err flag.
86810>>>            Get _MertechApiTableConvertToSQL hTable sRootName sDatabase sDriverID sBaseTableSpace sIndexTableSpace bCopyData to bOK
86811>>>        End
86811>>>>
86811>>>
86811>>>        If (bMertechDriver = False) Begin
86813>>>            Structure_Start hToTable sDriverID
86814>>>                Structure_Copy hTable to hToTable
86815>>>                
86815>>>                Set_Attribute DF_FILE_PHYSICAL_NAME of hToTable to sPhysicalName  
86818>>>
86818>>>                If (sDriverID <> DATAFLEX_ID) Begin
86820>>>                    If (bUseConnectionID = True) Begin
86822>>>                        Set_Attribute DF_FILE_LOGIN     of hToTable to (CS_DFCONNID + "=" + sConnectionID)
86825>>>                    End
86825>>>>
86825>>>                    Else Begin
86826>>>                        Set_Attribute DF_FILE_LOGIN     of hToTable to sConnectionString
86829>>>                    End
86829>>>>
86829>>>                    
86829>>>                    Set_Attribute DF_FILE_TABLE_CHARACTER_FORMAT   of hToTable to sANSI_OEM
86832>>>                    Set_Attribute DF_FILE_RECNUM_TABLE             of hToTable to bRecnum
86835>>>                    
86835>>>                    If (sSchema <> "") Begin
86837>>>                        Set_Attribute DF_FILE_OWNER                of hToTable to sSchema
86840>>>                    End
86840>>>>
86840>>>        
86840>>>                    If (sDriverID = DB2_DRV_ID) Begin                           
86842>>>                        If (sLongTableSpace <> "") Begin
86844>>>                            Set_Attribute DF_FILE_LONG_TABLESPACE  of hToTable to sLongTableSpace
86847>>>                        End
86847>>>>
86847>>>                        If (sBaseTableSpace <> "") Begin
86849>>>                            Set_Attribute DF_FILE_TABLE_TABLESPACE of hToTable to sBaseTableSpace
86852>>>                        End
86852>>>>
86852>>>                        If (sIndexTableSpace <> "") Begin
86854>>>                            Set_Attribute DF_FILE_INDEX_TABLESPACE of hToTable to sIndexTableSpace
86857>>>                        End
86857>>>>
86857>>>                    End   
86857>>>>
86857>>>                End 
86857>>>>
86857>>>                       
86857>>>            Structure_End hToTable        
86859>>>        End
86859>>>>
86859>>>        
86859>>>        Move (not(Err)) to bOK
86860>>>        If (bOK = True and bCopyData = True and bMertechDriver = False) Begin
86862>>>            Get ApiTableCopyData hTable sPhysicalName sRootName sDriverID to bOK
86863>>>        End
86863>>>>
86863>>>
86863>>>        If (bMertechDriver = True) Begin
86865>>>            Open hTable
86867>>>        End
86867>>>>
86867>>>        
86867>>>        // This must be after copying data...    
86867>>>        If (Err = False) Begin
86869>>>            Set_Attribute DF_FILE_ROOT_NAME of hTable to (sDriverID + ":" + sRootName)
86872>>>            // We also adjust the display name by prefixing it by the schema name;
86872>>>            If (not(Lowercase(sDisplayName) contains Lowercase(sSchema + "."))) Begin
86874>>>                // The max length for the display_name is 31 characters...
86874>>>                If (Length(sSchema + "." + sDisplayName) < 31) Begin
86876>>>                    Set_Attribute DF_FILE_DISPLAY_NAME of hTable to (Lowercase(sSchema) + "." + sDisplayName)
86879>>>                End
86879>>>>
86879>>>            End
86879>>>>
86879>>>        End
86879>>>>
86879>>>        
86879>>>        Move (not(Err)) to bOK
86880>>>        Function_Return (bOK = True)
86881>>>    End_Function                 
86882>>>    
86882>>>    // Calls a driver function directly to copy data from one table to another (table structures needs to be the same).
86882>>>    // It will first drop all indicies, copy the data and then recreate indicies. 
86882>>>    // An error log file with the sRootname + ".err" will be created in the Data folder.
86882>>>    Function ApiTableCopyData Integer hFromTable String sPhysicalName String sRootName String sDriverID Returns Boolean
86884>>>        Boolean bOpened bOK
86884>>>        Integer hToTable iIndex iCount iRetval iVoid iOrgFreq
86884>>>        String sErrorFile sEmpty sPath
86884>>>        
86884>>>        Get_Attribute DF_FILE_NEXT_EMPTY of 0 to hToTable
86887>>>        Get AutoConnectionIDLogin to bOK
86888>>>        If (sDriverID = DATAFLEX_ID) Begin
86890>>>            Send IncreaseSortBufferSize  
86891>>>//            Send SetAllIndexesToBatch hToTable
86891>>>        End                          
86891>>>>
86891>>>
86891>>>        Move False to Err
86892>>>        Open sPhysicalName as hToTable
86894>>>        Get_Attribute DF_FILE_OPENED of hToTable to bOpened
86897>>>        If (bOpened = False) Begin
86899>>>            Function_Return False
86900>>>        End                      
86900>>>>
86900>>>        
86900>>>        Move "" to sEmpty 
86901>>>        Move False to Err   
86902>>>        Move True to bOK       
86903>>>        
86903>>>        Get_Attribute DF_RUNTIME_PROGRESS_FREQUENCY to iOrgFreq
86906>>>        Set_Attribute DF_RUNTIME_PROGRESS_FREQUENCY to 10        
86909>>>        If (sDriverID <> DATAFLEX_ID) Begin
86911>>>            // Remove all indices to speed up copying of data:
86911>>>            Call_Driver hToTable sDriverID Function CLI_DROPINDICES Callback Self Passing sEmpty sEmpty iVoid Result iRetval
86916>>>            If (iRetval <> 0) Begin
86918>>>                Error DFERR_PROGRAM ("Failed dropping indices for table:" * sRootName)
86919>>>>
86919>>>                Function_Return False
86920>>>            End
86920>>>>
86920>>>        End
86920>>>>
86920>>>        
86920>>>        Move (sRootName + ".err") to sErrorFile  
86921>>>        Move 0 to iIndex           
86922>>>        Move False to Err   
86923>>>        
86923>>>        Copy_Records hFromTable to hToTable using 0 Callback Self
86926>>>                  
86926>>>        If (Err = False) Begin             
86928>>>            Get psHome of (phoWorkspace(ghoApplication)) to sPath  
86929>>>            Get vDeleteFile (sPath + sErrorFile) to iRetval
86930>>>        End                                                          
86930>>>>
86930>>>        
86930>>>        If (sDriverID <> DATAFLEX_ID) Begin
86932>>>            // Recreate indices:
86932>>>            Call_Driver hToTable sDriverID Function CLI_CREATEINDICES Callback Self Passing sEmpty sEmpty iVoid Result iRetval
86937>>>        End
86937>>>>
86937>>>        
86937>>>        Close hToTable
86938>>>        Set_Attribute DF_RUNTIME_PROGRESS_FREQUENCY to iOrgFreq
86941>>>        
86941>>>        If (bOK = True) Begin
86943>>>            Move (not(Err)) to bOK
86944>>>        End
86944>>>>
86944>>>        
86944>>>        If (ghoStatusPanel <> 0) Begin
86946>>>            Set Message_Text of ghoStatusPanel to ""
86947>>>            Set Action_Text  of ghoStatusPanel to ""
86948>>>        End
86948>>>>
86948>>>        
86948>>>        Function_Return (bOK = True)
86949>>>    End_Function 
86950>>>
86950>>>    Procedure IncreaseSortBufferSize
86952>>>        String sNull
86952>>>        Integer iSortBufferSize
86952>>>        Boolean bBufferSet
86952>>>    
86952>>>        Move "" to sNull
86953>>>        Move (1024 * 128) to iSortBufferSize
86954>>>        Call_Driver 0 DATAFLEX_ID Function FLEX_SET_MAX_SORT_BUFFER Callback Self Passing sNull sNull iSortBufferSize Result bBufferSet
86959>>>    
86959>>>    End_Procedure     
86960>>>    
86960>>>    Procedure SetAllIndexesToBatch Handle hTable
86962>>>        Integer iLastIndex iIndex iNumSegments iIndexType
86962>>>        String sTable
86962>>>    
86962>>>        If (hTable > 0) Begin
86964>>>            Close hTable
86965>>>            Open hTable Mode DF_EXCLUSIVE
86967>>>            Get_Attribute DF_FILE_LAST_INDEX_NUMBER of hTable to iLastIndex
86970>>>            for iIndex from 1 to iLastIndex
86976>>>>
86976>>>                Get_Attribute DF_INDEX_NUMBER_SEGMENTS of hTable iIndex to iNumSegments
86979>>>                If (iNumSegments > 0) Begin
86981>>>                    Set_Attribute DF_INDEX_TYPE of hTable iIndex to DF_INDEX_TYPE_BATCH
86984>>>                End
86984>>>>
86984>>>            Loop
86985>>>>
86985>>>            Close hTable
86986>>>        End
86986>>>>
86986>>>    End_Procedure 
86987>>>    
86987>>>
86987>>>    // The bANSI parameter's default value = True, meaning a table in ANSI format will be created.
86987>>>    // i.e. DF_FILE_TABLE_CHARACTER_FORMAT {"OEM"|"ANSI"}
86987>>>    Function ApiTableCreate Handle hTable String sRoot String sDisplay String sTableName Boolean bUseConnectionID Boolean bANSI Boolean bRecnum Returns Boolean
86989>>>        Handle hFile
86989>>>        String sConnectionID sPhysicalFile sANSI_OEM sVal sSchema sOriginalDriverID sDriverID
86989>>>        Integer iColumn 
86989>>>        Boolean bOk bExists bMertechDriver
86989>>>        tSQLConnection SQLConnection
86989>>>        tSQLConnection SQLConnection
86989>>>
86989>>>        If (ghoProgressBar <> 0) Begin
86991>>>            Send DoAdvance of ghoProgressBar
86992>>>        End
86992>>>>
86992>>>        
86992>>>        // First check if the passed filenumber already exists; in case we do nothing
86992>>>        Get UtilTableNumberIsInUse hTable to bOk
86993>>>        If (bOk = True) Begin
86995>>>            Function_Return False
86996>>>        End
86996>>>>
86996>>>        
86996>>>        Get psDriverID to sDriverID
86997>>>        // If this is a SQL based driver we also check if the table exists
86997>>>        // in the SQL back end; in case we do nothing.
86997>>>        Get IsSQLDriver sDriverID to bOk
86998>>>        If (bOk = True) Begin
87000>>>            Get SqlUtilCheckIfTableHandleExists hTable sDriverID to bExists
87001>>>            If (bExists = True) Begin
87003>>>                Function_Return False
87004>>>            End                      
87004>>>>
87004>>>        
87004>>>            // Get all connection properties
87004>>>            Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection  
87005>>>            Move SQLConnection.sSchema to sSchema
87006>>>            If (sSchema = "") Begin
87008>>>                Get _SqlFindKeyWord CI_SQLDBO to sSchema  
87009>>>            End
87009>>>>
87009>>>        End
87009>>>>
87009>>>        
87009>>>        Move CS_ANSI_Txt to sANSI_OEM
87010>>>        If (num_arguments > 6) Begin
87012>>>            If (bANSI = False) Begin
87014>>>                Move CS_OEM_Txt to sANSI_OEM
87015>>>            End
87015>>>>
87015>>>        End  
87015>>>>
87015>>>        
87015>>>        // Mertech drivers don't use connection id's, so if the passed bUseConnectionID = True that
87015>>>        // is a programmer's error and we auto-correct for it here.
87015>>>        // This is also a bit messy. If a Mertech driver is used and we want to create a new table,
87015>>>        // we first need to create it as embedded (DataFlex) and then convert it to SQL (!)
87015>>>        // So we set the driver ID temporarily to "DataFlex" to get the table created as embedded and later
87015>>>        // set it back and use a Mertech function to convert it to SQL.
87015>>>        Get IsMertechDriver sDriverID to bMertechDriver
87016>>>        If (bMertechDriver = True) Begin
87018>>>            If (bUseConnectionID = True) Begin
87020>>>                Move False to bUseConnectionID
87021>>>            End
87021>>>>
87021>>>            Move sDriverID to sOriginalDriverID
87022>>>            Move DATAFLEX_ID to sDriverID
87023>>>        End
87023>>>>
87023>>>            
87023>>>        Move False to Err
87024>>>        If (sDriverID = DATAFLEX_ID) Begin
87026>>>            Move sRoot to sPhysicalFile 
87027>>>        End
87027>>>>
87027>>>        
87027>>>        If (sDriverID <> DATAFLEX_ID) Begin 
87029>>>            Move SQLConnection.sConnectionID to sConnectionID
87030>>>            
87030>>>            // If DAW driver and we should use a connection id we need to
87030>>>            // check if the connection ID exists; else we create it before attempting creating the table
87030>>>            If (bMertechDriver = False and bUseConnectionID = True) Begin
87032>>>                Get IsConnectionID sConnectionID sDriverID to bExists
87033>>>                If (bExists = False) Begin
87035>>>                    Get UtilCreateConnectionID sConnectionID to bOk
87036>>>                    If (bOk = False) Begin
87038>>>                        Error DFERR_PROGRAM ("The Connection ID:" * sConnectionID * "could not be created and therefor the table can't be created.")
87039>>>>
87039>>>                        Function_Return False
87040>>>                    End
87040>>>>
87040>>>                End
87040>>>>
87040>>>            End
87040>>>>
87040>>>            
87040>>>            Move (sRoot + ".int") to sPhysicalFile
87041>>>            Move (Uppercase(sDisplay)) to sVal
87042>>>            If (not(sVal contains (sSchema + "."))) Begin    
87044>>>                Move (Lowercase(sSchema) + "." + sTableName) to sDisplay
87045>>>            End                                       
87045>>>>
87045>>>        End                                          
87045>>>>
87045>>>        Move 0 to hFile   
87046>>>        Move False to Err 
87047>>>        
87047>>>        Structure_Start hFile sDriverID
87048>>>            If (sDriverID <> DATAFLEX_ID) Begin
87050>>>                If (bUseConnectionID = True) Begin
87052>>>                    Set_Attribute DF_FILE_LOGIN              of hFile to (CS_DFCONNID + "=" + sConnectionID)
87055>>>                End 
87055>>>>
87055>>>                Else Begin
87056>>>                    Set_Attribute DF_FILE_LOGIN              of hFile to SQLConnection.sConnectionString
87059>>>                End
87059>>>>
87059>>>                Set_Attribute DF_FILE_TABLE_NAME             of hFile to sRoot  
87062>>>                Set_Attribute DF_FILE_USE_DUMMY_ZERO_DATE    of hFile to True     
87065>>>                Set_Attribute DF_FILE_TABLE_CHARACTER_FORMAT of hFile to sANSI_OEM
87068>>>                Set_Attribute DF_FILE_RECNUM_TABLE           of hFile to bRecnum
87071>>>
87071>>>                If (sSchema <> "") Begin
87073>>>                    Set_Attribute DF_FILE_OWNER                of hFile to sSchema
87076>>>                End
87076>>>>
87076>>>    
87076>>>                If (sDriverID = DB2_DRV_ID) Begin                           
87078>>>                    If (SQLConnection.sLongTableSpace <> "") Begin
87080>>>                        Set_Attribute DF_FILE_LONG_TABLESPACE  of hFile to SQLConnection.sLongTableSpace
87083>>>                    End
87083>>>>
87083>>>                End   
87083>>>>
87083>>>                If (sDriverID = DB2_DRV_ID or sDriverID = ORAFLEX or sDriverID = MDSPgSQL) Begin
87085>>>                    If (SQLConnection.sBaseTableSpace <> "") Begin
87087>>>                        Set_Attribute DF_FILE_TABLE_TABLESPACE of hFile to SQLConnection.sBaseTableSpace
87090>>>                    End
87090>>>>
87090>>>                    If (SQLConnection.sIndexTableSpace <> "") Begin
87092>>>                        Set_Attribute DF_FILE_INDEX_TABLESPACE of hFile to SQLConnection.sIndexTableSpace
87095>>>                    End
87095>>>>
87095>>>                End
87095>>>>
87095>>>            End 
87095>>>>
87095>>>                       
87095>>>            Set_Attribute DF_FILE_PHYSICAL_NAME              of hFile to sPhysicalFile 
87098>>>            
87098>>>            // We need to create at least one column else the table creation will fail.
87098>>>            // We remove it before the end of this function.
87098>>>            Move 0 to iColumn
87099>>>            Create_Field hFile at iColumn                   
87100>>>            
87100>>>            Set_Attribute DF_FIELD_NAME of hFile iColumn to "temp"
87103>>>            Set_Attribute DF_FIELD_TYPE of hFile iColumn to DF_DATE
87106>>>        Structure_End hFile
87108>>>        
87108>>>        // If Mertech driver we convert the newly created embedded table (DataFlex) to SQL
87108>>>        If (bMertechDriver = True) Begin
87110>>>            Move sOriginalDriverID to sDriverID
87111>>>            If (not(sVal contains (sSchema + "."))) Begin    
87113>>>                Move (Lowercase(sSchema) + "." + sTableName) to sDisplay
87114>>>            End                                       
87114>>>>
87114>>>            // Note: This function also sets the Err flag.
87114>>>            Get _MertechApiTableConvertToSQL hTable sRoot SQLConnection.sDatabase sDriverID SQLConnection.sBaseTableSpace SQLConnection.sIndexTableSpace False to bOK
87115>>>        End
87115>>>>
87115>>>
87115>>>        Move (not(Err)) to bOK                                     
87116>>>        If (bOk = True) Begin
87118>>>            If (sDriverID <> DATAFLEX_ID) Begin
87120>>>                Move (sDriverID + ":" + sRoot) to sRoot
87121>>>            End
87121>>>>
87121>>>    
87121>>>            If (sDriverID <> DATAFLEX_ID and not(Uppercase(sRoot) contains sDriverID)) Begin
87123>>>                Move (sDriverID + ":" + sRoot) to sRoot
87124>>>            End
87124>>>>
87124>>>            Set_Attribute DF_FILE_ROOT_NAME     of hTable to sRoot
87127>>>            Set_Attribute DF_FILE_LOGICAL_NAME  of hTable to sTableName 
87130>>>            Set_Attribute DF_FILE_DISPLAY_NAME  of hTable to sDisplay
87133>>>        
87133>>>            // Lastly we remove the temporary column we created above, if all went well.
87133>>>            Get ApiColumnRemove hTable "temp" to bOk
87134>>>        End
87134>>>>
87134>>>        
87134>>>        Function_Return (bOK = True)
87135>>>    End_Function  
