85574>>>    // This function allows you to put an Sql script in a CM Image. It makes it easier to
85574>>>    // copy and paste between a DataFlex program and an Sql Editor.
85574>>>    Function SqlUtilLoadImageFile String sFileName Returns String
85576>>>        Integer iChannel iPos
85576>>>        String sTextValue sLine sPath
85576>>>        Boolean bSeqEof
85576>>>        
85576>>>        Move "" to sTextValue        
85577>>>        Get ParseFolderName sFileName to sPath
85578>>>        If (Trim(sPath) = "") Begin
85580>>>            Get psDataPathFirstPart to sPath
85581>>>            Move (sPath + sFileName) to sFileName
85582>>>        End
85582>>>>
85582>>>        
85582>>>        Get Seq_New_Channel to iChannel
85583>>>        If (iChannel = DF_SEQ_CHANNEL_NOT_AVAILABLE) Begin
85585>>>            Error DFERR_PROGRAM "No channel available..."
85586>>>>
85586>>>        End
85586>>>>
85586>>>        Else Begin        
85587>>>            Direct_Input channel iChannel sFileName
85589>>>            Move (SeqEof) to bSeqEof
85590>>>            If (bSeqEof = True) Begin
85592>>>                Send Seq_Release_Channel iChannel 
85593>>>                Set psSQLStatementString to ""  
85594>>>                Error DFERR_PROGRAM ("The Sql script file:\n" + sFileName + "\nCould not be found.")
85595>>>>
85595>>>                Function_Return "" 
85596>>>            End
85596>>>>
85596>>>    
85596>>>            While (not(bSeqEof))
85600>>>                Readln channel iChannel sLine 
85602>>>                Move (Pos("/", sLine)) to iPos
85603>>>                Move (SeqEol) to bSeqEof
85604>>>                If (not(bSeqEof) and iPos <> 1) Begin
85606>>>                    Move (sTextValue + sLine + Character(13)) to sTextValue
85607>>>                End
85607>>>>
85607>>>            Loop
85608>>>>
85608>>>            Send Seq_Release_Channel iChannel
85609>>>        End
85609>>>>
85609>>>        
85609>>>        Set psSQLStatementString to sTextValue
85610>>>        Function_Return sTextValue
85611>>>    End_Function  
