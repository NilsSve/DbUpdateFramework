83994>>>        Get _SqlProperTableName sTableName to sTableName
83995>>>        Get _SqlFindKeyWord CI_SQLCreateTable iDbType to sCreateTable
83996>>>        Move (sCreateTable * String(sTableName) * "(Dummy Decimal(2,0))") to sSQLString
83997>>>        
83997>>>        Move False to Err               
83998>>>        Send SqlUtilExecuteQuery sSQLString sDriverID
83999>>>    
83999>>>        Function_Return (Err = False)
84000>>>    End_Function       
