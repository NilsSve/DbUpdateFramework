89666>>>    
89666>>>    // Internal usage. Use the UtilColumnTypeXXX functions instead.
89666>>>    Function _UtilColumnType String sDriverID Integer iDbType Integer iType String sType Boolean bIntegerInputType Returns tColumnType
89668>>>        Integer iValue iSize iCount iStart
89668>>>        tColumnType[] ColumnTypeArray   
89668>>>        tColumnType[] ColumnTypeArray   
89669>>>        tColumnType RetvalType 
89669>>>        tColumnType RetvalType 
89669>>>        String sValue
89669>>>        
89669>>>        Move "Undefined" to RetvalType.sType 
89670>>>        Move -1999       to RetvalType.iType
89671>>>        
89671>>>        Move 0 to iStart
89672>>>        Move (Uppercase(sType)) to sType            
89673>>>        
89673>>>        If (iType <= -1500) Begin
89675>>>            Move EN_dbTypeDataFlex to iDbType
89676>>>            Move DATAFLEX_ID       to sDriverID
89677>>>        End
89677>>>>
89677>>>
89677>>>        Get UtilEnumerateColumnTypes sDriverID iDbType to ColumnTypeArray
89678>>>        
89678>>>        Move (SizeOfArray(ColumnTypeArray)) to iSize 
89679>>>        Decrement iSize
89680>>>        
89680>>>        for iCount from iStart to iSize
89686>>>>
89686>>>            Move ColumnTypeArray[iCount].iType to iValue
89687>>>            Move ColumnTypeArray[iCount].sType to sValue 
89688>>>            If (bIntegerInputType = True) Begin
89690>>>                If (iValue = iType) Begin
89692>>>                    Move ColumnTypeArray[iCount].sType          to RetvalType.sType  
89693>>>                    Move iType                                  to RetvalType.iType
89694>>>                    Move ColumnTypeArray[iCount].sDataFlexType  to RetvalType.sDataFlexType
89695>>>                    Move ColumnTypeArray[iCount].iDataFlexType  to RetvalType.iDataFlexType
89696>>>                    Move ColumnTypeArray[iCount].sPrecision     to RetvalType.sPrecision
89697>>>                    Move ColumnTypeArray[iCount].bFixedSize     to RetvalType.bFixedSize
89698>>>                    Move iSize to iCount // We're done!
89699>>>                End
89699>>>>
89699>>>            End
89699>>>>
89699>>>            Else Begin
89700>>>                Move (Uppercase(sValue)) to sValue
89701>>>                If (sValue = sType) Begin
89703>>>                    Move sType                                  to RetvalType.sType
89704>>>                    Move ColumnTypeArray[iCount].iType          to RetvalType.iType 
89705>>>                    Move ColumnTypeArray[iCount].sDataFlexType  to RetvalType.sDataFlexType
89706>>>                    Move ColumnTypeArray[iCount].iDataFlexType  to RetvalType.iDataFlexType
89707>>>                    Move ColumnTypeArray[iCount].sPrecision     to RetvalType.sPrecision
89708>>>                    Move ColumnTypeArray[iCount].bFixedSize     to RetvalType.bFixedSize
89709>>>                    Move iSize to iCount // We're done!
89710>>>                End
89710>>>>
89710>>>            End
89710>>>>
89710>>>        Loop
89711>>>>
89711>>>        
89711>>>        Function_Return RetvalType
89712>>>    End_Function
89713>>>    
89713>>>    // *** Miscellaneous other functions ***
89713>>>    // Some of which can be used by both "Sqlxxx" and "Apixxx" functions.
89713>>>    //
89713>>>    
89713>>>    // Callback functionality used when e.g. calling driver functions directly.
89713>>>    Function Callback String sCallback_Text Integer iCallback_Type Returns Integer
89715>>>        Integer iRetval iPos iPerc
89715>>>        String sVal1 sVal2 
89715>>>        Number nReady nTotal 
89715>>>        
89715>>>        Send DoAdvance of ghoProgressBar           
89716>>>        
89716>>>        If (sCallback_Text contains "Copy records") Begin
89718>>>            Move CS_SQLCopyingData to sCallback_Text
89719>>>        End                                        
89719>>>>
89719>>>        If (sCallback_Text contains "Dropping index" or sCallback_Text contains "Temporary delete of all indices of table") Begin
89721>>>            Move (Replace("Dropping index", sCallback_Text, CS_SQLDeletingIndex)) to sCallback_Text 
89722>>>            Move (Replace("Temporary delete of all indices of table", sCallback_Text, CS_SQLDeletingIndex)) to sCallback_Text
89723>>>        End
89723>>>>
89723>>>        If (sCallback_Text contains "Creating index") Begin
89725>>>            Move (Replace("Creating index", sCallback_Text, CS_SQLCreatingIndex)) to sCallback_Text
89726>>>        End                                               
89726>>>>
89726>>>        
89726>>>        Case Begin
89726>>>            Case (iCallback_Type = DF_Message_Text) 
89728>>>                Set Message_Text of ghoStatusPanel to sCallback_Text  
89729>>>                Set Action_Text  of ghoStatusPanel to ""
89730>>>                Case Break
89731>>>            Case (iCallback_Type = DF_Message_Heading_1) 
89734>>>                Set Message_Text of ghoStatusPanel to sCallback_Text 
89735>>>                Set Action_Text  of ghoStatusPanel to ""
89736>>>                Case Break
89737>>>            Case (iCallback_Type = DF_Message_Heading_2) 
89740>>>                Set Message_Text of ghoStatusPanel to sCallback_Text 
89741>>>                Set Action_Text  of ghoStatusPanel to ""
89742>>>                Case Break
89743>>>            Case (iCallback_Type = DF_Message_Heading_3) 
89746>>>                Set Message_Text of ghoStatusPanel to sCallback_Text 
89747>>>                Set Action_Text  of ghoStatusPanel to ""
89748>>>                Case Break
89749>>>            Case (iCallback_Type = DF_Message_Heading_4) 
89752>>>                Set Message_Text of ghoStatusPanel to sCallback_Text 
89753>>>                Set Action_Text  of ghoStatusPanel to ""
89754>>>                Case Break
89755>>>            Case (iCallback_Type = DF_Message_Heading_5) 
89758>>>                Set Message_Text of ghoStatusPanel to sCallback_Text 
89759>>>                Set Action_Text  of ghoStatusPanel to ""
89760>>>                Case Break
89761>>>            Case (iCallback_Type = DF_Message_Warning) 
89764>>>                Send None
89765>>>                Case Break
89766>>>            Case (iCallback_Type = DF_Message_Progress_Title) 
89769>>>                Set Message_Text of ghoStatusPanel to sCallback_Text 
89770>>>                Set Action_Text  of ghoStatusPanel to ""
89771>>>                Case Break
89772>>>            Case (iCallback_Type = DF_Message_Progress_Value) 
89775>>>                //*** Interpret numbers
89775>>>                Move (Left(sCallback_Text, (Pos(",", sCallback_Text) - 1)))                       to nReady
89776>>>                Move (Right(sCallback_Text, (Length(sCallback_Text) - Pos(",", sCallback_Text)))) to nTotal
89777>>>                Move ((nReady / nTotal) * 100)                                                    to iPerc
89778>>>                Set Action_Text of ghoStatusPanel to (String(iPerc) * String("% (Total:") * String(nTotal) + ")")
89779>>>                Case Break
89780>>>            Case Else
89780>>>                Set Message_Text to ""
89781>>>                Set Action_Text  to ""    
89782>>>        Case End
89782>>>
89782>>>        Send ProcessEvents of ghoStatusPanel
89783>>>        Function_Return False
89784>>>    End_Function
