91495>>>>>>>>>>>//     Property Integer Help_Id_Keys    0
91495>>>>>>>>>>>//     Property Integer Help_Id_Files   0
91495>>>>>>>>>>>//     Property Integer Help_Id_Errors  0
91495>>>>>>>>>>>//
91495>>>>>>>>>>>//
91495>>>>>>>>>>>// Public messsages which are sent to this object:
91495>>>>>>>>>>>//
91495>>>>>>>>>>>//    procedure View_Context_KeyWord_Help integer Obj
