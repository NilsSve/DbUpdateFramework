92318>>>>>
92318>>>>>    Procedure Set Version String sVersion
92320>>>>>        Handle hoVersionInfo
92320>>>>>        Boolean bIncluded
92320>>>>>        Integer iMajor iMinor iRelease iBuild
92320>>>>>        Date dCompileDate
92320>>>>>
92320>>>>>        If (sVersion = "") Begin
92322>>>>>            // This automatically shows the program version of the program, if available.
92322>>>>>            // It will be displayed as the second item in the edit object.
92322>>>>>            If (ghoApplication <> 0) Begin
92324>>>>>                Get phoVersionInfo of ghoApplication to hoVersionInfo
92325>>>>>                If (hoVersionInfo <> 0) Begin
92327>>>>>                    Get pbIncluded of hoVersionInfo to bIncluded
92328>>>>>                    If (bIncluded) Begin
92330>>>>>                        Get piVersionMajor of hoVersionInfo to iMajor
92331>>>>>                        Get piVersionMinor of hoVersionInfo to iMinor
92332>>>>>                        Get piVersionRelease of hoVersionInfo to iRelease
92333>>>>>                        Get piVersionBuild of hoVersionInfo to iBuild
92334>>>>>                        Move (SFormat (C_$VERSION + ": %1.%2.%3.%4", iMajor, iMinor, iRelease, iBuild)) to sVersion
92335>>>>>                    End
92335>>>>>>
92335>>>>>                End
92335>>>>>>
92335>>>>>            End
92335>>>>>>
92335>>>>>        End
92335>>>>>>
92335>>>>>
92335>>>>>        // Display the compiled date as the next row in the edit object, after the program version.
92335>>>>>        Get GetCompileDate to dCompileDate
92336>>>>>        If (sVersion <> "") Begin
92338>>>>>            Send Add_Lineln (sVersion + (Character(13)) + C_$Compile_Date * String(dCompileDate))
92339>>>>>        End
92339>>>>>>
92339>>>>>    End_Procedure
92340>>>>>
92340>>>>>    Function GetCompileDate Returns Date
92342>>>>>        Date dCompileDate
92342>>>>>        String sAppFilename sData sCompileDate
92342>>>>>        Integer iChannel iPos iDateFormat
92342>>>>>
92342>>>>>        // Get full path to the current running executable
92342>>>>>        Get GetApplicationFileName of ghoApplication to sAppFilename
92343>>>>>
92343>>>>>        //Read the current file  up to where the data we're interesting in is (this was hand calced and so could vary)
92343>>>>>        Get Seq_Open_Input_Channel ("binary:" * sAppFilename) to iChannel
92344>>>>>        Read_Block channel iChannel sData (8 * 1024)    // First 8K is .exe header skip it
92346>>>>>        Read_Block channel iChannel sData 75            // The compile information we're interested in
92348>>>>>        Send Seq_Close_Channel iChannel
92349>>>>>
92349>>>>>        // The data is padded with Character(0)s. Strip them out
92349>>>>>        Move (CString(sData)) to sData
92350>>>>>
92350>>>>>        // The compile date is after the first ", ", so string parsing is required
92350>>>>>        Move (Pos(", ", sData)) to iPos
92351>>>>>        Move (Mid(sData, 10, (iPos + 2) ))  to sCompileDate // In US format
92352>>>>>        // If the current date format is non US, we need to temporary
92352>>>>>        // change the format and then move the string to the date variable.
92352>>>>>        Get_Attribute DF_DATE_FORMAT        to iDateFormat
92355>>>>>        Set_Attribute DF_DATE_FORMAT        to DF_DATE_USA
92358>>>>>        Move (Date(sCompileDate))           to dCompileDate
92359>>>>>        Set_Attribute DF_DATE_FORMAT        to iDateFormat // Reset date format
92362>>>>>
92362>>>>>        Function_Return dCompileDate
92363>>>>>    End_Function
92364>>>>>
