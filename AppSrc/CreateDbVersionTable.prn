82965>>>>>        // There's a bug in Mertech drivers creating "an Exception error" in the debugger (probably will crash an application too.)
82965>>>>>        If (bIsMertech = False) Begin
82967>>>>>            Set_Attribute DF_DRIVER_SILENT_LOGIN of iDriverID to SQLConnection.bSilentLogin
82970>>>>>        End
82970>>>>>>
82970>>>>>        
82970>>>>>        Get Create (RefClass(cDbUpdateDatabaseDriver)) to hoDriver
82971>>>>>        Set psDriverID of hoDriver to SQLConnection.sDriverID
82972>>>>>        Get DbLogin    of hoDriver sConnectionString SQLConnection.sServer SQLConnection.sDatabase SQLConnection.bTrusted SQLConnection.sUserID SQLConnection.sPassword to bOK
82973>>>>>        Send Destroy   of hoDriver
82974>>>>>        Move hoErrorObj to Error_Object_Id
82975>>>>>        
82975>>>>>        Function_Return bOK
82976>>>>>    End_Function
