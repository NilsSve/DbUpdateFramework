87735>>>    // Checks if a field name exists in a table definition
87735>>>    // Returns True if it does
87735>>>    // Sample:
87735>>>    //   Get UtilColumnExists MyTable.File_Number "MyColumnName" to iExists
87735>>>    Function UtilColumnExists Handle hTable String sFieldName Returns Boolean
87737>>>        Integer iNumColumns iColumn
87737>>>        String sColumn
87737>>>        Boolean bExists bOK
87737>>>    
87737>>>        Get AutoConnectionIDLogin to bOK
87738>>>        Send Ignore_Error of Error_Object_Id DFERR_CANT_OPEN_DATA_FILE
87739>>>        Open hTable                       
87741>>>        Send Trap_Error   of Error_Object_Id DFERR_CANT_OPEN_DATA_FILE
87742>>>        If (Found = False) Begin
87744>>>            Function_Return False
87745>>>        End                      
87745>>>>
87745>>>        
87745>>>        Move False to bExists  
87746>>>        Get_Attribute DF_FILE_NUMBER_FIELDS of hTable to iNumColumns
87749>>>        for iColumn from 1 to iNumColumns
87755>>>>
87755>>>            Get_Attribute DF_FIELD_NAME of hTable iColumn to sColumn
87758>>>            If (Uppercase(sFieldName) = Uppercase(sColumn)) Begin
87760>>>                Move iNumColumns to iColumn
87761>>>                Move True to bExists
87762>>>            End
87762>>>>
87762>>>        Loop
87763>>>>
87763>>>        Close hTable
87764>>>    
87764>>>        Function_Return bExists
87765>>>    End_Function
87766>>>    
87766>>>    // Checks if the current psConnectionID is logged in; if not
87766>>>    // attempts to make a login. 
87766>>>    // Because
87766>>>    // Returns True if already logged in or the new login was successful.
87766>>>    Function AutoConnectionIDLogin Returns Boolean
87768>>>        String sConnectionID sConnectionString sDriverID
87768>>>        Boolean bExists bOK bDAWDriver
87768>>>        Handle hoCLI hoDriver                                    
87768>>>        Integer iRetval
87768>>>        tSQLConnection SQLConnection
87768>>>        tSQLConnection SQLConnection
87768>>>        
87768>>>        Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
87769>>>        Move SQLConnection.sDriverID                  to sDriverID      
87770>>>        Move SQLConnection.sConnectionString          to sConnectionString
87771>>>        Get IsDAWSQLDriver sDriverID to bOK
87772>>>        If (bOK = False) Begin                         
87774>>>            Get _MertechSQLManagerHandle to hoCLI
87775>>>            Get Create (RefClass(cDbUpdateDatabaseDriver)) to hoDriver
87776>>>            Set psDriverID of hoDriver to SQLConnection.sDriverID
87777>>>            Get DbLogin    of hoDriver sConnectionString SQLConnection.sServer SQLConnection.sDatabase SQLConnection.bTrusted SQLConnection.sUserID SQLConnection.sPassword to bOK
87778>>>            Send Destroy   of hoDriver
87779>>>            Function_Return False
87780>>>        End                      
87780>>>>
87780>>>        
87780>>>        Move SQLConnection.sConnectionID to sConnectionID
87781>>>        
87781>>>        Get IsConnectionID sConnectionID sDriverID to bExists
87782>>>        If (bExists = False) Begin
87784>>>            // We always start by deleting the current connection - if any - because the
87784>>>            // login details my have changed.
87784>>>            Get phoCLIHandler to hoCLI   
87785>>>            Set psDriverID    of hoCLI to sDriverID
87786>>>            Get DeleteConnectionID of hoCLI sConnectionID -1 to iRetval
87787>>>            Get UtilCreateConnectionID sConnectionID to bOk
87788>>>            If (bOk = False) Begin
87790>>>                Error DFERR_PROGRAM ("The Connection ID:" * sConnectionID * "could not be created and therefor the table can't be changed.")
87791>>>>
87791>>>                Function_Return False
87792>>>            End
87792>>>>
87792>>>            Move bOK to bExists
87793>>>        End
87793>>>>
87793>>>        
87793>>>        Function_Return (bExists = True)
87794>>>    End_Function
87795>>>    
87795>>>    // *** Utility Messages ***
87795>>>    // 
87795>>>    //
87795>>>    // To add a value to the CodeMast & CodeType tables. Pass; a) bCodeType if it is CodeType that should be updated. 
87795>>>    // Else it is CodeMast. b) sTypeValue; either to be added If bCodeType = True, or it will be used to find the correct 
87795>>>    // CodeType record. c) sValue1 and d) sValue2 is the CodeType Description & Comment, or CodeMast Type and Code values.
87795>>>    Function UtilCodeMasterAddValue Boolean bCodeType String sTypeValue String sValue2 String sValue3 Returns Boolean
87797>>>        Boolean bError bFound
87797>>>        
87797>>>        Move False to Err
87798>>>        Open CodeMast
87800>>>        Open CodeType
87802>>>        
87802>>>        If (bCodeType = True) Begin
87804>>>            Clear CodeType
87805>>>            Move sTypeValue to CODETYPE.Type 
87806>>>            Find eq CODETYPE.Type
87807>>>>
87807>>>            Move (Found = True) to bFound
87808>>>            If (bFound = True) Begin
87810>>>                Reread CodeType
87814>>>            End
87814>>>>
87814>>>            If (bFound = False) Begin
87816>>>                Clear CodeType
87817>>>            End       
87817>>>>
87817>>>                Move sTypeValue to CODETYPE.Type 
87818>>>                Move sValue2    to CODETYPE.Description
87819>>>                Move sValue3    to CODETYPE.Comment
87820>>>                SaveRecord CODETYPE
87821>>>            If (bFound = True) Begin
87823>>>                Unlock
87824>>>>
87824>>>            End
87824>>>>
87824>>>        End
87824>>>>
87824>>>        
87824>>>        If (bCodeType = False) Begin
87826>>>            Clear CODEMAST
87827>>>            Move sTypeValue to CODEMAST.Type
87828>>>            Move sValue2    to CODEMAST.Code  
87829>>>            Find eq CODEMAST.Code
87830>>>>
87830>>>            Move (Found = True) to bFound
87831>>>            If (bFound = True) Begin
87833>>>                Reread CODEMAST
87837>>>            End
87837>>>>
87837>>>            If (bFound = False) Begin
87839>>>                Clear CODEMAST
87840>>>            End   
87840>>>>
87840>>>                Move sTypeValue to CODEMAST.Type
87841>>>                Move sValue2    to CODEMAST.Code  
87842>>>                Move sValue3    to CODEMAST.Description
87843>>>                SaveRecord CODEMAST
87844>>>            If (bFound = True) Begin
87846>>>            Unlock
87847>>>>
87847>>>            End
87847>>>>
87847>>>        End
87847>>>>
87847>>>        
87847>>>        Close CodeMast
87848>>>        Close CodeType
87849>>>        
87849>>>        Function_Return (Err = False)
87850>>>    End_Function
87851>>>
87851>>>    // Changes values in CodeType & CodeMast - From type value To type value. It first changes the type value in 
87851>>>    // CodeType and then spins through all CodeMast records to change all related records.
87851>>>    Function UtilCodeMasterChangeValue String sFromValue String sToValue Returns Boolean
87853>>>        Boolean bFound
87853>>>        
87853>>>        Move False to Err
87854>>>        Open CodeMast
87856>>>        Open CodeType
87858>>>        
87858>>>        Clear CodeType
87859>>>        Move sFromValue to CODETYPE.Type
87860>>>        Find eq CODETYPE.Type
87861>>>>
87861>>>        If (Found = True) Begin
87863>>>            Reread CODETYPE
87867>>>                Move sToValue to CODETYPE.Type
87868>>>                SaveRecord CODETYPE
87869>>>            Unlock                 
87870>>>>
87870>>>        End
87870>>>>
87870>>>            
87870>>>        Clear CODEMAST
87871>>>        Find gt CODEMAST by Recnum
87872>>>>
87872>>>        While (Found = True)
87876>>>            Move (Trim(Uppercase(CODEMAST.Type) = Trim(Uppercase(sFromValue)))) to bFound
87877>>>            If (bFound = True) Begin
87879>>>                Reread CODEMAST
87883>>>                    Move sToValue to CODEMAST.Type
87884>>>                    SaveRecord CODEMAST
87885>>>                Unlock
87886>>>>
87886>>>            End
87886>>>>
87886>>>            Find gt CODEMAST by Recnum
87887>>>>
87887>>>        Loop
87888>>>>
87888>>>        
87888>>>        Close CodeMast
87889>>>        Close CodeType
87890>>>        
87890>>>        Function_Return (Err = False)
87891>>>    End_Function
87892>>>    
87892>>>    // Removes a value from CodeMast. Pass the sTypeValue and the sValue2 to remove.
87892>>>    Function UtilCodeMasterRemoveValue String sTypeValue String sValue2 Returns Boolean
87894>>>        Boolean bError bFound
87894>>>        
87894>>>        Move False to Err
87895>>>        Open CodeMast
87897>>>        
87897>>>        Clear CODEMAST
87898>>>        Move sTypeValue to CODEMAST.Type
87899>>>        Move sValue2    to CODEMAST.Code  
87900>>>        Find eq CODEMAST.Code
87901>>>>
87901>>>        Move (Found = True) to bFound
87902>>>        If (bFound = True) Begin
87904>>>            Delete CODEMAST
87905>>>        End
87905>>>>
87905>>>        
87905>>>        Close CodeMast
87906>>>        
87906>>>        Function_Return (Err = False)
87907>>>    End_Function
87908>>>
87908>>>    // Note:
87908>>>    // The DF_FILE_TABLE_NAME attribute holds the name of the table at the back end. Depending on the back end, table 
87908>>>    // names may be case sensitive, contain spaces or other special characters. This attribute is used to determine a table's 
87908>>>    // back end name when using Embedded SQL. Since Embedded SQL works on the back end directly, the back end's name must be used. 
87908>>>    // In most cases the back end name will be the same as the table name used in DataFlex.
87908>>>    // To do the opposite; To get the file handle from a table name string use the UtilTableNameToHandle function.
87908>>>    Function UtilTableHandleToString Handle hTable Returns String
87910>>>        String sTableName
87910>>>        Boolean bOpen bExists bRecnum bOK
87910>>>        
87910>>>        Get UtilTableNumberIsInUse hTable to bExists
87911>>>        If (bExists = False) Begin
87913>>>            Move True to Err
87914>>>            Function_Return ""
87915>>>        End
87915>>>>
87915>>>
87915>>>        Set Error_Report_Mode to DUF_ERROR_NO_REPORT
87916>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpen
87919>>>        If (bOpen = False) Begin                       
87921>>>            Get AutoConnectionIDLogin to bOK
87922>>>            Send Ignore_Error of Error_Object_Id DFERR_CANT_OPEN_DATA_FILE
87923>>>            Send Ignore_Error of Error_Object_Id DFERR_CANT_OPEN_INTERMEDIATE_FILE
87924>>>            Send Ignore_Error of Error_Object_Id CLIERR_GENERAL_ERROR
87925>>>            Open hTable
87927>>>            Send Trap_Error of Error_Object_Id DFERR_CANT_OPEN_DATA_FILE
87928>>>            Send Trap_Error of Error_Object_Id DFERR_CANT_OPEN_INTERMEDIATE_FILE
87929>>>            Send Trap_Error of Error_Object_Id CLIERR_GENERAL_ERROR
87930>>>            Get_Attribute DF_FILE_OPENED of hTable to bOpen
87933>>>        End
87933>>>>
87933>>>        If (bOpen = True) Begin
87935>>>            Send Ignore_Error of Error_Object_Id DFERR_UNSUPPORTED_ATTRIBUTE 
87936>>>            Get_Attribute DF_FILE_TABLE_NAME of hTable to sTableName 
87939>>>            // If blank it is an embedded table:
87939>>>            If (sTableName = "") Begin
87941>>>                Get_Attribute DF_FILE_LOGICAL_NAME of hTable to sTableName 
87944>>>                Move 0 to LastErr
87945>>>                Move False to Err
87946>>>            End
87946>>>>
87946>>>            Send Trap_Error of Error_Object_Id DFERR_UNSUPPORTED_ATTRIBUTE
87947>>>        End
87947>>>>
87947>>>        Set Error_Report_Mode to DUF_ERROR_REPORT
87948>>>            
87948>>>        Function_Return sTableName
87949>>>    End_Function
87950>>>    
87950>>>    // Returns the filenumber for the passed Table name from Filelist.cfg.
87950>>>    // Returns 0 if unsuccessful.
87950>>>    // To do the opposite; To get the string value from a table handle string use the UtilTableHandleToString function.
87950>>>    Function UtilTableNameToHandle String sTableName Returns Integer
87952>>>        String sValue sPrefixTableName sDriverID
87952>>>        Handle hTable hRetval
87952>>>        
87952>>>        Get psDriverID to sDriverID 
87953>>>        If (sDriverID <> DATAFLEX_ID and not(sTableName contains ":")) Begin
87955>>>            Move (sDriverID + ":" + sTableName) to sPrefixTableName
87956>>>        End
87956>>>>
87956>>>        Move 0 to hTable 
87957>>>        Move 0 to hRetval
87958>>>        Repeat 
87958>>>>
87958>>>            Get_Attribute DF_FILE_NEXT_USED of hTable to hTable
87961>>>            If (hTable <> 0) Begin
87963>>>                Get_Attribute DF_FILE_ROOT_NAME of hTable to sValue
87966>>>                If (Uppercase(sValue) = Uppercase(sTableName) or Uppercase(sValue) = Uppercase(sPrefixTableName)) Begin
87968>>>                    Move hTable to hRetval
87969>>>                    Move 0 to hTable
87970>>>                End
87970>>>>
87970>>>            End
87970>>>>
87970>>>        Until (hTable = 0)
87972>>>        
87972>>>        Function_Return hRetval
87973>>>    End_Function
87974>>>        
87974>>>    // Check if the file exists in the Data folder,
87974>>>    // else creates it from memory as it has been compiled into the program as a resource:
87974>>>    Function UtilCheckCreateIfFileExists String sFileName String sResourceName Boolean bDataFile Returns Boolean
87976>>>        String sPath sDataPath
87976>>>        Boolean bExists
87976>>>    
87976>>>        Get psDataPathFirstPart to sPath
87977>>>        Move (sPath + sFileName) to sFileName
87978>>>        Get vFilePathExists sFileName to bExists
87979>>>    
87979>>>        If (bExists = False) Begin
87981>>>            // Read from memory & create file on disk.
87981>>>            Send SqlUtilCreateFileFromMemory sResourceName sFileName
87982>>>            Get vFilePathExists sFileName to bExists
87983>>>        End     
87983>>>>
87983>>>        Function_Return bExists
87984>>>    End_Function
