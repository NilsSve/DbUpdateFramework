85549>>>    // To open all Sql based tables in Filelist.cfg
85549>>>    Procedure SqlUtilOpenAllTables
85551>>>        Handle hTable
85551>>>        String sRoot sDriverID
85551>>>        Boolean bOK
85551>>>        
85551>>>        Move 0 to hTable
85552>>>        Move "" to sDriverID
85553>>>        Get AutoConnectionIDLogin to bOK
85554>>>        
85554>>>        Repeat
85554>>>>
85554>>>            Get_Attribute DF_FILE_NEXT_USED of hTable to hTable
85557>>>            If (hTable > 0) Begin     
85559>>>                Get_Attribute DF_FILE_DRIVER of hTable to sDriverID
85562>>>                If (sDriverID = MSSQLDRV_ID or sDriverID = DB2_DRV_ID or sDriverID = ODBC_DRV_ID) Begin
85564>>>                    Get_Attribute DF_FILE_ROOT_NAME of hTable to sRoot
85567>>>                    If (Uppercase(sRoot) contains ".INT" or Uppercase(sRoot) contains MSSQLDRV_ID or Uppercase(sRoot) contains DB2_DRV_ID or Uppercase(sRoot) contains ODBC_DRV_ID) Begin
85569>>>                        Open hTable
85571>>>                    End
85571>>>>
85571>>>                End
85571>>>>
85571>>>            End
85571>>>>
85571>>>    
85571>>>        Until (hTable = 0)
85573>>>    End_Procedure             
