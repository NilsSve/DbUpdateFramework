92166>>>>>Class cAboutEdit is an cRichEdit
92167>>>>>    Procedure Construct_Object
92169>>>>>        Forward Send Construct_Object
92171>>>>>
92171>>>>>        Set Size to 57 153
92172>>>>>        Set Location to 8 60
92173>>>>>
92173>>>>>        Set Read_Only_State to True
92174>>>>>        Set Skip_State to True
92175>>>>>        // Font size is calculated in "Twips", which are 1/1440 of an inch,
92175>>>>>        // or 1/20 of a printer's point.
92175>>>>>//        Set piFontSize    to (9 * 20)
92175>>>>>        Set piRightMargin to (0.1 * 1440)
92176>>>>>        Set Border_Style  to Border_None
92177>>>>>    End_Procedure
92178>>>>>
92178>>>>>    // Adds a line of text to the edit object
92178>>>>>    Procedure Add_Line String sVal
92180>>>>>        String sText
92180>>>>>        Address aAddress
92180>>>>>        Get paValue to aAddress
92181>>>>>        Move aAddress to sText
92182>>>>>        Move (sText + String(sVal)) to sVal
92183>>>>>        GetAddress of sVal to aAddress
92184>>>>>        Set paValue to aAddress
92185>>>>>    End_Procedure
92186>>>>>
92186>>>>>    // Compared to Add_Line above, this adds an extra empty line after the passed value.
92186>>>>>    // Note that we use the paValue interface,
92186>>>>>    // because the object isn't paged yet when we add the
92186>>>>>    // values and the COM edit object needs to be paged
92186>>>>>    // for the "Set Value" interface to be used.
92186>>>>>    Procedure Add_LineLn String sVal
92188>>>>>        String sText
92188>>>>>        Address aAddress
92188>>>>>        Get paValue to aAddress
92189>>>>>        Move aAddress to sText
92190>>>>>        Move (sText + String(sVal) + Character(10) + Character(13)) to sVal
92191>>>>>        GetAddress of sVal to aAddress
92192>>>>>        Set paValue to aAddress
92193>>>>>    End_Procedure
