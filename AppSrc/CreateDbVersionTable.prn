85045>>>    // Returns a string array with all tables for the current database.
85045>>>    Function SqlUtilEnumerateTables String sDriverID Returns String[]
85047>>>        String[] sReturnArray sArray
85049>>>        String sServer sDatabase sConnectionString sSelect sSchema     
85049>>>        Integer iSize iCount
85049>>>        Boolean bOK
85049>>>
85049>>>        If (sDriverID = DATAFLEX_ID) Begin
85051>>>            Function_Return sArray        
85052>>>        End                       
85052>>>>
85052>>>        
85052>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
85053>>>        If (bOK = False) Begin
85055>>>            Function_Return sReturnArray
85056>>>        End    
85056>>>>
85056>>>        
85056>>>        Get psConnectionString to sConnectionString
85057>>>        Get psDatabase to sDatabase                               
85058>>>        Get psSchema   to sSchema                                                                              
85059>>>                                                                                                              
85059>>>        Case Begin
85059>>>            Case (sDriverID = MSSQLDRV_ID)
85061>>>                Get _SqlTableArrayDAW to sReturnArray
85062>>>                Case Break                                                            
85063>>>            
85063>>>            Case (sDriverID = DB2_DRV_ID)
85066>>>                Get _SqlTableArrayDAW to sReturnArray
85067>>>                Case Break
85068>>>            
85068>>>            Case (sDriverID = ODBC_DRV_ID)
85071>>>                Get _SqlTableArrayDAW to sReturnArray
85072>>>                Case Break
85073>>>            
85073>>>            Case (sDriverID = SQLFLEX)
85076>>>                Move ("SELECT TABLE_NAME FROM" * sDatabase + ".INFORMATION_SCHEMA.TABLES WHERE TABLE_TYPE != 'VIEW'") to sSelect
85077>>>                Get SqlEnumerateEsqlMertech sSelect to sReturnArray
85078>>>                Case Break
85079>>>            
85079>>>            Case (sDriverID = MDSMySQL)                                   
85082>>>                Move ("SELECT TABLE_NAME from INFORMATION_SCHEMA.TABLES where TABLE_SCHEMA = '" + sDatabase + "' and TABLE_TYPE = 'BASE TABLE' order by TABLE_NAME") to sSelect
85083>>>                Get SqlEnumerateEsqlMertech sSelect to sReturnArray
85084>>>                Case Break
85085>>>            
85085>>>            Case (sDriverID = MDSPgSQL)                                          
85088>>>                Move "select tablename, schemaname from pg_catalog.pg_tables order by tablename"  to sSelect
85089>>>                Get SqlEnumerateEsqlMertech sSelect "" to sReturnArray
85090>>>                Case Break            
85091>>>            
85091>>>            Case (sDriverID = ORAFLEX)                                          
85094>>>                Move "SELECT table_name from user_tables" to sSelect  
85095>>>                Get SqlEnumerateEsqlMertech sSelect to sArray
85096>>>                Move (SizeOfArray(sArray)) to iSize
85097>>>                Decrement iSize
85098>>>                For iCount from 0 to iSize
85104>>>>
85104>>>                    If (not(sArray[iCount] contains "$")) Begin
85106>>>                        Move sArray[iCount] to sReturnArray[SizeOfArray(sReturnArray)]
85107>>>                    End
85107>>>>
85107>>>                Loop
85108>>>>
85108>>>                Case Break            
85109>>>
85109>>>            Case Else     
85109>>>                Error DFERR_PROGRAM "Unsupported driver passed to SqlUtilEnumerateTables function."
85110>>>>
85110>>>                Case Break
85111>>>        Case End
85111>>>        
85111>>>        Function_Return sReturnArray
85112>>>    End_Function
