88005>>>    
88005>>>    Function UtilColumnTypePrecisionSize String sDriverID Integer iDbType Integer iDataType Returns Integer
88007>>>        tColumnType RetvalType  
88007>>>        tColumnType RetvalType  
88007>>>        String sValue
88007>>>        Integer iRetval iPos
88007>>>        
88007>>>        Get _UtilColumnType sDriverID iDbType iDataType "" True to RetvalType 
88008>>>        Move RetvalType.sPrecision to sValue
88009>>>        Move (Pos(".", sValue)) to iPos
88010>>>        If (iPos <> 0) Begin
88012>>>            Move (Left(sValue, (iPos -1))) to iRetval
88013>>>        End                                          
88013>>>>
88013>>>        Else Begin
88014>>>            Move sValue to iRetval
88015>>>        End
88015>>>>
88015>>>        Function_Return iRetval
88016>>>    End_Function
88017>>>    
88017>>>    Function UtilColumnTypePrecisionDec String sDriverID Integer iDbType Integer iDataType Returns Integer
88019>>>        tColumnType RetvalType  
88019>>>        tColumnType RetvalType  
88019>>>        String sValue
88019>>>        Integer iRetval iPos
88019>>>        
88019>>>        Get _UtilColumnType sDriverID iDbType iDataType "" True to RetvalType 
88020>>>        Move RetvalType.sPrecision to sValue
88021>>>        Move (Pos(".", sValue)) to iPos
88022>>>        If (iPos = 0) Begin
88024>>>            Function_Return 0
88025>>>        End
88025>>>>
88025>>>        Move (Mid(sValue, 99, (iPos + 1))) to iRetval
88026>>>
88026>>>        Function_Return iRetval
88027>>>    End_Function
