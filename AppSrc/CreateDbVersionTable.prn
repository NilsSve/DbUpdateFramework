86683>>>    
86683>>>    Function _AllTablesToConvert Returns Integer[]
86685>>>        Integer[] iTableConvertExceptions iTablesArray
86687>>>        Handle hTable
86687>>>        Integer iIndex   
86687>>>        String sTableName
86687>>>        
86687>>>        // a) Get the exception table array the developer has specified
86687>>>        Get piTableConvertExceptions to iTableConvertExceptions        
86688>>>        
86688>>>        // b) Add CodeMast, CodeType & DbVersion to exceptions
86688>>>        Repeat 
86688>>>>
86688>>>            Get_Attribute DF_FILE_NEXT_USED of hTable to hTable
86691>>>            If (hTable > 0 and hTable <> 50) Begin // 50 = Flexerrs.
86693>>>                Get_Attribute DF_FILE_LOGICAL_NAME of hTable to sTableName
86696>>>                If (Uppercase(sTableName) = "CODEMAST" or Uppercase(sTableName) = "CODETYPE" or Uppercase(sTableName) = "DBVERSION") Begin
86698>>>                    Move (SearchArray(hTable, iTableConvertExceptions)) to iIndex
86699>>>                    If (iIndex = -1) Begin
86701>>>                        Move hTable to iTableConvertExceptions[SizeOfArray(iTableConvertExceptions)]
86702>>>                    End
86702>>>>
86702>>>                End
86702>>>>
86702>>>            End
86702>>>>
86702>>>        Until (hTable = 0) 
86704>>>        
86704>>>        Move 0 to hTable
86705>>>        
86705>>>        // c) Spin through filelist.cfg and add all tables except those from the exception array, to the return array.
86705>>>        Repeat 
86705>>>>
86705>>>            Get_Attribute DF_FILE_NEXT_USED of hTable to hTable
86708>>>            If (hTable > 0 and hTable <> 50) Begin // 50 = Flexerrs.
86710>>>                Move (SearchArray(hTable, iTableConvertExceptions)) to iIndex
86711>>>                If (iIndex = -1) Begin
86713>>>                    Move hTable to iTablesArray[SizeOfArray(iTablesArray)]    
86714>>>                End
86714>>>>
86714>>>            End
86714>>>>
86714>>>        Until (hTable = 0) 
86716>>>        
86716>>>        Function_Return iTablesArray
86717>>>    End_Function
86718>>>        
86718>>>    Function ApiTableConvertToSQL_Ex Handle hTable String sDriverID Boolean bUseConnectionID Boolean bToAnsi Boolean bRecnum Boolean bCopyData Returns Boolean
86720>>>        Handle hToTable
86720>>>        Boolean bOK bExists bOpened bMertechDriver bDAWDriver
86720>>>        String sPhysicalName sRootName sDisplayName sEmpty sConnectionID sConnectionString
