86363>>>
86363>>>    // We might have a split Sql script where the info about which database to use is
86363>>>    // put on top of the Sql script, we then need to save it to be able to retrieve it later and
86363>>>    // insert it for scriplets to come after the first one.
86363>>>    Function _SqlFormatStatement String sStmt Returns String
86365>>>        String sUseDatabase sTmp sUseKeyWord sCreateViewKeyWord sDBOKeyWord sNoCountKeyWord sDriverID
86365>>>        Integer iStart iEnd iDbType
86365>>>        Boolean bOK
86365>>>        
86365>>>        Get piDbType to iDbType 
86366>>>        Get psDriverID to sDriverID
86367>>>        Get _SqlFindKeyWord CI_SQLUse          to sUseKeyWord  
86368>>>        Get _SqlFindKeyWord CI_SQLSetNoCountOn to sNoCountKeyWord
86369>>>        Get _SqlFindKeyWord CI_SQLCreateView   to sCreateViewKeyWord            
86370>>>        Get _SqlFindKeyWord CI_SQLDBO          to sDBOKeyWord 
86371>>>        Move (Replaces(" ", sStmt, "")) to sTmp
86372>>>        If (Uppercase(sTmp) contains (sUseKeyWord +"[")) Begin
86374>>>            Move (Pos("[", (Uppercase(sTmp)))) to iStart
86375>>>            Move (Pos("]", sTmp)) to iEnd
86376>>>            Move (Mid(sTmp, (iEnd -iStart +1), iStart)) to sUseDatabase
86377>>>            Move (sUseKeyWord * sUseDatabase + " ") to sUseDatabase
86378>>>            Set Private.psUseDatabase to sUseDatabase
86379>>>        End
86379>>>>
86379>>>        Else Begin   
86380>>>            Move (Uppercase(sStmt)) to sTmp
86381>>>
86381>>>            // A "Create View" statement _must_ be the very first words in a Sql statement.
86381>>>            If (not(sTmp contains sCreateViewKeyWord)) Begin
86383>>>                Get Private.psUseDatabase to sUseDatabase
86384>>>                Move (Insert(sUseDatabase, sStmt, 1)) to sStmt
86385>>>            End 
86385>>>>
86385>>>            
86385>>>            // This is a bit special to place here but was done so because it was easier that way.
86385>>>            // We will get an error when trying to create a view if it already exists.
86385>>>            // So to avoid such errors; we first remove it & then recreate it.
86385>>>            Else If (sTmp contains sCreateViewKeyWord) Begin 
86388>>>                // Make sure we only have one space between statements/words.  
86388>>>                Move (Replaces("  ", sTmp, " ")) to sTmp
86389>>>                Move (Replace(sCreateViewKeyWord, sTmp, "")) to sTmp
86390>>>                Move (Trim(sTmp)) to sTmp
86391>>>                Move (Pos(" ", sTmp)) to iEnd
86392>>>                Move (Left(sTmp, iEnd)) to sTmp
86393>>>                If ((not(sTmp contains ("[" + sDBOKeyWord + "]."))) and (not(sTmp contains (sDBOKeyWord + ".")))) Begin
86395>>>                    Move (sDBOKeyWord + "." + Trim(sTmp)) to sTmp
86396>>>                End  
86396>>>>
86396>>>                Move (Trim(sTmp)) to sTmp
86397>>>                // Remove data view as it already exists!
86397>>>                Get SqlViewRemove sDriverID sTmp to bOK
86398>>>            End
86398>>>>
86398>>>        End
86398>>>>
86398>>>
86398>>>        Function_Return sStmt    
86399>>>    End_Function
86400>>>    
86400>>>    // Returns the proper Sql language key word(s) for the passed SQL key-word constant
86400>>>    Function _SqlFindKeyWord Integer iSQLKeywordConstant Returns String
86402>>>        String sRetval         
86402>>>        Integer iDbType iSize iItem iIndex
86402>>>        tSQLKeyWords[] SQLKeywordArray 
86402>>>        tSQLKeyWords[] SQLKeywordArray 
86403>>>        tSQLKeyWords   SQLKeyWords
86403>>>        tSQLKeyWords   SQLKeyWords
86403>>>        
86403>>>        // Sql back-end type. E.g. MS-SQL, MySQL, Oracle, DB2...
86403>>>        Get piDbType to iDbType
86404>>>        Move iDbType             to SQLKeyWords.iSQLDbType
86405>>>        Move iSQLKeywordConstant to SQLKeyWords.iSQLWord
86406>>>         
86406>>>        Get paSQLKeywordArray to SQLKeywordArray
86407>>>        Move (SearchArray(SQLKeyWords, SQLKeywordArray, Self, RefFunc(CompareFindSQLKeyWords))) to iIndex
86408>>>        Move SQLKeywordArray[iIndex].sSQLPhrase to sRetval
86409>>>
86409>>>        Function_Return sRetval
86410>>>    End_Function
86411>>>    
86411>>>    // Function will "clean/sanitize" the script by removing all comments and blank lines.
86411>>>    Function _SqlUtilSanitizeScript tSQLScriptArray SqlScriptArray Returns tSQLScriptArray[] 
86413>>>        String[] sSQLScriptArray
86414>>>        String sText sLine sTmp sCommentStart sCommentEnd sDashComment
86414>>>        Integer iCh iSize iArgSize iPos iCount
86414>>>        Boolean bCommentStart bCommentEnd bDashComment
86414>>>        
86414>>>        Move False to bCommentStart
86415>>>        Move False to bCommentEnd 
86416>>>        Move False to bDashComment                                    
86417>>>        Move "/*"  to sCommentStart   // These are the standard comment start & stop tokens...
86418>>>        Move "*/"  to sCommentEnd
86419>>>        Move "--"  to sDashComment    // ...but a comment can also start with two dashes "--".
86420>>>
86420>>>        Move (SizeOfArray(SqlScriptArray.sSQLScriptArray)) to iSize
86421>>>        Decrement iSize
86422>>>        Move "" to sText  
86423>>>        
86423>>>        For iCount from 0 to iSize
86429>>>>
86429>>>            Move SqlScriptArray.sSQLScriptArray[iCount] to sLine
86430>>>            Move (Trim(sLine)) to sTmp
86431>>>            If (sTmp <> "") Begin
86433>>>                Move (Left(sTmp, 2) = sDashComment) to bDashComment
86434>>>                If (bCommentStart = False) Begin
86436>>>                    Move (Left(sTmp, 2) = sCommentStart) to bCommentStart
86437>>>                    If (bCommentStart = False) Begin
86439>>>                    End
86439>>>>
86439>>>                End
86439>>>>
86439>>>                Move (sTmp contains sCommentEnd) to bCommentEnd
86440>>>                If (bCommentEnd = True) Begin
86442>>>                    Move False to bCommentStart
86443>>>                End
86443>>>>
86443>>>                If (bDashComment = False and bCommentStart = False and bCommentEnd = False) Begin
86445>>>                    Move sLine to sSQLScriptArray[SizeOfArray(sSQLScriptArray)] 
86446>>>                End
86446>>>>
86446>>>            End
86446>>>>
86446>>>        Loop 
86447>>>>
86447>>>        
86447>>>        // Update the retval struct array:    
86447>>>        Move sSQLScriptArray to SqlScriptArray.sSQLScriptArray
86448>>>        Function_Return SqlScriptArray
86449>>>    End_Function
86450>>>
86450>>>    // *** Database API Functions: ***
86450>>>    // Instead of using Sql Scripts (ESQL), we can opt to use the DataFlex Database API's to 
86450>>>    // make changes/updates to the database.
86450>>>    //
86450>>>    //
86450>>>    // This might not do what you think - Here's what it does:
86450>>>    // It checks that the passed hTable TableName in filelist.cfg is exactly the same as at the SQL back-end.
86450>>>    // If that is True; it creates an .int file for it and changes Filelist.cfg to point
86450>>>    // to the SQL table.
86450>>>    // Typical usage for this function is when an entry exists in the Filelist for a table and the table
86450>>>    // already exists in SQL. 
86450>>>    // This is a bit fiddly as the DF_FILE_PHYSICAL_NAME attribute can only be set inside a 
86450>>>    // Structure_Start ... Structure_End operation when creating a NEW table. Thus it cannot be set when 
86450>>>    // restructuring an existing table.
86450>>>    Function ApiTableAttachToSQL Handle hTable Boolean bUseConnID Returns Boolean
86452>>>        Boolean bExists bOpened bOK bSystemFile bMertechDriver bUseConnectionID
86452>>>        String sDriverID sTableName sConnectionID sConnectionString sDisplayName sRootName sLogicalName sPhysicalName sSchema
86452>>>        Handle hToTable 
86452>>>        Integer iPos
86452>>>        
86452>>>        Move True to bUseConnectionID
86453>>>        If (num_arguments > 1) Begin
86455>>>            Move bUseConnID to bUseConnectionID
86456>>>        End                                    
86456>>>>
86456>>>        
86456>>>        Get psDriverID to sDriverID
86457>>>        // If the table doesn't exist on the SQL back-end we do nothing.
86457>>>        Get SqlUtilCheckIfTableHandleExists hTable sDriverID to bExists
86458>>>        If (bExists = False) Begin
86460>>>            Function_Return False
86461>>>        End
86461>>>>
86461>>>        
86461>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
86462>>>        If (bOK = False) Begin
86464>>>            Function_Return False
86465>>>        End
86465>>>>
86465>>>        
86465>>>        // Then we need to check that the function hasn't been called before; which in case
86465>>>        // we do nothing
86465>>>        Get SQLUtilTableIsAttached sDriverID hTable to bExists
86466>>>        If (bExists = True) Begin
86468>>>            Function_Return False
86469>>>        End
86469>>>>
86469>>>        
86469>>>        Get psConnectionID     to sConnectionID
86470>>>        Get psConnectionString to sConnectionString 
86471>>>        If (sConnectionID = "" or sConnectionString = "") Begin
86473>>>            Error DFERR_PROGRAM ("An SQL connection has NOT been setup correctly. Could not attach table:" * String(hTable) * "to SQL")
86474>>>>
86474>>>            Function_Return False
86475>>>        End                      
86475>>>>
86475>>>
86475>>>        Get psSchema to sSchema
86476>>>        If (sSchema = "") Begin
86478>>>            Get _SqlFindKeyWord CI_SQLDBO to sSchema  
86479>>>        End
86479>>>>
86479>>>
86479>>>        Get IsMertechDriver sDriverID to bMertechDriver
86480>>>        
86480>>>        // Mertech drivers don't use connection id's, so if the passed bUseConnectionID = True that
86480>>>        // was a programmer's error and we adjust for it here.
86480>>>        If (bMertechDriver = True) Begin
86482>>>            Move False to bUseConnectionID
86483>>>        End
86483>>>>
86483>>>            
86483>>>        // If we should use a connection id we need to check it exists; 
86483>>>        // else we create it before attempting creating the table
86483>>>        If (bUseConnectionID = True) Begin  
86485>>>            Get AutoConnectionIDLogin to bOK
86486>>>            If (bOk = False) Begin
86488>>>                Error DFERR_PROGRAM ("The Connection ID:" * sConnectionID * "could not be created and therefor the table can't be created.")
86489>>>>
86489>>>                Function_Return False
86490>>>            End
86490>>>>
86490>>>        End
86490>>>>
86490>>>            
86490>>>        Get_Attribute DF_FILE_ROOT_NAME of hTable to sRootName
86493>>>        Get _TableNameOnly sRootName to sRootName             
86494>>>        If (sRootName = "") Begin
86496>>>            Function_Return False
86497>>>        End
86497>>>>
86497>>>        Move (sRootName + ".int")                    to sPhysicalName       
86498>>>        Get_Attribute DF_FILE_LOGICAL_NAME of hTable to sLogicalName
86501>>>        Get_Attribute DF_FILE_DISPLAY_NAME of hTable to sDisplayName
86504>>>        If (sDisplayName contains ".") Begin
86506>>>            Move (Pos(".", sDisplayName)) to iPos  
86507>>>            Move (Mid(sDisplayName, 200 ,(iPos + 1))) to sDisplayName
86508>>>            Move (sSchema + "." + sDisplayName)       to sDisplayName
86509>>>        End
86509>>>>
86509>>>        If (not(Lowercase(sDisplayName) contains Lowercase(sSchema + "."))) Begin
86511>>>            Move (Lowercase(sSchema) + "." + sDisplayName) to sDisplayName
86512>>>        End
86512>>>>
86512>>>        
86512>>>        // ToDo: Needs to be revised. Should be able to connect to SQL without table already exist?
86512>>>        Open hTable Mode DF_EXCLUSIVE
86514>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpened
86517>>>        If (bOpened = False) Begin 
86519>>>            Error DFERR_PROGRAM ("Function ApiTableAttachToSQL - Could not open table number:" * String(hTable) * sLogicalName)
86520>>>>
86520>>>            Function_Return False
86521>>>        End                      
86521>>>>
86521>>>        
86521>>>        If (ghoProgressBar <> 0) Begin
86523>>>            Send DoAdvance of ghoProgressBar
86524>>>        End
86524>>>>
86524>>>        // Note: The hToTable will get changed by the Structure_xxx command...
86524>>>        Move hTable to hToTable 
86525>>>        Move False to Err       
86526>>>        
86526>>>        // We now create a stub .int file and after Structure_end and also change the Filelist.cfg,
86526>>>        // then we do a pseudo .int file change with the "SqlUtilUpdateIntFile" function. After that we have
86526>>>        // a proper and updated .int file.
86526>>>        Get_Attribute DF_FILE_IS_SYSTEM_FILE of hTable to bSystemFile  
86529>>>        Get SqlUtilCreateIntFile hTable sDriverID sConnectionID True bSystemFile to bOK
86530>>>        
86530>>>        Structure_Start hToTable sDriverID
86531>>>            If (bUseConnectionID = True) Begin  
86533>>>                Set_Attribute DF_FILE_LOGIN     of hToTable to (CS_DFCONNID + "=" + sConnectionID)
86536>>>            End
86536>>>>
86536>>>            Else Begin
86537>>>                Set_Attribute DF_FILE_LOGIN     of hToTable to sConnectionString
86540>>>            End
86540>>>>
86540>>>            Set_Attribute DF_FILE_OWNER         of hToTable to (Lowercase(sSchema))
86543>>>            // For unknown reason the above sometimes triggers an error and it doesn't help to try to trap the error; so we cheat...
86543>>>            Move False to Err
86544>>>            Move 0 to LastErr
86545>>>        Structure_End hToTable 
86547>>>        
86547>>>        Move (not(Err)) to bOK
86548>>>        If (bOK = True) Begin
86550>>>            // The attributes set above will always trigger an error
86550>>>            // We also adjust the Filelist entries
86550>>>            Set_Attribute DF_FILE_ROOT_NAME    of hTable to (sDriverID + ":" + sRootName)
86553>>>            Set_Attribute DF_FILE_LOGICAL_NAME of hTable to sLogicalName
86556>>>            Set_Attribute DF_FILE_DISPLAY_NAME of hTable to sDisplayName
86559>>>            
86559>>>            // This pseudo updates the .int file to make it up-to-date with the SQL back-end.
86559>>>            Get SqlUtilUpdateIntFile hTable to bOK
86560>>>        End
86560>>>>
86560>>>          
86560>>>        Function_Return (bOK = True)
86561>>>    End_Function
86562>>>    
86562>>>    // Sample usage:    
