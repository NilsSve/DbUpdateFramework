90974>            Get UtilColumnTypePrecisionDec  of ghoDbUpdateFunctionLibrary DATAFLEX_ID EN_DbTypeDataFlex iDataType to iDec   
90975>            Get UtilColumnTypeFixed         of ghoDbUpdateFunctionLibrary DATAFLEX_ID EN_DbTypeDataFlex iDataType to bFixed
90976>            Set Enabled_State of oLength_sf   to (bFixed = False)
90977>            Set Enabled_State of oDecimals_sf to (bFixed = False)
90978>            Set Value of oLength_sf to iSize
90979>            If (iDec = 0) Begin
90981>                Set Value of oDecimals_sf to ""
90982>            End                                                
90982>            Else Begin
90983>                Set Value of oDecimals_sf to iDec
90984>            End      
