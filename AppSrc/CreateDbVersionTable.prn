83006>>>>>        If (sValue <> DATAFLEX_ID) Begin
83008>>>>>            Get ConstructConnectionString SQLConnection.sDriverID SQLConnection.sServer SQLConnection.sDatabase SQLConnection.bTrusted SQLConnection.sUserID SQLConnection.sPassword to SQLConnection.sConnectionString
83009>>>>>        End
83009>>>>>>
83009>>>>>    End_Procedure
