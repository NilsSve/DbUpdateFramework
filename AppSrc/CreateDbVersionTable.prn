85113>>>    // Returns a string array with all table columns/fields for the passed table handle and driver id.
85113>>>    Function SqlUtilEnumerateColumns String sDriverID String sTableName Returns String[]
85115>>>        String[] sReturnArray                                          
85116>>>        String sServer sConnectionString sSelect sSchema
85116>>>        Boolean bOK
85116>>>        
85116>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
85117>>>        If (bOK = False) Begin
85119>>>            Error DFERR_PROGRAM ("Unsupported driver. A list of table columns could not be retrieved for:" * sDriverID + ".")
85120>>>>
85120>>>            Function_Return sReturnArray
85121>>>        End   
85121>>>>
85121>>>       
85121>>>        Get psConnectionString to sConnectionString  
85122>>>        Get psSchema to sSchema
85123>>>        
85123>>>        Case Begin
85123>>>            Case (sDriverID = MSSQLDRV_ID)    
85125>>>                Move ("select name from sys.columns where [object_id] = object_id('dbo." + sTableName + "')") to sSelect
85126>>>                Get SqlEnumerateEsqlDAW sSelect 1 to sReturnArray
85127>>>                Case Break
85128>>>
85128>>>            Case (sDriverID = DB2_DRV_ID) 
85131>>>                Move ("SELECT colname from syscat.columns WHERE tabschema = '" + sSchema + "'" * "AND tabname = '" + sTableName + "'") to sSelect  
85132>>>                Get SqlEnumerateEsqlDAW sSelect 1 to sReturnArray
85133>>>                Case Break
85134>>>
85134>>>            Case (sDriverID = SQLFLEX)
85137>>>                Move ("select name from sys.columns where [object_id] = object_id('dbo." + sTableName + "')") to sSelect
85138>>>                Get SqlEnumerateEsqlMertech sSelect 1 to sReturnArray
85139>>>                Case Break
85140>>>            
85140>>>            Case (sDriverID = MDSMySQL) 
85143>>>                Move ("SHOW COLUMNS FROM" * sTableName) to sSelect
85144>>>                Get SqlEnumerateEsqlMertech sSelect 1 to sReturnArray
85145>>>                Case Break
85146>>>            
85146>>>            Case (sDriverID = MDSPgSQL) 
85149>>>                Move ("select column_name, data_type, character_maximum_length from INFORMATION_SCHEMA.COLUMNS where table_name = '" +sTableName + "'") to sSelect
85150>>>                Get SqlEnumerateEsqlMertech sSelect 1 to sReturnArray
85151>>>                Case Break            
85152>>>            
85152>>>            Case (sDriverID = ORAFLEX) 
85155>>>                Move ("SELECT column_name from user_tab_cols WHERE table_name = '" + sTableName + "'") to sSelect
85156>>>                Get SqlEnumerateEsqlMertech sSelect 1 to sReturnArray
85157>>>                Case Break
85158>>>                            
85158>>>            Case Else     
85158>>>                Error DFERR_PROGRAM "Unsupported driver passed to SqlUtilEnumerateColumns function."
85159>>>>
85159>>>                Case Break
85160>>>        Case End
85160>>>        
85160>>>        Function_Return sReturnArray
85161>>>    End_Function  
