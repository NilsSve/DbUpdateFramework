87150>>>    // ToDo: Needs to be revised
87150>>>    Procedure ApiTableCreateFromDEF String sPath String sFileName String sTableName String sDisplayName Integer iFilelistSlot
87152>>>        Handle hTable 
87152>>>        String sDEFName sDataPath sDriverID
87152>>>        Boolean bExists
87152>>>        
87152>>>        // Do nothing if MSSQL Driver.
87152>>>//        Get IsMSSQLDriver to bExists
87152>>>//        If (bExists = True) Begin
87152>>>//            Procedure_Return
87152>>>//        End
87152>>>        
87152>>>        Get psDataPathFirstPart to sDataPath
87153>>>        Get vFilePathExists (sDataPath + sFileName + ".dat") to bExists
87154>>>        If (bExists = True) Begin      
87156>>>            // We also needs to check if it is an Alias file, in case the sFileName.dat exists, but it may
87156>>>            // still be missing from the filelist and needs to be added.
87156>>>            Get UtilTableNumberIsInUse iFilelistSlot to bExists
87157>>>            If (bExists = True) Begin
87159>>>                Procedure_Return
87160>>>            End 
87160>>>>
87160>>>            // Do _not_ use the DEF file if an alias, it will overwrite the base table data.
87160>>>            Else Begin
87161>>>                Set_Attribute DF_FILE_ROOT_NAME    of iFilelistSlot to sFileName
87164>>>                Set_Attribute DF_FILE_LOGICAL_NAME of iFilelistSlot to sTableName
87167>>>                Set_Attribute DF_FILE_DISPLAY_NAME of iFilelistSlot to sDisplayName
87170>>>                Procedure_Return
87171>>>            End
87171>>>>
87171>>>        End
87171>>>>
87171>>>    
87171>>>        Move (sPath + sFileName + ".def") to sDEFName
87172>>>        Move 0 to hTable
87173>>>        Move False to Err
87174>>>    
87174>>>        Structure_Start hTable DATAFLEX_ID
87175>>>            Load_Def sDEFName Onto hTable
87176>>>            Set_Attribute DF_FILE_PHYSICAL_NAME of hTable to sFileName
87179>>>        Structure_End hTable DF_STRUCTEND_OPT_NONE
87181>>>    
87181>>>        Move iFilelistSlot to hTable
87182>>>        Set_Attribute DF_FILE_ROOT_NAME    of hTable to sFileName
87185>>>        Set_Attribute DF_FILE_LOGICAL_NAME of hTable to sTableName
87188>>>        Set_Attribute DF_FILE_DISPLAY_NAME of hTable to sDisplayName
87191>>>    
87191>>>    End_Procedure      
