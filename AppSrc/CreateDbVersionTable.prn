91495>>>>>>>>>>>// Public Properties that should be set:
91495>>>>>>>>>>>//
91495>>>>>>>>>>>//     Property String  Help_Filename   (Help_File_Default(self))
91495>>>>>>>>>>>//     Property Integer Help_Id_General 0
