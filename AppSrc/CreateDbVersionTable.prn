82414>>>>>>>    // The normal connection string looks something like this;
82414>>>>>>>    // "SERVER=.\SQLEXPRESS; DATABASE=OrderEntry; TRUSTED_CONNECTION=Yes; ,0"
82414>>>>>>>    // ...but the full connection string looks like this;
82414>>>>>>>    // "DFConnectionId OrderEntry, SERVER=.\SQLEXPRESS; DATABASE=OrderEntry; TRUSTED_CONNECTION=Yes; ,0"
82414>>>>>>>//    Function SQLIniFileAddConnection String sFullConnectionString Returns Boolean
82414>>>>>>>//        String sSection
82414>>>>>>>//        Integer iCount
82414>>>>>>>//        
82414>>>>>>>//        Move False to Err
82414>>>>>>>//        Get psIniSectionName to sSection
82414>>>>>>>//        Get SQLIniFileNumberOfConnections to iCount
82414>>>>>>>//        Increment iCount
82414>>>>>>>//        Set IniFileValue sSection (CS_SQLIniSectionName + String(iCount)) to sFullConnectionString
82414>>>>>>>//        
82414>>>>>>>//        Function_Return (Err = False)
82414>>>>>>>//    End_Function
82414>>>>>>>    
82414>>>>>>>    Function SQLIniFileDeleteAllConnections Returns Boolean
82416>>>>>>>        Integer iCount 
82416>>>>>>>        Boolean bExists 
82416>>>>>>>        String sSection
82416>>>>>>>        
82416>>>>>>>        Move False to Err
82417>>>>>>>        Move 1 to iCount
82418>>>>>>>        Get psIniSectionName to sSection
82419>>>>>>>        Get SectionExists (CS_SQLIniSectionName + String(iCount)) to bExists
82420>>>>>>>        While (bExists = True)
82424>>>>>>>            Send DeleteSection (CS_SQLIniSectionName + String(iCount))
82425>>>>>>>            Increment iCount
82426>>>>>>>            Get SectionExists (CS_SQLIniSectionName + String(iCount)) to bExists
82427>>>>>>>        Loop
82428>>>>>>>>
82428>>>>>>>        Function_Return (Err = False)
82429>>>>>>>    End_Function
82430>>>>>>>    
82430>>>>>>>    Function SQLIniFileDeleteConnection Integer iItem Returns Boolean
82432>>>>>>>        Integer iCount 
82432>>>>>>>        String sSection 
82432>>>>>>>        Boolean bExists
82432>>>>>>>        
82432>>>>>>>        Move False to Err
82433>>>>>>>        Move 1 to iCount
82434>>>>>>>        Get psIniSectionName to sSection
82435>>>>>>>        Get KeyExists sSection CS_SQLIniConnectionIdKeyword to bExists
82436>>>>>>>        While (bExists = True)
82440>>>>>>>            If (iCount = iItem) Begin   
82442>>>>>>>                Send DeleteSection sSection
82443>>>>>>>//                Set IniFileValue sSection (CS_SQLIniSectionName + String(iCount)) to ""
82443>>>>>>>                Move 9999 to iCount // Just some ridiculously high number to get out of the loop as we're done.
82444>>>>>>>            End
82444>>>>>>>>
82444>>>>>>>            Increment iCount
82445>>>>>>>            Get KeyExists sSection (CS_SQLIniSectionName + String(iCount)) to bExists
82446>>>>>>>        Loop
82447>>>>>>>>
82447>>>>>>>        
82447>>>>>>>        Function_Return (Err = False)
82448>>>>>>>    End_Function
82449>>>>>>>    
82449>>>>>>>    // Returns all connection details for the passed Connection ID as a tSQLConnection
82449>>>>>>>    // If it fails the returned struct member SQLConnection.bError = True. 
82449>>>>>>>    Function SQLIniFileConnectionID String sConnectionID Returns tSQLConnection
82451>>>>>>>        tSQLConnection[] SQLConnectionsArray
82451>>>>>>>        tSQLConnection[] SQLConnectionsArray
82452>>>>>>>        tSQLConnection   SQLConnection
82452>>>>>>>        tSQLConnection   SQLConnection
82452>>>>>>>        Integer iIndex
82452>>>>>>>        
82452>>>>>>>        Get SQLIniFileConnectionIDIndex sConnectionID to iIndex
82453>>>>>>>        If (iIndex = -1) Begin
82455>>>>>>>            Move True to SQLConnection.bError
82456>>>>>>>            Function_Return SQLConnection
82457>>>>>>>        End
82457>>>>>>>>
82457>>>>>>>
82457>>>>>>>        Get SQLIniFileReadConnections to SQLConnectionsArray
82458>>>>>>>        Move SQLConnectionsArray[iIndex -1] to SQLConnection
82459>>>>>>>        
82459>>>>>>>        Function_Return SQLConnection    
82460>>>>>>>    End_Function
82461>>>>>>>            
82461>>>>>>>    // Returns -1 if the passed connection ID was not found, else the item number.
82461>>>>>>>    Function SQLIniFileConnectionIDIndex String sConnectionID Returns Integer
82463>>>>>>>        tSQLConnection[] SQLConnectionsArray
82463>>>>>>>        tSQLConnection[] SQLConnectionsArray
82464>>>>>>>        Integer iRetval iCount iSize
82464>>>>>>>        String sValue
82464>>>>>>>        Boolean bExists
82464>>>>>>>        
82464>>>>>>>        Move -1 to iRetval
82465>>>>>>>
82465>>>>>>>        Get SQLIniFileReadConnections to SQLConnectionsArray
82466>>>>>>>        Move (SizeOfArray(SQLConnectionsArray)) to iSize
82467>>>>>>>        Decrement iSize
82468>>>>>>>        For iCount from 0 to iSize
82474>>>>>>>>
82474>>>>>>>            Move SQLConnectionsArray[iCount].sConnectionID to sValue 
82475>>>>>>>            Move (Uppercase(sValue) = Uppercase(sConnectionID)) to bExists
82476>>>>>>>            If (bExists) Begin
82478>>>>>>>                Move (iCount + 1) to iRetval // The [ConnectionX] keys are one-based (starts at 1) but the loop starts at zero.
82479>>>>>>>                Move iSize to iCount         // We're done!
82480>>>>>>>            End
82480>>>>>>>>
82480>>>>>>>        Loop
82481>>>>>>>>
82481>>>>>>>                
82481>>>>>>>        Function_Return iRetval
82482>>>>>>>    End_Function       
82483>>>>>>>    
82483>>>>>>>    // Checks if the passed sConnectionID exists more than once in the passed struct array.
82483>>>>>>>    // Used to check that ConnectionID's are unique.
82483>>>>>>>    Function IsConnectionIDDuplicate String sConnectionID Returns Boolean
82485>>>>>>>        Integer iCount iSize iItems
82485>>>>>>>        String sValue
82485>>>>>>>        Boolean bExists                                   
82485>>>>>>>        tSQLConnection[] SQLConnectionsArray 
82485>>>>>>>        tSQLConnection[] SQLConnectionsArray 
82486>>>>>>>        
82486>>>>>>>        Move 0 to iItems                     
82487>>>>>>>        Get SQLIniFileReadConnections to SQLConnectionsArray
82488>>>>>>>        Move (SizeOfArray(SQLConnectionsArray)) to iSize
82489>>>>>>>        Decrement iSize
82490>>>>>>>        For iCount from 0 to iSize
82496>>>>>>>>
82496>>>>>>>            Move SQLConnectionsArray[iCount].sConnectionID to sValue 
82497>>>>>>>            Move (sValue = sConnectionID) to bExists
82498>>>>>>>            If (bExists) Begin
82500>>>>>>>                Increment iItems
82501>>>>>>>            End
82501>>>>>>>>
82501>>>>>>>        Loop
82502>>>>>>>>
82502>>>>>>>                
82502>>>>>>>        Function_Return (iItems > 1)
82503>>>>>>>    End_Function       
82504>>>>>>>    
82504>>>>>>>    // To update the SQLConnections.ini file with a new default Connection ID.
82504>>>>>>>    Function SQLIniFileSetDefaultConnection String sConnectionID Returns Boolean
82506>>>>>>>        Boolean bRetval bOK
82506>>>>>>>        Integer iItem iSize iCount
82506>>>>>>>        tSQLConnection[] SQLConnectionsArray
82506>>>>>>>        tSQLConnection[] SQLConnectionsArray
82507>>>>>>>        tSQLConnection SQLConnection
82507>>>>>>>        tSQLConnection SQLConnection
82507>>>>>>>        String sConnectionString
82507>>>>>>>        
82507>>>>>>>        Move False to Err     
82508>>>>>>>        Get psConnectionString to sConnectionString             
82509>>>>>>>        
82509>>>>>>>        Get SQLIniFileReadConnections to SQLConnectionsArray
82510>>>>>>>        Move (SizeOfArray(SQLConnectionsArray)) to iSize
82511>>>>>>>        Decrement iSize
82512>>>>>>>        // Set all current connection to inactive.
82512>>>>>>>        For iCount from 0 to iSize
82518>>>>>>>>
82518>>>>>>>            Move False to SQLConnectionsArray[iCount].bEnabled
82519>>>>>>>        Loop                                              
82520>>>>>>>>
82520>>>>>>>        
82520>>>>>>>        Get SQLIniFileConnectionID sConnectionID to SQLConnection
82521>>>>>>>        Move True              to SQLConnection.bEnabled
82522>>>>>>>        Move sConnectionString to SQLConnection.sConnectionString
82523>>>>>>>        Move (InsertInArray(SQLConnectionsArray, 0, SQLConnection)) to SQLConnectionsArray
82524>>>>>>>        Get SQLIniFileWriteConnections SQLConnectionsArray to bOK
82525>>>>>>>        
82525>>>>>>>        Function_Return (bOK = True)
82526>>>>>>>    End_Function
82527>>>>>>>    
82527>>>>>>>    // Used for updating an existing connection with new data.
82527>>>>>>>    // Returns True if successful.
82527>>>>>>>    Function SQLIniFileUpdateConnection tSQLConnection SQLConnection Returns Boolean
82529>>>>>>>        Boolean bRetval bOK
82529>>>>>>>        Integer iItem iSize iCount
82529>>>>>>>        tSQLConnection[] SQLConnectionsArray
82529>>>>>>>        tSQLConnection[] SQLConnectionsArray
82530>>>>>>>        
82530>>>>>>>        Move False to Err           
82531>>>>>>>        Move -1 to iItem  
82532>>>>>>>        Get SQLIniFileReadConnections to SQLConnectionsArray
82533>>>>>>>        Move (SizeOfArray(SQLConnectionsArray)) to iSize
82534>>>>>>>        Decrement iSize
82535>>>>>>>        // Set all current connection to inactive.
82535>>>>>>>        For iCount from 0 to iSize
82541>>>>>>>>
82541>>>>>>>            Move False to SQLConnectionsArray[iCount].bEnabled 
82542>>>>>>>            If (SQLConnectionsArray[iCount].sConnectionID = SQLConnection.sConnectionID) Begin
82544>>>>>>>                Move iCount to iItem
82545>>>>>>>            End
82545>>>>>>>>
82545>>>>>>>        Loop                                              
82546>>>>>>>>
82546>>>>>>>        
82546>>>>>>>        If (iItem <> -1) Begin
82548>>>>>>>            Move True to SQLConnection.bEnabled
82549>>>>>>>            Move SQLConnection to SQLConnectionsArray[iItem]
82550>>>>>>>            Get SQLIniFileWriteConnections SQLConnectionsArray to bOK
82551>>>>>>>        End
82551>>>>>>>>
82551>>>>>>>        
82551>>>>>>>        Function_Return (bOK = True)
82552>>>>>>>    End_Function
82553>>>>>>>    
82553>>>>>>>    Function SQLIniFileReadConnections Returns tSQLConnection[]
82555>>>>>>>        tSQLConnection[] SQLConnectionsArray
82555>>>>>>>        tSQLConnection[] SQLConnectionsArray
82556>>>>>>>        String sSection sValue
82556>>>>>>>        Integer iCount
82556>>>>>>>        Boolean bExists bEnabled
82556>>>>>>>        
82556>>>>>>>        Get psIniSectionName to sSection
82557>>>>>>>        Get SectionExists sSection to bExists
82558>>>>>>>        If (bExists = False) Begin   
82560>>>>>>>            Function_Return SQLConnectionsArray
82561>>>>>>>        End                                  
82561>>>>>>>>
82561>>>>>>>        Get SectionExists CS_SQLIniConnectionSection to bExists
82562>>>>>>>        If (bExists = True) Begin
82564>>>>>>>            Error DFERR_PROGRAM "Sorry, the format for the SQLConnections.ini file has been changed and this file has the old format that is no longer valid and thus cannot be read. You need to re-enter your connection(s)."
82565>>>>>>>>
82565>>>>>>>        End
82565>>>>>>>>
82565>>>>>>>                
82565>>>>>>>        Move 1 to iCount // The section name "[ConnectionXX]" starts with "1"
82566>>>>>>>        Get SectionExists (CS_SQLIniSectionName + String(iCount)) to bExists 
82567>>>>>>>        
82567>>>>>>>        While (bExists = True)
82571>>>>>>>            // We always put the enabled/active connection at the top
82571>>>>>>>            Move (iCount = 1) to bEnabled
82572>>>>>>>            Move bEnabled to SQLConnectionsArray[iCount].bEnabled
82573>>>>>>>            
82573>>>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniConnectionIdKeyword ""        to SQLConnectionsArray[iCount].sConnectionID
82574>>>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniDriverKeyword       ""        to SQLConnectionsArray[iCount].sDriverID
82575>>>>>>>
82575>>>>>>>            // The iDbType might be missing from the ini-file. This is e.g. the case when a DAW Managed Connection "DFConnId.ini" file is read.
82575>>>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniDbTypeKeyword       "99"      to sValue
82576>>>>>>>            If (sValue = "99") Begin
82578>>>>>>>                Get SqlUtilDbTypeFromDriver SQLConnectionsArray[iCount].sDriverID to sValue
82579>>>>>>>            End
82579>>>>>>>>
82579>>>>>>>            Move sValue                                                                                     to SQLConnectionsArray[iCount].iDbType
82580>>>>>>>
82580>>>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniConnectionKeyWord   ""        to SQLConnectionsArray[iCount].sConnectionString
82581>>>>>>>            Get ParseKeyWord SQLConnectionsArray[iCount].sConnectionString (CS_SQLIniServerKeyword + "=")   to SQLConnectionsArray[iCount].sServer
82582>>>>>>>            If (SQLConnectionsArray[iCount].sServer = "") Begin
82584>>>>>>>                Get ParseKeyWord SQLConnectionsArray[iCount].sConnectionString (CS_SQLIniDSNKeyword +"=")   to SQLConnectionsArray[iCount].sServer
82585>>>>>>>            End
82585>>>>>>>>
82585>>>>>>>            Get ParseKeyWord SQLConnectionsArray[iCount].sConnectionString (CS_SQLIniDatabaseKeyword + "=") to SQLConnectionsArray[iCount].sDatabase
82586>>>>>>>
82586>>>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniTrustedKeyword      ""        to sValue
82587>>>>>>>            Move (If(Uppercase(sValue) = "YES", True, False))                                               to SQLConnectionsArray[iCount].bTrusted
82588>>>>>>>
82588>>>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniUIDKeyword          ""        to SQLConnectionsArray[iCount].sUserID
82589>>>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniDFPWDKeyword        ""        to sValue
82590>>>>>>>            If (pbDFConnId(Self) = False and sValue <> "") Begin
82592>>>>>>>                Get DecryptPassword sValue to sValue    
82593>>>>>>>            End
82593>>>>>>>>
82593>>>>>>>            Move sValue                                                                                     to SQLConnectionsArray[iCount].sPassword
82594>>>>>>>            
82594>>>>>>>            // Here we reconstruct the connection string to be complete with all params;
82594>>>>>>>            Get ConstructConnectionString SQLConnectionsArray[iCount].sDriverID SQLConnectionsArray[iCount].sServer SQLConnectionsArray[iCount].sDatabase ;                                          SQLConnectionsArray[iCount].bTrusted SQLConnectionsArray[iCount].sUserID SQLConnectionsArray[iCount].sPassword ;                                          to SQLConnectionsArray[iCount].sConnectionString    
82595>>>>>>>            
82595>>>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniSchemaKeyword          ""     to SQLConnectionsArray[iCount].sSchema
82596>>>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniBaseTableSpaceKeyword  ""     to SQLConnectionsArray[iCount].sBaseTableSpace
82597>>>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniLongTableSpaceKeyword  ""     to SQLConnectionsArray[iCount].sLongTableSpace
82598>>>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniIndexTableSpaceKeyword ""     to SQLConnectionsArray[iCount].sIndexTableSpace
82599>>>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniSilentLoginKeyword     ""     to SQLConnectionsArray[iCount].bSilentLogin  
82600>>>>>>>//            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniDisabledKeyword        ""     to SQLConnectionsArray[iCount].bDisabled
82600>>>>>>>
82600>>>>>>>            Increment iCount
82601>>>>>>>            Get SectionExists (CS_SQLIniSectionName + String(iCount)) to bExists
82602>>>>>>>        Loop
82603>>>>>>>>
82603>>>>>>>        
82603>>>>>>>        // Lastly, we remove the very first array item as it is empty (we started at 1 because that is the first [Connection#])
82603>>>>>>>        If (SizeOfArray(SQLConnectionsArray) > 0) Begin
82605>>>>>>>            Move (RemoveFromArray(SQLConnectionsArray, 0)) to SQLConnectionsArray
82606>>>>>>>        End
82606>>>>>>>>
82606>>>>>>>        
82606>>>>>>>        Function_Return SQLConnectionsArray
82607>>>>>>>    End_Function 
82608>>>>>>>        
82608>>>>>>>    Function SQLIniFileWriteConnections tSQLConnection[] SQLConnectionsArray Returns Boolean
82610>>>>>>>        Integer iCount iSize iItem
82610>>>>>>>        Boolean bIsOneActive bEnabled bExists bOK
82610>>>>>>>        String sConnectionString sSection sValue
82610>>>>>>>        
82610>>>>>>>        // First we need to _remove_ all current connections in the ini-file, we
82610>>>>>>>        // do that by setting their values to "".
82610>>>>>>>        Move 0 to iCount  
82611>>>>>>>        Get SQLIniFileDeleteAllConnections to bOK
82612>>>>>>>        If (bOK = False) Begin
82614>>>>>>>            Function_Return False
82615>>>>>>>        End                 
82615>>>>>>>>
82615>>>>>>>        
82615>>>>>>>        Move False to Err
82616>>>>>>>        Get psIniSectionName to sSection                                                          
82617>>>>>>>        // Sorting will make sure we have the active connection record as the first connection item in the ini-file.
82617>>>>>>>        Move (SortArray(SQLConnectionsArray, Self, (RefFunc(SortActiveFirst)))) to SQLConnectionsArray
82618>>>>>>>        Move (SizeOfArray(SQLConnectionsArray)) to iSize
82619>>>>>>>        Decrement iSize       
82620>>>>>>>        
82620>>>>>>>        For iCount from 0 to iSize
82626>>>>>>>>
82626>>>>>>>            // DF 19 compatible settings:
82626>>>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniConnectionIdKeyword   to SQLConnectionsArray[iCount].sConnectionID
82627>>>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniDriverKeyword         to SQLConnectionsArray[iCount].sDriverID
82628>>>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniUIDKeyword            to SQLConnectionsArray[iCount].sUserID
82629>>>>>>>            
82629>>>>>>>            Move SQLConnectionsArray[iCount].sPassword to sValue
82630>>>>>>>            If (pbDFConnId(Self) = False and sValue <> "") Begin
82632>>>>>>>                Get EncryptPassword sValue to sValue    
82633>>>>>>>            End
82633>>>>>>>>
82633>>>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniDFPWDKeyword          to sValue
82634>>>>>>>
82634>>>>>>>            If (SQLConnectionsArray[iCount].bTrusted = True) Begin
82636>>>>>>>                Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniTrustedKeyword    to CS_SQLIniConnectionYes
82637>>>>>>>            End                                                                
82637>>>>>>>>
82637>>>>>>>            
82637>>>>>>>            Get ConstructShortConnectionString SQLConnectionsArray[iCount].sDriverID SQLConnectionsArray[iCount].sServer SQLConnectionsArray[iCount].sDatabase ;                                            to SQLConnectionsArray[iCount].sConnectionString
82638>>>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniConnectionKeyWord     to SQLConnectionsArray[iCount].sConnectionString
82639>>>>>>>            
82639>>>>>>>            // The Database Update Framework extended settings:
82639>>>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniDbTypeKeyword          to SQLConnectionsArray[iCount].iDbType
82640>>>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniSchemaKeyword          to SQLConnectionsArray[iCount].sSchema
82641>>>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniBaseTableSpaceKeyword  to SQLConnectionsArray[iCount].sBaseTableSpace
82642>>>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniLongTableSpaceKeyword  to SQLConnectionsArray[iCount].sLongTableSpace
82643>>>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniIndexTableSpaceKeyword to SQLConnectionsArray[iCount].sIndexTableSpace
82644>>>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniSilentLoginKeyword     to SQLConnectionsArray[iCount].bSilentLogin
82645>>>>>>>        Loop                 
82646>>>>>>>>
82646>>>>>>>        
82646>>>>>>>        Function_Return (bOK and Err = False)
82647>>>>>>>    End_Function
82648>>>>>>>
82648>>>>>>>    // *** DbType conversion routines - Converts between string/integer and driver ID values ***
82648>>>>>>>    //
82648>>>>>>>    // SQL utility function that returns a database type (string) constant
82648>>>>>>>    // corresponding to the passed iDbType.
82648>>>>>>>    Function SqlUtilDbTypeToString Integer iDbType Returns String
82650>>>>>>>        String sRetval
82650>>>>>>>        If (iDbType = EN_dbTypeMSSQL)       Move CS_dbTypeMSSQL     to sRetval
82653>>>>>>>        If (iDbType = EN_dbTypeMySQL)       Move CS_dbTypeMySQL     to sRetval
82656>>>>>>>        If (iDbType = EN_dbTypeOracle)      Move CS_dbTypeOracle    to sRetval
82659>>>>>>>        If (iDbType = EN_dbTypeDB2)         Move CS_dbTypeDB2       to sRetval
82662>>>>>>>        If (iDbType = EN_dbTypePostgre)     Move CS_dbTypePostgre   to sRetval
82665>>>>>>>        Function_Return sRetval
82666>>>>>>>    End_Function
82667>>>>>>>    
82667>>>>>>>    // SQL utility function that returns a database type constant (integer)
82667>>>>>>>    // corresponding to the passed sDbType string constant.
82667>>>>>>>    Function SqlUtilDbTypeToInteger String sDbType  Returns Integer
82669>>>>>>>        Integer iRetval
82669>>>>>>>        If (sDbType = CS_dbTypeMSSQL)       Move EN_dbTypeMSSQL     to iRetval
82672>>>>>>>        If (sDbType = CS_dbTypeMySQL)       Move EN_dbTypeMySQL     to iRetval
82675>>>>>>>        If (sDbType = CS_dbTypeOracle)      Move EN_dbTypeOracle    to iRetval
82678>>>>>>>        If (sDbType = CS_dbTypeDB2)         Move EN_dbTypeDB2       to iRetval
82681>>>>>>>        If (sDbType = CS_dbTypePostgre)     Move EN_dbTypePostgre   to iRetval
82684>>>>>>>        Function_Return iRetval
82685>>>>>>>    End_Function    
82686>>>>>>>    
82686>>>>>>>    // Pass an integer DbType and function returns the database type integer as a string value.
82686>>>>>>>    // Used e.g. when reading a connection ini-file to display the database type in
82686>>>>>>>    // the SQL Connection program's grid.
82686>>>>>>>    Function SqlUtilDbTypeIntegerToStringConstant Integer iDbType Returns String
82688>>>>>>>        String sRetval
