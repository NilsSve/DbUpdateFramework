81199>>>>>>>Class cMSSQLHandler Is A cCLIHandler
81200>>>>>>>
81200>>>>>>>    Procedure Construct_Object
81202>>>>>>>        Forward Send Construct_Object
81204>>>>>>>
81204>>>>>>>        Set psDriverID To MSSQLDRV_ID
81205>>>>>>>    End_Procedure // Construct_Object
81206>>>>>>>
81206>>>>>>>
81206>>>>>>>
81206>>>>>>>    //***
81206>>>>>>>    //*** Function: ExtractList
81206>>>>>>>    //*** Purpose : Extract the list from the out connect string.
81206>>>>>>>    //***
81206>>>>>>>
81206>>>>>>>    Function ExtractList String sOutConnStr Integer hoStore Returns Integer
81208>>>>>>>        Local String  sItem
81208>>>>>>>        Local Integer iStart
81208>>>>>>>        Local Integer iEnd
81208>>>>>>>
81208>>>>>>>        If (hoStore = 0) ;            Move Current_object To hoStore
81211>>>>>>>
81211>>>>>>>        Send Delete_Data To hoStore
81212>>>>>>>        Move (Pos("{", sOutConnStr)) To iStart
81213>>>>>>>        While (iStart > 0)
81217>>>>>>>            Move (Right(sOutConnStr, Length(sOutConnStr) - iStart)) To sOutConnStr
81218>>>>>>>            If (Left(sOutConnStr, 1) = "}") ;                Move 0 To iStart
81221>>>>>>>            Else Begin
81222>>>>>>>                Move (Pos(",", sOutConnStr)) To iStart
81223>>>>>>>                Move (Pos("}", sOutConnStr)) To iEnd
81224>>>>>>>                If ((iStart = 0) Or (iEnd < iStart)) ;                    Move iEnd To iStart
81227>>>>>>>
81227>>>>>>>                If (iStart > 0) ;                    Set Value Of hoStore Item (Item_Count(Current_Object)) To (Left(sOutConnStr, iStart - 1))
81230>>>>>>>
81230>>>>>>>                If (iStart = iEnd) ;                    Move 0 To iStart
81233>>>>>>>            End
81233>>>>>>>>
81233>>>>>>>        Loop
81234>>>>>>>>
81234>>>>>>>
81234>>>>>>>        Function_Return (Item_Count(hoStore))
81235>>>>>>>    End_Procedure // ExtractList
81236>>>>>>>
81236>>>>>>>
81236>>>>>>>
81236>>>>>>>    //***
81236>>>>>>>    //*** Function: BrowseConnect
81236>>>>>>>    //*** Purpose : Call the driver's browse connect function
81236>>>>>>>    //***
81236>>>>>>>
81236>>>>>>>    Function BrowseConnect String sInConnStr Returns String
81238>>>>>>>        Local String  sDriver
81238>>>>>>>        Local String  sOutConnStr
81238>>>>>>>        Local Integer iArg
81238>>>>>>>        Local Integer iRetval
81238>>>>>>>
81238>>>>>>>        Get psDriverID To sDriver
81239>>>>>>>        If (sDriver <> "") Begin
81241>>>>>>>            Move (Repeat(" ", 8192)) To sOutConnStr
81242>>>>>>>            Call_Driver 0 sDRiver Function CLI_BROWSECONNECT Callback 0 Passing sInConnStr sOutConnStr iArg Result iRetval
81247>>>>>>>        End
81247>>>>>>>>
81247>>>>>>>
81247>>>>>>>        Function_Return sOutConnStr
81248>>>>>>>    End_Function// BrowseConnect
81249>>>>>>>
81249>>>>>>>
81249>>>>>>>    Function BrowseConnectLocal String sInConnStr Returns String
81251>>>>>>>        Local String  sDriver
81251>>>>>>>        Local String  sOutConnStr
81251>>>>>>>        Local Integer iArg
81251>>>>>>>        Local Integer iRetval
81251>>>>>>>        
81251>>>>>>>        Move 1 to iArg // Browses only local
81252>>>>>>>
81252>>>>>>>        Get psDriverID to sDriver
81253>>>>>>>        If (sDriver <> "") Begin
81255>>>>>>>            Move (Repeat(" ", 8192)) to sOutConnStr
81256>>>>>>>            Call_Driver 0 sDRiver Function CLI_BROWSECONNECT Callback 0 Passing sInConnStr sOutConnStr iArg Result iRetval
81261>>>>>>>        End
81261>>>>>>>>
81261>>>>>>>
81261>>>>>>>        Function_Return sOutConnStr
81262>>>>>>>    End_Function// BrowseConnect
81263>>>>>>>
81263>>>>>>>
81263>>>>>>>    Function DriverIndex String sDriver Returns Integer
81265>>>>>>>    
81265>>>>>>>        Local String  sCurrentDriver
81265>>>>>>>        Local Integer iNumberOfDrivers iDriver iCount
81265>>>>>>>    
81265>>>>>>>        Move 0 to iDriver
81266>>>>>>>    
81266>>>>>>>        Get_Attribute DF_NUMBER_DRIVERS to iNumberOfDrivers
81269>>>>>>>        For iCount from 1 to iNumberOfDrivers
81275>>>>>>>>
81275>>>>>>>    
81275>>>>>>>            Get_Attribute DF_DRIVER_NAME of iCount to sCurrentDriver
81278>>>>>>>            If ( Uppercase(sCurrentDriver) = Uppercase(sDriver) ) Begin
81280>>>>>>>                Move iCount to iDriver
81281>>>>>>>            End
81281>>>>>>>>
81281>>>>>>>        Loop
81282>>>>>>>>
81282>>>>>>>    
81282>>>>>>>        Function_Return iDriver
81283>>>>>>>    
81283>>>>>>>    End_Function 
81284>>>>>>>
81284>>>>>>>    Function EnumerateServersNetworkOrLocal Integer iNetworkLocal  Returns Integer
81286>>>>>>>        
81286>>>>>>>        Local String  sServerList
81286>>>>>>>        Local Integer iNumServers
81286>>>>>>>        Local Integer iDriver
81286>>>>>>>        Local Integer iClientVersion
81286>>>>>>>        Local String  sDriver
81286>>>>>>>        
81286>>>>>>>        Get DriverIndex MSSQLDRV_ID to iDriver
81287>>>>>>>
81287>>>>>>>        If (iDriver) Begin
81289>>>>>>>                
81289>>>>>>>            Get_Attribute DF_DRIVER_SQLSERVER_CLIENT_VERSION of iDriver to iClientVersion
81292>>>>>>>            
81292>>>>>>>            Case Begin
81292>>>>>>>    
81292>>>>>>>                Case (iClientVersion = SQLSERVER2016CLIENT)
81294>>>>>>>                    Move SQLSERVER2016DRVRSTR to sDriver
81295>>>>>>>                    Case Break
81296>>>>>>>    
81296>>>>>>>                Case (iClientVersion = SQLSERVER2014CLIENT)
81299>>>>>>>                    Move SQLSERVER2014DRVRSTR to sDriver
81300>>>>>>>                    Case Break
81301>>>>>>>            
81301>>>>>>>                Case (iClientVersion = SQLSERVER2012CLIENT)
81304>>>>>>>                    Move SQLSERVER2012DRVRSTR to sDriver
81305>>>>>>>                    Case Break
81306>>>>>>>    
81306>>>>>>>                Case (iClientVersion = SQLSERVER2008CLIENT)
81309>>>>>>>                    Move SQLSERVER2008DRVRSTR to sDriver
81310>>>>>>>                    Case Break
81311>>>>>>>    
81311>>>>>>>                Case (iClientVersion = SQLSERVER2005CLIENT)
81314>>>>>>>                    Move SQLSERVER2005DRVRSTR to sDriver
81315>>>>>>>                    Case Break
81316>>>>>>>            
81316>>>>>>>                Case (iClientVersion = SQLSERVER2000CLIENT)
81319>>>>>>>                    Move SQLSERVER2000DRVRSTR to sDriver
81320>>>>>>>                    Case Break
81321>>>>>>>            
81321>>>>>>>                Case Else
81321>>>>>>>                    Move SQLSERVER2000DRVRSTR to sDriver
81322>>>>>>>            
81322>>>>>>>            Case End
81322>>>>>>>    
81322>>>>>>>            Move ("DRIVER={" + sDriver + "};") to sDriver
81323>>>>>>>            If (iNetworkLocal = 0) Begin
81325>>>>>>>                Get BrowseConnect sDriver to sServerList
81326>>>>>>>            End
81326>>>>>>>>
81326>>>>>>>            Else Begin
81327>>>>>>>                Get BrowseConnectLocal sDriver to sServerList
81328>>>>>>>            End
81328>>>>>>>>
81328>>>>>>>            Get ExtractList sServerList Current_object to iNumServers
81329>>>>>>>        End
81329>>>>>>>>
81329>>>>>>>        
81329>>>>>>>        Function_Return iNumServers
81330>>>>>>>        
81330>>>>>>>    End_Function
81331>>>>>>>
81331>>>>>>>    //***
81331>>>>>>>    //*** Procedure: EnumerateServers
81331>>>>>>>    //*** Purpose  : Enumerate the available SQL Server database servers
81331>>>>>>>    //***            This function will return all SQL Server instances on the network. 
81331>>>>>>>    //***            This may take a long time. 
81331>>>>>>>    //***            To enumerate only local SQL Server instances use EnumerateServersLocal 
81331>>>>>>>    Function EnumerateServers Returns Integer
81333>>>>>>>
81333>>>>>>>        Local Integer iNumServers
81333>>>>>>>        Local Integer iNetworkLocal
81333>>>>>>>        
81333>>>>>>>        Move 0 to iNetworkLocal // 0 = enumerate network servers
81334>>>>>>>        
81334>>>>>>>        Get EnumerateServersNetworkOrLocal iNetworkLocal to iNumServers
81335>>>>>>>        
81335>>>>>>>        Function_Return iNumServers
81336>>>>>>>        
81336>>>>>>>    End_Function
81337>>>>>>>
81337>>>>>>>
81337>>>>>>>    //***
81337>>>>>>>    //*** Procedure: EnumerateServersLocal
81337>>>>>>>    //*** Purpose  : Enumerate the available SQL Server database servers
81337>>>>>>>    //***            This function will return only return SQL Server instance on the local machine
81337>>>>>>>    //***            To enumerate all SQL Server instances in a network use EnumerateServers
81337>>>>>>>    Function EnumerateServersLocal Returns Integer
81339>>>>>>>
81339>>>>>>>        Local Integer iNumServers
81339>>>>>>>        Local Integer iNetworkLocal
81339>>>>>>>        
81339>>>>>>>        Move 1 to iNetworkLocal // 1 = enumerate local servers
81340>>>>>>>        
81340>>>>>>>        Get EnumerateServersNetworkOrLocal iNetworkLocal to iNumServers
81341>>>>>>>        
81341>>>>>>>        Function_Return iNumServers
81342>>>>>>>        
81342>>>>>>>    End_Function
81343>>>>>>>
81343>>>>>>>    
81343>>>>>>>
81343>>>>>>>    //***
81343>>>>>>>    //*** Function: EnumerateDatabases
81343>>>>>>>    //*** Purpose : Enumerate database in a given server.
81343>>>>>>>    //***
81343>>>>>>>
81343>>>>>>>    Function EnumerateDatabases String sServer String sUser String sPassWord Returns Integer
81345>>>>>>>        Local Integer hoSQL
81345>>>>>>>        Local String  sConnect
81345>>>>>>>        Local String  sDatabase
81345>>>>>>>        Local Integer hdbc
81345>>>>>>>        Local Integer hstmt
81345>>>>>>>        Local Integer iFetchResult
81345>>>>>>>
81345>>>>>>>        If (Num_Arguments < 3) ;            Move "" To sPassWord
81348>>>>>>>        If (Num_Arguments < 2) ;            Move "" To sUser
81351>>>>>>>
81351>>>>>>>        If (sUser <> "") ;            Move ("SERVER=" + Trim(sServer) + ";UID=" + Trim(sUser) + ";PWD=" + Trim(sPassword) + ";") To sConnect
81354>>>>>>>        Else ;            Move ("SERVER=" + Trim(sServer) + ";Trusted_Connection=yes") To sConnect
81356>>>>>>>
81356>>>>>>>        Object oEnumDBSQLmanager Is A cSQLHandleManager
81358>>>>>>>            Move Current_Object To hoSQL
81359>>>>>>>        End_Object // oEnumDBSQLManager
81360>>>>>>>
81360>>>>>>>        If (hoSQL <> 0) Begin
81362>>>>>>>            Get SQLConnect Of hoSQL "MSSQLDRV" sConnect To hdbc
81363>>>>>>>            If (hdbc <> 0) Begin
81365>>>>>>>                Get SQLOpen Of hdbc To hstmt
81366>>>>>>>                If (hstmt <> 0) Begin
81368>>>>>>>                    //*** We could do a direct select on the sysdatabases table but we use
81368>>>>>>>                    //*** the stored procedure sp_database instead. SQL Server recommends this
81368>>>>>>>                    //*** approach in case meta data might change, the stored procedure will
81368>>>>>>>                    //*** stay the same.
81368>>>>>>>                    Send SQLSetProcedureName To hstmt "sp_databases"
81369>>>>>>>                    Send SQLCall To hstmt
81370>>>>>>>                    Repeat
81370>>>>>>>>
81370>>>>>>>                        Get SQLFetch Of hstmt To iFetchResult
81371>>>>>>>                        If (iFetchResult <> 0) Begin
81373>>>>>>>                            Get SQLColumnValue Of hstmt 1 To sDatabase
81374>>>>>>>                            Set Value Item (Item_Count(Current_Object)) To sDatabase
81375>>>>>>>                        End
81375>>>>>>>>
81375>>>>>>>                    Until (iFetchResult = 0)
81377>>>>>>>
81377>>>>>>>                    Send SQLClose To hstmt
81378>>>>>>>                End
81378>>>>>>>>
81378>>>>>>>                Send SQLDisconnect To hdbc
81379>>>>>>>            End
81379>>>>>>>>
81379>>>>>>>        End
81379>>>>>>>>
81379>>>>>>>        Send Destroy_Object To hoSQL
81380>>>>>>>
81380>>>>>>>        Function_return (Item_Count(Current_Object))
81381>>>>>>>    End_Function // EnumerateDatabases
81382>>>>>>>
81382>>>>>>>
81382>>>>>>>    Function SqlServerClientVersionName Integer iClientVersion  Returns String
81384>>>>>>>        
81384>>>>>>>        Local String  sSqlServerClientVersionName
81384>>>>>>>        
81384>>>>>>>            
81384>>>>>>>        Case Begin
81384>>>>>>>
81384>>>>>>>            Case (iClientVersion = SQLSERVER2016CLIENT)
81386>>>>>>>                Move SQLSERVER2016CLIENTNAME to sSqlServerClientVersionName
81387>>>>>>>                Case Break
81388>>>>>>>
81388>>>>>>>            Case (iClientVersion = SQLSERVER2014CLIENT)
81391>>>>>>>                Move SQLSERVER2014CLIENTNAME to sSqlServerClientVersionName
81392>>>>>>>                Case Break
81393>>>>>>>        
81393>>>>>>>            Case (iClientVersion = SQLSERVER2012CLIENT)
81396>>>>>>>                Move SQLSERVER2012CLIENTNAME to sSqlServerClientVersionName
81397>>>>>>>                Case Break
81398>>>>>>>
81398>>>>>>>            Case (iClientVersion = SQLSERVER2008CLIENT)
81401>>>>>>>                Move SQLSERVER2008CLIENTNAME to sSqlServerClientVersionName
81402>>>>>>>                Case Break
81403>>>>>>>
81403>>>>>>>            Case (iClientVersion = SQLSERVER2005CLIENT)
81406>>>>>>>                Move SQLSERVER2005CLIENTNAME to sSqlServerClientVersionName
81407>>>>>>>                Case Break
81408>>>>>>>        
81408>>>>>>>            Case (iClientVersion = SQLSERVER2000CLIENT)
81411>>>>>>>                Move SQLSERVER2000CLIENTNAME to sSqlServerClientVersionName
81412>>>>>>>                Case Break
81413>>>>>>>        
81413>>>>>>>            Case Else
81413>>>>>>>                Move SQLSERVERUNKNOWNCLIENTNAME to sSqlServerClientVersionName
81414>>>>>>>        
81414>>>>>>>        Case End
81414>>>>>>>    
81414>>>>>>>        
81414>>>>>>>        Function_Return sSqlServerClientVersionName
81415>>>>>>>        
81415>>>>>>>    End_Function
81416>>>>>>>
81416>>>>>>>
81416>>>>>>>End_Class // cMSSQLHandler
