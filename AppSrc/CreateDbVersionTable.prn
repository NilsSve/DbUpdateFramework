87495>>>                Set_Attribute DF_FIELD_LENGTH of hTable iNew to iLength
87498>>>            End
87498>>>>
87498>>>    
87498>>>            If (iType = DF_BCD) Begin
87500>>>                Set_Attribute DF_FIELD_PRECISION of hTable iNew to iPrecision
87503>>>            End
87503>>>>
87503>>>    
87503>>>            Set_Attribute DF_FIELD_OLD_NUMBER of hTable iNew to iOld
87506>>>        Structure_End hTable
87508>>>        
87508>>>        Function_Return (Err = False)
87509>>>    End_Function
