81199>>>>>// SQL Back-ends (iSQLDbType in the tSQLKeywords struct).
81199>>>>>// They can have slightly different SQL keywords. 
81199>>>>>// Note: If a new type is added to the list,
81199>>>>>//       the struct array xxx must be adjusted
81199>>>>>//       so that it is filled with all SQL
81199>>>>>//       keywords for that new type.
81199>>>>>Enum_List
81199>>>>>    Define EN_DbTypeMSSQL
81199>>>>>    Define EN_DbTypeMySQL
81199>>>>>    Define EN_DbTypeOracle
81199>>>>>    Define EN_DbTypeDB2 
81199>>>>>    Define EN_DbTypePostgre 
81199>>>>>    Define EN_DbTypeDataFlex // Embedded database.
81199>>>>>End_Enum_List 
81199>>>>>
81199>>>>>// We need to have our "own" constants for the standard DataFlex data types.
81199>>>>>// These can be used with SQL functions such as e.g. SQLColumnAdd, instead
81199>>>>>// of using one of the driver specific integer constants such as e.g. "SQL_VARCHAR".
81199>>>>>// We need to re-define the standard constants because several driver constants
81199>>>>>// have the same value and we need to be able to distinguish which data type to use when
81199>>>>>// e.g. creating a column with embedded SQL (ESQL).
81199>>>>>Enum_List 
81199>>>>>    Define DF_ASCII_DUF     for 1500
81199>>>>>    Define DF_BCD_DUF       for 1499
81199>>>>>    Define DF_BINARY_DUF    for 1494
81199>>>>>    Define DF_DATE_DUF      for 1498
81199>>>>>    Define DF_DATETIME_DUF  for 1493
81199>>>>>    Define DF_TEXT_DUF      for 1495
81199>>>>>End_Enum_List
81199>>>>>
81199>>>>>Define CS_DbTypeMSSQL       for "Microsoft SQL Server"
81199>>>>>Define CS_DbTypeMySQL       for "MySQL"
81199>>>>>Define CS_DbTypeOracle      for "Oracle"
81199>>>>>Define CS_DbTypeDB2         for "IBM DB2"
81199>>>>>Define CS_DbTypePostgre     for "PostgreSQL"
81199>>>>>Define CS_DbTypeDataFlex    for "DataFlex Embedded"
81199>>>>>
81199>>>>>    Define SQL_TEXT for (DF_TEXT + 1024)
81199>>>>>
81199>>>>>Define SQL_CHARBIT          for (DF_BINARY + 1024)
81199>>>>>Define SQL_LONGVARCHARBIT   for (DF_BINARY + 1025)
81199>>>>>Define SQL_VARCHARBIT       for (DF_BINARY + 1026)
81199>>>>>
