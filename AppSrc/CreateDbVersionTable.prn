85980>>>    Function SqlEnumerateEsqlMertech String sStmt Returns String[]
85982>>>        String[] sReturnArray
85983>>>        String sValue sUserID sPassword 
85983>>>        Handle hoSQLHandler hoSQLConnect hStmt
85983>>>        Integer iFetchResult iRows
85983>>>        tSQLConnection SQLConnection
85983>>>        tSQLConnection SQLConnection
85983>>>        
85983>>>        Get _MertechSQLManagerHandle to hoSQLHandler
85984>>>
85984>>>        If (hoSQLHandler <> 0) Begin 
85986>>>            Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
85987>>>            Get SQLConnect of hoSQLHandler SQLConnection.sDriverID SQLConnection.sServer SQLConnection.sUserID SQLConnection.sPassword to hoSQLConnect
85988>>>            
85988>>>            If (hoSQLConnect <> 0) Begin   
85990>>>                Get SQLOpen of hoSQLConnect to hStmt
85991>>>                If (hStmt <> 0) Begin                                   
85993>>>                    Send SqlExecDirect of hStmt sStmt                                             
85994>>>                    Get SqlStmtAttribute of hStmt SqlSTMTATTRIB_ROWCOUNT to iRows
85995>>>                    Repeat
85995>>>>
85995>>>                        Get SQLFetch of hStmt to iFetchResult
85996>>>                        If (iFetchResult <> 0) Begin
85998>>>                            Get SQLColumnValue of hStmt 1 to sValue
85999>>>                            Move (Trim(sValue)) to sReturnArray[SizeOfArray(sReturnArray)
86000>>>                        End
86000>>>>
86000>>>                    Until (iFetchResult = 0)
86002>>>                    Send SQLClose of hStmt
86003>>>                End
86003>>>>
86003>>>                Send SQLDisconnect of hoSQLConnect    
86004>>>            End
86004>>>>
86004>>>        End
86004>>>>
86004>>>    
86004>>>        Function_Return sReturnArray
86005>>>    End_Function 
86006>>>    
86006>>>    // Backs up an SQL database to a folder of choice. If no path is passed the SQL default backup folder
86006>>>    // will be used.
86006>>>    Function SqlUtilBackupDatabaseToDisk String sDatabase String sBackupName String sPath Boolean bShowProg Returns Boolean
86008>>>        Boolean bOK bExists bShowProgress      
86008>>>        String sStatement sDriverID 
86008>>>        tSQLScriptArray SQLScriptArray SQLScriptArrayPercentReady
86008>>>        tSQLScriptArray SQLScriptArray SQLScriptArrayPercentReady
86008>>>        Integer iDbType
86008>>>        
86008>>>        If (sDatabase = "") Begin
86010>>>            Error DFERR_PROGRAM "The database name was not passed as a parameter to the 'SqlUtilBackupDatabaseToDisk' function"
86011>>>>
86011>>>            Function_Return False
86012>>>        End
86012>>>>
86012>>>        If (sBackupName = "") Begin
86014>>>            Error DFERR_PROGRAM "The database backup name was not passed as a parameter to the 'SqlUtilBackupDatabaseToDisk' function"
86015>>>>
86015>>>            Function_Return False
86016>>>        End
86016>>>>
86016>>>            
86016>>>        // Create backup-folder if it doesn't exist
86016>>>        Get vFolderExists sPath to bExists
86017>>>        If (bExists = False) Begin
86019>>>            Get vCreateDirectory sPath to bOK
86020>>>            If (bOK = False) Begin
86022>>>                Error DFERR_PROGRAM ("Could not create database backup folder:" * sPath)
86023>>>>
86023>>>                Function_Return False
86024>>>            End
86024>>>>
86024>>>        End                     
86024>>>>
86024>>>        // Make sure the path ends with a back-slash
86024>>>        If (sPath <> "") Begin
86026>>>            Get vFolderFormat sPath to sPath
86027>>>        End
86027>>>>
86027>>>        
86027>>>        Get psDriverID to sDriverID  
86028>>>        Get piDbType   to iDbType        
86029>>>        If (num_arguments > 3) Begin
86031>>>            Move bShowProg to bShowProgress
86032>>>        End
86032>>>>
86032>>>        
86032>>>        Case Begin
86032>>>            Case (iDbType = EN_DbTypeMSSQL)
86034>>>                SQLIncludeScriptFile ..\Scripts\BackupMSSQLDatabase.sql as BackupMSSQLDatabase.sql
86034>>>                SQLIncludeScriptFile ..\Scripts\GetPercentageBackupCompletionMSSQL.sql as GetPercentageBackupCompletionMSSQL.sql
86034>>>                Get SqlUtilReadResource of ghoDbUpdateFunctionLibrary "BackupMSSQLDatabase.sql" sDriverID False to SQLScriptArray
86035>>>                Get SqlUtilReadResource of ghoDbUpdateFunctionLibrary "GetPercentageBackupCompletionMSSQL.sql" sDriverID False to SQLScriptArrayPercentReady
86036>>>                
86036>>>                Move SQLScriptArray.sSQLScriptArray[0] to sStatement
86037>>>                Move (Replaces("DATABASE_NAME_XXX", sStatement, sDatabase))   to sStatement
86038>>>                Move (Replaces("BACKUP_PATH_XXX",   sStatement, sPath))       to sStatement
86039>>>                Move (Replaces("BACKUP_NAME_XXX",   sStatement, sBackupName)) to sStatement
86040>>>                Move sStatement to SQLScriptArray.sSQLScriptArray[0]    
86041>>>                Get SqlUtilExecuteEmbeddedScript of ghoDbUpdateFunctionLibrary SQLScriptArray sDriverID False "" bShowProgress to bOK
86042>>>                Case Break
86043>>>            Case Else
86043>>>                Send Info_Box ("The SqlUtilBackupDatabaseToDisk function is currently not implemented for the driver:" * sDriverID + ". It would be great if you could spend a couple of minutes and add a little ESQL code snippet to make it work for that driver! Thanks for helping out.")
86044>>>        Case End
86044>>>        
86044>>>        Function_Return bOK    
86045>>>    End_Function
86046>>>
86046>>>    // Reads a resource that has been embedded by the compiler and writes it to disk.
86046>>>    // Pass the memory resource file reference and the filename to be created,
86046>>>    // including full path.
86046>>>    Procedure SqlUtilCreateFileFromMemory String sMemFileName String sFileName
86048>>>        String sText
86048>>>        Integer iCh iSize iArgSize  
86048>>>        
86048>>>        Move ("Resource:" + sMemFileName) to sMemFileName
86049>>>        Get Seq_Open_Input_Channel sMemFileName to iCh
86050>>>            Get_Channel_Size iCh to iSize
86051>>>            Get_Argument_Size to iArgSize
86052>>>            If (iSize > iArgSize) Begin
86054>>>                Set_Argument_Size iSize
86055>>>>
86055>>>            End
86055>>>>
86055>>>            Read_Block channel iCh sText iSize
86057>>>        Send Seq_Close_Channel iCh
86058>>>    
86058>>>        Get Seq_Open_Output_Channel sFileName to iCh
86059>>>            Write channel iCh sText
86061>>>        Send Seq_Close_Channel iCh
86062>>>    
86062>>>        If (iSize <> iArgSize) Begin
86064>>>            Set_Argument_Size iArgSize
86065>>>>
86065>>>        End
86065>>>>
86065>>>    
86065>>>        // Wait for file to be written to disk.
86065>>>        Sleep 2
86066>>>    End_Procedure 
86067>>>    
86067>>>    // L„s f”rst .int fil och spara alla FIELD_INDEX + FIELD_NUMBER + FIELD_RELATED_FILE + FIELD_RELATED_FIELD i en struct array,
86067>>>    // INDEX_NUMBER + INDEX_NAME (string)
86067>>>    // samt spara undan .int "header rader" s† de kan skrivas ut senare.
86067>>>    // Check if index exists:    
86067>>>    //IF EXISTS (
86067>>>    //   SELECT 'X'
86067>>>    //   from sysindexes
86067>>>    //   WHERE id = (SELECT OBJECT_ID('accounts'))
86067>>>    //     and name = 'idx_acct_no'
86067>>>    //)          
86067>>>    //
86067>>>    // Helper function to create a SQL statement like;
86067>>>    // "SELECT * FROM SYS.INDEXES WHERE NAME = MyIndexName AND OBJECT_ID = OBJECT_ID([MySchmaName].[MyTableName])"
86067>>>    // Used for checking if an index exists.
86067>>>    Function _SqlQueryIfIndexExists String sSchemaName String sTableName String sIndexName Returns String
86069>>>        String sRetval sSelect sFrom sSysIndexes sWhere sObjectID sAnd sName
86069>>>        
86069>>>        Get _SqlFindKeyWord CI_SQLSelect to sSelect
86070>>>        Get _SqlFindKeyWord CI_SQLFrom to sFrom
86071>>>        Get _SqlFindKeyWord CI_SQLSysIndexes to sSysIndexes
86072>>>        Get _SqlFindKeyWord CI_SQLWhere to sWhere
86073>>>        Get _SqlFindKeyWord CI_SQLObjectID to sObjectID
86074>>>        Get _SqlFindKeyWord CI_SQLAND to sAnd
86075>>>        Get _SqlFindKeyWord CI_SQLName to sName
86076>>>        
86076>>>        Move (sSelect * String("*") * sFrom * sSysIndexes * sWhere * sName * "=" * sIndexName * sAnd * sObjectID * "=([" + sSchemaName + "].[" + sTableName + "])") to sRetval
86077>>>        
86077>>>        Function_Return sRetval
86078>>>    End_Function  
86079>>>    
86079>>>    // Formats a columns iLenght & iDecimal parameters as SQL expects them in a string. 
86079>>>    // E.g. (4,2), where 4 is the iLength and 2 the iDecimals param.
86079>>>    Function _SqlFormatLengthAndDecimalAsString Integer iLength Integer iDecimals Returns String
86081>>>        String sRetval
86081>>>        If (iLength <> 0) Begin
86083>>>            Move ("(" + String(iLength)) to sRetval
86084>>>            If (iDecimals <> 0) Begin
86086>>>                Move (sRetval + "," + String(iDecimals)) to sRetval
86087>>>            End
86087>>>>
86087>>>            Move (sRetval + ")") to sRetval
86088>>>        End
86088>>>>
86088>>>        Function_Return sRetval
86089>>>    End_Function
86090>>>    
86090>>>    Procedure _SqlColumnInfo Handle hoStmt
86092>>>        Integer i iCols iItem
86092>>>        tSqlColumnNew[] aQueryColumns
86092>>>        tSqlColumnNew[] aQueryColumns
86093>>>
86093>>>        Get SqlStmtAttribute of hoStmt SqlSTMTATTRIB_COLUMNCOUNT to iCols
86094>>>        For i from 1 to iCols
86100>>>>
86100>>>            Move (SizeOfArray(aQueryColumns)) to iItem
86101>>>            Get SqlColAttribute of hoStmt i SqlCOLATTRIB_BASECOLUMNNAME to aQueryColumns[iItem].sBaseColumnName
86102>>>            Get SqlColAttribute of hoStmt i SqlCOLATTRIB_BASETABLENAME  to aQueryColumns[iItem].sBaseTableName
86103>>>            Get SqlColAttribute of hoStmt i SqlCOLATTRIB_LABEL          to aQueryColumns[iItem].sLabel
86104>>>            Get SqlColAttribute of hoStmt i SqlCOLATTRIB_SQLTYPE        to aQueryColumns[iItem].iSqlType
86105>>>            Get SqlColAttribute of hoStmt i SqlCOLATTRIB_DFTYPE         to aQueryColumns[iItem].iDFType
86106>>>            Get SqlColAttribute of hoStmt i SqlCOLATTRIB_SIZE           to aQueryColumns[iItem].iSize
86107>>>            Get SqlColAttribute of hoStmt i SqlCOLATTRIB_PRECISION      to aQueryColumns[iItem].iPrecision
86108>>>        Loop
86109>>>>
86109>>>        Set piColumns to iCols
86110>>>        Set paQueryColumns to aQueryColumns
86111>>>    End_Procedure
86112>>>    
86112>>>    // Checks that the passed sDriverID is defined.
86112>>>    // Also checks if the driver has been loaded; else it gets loaded.
86112>>>    Function _SqlCheckCurrentDriver String sDriverID Returns Boolean
86114>>>        Boolean bOK                         
86114>>>        Integer iDriver
86114>>>        
86114>>>        If (sDriverID = DATAFLEX_ID) Begin
86116>>>            Function_Return False
86117>>>        End                      
86117>>>>
86117>>>
86117>>>        Get IsDAWSQLDriver sDriverID to bOK
86118>>>
86118>>>        If (bOK = False) Begin
86120>>>            Get IsMertechDriver sDriverID to bOK
86121>>>        End   
86121>>>>
86121>>>        
86121>>>        If (bOK = False) Begin        
86123>>>            Error DFERR_PROGRAM "Driver needs to be one of MSSQLDRV, DB2_DRV, ODBC_DRV, SQLFLEX, ORAFLEX, MDSPgSQL or MDSMySQL"
86124>>>>
86124>>>            Function_Return False
86125>>>        End 
86125>>>>
86125>>>        
86125>>>        Get DriverIndex sDriverID to iDriver
86126>>>        If (iDriver = 0) Begin
86128>>>            Load_Driver sDriverID
86129>>>        End
86129>>>>
86129>>>        
86129>>>        Function_Return True
86130>>>    End_Function
86131>>>    
86131>>>    // Checks that the length parameter has been passed correctly.
86131>>>    // This is only of concern for certain SQL data types.
86131>>>    Function _SqlCheckLengthParamForDataType Integer iDataType Integer iLen Returns Boolean
86133>>>        Integer iLength 
86133>>>        Boolean bOK bCheckTypeLength 
86133>>>        
86133>>>        If (num_arguments > 1) Begin
86135>>>            Move iLen to iLength
86136>>>        End
86136>>>>
86136>>>        Move (iDataType = SQL_DECIMAL   or iDataType = SQL_NUMERIC or iDataType = SQL_FLOAT   or iDataType = SQL_INTEGER or;              iDataType = SQL_VARBINARY or iDataType = SQL_BINARY  or iDataType = SQL_VARCHAR or iDataType = SQL_CHAR or;              iDataType = SQL_BIGINT    or iDataType = SQL_REAL) to bCheckTypeLength
86137>>>        
86137>>>        If (bCheckTypeLength = True) Begin
86139>>>            Move (iLength > 0) to bOK
86140>>>        End
86140>>>>
86140>>>
86140>>>        Function_Return (bOK = True)
86141>>>    End_Function
