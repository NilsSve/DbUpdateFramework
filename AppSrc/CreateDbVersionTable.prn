86222>>>    Function _SqlTableArrayDAW Returns String[]
86224>>>        String[] sReturnArray   
86225>>>        String sTable sTableType sSchema sDefSchema sComment sTableKeyWord sSysKeyWord
86225>>>        Handle hoSQLHandler
86225>>>        Integer iCount iSize iItem
86225>>>        Boolean bOK   
86225>>>        tSQLConnection SQLConnection
86225>>>        tSQLConnection SQLConnection
86225>>>        
86225>>>        Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
86226>>>        If (SQLConnection.sConnectionString = "") Begin
86228>>>            Function_Return sReturnArray
86229>>>        End 
86229>>>>
86229>>>        
86229>>>        Move SQLConnection.sSchema      to sDefSchema
86230>>>        Move (Uppercase(sDefSchema))    to sDefSchema
86231>>>        Get _SqlFindKeyWord CI_SQLTable to sTableKeyWord
86232>>>        Get _SqlFindKeyWord CI_SQLSys   to sSysKeyWord
86233>>>
86233>>>        Get phoCLIHandler to hoSQLHandler             
86234>>>        Set psDriverID    of hoSQLHandler to SQLConnection.sDriverID
86235>>>        Send Delete_Data  of hoSQLHandler
86236>>>
86236>>>        Send Ignore_Error of Error_Object_Id CLIERR_LOGIN_UNSUCCESSFUL
86237>>>        Get EnumerateTables of hoSQLHandler SQLConnection.sConnectionString to iSize 
86238>>>        Move False to Err
86239>>>        Decrement iSize
86240>>>
86240>>>        For iCount from 0 to iSize
86246>>>>
86246>>>            Get TableName    of hoSQLHandler iCount to sTable
86247>>>            Get TableType    of hoSQLHandler iCount to sTableType 
86248>>>            Get SchemaName   of hoSQLHandler iCount to sSchema
86249>>>            Get TableComment of hoSQLHandler iCount to sComment
86250>>>            Move (Trim(sTable)) to sTable
86251>>>            If (SQLConnection.sDriverID = DB2_DRV_ID) Begin
86253>>>                Move (sTable <> "" and Uppercase(sTableType) = sTableKeyWord and Uppercase(sSchema) = sDefSchema) to bOK
86254>>>            End
86254>>>>
86254>>>            Else Begin
86255>>>                Move (sTable <> "" and Uppercase(sTableType) = sTableKeyWord and Uppercase(sSchema) <> sSysKeyWord and Uppercase(sSchema) <> "SYSTOOLS") to bOK
86256>>>            End
86256>>>>
86256>>>            If (bOK = True) Begin
86258>>>                Move sTable to sReturnArray[iItem]
86259>>>                Increment iItem
86260>>>            End
86260>>>>
86260>>>        Loop
86261>>>>
86261>>>
86261>>>        Send Trap_Error of Error_Object_Id CLIERR_LOGIN_UNSUCCESSFUL
86262>>>
86262>>>        Function_Return sReturnArray
86263>>>    End_Function
86264>>>
86264>>>    Function _SqlProcedureArrayDAW String sStmt String sArgument Returns String[]
86266>>>        String[] sReturnArray  
86267>>>        String sValue                         
86267>>>        Handle hoSQLHandler hoSQLConnect hStmt    
86267>>>        Integer iRetval iCols iFetchResult
86267>>>        tSQLConnection SQLConnection
86267>>>        tSQLConnection SQLConnection
86267>>>        
86267>>>        Get phoSQLManager to hoSQLHandler
86268>>>        Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
86269>>>        Get SqlConnect of hoSQLHandler SQLConnection.sDriverID SQLConnection.sConnectionString to hoSQLConnect
86270>>>
86270>>>        If (hoSQLConnect <> 0) Begin
86272>>>            Get SqlOpen of hoSQLConnect to hStmt
86273>>>            If (hStmt <> 0) Begin
86275>>>                Send SqlSetProcedurename of hStmt sStmt 
86276>>>                If (sArgument <> "") Begin
86278>>>                    Send SqlSetArgument  of hStmt 1 sArgument
86279>>>                End
86279>>>>
86279>>>                            
86279>>>                Send SqlCall             of hStmt      
86280>>>                Get SqlReturnValue       of hStmt to iRetval
86281>>>                If (iRetval = 0) Begin
86283>>>                    Repeat    
86283>>>>
86283>>>                        Get SqlStmtAttribute of hStmt SqlSTMTATTRIB_COLUMNCOUNT to iCols
86284>>>                        If (iCols > 0) Begin 
86286>>>                            Repeat
86286>>>>
86286>>>                                Get SqlFetch of hStmt to iFetchResult
86287>>>                                If (iFetchResult <> 0) Begin
86289>>>                                    Get SqlColumnValue of hStmt 1 to sValue    
86290>>>                                    Move (Trim(sValue)) to sReturnArray[SizeOfArray(sReturnArray)]
86291>>>                                End
86291>>>>
86291>>>                            Until (iFetchResult = 0)
86293>>>                        End
86293>>>>
86293>>>                        Get SqlNextResultSet of hStmt to iRetval
86294>>>                    Until (iRetval = 0) 
86296>>>                    Send SqlClose of hStmt
86297>>>                End
86297>>>>
86297>>>            End                       
86297>>>>
86297>>>            Send SqlDisconnect of hoSQLConnect
86298>>>        End                                                                         
86298>>>>
86298>>>        Function_Return sReturnArray
86299>>>    End_Function
