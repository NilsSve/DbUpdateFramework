90947>        Procedure Combo_Fill_List                                  
90950>            tColumnType[] ColumnTypeArray      
90950>            tColumnType[] ColumnTypeArray      
90951>            Integer iSize iCount iStart
90951>            
90951>            Send Delete_Data
90952>            Get UtilEnumerateColumnTypes of ghoDbUpdateFunctionLibrary DATAFLEX_ID EN_DbTypeDataFlex to ColumnTypeArray
90953>            Move (SizeOfArray(ColumnTypeArray)) to iSize                        
90954>            Decrement iSize
90955>            For iCount from 0 to iSize
90961>                Send Combo_Add_Item ColumnTypeArray[iCount].sType
90962>            Loop  
90963>            Set Value to "NUMERIC"
90964>            Set Enabled_State of oLength_sf to False
90965>            Set Enabled_State of oDecimals_sf to False
90966>            Set Value of oLength_sf   to 4
