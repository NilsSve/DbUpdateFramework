87364>>>    // *** Field/Column Level Functions: ***
87364>>>    //
87364>>>    // Adds a column name to the passed table number.
87364>>>    // Note: Types must be the standard DF_ASCII, DF_DATE etcetera and _cannot_ be any of the SQL_xxx types.
87364>>>    Function ApiColumnAdd Handle hTable String sFieldName Integer iType Integer iLength Integer iPrecision Returns Boolean
87366>>>        Integer iColumn iCount iFile
87366>>>        Boolean bExists bOK  
87366>>>        String sDdSrcPath sTableName
87366>>>    
87366>>>        Get UtilColumnExists hTable sFieldName to bExists
87367>>>        If (bExists = True) Begin
87369>>>            Function_Return False
87370>>>        End  
87370>>>>
87370>>>        If (iPrecision > 0) Begin
87372>>>            Move (iLength + iPrecision) to iLength
87373>>>        End
87373>>>>
87373>>>        
87373>>>        Get AutoConnectionIDLogin to bOK
87374>>>        Move False to Err   
87375>>>        // Structure_start will change the value of hTable...
87375>>>        Move hTable to iFile
87376>>>        Open iFile Mode DF_EXCLUSIVE
87378>>>        
87378>>>        Structure_Start iFile
87379>>>            Move 0 to iColumn
87380>>>            Create_Field hTable At iColumn
87381>>>            Set_Attribute DF_FIELD_NAME      of iFile iColumn to sFieldName
87384>>>            Set_Attribute DF_FIELD_TYPE      of iFile iColumn to iType
87387>>>            Set_Attribute DF_FIELD_LENGTH    of iFile iColumn to iLength
87390>>>            Set_Attribute DF_FIELD_PRECISION of iFile iColumn to iPrecision
87393>>>        Structure_End iFile
87395>>>        
87395>>>        // If in development environment; create .fd file:
87395>>>        Open hTable
87397>>>        Get psDdSrcPath of (phoWorkspace(ghoApplication)) to sDDSrcPath
87398>>>        Get CountOfPaths of (phoWorkspace(ghoApplication)) sDDSrcPath to iCount
87399>>>        If (iCount > 1) Begin
87401>>>            Get PathAtIndex of (phoWorkspace(ghoApplication)) sDDSrcPath 1 to sDDSrcPath    
87402>>>        End 
87402>>>>
87402>>>        Get vFolderExists sDDSrcPath to bExists
87403>>>        If (bExists = True) Begin                                   
87405>>>            Get vFolderFormat sDDSrcPath to sDDSrcPath 
87406>>>            Get_Attribute DF_FILE_ROOT_NAME of hTable to sTableName
87409>>>            Get _TableNameOnly sTableName to sTableName 
87410>>>            Output_Aux_File DF_AUX_FILE_FD for hTable to (sDDSrcPath + sTableName + ".fd")
87412>>>        End
87412>>>>
87412>>>        Close hTable
87413>>>
87413>>>        Function_Return (Err = False)
87414>>>    End_Function  
