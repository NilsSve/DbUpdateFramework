82841>>>>>        Forward Send Construct_Object
82843>>>>>        Move Self to ghoSQLConnectionHandler
82844>>>>>        
82844>>>>>        Property Handle phoSQLConnectionIniFile (Create(Self,RefClass(cSQLConnectionIniFile))) 
82845>>>>>        
82845>>>>>        // These properties are used by the cDbUpdateVersion and cDbUpdateFunctionLibrary classes,
82845>>>>>        // but put here so they can be set/get in both class objects. Those classes has "relay"
82845>>>>>        // methods to this class.
82845>>>>>        Property Boolean pbUseConnectionID True
82846>>>>>        Property Boolean pbToANSI          True
82847>>>>>        Property Boolean pbRecnum          True
82848>>>>>        Property Boolean pbCopyData        True
82849>>>>>
82849>>>>>        // Driver default value settings:
82849>>>>>        // Note: When the object is created the corresponding values
82849>>>>>        // from the driver .int files are read.
82849>>>>>        // Sample: Get_Attribute DF_DRIVER_DEFAULT_DEFAULT_NUMERIC of {driverNumber} to {StringVariable}
82849>>>>>        Property String psDriverDefaultValueASCII    ""
82850>>>>>        Property String psDriverDefaultValueBinary   ""
82851>>>>>        Property String psDriverDefaultValueDate     ""
82852>>>>>        Property String psDriverDefaultValueDateTime ""
82853>>>>>        Property String psDriverDefaultValueNumeric  ""
82854>>>>>        Property String psDriverDefaultValueText     ""
82855>>>>>        
82855>>>>>        // Driver "nullability" settings:
82855>>>>>        // Note: When the object is created the corresponding values
82855>>>>>        // from the driver .int files are read.
82855>>>>>        // Get_Attribute DF_DRIVER_DEFAULT_NULLABLE_ASCII of {driverNumber} to {BooleanVariable}
82855>>>>>        Property Boolean pbDriverDefaultNullableASCII    False
82856>>>>>        Property Boolean pbDriverDefaultNullableBinary   False
82857>>>>>        Property Boolean pbDriverDefaultNullableDate     False
82858>>>>>        Property Boolean pbDriverDefaultNullableDateTime False
82859>>>>>        Property Boolean pbDriverDefaultNullableNumeric  False
82860>>>>>        Property Boolean pbDriverDefaultNullableText     False
82861>>>>>
82861>>>>>        // *** This is the central point of connection data for the Database Update Framework ***
82861>>>>>        //     It is private because the get/set version also updates the DAW/Mertech
82861>>>>>        //     driver interfaces.
82861>>>>>        //     There are also procedure/function pairs to set/get individual data members
82861>>>>>        //     of the struct they are all routed throu this struct property.
82861>>>>>        Property tSQLConnection Private.pSQLConnection
82862>>>>>
82862>>>>>    End_Procedure
82863>>>>>    
