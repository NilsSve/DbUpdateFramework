88028>>>    // The default value used for a datatype as specified in the driver int file.
88028>>>    Function UtilDataTypeDefaultValue String sDriverID Integer iDbType Integer iDataType Returns String
88030>>>        String sRetval sServer
88030>>>        tColumnType RetvalType 
88030>>>        tColumnType RetvalType 
88030>>>        Integer iDriver iDataFlexType
88030>>>        Handle hDatabase
88030>>>        
88030>>>        Get _UtilColumnType sDriverID iDbType iDataType "" True to RetvalType 
88031>>>        Move RetvalType.iDataFlexType to iDataFlexType
88032>>>        Get DriverIndex sDriverID to iDriver
88033>>>        Get psServer to sServer
88034>>>        Get SqlUtilDatabaseHandle sDriverID sServer to hDatabase 
88035>>>        If (hDatabase = 0) Begin
88037>>>            Function_Return ""
88038>>>        End                   
88038>>>>
88038>>>        
88038>>>        Case Begin
88038>>>            Case (iDataFlexType = DF_ASCII)
88040>>>                Get_Attribute DF_DATABASE_DEFAULT_DEFAULT_ASCII     of iDriver hDatabase to sRetval
88043>>>                Case Break
88044>>>            Case (iDataFlexType = DF_BCD)
88047>>>                Get_Attribute DF_DATABASE_DEFAULT_DEFAULT_NUMERIC   of iDriver hDatabase to sRetval
88050>>>                Case Break
88051>>>            Case (iDataFlexType = DF_BINARY)
88054>>>                Get_Attribute DF_DATABASE_DEFAULT_DEFAULT_BINARY    of iDriver hDatabase to sRetval
88057>>>                Case Break
88058>>>            Case (iDataFlexType = DF_DATE)
88061>>>                Get_Attribute DF_DATABASE_DEFAULT_DEFAULT_DATE      of iDriver hDatabase to sRetval
88064>>>                Case Break
88065>>>            Case (iDataFlexType = DF_DATETIME)
88068>>>                Get_Attribute DF_DATABASE_DEFAULT_DEFAULT_DATETIME  of iDriver hDatabase to sRetval
88071>>>                Case Break
88072>>>            Case (iDataFlexType = DF_TEXT)
88075>>>                Get_Attribute DF_DATABASE_DEFAULT_DEFAULT_TEXT      of iDriver hDatabase to sRetval
88078>>>                Case Break
88079>>>            Case Else
88079>>>                Move "" to sRetval            
88080>>>        Case End
88080>>>        
88080>>>        Function_Return sRetval
88081>>>    End_Function  
88082>>>    
88082>>>    Function SQLUtilDefaultNullValue String sDriverID Integer iDbType Integer iDataType Returns String
88084>>>        String sNotNull sRetval sDefaultValue
88084>>>        Boolean bOK
88084>>>        
88084>>>        Get IsSQLDriver sDriverID to bOK
88085>>>        If (bOK = False) Begin
88087>>>            Function_Return ""
88088>>>        End                   
88088>>>>
88088>>>        
88088>>>        Get UtilDataTypeDefaultValue sDriverID iDbType iDataType to sDefaultValue
88089>>>        Get _SqlFindKeyWord CI_SQLNotNull to sNotNull
88090>>>        
88090>>>        Case Begin
88090>>>            Case (iDbType = EN_dbTypeMSSQL)
88092>>>                Move ("DEFAULT" * String(sDefaultValue) * String(sNotNull)) to sRetval
88093>>>                Case Break
88094>>>            Case (iDbType = EN_dbTypeMySQL)
88097>>>                Move (String(sNotNull) * "DEFAULT" * String(sDefaultValue)) to sRetval
88098>>>                Case Break
88099>>>            Case (iDbType = EN_dbTypePostgre)
88102>>>                Move (String(sNotNull) * "DEFAULT" * String(sDefaultValue)) to sRetval
88103>>>                Case Break
88104>>>            Case (iDbType = EN_dbTypeDB2)
88107>>>                Move (String(sNotNull))                                     to sRetval
88108>>>                Case Break
88109>>>            
88109>>>            // Seems like Oracle can't handle setting a new column to 'NOT NULL' if the table exists with data(!)
88109>>>            // ToDo: We need to look deeper into how Oracle handles NULL
88109>>>            Case (iDbType = EN_dbTypeOracle)
88112>>>                Move  ""                                                    to sRetval
88113>>>                Case Break                                              
88114>>>
88114>>>            Case Else
88114>>>                Move  ""                                                    to sRetval
88115>>>        Case End        
88115>>>        
88115>>>        Function_Return sRetval
88116>>>    End_Function
