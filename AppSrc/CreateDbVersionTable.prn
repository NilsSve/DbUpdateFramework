88294>>>        Get IsDAWSQLDriver sDriverID to bDawDriver
88295>>>        If (bDawDriver = False) Begin
88297>>>            Error DFERR_PROGRAM "The UtilCreateConnectionID function is only available for DAW drivers. (Not Mertech)."
88298>>>>
88298>>>            Function_Return False
88299>>>        End
88299>>>>
88299>>>        
88299>>>        Get psConnectionString to sConnectionString
88300>>>        Get pbSilentLogin      to bSilent
88301>>>        
88301>>>        Get phoCLIHandler to hoCLI 
88302>>>        If (hoCLI <> 0) Begin
88304>>>            Set psDriverID of hoCLI to sDriverID
88305>>>            Get CreateConnectionID of hoCLI sConnectionID sConnectionString bSilent to bOK
88306>>>        End
88306>>>>
