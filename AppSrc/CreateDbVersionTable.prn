88308>>>    // This message creates an error log in the "Home" folder named "SQLErrorLog.txt",
88308>>>    // and opens it in "notepad.exe".
88308>>>    // Note: This is _not_ used by the cDbUpdateHandler & cDbUpdateVersion classes!
88308>>>    //       Instead the cDbUpdateLogFile's WriteErrorLog & ShowErrorLog are then used.
88308>>>    Procedure UtilShowErrorList
88310>>>        tSqlErrorArray aSqlErrorArray 
88310>>>        tSqlErrorArray aSqlErrorArray 
88310>>>        Integer iRows iCount iCh iErrorNum
88310>>>        String sPath sFileName sErrorTxt sStatement
88310>>>        
88310>>>        Get psHome of (phoWorkspace(ghoApplication)) to sPath
88311>>>        Get vFolderFormat sPath to sPath
88312>>>        Move "SQLErrorLog.txt"  to sFileName
88313>>>        Get Seq_Open_Output_Channel (sPath + sFileName) to iCh
88314>>>            Get paSqlErrorArray to aSqlErrorArray
88315>>>            Move (SizeOfArray(aSqlErrorArray.sSqlErrorArray)) to iRows
88316>>>            If (iRows > 0) Begin
88318>>>                Decrement iRows
88319>>>                for iCount from 0 to iRows
88325>>>>
88325>>>                    Move aSqlErrorArray.sSqlErrorArray[iCount]      to sErrorTxt
88326>>>                    Move aSqlErrorArray.sSqlStatementArray[iCount]  to sStatement
88327>>>                    Move aSqlErrorArray.iSqlErrorArray[iCount]      to iErrorNum
88328>>>                    Writeln channel iCh "Error No: " iErrorNum " Error Text: " sErrorTxt
88334>>>                    Writeln channel iCh "SQL Statement: " sStatement
88338>>>                Loop
88339>>>>
88339>>>            End
88339>>>>
88339>>>        Send Seq_Close_Channel iCh
88340>>>        
88340>>>        If (iRows > 0) Begin
88342>>>            Runprogram Background "Notepad.exe" (sPath + sFileName)
88343>>>        End
88343>>>>
88343>>>    End_Procedure
