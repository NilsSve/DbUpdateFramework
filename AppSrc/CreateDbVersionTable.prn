82168>>>>>>>>>    Function DbLogin String sConnectionString String sServer String sDatabase Boolean bTrusted String sUserID String sPassword Returns Boolean
82170>>>>>>>>>        Boolean bLoginSuccessful
82170>>>>>>>>>        String sDriverID 
82170>>>>>>>>>        
82170>>>>>>>>>        Get psDriverID to sDriverID
82171>>>>>>>>>        //For the Mertech driver, using the Err indicator is the sanctioned way
82171>>>>>>>>>        Move False to Err
82172>>>>>>>>>        If (bTrusted = False) Begin
82174>>>>>>>>>            Login sServer sUserId sPassword sDriverID
82176>>>>>>>>>        End 
82176>>>>>>>>>>
