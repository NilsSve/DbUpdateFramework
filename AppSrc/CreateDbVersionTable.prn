83468>>>>>                        Case (sDriverID = MSSQLDRV_ID)
83470>>>>>                            Get ParseKeyWord sConnectionString (CS_SQLIniTrustedKeyword + "=") to sVal
83471>>>>>                            Move (If(Uppercase(sVal) = Uppercase(CS_SQLIniConnectionYes), True, False)) to bTrusted
83472>>>>>                            Move bTrusted                                               to SQLConnection.bTrusted
83473>>>>>                            Case Break
83474>>>>>                        Case (sDriverID = DB2_DRV_ID)
