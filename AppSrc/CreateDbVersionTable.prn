80304>Object oApplication is a cApplication
80306>    Set peHelpType to htHtmlHelp
80307>    Set psCompany to "RDC Tools International"
80308>    Set psProduct to "Create DbVersion Table"
80309>    Set psHelpFile to "DataFlex.chm"
80310>    Set psAutoOpenWorkspace to ""
80311>    
80311>    Property String psFilelistName  
80313>    Property String psOpenPath
80315>    
80315>    Procedure OnCreate
80318>        Handle ho hoIni            
80318>        String sSWSFile sWSFile sOpenPath sPath sHomeFolder sDdSrcPath sDataPath sFilelistname
80318>        Integer eOpened iPos                                         
80318>        Boolean bExists
80318>        
80318>        Get phoCommandLine to ho
80319>        Get Argument of ho 1 to sSWSFile  
80320>        
80320>        // Was the program started with a parameter on the command line from e.g. the Studio?
80320>        If (sSWSFile <> "") Begin
80322>            Get Create (RefClass(cIniFile)) to hoIni
80323>            Set psFileName of hoIni to sSWSFile 
80324>            Get ParseFolderName sSWSFile to sPath
80325>            
80325>            // Read .ws file path from the .sws file:
80325>            Get ReadString of hoIni "WorkspacePaths" "ConfigFile" "" to sWSFile 
80326>            Move (Pos(".\", sWSFile)) to iPos
80327>            If (iPos <> 0) Begin
80329>                Move (Replace(".\", sWSFile, "")) to sWSFile
80330>            End
80330>            Send Destroy of hoIni       
80331>            Move (sPath + sWSFile) to sWSFile
80332>            Get vFilePathExists sWSFile to bExists
80333>            If (bExists = True) Begin
80335>                Get OpenWorkspaceFile of (phoWorkspace(Self)) sWSFile to eOpened
80336>                If (eOpened = wsWorkspaceOpened) Begin
80338>                    Set psFilelistName to (psFileList(phoWorkspace(Self)))
80339>                    Procedure_Return // Workspace opened; We're done!
80340>                End
80340>            End
80340>        End   
80340>        
80340>        Get_Attribute DF_OPEN_PATH to sOpenPath  
80343>        Set psOpenPath to sOpenPath
80344>        
80344>        // Check if there is a config.ws file in the Programs folder:
80344>        Get OpenWorkspaceFile of (phoWorkspace(Self)) "config.ws" to eOpened
80345>        If (eOpened = wsWorkspaceOpened) Begin
80347>            Get psFileList of (phoWorkspace(Self)) to sFileListName
80348>            Set psFilelistName to sFileListName
80349>            Procedure_Return         // Workspace opened; We're done!
80350>        End
80350>        
80350>        // If no config.ws was not found; let user select a .ws file
80350>        Get GetApplicationPath to sPath 
80351>        Get vSelect_File "Workspace Files (*.ws)|*.ws|All Files (*.*)|*.*" "Please select a Workspace file (*.ws)" sPath to sWsFile
80352>        Get vFilePathExists sWsFile to bExists
80353>        If (bExists = False) Begin
80355>            Send Stop_Box "No Workspace file selected. Cannot continue!"
80356>            Send Exit_Application
80357>        End
80357>        Get OpenWorkspaceFile of (phoWorkspace(Self)) sWsFile to eOpened
80358>        If (eOpened = wsWorkspaceOpened) Begin
80360>            Get psFileList of (phoWorkspace(Self)) to sFileListName
80361>            Set psFilelistName to sFileListName
80362>            Procedure_Return
80363>        End  
80363>        Else Begin
80364>            Send Stop_Box "Could not open the Workspace. Cannot continue!"
80365>            Send Exit_Application
80366>        End
80366>
80366>    End_Procedure                            
80367>    
80367>End_Object
