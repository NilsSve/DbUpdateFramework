81656>>>>>>>>>Class cCryptographer is a cObject
81657>>>>>>>>>    
81657>>>>>>>>>    // Procedure : Construct_Object
81657>>>>>>>>>    // Purpose   : Object constructor
81657>>>>>>>>>    Procedure Construct_Object
81659>>>>>>>>>        Forward Send Construct_Object
81661>>>>>>>>>
81661>>>>>>>>>        Property String     psProvider  MS_ENHANCED_PROV
81662>>>>>>>>>        Property Integer    piProvider  PROV_RSA_FULL
81663>>>>>>>>>        Property Integer    piCipher    CALG_RC4
81664>>>>>>>>>        Property Integer    piHash      CALG_MD5
81665>>>>>>>>>        
81665>>>>>>>>>        // Private properties
81665>>>>>>>>>        Property Handle     Private_phProv
81666>>>>>>>>>    End_Procedure
81667>>>>>>>>>    
81667>>>>>>>>>    
81667>>>>>>>>>    // Function : AcquireContext
81667>>>>>>>>>    // Purpose  : Acquire key container handle
81667>>>>>>>>>    Function AcquireContext Returns Handle
81669>>>>>>>>>        Integer iProvider
81669>>>>>>>>>        String sProvider
81669>>>>>>>>>        Handle hProv
81669>>>>>>>>>        Boolean bOk
81669>>>>>>>>>        Address addrProv
81669>>>>>>>>>        
81669>>>>>>>>>        Move 0 to hProv
81670>>>>>>>>>        Get piProvider to iProvider
81671>>>>>>>>>        Get psProvider to sProvider
81672>>>>>>>>>        
81672>>>>>>>>>        //  Determine address to be passed as provider
81672>>>>>>>>>        If (Trim(sProvider) <> "") Begin
81674>>>>>>>>>            Move (AddressOf(sProvider)) to addrProv
81675>>>>>>>>>        End
81675>>>>>>>>>>
81675>>>>>>>>>        Else Begin
81676>>>>>>>>>            Move 0 to addrProv
81677>>>>>>>>>        End
81677>>>>>>>>>>
81677>>>>>>>>>        
81677>>>>>>>>>        //  Acquire Crypto Context
81677>>>>>>>>>        Move (CryptAcquireContext(AddressOf(hProv),0,addrProv,iProvider,CRYPT_VERIFYCONTEXT)) to bOk
81678>>>>>>>>>        If (not(bOk) or hProv = 0) Begin
81680>>>>>>>>>            Move (CryptAcquireContext(AddressOf(hProv),0,addrProv,iProvider,CRYPT_NEWKEYSET ior CRYPT_VERIFYCONTEXT)) to bOk
81681>>>>>>>>>        End
81681>>>>>>>>>>
81681>>>>>>>>>        
81681>>>>>>>>>        If (not(bOk) or hProv = 0) Begin
81683>>>>>>>>>            // Fallback to original
81683>>>>>>>>>            Move (CryptAcquireContext(AddressOf(hProv),0,addrProv,iProvider,0)) to bOk
81684>>>>>>>>>            
81684>>>>>>>>>            If (not(bOk) or hProv = 0) Begin
81686>>>>>>>>>                Move (CryptAcquireContext(AddressOf(hProv),0,addrProv,iProvider,CRYPT_NEWKEYSET)) to bOk
81687>>>>>>>>>            End
81687>>>>>>>>>>
81687>>>>>>>>>        End
81687>>>>>>>>>>
81687>>>>>>>>>        Set Private_phProv to hProv
81688>>>>>>>>>        
81688>>>>>>>>>        Function_Return hProv
81689>>>>>>>>>    End_Function
81690>>>>>>>>>    
81690>>>>>>>>>    // Function : ReleaseContext
81690>>>>>>>>>    // Purpose  : Releases key container handle
81690>>>>>>>>>    Function ReleaseContext Handle hProv Returns Boolean
81692>>>>>>>>>        Function_Return (CryptReleaseContext(hProv,0))
81693>>>>>>>>>    End_Function
81694>>>>>>>>>    
81694>>>>>>>>>    // Function : CreateHash
81694>>>>>>>>>    // Purpose  : Creates hash object
81694>>>>>>>>>    Function CreateHash Handle hProv Returns Handle
81696>>>>>>>>>        Integer iAlgorithm
81696>>>>>>>>>        Handle hHash
81696>>>>>>>>>        Boolean bOk
81696>>>>>>>>>        
81696>>>>>>>>>        Move 0 to hHash
81697>>>>>>>>>        Get piHash to iAlgorithm
81698>>>>>>>>>        Move (CryptCreateHash(hProv,iAlgorithm,0,0,AddressOf(hHash))) to bOk
81699>>>>>>>>>        
81699>>>>>>>>>        Function_Return hHash
81700>>>>>>>>>    End_Function
81701>>>>>>>>>    
81701>>>>>>>>>    // Function : DestroyHash
81701>>>>>>>>>    // Purpose  : Destroys the hash object
81701>>>>>>>>>    Function DestroyHash Handle hHash Returns Boolean
81703>>>>>>>>>        Function_Return (CryptDestroyHash(hHash))
81704>>>>>>>>>    End_Function
81705>>>>>>>>>    
81705>>>>>>>>>    // Function : HashData
81705>>>>>>>>>    // Purpose  : Adds data to hash object
81705>>>>>>>>>    Function HashData Handle hHash String sData Returns Boolean
81707>>>>>>>>>        Function_Return (CryptHashData(hHash,AddressOf(sData),Length(sData),0))
81708>>>>>>>>>    End_Function
81709>>>>>>>>>    
81709>>>>>>>>>    // Function : DeriveKey
81709>>>>>>>>>    // Purpose  : Generates session key
81709>>>>>>>>>    Function DeriveKey Handle hProv Handle hHash Returns Handle
81711>>>>>>>>>        Integer iAlgorithm
81711>>>>>>>>>        Handle hKey
81711>>>>>>>>>        Boolean bOk
81711>>>>>>>>>        
81711>>>>>>>>>        Move 0 to hKey
81712>>>>>>>>>        Get piCipher to iAlgorithm
81713>>>>>>>>>        Move (CryptDeriveKey(hProv,iAlgorithm,hHash,CRYPT_EXPORTABLE,AddressOf(hKey))) to bOk
81714>>>>>>>>>        
81714>>>>>>>>>        Function_Return hKey
81715>>>>>>>>>    End_Function
81716>>>>>>>>>    
81716>>>>>>>>>    // Function : ImportPlainTextKey
81716>>>>>>>>>    // Purpose  : Imports a plain text key
81716>>>>>>>>>    Function ImportPlainTextKey Handle hProv UChar[] ucaKey Returns Handle
81718>>>>>>>>>        tPLAINTEXTKEYBLOB blobhead
81718>>>>>>>>>        tPLAINTEXTKEYBLOB blobhead
81718>>>>>>>>>        Boolean   bSuccess
81718>>>>>>>>>        Handle    hKey
81718>>>>>>>>>        Integer   iHeadSize iKeySize
81718>>>>>>>>>        UChar[]   ucaKeyblob
81719>>>>>>>>>        Integer iVoid
81719>>>>>>>>>    
81719>>>>>>>>>        Move (SizeOfType(tPLAINTEXTKEYBLOB)) to iHeadSize
81720>>>>>>>>>        Move (SizeOfArray(ucaKey)) to iKeySize
81721>>>>>>>>>    
81721>>>>>>>>>        Move PLAINTEXTKEYBLOB to blobhead.hdr.bType
81722>>>>>>>>>        Move CUR_BLOB_VERSION   to blobhead.hdr.bVersion
81723>>>>>>>>>        Get piCipher            to blobhead.hdr.aiKeyAlg
81724>>>>>>>>>        Move iKeySize           to blobhead.dwKeySize
81725>>>>>>>>>    
81725>>>>>>>>>        Move (ResizeArray(ucaKeyblob, iHeadSize)) to ucaKeyblob
81726>>>>>>>>>        Move (CopyMemory(AddressOf(ucaKeyblob), AddressOf(blobhead), iHeadSize)) to iVoid
81727>>>>>>>>>        Move (AppendArray(ucaKeyblob, ucaKey)) to ucaKeyblob
81728>>>>>>>>>    
81728>>>>>>>>>        Move 0 to hKey
81729>>>>>>>>>        Move (CryptImportKey(hProv, AddressOf(ucaKeyblob), SizeOfArray(ucaKeyblob), 0, 0, AddressOf(hKey))) to bSuccess
81730>>>>>>>>>        If (not(bSuccess)) Begin 
81732>>>>>>>>>            Move (ShowLastError()) to iVoid
81733>>>>>>>>>        End
81733>>>>>>>>>>
81733>>>>>>>>>    
81733>>>>>>>>>        Function_Return hKey
81734>>>>>>>>>    End_Function
81735>>>>>>>>>
81735>>>>>>>>>    // Function : DestroyKey
81735>>>>>>>>>    // Purpose  : Destroys the key
81735>>>>>>>>>    Function DestroyKey Handle hKey Returns Boolean
81737>>>>>>>>>        Function_Return (CryptDestroyKey(hKey))
81738>>>>>>>>>    End_Function
81739>>>>>>>>>    
81739>>>>>>>>>    // Function : KeyParameter
81739>>>>>>>>>    // Purpose  : Retrieves key data
81739>>>>>>>>>    Function KeyParameter Handle hKey Integer iQuery Returns Integer
81741>>>>>>>>>        Integer iBuffer iLen
81741>>>>>>>>>        Boolean bOk
81741>>>>>>>>>        
81741>>>>>>>>>        Move (SizeOfType(Integer)) to iLen
81742>>>>>>>>>        Move (CryptGetKeyParam(hKey,iQuery,AddressOf(iBuffer),AddressOf(iLen),0)) to bOk
81743>>>>>>>>>        Function_Return iBuffer
81744>>>>>>>>>    End_Function
81745>>>>>>>>>    
81745>>>>>>>>>    // Function : HashValue
81745>>>>>>>>>    // Purpose  : Retrieves a hash value
81745>>>>>>>>>    Function HashValue Handle lhHash Returns String
81747>>>>>>>>>        Pointer lpSize
81747>>>>>>>>>        Pointer lpHash
81747>>>>>>>>>        String  lsSize
81747>>>>>>>>>        String  lsHash
81747>>>>>>>>>        Integer liResult
81747>>>>>>>>>
81747>>>>>>>>>        Move (Repeat(Character(0),4)) to lsSize
81748>>>>>>>>>        GetAddress of lsSize to lpSize
81749>>>>>>>>>
81749>>>>>>>>>        Move (CryptGetHashParam(lhHash,HP_HASHVAL,0,lpSize,0)) to liResult
81750>>>>>>>>>        If (liResult = 0) Function_Return ""
81753>>>>>>>>>
81753>>>>>>>>>        Move (Repeat(Character(0),BytesTodWord(lsSize,1))) to lsHash
81754>>>>>>>>>        GetAddress of lsHash to lpHash
81755>>>>>>>>>
81755>>>>>>>>>        Move (CryptGetHashParam(lhHash,HP_HASHVAL,lpHash,lpSize,0)) to liResult
81756>>>>>>>>>        If (liResult = 0) Function_Return ""
81759>>>>>>>>>
81759>>>>>>>>>        Function_Return lsHash
81760>>>>>>>>>    End_Function  // HashValue
81761>>>>>>>>>    
81761>>>>>>>>>            
81761>>>>>>>>>    // Function : Encrypt
81761>>>>>>>>>    // Purpose  : Encrypts data
81761>>>>>>>>>    Function Encrypt String sPassword String sData Returns String
81763>>>>>>>>>        Handle hProv hHash hKey
81763>>>>>>>>>        Integer iAlgorithm iDataLen iCipherLen iErr
81763>>>>>>>>>        Boolean bOk
81763>>>>>>>>>        
81763>>>>>>>>>        Get AcquireContext to hProv
81764>>>>>>>>>        If (hProv) Begin
81766>>>>>>>>>            Get CreateHash hProv to hHash
81767>>>>>>>>>            If (hHash) Begin
81769>>>>>>>>>                Get HashData hHash sPassword to bOk
81770>>>>>>>>>                If (bOk) Begin
81772>>>>>>>>>                    Get piCipher to iAlgorithm
81773>>>>>>>>>                    Get DeriveKey hProv hHash to hKey
81774>>>>>>>>>                End // If (bOk) Begin            
81774>>>>>>>>>>
81774>>>>>>>>>                Get DestroyHash hHash to bOk
81775>>>>>>>>>            End // If (hHash) Begin
81775>>>>>>>>>>
81775>>>>>>>>>            
81775>>>>>>>>>            If (hKey) Begin
81777>>>>>>>>>                //  First call to determine resulting data size
81777>>>>>>>>>                Move (Length(sData)) to iDataLen
81778>>>>>>>>>                Move (Length(sData)) to iCipherLen
81779>>>>>>>>>                Move (CryptEncrypt(hKey, 0, True, 0, 0, AddressOf(iCipherLen), iDataLen)) to bOk
81780>>>>>>>>>                
81780>>>>>>>>>                //  Reserve space in string
81780>>>>>>>>>                If (iDataLen < iCipherLen) Begin
81782>>>>>>>>>                    Move (sData + Repeat(" ", iCipherLen - iDataLen)) to sData
81783>>>>>>>>>                End
81783>>>>>>>>>>
81783>>>>>>>>>                
81783>>>>>>>>>                //  Call to really decrypt
81783>>>>>>>>>                Move (CryptEncrypt(hKey,0,True,0,AddressOf(sData),AddressOf(iDataLen),Length(sData))) to bOk
81784>>>>>>>>>                //If (not(bOk)) Begin
81784>>>>>>>>>                    //Move "" to sData
81784>>>>>>>>>                    //Move (GetLastError()) to iErr
81784>>>>>>>>>                //End
81784>>>>>>>>>                
81784>>>>>>>>>                Get DestroyKey hKey to bOk
81785>>>>>>>>>            End // If (hKey) Begin
81785>>>>>>>>>>
81785>>>>>>>>>            Get ReleaseContext hProv to bOk
81786>>>>>>>>>        End // If (hProv) Begin
81786>>>>>>>>>>
81786>>>>>>>>>        Function_Return sData
81787>>>>>>>>>    End_Function
81788>>>>>>>>>    
81788>>>>>>>>>    // Function : Decrypt
81788>>>>>>>>>    // Purpose  : Decrypts data
81788>>>>>>>>>    Function Decrypt String sPassword String sData Returns String
81790>>>>>>>>>        Handle hProv hHash hKey
81790>>>>>>>>>        Integer iAlgorithm iDataLen
81790>>>>>>>>>        Boolean bOk
81790>>>>>>>>>        
81790>>>>>>>>>        Get AcquireContext to hProv
81791>>>>>>>>>        If (hProv) Begin
81793>>>>>>>>>            Get CreateHash hProv to hHash
81794>>>>>>>>>            If (hHash) Begin
81796>>>>>>>>>                Get HashData hHash sPassword to bOk
81797>>>>>>>>>                If (bOk) Begin
81799>>>>>>>>>                    Get piCipher to iAlgorithm
81800>>>>>>>>>                    Get DeriveKey hProv hHash to hKey
81801>>>>>>>>>                End // If (bOk) Begin            
81801>>>>>>>>>>
81801>>>>>>>>>                Get DestroyHash hHash to bOk
81802>>>>>>>>>            End // If (hHash) Begin
81802>>>>>>>>>>
81802>>>>>>>>>            
81802>>>>>>>>>            If (hKey) Begin
81804>>>>>>>>>                Move (Length(sData)) to iDataLen
81805>>>>>>>>>                Move (CryptDecrypt(hKey,0,True,0,AddressOf(sData),AddressOf(iDataLen))) to bOk
81806>>>>>>>>>                //If (bOk = False) Move "" to sData
81806>>>>>>>>>                
81806>>>>>>>>>                //  Resulting dat can be shorter as the input string, in that case we shorten the result string
81806>>>>>>>>>                If (Length(sData) > iDataLen) Begin
81808>>>>>>>>>                    Move (Left(sData, iDataLen)) to sData
81809>>>>>>>>>                End
81809>>>>>>>>>>
81809>>>>>>>>>                
81809>>>>>>>>>                Get DestroyKey hKey to bOk
81810>>>>>>>>>            End // If (hKey) Begin
81810>>>>>>>>>>
81810>>>>>>>>>            Get ReleaseContext hProv to bOk
81811>>>>>>>>>        End // If (hProv) Begin
81811>>>>>>>>>>
81811>>>>>>>>>        Function_Return sData
81812>>>>>>>>>    End_Function
81813>>>>>>>>>    
81813>>>>>>>>>    //  Function : GenerateRandom
81813>>>>>>>>>    //  Purpose  : Generates random data.
81813>>>>>>>>>    Function GenerateRandom Integer iBytes Returns UChar[]
81815>>>>>>>>>        Handle hProv
81815>>>>>>>>>        UChar[] uaResult
81816>>>>>>>>>        Boolean bRes
81816>>>>>>>>>        
81816>>>>>>>>>        Get AcquireContext to hProv
81817>>>>>>>>>        
81817>>>>>>>>>        Move (ResizeArray(uaResult, iBytes)) to uaResult
81818>>>>>>>>>        Move (CryptGenRandom(hProv, iBytes, AddressOf(uaResult))) to bRes
81819>>>>>>>>>        
81819>>>>>>>>>        Get ReleaseContext hProv to bRes
81820>>>>>>>>>        
81820>>>>>>>>>        Function_Return uaResult
81821>>>>>>>>>    End_Function
81822>>>>>>>>>    
81822>>>>>>>>>    //  Function : GenerateRandomString
81822>>>>>>>>>    //  Purpose  : Generates random data and does a base64 encoding to properly present it as a string.
81822>>>>>>>>>    Function GenerateRandomString Integer iLenght Returns String
81824>>>>>>>>>        String sResult
81824>>>>>>>>>        UChar[] aData
81825>>>>>>>>>        Address pBase64
81825>>>>>>>>>        Integer iVoid
81825>>>>>>>>>
81825>>>>>>>>>        Get GenerateRandom iLenght to aData
81826>>>>>>>>>        
81826>>>>>>>>>        Move (Base64Encode(AddressOf(aData), iLenght)) to pBase64
81827>>>>>>>>>        Move pBase64 to sResult
81828>>>>>>>>>        Move (Free(pBase64)) to iVoid    
81829>>>>>>>>>        
81829>>>>>>>>>        Function_Return (Left(sResult, iLenght))
81830>>>>>>>>>    End_Function
81831>>>>>>>>>
81831>>>>>>>>>End_Class
81832>>>>>>>Use Base64Functions.pkg  
Including file: Base64Functions.pkg    (C:\Projects\DF18\DbUpdateFramework\AppSrc\Base64Functions.pkg)
81832>>>>>>>>>//> This package enables base64 encoding and decoding of strings:
81832>>>>>>>>>//>
81832>>>>>>>>>//>     Get EncodeString of oBase64Functions sValue to sValue
81832>>>>>>>>>//>     Get DecodeString of oBase64Functions sValue to sValue
81832>>>>>>>>>//>
81832>>>>>>>>>//> Remember to set the "max argument size" if dealing with very large
81832>>>>>>>>>//> strings.
81832>>>>>>>>>//>
81832>>>>>>>>>//> For 17.1 and later the functionality of this package is based on two functions (Base64Encode and
81832>>>>>>>>>//> Base64Decode) that are built into the runtime.
81832>>>>>>>>>//>
81832>>>>>>>>>//> But for versions up to and including 17.0 it's based on the vdfBase64.dll file that was obtained
81832>>>>>>>>>//> from DAE that have kindly allowed me to distribute it to other DF developers. Programs including
81832>>>>>>>>>//> this package will give off an error on start-up if vdfBase64.dll is not found in the /bin folder
81832>>>>>>>>>//> if the VDF runtime. You will find the DLL in the /programs folder of the StureApsPublicLib workspace
81832>>>>>>>>>
81832>>>>>>>>>Use VdfBase.pkg
81832>>>>>>>>>
81832>>>>>>>>>// Functions in vdfBase64.dll
81832>>>>>>>>>External_Function xxBase64Encode "vdfbase64Encode" vdfBase64.dll Pointer pBuffer Returns Integer
81833>>>>>>>>>External_Function xxBase64Decode "vdfbase64Decode" vdfBase64.dll Pointer pBuffer Returns Integer
81834>>>>>>>>>External_Function xxBase64Free   "vdfbase64Free"   vdfBase64.dll Pointer pBuffer Returns Integer
81835>>>>>>>>>
81835>>>>>>>>>// Structure
81835>>>>>>>>>Struct txxfBase64Buffer
81835>>>>>>>>>    Pointer pData
81835>>>>>>>>>    Integer iLength
81835>>>>>>>>>End_Struct 
81835>>>>>>>>>
81835>>>>>>>>>Global_Variable Integer oBase64Functions
81835>>>>>>>>>
81835>>>>>>>>>Object _oBase64Functions is a cObject
81837>>>>>>>>>    Move Self to oBase64Functions
81838>>>>>>>>>
81838>>>>>>>>>
81838>>>>>>>>>    Function EncodeString String sValue Returns String
81841>>>>>>>>>        Address pBase64
81841>>>>>>>>>        String sResult
81841>>>>>>>>>        Integer iVoid
81841>>>>>>>>>        Move (Base64Encode(AddressOf(sValue), Length(sValue))) to pBase64
81842>>>>>>>>>        Move pBase64 to sResult
81843>>>>>>>>>        Move (Free(pBase64)) to iVoid
81844>>>>>>>>>        Function_Return sResult
81845>>>>>>>>>    End_Function
81846>>>>>>>>>
81846>>>>>>>>>    Function DecodeString String sValue Returns String
81849>>>>>>>>>        Address pBinary
81849>>>>>>>>>        String sBinary
81849>>>>>>>>>        Integer iVoid iLen
81849>>>>>>>>>        Move (Base64Decode(AddressOf(sValue), &iLen)) to pBinary
81850>>>>>>>>>        Move (Repeat(Character(0), iLen)) to sBinary
81851>>>>>>>>>        Move (MemCopy(AddressOf(sBinary), pBinary, iLen)) to iVoid
81852>>>>>>>>>        Move (Free(pBinary)) to iVoid
81853>>>>>>>>>        Function_Return sBinary
81854>>>>>>>>>    End_Function
81855>>>>>>>>>
81855>>>>>>>>>End_Object
