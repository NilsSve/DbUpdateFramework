88203>>>    Function UtilDeleteCacheFile String sTableName Returns Boolean
88205>>>        String sDataPath sDriverID
88205>>>        Boolean bMertechDriver bOK  
88205>>>        Integer iPos
88205>>>        
88205>>>        If (sTableName contains ".") Begin
88207>>>            Move (Pos(".", sTableName)) to iPos
88208>>>            Move (Mid(sTableName, 999, (iPos +1))) to sTableName    
88209>>>        End                                                     
88209>>>>
88209>>>        
88209>>>        Get psDriverID to sDriverID
88210>>>        Get psDataPathFirstPart to sDataPath 
88211>>>        Get IsMertechDriver sDriverID to bMertechDriver
88212>>>        // First delete the cache file:
88212>>>        If (bMertechDriver = False) Begin
