91233>>>>>>>>>Class cFormatter is an cObject
91234>>>>>>>>>
91234>>>>>>>>>    Procedure Construct_object
91236>>>>>>>>>        Integer iCh
91236>>>>>>>>>        forward send construct_object
91238>>>>>>>>>        Property String  psCurrencySymbol
91239>>>>>>>>>        Set psCurrencySymbol to (Default_Currency_Symbol())
91240>>>>>>>>>
91240>>>>>>>>>        Property string  psLeft
91241>>>>>>>>>        Property string  psright
91242>>>>>>>>>        Property integer pbThousandsSep
91243>>>>>>>>>        Property integer piPoints
91244>>>>>>>>>
91244>>>>>>>>>        Property string  psCurPosLeft
91245>>>>>>>>>        Property string  psCurPosright
91246>>>>>>>>>        Property integer pbCurPosThousandsSep
91247>>>>>>>>>        Property integer piCurPosPoints
91248>>>>>>>>>
91248>>>>>>>>>        Property string  psCurNegLeft
91249>>>>>>>>>        Property string  psCurNegright
91250>>>>>>>>>        Property integer pbCurNegThousandsSep
91251>>>>>>>>>        Property integer piCurNegPoints
91252>>>>>>>>>
91252>>>>>>>>>        Property string  psNumPosLeft
91253>>>>>>>>>        Property string  psNumPosright
91254>>>>>>>>>        Property integer pbNumPosThousandsSep
91255>>>>>>>>>        Property integer piNumPosPoints
91256>>>>>>>>>
91256>>>>>>>>>        Property string  psNumNegLeft
91257>>>>>>>>>        Property string  psNumNegright
91258>>>>>>>>>        Property integer pbNumNegThousandsSep
91259>>>>>>>>>        Property integer piNumNegPoints
91260>>>>>>>>>
91260>>>>>>>>>        Send SetFormat "$,#.##;($,#.##)" true  // currency
91261>>>>>>>>>        Send SetFormat  ",#.*"           false // numeric
91262>>>>>>>>>
91262>>>>>>>>>    end_procedure
91263>>>>>>>>>
91263>>>>>>>>>    // internal
91263>>>>>>>>>    // parse passed format string and set temporary properties with result
91263>>>>>>>>>    //
91263>>>>>>>>>    Procedure ParseFormat string sFmt
91265>>>>>>>>>
91265>>>>>>>>>        string sLeft sRight sDigit
91265>>>>>>>>>        integer bSep iPos i iDigits
91265>>>>>>>>>
91265>>>>>>>>>        // replace any literals. A "/" followed by anything.
91265>>>>>>>>>        // some literals are special. $ . , / #
91265>>>>>>>>>        Move (Replaces("/$",sFmt,Character(1)))    to sFmt
91266>>>>>>>>>        Move (Replaces("/.",sFmt,Character(2)))    to sFmt
91267>>>>>>>>>        Move (Replaces("/,",sFmt,Character(3)))    to sFmt
91268>>>>>>>>>        Move (Replaces("/"+"/",sFmt,Character(4))) to sFmt
91269>>>>>>>>>        Move (Replaces("/#",sFmt,Character(5)))    to sFmt
91270>>>>>>>>>        Move (Character(9)) to sDigit
91271>>>>>>>>>        Move (Replaces("#",sFmt,sDigit))           to sFmt
91272>>>>>>>>>        Move (Replaces("/",sFmt,""))               to sFmt // replace all others
91273>>>>>>>>>
91273>>>>>>>>>        Move (Pos(",",sFmt))                 to bSep // if we have any , we use thousand seps
91274>>>>>>>>>        If bSep Move (Replaces(",",sFmt,"")) to sFmt // remove all ,
91277>>>>>>>>>
91277>>>>>>>>>        Move (Replaces("$",sFmt,psCurrencySymbol(self))) to sFmt // replace any $ with currency symbol
91278>>>>>>>>>
91278>>>>>>>>>        Move (Pos(".",sFmt)) to iPos                 // position of decimal
91279>>>>>>>>>
91279>>>>>>>>>        // Move all the special literals back into place before parsing
91279>>>>>>>>>        Move (Replaces(Character(1),sFmt,"$")) to sFmt
91280>>>>>>>>>        Move (Replaces(Character(2),sFmt,".")) to sFmt
91281>>>>>>>>>        Move (Replaces(Character(3),sFmt,",")) to sFmt
91282>>>>>>>>>        Move (Replaces(Character(4),sFmt,"/")) to sFmt
91283>>>>>>>>>        Move (Replaces(Character(5),sFmt,"#")) to sFmt
91284>>>>>>>>>
91284>>>>>>>>>        If (iPos>0) Begin                      // if we have a decimanl point
91286>>>>>>>>>            Move 1 to i                        // look for first non # to right and count the #s
91287>>>>>>>>>            If (mid(sFmt,1,iPos+i)="*") Begin  // the "*" is special. It means as many as you want
91289>>>>>>>>>               Move -2 to iDigits
91290>>>>>>>>>               increment i
91291>>>>>>>>>            end
91291>>>>>>>>>>
91291>>>>>>>>>            While (mid(sFmt,1,iPos+i)=sDigit)
91295>>>>>>>>>                 Increment i
91296>>>>>>>>>            end
91297>>>>>>>>>>
91297>>>>>>>>>            Move (Mid(sFmt,255,iPos+i)) to sRight // everything to the right of the last # is format stuff
91298>>>>>>>>>            If (iDigits=0) Move (i-1) to iDigits
91301>>>>>>>>>            //
91301>>>>>>>>>            Move 1 to i                           // find the first non-# to the left of the point
91302>>>>>>>>>            While (mid(sFmt,1,iPos-i)=sDigit)     // everything to the left is format stuff
91306>>>>>>>>>                 increment i
91307>>>>>>>>>            end
91308>>>>>>>>>>
91308>>>>>>>>>            Move (left(sFmt,iPos-i)) to sLeft
91309>>>>>>>>>        end
91309>>>>>>>>>>
91309>>>>>>>>>        else begin                             // we have no decinal
91310>>>>>>>>>            Move 0 to iDigits                  // so points is none
91311>>>>>>>>>            Move (Pos(sDigit,sFmt)) to iPos    // find first #.
91312>>>>>>>>>            If (iPos=0) Begin                  // if none, entire string is left format stuff..wierd!
91314>>>>>>>>>                Move sFmt to sLeft
91315>>>>>>>>>                Move ""   to sRight
91316>>>>>>>>>            end
91316>>>>>>>>>>
91316>>>>>>>>>            else begin
91317>>>>>>>>>                Move (left(sFmt,iPos-1)) to sLeft // all char to left of first # is left format stuff
91318>>>>>>>>>                Move 1 to i
91319>>>>>>>>>                While (mid(sFmt,1,iPos+i)=sDigit) // find last #, all char to right is right format
91323>>>>>>>>>                    Increment i
91324>>>>>>>>>                end
91325>>>>>>>>>>
91325>>>>>>>>>                Move (Mid(sFmt,255,i+iPos)) to sRight
91326>>>>>>>>>            end
91326>>>>>>>>>>
91326>>>>>>>>>        end
91326>>>>>>>>>>
91326>>>>>>>>>        // set temporary format properties and exit
91326>>>>>>>>>        Set pbThousandsSep to bSep
91327>>>>>>>>>        set psLeft         to sLeft
91328>>>>>>>>>        set psRight        to sRight
91329>>>>>>>>>        Set piPoints       to iDigits
91330>>>>>>>>>     End_procedure
91331>>>>>>>>>
91331>>>>>>>>>    // Public: Sets a format string. Pass full format for Positve and negative in sFmt. Pass
91331>>>>>>>>>    //         bCurrency true is this is a currency format, false if a numeric format
91331>>>>>>>>>    //
91331>>>>>>>>>    //  e.g. Send SetFormat "$,#.##;($,#.##)" True
91331>>>>>>>>>    //
91331>>>>>>>>>    Procedure SetFormat string sFmt integer bCurrency
91333>>>>>>>>>        string sPos sNeg
91333>>>>>>>>>        integer iPos
91333>>>>>>>>>
91333>>>>>>>>>        Move (Pos(";",sFmt)) to iPos
91334>>>>>>>>>        If iPos begin
91336>>>>>>>>>            Move (left(sFmt,iPos-1))    to sPos
91337>>>>>>>>>            Move (mid(sFmt,255,iPos+1)) to sNeg
91338>>>>>>>>>        end
91338>>>>>>>>>>
91338>>>>>>>>>        else Begin
91339>>>>>>>>>            Move sFmt         to sPos
91340>>>>>>>>>            Move ("-" + sFmt) to sNeg
91341>>>>>>>>>        end
91341>>>>>>>>>>
91341>>>>>>>>>        Send ParseFormat sPos
91342>>>>>>>>>        If bCurrency begin
91344>>>>>>>>>            Set pbCurPosThousandsSep to (pbThousandsSep(self))
91345>>>>>>>>>            set psCurPosLeft         to (psLeft(self))
91346>>>>>>>>>            set psCurPosRight        to (psRight(self))
91347>>>>>>>>>            Set piCurPosPoints       to (piPoints(self))
91348>>>>>>>>>        End
91348>>>>>>>>>>
91348>>>>>>>>>        else Begin
91349>>>>>>>>>            Set pbNumPosThousandsSep to (pbThousandsSep(self))
91350>>>>>>>>>            set psNumPosLeft         to (psLeft(self))
91351>>>>>>>>>            set psNumPosRight        to (psRight(self))
91352>>>>>>>>>            Set piNumPosPoints       to (piPoints(self))
91353>>>>>>>>>        end
91353>>>>>>>>>>
91353>>>>>>>>>
91353>>>>>>>>>        Send ParseFormat sNeg
91354>>>>>>>>>        If bCurrency begin
91356>>>>>>>>>            Set pbCurNegThousandsSep to (pbThousandsSep(self))
91357>>>>>>>>>            set psCurNegLeft         to (psLeft(self))
91358>>>>>>>>>            set psCurNegRight        to (psRight(self))
91359>>>>>>>>>            Set piCurNegPoints       to (piPoints(self))
91360>>>>>>>>>        End
91360>>>>>>>>>>
91360>>>>>>>>>        else Begin
91361>>>>>>>>>            Set pbNumNegThousandsSep to (pbThousandsSep(self))
91362>>>>>>>>>            set psNumNegLeft         to (psLeft(self))
91363>>>>>>>>>            set psNumNegRight        to (psRight(self))
91364>>>>>>>>>            Set piNumNegPoints       to (piPoints(self))
91365>>>>>>>>>        end
91365>>>>>>>>>>
91365>>>>>>>>>    End_procedure
91366>>>>>>>>>
91366>>>>>>>>>    // low level formatting. Pass parameters
91366>>>>>>>>>    Function Format_Num number nNumber integer iPoints integer bSep ;                       string sPrefix string sSuffix returns string
91368>>>>>>>>>        string  sLeft sRight sNumber sSep sDec
91368>>>>>>>>>        integer bIsNegative iDec iLen iCh
91368>>>>>>>>>
91368>>>>>>>>>        Get_Attribute DF_DECIMAL_SEPARATOR to iCh
91371>>>>>>>>>        Move (Character(iCh)) to sDec
91372>>>>>>>>>
91372>>>>>>>>>        Move (abs(nNumber)) to sNumber
91373>>>>>>>>>        Move (Pos(sDec,sNumber)) to iDec
91374>>>>>>>>>        Move (If(iDec=0, sNumber, left(sNumber,iDec-1))) to sLeft
91375>>>>>>>>>        Move (If(iDec=0, "", mid(sNumber,255,iDec+1)))   to sRight
91376>>>>>>>>>        // format for decimal separator
91376>>>>>>>>>        If (iPoints>=0) ; // if -2, leave it alone, it should not be -1            Move (left(sRight+repeat("0",iPoints),iPoints)) to sRight
91379>>>>>>>>>
91379>>>>>>>>>        // format for thousand sep.
91379>>>>>>>>>        If bSep Begin
91381>>>>>>>>>            Get_Attribute DF_THOUSANDS_SEPARATOR to iCh
91384>>>>>>>>>            Move (Character(iCh)) to sSep
91385>>>>>>>>>            Move (Length(sLeft)) to iLen
91386>>>>>>>>>            While (iLen>3)
91390>>>>>>>>>                Move (insert(sSep,sLeft,iLen-2)) to sLeft
91391>>>>>>>>>                Move (iLen-3) to iLen
91392>>>>>>>>>            End
91393>>>>>>>>>>
91393>>>>>>>>>        End
91393>>>>>>>>>>
91393>>>>>>>>>        // if decimal points or -2 (allow anything) and there are points to show
91393>>>>>>>>>        If (iPoints>0 OR (iPoints=-2 AND sRight<>"")) ;            Move (sLeft + sDec + sright) to sLeft
91396>>>>>>>>>        Function_return (sPrefix + sLeft+ sSuffix)
91397>>>>>>>>>    End_Function
91398>>>>>>>>>
91398>>>>>>>>>    // Public: Format for currency
91398>>>>>>>>>    //
91398>>>>>>>>>    Function FormatCur number nNumber integer iPoints returns string
91400>>>>>>>>>        string  sLeft sRight
91400>>>>>>>>>        integer bSep
91400>>>>>>>>>        If (nNumber<0) Begin
91402>>>>>>>>>            get pbCurNegThousandsSep to bSep
91403>>>>>>>>>            get psCurNegLeft         to sLeft
91404>>>>>>>>>            get psCurNegRight        to sRight
91405>>>>>>>>>            If (iPoints=-1) get piCurNegPoints       to iPoints
91408>>>>>>>>>        end
91408>>>>>>>>>>
91408>>>>>>>>>        Else Begin
91409>>>>>>>>>            get pbCurPosThousandsSep to bSep
91410>>>>>>>>>            get psCurPosLeft         to sLeft
91411>>>>>>>>>            get psCurPosRight        to sRight
91412>>>>>>>>>            If (iPoints=-1) get piCurPosPoints       to iPoints
91415>>>>>>>>>        end
91415>>>>>>>>>>
91415>>>>>>>>>        Function_return (Format_Num(self, nNumber,iPoints,bSep,sLeft,sRight))
91416>>>>>>>>>    End_function
91417>>>>>>>>>
91417>>>>>>>>>    // Public: Format for numeric
91417>>>>>>>>>    //
91417>>>>>>>>>    Function FormatNum number nNumber integer iPoints returns string
91419>>>>>>>>>        string  sLeft sRight
91419>>>>>>>>>        integer bSep
91419>>>>>>>>>        If (nNumber<0) Begin
91421>>>>>>>>>            get pbNumNegThousandsSep to bSep
91422>>>>>>>>>            get psNumNegLeft         to sLeft
91423>>>>>>>>>            get psNumNegRight        to sRight
91424>>>>>>>>>            If (iPoints=-1) get piNumNegPoints       to iPoints
91427>>>>>>>>>        end
91427>>>>>>>>>>
91427>>>>>>>>>        Else Begin
91428>>>>>>>>>            get pbNumPosThousandsSep to bSep
91429>>>>>>>>>            get psNumPosLeft         to sLeft
91430>>>>>>>>>            get psNumPosRight        to sRight
91431>>>>>>>>>            If (iPoints=-1) get piNumPosPoints       to iPoints
91434>>>>>>>>>        end
91434>>>>>>>>>>
91434>>>>>>>>>        Function_return (Format_Num(self, nNumber,iPoints,bSep,sLeft,sRight))
91435>>>>>>>>>    End_function
91436>>>>>>>>>
91436>>>>>>>>>
91436>>>>>>>>>    // Public: Format passing format string
91436>>>>>>>>>    //
91436>>>>>>>>>    Function FormatVal number nNumber string sFmt returns string
91438>>>>>>>>>        integer iPos bIsNeg
91438>>>>>>>>>        string  sLeft sRight
91438>>>>>>>>>        integer iPoints bSep
91438>>>>>>>>>        Move (nNumber<0) to bIsNeg
91439>>>>>>>>>        Move (Pos(";",sFmt)) to iPos
91440>>>>>>>>>        Case Begin
91440>>>>>>>>>            Case (iPos and Not(bIsNeg))      Move (left(sFmt,iPos-1))    to sFmt
91443>>>>>>>>>            Case (iPos and bIsNeg)           Move (mid(sFmt,255,iPos+1)) to sFmt
91447>>>>>>>>>            Case (not(iPos) and not(bIsNeg)) Move sFmt                   to sFmt
91451>>>>>>>>>            Case else                        Move ("-" + sFmt)           to sFmt
91453>>>>>>>>>        case end
91453>>>>>>>>>        Send ParseFormat sFmt
91454>>>>>>>>>        get pbThousandsSep to bSep
91455>>>>>>>>>        get psLeft         to sLeft
91456>>>>>>>>>        get psRight        to sRight
91457>>>>>>>>>        get piPoints       to iPoints
91458>>>>>>>>>        Function_return (Format_Num(self, nNumber,iPoints,bSep,sLeft,sRight))
91459>>>>>>>>>    end_function
91460>>>>>>>>>
91460>>>>>>>>>End_Class
