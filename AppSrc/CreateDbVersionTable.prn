84876>>>    // Enumerate SQL Servers. 
84876>>>    // Pass a driver id. Returns a string array.                     
84876>>>    // The iDataSourceType (iDatSrcType) parameter is optional and is for the ODBC driver only.
84876>>>    // Note: Returns servers for MSSQLDRV; else data-sources on the machine.
84876>>>    Function SqlUtilEnumerateServers String sDriverID Integer iDatSrcType Returns String[]
84878>>>        String[] sReturnArray
84879>>>        Handle hoSQLHandler
84879>>>        String sServer
84879>>>        Integer iCount iNumItems iDataSourceType
84879>>>        Boolean bOK
84879>>>        
84879>>>        If (num_arguments > 1) Begin
84881>>>            Move iDatSrcType to iDataSourceType
84882>>>        End                                    
84882>>>>
84882>>>        
84882>>>        Case Begin
84882>>>            Case (sDriverID = MSSQLDRV_ID) 
84884>>>                Get phoMSSQLHandler to hoSQLHandler
84885>>>                    Get EnumerateServersLocal of hoSQLHandler to iNumItems
84886>>>                    If (iNumItems = 0) Begin
84888>>>                        Get EnumerateServers of hoSQLHandler to iNumItems
84889>>>                    End            
84889>>>>
84889>>>                For iCount from 0 to (iNumItems - 1)
84895>>>>
84895>>>                    Get String_Value of hoSQLHandler item iCount to sServer
84896>>>                    Move (Trim(sServer)) to sReturnArray[iCount]
84897>>>                Loop
84898>>>>
84898>>>                Case Break 
84899>>>    
84899>>>            Case (sDriverID = DB2_DRV_ID) 
84902>>>                Get phoDB2SQLHandler to hoSQLHandler
84903>>>                Send SeedDataSources of hoSQLHandler          
84904>>>                Move 0 to iCount
84905>>>                Repeat
84905>>>>
84905>>>                    Get DataSources of hoSQLHandler to sServer
84906>>>                    If (sServer <> "") Begin   
84908>>>                        Move (Replace(",", sServer, "")) to sServer
84909>>>                        Move sServer to sReturnArray[iCount]
84910>>>                    End
84910>>>>
84910>>>                    Increment iCount    
84911>>>                Until (sServer = "")
84913>>>                Case Break
84914>>>    
84914>>>            Case (sDriverID = ODBC_DRV_ID) 
84917>>>                Get phoODBCSQLHandler to hoSQLHandler
84918>>>                Set DataSourceType of hoSQLHandler to iDataSourceType       
84919>>>                Move 0 to iCount
84920>>>                Repeat
84920>>>>
84920>>>                    Get DataSources of hoSQLHandler to sServer
84921>>>                    If (sServer <> "") Begin   
84923>>>                        Move (Replace(",", sServer, ", ")) to sServer
84924>>>                        Move sServer to sReturnArray[iCount]
84925>>>                    End
84925>>>>
84925>>>                    Increment iCount    
84926>>>                Until (sServer = "")
84928>>>                Case Break    
84929>>>            
84929>>>            Case (sDriverID = SQLFLEX)  
84932>>>                Get _MertechEnumerateSQLFlexServers to sReturnArray
84933>>>                Case Break
84934>>>            
84934>>>            Case (sDriverID = ORAFLEX)          
84937>>>                Get _MertechEnumerateORAFLEXServers to sReturnArray
84938>>>                Case Break
84939>>>            
84939>>>            // There appearantly is no way to enumerate servers for this backend.
84939>>>            Case (sDriverID = MDSPgSQL)
84942>>>                Move "localhost" to sReturnArray[0]
84943>>>                Case Break
84944>>>            
84944>>>            // There appearantly is no way to enumerate servers for this backend.
84944>>>            Case (sDriverID = MDSMySQL)
84947>>>                Move "localhost" to sReturnArray[0]
84948>>>                Case Break
84949>>>            
84949>>>            Case Else
84949>>>                Error DFERR_PROGRAM "Unsupported DriverID passed to SqlUtilEnumerateServers function"
84950>>>>
84950>>>        Case End
84950>>>
84950>>>        Function_Return sReturnArray
84951>>>    End_Function
