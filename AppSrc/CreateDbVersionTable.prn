80670>>>>>>>Class cCJSkinFramework is a cCJComSkinFramework
80671>>>>>>>    
80671>>>>>>>    Procedure Construct_Object
80673>>>>>>>        Forward Send Construct_Object
80675>>>>>>>        
80675>>>>>>>        Property String psSkinFile ""
80676>>>>>>>        Property String psSkinIni ""
80677>>>>>>>        Property Boolean pbLoadPreference False
80678>>>>>>>        
80678>>>>>>>        Set peAutoCreate to acAutoCreate
80679>>>>>>>        
80679>>>>>>>        Move Self to ghoSkinFramework
80680>>>>>>>    End_Procedure
80681>>>>>>>    
80681>>>>>>>    // return the default skin path, which is the programs directory.
80681>>>>>>>    // This requires an application object.
80681>>>>>>>    // If you want to different skin path, override this.
80681>>>>>>>    Function SkinPath Returns String
80683>>>>>>>        String sPath sPaths
80683>>>>>>>        Handle hoWorkspace
80683>>>>>>>        If ghoApplication Begin
80685>>>>>>>            Get phoWorkspace of ghoApplication to hoWorkspace
80686>>>>>>>            Get psProgramPath of hoWorkspace to sPaths
80687>>>>>>>            Get PathAtIndex of hoWorkspace sPaths 1 to sPath
80688>>>>>>>        End
80688>>>>>>>>
80688>>>>>>>        Else Begin
80689>>>>>>>            Error DFERR_PROGRAM C_$ApplicationObjectNotCreated
80690>>>>>>>>
80690>>>>>>>        End
80690>>>>>>>>
80690>>>>>>>        Function_Return sPath
80691>>>>>>>    End_Function
80692>>>>>>>    
80692>>>>>>>    // Returns the Qualified name of psSkinFile. If the file is already qualified it just
80692>>>>>>>    // returns itself. If it is not, it uses SkinPath to get the path.
80692>>>>>>>    Function SkinQFile Returns String
80694>>>>>>>        String sFile sPath sSep
80694>>>>>>>        Boolean bQualified
80694>>>>>>>        Get psSkinFile to sFile
80695>>>>>>>        If not (IsFileNameQualified(sFile)) Begin
80697>>>>>>>            Get SkinPath to sPath
80698>>>>>>>            Move (SysConf(SYSCONF_DIR_SEPARATOR)) to sSep
80699>>>>>>>            Move (sPath - sSep - sFile) to sFile
80700>>>>>>>        End
80700>>>>>>>>
80700>>>>>>>        Function_Return sFile
80701>>>>>>>    End_Function
80702>>>>>>>        
80702>>>>>>>    // defines the default VDF window class mapping.    
80702>>>>>>>    Procedure OnAddVDFWindowClasses
80704>>>>>>>        Send ComAddWindowClass "DFlistbox"               "ListBox"
80705>>>>>>>        Send ComAddWindowClass "DFentry"                 "Edit"
80706>>>>>>>        Send ComAddWindowClass "DFtextbox"               "Edit"
80707>>>>>>>        Send ComAddWindowClass "DFRichEditCtrl"          "Edit"
80708>>>>>>>        Send ComAddWindowClass "DFcombobox"              "ComboBox"
80709>>>>>>>        Send ComAddWindowClass "DFformlist"              "Edit"
80710>>>>>>>        Send ComAddWindowClass "DFFormListHeader"        "SysHeader32"
80711>>>>>>>        Send ComAddWindowClass "DFbutton"                "Button"
80712>>>>>>>        Send ComAddWindowClass "HPromptBtn"              "Button"
80713>>>>>>>        Send ComAddWindowClass "Hspinbtn"                "msctls_updown32"
80714>>>>>>>        Send ComAddWindowClass "DFSysTabControl32"       "SysTabControl32"
80715>>>>>>>        Send ComAddWindowClass "DFMDIClient"             "MDIClient" 
80716>>>>>>>        Send ComAddWindowClass "DFedit"                  "edit"
80717>>>>>>>        Send ComAddWindowClass "DFlistedit"              "edit"
80718>>>>>>>        Send ComAddWindowClass "DFscrollbar"             "scrollbar"
80719>>>>>>>        Send ComAddWindowClass "DFgroup"                 "Button"
80720>>>>>>>        Send ComAddWindowClass "DFComboGrid"             "ComboBox"
80721>>>>>>>        // External class
80721>>>>>>>        Send ComAddWindowClass "cVdfAnimation"           "SysAnimate32"
80722>>>>>>>        Send ComAddWindowClass "cVdfProgressBar"         "msctls_progress32"
80723>>>>>>>        Send ComAddWindowClass "cVdfStatusBar"           "msctls_statusbar32"
80724>>>>>>>        Send ComAddWindowClass "cVdfToolbar"             "ToolbarWindow32"
80725>>>>>>>        Send ComAddWindowClass "cObsoleteVdfProgressBar" "msctls_progress32"
80726>>>>>>>        Send ComAddWindowClass "cVdfTrackBar"            "msctls_trackbar32"
80727>>>>>>>        Send ComAddWindowClass "cObsoleteBasicStatusBar" "msctls_statusbar32"
80728>>>>>>>        Send ComAddWindowClass "cVdfTreeView"            "SysTreeView32"
80729>>>>>>>    End_Procedure
80730>>>>>>>    
80730>>>>>>>    // Used to support developer designed class mappings (e.g. COM controls)
80730>>>>>>>    Procedure OnAddCustomWindowClasses
80732>>>>>>>    End_Procedure
80733>>>>>>>
80733>>>>>>>    // called when object is created during end_construct_object.
80733>>>>>>>    Procedure OnCreate
80735>>>>>>>        Integer iOpts
80735>>>>>>>        Boolean bUseWindowsFont
80735>>>>>>>        Forward Send OnCreate
80737>>>>>>>        
80737>>>>>>>        // if we are using the windows fonts we will disable the apply metrics which
80737>>>>>>>        // never really looked good anyway. This test only exists or legacy purposes
80737>>>>>>>        Get pbUseWindowsFont of Desktop to bUseWindowsFont
80738>>>>>>>        If bUseWindowsFont Begin
80740>>>>>>>            Get ComApplyOptions to iOpts
80741>>>>>>>            Set ComApplyOptions to (RemoveBitValue(xtpSkinApplyMetrics, iOpts))
80742>>>>>>>        End
80742>>>>>>>>
80742>>>>>>>
80742>>>>>>>        // this works around a CJ issue where skins applied to other threads causes an exception upon close down. 
80742>>>>>>>        // We saw this with our mssql driver but it could occur elsewhere. This has been reported in the CJ newsgroup
80742>>>>>>>        // and this was the suggested workaround.
80742>>>>>>>        Set ComAutoApplyNewThreads to False
80743>>>>>>>
80743>>>>>>>        Send OnAddVDFWindowClasses
80744>>>>>>>        Send OnAddCustomWindowClasses
80745>>>>>>>        
80745>>>>>>>        // if preferences are used, it will set psSkinFile and psSkinIni
80745>>>>>>>        If (pbLoadPreference(Self)) Begin
80747>>>>>>>            Send LoadSkinPreference
80748>>>>>>>        End
80748>>>>>>>>
80748>>>>>>>        // if a skin file name exists, we apply the skin.    
80748>>>>>>>        If (psSkinFile(Self)<>"") Begin
80750>>>>>>>            Send ApplySkin
80751>>>>>>>        End        
80751>>>>>>>>
80751>>>>>>>    End_Procedure
80752>>>>>>>    
80752>>>>>>>    // called by framework as part of application exit.
80752>>>>>>>    Procedure Broadcast_Notify_Exit_Application
80754>>>>>>>        Send Notify_Exit_Application
80755>>>>>>>    End_Procedure // Notify_Exit_Application
80756>>>>>>>
80756>>>>>>>    Procedure Notify_Exit_Application
80758>>>>>>>        If (pbLoadPreference(Self)) Begin
80760>>>>>>>            Send SaveSkinPreference
80761>>>>>>>        End
80761>>>>>>>>
80761>>>>>>>    End_Procedure
80762>>>>>>>
80762>>>>>>>    Procedure NotifyPreApplySkin
80764>>>>>>>        Broadcast Send OnPreApplySkin of Desktop True       
80766>>>>>>>    End_Procedure
80767>>>>>>>
80767>>>>>>>    Procedure NotifyPostApplySkin
80769>>>>>>>        Broadcast Send OnPostApplySkin of Desktop True       
80771>>>>>>>    End_Procedure
80772>>>>>>>    
80772>>>>>>>    // returns an array of all skins in the path. If path is "", use the default path.
80772>>>>>>>    // If the default path is used, returns the file names as relative names, else use full path.
80772>>>>>>>    Function EnumerateSkins String sPath Boolean bRecursive Returns tSkinInformation[]
80774>>>>>>>        tSkinInformation[] Skins
80774>>>>>>>        tSkinInformation[] Skins
80775>>>>>>>        String sSkinName sSkinFile sDefaultPath sSep
80775>>>>>>>        Variant vSkinDescriptions vSkinDescription vSkinIniFile
80775>>>>>>>        Handle hSkinDescriptions hSkinDescription hSkinIniFile
80775>>>>>>>        Integer iSkinsCount iSkinFilesCount iNumSkins iNumSkinFiles iArrayItem
80775>>>>>>>        Integer iPos iDfltLen
80775>>>>>>>        Boolean bUseRelativePath
80775>>>>>>>        
80775>>>>>>>        Move (SysConf(SYSCONF_DIR_SEPARATOR)) to sSep
80776>>>>>>>        
80776>>>>>>>        Get SkinPath to sDefaultPath
80777>>>>>>>        If (sPath="") Begin
80779>>>>>>>            Move sDefaultPath to sPath
80780>>>>>>>        End
80780>>>>>>>>
80780>>>>>>>        Move (Uppercase(sDefaultPath)) to sDefaultPath
80781>>>>>>>        Move (Length(sDefaultPath)) to iDfltLen
80782>>>>>>>        Move (sDefaultPath=Uppercase(sPath)) to bUseRelativePath
80783>>>>>>>
80783>>>>>>>        Get ComEnumerateSkinDirectory sPath bRecursive to vSkinDescriptions
80784>>>>>>>        If (not(IsNullComObject(vSkinDescriptions))) Begin
80786>>>>>>>
80786>>>>>>>            Get Create U_cCJSkinDescriptions to hSkinDescriptions
80787>>>>>>>            Get Create U_cCJSkinDescription to hSkinDescription
80788>>>>>>>            Get Create U_cCJSkinIniFile to hSkinIniFile
80789>>>>>>>            
80789>>>>>>>            Set pvComObject of hSkinDescriptions to vSkinDescriptions
80790>>>>>>>            Get ComCount of hSkinDescriptions to iNumSkinFiles
80791>>>>>>>            
80791>>>>>>>            For iSkinFilesCount from 0 to (iNumSkinFiles-1)
80797>>>>>>>>
80797>>>>>>>                Get ComSkin of hSkinDescriptions iSkinFilesCount to vSkinDescription
80798>>>>>>>                Set pvComObject of hSkinDescription to vSkinDescription
80799>>>>>>>
80799>>>>>>>                Get ComCount of hSkinDescription to iNumSkins
80800>>>>>>>                    
80800>>>>>>>                For iSkinsCount from 0 to (iNumSkins-1)
80806>>>>>>>>
80806>>>>>>>                    Get ComIniFile of hSkinDescription iSkinsCount to vSkinIniFile
80807>>>>>>>                    Set pvComObject of hSkinIniFile to vSkinIniFile
80808>>>>>>>
80808>>>>>>>                    Get ComName of hSkinDescription to Skins[iArrayItem].sName
80809>>>>>>>                    Get ComPath of hSkinDescription to sSkinFile
80810>>>>>>>                    If bUseRelativePath Begin
80812>>>>>>>                        Move (pos(sDefaultPath,uppercase(sSkinFile))) to iPos
80813>>>>>>>                        If iPos Begin
80815>>>>>>>                            Move (Remove(sSkinFile,iPos,iDfltLen)) to sSkinFile   
80816>>>>>>>                            While (Left(sSkinFile,1)=sSep)
80820>>>>>>>                                Move (Remove(sSkinFile,1,1)) to sSkinFile   
80821>>>>>>>                            Loop                         
80822>>>>>>>>
80822>>>>>>>                        End
80822>>>>>>>>
80822>>>>>>>                    End
80822>>>>>>>>
80822>>>>>>>                    Move sSkinFile to Skins[iArrayItem].sSkinfile
80823>>>>>>>                    Get ComIniFileName of hSkinIniFile to Skins[iArrayItem].sSkinIni
80824>>>>>>>
80824>>>>>>>                    Increment iArrayItem
80825>>>>>>>                Loop
80826>>>>>>>>
80826>>>>>>>            Loop
80827>>>>>>>>
80827>>>>>>>                            
80827>>>>>>>            Send Destroy of hSkinDescriptions
80828>>>>>>>            Send Destroy of hSkinDescription
80829>>>>>>>            Send Destroy of hSkinIniFile
80830>>>>>>>                
80830>>>>>>>        End
80830>>>>>>>>
80830>>>>>>>        Function_Return Skins
80831>>>>>>>    End_Function 
