89800>>>    // Returns the integer number for the passed Driver ID that is 
89800>>>    // needed by some database API calls.
89800>>>    Function DriverIndex String sDriverID Returns Integer
89802>>>        String  sCurrentDriver
89802>>>        Integer iNumberOfDrivers iDriver iCount
89802>>>    
89802>>>        Move 0 to iDriver
89803>>>    
89803>>>        Get_Attribute DF_NUMBER_DRIVERS to iNumberOfDrivers
89806>>>        for iCount from 1 to iNumberOfDrivers
89812>>>>
89812>>>    
89812>>>            Get_Attribute DF_DRIVER_NAME of iCount to sCurrentDriver
89815>>>            If ( Uppercase(sCurrentDriver) = Uppercase(sDriverID) ) Begin
89817>>>                Move iCount to iDriver
89818>>>            End
89818>>>>
89818>>>        Loop
89819>>>>
89819>>>        
89819>>>        // In case it was not found, it wasn't loaded so we do that now.
89819>>>        If (iDriver = 0) Begin
89821>>>            Move False to Err
89822>>>            Load_Driver sDriverID
89823>>>            If (Err = False) Begin
89825>>>                Move 1 to iDriver
89826>>>            End
89826>>>>
89826>>>        End
89826>>>>
89826>>>    
89826>>>        Function_Return iDriver
89827>>>    End_Function 
89828>>>    
89828>>>    // Scans to see if all tables can be opened exclusivly. I.e. that nobody else is running the application.
89828>>>    // Returns: False if nobody else is running
89828>>>    //          True if at least one table is open by another process (e.g. another user is running the application) 
89828>>>    // N.B! Only works for Embedded DataFlex Tables! It will _not_ work for Sql tables because; these
89828>>>    //      tables are not locked as DataFlex tables are.
89828>>>    Function IsDatabaseInUse Returns Boolean
89830>>>        Handle  hTable
89830>>>        Integer iTemp
89830>>>        String  sRootName sOrgOpenPath sOrgFileList
89830>>>        Boolean bOpen bErr bAlias bOK bIsSQLTable
89830>>>
89830>>>        Get AutoConnectionIDLogin to bOK
89831>>>        Move 0 to hTable
89832>>>        Get_Attribute DF_FILE_NEXT_USED of hTable to hTable
89835>>>        Move False to bErr
89836>>>        Send Ignore_Error of Error_Object_Id DFERR_FILE_ACCESS_VIOLATION
89837>>>
89837>>>        Repeat
89837>>>>
89837>>>            Get_Attribute DF_FILE_ROOT_NAME of hTable to sRootName
89840>>>            
89840>>>            // This test is only applicable for DataFlex embedded tables; so skip test if driver based table.
89840>>>            Get UtilTableIsSQLByRootName sRootName to bIsSQLTable
89841>>>            Move False to bOpen
89842>>>            
89842>>>            // Don't bother about FlexErrs (Table 50)
89842>>>            If (bIsSQLTable = False and hTable <> 0 and hTable <> 50) Begin
89844>>>                Set Error_Report_Mode to DUF_ERROR_NO_REPORT
89845>>>                Open hTable 
89847>>>                Get_Attribute DF_FILE_OPENED of hTable to bOpen
89850>>>                Set Error_Report_Mode to DUF_ERROR_REPORT
89851>>>                If (bOpen = True) Begin                        
89853>>>                    // We cannot open an Alias file exclusive as it will generate an error (4177 - "File in use")
89853>>>                    Get UtilTableIsAlias hTable to bAlias
89854>>>                    If (bAlias = False) Begin
89856>>>                        Open hTable mode DF_EXCLUSIVE   
89858>>>                        Get_Attribute DF_FILE_OPENED of hTable to bOpen
89861>>>                        If (bOpen = False) Begin
89863>>>                            Move True to bErr
89864>>>                        End
89864>>>>
89864>>>                    End
89864>>>>
89864>>>                End
89864>>>>
89864>>>            End
89864>>>>
89864>>>            Get_Attribute DF_FILE_NEXT_USED of hTable to hTable
89867>>>            If (bOpen = False) Break
89870>>>        Until (not(hTable))
89872>>>
89872>>>        Send Trap_Error of Error_Object_Id DFERR_FILE_ACCESS_VIOLATION
89873>>>        Move False to Err
89874>>>        
89874>>>        Function_Return bErr
89875>>>    End_Function  
89876>>>    
89876>>>    // Checks if the passed connection id exists in the CLI interface.
89876>>>    // This might be needed by API-methods when a connection id is to be used and
89876>>>    // the connection id hasn't been established with the driver's CLI interface.
89876>>>    // NOTE: Only applicable for DAW drivers.
89876>>>    Function IsConnectionID String sConnectionID String sDriverID Returns Boolean
89878>>>        String sID 
89878>>>        Integer iDriver iNumConn iCount
89878>>>        Handle hoCLI                                            
89878>>>        Boolean bOK
89878>>>        
89878>>>        Get IsDAWSQLDriver sDriverID to bOK
89879>>>        If (bOK = False) Begin
89881>>>            Error DFERR_PROGRAM "Connection ID's can only be used with DAW drivers (not Mertech)."
89882>>>>
89882>>>            Function_Return False
89883>>>        End
89883>>>>
89883>>>        
89883>>>        Move False to bOK
89884>>>        Get phoCLIHandler to hoCLI 
89885>>>        If (hoCLI <> 0) Begin
89887>>>            Set psDriverID of hoCLI to sDriverID
89888>>>            Get DriverIndex of hoCLI sDriverID to iDriver
89889>>>            
89889>>>            // If driver not loaded; load it.
89889>>>            If (iDriver = 0) Begin
89891>>>                Load_Driver sDriverID
89892>>>                Get DriverIndex sDriverID to iDriver
89893>>>            End                      
89893>>>>
89893>>>            If (iDriver <> 0) Begin
89895>>>                Get_Attribute DF_DRIVER_NUMBER_CONNECTION_IDS of iDriver to iNumConn
89898>>>                Decrement iNumConn
89899>>>                For iCount from 0 to iNumConn
89905>>>>
89905>>>                    Get_Attribute DF_DRIVER_CONNECTION_ID of iDriver iCount to sID
89908>>>                    If (sID = sConnectionID) Move True to bOK
89911>>>                Loop
89912>>>>
89912>>>            End
89912>>>>
89912>>>        End
89912>>>>
89912>>>        
89912>>>        Function_Return bOK
89913>>>    End_Function                   
89914>>>    
89914>>>    Function IsDAWSQLDriver String sDriverID Returns Boolean
89916>>>        Boolean bOK
89916>>>        Move (sDriverID = MSSQLDRV_ID or sDriverID = DB2_DRV_ID or sDriverID = ODBC_DRV_ID) to bOK
89917>>>        Function_Return bOK
89918>>>    End_Function
89919>>>
89919>>>    Function IsMertechDriver String sDriverID Returns Boolean
89921>>>        Boolean bOK
89921>>>        Move False to bOK
89922>>>        Move (sDriverID = SQLFLEX or sDriverID = ORAFLEX or sDriverID = MDSPgSQL or sDriverID = MDSMySQL) to bOK
89923>>>        Function_Return bOK
89924>>>    End_Function
89925>>>            
