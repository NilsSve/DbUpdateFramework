84046>>>        
84046>>>        Get piDbType to iDbType
84047>>>        Get _SqlFindKeyWord CI_SQLDropTable iDbType to sDropTable 
84048>>>        Get psSchema to sSchema
84049>>>        If (sSchema = "") Begin
84051>>>            Get _SqlFindKeyWord CI_SQLDBO to sSchema 
84052>>>        End
84052>>>>
84052>>>        Move (Uppercase(sTableName)) to sVal
84053>>>        If (not(sVal contains (sSchema + "."))) Begin    
84055>>>            Move (Lowercase(sSchema) + "." + sTableName) to sTableName
84056>>>        End    
84056>>>>
84056>>>        Move (sDropTable * String(sTableName)) to sSQLString
84057>>>        
84057>>>        Move False to Err               
84058>>>        Send SqlUtilExecuteQuery sSQLString sDriverID
84059>>>    
84059>>>        // We also need to remove the cache-file since the table has been changed
84059>>>        Get UtilDeleteCacheFile sTableName to bOK
84060>>>    
84060>>>        Function_Return (Err = False)
84061>>>    End_Function 
84062>>>
84062>>>    // *** Sql View Messages ***
84062>>>
84062>>>    // First deletes the data cache file and then drops the passed Sql data view. 
84062>>>    Function SqlViewRemove String sDataView Returns Boolean
84064>>>        String sDriverID sSQLString sPath sDropViewKeyWord 
84064>>>        Integer iRetval                                
84064>>>        Boolean bMertechDriver bOK
84064>>>        
84064>>>        Get psDriverID to sDriverID
84065>>>        Get IsMertechDriver sDriverID to bMertechDriver
84066>>>        Get UtilDeleteCacheFile sDataView to iRetval
84067>>>        
84067>>>        Get _SqlFindKeyWord CI_SQLDropView to sDropViewKeyWord
84068>>>        Move (sDropViewKeyWord * String(sDataView)) to sSQLString
84069>>>        Set psSQLStatementString to sSQLString 
84070>>>        
84070>>>        // As we don't check if the view exist or not, it might happen
84070>>>        // that it doesn't and that would through an error, so guard for that eventuality (just ignore it).
84070>>>        Move False to Err 
84071>>>        Set Error_Report_Mode to DUF_ERROR_NO_REPORT
84072>>>        Send SqlUtilExecuteQuery sSQLString sDriverID
84073>>>        Set Error_Report_Mode to DUF_ERROR_REPORT
84074>>>        Move 0 to LastErr
84075>>>        
84075>>>        // We also need to remove the cache-file since the table has been changed
84075>>>        Get UtilDeleteCacheFile sDataView to bOK
84076>>>    
84076>>>        Function_Return (Err = False)
84077>>>    End_Function
84078>>>    
84078>>>    // *** Sql Column Messages ***
84078>>>    //
84078>>>    // Sample: Get SqlColumnAdd MyTable.File_Number "NewColumnName" True "InitValue" DF_ASCII 35  
84078>>>    Function SqlColumnAdd Integer hTable String sColumnName Integer iDataType Integer iLen Integer iDec Boolean bInitVal String sColVal Returns Boolean
84080>>>        Integer iColumn iDbType iLength iDecimals
84080>>>        String sStmt sAlterTable sAddColumn sModifyColumn sVal sDataType sLengthAndDecimals sColumnValue
84080>>>        String sTableName sDriverID sUpdate sSet sNoCountOn
84080>>>        Boolean bExists bOK bInitializeValue 
84080>>>        
84080>>>        Get psDriverID to sDriverID
84081>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
84082>>>        If (bOK = False) Begin   
84084>>>            Function_Return False
84085>>>        End              
84085>>>>
84085>>>        
84085>>>        Get UtilTableHandleToString hTable to sTableName
84086>>>        If (sTableName = "") Begin
84088>>>            Function_Return False    
84089>>>        End  
84089>>>>
84089>>>        
84089>>>        If (num_arguments > 4) Begin
84091>>>            Move iDec     to iDecimals
84092>>>            Move bInitVal to bInitializeValue                                      
84093>>>            Move sColVal  to sColumnValue
84094>>>        End                       
84094>>>>
84094>>>        
84094>>>        Get SqlColumnAddByTableName sTableName sColumnName iDataType iLen iDecimals bInitializeValue sColumnValue to bOK
84095>>>        
84095>>>        Function_Return (bOK = True)    
84096>>>    End_Function  
84097>>>    
84097>>>    // Sample: Get SqlColumnAddByTableName "MyTable" "NewColumnName" DF_ASCII 35 0 True "InitValue" 
84097>>>    Function SqlColumnAddByTableName String sTableName String sColumnName Integer iDataType Integer iLen Integer iDec Boolean bInitVal String sColVal Returns Boolean
84099>>>        Integer iColumn iDbType iLength iDecimals iDriver
84099>>>        String sStmt sAlterTable sAddColumn sModifyColumn sVal sDataType sLengthAndDecimals sColumnValue
84099>>>        String sDriverID sUpdate sSet sNoCountOn sNotNull
84099>>>        Boolean bExists bOK bInitializeValue bRetval bFixed bDriverIgnoreErrorState
84099>>>        Handle hTable 
84099>>>        
84099>>>        Get psDriverID to sDriverID
84100>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
84101>>>        If (bOK = False) Begin   
84103>>>            Function_Return False
84104>>>        End              
84104>>>>
84104>>>        
84104>>>        Get UtilTableNameToHandle sTableName to hTable
84105>>>        If (hTable = 0) Begin
84107>>>            Get NextFreeFilelistSlot to hTable
84108>>>        End
84108>>>>
84108>>>        
84108>>>        Get piDbType to iDbType
84109>>>        // If a field/column already exists; we just ignore the request to not add unneccesary errors to the log.
84109>>>        Get _SqlFindColumnName sTableName sColumnName to sVal
84110>>>        If (Uppercase(sVal) = Uppercase(sColumnName)) Begin
84112>>>            Function_Return False
84113>>>        End
84113>>>>
84113>>>
84113>>>        Get DriverIndex sDriverID to iDriver
84114>>>        Get_Attribute DF_DRIVER_IGNORE_WARNINGS of iDriver to bDriverIgnoreErrorState
84117>>>        Set_Attribute DF_DRIVER_IGNORE_WARNINGS of iDriver to True
84120>>>
84120>>>        Get UtilColumnTypeToString sDriverID iDbType iDataType to sDataType
84121>>>        Move iLen to iLength
84122>>>        Move iDec to iDecimals                           
84123>>>        If (num_arguments > 6) Begin
84125>>>            Move bInitVal to bInitializeValue
84126>>>            Move sColVal  to sColumnValue
84127>>>        End
84127>>>>
84127>>>        
84127>>>        Get _SqlProperTableName sTableName   to sTableName
84128>>>        Get _SqlFindKeyWord CI_SQLAlterTable to sAlterTable
84129>>>        Get _SqlFindKeyWord CI_SQLAdd        to sAddColumn
84130>>>        Get SQLUtilDefaultNullValue sDriverID iDbType iDataType to sNotNull
84131>>>        
84131>>>        Get UtilColumnTypeFixed sDriverID iDbType iDataType to bFixed
84132>>>        If (bFixed = False) Begin
84134>>>            Get _SqlFormatLengthAndDecimalAsString iLength iDecimals to sLengthAndDecimals
84135>>>        End
84135>>>>
84135>>>        Move (sAlterTable * sTableName * sAddColumn * sColumnName * sDataType + sLengthAndDecimals * sNotNull) to sStmt 
84136>>>        
84136>>>        Move False to Err              
84137>>>        Send SqlUtilExecuteQuery sStmt sDriverID 
84138>>>        
84138>>>        If (bInitializeValue = True and Err = False) Begin
84140>>>            Get _SqlFindKeyWord CI_SQLUpdate       to sUpdate
84141>>>            Get _SqlFindKeyWord CI_SQLSet          to sSet
84142>>>            Get _SqlFindKeyWord CI_SQLSetNoCountOn to sNoCountOn
84143>>>            Move (sNoCountOn * sUpdate * sTableName * sSet * sColumnName + "='" + sColumnValue + "'") to sStmt
84144>>>            Send SqlUtilExecuteQuery sStmt sDriverID
84145>>>        End
84145>>>>
84145>>>
84145>>>        If (Err = False) Begin
84147>>>            Get SqlUtilAdjustAuxFiles hTable sTableName sColumnName to bOK
84148>>>        End
84148>>>>
84148>>>        
84148>>>        Move (not(Err)) to bRetval 
84149>>>        
84149>>>        // We also need to remove the cache-file since the table has been changed
84149>>>        Get UtilDeleteCacheFile sTableName to bOK
84150>>>        Set_Attribute DF_DRIVER_IGNORE_WARNINGS of iDriver to bDriverIgnoreErrorState
84153>>>    
84153>>>        Function_Return bRetval
84154>>>    End_Function  
