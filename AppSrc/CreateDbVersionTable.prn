87456>>>        String sColumn sDriverID
87456>>>        Integer iType iLength iPrecision
87456>>>        Boolean bOK
87456>>>        
87456>>>        Get_Attribute DF_FILE_DRIVER of hTable to sDriverID
87459>>>        If (sDriverID = DFBTRDRV_ID) Begin
