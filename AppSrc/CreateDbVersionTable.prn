86730>>>            Move CS_OEM_Txt to sANSI_OEM
86731>>>        End                                       
86731>>>>
86731>>>        
86731>>>        Get IsDAWSQLDriver sDriverID to bDAWDriver
86732>>>        // Mertech drivers don't use Connection ID's; so if bUseConnectionID was
86732>>>        // passed as True, we adjust for that here.
86732>>>        Get IsMertechDriver sDriverID to bMertechDriver
86733>>>        If (bMertechDriver = True and bUseConnectionID = True) Begin
86735>>>            Move False to bUseConnectionID
86736>>>        End  
86736>>>>
86736>>>
86736>>>        Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection  
86737>>>        Move SQLConnection.sSchema           to sSchema
86738>>>        If (sSchema = "") Begin
86740>>>            Get _SqlFindKeyWord CI_SQLDBO    to sSchema  
