82868>>>>>        //       and one for the "to" database??
82868>>>>>        Set Private.pSQLConnection to SQLConnection
82869>>>>>    End_Procedure    
82870>>>>>    
82870>>>>>    // *** Properties ***
82870>>>>>    // All connection related "properties" (get/set pairs) are really done by changing the
82870>>>>>    // private.pSQLConnection struct connection property. These "properties" are 
82870>>>>>    // merely here for conveniance.
82870>>>>>    //           
82870>>>>>    // The pSQLConnection get/set are here so we have a "central hub"
82870>>>>>    // where we update data to/from the DAW & Mertech driver interfaces and this framework.
82870>>>>>    // This struct property contains all the connection data.
82870>>>>>    //
82870>>>>>    Procedure Set pSQLConnection tSQLConnection SQLConnection
82872>>>>>        Boolean bIsDaw bIsMertech bOK
82872>>>>>        
82872>>>>>        Set Private.pSQLConnection to SQLConnection 
82873>>>>>        
82873>>>>>        // When starting a program we might not have a connection id yet:
82873>>>>>        If (SQLConnection.sConnectionID = "" or SQLConnection.sDriverID = DATAFLEX_ID) Begin
82875>>>>>            Procedure_Return
82876>>>>>        End                 
82876>>>>>>
82876>>>>>        
82876>>>>>        // After we have set the class property we need to tell the DAW/Mertech
82876>>>>>        // driver interfaces about the change & make a new login.
82876>>>>>        Get SQLLogin SQLConnection to bOK
82877>>>>>        If (bOK = False) Begin
82879>>>>>            Error DFERR_PROGRAM "Login error."       
82880>>>>>>
82880>>>>>        End 
82880>>>>>>
82880>>>>>        
82880>>>>>        // Now is the time to setup our driver default values by reading the driver .int file:
82880>>>>>        Send SetupDriverDefaults SQLConnection.sDriverID
82881>>>>>        
82881>>>>>    End_Procedure                 
82882>>>>>    
82882>>>>>    // Similar to _SqlCheckCurrentDriver but generates no error and it doesn't 
