83166>>>>>    // ************************************        
83166>>>>>    Function SetupSQLConnection Boolean bReadSettings Returns tSQLConnection
83168>>>>>        tSQLConnection SQLConnection 
83168>>>>>        tSQLConnection SQLConnection 
83168>>>>>        
83168>>>>>        // If this object was created by the cDbUpdateHandler class we will
83168>>>>>        // deferr reading SQL connection values until later.
83168>>>>>        If (bReadSettings = True) Begin
83170>>>>>            // This is the new SQL login logic for DF 19 and up; "Managed Connections"
83170>>>>>            If (ghoConnection > 0) Begin
83172>>>>>                Get ReadcConnections to SQLConnection
83173>>>>>            End
83173>>>>>>
83173>>>>>            
83173>>>>>            // In addition to the above; there might be other values set even if a cConnection
83173>>>>>            // object is used.
83173>>>>>            Get ReadSQLConnectionsIniSettings to SQLConnection
83174>>>>>        End     
83174>>>>>>
83174>>>>>        
83174>>>>>        Function_Return SQLConnection
83175>>>>>    End_Function
83176>>>>>    
83176>>>>>    // This is for the new cConnection class used by DF 19 and up (only).
83176>>>>>    Function ReadcConnections Returns tSQLConnection
83178>>>>>        tConnection Connection                 
83178>>>>>        tConnection Connection                 
83178>>>>>        tSQLConnection SQLConnection SQLConnectionEmpty
83178>>>>>        tSQLConnection SQLConnection SQLConnectionEmpty
83178>>>>>        Integer iCount iSize iRetval iDbType
83178>>>>>        Boolean bOK bEnabled bConnected bVal
83178>>>>>        String sConnectionID sSchema
83178>>>>>        
83178>>>>>            // - If the DF 19 cConnection class has been used in the cApplication object
83178>>>>>            // - and there are multiple connection id's defined for the same driver. This is
83178>>>>>            //   because otherwise we can't possibly know which connection id to use... So
83178>>>>>            //   we then generate an error and abort the program...
83178>>>>>            Get IsSinglecConnection (&sConnectionID) to bOK                                     
83179>>>>>            If (bOK = False) Begin
83181>>>>>                Error DFERR_PROGRAM ("Programming error. The psConnectionID must be set in the cDbUpdateVersion object when a cConnect object is used in the cApplication object, and there are multiple connections defined. Program will now exit!")
83182>>>>>>
83182>>>>>                Abort
83183>>>>>>
83183>>>>>            End  
83183>>>>>>
83183>>>>>            
83183>>>>>            Move 0 to iRetval
83184>>>>>            // DAW DF19 connection info: 
83184>>>>>            // We first check that the connection is OK:  
83184>>>>>            Get ConnectionIdIndex of ghoConnection sConnectionID to iRetval
83185>>>>>            // It might happen that no connection has been setup although the object exists, in case we do nothing.
83185>>>>>            If (iRetval = -1) Begin
83187>>>>>                Function_Return SQLConnectionEmpty
83188>>>>>            End                                 
83188>>>>>>
83188>>>>>
83188>>>>>            If (sConnectionID <> "") Begin
83190>>>>>                Get ConnectionIdInfo of ghoConnection sConnectionID to Connection  
83191>>>>>            End
83191>>>>>>
83191>>>>>            If (Connection.sId = "") Begin
83193>>>>>                Move True to SQLConnectionEmpty.bError
83194>>>>>                Function_Return SQLConnectionEmpty
83195>>>>>            End
83195>>>>>>
83195>>>>>            
83195>>>>>            Move Connection.sId to sConnectionID  
83196>>>>>            Get IsConnectionIdLoggedIn of ghoConnection sConnectionID to bConnected
83197>>>>>    
83197>>>>>            If (bConnected = False) Begin
83199>>>>>                Get LoginConnectionId of ghoConnection to iRetval    
83200>>>>>                If (iRetval <> 0) Begin 
83202>>>>>                    Send UserError CS_DUF_CannotLoginToServer
83203>>>>>                    Send Exit_Application    
83204>>>>>                End
83204>>>>>>
83204>>>>>            End
83204>>>>>>
83204>>>>>            
83204>>>>>            // DUF connection info struct property:
83204>>>>>            Get Private.pSQLConnection                       to SQLConnection   
83205>>>>>            Move True                                        to SQLConnection.bEnabled
83206>>>>>            Move Connection.bTrustedConnection               to SQLConnection.bTrusted
83207>>>>>    
83207>>>>>            // Not used in DUF:
83207>>>>>            // Move Connection.iDriverIndex                    to SQLConnection.iDriverIndex
83207>>>>>    
83207>>>>>            Move (If(Connection.iOptions = 0, False, True))  to SQLConnection.bSilentLogin
83208>>>>>            Move Connection.sConnectionString                to SQLConnection.sConnectionString
83209>>>>>            Move Connection.sDriver                          to SQLConnection.sDriverID
83210>>>>>            Move Connection.sId                              to SQLConnection.sConnectionID
83211>>>>>            Move Connection.sUID                             to SQLConnection.sUserID
83212>>>>>            Move Connection.sPWD                             to SQLConnection.sPassword
83213>>>>>    
83213>>>>>            // Not used in DUF:
83213>>>>>            // Move Connection.sSection to SQLConnection.xxx
83213>>>>>            
83213>>>>>            // The rest of the properties of the SQLConnection struct should have been
83213>>>>>            // setup in the cDbUpdateHandler object, and we should be able to reach them through delegation:
83213>>>>>            If (Connection.sDriver <> ODBC_DRV_ID) Begin
83215>>>>>                Get ParseKeyWord Connection.sString CS_SQLIniServerKeyword to SQLConnection.sServer
83216>>>>>            End
83216>>>>>>
83216>>>>>            If (Connection.sDriver = ODBC_DRV_ID) Begin
83218>>>>>                Get ParseKeyWord Connection.sString CS_SQLIniDSNKeyword    to SQLConnection.sServer
83219>>>>>            End
83219>>>>>>
83219>>>>>            Get ParseKeyWord Connection.sString CS_SQLIniDatabaseKeyword   to SQLConnection.sDatabase  
83220>>>>>            
83220>>>>>            // The DbType is a bit special. If the piDbType has _not_ been setup in object code we try to derave
83220>>>>>            // the value from the driver id:
83220>>>>>            Get SqlUtilDbTypeFromDriver of (phoSQLConnectionIniFile(Self)) Connection.sDriver to SQLConnection.iDbType
83221>>>>>            // ...but in case it has been explicitly set in the object we use that value.
83221>>>>>            Get piDbType                                     to iDbType
83222>>>>>            If (iDbType <> SQLConnection.iDbType) Begin
83224>>>>>                Move iDbType to SQLConnection.iDbType
83225>>>>>            End
83225>>>>>>
83225>>>>>            Get psBaseTableSpace                             to SQLConnection.sBaseTableSpace
83226>>>>>            Get psLongTableSpace                             to SQLConnection.sLongTableSpace
83227>>>>>            Get psIndexTableSpace                            to SQLConnection.sIndexTableSpace
83228>>>>>            Get psSchema                                     to SQLConnection.sSchema
83229>>>>>            
83229>>>>>            // We finally set the struct property to the newly fetched values.
83229>>>>>            Set pSQLConnection to SQLConnection
83230>>>>>        
83230>>>>>        Function_Return SQLConnection
83231>>>>>    End_Function
83232>>>>>    
83232>>>>>    // Returns True if the psConnectionID has been set in the cDbUpateHandler object,
83232>>>>>    // or the DAW cConnect array of registered connection only contains one active/enabled
83232>>>>>    // connection id for a particular driver.
83232>>>>>    // So either the psConnectionID or the psDriverID can have been set in the cDbUpdateHandler
83232>>>>>    // object. We can then match a connection id from the DAW cConnect class array.
83232>>>>>    // Returns False if there are multiple connections that are enabled or the psConnectionID has
83232>>>>>    // been set in the cDbUpdateHandler object but it cannot be found amongst the registered 
83232>>>>>    // connections of the DAW cConnect class.
83232>>>>>    Function IsSinglecConnection String ByRef sConnectionID Returns Boolean
83234>>>>>        tConnection[] ConnIdArray
83234>>>>>        tConnection[] ConnIdArray
83235>>>>>        Integer iCount iSize iConnectionIDCounter
83235>>>>>        Boolean bOK bEnabled bFound
83235>>>>>        String sConnectionID2 sDriverID sDriverConn
83235>>>>>        
83235>>>>>        Move False to bFound
83236>>>>>        If (ghoConnection > 0) Begin           
83238>>>>>            
83238>>>>>            // The property of the cDbUpdateHandler container object
83238>>>>>            Get psDriverID to sDriverID
83239>>>>>            
83239>>>>>            Move 0 to iConnectionIDCounter 
83240>>>>>            // This is the the DAW cConnect array with all registered connection id's.
83240>>>>>                Get ConnectionIDs of ghoConnection to ConnIdArray
83241>>>>>            Move (SizeOfArray(ConnIdArray)) to iSize
83242>>>>>            Decrement iSize
83243>>>>>            For iCount from 0 to iSize
83249>>>>>>
83249>>>>>                Move ConnIdArray[iCount].sDriver to sDriverConn
83250>>>>>                Move ConnIdArray[iCount].sId to sConnectionID2
83251>>>>>                Move (ConnIdArray[iCount].bDisabled = False) to bEnabled    
83252>>>>>                // If no psConnectionID specified in the cDbUpdateHandler, we check if there is a driver
83252>>>>>                // connection in the DAW cConnect object _and_ that there is only one!
83252>>>>>                If (sConnectionID = "") Begin
83254>>>>>                    Move (sDriverID = sDriverConn and bEnabled = True) to bFound 
83255>>>>>                End 
83255>>>>>>
83255>>>>>                Else Begin
83256>>>>>                    If (Uppercase(sConnectionID) = Uppercase(sConnectionID2)) Begin
83258>>>>>                        Move iSize to iCount // Then we've found what we were looking for and we're out of here... 
83259>>>>>                    End
83259>>>>>>
83259>>>>>                End
83259>>>>>>
83259>>>>>                    
83259>>>>>                If (bFound = True) Begin
83261>>>>>                    Increment iConnectionIDCounter
83262>>>>>                End
83262>>>>>>
83262>>>>>            Loop
83263>>>>>>
83263>>>>>            Move (iConnectionIDCounter <= 1 and sDriverConn <> "" and sConnectionID2 <> "") to bFound 
83264>>>>>            If (bFound = True) Begin
83266>>>>>                Move sConnectionID2 to sConnectionID
83267>>>>>            End
83267>>>>>>
83267>>>>>        End 
83267>>>>>>
83267>>>>>        
83267>>>>>        // Special case; a cConnection object has been setup in the cApplication,
83267>>>>>        // but no DFConn.ini record has been created.
83267>>>>>        If (iSize = -1) Begin
83269>>>>>            Move True to bFound
83270>>>>>        End
83270>>>>>>
83270>>>>>            
83270>>>>>        Function_Return bFound
83271>>>>>    End_Function
83272>>>>>    
83272>>>>>    // Send on object creation to read the default connection string settings, and
83272>>>>>    // create a connection to the server.
83272>>>>>    Function ReadSQLConnectionsIniSettings Returns tSQLConnection
83274>>>>>        String sPath sFileName sSection sConnectionString sPassword 
83274>>>>>        Boolean bExists
83274>>>>>        tSQLConnection[] SQLConnectionArray
83274>>>>>        tSQLConnection[] SQLConnectionArray
83275>>>>>        tSQLConnection SQLConnection SQLConnectionEmpty
83275>>>>>        tSQLConnection SQLConnection SQLConnectionEmpty
83275>>>>>        Handle hoIniFile
83275>>>>>        Integer iSize iCount
83275>>>>>        
83275>>>>>        Get psIniFilePath to sPath
83276>>>>>        Get phoSQLConnectionIniFile to hoIniFile
83277>>>>>        If (sPath = "") Begin
83279>>>>>            Get ApplicationPath of hoIniFile to sPath 
83280>>>>>            Set psIniFilePath   of hoIniFile to sPath 
83281>>>>>        End         
83281>>>>>>
83281>>>>>        Get vFolderFormat sPath to sPath
83282>>>>>        Get psIniFileName to sFileName    
83283>>>>>        Get vFilePathExists (sPath + sFileName) to bExists
83284>>>>>//        If (bExists = False) Begin   
83284>>>>>//            Move True to SQLConnection.bError
83284>>>>>//            Function_Return SQLConnectionEmpty 
83284>>>>>//        End                                                         
83284>>>>>        
83284>>>>>        Get SQLIniFileReadConnections of hoIniFile to SQLConnectionArray
83285>>>>>        Move (SizeOfArray(SQLConnectionArray)) to iSize
83286>>>>>        If (iSize = 0) Begin
83288>>>>>            // This may have been set by the "ReadcConnections" function,
83288>>>>>            // if a cConnection object has been setup for DataFlex 19 or later
83288>>>>>            // in the cApplication object.
83288>>>>>            Get pSQLConnection to SQLConnection
83289>>>>>            If (SQLConnection.sConnectionID = "") Begin
83291>>>>>                Function_Return SQLConnectionEmpty
83292>>>>>            End
83292>>>>>>
83292>>>>>            Move SQLConnection to SQLConnectionArray[0]
83293>>>>>        End
83293>>>>>>
83293>>>>>        
83293>>>>>        // The first connection should be the one that is active, but just in case...
83293>>>>>        Decrement iSize
83294>>>>>        For iCount from 0 to iSize
83300>>>>>>
83300>>>>>            Move SQLConnectionArray[iCount] to SQLConnection
83301>>>>>            If (SQLConnection.bEnabled = True) Begin
83303>>>>>                Move iSize to iCount // We've found the enabled item, so we're out of here.
83304>>>>>            End
83304>>>>>>
83304>>>>>        Loop
83305>>>>>>
83305>>>>>
83305>>>>>        Send CreateSQLConnection SQLConnection.sDriverID SQLConnection.sConnectionID ;             SQLConnection.sServer SQLConnection.sDatabase SQLConnection.bTrusted ;             SQLConnection.sUserID SQLConnection.sPassword SQLConnection.bSilentLogin   
83306>>>>>             
83306>>>>>        Set pSQLConnection to SQLConnection 
83307>>>>>        Send AutoSetConnectionID
83308>>>>>        
83308>>>>>        Function_Return SQLConnection
83309>>>>>    End_Function
83310>>>>>    
83310>>>>>    Procedure Set psIniFilePath String sPath
83312>>>>>        Set psIniFilePath of (phoSQLConnectionIniFile(Self)) to sPath
83313>>>>>    End_Procedure
83314>>>>>    
83314>>>>>    Function psIniFilePath Returns String
83316>>>>>        String sRetval
83316>>>>>        Get psIniFilePath of (phoSQLConnectionIniFile(Self)) to sRetval
83317>>>>>        Function_Return sRetval
83318>>>>>    End_Function
83319>>>>>
83319>>>>>    Procedure Set psIniFileName String sFileName
