91495>>>>>>>>>>>class HelpSystem is an cObject
91496>>>>>>>>>>>
91496>>>>>>>>>>>    register_function Help_File_Default returns string
91496>>>>>>>>>>>
91496>>>>>>>>>>>    procedure Construct_Object
91498>>>>>>>>>>>       Forward send Construct_Object
91500>>>>>>>>>>>
91500>>>>>>>>>>>       // Help file name only. If set, this overrides all other settings.
91500>>>>>>>>>>>       Property String psHelpFile
91501>>>>>>>>>>>
91501>>>>>>>>>>>       // Help_FileName
91501>>>>>>>>>>>       //   full path name of Help file. The default value grabs its value
91501>>>>>>>>>>>       //   from .ini or environment settings. See functiob Help_file_Default
91501>>>>>>>>>>>       //
91501>>>>>>>>>>>       Property String  Private.Help_Filename (Help_File_Default(self))
91502>>>>>>>>>>>
91502>>>>>>>>>>>       // The following properties are the default values for the help files
91502>>>>>>>>>>>       // IDs for the various subjects. Setting these requires an agreement
91502>>>>>>>>>>>       // between the DF help system and the help file.
91502>>>>>>>>>>>       //
91502>>>>>>>>>>>       Property Integer Help_Id_General  0
91503>>>>>>>>>>>       Property Integer Help_Id_Index    0
91504>>>>>>>>>>>       Property Integer Help_Id_Keys     0
91505>>>>>>>>>>>       Property Integer Help_Id_Files    0
91506>>>>>>>>>>>       Property Integer Help_Id_Errors   0
91507>>>>>>>>>>>
91507>>>>>>>>>>>       // this is now the default help object
91507>>>>>>>>>>>       Move self to Help_Object_id
91508>>>>>>>>>>>    End_Procedure
91509>>>>>>>>>>>
91509>>>>>>>>>>>   // New rules for VDF8:
91509>>>>>>>>>>>   // 1. If psHelpFile exists, find the file in the file path and use it
91509>>>>>>>>>>>   // 2. If application object exists and help type is windows, use psHelpFile from there, find in file path and use it.
91509>>>>>>>>>>>   // 3. If no help file exists, use thge old private help name (which gets the full name from the registry -only if no app object)
91509>>>>>>>>>>>   //    Last method is deprecated and only used for old applications
91509>>>>>>>>>>>   //
91509>>>>>>>>>>>   Function Help_filename returns string
91511>>>>>>>>>>>        string sHelpName
91511>>>>>>>>>>>        // If ghoWorkSpace Get Help_FileName of ghoWorkSpace to sHelpName // removed for VDF8
91511>>>>>>>>>>>
91511>>>>>>>>>>>        // If an Application object is used, take the name from there.
91511>>>>>>>>>>>        Get psHelpFile to sHelpName
91512>>>>>>>>>>>        If (sHelpName="" AND ghoApplication AND peHelpType(ghoApplication)=htWinHelp) Begin
91514>>>>>>>>>>>            Get psHelpFile of ghoApplication To sHelpName
91515>>>>>>>>>>>            //Move (psHelpPath(phoWorkspace(ghoApplication)) -"\" -sHelpName) To sHelpName
91515>>>>>>>>>>>        End
91515>>>>>>>>>>>>
91515>>>>>>>>>>>        If (sHelpName<>"") begin
91517>>>>>>>>>>>            Get_File_Path sHelpName To sHelpName
91518>>>>>>>>>>>            Function_Return sHelpName
91519>>>>>>>>>>>        end
91519>>>>>>>>>>>>
91519>>>>>>>>>>>        // if not set anywhere (and ideally it is) we use this.
91519>>>>>>>>>>>        Get Private.Help_FileName to sHelpName
91520>>>>>>>>>>>        Function_Return sHelpName
91521>>>>>>>>>>>    End_Function
91522>>>>>>>>>>>
91522>>>>>>>>>>>    Procedure Set Help_FileName string sName
91524>>>>>>>>>>>        Set Private.Help_FileName to sName
91525>>>>>>>>>>>    End_Procedure
91526>>>>>>>>>>>
91526>>>>>>>>>>>
91526>>>>>>>>>>>
91526>>>>>>>>>>>    // Consider this message PRIVATE in that it should only be changed
91526>>>>>>>>>>>    // by a sub-class and not an object. It is called in construct_object
91526>>>>>>>>>>>    // before it knows about object augmentations!!!!
91526>>>>>>>>>>>    //
91526>>>>>>>>>>>    //  Sets the Help_file_name by looking at the .INI file for:
91526>>>>>>>>>>>    //        HELP_DIR    - help directory (will check environment variable
91526>>>>>>>>>>>    //                      windir if not found - avoid this usage). If not
91526>>>>>>>>>>>    //                      blank append "\" as required.
91526>>>>>>>>>>>    //
91526>>>>>>>>>>>    //        HELP_FILE   - help file name. If blank uses the default help
91526>>>>>>>>>>>    //                      file name
91526>>>>>>>>>>>    //
91526>>>>>>>>>>>    Function Help_File_Default Returns String
91528>>>>>>>>>>>       String HelpFileDir HelpFileName sSubKey
91528>>>>>>>>>>>       // if using the application object we expect the help name to be
91528>>>>>>>>>>>       // defined in the application object or directly in the help object. No Exceptions
91528>>>>>>>>>>>       If (ghoApplication) function_return ""
91531>>>>>>>>>>>
91531>>>>>>>>>>>       // else if no application (and hence no WS) use an old deprecated method of checking
91531>>>>>>>>>>>       // for the module name in local_machine.
91531>>>>>>>>>>>       Get Module_name of Desktop to sSubKey
91532>>>>>>>>>>>       Get_Profile_String sSubKey HELP_DIR to HelpFileDir
91535>>>>>>>>>>>       Get_Profile_String sSubKey HELP_FILE to HelpFileName
91538>>>>>>>>>>>       // if dir exists, sure it has a "\" at the end. If no directory the
91538>>>>>>>>>>>       // dir must be blank so current directory is searched
91538>>>>>>>>>>>       If ( (HelpFileDir<>'') AND (Right(HelpFileDir,1)<>"\") ) ;          Move (HelpFileDir - '\') to HelpFileDir
91541>>>>>>>>>>>       If HelpFileName eq '' Move DEFAULT_HELP_FILENAME to HelpFileName
91544>>>>>>>>>>>       Function_Return (HelpFileDir - HelpFileName)
91545>>>>>>>>>>>    End_Function
91546>>>>>>>>>>>
91546>>>>>>>>>>>    // The System_Help_xxxx messages convert a DF help integer ID into
91546>>>>>>>>>>>    // a context value that can be used by the windows help system. If
91546>>>>>>>>>>>    // you return a number or a string. Numbers will get used for context ID
91546>>>>>>>>>>>    // help, non-numbers get used for keyword context help
91546>>>>>>>>>>>
91546>>>>>>>>>>>    // By default return ID passed. This creates a direct mapping between
91546>>>>>>>>>>>    // context IDs in your object and the context IDs in windows help.
91546>>>>>>>>>>>    //
91546>>>>>>>>>>>    Function System_Help_Context_id Integer ID Returns String
91548>>>>>>>>>>>       Function_Return ID
91549>>>>>>>>>>>    End_Function // System_Help_Context_id
91550>>>>>>>>>>>
91550>>>>>>>>>>>    // Returns the file# which assumes that we have a direct mapping between
91550>>>>>>>>>>>    // the file number and a window's help context_id. We are ignoring field#
91550>>>>>>>>>>>    // in this case (although your augmentation would not have to). If the
91550>>>>>>>>>>>    // file# is 0, return a the HELP_ID context id.
91550>>>>>>>>>>>    //
91550>>>>>>>>>>>    Function System_Help_File_Id Integer File# Integer Field# Returns String
91552>>>>>>>>>>>       String rVal
91552>>>>>>>>>>>       if File# eq 0 Move (Help_id_files(self)) to rVal
91555>>>>>>>>>>>       Else Move File# to rVal
91557>>>>>>>>>>>       Function_Return Rval
91558>>>>>>>>>>>    End_Function // System_Help_File_id
91559>>>>>>>>>>>
91559>>>>>>>>>>>    // Convert an error id into a help context id. Return the general
91559>>>>>>>>>>>    // Help id property value. We do this because error number have
91559>>>>>>>>>>>    // a rather large range (1-9000) and just using the number would consume
91559>>>>>>>>>>>    // too much of the context id space.
91559>>>>>>>>>>>    //
91559>>>>>>>>>>>    Function System_Help_Error_id Integer Id Returns String
91561>>>>>>>>>>>       Function_Return (Help_Id_Errors(self))
91562>>>>>>>>>>>    End_Function // System_Help_Error_id
91563>>>>>>>>>>>
91563>>>>>>>>>>>    // Use this if you want your help context to be keyword based
91563>>>>>>>>>>>    //
91563>>>>>>>>>>>    procedure View_Context_KeyWord_Help integer Obj
91565>>>>>>>>>>>       String Context
91565>>>>>>>>>>>       If Obj gt 0 ;          Get Help_Context of obj HELP_CONTEXT_KEYWORD to Context
91568>>>>>>>>>>>       Send Exec_System_Help Context
91569>>>>>>>>>>>    end_procedure
91570>>>>>>>>>>>
91570>>>>>>>>>>>    // Use this if you want your help context to be ID based
91570>>>>>>>>>>>    //
91570>>>>>>>>>>>    procedure View_Context_ID_Help integer Obj
91572>>>>>>>>>>>       Integer Context_ID
91572>>>>>>>>>>>       String Context
91572>>>>>>>>>>>       If Obj gt 0 ;          Get Help_Context of Obj HELP_CONTEXT_ID to Context_ID
91575>>>>>>>>>>>       Get System_Help_Context_id Context_Id to Context
91576>>>>>>>>>>>       Send Exec_Context_Help Context
91577>>>>>>>>>>>    end_procedure
91578>>>>>>>>>>>
91578>>>>>>>>>>>    // Use this is you want the object requesting help to support either
91578>>>>>>>>>>>    // keyword or context ID help (it will use whatever it finds first).
91578>>>>>>>>>>>    //
91578>>>>>>>>>>>    procedure View_Context_Help integer Obj
91580>>>>>>>>>>>       String Context
91580>>>>>>>>>>>       If Obj gt 0 ;          Get Help_Context of obj HELP_CONTEXT_ID_OR_KEY to Context
91583>>>>>>>>>>>       if (left(context,1)) in '0123456789' ;          Get System_Help_Context_id Context to Context
91586>>>>>>>>>>>       Send Exec_Context_Help Context
91587>>>>>>>>>>>    end_procedure
91588>>>>>>>>>>>
91588>>>>>>>>>>>    Procedure View_Help_for_Help Integer obj
91590>>>>>>>>>>>        Send Exec_System_Help HELP_FOR_HELP_STRING
91591>>>>>>>>>>>    end_procedure
91592>>>>>>>>>>>
91592>>>>>>>>>>>    Procedure View_Help_Index integer obj
91594>>>>>>>>>>>       Send Exec_Context_Help (Help_id_index(self))
91595>>>>>>>>>>>    End_Procedure // View_help_index
91596>>>>>>>>>>>
91596>>>>>>>>>>>    procedure View_Keys_Help Integer Obj
91598>>>>>>>>>>>        Send Exec_Context_Help (Help_id_keys(self))
91599>>>>>>>>>>>    end_procedure
91600>>>>>>>>>>>
91600>>>>>>>>>>>    Procedure View_File_Help Integer Obj
91602>>>>>>>>>>>       String Context FilFld
91602>>>>>>>>>>>       Integer File# Field# Dot
91602>>>>>>>>>>>       If Obj gt 0 Begin
91604>>>>>>>>>>>          // This should return the file and field as a string in
91604>>>>>>>>>>>          // FFF.fff format (F=File, f=format).
91604>>>>>>>>>>>          Get Help_Context of Obj HELP_CONTEXT_DATAFILE to FilFld
91605>>>>>>>>>>>          // Parse FilFld into File# and Field#.
91605>>>>>>>>>>>          Pos '.' in FilFld to Dot
91607>>>>>>>>>>>>
91607>>>>>>>>>>>          if Dot ne 0 begin
91609>>>>>>>>>>>             Left FilFld to File#  (dot-1)
91611>>>>>>>>>>>>
91611>>>>>>>>>>>             Mid  FilFld to Field# 255 (dot+1)
91614>>>>>>>>>>>>
91614>>>>>>>>>>>          End
91614>>>>>>>>>>>>
91614>>>>>>>>>>>       End
91614>>>>>>>>>>>>
91614>>>>>>>>>>>       Get System_Help_File_id File# Field# to Context
91615>>>>>>>>>>>       Send Exec_Context_Help Context
91616>>>>>>>>>>>    End_Procedure // View_File_Help
91617>>>>>>>>>>>
91617>>>>>>>>>>>    //  View help on an error. Current version uses context id help.
91617>>>>>>>>>>>    //  The error number should be in global integer last_err
91617>>>>>>>>>>>    //
91617>>>>>>>>>>>    procedure View_Error_Help Integer Obj
91619>>>>>>>>>>>        String Context
91619>>>>>>>>>>>        If Obj gt 0 ;           Get Help_Context of obj HELP_CONTEXT_ERROR to Context
91622>>>>>>>>>>>        if (left(context,1)) in '0123456789' ;           Get System_Help_Error_id Context to Context
91625>>>>>>>>>>>        Send Exec_Context_Help Context
91626>>>>>>>>>>>    end_procedure
91627>>>>>>>>>>>
91627>>>>>>>>>>>    // View list of help topics.
91627>>>>>>>>>>>    //
91627>>>>>>>>>>>    Procedure View_Help_on_Topic Integer obj
91629>>>>>>>>>>>        Send Exec_System_Help HELP_ON_TOPIC_STRING
91630>>>>>>>>>>>    end_procedure
91631>>>>>>>>>>>
91631>>>>>>>>>>>    // Request context help. If context is a number assume that it is
91631>>>>>>>>>>>    // context id help, else assume it is keyword help.
91631>>>>>>>>>>>    //
91631>>>>>>>>>>>    Procedure Exec_Context_Help string Context
91633>>>>>>>>>>>       if (left(context,1)) in '0123456789' ;    // if first character is a          Send Exec_System_Context_Help Context  // numeric we assume ID help
91636>>>>>>>>>>>       else ;                                    // otherwise we assume key-          Send Exec_System_Help Context          // word help.
91638>>>>>>>>>>>    End_Procedure // Exec_Context_Help
91639>>>>>>>>>>>
91639>>>>>>>>>>>    // NOTE: the following two messages are the only messages that directly make calls
91639>>>>>>>>>>>    //       to the windows API. This is important. These two messages could be changed
91639>>>>>>>>>>>    //       to call other help systems (e.g. HTML help) and the rest of the high level
91639>>>>>>>>>>>    //       program remains the same. These are the only two messages that are
91639>>>>>>>>>>>    //       expected to be windows help centric.
91639>>>>>>>>>>>
91639>>>>>>>>>>>    // Get Context Id help for passed ID. Use help file as defined
91639>>>>>>>>>>>    // in Help_filename. If id is 0 use general help id (which must be
91639>>>>>>>>>>>    // defined.
91639>>>>>>>>>>>    //
91639>>>>>>>>>>>    Procedure Exec_System_Context_Help integer Context_id
91641>>>>>>>>>>>        If Context_Id eq 0 ; // if zero, see if we have a contents page            Move (Help_Id_General(self)) to Context_id
91644>>>>>>>>>>>        If Context_Id eq 0 ; // if still zero, jump to the topics popup dialog            Send Exec_System_Help HELP_ON_TOPIC_STRING
91647>>>>>>>>>>>        Else ;            Send gDoWinHelp WH_INTCONTEXT (Help_Filename(self)) Context_Id
91649>>>>>>>>>>>    end_procedure
91650>>>>>>>>>>>
91650>>>>>>>>>>>    // Get keyword help for passed keyword. Use help file as defined
91650>>>>>>>>>>>    // in help_filename.
91650>>>>>>>>>>>    //
91650>>>>>>>>>>>    procedure Exec_System_Help string Keyword
91652>>>>>>>>>>>        If Keyword eq HELP_FOR_HELP_STRING ;            Send gDoWinHelp WH_HELPONHELP
91655>>>>>>>>>>>        else if (Keyword eq HELP_ON_TOPIC_STRING OR KeyWord="");            Send gDoWinHelp WH_FINDER (Help_Filename(self))
91659>>>>>>>>>>>        else ;            Send gDoWinHelp WH_STRINGCONTEXT (Help_Filename(self)) KeyWord
91661>>>>>>>>>>>    end_procedure
91662>>>>>>>>>>>
91662>>>>>>>>>>>end_class
