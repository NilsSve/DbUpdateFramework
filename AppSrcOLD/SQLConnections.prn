85211>>>>>>>Class cDbUpdateGenericDatabaseDriver is a cObject
85212>>>>>>>    Procedure Construct_Object
85214>>>>>>>        Forward Send Construct_Object
85216>>>>>>>        Property String psDriverID DATAFLEX_ID
85217>>>>>>>    End_Procedure 
85218>>>>>>>    
85218>>>>>>>    Function ServerKeyword Returns String
85220>>>>>>>        Function_Return CS_SQLIniDSNKeyword
85221>>>>>>>    End_Function
85222>>>>>>>    
85222>>>>>>>    Function ConstructConnectionString String sServer String sDatabase Boolean bTrusted String sUserID String sPassword Returns String
85224>>>>>>>        String sConnect
85224>>>>>>>        
85224>>>>>>>        Move (sConnect * ServerKeyword(Self) + "=" + sServer) to sConnect
85225>>>>>>>        If (sDatabase <> "") Begin
85227>>>>>>>            Move (sConnect * ";" + CS_SQLIniDatabaseKeyword + "=" + sDatabase) to sConnect
85228>>>>>>>        End
85228>>>>>>>>
85228>>>>>>>        If (bTrusted = True) Begin
85230>>>>>>>            Move (sConnect * ";" + CS_SQLIniTrustedKeyword + "=Yes") to sConnect
85231>>>>>>>        End
85231>>>>>>>>
85231>>>>>>>        Else Begin
85232>>>>>>>            Move (sConnect * ";" + CS_SQLIniUIDKeyword + "=" + sUserID * ";" + CS_SQLIniPWDKeyword + "=" + sPassword) to sConnect
85233>>>>>>>        End
85233>>>>>>>>
85233>>>>>>>        Function_Return sConnect
85234>>>>>>>    End_Function
85235>>>>>>>    
85235>>>>>>>    Function DbLogin String sConnectionString String sServer String sDatabase Boolean bTrusted String sUserID String sPassword Returns Boolean
85237>>>>>>>        Boolean bLoginSuccessful
85237>>>>>>>        String sDriverID 
85237>>>>>>>        
85237>>>>>>>        Get psDriverID to sDriverID
85238>>>>>>>        Move 0 to LastErr  // Do NOT use the Err flag, it will be set true by the login command although it is successful.
85239>>>>>>>        If (bTrusted = False) Begin
85241>>>>>>>            Login sServer sUserId sPassword sDriverID
85243>>>>>>>        End 
85243>>>>>>>>
85243>>>>>>>        Else Begin
85244>>>>>>>            Login sConnectionString "" "" sDriverID
85246>>>>>>>        End
85246>>>>>>>>
85246>>>>>>>        Move (LastErr = 0) to bLoginSuccessful
85247>>>>>>>        Function_Return bLoginSuccessful
85248>>>>>>>    End_Function
85249>>>>>>>End_Class
