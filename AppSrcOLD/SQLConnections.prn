80037>>>
80037>>>  // Courtesy Of Steve Walter
80037>>>  // Requires Windows 2000 and up according to msdn but it was
80037>>>  //  in fact available before that as an unpublished API call
80037>>>  //  a little google search shows that this was already available
80037>>>  //  in windows 95 and NT
80037>>>  //
80037>>>  // The format is controlled by the dialog interface.
80037>>>  // That is, the user must click the OK button To actually Begin the format
80037>>>  // the format cannot be started programmatically.
80037>>>  // An alternative to this functionality would be to use a controlpanel
80037>>>  //  http://www.vdf-guidance.com/ContribPage.asp?Page=PKGCLSDFCPLAPP&ContribRecId=93
80037>>>  //
80037>>>  // hWnd = The windows handle of the object from which the format Function
80037>>>  //        is called.
80037>>>  // To Get this,
80037>>>  //          use:  Get Window_Handle Of <object>
80037>>>  //          For instance, in this app, we're going to use the Report_Panel:
80037>>>  //                  Get Window_Handle Of (Report_Panel(Main(Self))) To hWind
80037>>>  //
80037>>>  // sDrive = The drive letter. At this moment only A and B are valid
80037>>>  //
80037>>>  // iOptions = Format options.
80037>>>  //  SHFMT_OPT_DEFAULT = Quick format
80037>>>  //  SHFMT_OPT_FULL    = Full Format
80037>>>  //  SHFMT_OPT_SYSONLY = System only
80037>>>  //  3                 = Full format with system. (unsupported)
80037>>>  //
80037>>>  // Return Values:
80037>>>  //  SHFMT_ERROR    = Error on format or no drive specified.
80037>>>  //  SHFMT_CANCEL   = Format cancelled by user.
80037>>>  //  SHFMT_NOFORMAT = Drive is not formatable.
80037>>>  //
80037>>>  //
80037>>>  // *** ATTENTION: This function has been disabled as it doesn't
80037>>>  //                seem to work, i must have made a silly mistake
80037>>>  //                somewhere.
80037>>>  //
80037>>>  Function sfoFormatDisk String sDrive Integer iOptions Returns DWORD
80039>>>    Handle   hWnd
80039>>>    Integer  iObj
80039>>>    DWORD    dwReturnVal
80039>>>    Integer iDrive
80039>>>
80039>>>    Function_Return (1) // STOP HERE
80040>>>    
80040>>>    Move (Trim(sDrive)) To sDrive
80041>>>    If ( sDrive <> '' ) Begin
80043>>>      If ( sDrive Contains ':' ) Move (Replace(':',sDrive,'')) To sDrive
80046>>>      If (Not( 'AB' Contains sDrive )) Function_Return (SHFMT_NOFORMAT)
80049>>>      If ( sDrive = 'A' ) Move 0 To iDrive
80052>>>      Else If ( sDrive = 'B' ) Move 1 To iDrive
80056>>>      // Window_Handle Of Desktop equals to 0
80056>>>      
80056>>>      Get focus Of desktop To iObj
80057>>>      If (iObj>desktop) ;          Get Container_Handle Of iObj To hWnd
80060>>>      While (hWnd=0 And iObj<>Desktop)
80064>>>          Get Parent Of iObj To iObj
80065>>>          Get Container_Handle Of iObj To hWnd
80066>>>      End
80067>>>>
80067>>>                      
80067>>>      //Showln "hWnd = " hWnd " iDrive " iDrive " iOptions " iOptions
80067>>>      Move (vWin32_ShFormatDrive(hWnd, iDrive, SHFMT_ID_DEFAULT, iOptions)) To dwReturnVal
80068>>>    End
80068>>>>
80068>>>    Else Begin
80069>>>      Move (SHFMT_ERROR) To dwReturnVal
80070>>>    End
80070>>>>
80070>>>    Function_Return dwReturnVal
80071>>>  End_Function // sfoFormatDisk
80072>>> 
80072>>>  //Example:
80072>>>  // Get sfoFormatDisk 'A' 0 To dReturnVal    // Formats drive A in QuickFormat
80072>>>  //                                          mode.
80072>>>  
80072>>>End_Class // cShellFileOperations
