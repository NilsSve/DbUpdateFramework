89066>>>    // Removes all driver identifications (e.g. "MSSQLDRV;MyTable" or "MyTable.MSSQLDRV"
89066>>>    // from the passed filelist.
89066>>>    // Returns the number of tables affected.
89066>>>    Function SqlUtilFilelistRemoveDriverInfo String sFilelist Returns Integer
89068>>>        String sCurrentFileList sRootName sDisplayName sLogicalName sVal
89068>>>        Integer iRetval
89068>>>        Handle hTable
89068>>>        
89068>>>        // We first save the current filelist as the passed filelist name
89068>>>        // may come from another workspace, to restore it when we're ready.
89068>>>        Get_Attribute DF_FILELIST_NAME to sCurrentFileList
89071>>>        Set_Attribute DF_FILELIST_NAME to sFilelist
89074>>>        Move 0 to hTable
89075>>>        Move 0 to iRetval
89076>>>        
89076>>>        Repeat
89076>>>>
89076>>>            Get_Attribute DF_FILE_NEXT_USED of hTable to hTable
89079>>>            If (hTable <> 0) Begin
89081>>>                Get_Attribute DF_FILE_ROOT_NAME    of hTable to sRootName
89084>>>                Get_Attribute DF_FILE_DISPLAY_NAME of hTable to sDisplayName
89087>>>                Get_Attribute DF_FILE_LOGICAL_NAME of hTable to sLogicalName
89090>>>                Move (Uppercase(sRootName)) to sVal
89091>>>                If (sVal contains MSSQLDRV_ID or sVal contains DB2_DRV_ID or sVal contains ODBC_DRV_ID) Begin
89093>>>                    // Prefixes:
89093>>>                    Move (Replace((MSSQLDRV_ID + ":"), sRootName, "")) to sRootName
89094>>>                    Move (Replace((DB2_DRV_ID  + ":"), sRootName, "")) to sRootName
89095>>>                    Move (Replace((ODBC_DRV_ID + ":"), sRootName, "")) to sRootName
89096>>>                    // Suffixes:
89096>>>                    Move (Replace(("." + MSSQLDRV_ID), sRootName, "")) to sRootName
89097>>>                    Move (Replace(("." + DB2_DRV_ID),  sRootName, "")) to sRootName
89098>>>                    Move (Replace(("." + ODBC_DRV_ID), sRootName, "")) to sRootName
89099>>>                    
89099>>>                    // Change Filelist entry:
89099>>>                    Set_Attribute DF_FILE_ROOT_NAME of hTable          to sRootName
89102>>>
89102>>>                    Move (Lowercase(sDisplayName)) to sVal
89103>>>                    If (sVal contains "dbo.") Begin
89105>>>                        Move (Replace("dbo.", sDisplayName, ""))       to sDisplayName
89106>>>                        
89106>>>                        // Change Filelist entry:
89106>>>                        Set_Attribute DF_FILE_DISPLAY_NAME of hTable   to sDisplayName
89109>>>                    End
89109>>>>
89109>>>                    Increment iRetval
89110>>>                End
89110>>>>
89110>>>            End
89110>>>>
89110>>>        Until (hTable = 0)
89112>>>        
89112>>>        Set_Attribute DF_FILELIST_NAME to sCurrentFileList
89115>>>        
89115>>>        Function_Return iRetval
89116>>>    End_Function
89117>>>    
89117>>>    // To open all Sql based tables in Filelist.cfg
89117>>>    Procedure SqlUtilOpenAllTables
89119>>>        Handle hTable
89119>>>        String sRoot sDriverID
89119>>>        Boolean bOK
89119>>>        
89119>>>        Move 0 to hTable
89120>>>        Move "" to sDriverID
89121>>>        Get AutoConnectionIDLogin to bOK
89122>>>        
89122>>>        Repeat
89122>>>>
89122>>>            Get_Attribute DF_FILE_NEXT_USED of hTable to hTable
89125>>>            If (hTable > 0) Begin     
89127>>>                Get_Attribute DF_FILE_DRIVER of hTable to sDriverID
89130>>>                If (sDriverID = MSSQLDRV_ID or sDriverID = DB2_DRV_ID or sDriverID = ODBC_DRV_ID) Begin
89132>>>                    Get_Attribute DF_FILE_ROOT_NAME of hTable to sRoot
89135>>>                    If (Uppercase(sRoot) contains ".INT" or Uppercase(sRoot) contains MSSQLDRV_ID or Uppercase(sRoot) contains DB2_DRV_ID or Uppercase(sRoot) contains ODBC_DRV_ID) Begin
89137>>>                        Open hTable
89139>>>                    End
89139>>>>
89139>>>                End
89139>>>>
89139>>>            End
89139>>>>
89139>>>    
89139>>>        Until (hTable = 0)
89141>>>    End_Procedure             
