90493>>>
90493>>>    // The bANSI parameter's default value = True, meaning a table in ANSI format will be created.
90493>>>    // i.e. DF_FILE_TABLE_CHARACTER_FORMAT {"OEM"|"ANSI"}
90493>>>    Function ApiTableCreate Handle hTable String sRoot String sDisplay String sTableName Boolean bUseConnectionID Boolean bANSI Boolean bRecnum Returns Boolean
90495>>>        Handle hFile
90495>>>        String sConnectionID sPhysicalFile sANSI_OEM sVal sSchema sOriginalDriverID sDriverID
90495>>>        Integer iColumn 
90495>>>        Boolean bOk bExists bMertechDriver
90495>>>        tSQLConnection SQLConnection
90495>>>        tSQLConnection SQLConnection
90495>>>
90495>>>        If (ghoProgressBar <> 0) Begin
90497>>>            Send DoAdvance of ghoProgressBar
90498>>>        End
90498>>>>
90498>>>        
90498>>>        // First check if the passed filenumber already exists; in case we do nothing
90498>>>        Get UtilTableNumberIsInUse hTable to bOk
90499>>>        If (bOk = True) Begin
90501>>>            Function_Return False
90502>>>        End
90502>>>>
90502>>>        
90502>>>        Get psDriverID to sDriverID
90503>>>        // If this is a SQL based driver we also check if the table exists
90503>>>        // in the SQL back end; in case we do nothing.
90503>>>        Get IsSQLDriver sDriverID to bOk
90504>>>        If (bOk = True) Begin
90506>>>            Get SqlUtilCheckIfTableHandleExists hTable sDriverID to bExists
90507>>>            If (bExists = True) Begin
90509>>>                Function_Return False
90510>>>            End                      
90510>>>>
90510>>>        
90510>>>            // Get all connection properties
90510>>>            Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection  
90511>>>            Move SQLConnection.sSchema to sSchema
90512>>>            If (sSchema = "") Begin
90514>>>                Get _SqlFindKeyWord CI_SQLDBO to sSchema  
90515>>>            End
90515>>>>
90515>>>        End
90515>>>>
90515>>>        
90515>>>        Move CS_ANSI_Txt to sANSI_OEM
90516>>>        If (num_arguments > 6) Begin
90518>>>            If (bANSI = False) Begin
90520>>>                Move CS_OEM_Txt to sANSI_OEM
90521>>>            End
90521>>>>
90521>>>        End  
90521>>>>
90521>>>        
90521>>>        // Mertech drivers don't use connection id's, so if the passed bUseConnectionID = True that
90521>>>        // is a programmer's error and we auto-correct for it here.
90521>>>        // This is also a bit messy. If a Mertech driver is used and we want to create a new table,
90521>>>        // we first need to create it as embedded (DataFlex) and then convert it to SQL (!)
90521>>>        // So we set the driver ID temporarily to "DataFlex" to get the table created as embedded and later
90521>>>        // set it back and use a Mertech function to convert it to SQL.
90521>>>        Get IsMertechDriver sDriverID to bMertechDriver
90522>>>        If (bMertechDriver = True) Begin
90524>>>            If (bUseConnectionID = True) Begin
90526>>>                Move False to bUseConnectionID
90527>>>            End
90527>>>>
90527>>>            Move sDriverID to sOriginalDriverID
90528>>>            Move DATAFLEX_ID to sDriverID
90529>>>        End
90529>>>>
90529>>>            
90529>>>        Move False to Err
90530>>>        If (sDriverID = DATAFLEX_ID) Begin
90532>>>            Move sRoot to sPhysicalFile 
90533>>>        End
90533>>>>
90533>>>        
90533>>>        If (sDriverID <> DATAFLEX_ID) Begin 
90535>>>            Move SQLConnection.sConnectionID to sConnectionID
90536>>>            
90536>>>            // If DAW driver and we should use a connection id we need to
90536>>>            // check if the connection ID exists; else we create it before attempting creating the table
90536>>>            If (bMertechDriver = False and bUseConnectionID = True) Begin
90538>>>                Get IsConnectionID sConnectionID sDriverID to bExists
90539>>>                If (bExists = False) Begin
90541>>>                    Get UtilCreateConnectionID sConnectionID to bOk
90542>>>                    If (bOk = False) Begin
90544>>>                        Error DFERR_PROGRAM ("The Connection ID:" * sConnectionID * "could not be created and therefor the table can't be created.")
90545>>>>
90545>>>                        Function_Return False
90546>>>                    End
90546>>>>
90546>>>                End
90546>>>>
90546>>>            End
90546>>>>
90546>>>            
90546>>>            Move (sRoot + ".int") to sPhysicalFile
90547>>>            Move (Uppercase(sDisplay)) to sVal
90548>>>            If (not(sVal contains (sSchema + "."))) Begin    
90550>>>                Move (Lowercase(sSchema) + "." + sTableName) to sDisplay
90551>>>            End                                       
90551>>>>
90551>>>        End                                          
90551>>>>
90551>>>        Move 0 to hFile   
90552>>>        Move False to Err 
90553>>>        
90553>>>        Structure_Start hFile sDriverID
90554>>>            If (sDriverID <> DATAFLEX_ID) Begin
90556>>>                If (bUseConnectionID = True) Begin
90558>>>                    Set_Attribute DF_FILE_LOGIN              of hFile to (CS_DFCONNID + "=" + sConnectionID)
90561>>>                End 
90561>>>>
90561>>>                Else Begin
90562>>>                    Set_Attribute DF_FILE_LOGIN              of hFile to SQLConnection.sConnectionString
90565>>>                End
90565>>>>
90565>>>                Set_Attribute DF_FILE_TABLE_NAME             of hFile to sRoot  
90568>>>                Set_Attribute DF_FILE_USE_DUMMY_ZERO_DATE    of hFile to True     
90571>>>                Set_Attribute DF_FILE_TABLE_CHARACTER_FORMAT of hFile to sANSI_OEM
90574>>>                Set_Attribute DF_FILE_RECNUM_TABLE           of hFile to bRecnum
90577>>>
90577>>>                If (sSchema <> "") Begin
90579>>>                    Set_Attribute DF_FILE_OWNER                of hFile to sSchema
90582>>>                End
90582>>>>
90582>>>    
90582>>>                If (sDriverID = DB2_DRV_ID) Begin                           
90584>>>                    If (SQLConnection.sLongTableSpace <> "") Begin
90586>>>                        Set_Attribute DF_FILE_LONG_TABLESPACE  of hFile to SQLConnection.sLongTableSpace
90589>>>                    End
90589>>>>
90589>>>                End   
90589>>>>
90589>>>                If (sDriverID = DB2_DRV_ID or sDriverID = ORAFLEX or sDriverID = MDSPgSQL) Begin
90591>>>                    If (SQLConnection.sBaseTableSpace <> "") Begin
90593>>>                        Set_Attribute DF_FILE_TABLE_TABLESPACE of hFile to SQLConnection.sBaseTableSpace
90596>>>                    End
90596>>>>
90596>>>                    If (SQLConnection.sIndexTableSpace <> "") Begin
90598>>>                        Set_Attribute DF_FILE_INDEX_TABLESPACE of hFile to SQLConnection.sIndexTableSpace
90601>>>                    End
90601>>>>
90601>>>                End
90601>>>>
90601>>>            End 
90601>>>>
90601>>>                       
90601>>>            Set_Attribute DF_FILE_PHYSICAL_NAME              of hFile to sPhysicalFile 
90604>>>            
90604>>>            // We need to create at least one column else the table creation will fail.
90604>>>            // We remove it before the end of this function.
90604>>>            Move 0 to iColumn
90605>>>            Create_Field hFile at iColumn                   
90606>>>            
90606>>>            Set_Attribute DF_FIELD_NAME of hFile iColumn to "temp"
90609>>>            Set_Attribute DF_FIELD_TYPE of hFile iColumn to DF_DATE
90612>>>        Structure_End hFile
90614>>>        
90614>>>        // If Mertech driver we convert the newly created embedded table (DataFlex) to SQL
90614>>>        If (bMertechDriver = True) Begin
90616>>>            Move sOriginalDriverID to sDriverID
90617>>>            If (not(sVal contains (sSchema + "."))) Begin    
90619>>>                Move (Lowercase(sSchema) + "." + sTableName) to sDisplay
90620>>>            End                                       
90620>>>>
90620>>>            // Note: This function also sets the Err flag.
90620>>>            Get _MertechApiTableConvertToSQL hTable sRoot SQLConnection.sDatabase sDriverID SQLConnection.sBaseTableSpace SQLConnection.sIndexTableSpace False to bOK
90621>>>        End
90621>>>>
90621>>>
90621>>>        Move (not(Err)) to bOK                                     
90622>>>        If (bOk = True) Begin
90624>>>            If (sDriverID <> DATAFLEX_ID) Begin
90626>>>                Move (sDriverID + ":" + sRoot) to sRoot
90627>>>            End
90627>>>>
90627>>>    
90627>>>            If (sDriverID <> DATAFLEX_ID and not(Uppercase(sRoot) contains sDriverID)) Begin
90629>>>                Move (sDriverID + ":" + sRoot) to sRoot
90630>>>            End
90630>>>>
90630>>>            Set_Attribute DF_FILE_ROOT_NAME     of hTable to sRoot
90633>>>            Set_Attribute DF_FILE_LOGICAL_NAME  of hTable to sTableName 
90636>>>            Set_Attribute DF_FILE_DISPLAY_NAME  of hTable to sDisplay
90639>>>        
90639>>>            // Lastly we remove the temporary column we created above, if all went well.
90639>>>            Get ApiColumnRemove hTable "temp" to bOk
90640>>>        End
90640>>>>
90640>>>        
90640>>>        Function_Return (bOK = True)
90641>>>    End_Function  
