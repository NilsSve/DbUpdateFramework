91241>>>    
91241>>>    // Checks if a field name exists in a table definition
91241>>>    // Returns True if it does
91241>>>    // Sample:
91241>>>    //   Get UtilColumnExists MyTable.File_Number "MyColumnName" to iExists
91241>>>    Function UtilColumnExists Handle hTable String sFieldName Returns Boolean
91243>>>        Integer iNumColumns iColumn
91243>>>        String sColumn
91243>>>        Boolean bExists bOK
91243>>>    
91243>>>        Get AutoConnectionIDLogin to bOK
91244>>>        Send Ignore_Error of Error_Object_Id DFERR_CANT_OPEN_DATA_FILE
91245>>>        Open hTable                       
91247>>>        Send Trap_Error   of Error_Object_Id DFERR_CANT_OPEN_DATA_FILE
91248>>>        If (Found = False) Begin
91250>>>            Function_Return False
91251>>>        End                      
91251>>>>
91251>>>        
91251>>>        Move False to bExists  
91252>>>        Get_Attribute DF_FILE_NUMBER_FIELDS of hTable to iNumColumns
91255>>>        for iColumn from 1 to iNumColumns
91261>>>>
91261>>>            Get_Attribute DF_FIELD_NAME of hTable iColumn to sColumn
91264>>>            If (Uppercase(sFieldName) = Uppercase(sColumn)) Begin
91266>>>                Move iNumColumns to iColumn
91267>>>                Move True to bExists
91268>>>            End
91268>>>>
91268>>>        Loop
91269>>>>
91269>>>        Close hTable
91270>>>    
91270>>>        Function_Return bExists
91271>>>    End_Function
91272>>>    
91272>>>    // Checks if the current psConnectionID is logged in; if not
91272>>>    // attempts to make a login. 
91272>>>    // Because
91272>>>    // Returns True if already logged in or the new login was successful.
91272>>>    Function AutoConnectionIDLogin Returns Boolean
91274>>>        String sConnectionID sConnectionString sDriverID
91274>>>        Boolean bExists bOK bDAWDriver
91274>>>        Handle hoCLI hoDriver                                    
91274>>>        Integer iRetval
91274>>>        tSQLConnection SQLConnection
91274>>>        tSQLConnection SQLConnection
91274>>>        
91274>>>        Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
91275>>>        Move SQLConnection.sDriverID                  to sDriverID      
91276>>>        Move SQLConnection.sConnectionString          to sConnectionString
91277>>>        Get IsDAWSQLDriver sDriverID to bOK
91278>>>        If (bOK = False) Begin                         
91280>>>            Get _MertechSQLManagerHandle to hoCLI
91281>>>            Get Create (RefClass(cDbUpdateDatabaseDriver)) to hoDriver
91282>>>            Set psDriverID of hoDriver to SQLConnection.sDriverID
91283>>>            Get DbLogin    of hoDriver sConnectionString SQLConnection.sServer SQLConnection.sDatabase SQLConnection.bTrusted SQLConnection.sUserID SQLConnection.sPassword to bOK
91284>>>            Send Destroy   of hoDriver
91285>>>            Function_Return False
91286>>>        End                      
91286>>>>
91286>>>        
91286>>>        Move SQLConnection.sConnectionID to sConnectionID
91287>>>        
91287>>>        Get IsConnectionID sConnectionID sDriverID to bExists
91288>>>        If (bExists = False) Begin
91290>>>            // We always start by deleting the current connection - if any - because the
91290>>>            // login details my have changed.
91290>>>            Get phoCLIHandler to hoCLI   
91291>>>            Set psDriverID    of hoCLI to sDriverID
91292>>>            Get DeleteConnectionID of hoCLI sConnectionID -1 to iRetval
91293>>>            Get UtilCreateConnectionID sConnectionID to bOk
91294>>>            If (bOk = False) Begin
91296>>>                Error DFERR_PROGRAM ("The Connection ID:" * sConnectionID * "could not be created and therefor the table can't be changed.")
91297>>>>
91297>>>                Function_Return False
91298>>>            End
91298>>>>
91298>>>            Move bOK to bExists
91299>>>        End
91299>>>>
91299>>>        
91299>>>        Function_Return (bExists = True)
91300>>>    End_Function
91301>>>    
91301>>>    // *** Utility Messages ***
91301>>>    // 
91301>>>    //
91301>>>    // To add a value to the CodeMast & CodeType tables. Pass; a) bCodeType if it is CodeType that should be updated. 
91301>>>    // Else it is CodeMast. b) sTypeValue; either to be added If bCodeType = True, or it will be used to find the correct 
91301>>>    // CodeType record. c) sValue1 and d) sValue2 is the CodeType Description & Comment, or CodeMast Type and Code values.
91301>>>    Function UtilCodeMasterAddValue Boolean bCodeType String sTypeValue String sValue2 String sValue3 Returns Boolean
91303>>>        Boolean bError bFound
91303>>>        
91303>>>        Move False to Err
91304>>>        Open CodeMast
91306>>>        Open CodeType
91308>>>        
91308>>>        If (bCodeType = True) Begin
91310>>>            Clear CodeType
91311>>>            Move sTypeValue to CODETYPE.Type 
91312>>>            Find eq CODETYPE.Type
91313>>>>
91313>>>            Move (Found = True) to bFound
91314>>>            If (bFound = True) Begin
91316>>>                Reread CodeType
91320>>>            End
91320>>>>
91320>>>            If (bFound = False) Begin
91322>>>                Clear CodeType
91323>>>            End       
91323>>>>
91323>>>                Move sTypeValue to CODETYPE.Type 
91324>>>                Move sValue2    to CODETYPE.Description
91325>>>                Move sValue3    to CODETYPE.Comment
91326>>>                SaveRecord CODETYPE
91327>>>            If (bFound = True) Begin
91329>>>                Unlock
91330>>>>
91330>>>            End
91330>>>>
91330>>>        End
91330>>>>
91330>>>        
91330>>>        If (bCodeType = False) Begin
91332>>>            Clear CODEMAST
91333>>>            Move sTypeValue to CODEMAST.Type
91334>>>            Move sValue2    to CODEMAST.Code  
91335>>>            Find eq CODEMAST.Code
91336>>>>
91336>>>            Move (Found = True) to bFound
91337>>>            If (bFound = True) Begin
91339>>>                Reread CODEMAST
91343>>>            End
91343>>>>
91343>>>            If (bFound = False) Begin
91345>>>                Clear CODEMAST
91346>>>            End   
91346>>>>
91346>>>                Move sTypeValue to CODEMAST.Type
91347>>>                Move sValue2    to CODEMAST.Code  
91348>>>                Move sValue3    to CODEMAST.Description
91349>>>                SaveRecord CODEMAST
91350>>>            If (bFound = True) Begin
91352>>>            Unlock
91353>>>>
91353>>>            End
91353>>>>
91353>>>        End
91353>>>>
91353>>>        
91353>>>        Close CodeMast
91354>>>        Close CodeType
91355>>>        
91355>>>        Function_Return (Err = False)
91356>>>    End_Function
91357>>>
91357>>>    // Changes values in CodeType & CodeMast - From type value To type value. It first changes the type value in 
91357>>>    // CodeType and then spins through all CodeMast records to change all related records.
91357>>>    Function UtilCodeMasterChangeValue String sFromValue String sToValue Returns Boolean
91359>>>        Boolean bFound
91359>>>        
91359>>>        Move False to Err
91360>>>        Open CodeMast
91362>>>        Open CodeType
91364>>>        
91364>>>        Clear CodeType
91365>>>        Move sFromValue to CODETYPE.Type
91366>>>        Find eq CODETYPE.Type
91367>>>>
91367>>>        If (Found = True) Begin
91369>>>            Reread CODETYPE
91373>>>                Move sToValue to CODETYPE.Type
91374>>>                SaveRecord CODETYPE
91375>>>            Unlock                 
91376>>>>
91376>>>        End
91376>>>>
91376>>>            
91376>>>        Clear CODEMAST
91377>>>        Find gt CODEMAST by Recnum
91378>>>>
91378>>>        While (Found = True)
91382>>>            Move (Trim(Uppercase(CODEMAST.Type) = Trim(Uppercase(sFromValue)))) to bFound
91383>>>            If (bFound = True) Begin
91385>>>                Reread CODEMAST
91389>>>                    Move sToValue to CODEMAST.Type
91390>>>                    SaveRecord CODEMAST
91391>>>                Unlock
91392>>>>
91392>>>            End
91392>>>>
91392>>>            Find gt CODEMAST by Recnum
91393>>>>
91393>>>        Loop
91394>>>>
91394>>>        
91394>>>        Close CodeMast
91395>>>        Close CodeType
91396>>>        
91396>>>        Function_Return (Err = False)
91397>>>    End_Function
91398>>>    
91398>>>    // Removes a value from CodeMast. Pass the sTypeValue and the sValue2 to remove.
91398>>>    Function UtilCodeMasterRemoveValue String sTypeValue String sValue2 Returns Boolean
91400>>>        Boolean bError bFound
