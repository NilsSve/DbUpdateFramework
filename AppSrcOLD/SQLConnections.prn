89790>>>    Function _SqlTableArrayDAW Returns String[]
89792>>>        String[] sReturnArray   
89793>>>        String sTable sTableType sSchema sDefSchema sComment sTableKeyWord sSysKeyWord
89793>>>        Handle hoSQLHandler
89793>>>        Integer iCount iSize iItem
89793>>>        Boolean bOK   
89793>>>        tSQLConnection SQLConnection
89793>>>        tSQLConnection SQLConnection
89793>>>        
89793>>>        Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
89794>>>        If (SQLConnection.sConnectionString = "") Begin
89796>>>            Function_Return sReturnArray
89797>>>        End 
89797>>>>
89797>>>        
89797>>>        Move SQLConnection.sSchema      to sDefSchema
89798>>>        Move (Uppercase(sDefSchema))    to sDefSchema
89799>>>        Get _SqlFindKeyWord CI_SQLTable to sTableKeyWord
89800>>>        Get _SqlFindKeyWord CI_SQLSys   to sSysKeyWord
89801>>>
89801>>>        Get phoCLIHandler to hoSQLHandler             
89802>>>        Set psDriverID    of hoSQLHandler to SQLConnection.sDriverID
89803>>>        Send Delete_Data  of hoSQLHandler
89804>>>
89804>>>        Send Ignore_Error of Error_Object_Id CLIERR_LOGIN_UNSUCCESSFUL
89805>>>        Get EnumerateTables of hoSQLHandler SQLConnection.sConnectionString to iSize 
89806>>>        Move False to Err
89807>>>        Decrement iSize
89808>>>
89808>>>        For iCount from 0 to iSize
89814>>>>
89814>>>            Get TableName    of hoSQLHandler iCount to sTable
89815>>>            Get TableType    of hoSQLHandler iCount to sTableType 
89816>>>            Get SchemaName   of hoSQLHandler iCount to sSchema
89817>>>            Get TableComment of hoSQLHandler iCount to sComment
89818>>>            Move (Trim(sTable)) to sTable
89819>>>            If (SQLConnection.sDriverID = DB2_DRV_ID) Begin
89821>>>                Move (sTable <> "" and Uppercase(sTableType) = sTableKeyWord and Uppercase(sSchema) = sDefSchema) to bOK
89822>>>            End
89822>>>>
89822>>>            Else Begin
89823>>>                Move (sTable <> "" and Uppercase(sTableType) = sTableKeyWord and Uppercase(sSchema) <> sSysKeyWord and Uppercase(sSchema) <> "SYSTOOLS") to bOK
89824>>>            End
89824>>>>
89824>>>            If (bOK = True) Begin
89826>>>                Move sTable to sReturnArray[iItem]
89827>>>                Increment iItem
89828>>>            End
89828>>>>
89828>>>        Loop
89829>>>>
89829>>>
89829>>>        Send Trap_Error of Error_Object_Id CLIERR_LOGIN_UNSUCCESSFUL
89830>>>
89830>>>        Function_Return sReturnArray
89831>>>    End_Function
