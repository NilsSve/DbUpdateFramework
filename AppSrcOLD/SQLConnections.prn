94489>>>>>>>>>use VDFBase.pkg
94489>>>>>>>>>
94489>>>>>>>>>Class cFormatter is an cObject
94490>>>>>>>>>
94490>>>>>>>>>    Procedure Construct_object
94492>>>>>>>>>        Integer iCh
94492>>>>>>>>>        forward send construct_object
94494>>>>>>>>>        Property String  psCurrencySymbol
94495>>>>>>>>>        Set psCurrencySymbol to (Default_Currency_Symbol())
94496>>>>>>>>>
94496>>>>>>>>>        Property string  psLeft
94497>>>>>>>>>        Property string  psright
94498>>>>>>>>>        Property integer pbThousandsSep
94499>>>>>>>>>        Property integer piPoints
94500>>>>>>>>>
94500>>>>>>>>>        Property string  psCurPosLeft
94501>>>>>>>>>        Property string  psCurPosright
94502>>>>>>>>>        Property integer pbCurPosThousandsSep
94503>>>>>>>>>        Property integer piCurPosPoints
94504>>>>>>>>>
94504>>>>>>>>>        Property string  psCurNegLeft
94505>>>>>>>>>        Property string  psCurNegright
94506>>>>>>>>>        Property integer pbCurNegThousandsSep
94507>>>>>>>>>        Property integer piCurNegPoints
94508>>>>>>>>>
94508>>>>>>>>>        Property string  psNumPosLeft
94509>>>>>>>>>        Property string  psNumPosright
94510>>>>>>>>>        Property integer pbNumPosThousandsSep
94511>>>>>>>>>        Property integer piNumPosPoints
94512>>>>>>>>>
94512>>>>>>>>>        Property string  psNumNegLeft
94513>>>>>>>>>        Property string  psNumNegright
94514>>>>>>>>>        Property integer pbNumNegThousandsSep
94515>>>>>>>>>        Property integer piNumNegPoints
94516>>>>>>>>>
94516>>>>>>>>>        Send SetFormat "$,#.##;($,#.##)" true  // currency
94517>>>>>>>>>        Send SetFormat  ",#.*"           false // numeric
94518>>>>>>>>>
94518>>>>>>>>>    end_procedure
94519>>>>>>>>>
94519>>>>>>>>>    // internal
94519>>>>>>>>>    // parse passed format string and set temporary properties with result
94519>>>>>>>>>    //
94519>>>>>>>>>    Procedure ParseFormat string sFmt
94521>>>>>>>>>
94521>>>>>>>>>        string sLeft sRight sDigit
94521>>>>>>>>>        integer bSep iPos i iDigits
94521>>>>>>>>>
94521>>>>>>>>>        // replace any literals. A "/" followed by anything.
94521>>>>>>>>>        // some literals are special. $ . , / #
94521>>>>>>>>>        Move (Replaces("/$",sFmt,Character(1)))    to sFmt
94522>>>>>>>>>        Move (Replaces("/.",sFmt,Character(2)))    to sFmt
94523>>>>>>>>>        Move (Replaces("/,",sFmt,Character(3)))    to sFmt
94524>>>>>>>>>        Move (Replaces("/"+"/",sFmt,Character(4))) to sFmt
94525>>>>>>>>>        Move (Replaces("/#",sFmt,Character(5)))    to sFmt
94526>>>>>>>>>        Move (Character(9)) to sDigit
94527>>>>>>>>>        Move (Replaces("#",sFmt,sDigit))           to sFmt
94528>>>>>>>>>        Move (Replaces("/",sFmt,""))               to sFmt // replace all others
94529>>>>>>>>>
94529>>>>>>>>>        Move (Pos(",",sFmt))                 to bSep // if we have any , we use thousand seps
94530>>>>>>>>>        If bSep Move (Replaces(",",sFmt,"")) to sFmt // remove all ,
94533>>>>>>>>>
94533>>>>>>>>>        Move (Replaces("$",sFmt,psCurrencySymbol(self))) to sFmt // replace any $ with currency symbol
94534>>>>>>>>>
94534>>>>>>>>>        Move (Pos(".",sFmt)) to iPos                 // position of decimal
94535>>>>>>>>>
94535>>>>>>>>>        // Move all the special literals back into place before parsing
94535>>>>>>>>>        Move (Replaces(Character(1),sFmt,"$")) to sFmt
94536>>>>>>>>>        Move (Replaces(Character(2),sFmt,".")) to sFmt
94537>>>>>>>>>        Move (Replaces(Character(3),sFmt,",")) to sFmt
94538>>>>>>>>>        Move (Replaces(Character(4),sFmt,"/")) to sFmt
94539>>>>>>>>>        Move (Replaces(Character(5),sFmt,"#")) to sFmt
94540>>>>>>>>>
94540>>>>>>>>>        If (iPos>0) Begin                      // if we have a decimanl point
94542>>>>>>>>>            Move 1 to i                        // look for first non # to right and count the #s
94543>>>>>>>>>            If (mid(sFmt,1,iPos+i)="*") Begin  // the "*" is special. It means as many as you want
94545>>>>>>>>>               Move -2 to iDigits
94546>>>>>>>>>               increment i
94547>>>>>>>>>            end
94547>>>>>>>>>>
94547>>>>>>>>>            While (mid(sFmt,1,iPos+i)=sDigit)
94551>>>>>>>>>                 Increment i
94552>>>>>>>>>            end
94553>>>>>>>>>>
94553>>>>>>>>>            Move (Mid(sFmt,255,iPos+i)) to sRight // everything to the right of the last # is format stuff
94554>>>>>>>>>            If (iDigits=0) Move (i-1) to iDigits
94557>>>>>>>>>            //
94557>>>>>>>>>            Move 1 to i                           // find the first non-# to the left of the point
94558>>>>>>>>>            While (mid(sFmt,1,iPos-i)=sDigit)     // everything to the left is format stuff
94562>>>>>>>>>                 increment i
94563>>>>>>>>>            end
94564>>>>>>>>>>
94564>>>>>>>>>            Move (left(sFmt,iPos-i)) to sLeft
94565>>>>>>>>>        end
94565>>>>>>>>>>
94565>>>>>>>>>        else begin                             // we have no decinal
94566>>>>>>>>>            Move 0 to iDigits                  // so points is none
94567>>>>>>>>>            Move (Pos(sDigit,sFmt)) to iPos    // find first #.
94568>>>>>>>>>            If (iPos=0) Begin                  // if none, entire string is left format stuff..wierd!
94570>>>>>>>>>                Move sFmt to sLeft
94571>>>>>>>>>                Move ""   to sRight
94572>>>>>>>>>            end
94572>>>>>>>>>>
94572>>>>>>>>>            else begin
94573>>>>>>>>>                Move (left(sFmt,iPos-1)) to sLeft // all char to left of first # is left format stuff
94574>>>>>>>>>                Move 1 to i
94575>>>>>>>>>                While (mid(sFmt,1,iPos+i)=sDigit) // find last #, all char to right is right format
94579>>>>>>>>>                    Increment i
94580>>>>>>>>>                end
94581>>>>>>>>>>
94581>>>>>>>>>                Move (Mid(sFmt,255,i+iPos)) to sRight
94582>>>>>>>>>            end
94582>>>>>>>>>>
94582>>>>>>>>>        end
94582>>>>>>>>>>
94582>>>>>>>>>        // set temporary format properties and exit
94582>>>>>>>>>        Set pbThousandsSep to bSep
94583>>>>>>>>>        set psLeft         to sLeft
94584>>>>>>>>>        set psRight        to sRight
94585>>>>>>>>>        Set piPoints       to iDigits
94586>>>>>>>>>     End_procedure
94587>>>>>>>>>
94587>>>>>>>>>    // Public: Sets a format string. Pass full format for Positve and negative in sFmt. Pass
94587>>>>>>>>>    //         bCurrency true is this is a currency format, false if a numeric format
94587>>>>>>>>>    //
94587>>>>>>>>>    //  e.g. Send SetFormat "$,#.##;($,#.##)" True
94587>>>>>>>>>    //
94587>>>>>>>>>    Procedure SetFormat string sFmt integer bCurrency
94589>>>>>>>>>        string sPos sNeg
94589>>>>>>>>>        integer iPos
94589>>>>>>>>>
94589>>>>>>>>>        Move (Pos(";",sFmt)) to iPos
94590>>>>>>>>>        If iPos begin
94592>>>>>>>>>            Move (left(sFmt,iPos-1))    to sPos
94593>>>>>>>>>            Move (mid(sFmt,255,iPos+1)) to sNeg
94594>>>>>>>>>        end
94594>>>>>>>>>>
94594>>>>>>>>>        else Begin
94595>>>>>>>>>            Move sFmt         to sPos
94596>>>>>>>>>            Move ("-" + sFmt) to sNeg
94597>>>>>>>>>        end
94597>>>>>>>>>>
94597>>>>>>>>>        Send ParseFormat sPos
94598>>>>>>>>>        If bCurrency begin
94600>>>>>>>>>            Set pbCurPosThousandsSep to (pbThousandsSep(self))
94601>>>>>>>>>            set psCurPosLeft         to (psLeft(self))
94602>>>>>>>>>            set psCurPosRight        to (psRight(self))
94603>>>>>>>>>            Set piCurPosPoints       to (piPoints(self))
94604>>>>>>>>>        End
94604>>>>>>>>>>
94604>>>>>>>>>        else Begin
94605>>>>>>>>>            Set pbNumPosThousandsSep to (pbThousandsSep(self))
94606>>>>>>>>>            set psNumPosLeft         to (psLeft(self))
94607>>>>>>>>>            set psNumPosRight        to (psRight(self))
94608>>>>>>>>>            Set piNumPosPoints       to (piPoints(self))
94609>>>>>>>>>        end
94609>>>>>>>>>>
94609>>>>>>>>>
94609>>>>>>>>>        Send ParseFormat sNeg
94610>>>>>>>>>        If bCurrency begin
94612>>>>>>>>>            Set pbCurNegThousandsSep to (pbThousandsSep(self))
94613>>>>>>>>>            set psCurNegLeft         to (psLeft(self))
94614>>>>>>>>>            set psCurNegRight        to (psRight(self))
94615>>>>>>>>>            Set piCurNegPoints       to (piPoints(self))
94616>>>>>>>>>        End
94616>>>>>>>>>>
94616>>>>>>>>>        else Begin
94617>>>>>>>>>            Set pbNumNegThousandsSep to (pbThousandsSep(self))
94618>>>>>>>>>            set psNumNegLeft         to (psLeft(self))
94619>>>>>>>>>            set psNumNegRight        to (psRight(self))
94620>>>>>>>>>            Set piNumNegPoints       to (piPoints(self))
94621>>>>>>>>>        end
94621>>>>>>>>>>
94621>>>>>>>>>    End_procedure
94622>>>>>>>>>
94622>>>>>>>>>    // low level formatting. Pass parameters
94622>>>>>>>>>    Function Format_Num number nNumber integer iPoints integer bSep ;                       string sPrefix string sSuffix returns string
94624>>>>>>>>>        string  sLeft sRight sNumber sSep sDec
94624>>>>>>>>>        integer bIsNegative iDec iLen iCh
94624>>>>>>>>>
94624>>>>>>>>>        Get_Attribute DF_DECIMAL_SEPARATOR to iCh
94627>>>>>>>>>        Move (Character(iCh)) to sDec
94628>>>>>>>>>
94628>>>>>>>>>        Move (abs(nNumber)) to sNumber
94629>>>>>>>>>        Move (Pos(sDec,sNumber)) to iDec
94630>>>>>>>>>        Move (If(iDec=0, sNumber, left(sNumber,iDec-1))) to sLeft
94631>>>>>>>>>        Move (If(iDec=0, "", mid(sNumber,255,iDec+1)))   to sRight
94632>>>>>>>>>        // format for decimal separator
94632>>>>>>>>>        If (iPoints>=0) ; // if -2, leave it alone, it should not be -1            Move (left(sRight+repeat("0",iPoints),iPoints)) to sRight
94635>>>>>>>>>
94635>>>>>>>>>        // format for thousand sep.
94635>>>>>>>>>        If bSep Begin
94637>>>>>>>>>            Get_Attribute DF_THOUSANDS_SEPARATOR to iCh
94640>>>>>>>>>            Move (Character(iCh)) to sSep
94641>>>>>>>>>            Move (Length(sLeft)) to iLen
94642>>>>>>>>>            While (iLen>3)
94646>>>>>>>>>                Move (insert(sSep,sLeft,iLen-2)) to sLeft
94647>>>>>>>>>                Move (iLen-3) to iLen
94648>>>>>>>>>            End
94649>>>>>>>>>>
94649>>>>>>>>>        End
94649>>>>>>>>>>
94649>>>>>>>>>        // if decimal points or -2 (allow anything) and there are points to show
94649>>>>>>>>>        If (iPoints>0 OR (iPoints=-2 AND sRight<>"")) ;            Move (sLeft + sDec + sright) to sLeft
94652>>>>>>>>>        Function_return (sPrefix + sLeft+ sSuffix)
94653>>>>>>>>>    End_Function
94654>>>>>>>>>
94654>>>>>>>>>    // Public: Format for currency
94654>>>>>>>>>    //
94654>>>>>>>>>    Function FormatCur number nNumber integer iPoints returns string
94656>>>>>>>>>        string  sLeft sRight
94656>>>>>>>>>        integer bSep
94656>>>>>>>>>        If (nNumber<0) Begin
94658>>>>>>>>>            get pbCurNegThousandsSep to bSep
94659>>>>>>>>>            get psCurNegLeft         to sLeft
94660>>>>>>>>>            get psCurNegRight        to sRight
94661>>>>>>>>>            If (iPoints=-1) get piCurNegPoints       to iPoints
94664>>>>>>>>>        end
94664>>>>>>>>>>
94664>>>>>>>>>        Else Begin
94665>>>>>>>>>            get pbCurPosThousandsSep to bSep
94666>>>>>>>>>            get psCurPosLeft         to sLeft
94667>>>>>>>>>            get psCurPosRight        to sRight
94668>>>>>>>>>            If (iPoints=-1) get piCurPosPoints       to iPoints
94671>>>>>>>>>        end
94671>>>>>>>>>>
94671>>>>>>>>>        Function_return (Format_Num(self, nNumber,iPoints,bSep,sLeft,sRight))
94672>>>>>>>>>    End_function
94673>>>>>>>>>
94673>>>>>>>>>    // Public: Format for numeric
94673>>>>>>>>>    //
94673>>>>>>>>>    Function FormatNum number nNumber integer iPoints returns string
94675>>>>>>>>>        string  sLeft sRight
94675>>>>>>>>>        integer bSep
94675>>>>>>>>>        If (nNumber<0) Begin
94677>>>>>>>>>            get pbNumNegThousandsSep to bSep
94678>>>>>>>>>            get psNumNegLeft         to sLeft
94679>>>>>>>>>            get psNumNegRight        to sRight
94680>>>>>>>>>            If (iPoints=-1) get piNumNegPoints       to iPoints
94683>>>>>>>>>        end
94683>>>>>>>>>>
94683>>>>>>>>>        Else Begin
94684>>>>>>>>>            get pbNumPosThousandsSep to bSep
94685>>>>>>>>>            get psNumPosLeft         to sLeft
94686>>>>>>>>>            get psNumPosRight        to sRight
94687>>>>>>>>>            If (iPoints=-1) get piNumPosPoints       to iPoints
94690>>>>>>>>>        end
94690>>>>>>>>>>
94690>>>>>>>>>        Function_return (Format_Num(self, nNumber,iPoints,bSep,sLeft,sRight))
94691>>>>>>>>>    End_function
94692>>>>>>>>>
94692>>>>>>>>>
94692>>>>>>>>>    // Public: Format passing format string
94692>>>>>>>>>    //
94692>>>>>>>>>    Function FormatVal number nNumber string sFmt returns string
94694>>>>>>>>>        integer iPos bIsNeg
94694>>>>>>>>>        string  sLeft sRight
94694>>>>>>>>>        integer iPoints bSep
94694>>>>>>>>>        Move (nNumber<0) to bIsNeg
94695>>>>>>>>>        Move (Pos(";",sFmt)) to iPos
94696>>>>>>>>>        Case Begin
94696>>>>>>>>>            Case (iPos and Not(bIsNeg))      Move (left(sFmt,iPos-1))    to sFmt
94699>>>>>>>>>            Case (iPos and bIsNeg)           Move (mid(sFmt,255,iPos+1)) to sFmt
94703>>>>>>>>>            Case (not(iPos) and not(bIsNeg)) Move sFmt                   to sFmt
94707>>>>>>>>>            Case else                        Move ("-" + sFmt)           to sFmt
94709>>>>>>>>>        case end
94709>>>>>>>>>        Send ParseFormat sFmt
94710>>>>>>>>>        get pbThousandsSep to bSep
94711>>>>>>>>>        get psLeft         to sLeft
94712>>>>>>>>>        get psRight        to sRight
94713>>>>>>>>>        get piPoints       to iPoints
94714>>>>>>>>>        Function_return (Format_Num(self, nNumber,iPoints,bSep,sLeft,sRight))
94715>>>>>>>>>    end_function
94716>>>>>>>>>
94716>>>>>>>>>End_Class
