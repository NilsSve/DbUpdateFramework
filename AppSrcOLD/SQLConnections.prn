94887>>>>>>>>>>>
94887>>>>>>>>>>>    // Request context help. If context is a number assume that it is
94887>>>>>>>>>>>    // context id help, else assume it is keyword help.
94887>>>>>>>>>>>    //
94887>>>>>>>>>>>    Procedure Exec_Context_Help string Context
94889>>>>>>>>>>>       if (left(context,1)) in '0123456789' ;    // if first character is a          Send Exec_System_Context_Help Context  // numeric we assume ID help
94892>>>>>>>>>>>       else ;                                    // otherwise we assume key-          Send Exec_System_Help Context          // word help.
94894>>>>>>>>>>>    End_Procedure // Exec_Context_Help
94895>>>>>>>>>>>
94895>>>>>>>>>>>    // NOTE: the following two messages are the only messages that directly make calls
94895>>>>>>>>>>>    //       to the windows API. This is important. These two messages could be changed
94895>>>>>>>>>>>    //       to call other help systems (e.g. HTML help) and the rest of the high level
94895>>>>>>>>>>>    //       program remains the same. These are the only two messages that are
94895>>>>>>>>>>>    //       expected to be windows help centric.
94895>>>>>>>>>>>
94895>>>>>>>>>>>    // Get Context Id help for passed ID. Use help file as defined
94895>>>>>>>>>>>    // in Help_filename. If id is 0 use general help id (which must be
94895>>>>>>>>>>>    // defined.
94895>>>>>>>>>>>    //
94895>>>>>>>>>>>    Procedure Exec_System_Context_Help integer Context_id
94897>>>>>>>>>>>        If Context_Id eq 0 ; // if zero, see if we have a contents page            Move (Help_Id_General(self)) to Context_id
94900>>>>>>>>>>>        If Context_Id eq 0 ; // if still zero, jump to the topics popup dialog            Send Exec_System_Help HELP_ON_TOPIC_STRING
94903>>>>>>>>>>>        Else ;            Send gDoWinHelp WH_INTCONTEXT (Help_Filename(self)) Context_Id
94905>>>>>>>>>>>    end_procedure
94906>>>>>>>>>>>
94906>>>>>>>>>>>    // Get keyword help for passed keyword. Use help file as defined
94906>>>>>>>>>>>    // in help_filename.
94906>>>>>>>>>>>    //
94906>>>>>>>>>>>    procedure Exec_System_Help string Keyword
94908>>>>>>>>>>>        If Keyword eq HELP_FOR_HELP_STRING ;            Send gDoWinHelp WH_HELPONHELP
94911>>>>>>>>>>>        else if (Keyword eq HELP_ON_TOPIC_STRING OR KeyWord="");            Send gDoWinHelp WH_FINDER (Help_Filename(self))
94915>>>>>>>>>>>        else ;            Send gDoWinHelp WH_STRINGCONTEXT (Help_Filename(self)) KeyWord
94917>>>>>>>>>>>    end_procedure
94918>>>>>>>>>>>
94918>>>>>>>>>>>end_class
