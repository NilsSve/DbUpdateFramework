91217>>>    // To delete an index
91217>>>    Function ApiIndexRemove Handle hTable Integer iIndex Returns Boolean
91219>>>        Integer iTableNo iNumSegments
91219>>>        String sDriverID
91219>>>        Boolean bOK
91219>>>        
91219>>>        Get AutoConnectionIDLogin to bOK
91220>>>        Move False to Err
91221>>>        Move hTable to iTableNo
91222>>>        Open hTable Mode DF_EXCLUSIVE
91224>>>        Get_Attribute DF_FILE_DRIVER of hTable to sDriverID
91227>>>        
91227>>>        // Check to see if the index exists or not...
91227>>>        Get_Attribute DF_INDEX_NUMBER_SEGMENTS of hTable iIndex to iNumSegments
91230>>>        If (iNumSegments = 0) Begin
91232>>>            Function_Return False
91233>>>        End
91233>>>>
91233>>>        
91233>>>        Structure_Start hTable sDriverID
91234>>>            Send Ignore_Error of Error_Object_Id DFERR_BAD_PARAMETER
91235>>>            Delete_Index iTableNo iIndex
91236>>>            Send Trap_Error of Error_Object_Id DFERR_BAD_PARAMETER
91237>>>        Structure_End hTable DF_STRUCTEND_OPT_NONE
91239>>>
91239>>>        Function_Return (Err = False)
