86661>>>    Function DriverIndex String sDriverID Returns Integer
86663>>>        String  sCurrentDriver
86663>>>        Integer iNumberOfDrivers iDriver iCount iRetval
86663>>>        
86663>>>        Move 0 to iDriver
86664>>>        Get_Attribute DF_NUMBER_DRIVERS to iNumberOfDrivers
86667>>>        For iCount from 1 to iNumberOfDrivers
86673>>>>
86673>>>            Get_Attribute DF_DRIVER_NAME of iCount to sCurrentDriver
86676>>>            If ( Uppercase(sCurrentDriver) = Uppercase(sDriverID) ) Begin
86678>>>                Function_Return iCount
86679>>>            End
86679>>>>
86679>>>        Loop
86680>>>>
86680>>>        
86680>>>        // If driver not previously loaded; attempt to do so now.
86680>>>        If (iDriver = 0) Begin
86682>>>            Move 0 to LastErr
86683>>>            Load_Driver sDriverID   
86684>>>            // If driver could not be loaded.
86684>>>            If (LastErr = 4255) Begin
86686>>>                Move 0 to iCount
86687>>>            End
86687>>>>
86687>>>            Function_Return iCount
86688>>>        End
86688>>>>
86688>>>        Function_Return 0
86689>>>    End_Function
