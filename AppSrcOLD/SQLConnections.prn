98300>>>        Function IsOneItemActive Returns Boolean
98303>>>            Handle hoDataSource ho
98303>>>            tDataSourceRow[] TheData
98303>>>            tDataSourceRow[] TheData
98304>>>            Integer iSize iCount
98304>>>            Boolean bRetval bExists
98304>>>            String sSection
98304>>>
98304>>>            Get phoSQLConnectionIniFile of ghoSQLConnectionHandler to ho
98305>>>            Get psIniSectionName of ho to sSection
98306>>>            Get SectionExists    of ho sSection to bExists
98307>>>
98307>>>            Get phoDataSource to hoDataSource
98308>>>            Get DataSource of hoDataSource to TheData
98309>>>
98309>>>            Move (SizeOfArray(TheData)) to iSize
98310>>>            If (iSize = 0) Begin
98312>>>                Function_Return True
98313>>>            End    
98313>>>>
98313>>>            
98313>>>            Decrement iSize
98314>>>            For iCount from 0 to iSize
98320>>>>
98320>>>                If (TheData[iCount].sValue[piColumnId(oActive_Col(Self))] = True) Begin
98322>>>                    Move True to bRetval
98323>>>                End
98323>>>>
98323>>>            Loop
98324>>>>
98324>>>
98324>>>            Function_Return bRetval
98325>>>        End_Function
