91407>>>>
91407>>>        Move (Found = True) to bFound
91408>>>        If (bFound = True) Begin
91410>>>            Delete CODEMAST
91411>>>        End
91411>>>>
91411>>>        
91411>>>        Close CodeMast
91412>>>        
91412>>>        Function_Return (Err = False)
91413>>>    End_Function
91414>>>
91414>>>    // Note:
91414>>>    // The DF_FILE_TABLE_NAME attribute holds the name of the table at the back end. Depending on the back end, table 
91414>>>    // names may be case sensitive, contain spaces or other special characters. This attribute is used to determine a table's 
91414>>>    // back end name when using Embedded SQL. Since Embedded SQL works on the back end directly, the back end's name must be used. 
91414>>>    // In most cases the back end name will be the same as the table name used in DataFlex.
91414>>>    // To do the opposite; To get the file handle from a table name string use the UtilTableNameToHandle function.
91414>>>    Function UtilTableHandleToString Handle hTable Returns String
91416>>>        String sTableName
91416>>>        Boolean bOpen bExists bRecnum bOK
91416>>>        
91416>>>        Get UtilTableNumberIsInUse hTable to bExists
91417>>>        If (bExists = False) Begin
91419>>>            Move True to Err
91420>>>            Function_Return ""
91421>>>        End
91421>>>>
91421>>>
91421>>>        Set Error_Report_Mode to DUF_ERROR_NO_REPORT
91422>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpen
91425>>>        If (bOpen = False) Begin                       
91427>>>            Get AutoConnectionIDLogin to bOK
91428>>>            Send Ignore_Error of Error_Object_Id DFERR_CANT_OPEN_DATA_FILE
91429>>>            Send Ignore_Error of Error_Object_Id DFERR_CANT_OPEN_INTERMEDIATE_FILE
91430>>>            Send Ignore_Error of Error_Object_Id CLIERR_GENERAL_ERROR
91431>>>            Open hTable
91433>>>            Send Trap_Error of Error_Object_Id DFERR_CANT_OPEN_DATA_FILE
91434>>>            Send Trap_Error of Error_Object_Id DFERR_CANT_OPEN_INTERMEDIATE_FILE
91435>>>            Send Trap_Error of Error_Object_Id CLIERR_GENERAL_ERROR
91436>>>            Get_Attribute DF_FILE_OPENED of hTable to bOpen
91439>>>        End
91439>>>>
91439>>>        If (bOpen = True) Begin
91441>>>            Send Ignore_Error of Error_Object_Id DFERR_UNSUPPORTED_ATTRIBUTE 
91442>>>            Get_Attribute DF_FILE_TABLE_NAME of hTable to sTableName 
91445>>>            // If blank it is an embedded table:
91445>>>            If (sTableName = "") Begin
91447>>>                Get_Attribute DF_FILE_LOGICAL_NAME of hTable to sTableName 
91450>>>                Move 0 to LastErr
91451>>>                Move False to Err
91452>>>            End
91452>>>>
91452>>>            Send Trap_Error of Error_Object_Id DFERR_UNSUPPORTED_ATTRIBUTE
91453>>>        End
91453>>>>
91453>>>        Set Error_Report_Mode to DUF_ERROR_REPORT
91454>>>            
91454>>>        Function_Return sTableName
91455>>>    End_Function
91456>>>    
91456>>>    // Returns the filenumber for the passed Table name from Filelist.cfg.
91456>>>    // Returns 0 if unsuccessful.
91456>>>    // To do the opposite; To get the string value from a table handle string use the UtilTableHandleToString function.
91456>>>    Function UtilTableNameToHandle String sTableName Returns Integer
91458>>>        String sValue sPrefixTableName sDriverID
91458>>>        Handle hTable hRetval
91458>>>        
91458>>>        Get psDriverID to sDriverID 
91459>>>        If (sDriverID <> DATAFLEX_ID and not(sTableName contains ":")) Begin
91461>>>            Move (sDriverID + ":" + sTableName) to sPrefixTableName
91462>>>        End
91462>>>>
91462>>>        Move 0 to hTable 
91463>>>        Move 0 to hRetval
91464>>>        Repeat 
91464>>>>
91464>>>            Get_Attribute DF_FILE_NEXT_USED of hTable to hTable
91467>>>            If (hTable <> 0) Begin
91469>>>                Get_Attribute DF_FILE_ROOT_NAME of hTable to sValue
91472>>>                If (Uppercase(sValue) = Uppercase(sTableName) or Uppercase(sValue) = Uppercase(sPrefixTableName)) Begin
91474>>>                    Move hTable to hRetval
91475>>>                    Move 0 to hTable
91476>>>                End
91476>>>>
91476>>>            End
91476>>>>
91476>>>        Until (hTable = 0)
91478>>>        
91478>>>        Function_Return hRetval
91479>>>    End_Function
91480>>>        
91480>>>    // Check if the file exists in the Data folder,
91480>>>    // else creates it from memory as it has been compiled into the program as a resource:
91480>>>    Function UtilCheckCreateIfFileExists String sFileName String sResourceName Boolean bDataFile Returns Boolean
91482>>>        String sPath sDataPath
91482>>>        Boolean bExists
91482>>>    
91482>>>        Get psDataPathFirstPart to sPath
91483>>>        Move (sPath + sFileName) to sFileName
91484>>>        Get vFilePathExists sFileName to bExists
91485>>>    
91485>>>        If (bExists = False) Begin
91487>>>            // Read from memory & create file on disk.
91487>>>            Send SqlUtilCreateFileFromMemory sResourceName sFileName
91488>>>            Get vFilePathExists sFileName to bExists
91489>>>        End     
91489>>>>
91489>>>        Function_Return bExists
91490>>>    End_Function
