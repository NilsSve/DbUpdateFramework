97415>>>>>    Function IsConnectionIDDuplicate tSQLConnection SQLConnection Returns Boolean
97418>>>>>        Integer iCount iSize iItems iCurrentRow
97418>>>>>        String sValue sConnectionID
97418>>>>>        Boolean bExists 
97418>>>>>        tDataSourceRow[] TheData 
97418>>>>>        tDataSourceRow[] TheData 
97419>>>>>        tDataSourceRow TheRow
97419>>>>>        tDataSourceRow TheRow
97419>>>>>        
97419>>>>>        Move 0 to iItems  
97420>>>>>        Get piCurrentRow to iCurrentRow                   
97421>>>>>        Move SQLConnection.sConnectionID to sConnectionID
97422>>>>>        Get MoveSQLConnectionToGridRow SQLConnection to TheRow      
97423>>>>>        Get pTheData to TheData
97424>>>>>        Move (SizeOfArray(TheData)) to iSize  
97425>>>>>        If (iCurrentRow <> -1) Begin  
97427>>>>>            // This is the sConnectionID:
97427>>>>>            Move TheRow.sValue[2] to TheData[iCurrentRow].sValue[2]
97428>>>>>        End 
97428>>>>>>
97428>>>>>        Else Begin
97429>>>>>            Move TheRow to TheData[iSize]
97430>>>>>        End
97430>>>>>>
97430>>>>>        Move (SizeOfArray(TheData)) to iSize  
97431>>>>>        Decrement iSize
97432>>>>>        For iCount from 0 to iSize
97438>>>>>>
97438>>>>>            Move TheData[iCount].sValue[2] to sValue    
97439>>>>>            Move (sValue = sConnectionID) to bExists
97440>>>>>            If (bExists) Begin
97442>>>>>                Increment iItems
97443>>>>>            End
97443>>>>>>
97443>>>>>        Loop
97444>>>>>>
97444>>>>>                
97444>>>>>        Function_Return (iItems > 1)
97445>>>>>    End_Function       
