89142>>>    // This function allows you to put an Sql script in a CM Image. It makes it easier to
89142>>>    // copy and paste between a DataFlex program and an Sql Editor.
89142>>>    Function SqlUtilLoadImageFile String sFileName Returns String
89144>>>        Integer iChannel iPos
89144>>>        String sTextValue sLine sPath
89144>>>        Boolean bSeqEof
89144>>>        
89144>>>        Move "" to sTextValue        
89145>>>        Get ParseFolderName sFileName to sPath
89146>>>        If (Trim(sPath) = "") Begin
89148>>>            Get psDataPathFirstPart to sPath
89149>>>            Move (sPath + sFileName) to sFileName
89150>>>        End
89150>>>>
89150>>>        
89150>>>        Get Seq_New_Channel to iChannel
89151>>>        If (iChannel = DF_SEQ_CHANNEL_NOT_AVAILABLE) Begin
89153>>>            Error DFERR_PROGRAM "No channel available..."
89154>>>>
89154>>>        End
89154>>>>
89154>>>        Else Begin        
89155>>>            Direct_Input channel iChannel sFileName
89157>>>            Move (SeqEof) to bSeqEof
89158>>>            If (bSeqEof = True) Begin
89160>>>                Send Seq_Release_Channel iChannel 
89161>>>                Set psSQLStatementString to ""  
89162>>>                Error DFERR_PROGRAM ("The Sql script file:\n" + sFileName + "\nCould not be found.")
89163>>>>
89163>>>                Function_Return "" 
89164>>>            End
89164>>>>
89164>>>    
89164>>>            While (not(bSeqEof))
89168>>>                Readln channel iChannel sLine 
89170>>>                Move (Pos("/", sLine)) to iPos
89171>>>                Move (SeqEol) to bSeqEof
89172>>>                If (not(bSeqEof) and iPos <> 1) Begin
89174>>>                    Move (sTextValue + sLine + Character(13)) to sTextValue
89175>>>                End
89175>>>>
89175>>>            Loop
89176>>>>
89176>>>            Send Seq_Release_Channel iChannel
89177>>>        End
89177>>>>
89177>>>        
89177>>>        Set psSQLStatementString to sTextValue
89178>>>        Function_Return sTextValue
89179>>>    End_Function  
