90816>>>    Function ApiTableRename Integer hTable String sRootName String sDisplayName String sLogicalName Returns Boolean
90818>>>        String sPhysicalName sDataPath sDriverID
90818>>>        Boolean bOK bExists
90818>>>        Integer iRetval
90818>>>        
90818>>>        Move False to Err
90819>>>        Get psDataPathFirstPart to sDataPath
90820>>>        Get_Attribute DF_FILE_PHYSICAL_NAME of hTable to sPhysicalName
90823>>>        
90823>>>        Get_Attribute DF_FILE_DRIVER of hTable to sDriverID
90826>>>        Close hTable  
90827>>>        If (sDriverID = DATAFLEX_ID) Begin                    
90829>>>            Get vFilePathExists (sDataPath + sRootName + ".dat") to bExists
90830>>>            If (bExists = True) Begin
90832>>>                If (Uppercase(sPhysicalName) = Uppercase(sRootName)) Begin
90834>>>                    Function_Return False
90835>>>                End
90835>>>>
90835>>>
90835>>>                // ToDo: How do we handle this when the library has been imported into 
90835>>>                // the cDbUpdateVersion Class?
90835>>>                // Get YesNo_Box ("The table:\n" + (sDataPath + sPhysicalName) + "\nis to be renamed to:\n" + (sDataPath + sRootName) + "\nBut the destination already exists. Overwrite?") to iRetval
90835>>>                If (iRetval <> MBR_Yes) Begin
90837>>>                    Function_Return False
90838>>>                End                      
90838>>>>
90838>>>            End                                           
90838>>>>
90838>>>            Copy_db (sDataPath + sPhysicalName) to (sDataPath + sRootName) 
90841>>>        End
90841>>>>
90841>>>        
90841>>>        If (sDriverID <> DATAFLEX_ID) Begin
90843>>>            Move (sDriverID + ":" + sRootName) to sRootName
90844>>>        End
90844>>>>
90844>>>
90844>>>        Set_Attribute DF_FILE_ROOT_NAME     of hTable to sRootName
90847>>>        Set_Attribute DF_FILE_DISPLAY_NAME  of hTable to sDisplayName
90850>>>        Set_Attribute DF_FILE_LOGICAL_NAME  of hTable to sLogicalName
90853>>>        
90853>>>        // We need a short break here before attempting to delete the physical file or Windows
90853>>>        // might report "File in use..." and the deletion will fail.
90853>>>        Sleep 2
90854>>>        If (sDriverID = DATAFLEX_ID) Begin                    
90856>>>            Get vDeleteFile (sDataPath + sPhysicalName + ".*") to bOK
90857>>>        End
90857>>>>
90857>>>        
90857>>>        Function_Return (Err = False)
90858>>>    End_Function
