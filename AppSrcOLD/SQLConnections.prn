87373>>>>Function ParseKeyWord String sConnect String sKeyWord Returns String
87375>>>>    Integer iStart iEnd
87375>>>>    String sRetval
87375>>>>
87375>>>>    Move (Trim(sConnect)) to sConnect
87376>>>>    Move (Pos(Uppercase(sKeyWord), Uppercase(sConnect)))  to iStart
87377>>>>    If (iStart = 0) Begin
87379>>>>        Function_Return ""
87380>>>>    End
87380>>>>>
87380>>>>    Move (Left(sConnect, (iStart -1 + Length(sKeyWord)))) to sRetval
87381>>>>    Move (Replace(sRetval, sConnect, "")) to sRetval 
87382>>>>    If (sKeyWord = Uppercase(CS_SQLConnectionIDText)) Begin
87384>>>>        Move (Pos(",", sRetval))          to iEnd
87385>>>>    End
87385>>>>>
87385>>>>    Else Begin
87386>>>>        Move (Pos(";", sRetval))          to iEnd
87387>>>>    End                                          
87387>>>>>
87387>>>>    If (iEnd = 0 and (sRetval contains ",")) Begin
87389>>>>        Move (Pos(",", sRetval))          to iEnd 
87390>>>>        Decrement iEnd
87391>>>>    End
87391>>>>>
87391>>>>    If (iEnd <> 0) Begin
87393>>>>        Move (Left(sRetval, (iEnd -1)))   to sRetval
87394>>>>    End
87394>>>>>
87394>>>>    Move (Replace("=", sRetval, ""))      to sRetval
87395>>>>
87395>>>>    Function_Return (Trim(sRetval))
87396>>>>End_Function
87397>>>>
