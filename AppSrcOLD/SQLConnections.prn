97478>>>>>        Move SQLConnection.sDriverID         to sConnectionData[4]  
97479>>>>>        Move SQLConnection.sServer           to sConnectionData[5]  
97480>>>>>        Move SQLConnection.sDatabase         to sConnectionData[6]
97481>>>>>        Move SQLConnection.sConnectionString to sConnectionData[7]
97482>>>>>        Move SQLConnection.bTrusted          to sConnectionData[8]
97483>>>>>        Move SQLConnection.sUserID           to sConnectionData[9]
97484>>>>>        
97484>>>>>        If (SQLConnection.sPassword <> "") Begin
97486>>>>>            Move MBR_Yes to iRetval
97487>>>>>            If (pbDFConnId(Self) = True) Begin
97489>>>>>                Get YesNo_Box "You are working with a DAW 'DFConnId.ini' file. Although this program can both read/write to such a file, the password encryption/decryption algorithms are (obviously) different. This password will not be touched. Continue?" to iRetval
97490>>>>>                If (iRetval = MBR_Yes) Begin
97492>>>>>                    Set psUncryptedPw to SQLConnection.sPassword 
97493>>>>>                    Move "" to SQLConnection.sPassword
97494>>>>>                End
97494>>>>>>
97494>>>>>                Else Begin
97495>>>>>                    Send Stop_UI
97496>>>>>                End
97496>>>>>>
97496>>>>>            End
97496>>>>>>
97496>>>>>            Else Begin
