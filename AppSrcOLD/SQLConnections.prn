95588>>>>>    Procedure Set Version String sVersion
95590>>>>>        Handle hoVersionInfo
95590>>>>>        Boolean bIncluded
95590>>>>>        Integer iMajor iMinor iRelease iBuild
95590>>>>>        Date dCompileDate
95590>>>>>
95590>>>>>        If (sVersion = "") Begin
95592>>>>>            // This automatically shows the program version of the program, if available.
95592>>>>>            // It will be displayed as the second item in the edit object.
95592>>>>>            If (ghoApplication <> 0) Begin
95594>>>>>                Get phoVersionInfo of ghoApplication to hoVersionInfo
95595>>>>>                If (hoVersionInfo <> 0) Begin
95597>>>>>                    Get pbIncluded of hoVersionInfo to bIncluded
95598>>>>>                    If (bIncluded) Begin
95600>>>>>                        Get piVersionMajor of hoVersionInfo to iMajor
95601>>>>>                        Get piVersionMinor of hoVersionInfo to iMinor
95602>>>>>                        Get piVersionRelease of hoVersionInfo to iRelease
95603>>>>>                        Get piVersionBuild of hoVersionInfo to iBuild
95604>>>>>                        Move (SFormat (C_$VERSION + ": %1.%2.%3.%4", iMajor, iMinor, iRelease, iBuild)) to sVersion
95605>>>>>                    End
95605>>>>>>
95605>>>>>                End
95605>>>>>>
95605>>>>>            End
95605>>>>>>
95605>>>>>        End
95605>>>>>>
95605>>>>>
95605>>>>>        // Display the compiled date as the next row in the edit object, after the program version.
95605>>>>>        Get GetCompileDate to dCompileDate
95606>>>>>        If (sVersion <> "") Begin
95608>>>>>            Send Add_Lineln (sVersion + (Character(13)) + C_$Compile_Date * String(dCompileDate))
95609>>>>>        End
95609>>>>>>
95609>>>>>    End_Procedure
95610>>>>>
95610>>>>>    Function GetCompileDate Returns Date
95612>>>>>        Date dCompileDate
95612>>>>>        String sAppFilename sData sCompileDate
95612>>>>>        Integer iChannel iPos iDateFormat
95612>>>>>
95612>>>>>        // Get full path to the current running executable
95612>>>>>        Get GetApplicationFileName of ghoApplication to sAppFilename
95613>>>>>
95613>>>>>        //Read the current file  up to where the data we're interesting in is (this was hand calced and so could vary)
95613>>>>>        Get Seq_Open_Input_Channel ("binary:" * sAppFilename) to iChannel
95614>>>>>        Read_Block channel iChannel sData (8 * 1024)    // First 8K is .exe header skip it
95616>>>>>        Read_Block channel iChannel sData 75            // The compile information we're interested in
95618>>>>>        Send Seq_Close_Channel iChannel
95619>>>>>
95619>>>>>        // The data is padded with Character(0)s. Strip them out
95619>>>>>        Move (CString(sData)) to sData
95620>>>>>
95620>>>>>        // The compile date is after the first ", ", so string parsing is required
95620>>>>>        Move (Pos(", ", sData)) to iPos
95621>>>>>        Move (Mid(sData, 10, (iPos + 2) ))  to sCompileDate // In US format
95622>>>>>        // If the current date format is non US, we need to temporary
95622>>>>>        // change the format and then move the string to the date variable.
95622>>>>>        Get_Attribute DF_DATE_FORMAT        to iDateFormat
95625>>>>>        Set_Attribute DF_DATE_FORMAT        to DF_DATE_USA
95628>>>>>        Move (Date(sCompileDate))           to dCompileDate
95629>>>>>        Set_Attribute DF_DATE_FORMAT        to iDateFormat // Reset date format
95632>>>>>
95632>>>>>        Function_Return dCompileDate
95633>>>>>    End_Function
