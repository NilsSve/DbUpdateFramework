89180>>>    Function SqlUtilUpdateIntFile Integer hTable Returns Boolean           
89182>>>        String sOrgFormat sNewFormat sRootName sDatabaseName sPhysicalFileName sDriverID sDataPath         
89182>>>        Boolean bOpened bOK bMertech
89182>>>        
89182>>>        Move CS_OEM_Txt  to sOrgFormat
89183>>>        Move CS_ANSI_Txt to sNewFormat
89184>>>        Get AutoConnectionIDLogin to bOK
89185>>>        Send Ignore_Error of Error_Object_Id DFERR_MISSING_VALUE
89186>>>        Open hTable //Mode DF_EXCLUSIVE
89188>>>        Send Trap_Error of Error_Object_Id DFERR_MISSING_VALUE
89189>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpened
89192>>>        
89192>>>        // ToDo: What to do if we cannot open the table?!
89192>>>        If (bOpened = False) Begin
89194>>>            Function_Return False
89195>>>        End
89195>>>>
89195>>>        
89195>>>        Get psDriverID to sDriverID
89196>>>        Get IsMertechDriver sDriverID to bMertech
89197>>>        If (bMertech = True) Begin       
89199>>>            Get psDataPathFirstPart to sDataPath
89200>>>            Get vFolderExists sDataPath to bOK
89201>>>            If (bOK = False) Begin
89203>>>                Error DFERR_PROGRAM "Function SqlUtilUpdateIntFile; psDataPath not found!"
89204>>>>
89204>>>                Function_Return False    
89205>>>            End                      
89205>>>>
89205>>>            Get vFolderFormat sDataPath to sDataPath 
89206>>>            Get_Attribute DF_FILE_ROOT_NAME of hTable to sRootName
89209>>>            Get _TableNameOnly sRootName to sDatabaseName
89210>>>            Move sDatabaseName to sPhysicalFileName
89211>>>            Move (sPhysicalFileName + ".int") to sPhysicalFileName
89212>>>            Get _MertechSqlUtilCreateIntFile hTable sDataPath sPhysicalFileName to bOK
89213>>>            Function_Return (bOK = True)
89214>>>        End
89214>>>>
89214>>>        
89214>>>        Move False to Err
89215>>>        Get_Attribute DF_FILE_TABLE_CHARACTER_FORMAT of hTable to sOrgFormat
89218>>>        Move (Uppercase(sOrgFormat)) to sOrgFormat       
89219>>>        // Lets swap the OEM/ANSI format, just to make a change in Structure_Start below (and back),
89219>>>        // to "touch" the table so the driver feels there has been a change and updates the .int file.
89219>>>        Move (If(sOrgFormat = CS_OEM_Txt, CS_ANSI_Txt, CS_OEM_Txt)) to sNewFormat
89220>>>        
89220>>>        Structure_Start hTable
89221>>>            Set_Attribute DF_FILE_TABLE_CHARACTER_FORMAT of hTable to sNewFormat
89224>>>            Set_Attribute DF_FILE_TABLE_CHARACTER_FORMAT of hTable to sOrgFormat
89227>>>        Structure_End hTable (DF_STRUCTEND_OPT_IN_PLACE ior DF_STRUCTEND_OPT_FORCE)
89229>>>        
89229>>>        Function_Return (Err = False)
89230>>>    End_Function 
89231>>>    
89231>>>    // Checks if the passed Table;
89231>>>    // 1) Already has a Filelist entry that points to SQL and
89231>>>    // 2) It has an .int file. 
89231>>>    // If both is True it should already be connected to SQL
89231>>>    Function SQLUtilTableIsAttached String sDriverID Handle hTable Returns Boolean
89233>>>        Boolean bExists bRootName
89233>>>        String sRootName sDataPath
89233>>>        Integer iCount
89233>>>        
89233>>>        Get_Attribute DF_FILE_ROOT_NAME of hTable to sRootName
89236>>>        Move (sRootName contains sDriverID) to bRootName
89237>>>        
89237>>>        Get psDataPathFirstPart to sDataPath
89238>>>        Get vFolderExists sDataPath to bExists
89239>>>        If (bExists = False) Begin
89241>>>            // If the path doesn't exist it cannot have an .int file and we're done, although it shouldn't happen.
89241>>>            Function_Return False
89242>>>        End                      
89242>>>>
89242>>>        
89242>>>        Get vFolderFormat sDataPath to sDataPath         
89243>>>        Get _TableNameOnly sRootName to sRootName
89244>>>        Get vFilePathExists (sDataPath + sRootName + ".int") to bExists
89245>>>
89245>>>        Function_Return (bRootName = True and bExists = True)
89246>>>    End_Function       
89247>>>    
89247>>>    Function SQLUtilTableIsViewType String sDriverID Handle hTable Returns Boolean
89249>>>        Boolean bViewTableType bOpen bMertechDriver bOK
89249>>>        Integer hoSQLHandler
89249>>>        Integer iTableCount iNumTables iPos iTableIndex
89249>>>        String sTableName sOwner sTableType sLogin sEnumTableName sEnumSchemaName sCurrent_Login
89249>>>        Handle hoCliHandler  
89249>>>        tSQLConnection SQLConnection
89249>>>        tSQLConnection SQLConnection
89249>>>        
89249>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpen
89252>>>        If (bOpen = False) Begin  
89254>>>            Get AutoConnectionIDLogin to bOK
89255>>>            Open hTable
89257>>>        End
89257>>>>
89257>>>        
89257>>>        Get pSQLConnection to SQLConnection   
89258>>>        Get phoCLIHandler to hoCliHandler
89259>>>        Set psDriverID of hoCliHandler to sDriverID
89260>>>        
89260>>>        Get_Attribute DF_FILE_ROOT_NAME of hTable to sTableName 
89263>>>        Get _TableNameOnly sTableName to sTableName             
89264>>>        Get_Attribute DF_FILE_OWNER     of hTable to sOwner
89267>>>        Get EnumerateTables of hoCliHandler SQLConnection.sConnectionString to iNumTables
89268>>>        
89268>>>        For iTableCount from 1 to iNumTables
89274>>>>
89274>>>            Get TableName  of hoCliHandler iTableCount to sEnumTableName
89275>>>            Get SchemaName of hoCliHandler iTableCount to sEnumSchemaName
89276>>>            If ((Uppercase(sEnumTableName)  = Uppercase(sTableName)) and (Uppercase(sEnumSchemaName) = Uppercase(sOwner))) Begin
89278>>>                Get TableType of hoCliHandler iTableCount to sTableType
89279>>>                Move iNumTables to iTableCount // We're done.
89280>>>            End
89280>>>>
89280>>>        Loop
89281>>>>
89281>>>        
89281>>>        Move (sTableType = "VIEW") to bViewTableType
89282>>>        If (bOpen = False) Begin
89284>>>            Close hTable
89285>>>        End
89285>>>>
89285>>>        
89285>>>        Function_Return bViewTableType
89286>>>    End_Function
