91730>>>    
91730>>>        Get vFilePathExists sFileName to bExists
91731>>>        If (bExists = False) Begin
91733>>>            If (bShowResult = True) Begin
91735>>>                Showln "File does not exist: " sFileName
91738>>>            End
91738>>>>
91738>>>            Function_Return False
91739>>>        End
91739>>>>
91739>>>    
91739>>>        Get Seq_Open_Input_Channel sFileName to iCh
91740>>>        If (iCh < 1) Begin
91742>>>            Function_Return False
91743>>>        End
91743>>>>
91743>>>        
91743>>>        If (bShowResult = True) Begin  
91745>>>            Showln ""
91747>>>            Showln "sFileName = " sFileName
91750>>>            Showln "sChangeFrom = " sChangeFrom " sChangeTo = " sChangeTo
91755>>>        End
91755>>>>
91755>>>        
91755>>>        While (not(SeqEof))
91759>>>            Readln channel iCh sRow
91761>>>            If (Uppercase(sRow) contains Uppercase(sChangeFrom)) Begin 
91763>>>                If (bShowResult = True) Begin
91765>>>                    Showln "Changed from: " sRow " to: " sChangeTo
91770>>>                End
91770>>>>
91770>>>                // Change the whole line to the new connection id:
91770>>>                Move sChangeTo to sRow
91771>>>                // Move (Replaces(sChangeFrom, sRow, sChangeTo)) to sValue
91771>>>            End
91771>>>>
91771>>>            Move sRow to sFileArray[iRow]
91772>>>            Increment iRow
91773>>>        End
91774>>>>
91774>>>        Send Seq_Close_Channel iCh
91775>>>        
91775>>>        Sleep 1 // Wait for Windows to close the file
91776>>>    
91776>>>        Get Seq_Open_Output_Channel sFileName to iCh
91777>>>        If (iCh < 1) Begin
91779>>>            Function_Return False
91780>>>        End
91780>>>>
91780>>>        Move (SizeOfArray(sFileArray)) to iItems
91781>>>        Decrement iItems
91782>>>    
91782>>>        For iCount from 0 to iItems
91788>>>>
91788>>>            Move sFileArray[iCount] to sValue
91789>>>            Writeln channel iCh sValue
91792>>>        Loop
91793>>>>
91793>>>        Send Seq_Close_Channel iCh
91794>>>    
91794>>>        Function_Return (Err = False)
91795>>>    End_Function
91796>>>    
91796>>>    // This might be needed by API-methods when a connection id is to be used and
91796>>>    // the connection ID hasn't been established with the driver's CLI interface.
91796>>>    // NOTE: Only applicable for DAW drivers, as Mertech drivers doesn't use connection ID's.
91796>>>    Function UtilCreateConnectionID String sConnectionID Returns Boolean
91798>>>        String sConnectionString sDriverID
91798>>>        Boolean bOK bSilent bDawDriver
91798>>>        Handle hoCLI
91798>>>        
91798>>>        Move False to bOK   
91799>>>        Get psDriverID to sDriverID
91800>>>        Get IsDAWSQLDriver sDriverID to bDawDriver
91801>>>        If (bDawDriver = False) Begin
91803>>>            Error DFERR_PROGRAM "The UtilCreateConnectionID function is only available for DAW drivers. (Not Mertech)."
91804>>>>
91804>>>            Function_Return False
91805>>>        End
91805>>>>
91805>>>        
91805>>>        Get psConnectionString to sConnectionString
91806>>>        Get pbSilentLogin      to bSilent
91807>>>        
91807>>>        Get phoCLIHandler to hoCLI 
91808>>>        If (hoCLI <> 0) Begin
91810>>>            Set psDriverID of hoCLI to sDriverID
91811>>>            Get CreateConnectionID of hoCLI sConnectionID sConnectionString bSilent to bOK
91812>>>        End
91812>>>>
91812>>>        
91812>>>        Function_Return (bOK = False)
91813>>>    End_Function
91814>>>
91814>>>    // This message creates an error log in the "Home" folder named "SQLErrorLog.txt",
91814>>>    // and opens it in "notepad.exe".
91814>>>    // Note: This is _not_ used by the cDbUpdateHandler & cDbUpdateVersion classes!
91814>>>    //       Instead the cDbUpdateLogFile's WriteErrorLog & ShowErrorLog are then used.
91814>>>    Procedure UtilShowErrorList
91816>>>        tSqlErrorArray aSqlErrorArray 
91816>>>        tSqlErrorArray aSqlErrorArray 
91816>>>        Integer iRows iCount iCh iErrorNum
91816>>>        String sPath sFileName sErrorTxt sStatement
91816>>>        
91816>>>        Get psHome of (phoWorkspace(ghoApplication)) to sPath
91817>>>        Get vFolderFormat sPath to sPath
91818>>>        Move "SQLErrorLog.txt"  to sFileName
91819>>>        Get Seq_Open_Output_Channel (sPath + sFileName) to iCh
91820>>>            Get paSqlErrorArray to aSqlErrorArray
91821>>>            Move (SizeOfArray(aSqlErrorArray.sSqlErrorArray)) to iRows
91822>>>            If (iRows > 0) Begin
91824>>>                Decrement iRows
91825>>>                for iCount from 0 to iRows
91831>>>>
91831>>>                    Move aSqlErrorArray.sSqlErrorArray[iCount]      to sErrorTxt
91832>>>                    Move aSqlErrorArray.sSqlStatementArray[iCount]  to sStatement
91833>>>                    Move aSqlErrorArray.iSqlErrorArray[iCount]      to iErrorNum
91834>>>                    Writeln channel iCh "Error No: " iErrorNum " Error Text: " sErrorTxt
91840>>>                    Writeln channel iCh "SQL Statement: " sStatement
91844>>>                Loop
91845>>>>
91845>>>            End
91845>>>>
91845>>>        Send Seq_Close_Channel iCh
91846>>>        
91846>>>        If (iRows > 0) Begin
91848>>>            Runprogram Background "Notepad.exe" (sPath + sFileName)
91849>>>        End
91849>>>>
91849>>>    End_Procedure
