87846>>>    
87846>>>    // Drop column by its table name as a string.
87846>>>    Function SqlColumnRemoveByTableName String sTableName String sColumnName Returns Boolean
87848>>>        Integer iColumn iDbType iDriver
87848>>>        String sDriverID sStmt sAlterTable sDropColumn sVal 
87848>>>        Boolean bExists bOK bRetval bDriverIgnoreErrorState
87848>>>        Handle hTable 
87848>>>        
87848>>>        Get psDriverID to sDriverID
87849>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
87850>>>        If (bOK = False) Begin
87852>>>            Function_Return False
87853>>>        End
87853>>>>
87853>>>
87853>>>        Get DriverIndex sDriverID to iDriver
87854>>>        Get_Attribute DF_DRIVER_IGNORE_WARNINGS of iDriver to bDriverIgnoreErrorState
87857>>>        Set_Attribute DF_DRIVER_IGNORE_WARNINGS of iDriver to True
87860>>>        
87860>>>        Get UtilTableNameToHandle sTableName to hTable
87861>>>        If (hTable <> 0) Begin
87863>>>            Get SQLUtilColumnExists sTableName sColumnName to bExists
87864>>>            If (bExists = False) Begin
87866>>>                Set_Attribute DF_DRIVER_IGNORE_WARNINGS of iDriver to bDriverIgnoreErrorState
87869>>>                Function_Return False
87870>>>            End
87870>>>>
87870>>>        End
87870>>>>
87870>>>
87870>>>        Get piDbType to iDbType
87871>>>        If (iDbType = EN_DbTypeMSSQL) Begin
87873>>>            Get _SqlUtilRemoveTableColumnMSSQL sTableName sColumnName to bOK
87874>>>            Get UtilDeleteCacheFile sTableName to bOK
87875>>>            Set_Attribute DF_DRIVER_IGNORE_WARNINGS of iDriver to bDriverIgnoreErrorState
87878>>>            Function_Return bOK
87879>>>        End
87879>>>>
87879>>>        
87879>>>        Move False to Err   
87880>>>        Get _SqlProperTableName sTableName    to sTableName
87881>>>        Get _SqlFindKeyWord CI_SQLAlterTable  to sAlterTable
87882>>>        Get _SqlFindKeyWord CI_SQLDropColumn  to sDropColumn   
87883>>>        
87883>>>        Move (sAlterTable * sTableName * sDropColumn * sColumnName) to sStmt
87884>>>        Send SqlUtilExecuteQuery sStmt sDriverID
87885>>>        Move (not(Err)) to bRetval
87886>>>    
87886>>>        // We also need to remove the cache-file since the table has been changed
87886>>>        Get UtilDeleteCacheFile sTableName to bOK
87887>>>        Set_Attribute DF_DRIVER_IGNORE_WARNINGS of iDriver to bDriverIgnoreErrorState
87890>>>    
87890>>>        Function_Return bRetval
87891>>>    End_Function    
87892>>>    
87892>>>    // Rename a field/column by table handle (filelist number)
87892>>>    Function SqlColumnRename Integer hTable String sColumnName String sNewColumnName Returns Boolean
87894>>>        Integer iColumn idbType
87894>>>        String sDriverID sTableName sStmt sAlterTable sRenameColumn sVal sColumnKeyWord
87894>>>        Boolean bExists bOK
87894>>>        
87894>>>        Get psDriverID to sDriverID
87895>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
87896>>>        If (bOK = False) Begin
87898>>>            Function_Return False
87899>>>        End
87899>>>>
87899>>>        
87899>>>        Get UtilTableHandleToString hTable to sTableName   
87900>>>        Get SqlColumnRenameByTableName sTableName sColumnName sNewColumnName to bOK
87901>>>
87901>>>        Function_Return (Err = False)    
87902>>>    End_Function    
87903>>>    
87903>>>    // Rename a field/column by table name.
87903>>>    Function SqlColumnRenameByTableName String sTableName String sColumnName String sNewColumnName Returns Boolean
87905>>>        Integer iColumn iDbType iDataType
87905>>>        String sDriverID sStmt sAlterTable sRenameColumn sVal sColumnKeyWord sOrgTableName sDatabase sDataType
87905>>>        Boolean bExists bOK bRetval                                        
87905>>>        Handle hTable
87905>>>        
87905>>>        Move sTableName to sOrgTableName
87906>>>        Get psDriverID to sDriverID
87907>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
87908>>>        If (bOK = False) Begin
87910>>>            Function_Return False
87911>>>        End
87911>>>>
87911>>>        
87911>>>        Get _SqlFindColumnName sTableName sColumnName to sVal
87912>>>        If (sVal = "") Begin
87914>>>            Function_Return False
87915>>>        End                          
87915>>>>
87915>>>        
87915>>>        Get piDbType to iDbType
87916>>>        Get _SqlFindKeyWord CI_SQLColumn       to sColumnKeyWord
87917>>>        Get _SqlProperTableName sTableName     to sTableName
87918>>>        Get _SqlFindKeyWord CI_SQLAlterTable   to sAlterTable
87919>>>        Get _SqlFindKeyWord CI_SQLRenameColumn to sRenameColumn
87920>>>        
87920>>>        Case Begin
87920>>>            Case (iDbType = EN_dbTypeMSSQL) 
87922>>>                Move (sRenameColumn * "'" + sTableName + "." + sColumnName + "'," * "'" + sNewColumnName + "'," * "'" + sColumnKeyWord + "'") to sStmt
87923>>>                Case Break
87924>>>            // Alter table "SYS"."Customer" rename column "Comments" to "NewColumnName"    
87924>>>            Case (iDbType = EN_dbTypeOracle) 
87927>>>                Move (sAlterTable * '"' + sTableName + '"' * sRenameColumn * '"' + sColumnName + '"' * "TO" * '"' + sNewColumnName + '"') to sStmt
87928>>>                Case Break  
87929>>>            // ALTER TABLE Schema.TableName RENAME COLUMN "deptnumb" TO "deptnum"
87929>>>            Case (iDbType = EN_dbTypeDB2)
87932>>>                Move (sAlterTable *  sTableName * sRenameColumn * '"' + sColumnName + '"' * "TO" * '"' + sNewColumnName + '"') to sStmt
87933>>>                Case Break
87934>>>            // ALTER TABLE "Customer" RENAME COLUMN "Comments" TO "NewColumnName"
87934>>>            Case (iDbType = EN_dbTypePostgre) 
87937>>>                Move sOrgTableName to sTableName
87938>>>                Move (sAlterTable * '"' + sTableName + '"' * sRenameColumn * '"' + sColumnName + '"' * "TO" * '"' + sNewColumnName + '"') to sStmt
87939>>>                Case Break  
87940>>>            Case (iDbType = EN_dbTypeMySQL)
87943>>>                // ALTER TABLE orderentry.customer CHANGE Comments NewColumnName text // Note: The last token is the column type!
87943>>>                Move sOrgTableName to sTableName
87944>>>                Get psDatabase to sDatabase 
87945>>>                Get UtilTableNameToHandle sTableName to hTable
87946>>>                If (hTable = 0) Begin
87948>>>                    Get UtilTableOpen hTable sTableName DF_SHARE to bOK
87949>>>                    If (bOK = False) Begin
87951>>>                        Function_Return False 
87952>>>                    End
87952>>>>
87952>>>                    Get NextFreeFilelistSlot to hTable
87953>>>                End
87953>>>>
87953>>>                Else Begin
87954>>>                    Open hTable
87956>>>                End          
87956>>>>
87956>>>                Get SQLColumnType sDriverID hTable sTableName sColumnName to iDataType
87957>>>                Get UtilColumnTypeToString sDriverID iDbType iDataType    to sDataType
87958>>>                Move (sAlterTable * sDatabase + "." + sTableName * sRenameColumn * sColumnName * sNewColumnName * sDataType) to sStmt
87959>>>                Case Break  
87960>>>            Case Else 
87960>>>                Move (sAlterTable * "'" + sTableName + "'" * sRenameColumn * "'" + sTableName + "." + sColumnName + "'" * "TO" * "'" + sNewColumnName + "'") to sStmt
87961>>>        Case End
87961>>>        
87961>>>        Move False to Err   
87962>>>        Send SqlUtilExecuteQuery sStmt sDriverID
87963>>>        Move (Err = False) to bRetval
87964>>>        // We also need to remove the cache-file since the table has been changed
87964>>>        Get UtilDeleteCacheFile sTableName to bOK
87965>>>    
87965>>>        Function_Return bRetval
87966>>>    End_Function    
87967>>>
87967>>>    Function SqlColumnType String sDriverID Handle hTable String sTableName String sColumnName Returns Integer
87969>>>        Handle hoSQLHandler hSQLConnect hStmt
87969>>>        Boolean bMertechDriver                                     
87969>>>        Integer iNumCols iCount iSQLType iDataType
87969>>>        String sValue 
87969>>>        
87969>>>        Get IsMertechDriver sDriverID to bMertechDriver
87970>>>        If (bMertechDriver = False) Begin
87972>>>            Get phoSQLManager to hoSQLHandler
87973>>>        End                                  
87973>>>>
87973>>>        Else Begin
87974>>>            Get _MertechSQLManagerHandle to hoSQLHandler
87975>>>        End                                    
87975>>>>
87975>>>        
87975>>>        Get SQLFileConnect of hoSQLHandler hTable to hSQLConnect
87976>>>        If (hSQLConnect <> 0) Begin
87978>>>            Get SQLOpen of hSQLConnect to hStmt
87979>>>            If (hStmt <> 0) Begin
87981>>>                Send SQLExecDirect of hStmt ("select * from" * sTableName)
87982>>>        
87982>>>                Get SQLStmtAttribute of hStmt SQLSTMTATTRIB_COLUMNCOUNT to iNumCols
87983>>>                For iCount from 1 to iNumCols
87989>>>>
87989>>>                    Get SQLColAttribute of hStmt iCount SQLCOLATTRIB_LABEL to sValue
87990>>>                    If (Lowercase(sValue) = Lowercase(sColumnName)) Begin
87992>>>                        Get SQLColAttribute of hStmt iCount SQLCOLATTRIB_SQLTYPE to iDataType
87993>>>                        Move iNumCols to iCount // We're out of here
87994>>>                    End
87994>>>>
87994>>>                Loop                                                
87995>>>>
87995>>>                
87995>>>                Send SQLClose of hStmt
87996>>>            End
87996>>>>
87996>>>            Send SQLDisconnect of hSQLConnect    
87997>>>        End
87997>>>>
87997>>>        
87997>>>        Function_Return iDataType
87998>>>    End_Function
87999>>>        
87999>>>    
87999>>>    // *** SQL Utility Messages ***
87999>>>    // They are not geared at making database changes.
87999>>>    //
87999>>>
87999>>>    // Will create an SQL table with the passed sTableName & sColumnName as Numeric 4.2 to keep
87999>>>    // the DbUpdateVersion database revision in.  
87999>>>    // Also pass the file number of the current (embedded?) table number used in development.
87999>>>    // It will first create the SQL Table & column, then create the .int file and change Filelist.cfg
87999>>>    Function SQLCreateDbVersionTable Handle hTable String sColumnName String sDriverID Returns Boolean
88001>>>        Boolean bOK bOpened
88001>>>        String sTableName sDataType sAlterTable sAddColumn sLengthAndDecimals sStmt sDropColumn
88001>>>        
88001>>>        Get_Attribute DF_FILE_ROOT_NAME of hTable to sTableName
88004>>>        Get _TableNameOnly sTableName to sTableName   
88005>>>        If (sTableName = "") Begin
88007>>>            Function_Return False
88008>>>        End 
88008>>>>
88008>>>        
88008>>>        // This just creates the table and a "dummy" column.
88008>>>        Get SqlTableCreate hTable sDriverID to bOK
88009>>>        If (bOK = False) Begin
88011>>>            Function_Return False 
88012>>>        End                      
88012>>>>
88012>>>        
88012>>>        Close hTable
88013>>>        Move False to Err
88014>>>        
88014>>>        Get _SqlFindKeyWord CI_SQLAlterTable to sAlterTable
88015>>>        Get _SqlFindKeyWord CI_SQLAdd        to sAddColumn
88016>>>        Move "Decimal" to sDataType
88017>>>        Get _SqlFormatLengthAndDecimalAsString 4 2 to sLengthAndDecimals
88018>>>        
88018>>>        // Adds the "sColumnName" passed to the function
88018>>>        Move (sAlterTable * sTableName * sAddColumn * sColumnName * sDataType + sLengthAndDecimals) to sStmt 
88019>>>        Send SqlUtilExecuteQuery sStmt sDriverID
88020>>>        
88020>>>        // Now we can delete the dummy column:
88020>>>        Get SqlColumnRemoveByTableName sTableName "Dummy" to bOK
88021>>>        
88021>>>        // Finally, we attach to the newly created table.
88021>>>        If (Err = False) Begin    
88023>>>            Get ApiTableAttachToSQL hTable True to bOK
88024>>>        End
88024>>>>
88024>>>        Open hTable                                                  
88026>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpened
88029>>>        
88029>>>        Function_Return (Err = False and bOK = True and bOpened = True)
88030>>>    End_Function
88031>>>    
88031>>>    // Checks if a column/field name exists in a SQL table definition
88031>>>    // Returns True if it does
88031>>>    // Sample:
88031>>>    //   Get SQLUtilColumnExists "MySQLTable" "MyColumnName" to bExists
88031>>>    Function SQLUtilColumnExists String sTableName String sFieldName Returns Boolean
88033>>>        Integer iNumColumns iColumn
88033>>>        String sColumn sDriverID
88033>>>        String[] sColumnsArray
88034>>>        Boolean bExists bOK
88034>>>    
88034>>>        Move False to bExists  
88035>>>        Get AutoConnectionIDLogin to bOK
88036>>>        Get psDriverID to sDriverID
88037>>>        
88037>>>        Get SqlUtilEnumerateColumns sDriverID sTableName to sColumnsArray
88038>>>        Move (SizeOfArray(sColumnsArray)) to iNumColumns
88039>>>        Decrement iNumColumns
88040>>>        For iColumn from 0 to iNumColumns
88046>>>>
88046>>>            Move sColumnsArray[iColumn] to sColumn
88047>>>            If (Uppercase(sFieldName) = Uppercase(sColumn)) Begin
88049>>>                Move True to bExists
88050>>>                Move iNumColumns to iColumn // We're out of here
88051>>>            End
88051>>>>
88051>>>        Loop
88052>>>>
88052>>>    
88052>>>        Function_Return bExists
88053>>>    End_Function
88054>>>    
88054>>>    Function SQLUtilConvertColumnTypesToSQL2008 Handle hTable Returns Boolean
88056>>>        Integer iNumColumns iColumn iDFType iNativeType
88056>>>        Boolean bOpened bOK
88056>>>        String sColumnName sNativeTypeName
88056>>>        
88056>>>        Get AutoConnectionIDLogin to bOK
88057>>>        Open hTable Mode DF_EXCLUSIVE
88059>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpened
88062>>>        If (bOpened = False) Begin
88064>>>            Error DFERR_PROGRAM ("Function SQLUtilConvertColumnTypesToSQL2008; Could not open table" * String(hTable))
88065>>>>
88065>>>            Function_Return False 
88066>>>        End
88066>>>>
88066>>>        
88066>>>        Move False to Err                               
88067>>>        
88067>>>        Structure_Start hTable
88068>>>            Get_Attribute DF_FILE_NUMBER_FIELDS of hTable to iNumColumns
88071>>>        
88071>>>            For iColumn from 1 to iNumColumns
88077>>>>
88077>>>                Get_Attribute DF_FIELD_TYPE             of hTable iColumn to iDfType
88080>>>                Get_Attribute DF_FIELD_NAME             of hTable iColumn to sColumnName
88083>>>                Get_Attribute DF_FIELD_NATIVE_TYPE      of hTable iColumn to iNativeType
88086>>>                Get_Attribute DF_FIELD_NATIVE_TYPE_Name of hTable iColumn to sNativeTypeName
88089>>>                
88089>>>                Case Begin
88089>>>                    Case (iDFType = DF_DATE) 
88091>>>                        If (iNativeType = SQL_TYPE_TIMESTAMP) Begin
88093>>>                            // Convert datetime to date
88093>>>                            Set_Attribute DF_FIELD_NATIVE_TYPE of hTable iColumn to SQL_TYPE_DATE
88096>>>                        End
88096>>>>
88096>>>                        Case Break
88097>>>                    Case (iDFType = DF_DATETIME) 
88100>>>                        If (iNativeType = SQL_TYPE_TIMESTAMP) Begin
88102>>>                            // Convert datetime to datetime2
88102>>>                            Set_Attribute DF_FIELD_NATIVE_TYPE of hTable iColumn to SQL_TYPE_TIMESTAMP2
88105>>>                        End
88105>>>>
88105>>>                        Case Break
88106>>>                    Case (iDFType = DF_ASCII) 
88109>>>                        If (iNativeType = SQL_CHAR) Begin
88111>>>                            // Convert char to varchar
88111>>>                            Set_Attribute DF_FIELD_NATIVE_TYPE of hTable iColumn to SQL_VARCHAR
88114>>>                        End
88114>>>>
88114>>>                        Case Break
88115>>>                    Case (iDFType = DF_TEXT) 
88118>>>                        If (iNativeType = SQL_LONGVARCHAR) Begin 
88120>>>                            // Convert text to varchar(max)
88120>>>                            Set_Attribute DF_FIELD_NATIVE_TYPE of hTable iColumn to SQL_VARCHAR
88123>>>                        End
88123>>>>
88123>>>                        Case Break
88124>>>                    Case (iDFType = DF_BINARY) 
88127>>>                        If (iNativeType = SQL_LONGVARBINARY) Begin
88129>>>                            // Convert image to varbinary(max)
88129>>>                            Set_Attribute DF_FIELD_NATIVE_TYPE of hTable iColumn to SQL_VARBINARY
88132>>>                        End
88132>>>>
88132>>>                        Case Break
88133>>>                Case End
88133>>>            Loop
88134>>>>
88134>>>        Structure_End hTable
88136>>>    
88136>>>        Function_Return (Err = False)    
88137>>>    End_Function  
88138>>>    
88138>>>    // Does three things with auxilirary files;
88138>>>    // 1) Deletes the cache file in the first Data folder of the psDataPath property as the table at the SQL end has been changed.
88138>>>    // 2) Adds the sColumnName to the TableName.tag file in the first Data folder of the psDataPath property
88138>>>    // 3) Creates a new TableName.fd file if the DdSrc folder is available (if this is a development environment)
88138>>>    Function SqlUtilAdjustAuxFiles Handle hTable String sTableName String sColumnName Returns Boolean
88140>>>        String sDataPath sDDSrcPath sVal sDriverID
88140>>>        Boolean bOK bExists bMertechDriver
88140>>>        Integer iCount iItems iCh iPos
88140>>>        
88140>>>        // If table name equals e.g. "dbo.MyTable" we need to remove the prefix.
88140>>>        If (sTableName contains ".") Begin
88142>>>            Move (Pos(".", sTableName)) to iPos
88143>>>            Move (Mid(sTableName, 999, (iPos +1))) to sTableName    
88144>>>        End                                                     
88144>>>>
88144>>>        
88144>>>        Get psDriverID to sDriverID
88145>>>        Get psDataPathFirstPart to sDataPath 
88146>>>        Get vFolderExists sDataPath to bOK
88147>>>        If (bOK = False) Begin
88149>>>            Error DFERR_PROGRAM "Function SqlUtilAdjustAuxFiles; psDataPath not found!"
88150>>>>
88150>>>            Function_Return False    
88151>>>        End                      
88151>>>>
88151>>>        
88151>>>        Get IsMertechDriver sDriverID to bMertechDriver
88152>>>        // First delete the cache file:
88152>>>        Get UtilDeleteCacheFile sTableName to bOK
88153>>>            
88153>>>        Get Seq_New_Channel to iCh  
88154>>>        If (iCh = DF_SEQ_CHANNEL_NOT_AVAILABLE) Begin
88156>>>            Function_Return False
88157>>>        End                      
88157>>>>
88157>>>        
88157>>>        Get vFilePathExists (sDataPath + sTableName + ".tag") to bExists
88158>>>        If (bExists = False) Begin
88160>>>            Function_Return False
88161>>>        End                      
88161>>>>
88161>>>        
88161>>>        // Add the new column name to the .tag file: 
88161>>>        Append_Output channel iCh (sDataPath + sTableName + ".tag")
88163>>>            Writeln channel iCh sColumnName
88166>>>        Close_Output
88167>>>        
88167>>>        // If in development environment; output new .fd file:
88167>>>        Get psDdSrcPath of (phoWorkspace(ghoApplication)) to sDDSrcPath
88168>>>        Get CountOfPaths of (phoWorkspace(ghoApplication)) sDDSrcPath to iCount
88169>>>        If (iCount > 1) Begin
88171>>>            Get PathAtIndex of (phoWorkspace(ghoApplication)) sDDSrcPath 1 to sDDSrcPath    
88172>>>        End 
88172>>>>
88172>>>        Get vFolderExists sDDSrcPath to bExists
88173>>>        If (bExists = True) Begin                                   
88175>>>            Get vFolderFormat sDDSrcPath to sDDSrcPath  
88176>>>            Move False to Err 
88177>>>            Get AutoConnectionIDLogin to bOK
88178>>>            If (hTable <> 0) Begin
88180>>>                Open hTable
88182>>>            End 
88182>>>>
88182>>>            Else Begin
88183>>>                Get UtilTableOpen hTable sTableName DF_SHARE to bOK
88184>>>            End
88184>>>>
88184>>>                
88184>>>            Get_Attribute DF_FILE_OPENED of hTable to bOK
88187>>>            If (bOK = True) Begin
88189>>>                Output_Aux_File DF_AUX_FILE_FD for hTable to (sDDSrcPath + sTableName + ".fd")
88191>>>            End
88191>>>>
88191>>>            If (Err = True) Begin
88193>>>                Move False to bOK
88194>>>            End
88194>>>>
88194>>>        End
88194>>>>
88194>>>        
88194>>>        Function_Return (bOK = True)
88195>>>    End_Function  
88196>>>    
88196>>>    // The table must already exist in the filelist for this function to work.
88196>>>    // It creates a rudimentary .int file in the first Data folder of the psDataPath property.
88196>>>    Function SqlUtilCreateIntFile Handle hTable String sDriverID String sConnectionID Boolean bAnsi Boolean bSysFile Returns Boolean
88198>>>        Boolean bOK bExists bUseConnectionID bMertech
88198>>>        String sDataPath sRootName sPhysicalFileName sConnectionString sDatabaseName sSchemaName sANSI_OEM
88198>>>        String[] sIndexArray
88199>>>        Integer iCount iCh iSize
88199>>>        
88199>>>        Move (Trim(sConnectionID) <> "") to bUseConnectionID
88200>>>        Get psConnectionString to sConnectionString
88201>>>
88201>>>        Move CS_ANSI_Txt to sANSI_OEM
88202>>>        If (bANSI = False) Begin
88204>>>            Move CS_OEM_Txt to sANSI_OEM
88205>>>        End
88205>>>>
88205>>>        
88205>>>        Get psDataPathFirstPart to sDataPath
88206>>>        Get vFolderExists sDataPath to bOK
88207>>>        If (bOK = False) Begin
88209>>>            Error DFERR_PROGRAM "Function SqlUtilCreateIntFile; psDataPath not found!"
88210>>>>
88210>>>            Function_Return False    
88211>>>        End                      
88211>>>>
88211>>>        Get vFolderFormat sDataPath to sDataPath 
88212>>>
88212>>>        Get_Attribute DF_FILE_ROOT_NAME of hTable to sRootName
88215>>>        Get _TableNameOnly sRootName to sDatabaseName
88216>>>        Move sDatabaseName to sPhysicalFileName
88217>>>        Move (sPhysicalFileName + ".int") to sPhysicalFileName
88218>>>
88218>>>        Get IsMertechDriver sDriverID to bMertech
88219>>>        If (bMertech = True) Begin       
88221>>>            // This should not be called here. Instead it is called by the SqlUtilUpdateIntFile!
88221>>>            // Else it will create an error in the error log (although it won't do anything...)
88221>>>            // Get _MertechSqlUtilCreateIntFile hTable sDataPath sPhysicalFileName to bOK
88221>>>            Function_Return (bOK = True)
88222>>>        End
88222>>>>
88222>>>        
88222>>>        Get psSchema hTable to sSchemaName
88223>>>        If (sSchemaName = "") Begin   
88225>>>            Get _SqlFindKeyWord CI_SQLDBO to sSchemaName
88226>>>        End
88226>>>>
88226>>>
88226>>>        // If the .int file already exists; we rename it to "FileName" + ".bak"
88226>>>        Get vFilePathExists (sDataPath + sPhysicalFileName) to bExists
88227>>>        If (bExists = True) Begin            
88229>>>            Get vRenameFile (sDataPath + sPhysicalFileName) (sDataPath + sPhysicalFileName + ".bak") to bOK 
88230>>>        End
88230>>>>
88230>>>        
88230>>>        Get UtilDeleteCacheFile sRootName to bOK
88231>>>        Get SqlUtilEnumerateIndexes sRootName sDriverID to sIndexArray
88232>>>        
88232>>>        Get Seq_Open_Output_Channel (sDataPath + sPhysicalFileName) to iCh
88233>>>            Writeln channel iCh CS_DRIVER_NAME     " " sDriverID 
88238>>>            If (bUseConnectionID = True) Begin
88240>>>                Writeln channel iCh CS_SERVER_NAME " " CS_DFCONNID "=" sConnectionID
88247>>>            End 
88247>>>>
88247>>>            Else Begin
88248>>>                Writeln channel iCh CS_SERVER_NAME " " CS_SERVER "=" sConnectionString
88255>>>            End                                                      
88255>>>>
88255>>>            Writeln channel iCh CS_DATABASE_NAME          " " sDatabaseName
88260>>>            Writeln channel iCh CS_SCHEMA_NAME            " " (Lowercase(sSchemaName))
88265>>>            // There seems to be a new order how these are set from DF19.
88265>>>            If (bSysFile = True) Begin
88267>>>                Writeln channel iCh CS_RECNUM_TABLE       " " "NO"
88272>>>            End 
88272>>>>
88272>>>            Writeln channel iCh CS_TABLE_CHARACTER_FORMAT " " sANSI_OEM
88277>>>            Writeln channel iCh CS_USE_DUMMY_ZERO_DATE    " " "YES" // ToDo: We maybe need to paramerize this setting?  
88282>>>            If (bSysFile = True) Begin
88284>>>                Writeln channel iCh CS_SYSTEM_FILE        " " "YES" 
88289>>>            End  
88289>>>>
88289>>>            
88289>>>            If (bSysFile = False) Begin
88291>>>                Move (SizeOfArray(sIndexArray)) to iSize  
88292>>>                Move (SortArray(sIndexArray)) to sIndexArray
88293>>>                If (iSize > 0) Begin
88295>>>                    Writeln channel iCh (CS_PRIMARY_INDEX * String("0"))
88298>>>                    Writeln channel iCh // Just an empty line
88300>>>                End
88300>>>>
88300>>>                Decrement iSize                              
88301>>>                For iCount from 0 to iSize
88307>>>>
88307>>>                    Writeln channel iCh (CS_INDEX_NUMBER * String(iCount))
88310>>>                    Writeln channel iCh (CS_INDEX_NAME   * String(sIndexArray[iCount]))
88313>>>                    Writeln channel iCh
88315>>>                Loop
88316>>>>
88316>>>            End
88316>>>>
88316>>>        Send Seq_Close_Channel iCh 
88317>>>        
88317>>>        // Wait a sec for Windows to finish writing the file:
88317>>>        Sleep 1
88318>>>        
88318>>>        Function_Return (bOK = True)
88319>>>    End_Function
88320>>>    
88320>>>    // Message for changing .int files to use connection ID's
88320>>>    //
88320>>>    // Changes all ".int" files for the passed sDataPath to use a sConnectionID,
88320>>>    // OR changes an existing connection id to a new id.
88320>>>    // Pass the full path to the data folder and the name of the connection id (string value). 
88320>>>    // Pass a True for the bShowResult parameter to show work in progress (showln's).
88320>>>    Procedure SqlUtilChangeIntFilesToConnectionIDs String sDataPath String sConnectionID Boolean bShowResult
88322>>>        String sFileName sDriverID sDriverFile sConnectionString
88322>>>        String[] sFilesData
88323>>>        Boolean bExists bOK                               
88323>>>        Integer iSize iCount
88323>>>        
88323>>>        Get SqlUtilEnumerateIntFiles sDataPath to sFilesData
88324>>>        Move (SizeOfArray(sFilesData))    to iSize
88325>>>        If (iSize = 0) Begin
88327>>>            Send Info_Box "No .int files found! Nothing was changed."
88328>>>            Procedure_Return
88329>>>        End                                                          
88329>>>>
88329>>>        
88329>>>        Move (Trim(sConnectionID)) to sConnectionID
88330>>>        Get vFolderFormat sDataPath to sDataPath
88331>>>        Decrement iSize
88332>>>        For iCount from 0 to iSize
88338>>>>
88338>>>            Move sFilesData[iCount] to sFileName                                   
88339>>>            // This makes sure that we also can change an existing connection id to something new:
88339>>>            Get UtilChangeSourceCodeLine (sDataPath + sFileName) CS_SERVER_NAME (CS_SERVER_NAME * CS_DFCONNID + "=" + sConnectionID) bShowResult to bOK 
88340>>>        Loop                      
88341>>>>
88341>>>        
88341>>>        Get psDriverID to sDriverID
88342>>>        
88342>>>         // Finally also change the driver file e.g. MSSQLDRV.int file in the Data folder in case it has a "DFconnectionID xxxxID,SERVER..."
88342>>>        Move "" to sFileName
88343>>>        If (sDriverID = MSSQLDRV_ID) Begin
88345>>>            Move "MSSQLDrv.int" to sFileName
88346>>>        End                 
88346>>>>
88346>>>        If (sDriverID = DB2_DRV_ID) Begin
88348>>>            Move "DB2_Drv.int" to sFileName
88349>>>        End                                
88349>>>>
88349>>>        If (sDriverID = ODBC_DRV_ID) Begin
88351>>>            Move "ODBC_Drv.int" to sFileName
88352>>>        End                                 
88352>>>>
88352>>>        If (sFileName <> "") Begin     
88354>>>            Move "" to sDriverFile
88355>>>            Get_File_Path sFileName to sDriverFile
88356>>>            If (sDriverFile <> "") Begin                        
88358>>>                Get psConnectionString to sConnectionString
88359>>>                Get UtilChangeSourceCodeLine sDriverFile CS_SQLConnectionIDText (CS_SQLConnectionIDText * String(sConnectionID) + "," * String(sConnectionString) * String(",0")) bShowResult to bOK
88360>>>            End
88360>>>>
88360>>>        End
88360>>>>
88360>>>    End_Procedure
88361>>>
88361>>>    // Checks if the database exists in SQL. Returns = True if it does.
88361>>>    Function SqlUtilCheckIfDatabaseExists String sDatabase Returns Boolean
88363>>>        String[] sDatabaseArray
88364>>>        String sVal sServer sDriverID
88364>>>        Integer iCount iSize iPos
88364>>>        Boolean bExists            
88364>>>        tSQLConnection SQLConnection
88364>>>        tSQLConnection SQLConnection
88364>>>        
88364>>>        Move False to bExists                              
88365>>>        Get psDriverID to sDriverID
88366>>>        // DB2 doesn't need to have a "Database" name, so we always return True.
88366>>>        If (sDriverID = DB2_DRV_ID) Begin
88368>>>            Function_Return bExists
88369>>>        End                     
88369>>>>
88369>>>        
88369>>>        Get SqlUtilEnumerateDatabases sDriverID to sDatabaseArray
88370>>>        If (SizeOfArray(sDatabaseArray) = 0) Begin
88372>>>            Function_Return False
88373>>>        End
88373>>>>
88373>>>        
88373>>>        Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
88374>>>        Get ParseKeyWord SQLConnection.sConnectionString (CS_SQLIniDSNKeyword + "=") to sServer
88375>>>        If (sServer contains "/") Begin
88377>>>            Move (Pos("/", sServer)) to iPos
88378>>>            Move (Mid(sServer, 999, (iPos +1)))                        to sDatabase
88379>>>        End
88379>>>>
88379>>>        
88379>>>        Move (SizeOfArray(sDatabaseArray)) to iSize
88380>>>        Decrement iSize
88381>>>        For iCount from 0 to iSize
88387>>>>
88387>>>            Move sDatabaseArray[iCount] to sVal
88388>>>            If (Uppercase(sVal) = Uppercase(sDatabase)) Begin
88390>>>                Move True to bExists
88391>>>            End
88391>>>>
88391>>>        Loop
88392>>>>
88392>>>        
88392>>>        Function_Return bExists
88393>>>    End_Function
88394>>>        
88394>>>    // Checks if a table exists as an SQL table. Returns = True if it does.
88394>>>    Function SqlUtilCheckIfTableHandleExists Handle hTable String sDriverID Returns Boolean
88396>>>        String sTableName sVal
88396>>>        Boolean bExists  
88396>>>        String[] sTablesArray                                 
88397>>>        Integer iSize iCount
88397>>>        
