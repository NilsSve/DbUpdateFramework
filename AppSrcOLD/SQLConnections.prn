85343>>>>>>>Class cDbUpdateDatabaseDriver is a cObject
85344>>>>>>>    Procedure Construct_Object
85346>>>>>>>        Forward Send Construct_Object
85348>>>>>>>        Property String psDriverID DATAFLEX_ID
85349>>>>>>>        Property Handle phoDriverSpecificObject
85350>>>>>>>    End_Procedure
85351>>>>>>>    
85351>>>>>>>    Function CreateDriver Returns Handle
85353>>>>>>>        String sDriverID
85353>>>>>>>        Handle hoDriver hcDriverClass
85353>>>>>>>        
85353>>>>>>>        Get psDriverID to sDriverID
85354>>>>>>>        Case Begin
85354>>>>>>>            Case (sDriverID = MSSQLDRV_ID)
85356>>>>>>>                Move (RefClass(cDbUpdateMSSQLDriver)) to hcDriverClass
85357>>>>>>>                Case Break
85358>>>>>>>            Case (sDriverID = ODBC_DRV_ID)
85361>>>>>>>                Move (RefClass(cDbUpdateODBCDriver)) to hcDriverClass
85362>>>>>>>                Case Break
85363>>>>>>>            Case (sDriverID = DB2_DRV_ID)
85366>>>>>>>                Move (RefClass(cDbUpdateDB2Driver)) to hcDriverClass
85367>>>>>>>                Case Break
85368>>>>>>>            Case (sDriverID = SQLFLEX)
85371>>>>>>>                Move (RefClass(cDbUpdateSQLFLEXDriver)) to hcDriverClass
85372>>>>>>>                Case Break
85373>>>>>>>            Case (sDriverID = ORAFLEX)
85376>>>>>>>                Move (RefClass(cDbUpdateORAFLEXDriver)) to hcDriverClass
85377>>>>>>>                Case Break
85378>>>>>>>            Case (sDriverID = MDSPgSQL)
85381>>>>>>>                Move (RefClass(cDbUpdateMDSPgSQLDriver)) to hcDriverClass
85382>>>>>>>                Case Break
85383>>>>>>>            Case (sDriverID = MDSMySQL)
85386>>>>>>>                Move (RefClass(cDbUpdateMDSMySQLDriver)) to hcDriverClass
85387>>>>>>>                Case Break
85388>>>>>>>            Case (sDriverID = DATAFLEX_ID)
85391>>>>>>>                Move (RefClass(cDbUpdateDataFlexDriver)) to hcDriverClass
85392>>>>>>>                Case Break
85393>>>>>>>            Case Else
85393>>>>>>>                Function_Return 0
85394>>>>>>>        Case End
85394>>>>>>>        
85394>>>>>>>        Get Create hcDriverClass to hoDriver
85395>>>>>>>        Set psDriverID of hoDriver to sDriverID
85396>>>>>>>        Set phoDriverSpecificObject to hoDriver
85397>>>>>>>        
85397>>>>>>>        Function_Return hoDriver
85398>>>>>>>    End_Procedure
85399>>>>>>>    
85399>>>>>>>    Procedure DestroyDriver
85401>>>>>>>        If (phoDriverSpecificObject(Self)) Begin
85403>>>>>>>            Send Destroy of (phoDriverSpecificObject(Self))
85404>>>>>>>        End
85404>>>>>>>>
85404>>>>>>>    End_Procedure
85405>>>>>>>    
85405>>>>>>>    Function ConstructConnectionString String sServer String sDatabase Boolean bTrusted String sUserID String sPassword Returns String
85407>>>>>>>        String sConnect
85407>>>>>>>        Handle hoDriver
85407>>>>>>>        
85407>>>>>>>        Get CreateDriver to hoDriver
85408>>>>>>>        Get ConstructConnectionString of hoDriver sServer sDatabase bTrusted sUserID sPassword to sConnect
85409>>>>>>>        Send DestroyDriver
85410>>>>>>>        Function_Return sConnect
85411>>>>>>>    End_Function
85412>>>>>>>    
85412>>>>>>>    Function DbLogin String sConnectionString String sServer String sDatabase Boolean bTrusted String sUserID String sPassword Returns Boolean
85414>>>>>>>        Boolean bLoginSuccessful
85414>>>>>>>        Handle hoDriver
85414>>>>>>>        
85414>>>>>>>        Get CreateDriver to hoDriver
85415>>>>>>>        Get DbLogin of hoDriver sConnectionString sServer sDatabase bTrusted sUserID sPassword to bLoginSuccessful
85416>>>>>>>        Send DestroyDriver
85417>>>>>>>        Function_Return bLoginSuccessful
85418>>>>>>>    End_Function 
85419>>>>>>>    
85419>>>>>>>End_Class
