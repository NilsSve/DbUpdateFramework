92070>>>    Function UtilEnumerateOverlapFields Integer hTable Integer iField Returns String[]
92072>>>        String  sRetval sColumnName
92072>>>        String[] sOverlapFieldsArray
92073>>>        Integer iType iColumn iColumns 
92073>>>        Boolean bOpen bOverlap
92073>>>        
92073>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpen
92076>>>        If (bOpen = False) Begin
92078>>>            Open hTable
92080>>>        End
92080>>>>
92080>>>        
92080>>>        Move "" to sRetval
92081>>>        
92081>>>        Get_Attribute DF_FILE_NUMBER_FIELDS of hTable to iColumns
92084>>>        
92084>>>        for iColumn from 0 to iColumns
92090>>>>
92090>>>            Get_Attribute DF_FIELD_TYPE of hTable iColumn to iType
92093>>>            If (iField <> iColumn and iType <> DF_OVERLAP) Begin
92095>>>                Get_Attribute DF_FIELD_OVERLAP of hTable iField iColumn to bOverlap
92098>>>                If (bOverlap) Begin
92100>>>                    If (sRetval <> "") Begin
92102>>>                        Append sRetval ","
92103>>>                    End
92103>>>>
92103>>>                    Append sRetval iColumn
92104>>>                End
92104>>>>
92104>>>            End
92104>>>>
92104>>>        Loop
92105>>>>
92105>>>        
92105>>>        If (bOpen = False) Begin
92107>>>            Close hTable
92108>>>        End    
92108>>>>
92108>>>        
92108>>>        Move (StrSplitToArray(sRetval, ",")) to sOverlapFieldsArray
92109>>>        
92109>>>        Function_Return sOverlapFieldsArray
92110>>>    End_Function
