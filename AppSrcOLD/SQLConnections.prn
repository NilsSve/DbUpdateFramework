80652>>>        Send ComAddWindowClass "cVdfTreeView"            "SysTreeView32"
80653>>>    End_Procedure
80654>>>    
80654>>>    // Used to support developer designed class mappings (e.g. COM controls)
80654>>>    Procedure OnAddCustomWindowClasses
80656>>>    End_Procedure
80657>>>
80657>>>    // called when object is created during end_construct_object.
80657>>>    Procedure OnCreate
80659>>>        Integer iOpts
80659>>>        Boolean bUseWindowsFont
80659>>>        Forward Send OnCreate
80661>>>        
80661>>>        // if we are using the windows fonts we will disable the apply metrics which
80661>>>        // never really looked good anyway. This test only exists or legacy purposes
80661>>>        Get pbUseWindowsFont of Desktop to bUseWindowsFont
80662>>>        If bUseWindowsFont Begin
80664>>>            Get ComApplyOptions to iOpts
80665>>>            Set ComApplyOptions to (RemoveBitValue(xtpSkinApplyMetrics, iOpts))
80666>>>        End
80666>>>>
80666>>>
80666>>>        // this works around a CJ issue where skins applied to other threads causes an exception upon close down. 
80666>>>        // We saw this with our mssql driver but it could occur elsewhere. This has been reported in the CJ newsgroup
80666>>>        // and this was the suggested workaround.
80666>>>        Set ComAutoApplyNewThreads to False
80667>>>
80667>>>        Send OnAddVDFWindowClasses
80668>>>        Send OnAddCustomWindowClasses
80669>>>        
80669>>>        // if preferences are used, it will set psSkinFile and psSkinIni
80669>>>        If (pbLoadPreference(Self)) Begin
80671>>>            Send LoadSkinPreference
80672>>>        End
80672>>>>
80672>>>        // if a skin file name exists, we apply the skin.    
80672>>>        If (psSkinFile(Self)<>"") Begin
80674>>>            Send ApplySkin
80675>>>        End        
80675>>>>
80675>>>    End_Procedure
80676>>>    
80676>>>    // called by framework as part of application exit.
80676>>>    Procedure Broadcast_Notify_Exit_Application
80678>>>        Send Notify_Exit_Application
80679>>>    End_Procedure // Notify_Exit_Application
80680>>>
80680>>>    Procedure Notify_Exit_Application
80682>>>        If (pbLoadPreference(Self)) Begin
80684>>>            Send SaveSkinPreference
80685>>>        End
80685>>>>
80685>>>    End_Procedure
80686>>>
80686>>>    Procedure NotifyPreApplySkin
80688>>>        Broadcast Send OnPreApplySkin of Desktop True       
80690>>>    End_Procedure
80691>>>
80691>>>    Procedure NotifyPostApplySkin
80693>>>        Broadcast Send OnPostApplySkin of Desktop True       
80695>>>    End_Procedure
80696>>>    
80696>>>    // returns an array of all skins in the path. If path is "", use the default path.
80696>>>    // If the default path is used, returns the file names as relative names, else use full path.
80696>>>    Function EnumerateSkins String sPath Boolean bRecursive Returns tSkinInformation[]
80698>>>        tSkinInformation[] Skins
80698>>>        tSkinInformation[] Skins
80699>>>        String sSkinName sSkinFile sDefaultPath sSep
80699>>>        Variant vSkinDescriptions vSkinDescription vSkinIniFile
80699>>>        Handle hSkinDescriptions hSkinDescription hSkinIniFile
80699>>>        Integer iSkinsCount iSkinFilesCount iNumSkins iNumSkinFiles iArrayItem
80699>>>        Integer iPos iDfltLen
80699>>>        Boolean bUseRelativePath
80699>>>        
80699>>>        Move (SysConf(SYSCONF_DIR_SEPARATOR)) to sSep
80700>>>        
80700>>>        Get SkinPath to sDefaultPath
80701>>>        If (sPath="") Begin
80703>>>            Move sDefaultPath to sPath
80704>>>        End
80704>>>>
80704>>>        Move (Uppercase(sDefaultPath)) to sDefaultPath
80705>>>        Move (Length(sDefaultPath)) to iDfltLen
80706>>>        Move (sDefaultPath=Uppercase(sPath)) to bUseRelativePath
80707>>>
80707>>>        Get ComEnumerateSkinDirectory sPath bRecursive to vSkinDescriptions
80708>>>        If (not(IsNullComObject(vSkinDescriptions))) Begin
80710>>>
80710>>>            Get Create U_cCJSkinDescriptions to hSkinDescriptions
80711>>>            Get Create U_cCJSkinDescription to hSkinDescription
80712>>>            Get Create U_cCJSkinIniFile to hSkinIniFile
80713>>>            
80713>>>            Set pvComObject of hSkinDescriptions to vSkinDescriptions
80714>>>            Get ComCount of hSkinDescriptions to iNumSkinFiles
80715>>>            
80715>>>            For iSkinFilesCount from 0 to (iNumSkinFiles-1)
80721>>>>
80721>>>                Get ComSkin of hSkinDescriptions iSkinFilesCount to vSkinDescription
80722>>>                Set pvComObject of hSkinDescription to vSkinDescription
80723>>>
80723>>>                Get ComCount of hSkinDescription to iNumSkins
80724>>>                    
80724>>>                For iSkinsCount from 0 to (iNumSkins-1)
80730>>>>
80730>>>                    Get ComIniFile of hSkinDescription iSkinsCount to vSkinIniFile
80731>>>                    Set pvComObject of hSkinIniFile to vSkinIniFile
80732>>>
80732>>>                    Get ComName of hSkinDescription to Skins[iArrayItem].sName
80733>>>                    Get ComPath of hSkinDescription to sSkinFile
80734>>>                    If bUseRelativePath Begin
80736>>>                        Move (pos(sDefaultPath,uppercase(sSkinFile))) to iPos
80737>>>                        If iPos Begin
80739>>>                            Move (Remove(sSkinFile,iPos,iDfltLen)) to sSkinFile   
80740>>>                            While (Left(sSkinFile,1)=sSep)
80744>>>                                Move (Remove(sSkinFile,1,1)) to sSkinFile   
80745>>>                            Loop                         
80746>>>>
80746>>>                        End
80746>>>>
80746>>>                    End
80746>>>>
80746>>>                    Move sSkinFile to Skins[iArrayItem].sSkinfile
80747>>>                    Get ComIniFileName of hSkinIniFile to Skins[iArrayItem].sSkinIni
80748>>>
80748>>>                    Increment iArrayItem
80749>>>                Loop
80750>>>>
80750>>>            Loop
80751>>>>
80751>>>                            
80751>>>            Send Destroy of hSkinDescriptions
80752>>>            Send Destroy of hSkinDescription
80753>>>            Send Destroy of hSkinIniFile
80754>>>                
80754>>>        End
80754>>>>
80754>>>        Function_Return Skins
80755>>>    End_Function 
80756>>>    
80756>>>    // Save the skin preference. This requires an application object.
80756>>>    // Only do this if the application object allows it. 
80756>>>    // This is called during startup if pbLoadPreference is True
80756>>>    // Suitable for override
80756>>>    Procedure SaveSkinPreference 
80758>>>        String sSkin sIni
80758>>>        If ghoApplication Begin
80760>>>            If (pbPreserveEnvironment(ghoApplication)) Begin
80762>>>                Get psSkinFile to sSkin
80763>>>                Get psSkinIni to sIni
80764>>>                Send WriteString of ghoApplication "Preferences" "SkinFile" sSkin
80765>>>                Send WriteString of ghoApplication "Preferences" "SkinIni" sIni
80766>>>            End
80766>>>>
80766>>>        End
80766>>>>
80766>>>        Else Begin
80767>>>            Error DFERR_PROGRAM C_$ApplicationObjectNotCreated
80768>>>>
80768>>>        End
80768>>>>
80768>>>    End_Procedure
80769>>>
80769>>>    // Load the skin preference. This requires an application object.
80769>>>    // Only do this if the application object allows it. 
80769>>>    // This is called during startup if pbLoadPreference is True
80769>>>    // Suitable for override
80769>>>    Procedure LoadSkinPreference 
80771>>>        String sSkin sIni
80771>>>        Boolean bExists
80771>>>        If ghoApplication Begin
80773>>>            If (pbPreserveEnvironment(ghoApplication)) Begin
80775>>>                Get ValueExists of ghoApplication "Preferences" "SkinFile" to bExists
80776>>>                If bExists Begin
80778>>>                    Get ReadString of ghoApplication "Preferences" "SkinFile" "" to sSkin
80779>>>                    Get ReadString of ghoApplication "Preferences" "SkinIni" "" to sIni
80780>>>                    Set psSkinFile to sSkin
80781>>>                    Set psSkinIni to sIni
80782>>>                End
80782>>>>
80782>>>            End
80782>>>>
80782>>>        End
80782>>>>
80782>>>        Else Begin
80783>>>            Error DFERR_PROGRAM C_$ApplicationObjectNotCreated
80784>>>>
80784>>>        End
80784>>>>
80784>>>    End_Procedure
80785>>>
80785>>>    // Can be called to apply the current skin.
80785>>>    Procedure ApplySkin
80787>>>        Boolean bOk
80787>>>        String sSkin sIni
80787>>>        If (IsComObjectCreated(Self)) Begin
80789>>>            Get SkinQFile to sSkin
80790>>>            Get psSkinIni to sIni
80791>>>            
80791>>>            Send NotifyPreApplySkin
80792>>>            // when skins are used we don't want to use built in Visual Styles
80792>>>            Send EnableVisualStyles of Desktop (sSkin="")
80793>>>            Get ComLoadSkin sSkin sIni to bOK
80794>>>            If (sSkin<>"" and not(bOk)) Begin
80796>>>                // if not ok, no skin was appied. Enable visual styles
80796>>>                Send EnableVisualStyles of Desktop True
80797>>>            End
80797>>>>
80797>>>            Send NotifyPostApplySkin
80798>>>        End
80798>>>>
80798>>>    End_Procedure
80799>>>
80799>>>
80799>>>End_Class
