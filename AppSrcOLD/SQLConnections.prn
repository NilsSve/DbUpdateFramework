88884>>>    // Returns an array with all ".int" files for the passed sDataPath, _except_ for the driver .int files;
88884>>>    // "MSSQLDRV.int", "DB2_DRV.int" & "ODBC_DRV.int".
88884>>>    Function SqlUtilEnumerateIntFiles String sDataPath Returns String[]
88886>>>        String[] sFilesData
88887>>>        Boolean bExists
88887>>>        Integer iCh
88887>>>        String sFileName sExt
88887>>>        
88887>>>        Get vFolderExists sDataPath to bExists
88888>>>        If (bExists = True) Begin
88890>>>            Move (ToANSI(Trim(sDataPath))) to sDataPath
88891>>>            Move ("dir:" + sDataPath)      to sDataPath
88892>>>            Get Seq_New_Channel to iCh  // get free channel for input
88893>>>            Direct_Input channel iCh sDataPath
88895>>>                Repeat
88895>>>>
88895>>>                    Readln channel iCh sFileName
88897>>>                    Get ParseFileExtension sFileName to sExt
88898>>>                    If (Uppercase(sExt) = "INT") Begin
88900>>>                        If (not(Uppercase(sFileName) contains "MSSQLDRV" and Uppercase(sFileName) contains "DB2_DRV" and Uppercase(sFileName) contains "ODBC_DRV")) Begin
88902>>>                            Move sFileName to sFilesData[SizeOfArray(sFilesData)]
88903>>>                        End
88903>>>>
88903>>>                    End
88903>>>>
88903>>>                Until (SeqEof = True)
88905>>>            Close_Input channel iCh
88907>>>        End
88907>>>>
88907>>>        Function_Return sFilesData
88908>>>    End_Function                                  
88909>>>    
88909>>>    // Returns a handle to the SQL server associated with the passed driver ID.
88909>>>    // Pass e.g. the psServer property to determine the current connection server.
88909>>>    // Returns a handle to the database connection, or a zero (0) if it fails.
88909>>>    // This handle can be used to obtain attributes about the server, such as default
88909>>>    // column types.
88909>>>    Function SqlUtilDatabaseHandle String sDriverID String sServer Returns Handle
88911>>>        Handle hDatabase
88911>>>        Integer iDriver iServers iCount
88911>>>        String sValue
88911>>>        
88911>>>        If (sServer = "") Begin
88913>>>            Function_Return 0
88914>>>        End 
88914>>>>
88914>>>        
88914>>>        Get DriverIndex sDriverID to iDriver
88915>>>        If (iDriver = 0) Begin
88917>>>            Function_Return 0
88918>>>        End                  
88918>>>>
88918>>>        
88918>>>        Get_Attribute DF_DRIVER_NUMBER_SERVERS of iDriver to iServers
88921>>>        For iCount from 1 to iServers
88927>>>>
88927>>>            Get_Attribute DF_DRIVER_SERVER_NAME of iDriver iCount to sValue
88930>>>            If (Uppercase(sValue) contains Uppercase(sServer)) Begin
88932>>>                Get_Attribute DF_DATABASE_ID of iDriver iCount to hDatabase
88935>>>            End
88935>>>>
88935>>>        Loop
88936>>>>
88936>>>                
88936>>>        Function_Return hDatabase
88937>>>    End_Function
88938>>>
88938>>>    Procedure SqlUtilExecuteQuery String sStmt String sDriverID Boolean bShowProgr 
88940>>>        String sConnectionString sMessage
88940>>>        Handle hoSqlHandler hoSQLConnect hoStmt hoError
88940>>>        Integer i iMsgs iFetchResult iResultCount iRowType iRows iErr iMessage
88940>>>        String[] sMsg aSQLQueryMessages aSQLFetchResults
88943>>>        DateTime dtQueryExecStart dtQueryExecEnd dtFetchStart dtFetchEnd
88943>>>        TimeSpan tsQuery tsFetch
88943>>>        tSqlErrorArray aSqlErrorArray
88943>>>        tSqlErrorArray aSqlErrorArray
88943>>>        Boolean bOK bMertechDriver bShowProgress
88943>>>        tSQLConnection SQLConnection
88943>>>        tSQLConnection SQLConnection
88943>>>        
88943>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
88944>>>        If (bOK = False) Begin
88946>>>            Procedure_Return
88947>>>        End
88947>>>>
88947>>>        
88947>>>        If (num_arguments > 2) Begin
88949>>>            Move bShowProgr to bShowProgress
88950>>>        End
88950>>>>
88950>>>
88950>>>        Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
88951>>>        
88951>>>        Get IsMertechDriver sDriverID to bMertechDriver
88952>>>        If (bMertechDriver = True) Begin
88954>>>            Get _MertechSQLConnect sDriverID SQLConnection.sServer SQLConnection.sUserID SQLConnection.sPassword to hoSQLConnect
88955>>>        End
88955>>>>
88955>>>        If (bMertechDriver = False) Begin
88957>>>            Get phoSQLManager to hoSqlHandler
88958>>>            Send SqlSetConnect of hoSqlHandler sDriverID SQLConnection.sConnectionString
88959>>>            Get SqlConnect     of hoSqlHandler "" "" to hoSQLConnect
88960>>>        End
88960>>>>
88960>>>
88960>>>        If (hoSQLConnect <> 0) Begin
88962>>>            Get SqlOpen of hoSQLConnect to hoStmt
88963>>>            If (hoStmt <> 0) Begin
88965>>>                // record starting date/time stamp
88965>>>                Move (CurrentDateTime()) to dtQueryExecStart
88966>>>                // turn on error handling if enabled 
88966>>>                If (pbHandleQueryErrors(Self)) Begin
88968>>>                    Set pbSqlError to False 
88969>>>                    Set paSqlErrorArray to aSqlErrorArray
88970>>>                    Move Error_Object_Id to hoError
88971>>>                    Move Self to Error_Object_Id
88972>>>                End               
88972>>>>
88972>>>                
88972>>>                // Before we execute the statement; save it so we can display the faulty statement in the error log.
88972>>>                Set psSQLStatementString to sStmt
88973>>>                Send SqlExecDirect of hoStmt sStmt
88974>>>                
88974>>>                If (pbHandleQueryErrors(Self)) Begin
88976>>>                    Move hoError to Error_Object_Id
88977>>>                End       
88977>>>>
88977>>>                
88977>>>                Move 0 to iMsgs
88978>>>                // ToDo: There seems to be some issues with this code and Mertech drivers that makes
88978>>>                // the debugger crash in some cases like an error in the ESQL statement; so we exclude it for now.
88978>>>                If (bMertechDriver = False) Begin   
88980>>>                    Move Err to iErr
88981>>>                    Get SqlStmtAttribute of hoStmt SQLSTMTATTRIB_NUMMESSAGES   to iMsgs
88982>>>                    Get SqlStmtAttribute of hoStmt SqlSTMTATTRIB_ROWCOUNT      to iRows
88983>>>                    Get SqlStmtAttribute of hoStmt SqlSTMTATTRIB_ROWCOUNT_TYPE to iRowType
88984>>>                    Send _SqlColumnInfo hoStmt
88985>>>                    Send Ignore_Error of Error_Object_Id 12289    
88986>>>                    Set Error_Report_Mode to DUF_ERROR_NO_REPORT
88987>>>                    Repeat     
88987>>>>
88987>>>                        Get SqlFetch of hoStmt to iFetchResult
88988>>>                        If (iFetchResult <> 0) Begin
88990>>>                            Get SQLColumnValue of hoStmt 1 to aSQLFetchResults[SizeOfArray(aSQLFetchResults)]
88991>>>                        End
88991>>>>
88991>>>                    Until (iFetchResult = 0)
88993>>>                    Send Trap_Error of Error_Object_Id 12289    
88994>>>                    Set Error_Report_Mode to DUF_ERROR_REPORT 
88995>>>                    Move iErr to Err
88996>>>                    Set paSQLFetchResults to aSQLFetchResults
88997>>>                End 
88997>>>>
88997>>>                
88997>>>                Set piRows    to iRows
88998>>>                Set piRowType to iRowType
88999>>>                Move (CurrentDateTime()) to dtQueryExecEnd
89000>>>                Move (CurrentDateTime()) to dtFetchStart
89001>>>
89001>>>                If (iMsgs <> 0) Begin
89003>>>                    If (ghoDbUpdateHandler > 0) Begin
89005>>>                        Get paSQLQueryMessages of ghoDbUpdateHandler to aSQLQueryMessages
89006>>>                    End
89006>>>>
89006>>>                    For i from 1 to iMsgs
89012>>>>
89012>>>                        Get SqlGetMessage of hoStmt i to sMessage
89013>>>                        Get RemoveComponentIdentifier of hoStmt sMessage to sMessage
89014>>>                        If (bShowProgress = True) Begin
89016>>>                            If (Active_State(ghoStatusPanel)) Begin
89018>>>                                Send Update_StatusPanel of ghoStatusPanel (Sformat("  SQLGetMessage iMessage %1 returned [%2]",iMessage,sMessage))
89019>>>                            End                                                   
89019>>>>
89019>>>                            Else Begin
89020>>>                                Showln (Sformat("  SQLGetMessage iMessage %1 returned [%2]",iMessage,sMessage))
89022>>>                            End                                           
89022>>>>
89022>>>                        End
89022>>>>
89022>>>                        Move sMessage to sMsg[SizeOfArray(sMsg)]
89023>>>                        Move sMessage to aSQLQueryMessages[SizeOfArray(aSQLQueryMessages)]
89024>>>                    Loop
89025>>>>
89025>>>                    If (ghoDbUpdateHandler > 0) Begin
89027>>>                        Set paSQLQueryMessages of ghoDbUpdateHandler to aSQLQueryMessages
89028>>>                    End
89028>>>>
89028>>>                    Set paQueryMessages to sMsg  
89029>>>                End
89029>>>>
89029>>>                Move (CurrentDateTime()) to dtFetchEnd
89030>>>            End
89030>>>>
89030>>>            Move (dtQueryExecEnd - dtQueryExecStart) to tsQuery
89031>>>            Move (dtFetchStart - dtFetchEnd) to tsFetch
89032>>>            Set ptsQueryExec to tsQuery
89033>>>            Set ptsFetchResults to tsFetch
89034>>>            Send SqlClose of hoStmt
89035>>>        End
89035>>>>
89035>>>
89035>>>        Send SqlDisconnect of hoSQLConnect
89036>>>    End_Procedure
89037>>>
89037>>>    // *** Main message for executing an SQL script that has been compiled into the program as a resource ***
89037>>>    // Use the SQLIncludeScriptFile command to include an SQL script into the program.
89037>>>    // Returns False if no error occured.
89037>>>    Function SqlUtilExecuteResource String sMemFileName String sDriverID Boolean bCreateScriptFile Boolean bShowProgr Returns Boolean
89039>>>        Boolean bOK bShowProgress                               
89039>>>        tSQLScriptArray SQLScriptArray                      
89039>>>        tSQLScriptArray SQLScriptArray                      
89039>>>        Integer iOut iRows iCount
89039>>>        DateTime dtTotalQueryStart dtTotalQueryEnd
89039>>>        TimeSpan tsTotalTime  
89039>>>        String sMessage
89039>>>        
89039>>>        Move (CurrentDateTime()) to dtTotalQueryStart
89040>>>        Get SqlUtilReadResource sMemFileName to SQLScriptArray
89041>>>        If (SQLScriptArray.bError = True) Begin
89043>>>            Function_Return False
89044>>>        End
89044>>>>
89044>>>
89044>>>        If (num_arguments > 3) Begin
89046>>>            Move bShowProgr to bShowProgress
89047>>>        End
89047>>>>
89047>>>
89047>>>        Set Error_Report_Mode to DUF_ERROR_NO_REPORT
89048>>>        Get SqlUtilExecuteEmbeddedScript SQLScriptArray sDriverID bCreateScriptFile sMemFileName bShowProgress to bOK
89049>>>        Set Error_Report_Mode to DUF_ERROR_REPORT 
89050>>>        
89050>>>        If (SQLScriptArray.bArgumentSizeChanged = True) Begin
89052>>>            Set_Argument_Size SQLScriptArray.iOrgArgumentSize
89053>>>>
89053>>>        End
89053>>>>
89053>>>
89053>>>        Move (CurrentDateTime()) to dtTotalQueryEnd
89054>>>        Move (dtTotalQueryEnd - dtTotalQueryStart) to tsTotalTime
89055>>>        Set ptsTotalQueryTime to tsTotalTime
89056>>>        
89056>>>        Function_Return bOK
89057>>>    End_Procedure
