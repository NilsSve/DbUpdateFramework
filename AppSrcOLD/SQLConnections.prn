83255>>>>>>>>>>>    Procedure HandleError Integer ihstmt Integer ihdbc String sDrvrId String sOriginMsg
83257>>>>>>>>>>>        Integer iErrHandle
83257>>>>>>>>>>>        Integer iErrNum
83257>>>>>>>>>>>        String  sLocationInfo
83257>>>>>>>>>>>
83257>>>>>>>>>>>        //*** Get the DataFlex statement identifier
83257>>>>>>>>>>>        Move Current_object to iErrHandle
83258>>>>>>>>>>>
83258>>>>>>>>>>>        //*** Determine error number
83258>>>>>>>>>>>        If (ihstmt = 0) ;            Move CLIERR_SQLINVALID_CLI_STMT_HANDLE to iErrNum
83261>>>>>>>>>>>        Else If (ihdbc = 0) ;            Move CLIERR_SQLINVALID_CLI_CONN_HANDLE to iErrNum
83265>>>>>>>>>>>        Else If (sDrvrId = "") ;            Move CLIERR_SQLINVALID_DRIVER_ID to iErrNum
83269>>>>>>>>>>>        Else ;            Move CLIERR_SQL_ERROR to iErrNum
83271>>>>>>>>>>>
83271>>>>>>>>>>>        //*** Create location information
83271>>>>>>>>>>>        Move "[" to sLocationInfo
83272>>>>>>>>>>>        If (sOriginMsg <> "") Begin
83274>>>>>>>>>>>            Move (Append(sLocationInfo, sOriginMsg)) to sLocationInfo
83275>>>>>>>>>>>            Move (Append(sLocationInfo, ", "))       to sLocationInfo
83276>>>>>>>>>>>        End
83276>>>>>>>>>>>>
83276>>>>>>>>>>>        Move (Append(sLocationInfo, "DataFlex hstmt = ")) to sLocationInfo
83277>>>>>>>>>>>        Move (Append(sLocationInfo, iErrHandle))          to sLocationInfo
83278>>>>>>>>>>>        Move (Append(sLocationInfo, "]"))                 to sLocationInfo
83279>>>>>>>>>>>
83279>>>>>>>>>>>        //*** Generate the error
83279>>>>>>>>>>>        Error iErrNum sLocationInfo
83280>>>>>>>>>>>>
83280>>>>>>>>>>>    End_Procedure
83281>>>>>>>>>>>    
83281>>>>>>>>>>>    Procedure StmtError Integer iErrNum String sErrText String sOriginMsg
83283>>>>>>>>>>>        Local Integer iErrHandle
83283>>>>>>>>>>>        Local String  sLocationInfo
83283>>>>>>>>>>>
83283>>>>>>>>>>>        //*** Get the DataFlex statement identifier
83283>>>>>>>>>>>        Move Current_object to iErrHandle
83284>>>>>>>>>>>
83284>>>>>>>>>>>
83284>>>>>>>>>>>        //*** Create location information
83284>>>>>>>>>>>        Move "[" to sLocationInfo
83285>>>>>>>>>>>        If (sOriginMsg <> "") Begin
83287>>>>>>>>>>>            Move (Append(sLocationInfo, sOriginMsg)) to sLocationInfo
83288>>>>>>>>>>>            Move (Append(sLocationInfo, ", "))       to sLocationInfo
83289>>>>>>>>>>>        End
83289>>>>>>>>>>>>
83289>>>>>>>>>>>        If (sErrtext <> "") Begin
83291>>>>>>>>>>>            Move (Append(sLocationInfo, sErrtext)) to sLocationInfo
83292>>>>>>>>>>>            Move (Append(sLocationInfo, ", "))     to sLocationInfo
83293>>>>>>>>>>>        End
83293>>>>>>>>>>>>
83293>>>>>>>>>>>        Move (Append(sLocationInfo, "DataFlex hstmt = ")) to sLocationInfo
83294>>>>>>>>>>>        Move (Append(sLocationInfo, iErrHandle))          to sLocationInfo
83295>>>>>>>>>>>        Move (Append(sLocationInfo, "]"))                 to sLocationInfo
83296>>>>>>>>>>>
83296>>>>>>>>>>>        //*** Generate the error
83296>>>>>>>>>>>        Error iErrNum sLocationInfo
83297>>>>>>>>>>>>
83297>>>>>>>>>>>    End_Procedure
83298>>>>>>>>>>>    
83298>>>>>>>>>>>    Procedure SQLIllegalAttribute String sErrText String sOriginMsg
83300>>>>>>>>>>>        Local Integer bReport
83300>>>>>>>>>>>
83300>>>>>>>>>>>        Get_Attribute DF_REPORT_UNSUPPORTED_ATTRIBUTES to bReport
83303>>>>>>>>>>>        If (bReport) ;            Send StmtError CLIERR_SQLINVALID_ATTRIBUTE sErrtext sOriginMsg
