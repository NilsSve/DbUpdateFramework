79697>>>>>Type vtSecurity_attributes
79697>>>>>  Field vtSecurity_attributes.nLength        as dWord
79697>>>>>  Field vtSecurity_attributes.lpDescriptor   as Pointer
79697>>>>>  Field vtSecurity_attributes.bInheritHandle as Integer
79697>>>>>End_Type // vtSecurity_attributes
79697>>>>>
79697>>>>>//nLength:
79697>>>>>// Specifies the size, in bytes, of this structure. Set this value to the size of the
79697>>>>>// SECURITY_ATTRIBUTES structure.
79697>>>>>// Windows NT: Some functions that use the SECURITY_ATTRIBUTES structure do not verify the
79697>>>>>// value of the nLength member. However, an application should still set it properly.
79697>>>>>// That ensures current, future, and cross-platform compatibility.
79697>>>>>//
79697>>>>>//lpSecurityDescriptor:
79697>>>>>// Points to a security descriptor for the object that controls the sharing of it.
79697>>>>>// If NULL is specified for this member, the object may be assigned the default security
79697>>>>>// descriptor of the calling process.
79697>>>>>//
79697>>>>>//bInheritHandle:
79697>>>>>// Specifies whether the returned handle is inherited when a new process is created.
79697>>>>>// If this member is TRUE, the new process inherits the handle.
79697>>>>>
79697>>>>>
79697>>>>>// BOOL CreateDirectory(
79697>>>>>//    LPCTSTR lpPathName,
79697>>>>>//    LPSECURITY_ATTRIBUTES lpSecurityAttributes  // pointer to a security descriptor
79697>>>>>//   );
79697>>>>>//
79697>>>>>// lpPathName
79697>>>>>//  Points to a null-terminated string that specifies the path of the directory
79697>>>>>//  to be created.
79697>>>>>//  There is a default string size limit for paths of MAX_PATH characters.
79697>>>>>//  This limit is related to how the CreateDirectory function parses paths.
79697>>>>>// lpSecurityAttributes
79697>>>>>//  Pointer to a SECURITY_ATTRIBUTES structure als called a security descriptor that
79697>>>>>//  determines whether the returned handle can be inherited by child processes.
79697>>>>>//  If lpSecurityAttributes is NULL, the handle cannot be inherited.
79697>>>>>// Returns:
79697>>>>>//  If the function succeeds, the return value is nonzero.
79697>>>>>//  If the function fails, the return value is zero. To get extended error information, call GetLastError.
79697>>>>>External_function vWin32_CreateDirectory "CreateDirectoryA" kernel32.dll ;  Pointer lpPathName Pointer lpSecurity_Attributes Returns Integer
79698>>>>>
79698>>>>>
79698>>>>>// lpPathName
79698>>>>>//  Points to a null-terminated string that specifies the path of the directory
79698>>>>>//  to be removed.
79698>>>>>//  There is a default string size limit for paths of MAX_PATH characters.
79698>>>>>// Returns:
79698>>>>>//  If the function succeeds, the return value is nonzero.
79698>>>>>//  If the function fails, the return value is zero. To get extended error information, call GetLastError.
79698>>>>>External_function vWin32_RemoveDirectory "RemoveDirectoryA" kernel32.dll ;  Pointer lpPathName Returns Integer
