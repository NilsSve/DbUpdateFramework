88774>>>        Decrement iSize
88775>>>        For iCount from 0 to iSize
88781>>>>
88781>>>            If (Trim(sReturnArray[iCount]) <> "") Begin
88783>>>                Move sReturnArray[iCount] to sReturnArray2[SizeOfArray(sReturnArray2)]
88784>>>            End
88784>>>>
88784>>>        Loop
88785>>>>
