86537>>>    Function ExistingConnectionSettings String sDriverID String sConnectionID Returns tSQLConnection
86539>>>        Integer iResult iDriver iNumConn iConn
86539>>>        Handle hoCLI
86539>>>        String sID sConnectionString sVal sDatabase
86539>>>        tSQLConnection SQLConnection
86539>>>        tSQLConnection SQLConnection
86539>>>        Boolean bTrusted
86539>>>        
86539>>>        Move 0 to iResult
86540>>>        Get Create U_cCLIHandler to hoCLI
86541>>>        If (hoCLI <> 0) Begin
86543>>>            Set psDriverID of hoCLI to sDriverID
86544>>>            Get DriverIndex sDriverID to iDriver
86545>>>            Get_Attribute DF_DRIVER_NUMBER_CONNECTION_IDS of iDriver to iNumConn 
86548>>>            Decrement iNumConn
86549>>>            For iConn from 0 to iNumConn
86555>>>>
86555>>>                Get_Attribute DF_DRIVER_CONNECTION_ID of iDriver iConn to sID
86558>>>                If (Uppercase(sID) = Uppercase(sConnectionID)) Begin                                             
86560>>>                    Move sDriverID                                                      to SQLConnection.sDriverID      // For completeness only...
86561>>>                    Get_Attribute DF_DRIVER_CONNECTION_ID of iDriver iConn              to SQLConnection.sConnectionID  // For completeness only...
86564>>>                    Get_Attribute DF_DRIVER_CONNECTION_ID_STRING of iDriver iConn       to sConnectionString
86567>>>                    Move sConnectionString                                              to SQLConnection.sConnectionString 
86568>>>                    Get_Attribute DF_DRIVER_CONNECTION_ID_OPTIONS of iDriver iConn      to SQLConnection.bSilentLogin
86571>>>                    Get ParseKeyWord sConnectionString (CS_SQLIniServerKeyword + "=")   to SQLConnection.sServer
86572>>>                    Get ParseKeyWord sConnectionString (CS_SQLIniDatabaseKeyword + "=") to SQLConnection.sDatabase
86573>>>                    Get ParseKeyWord sConnectionString (CS_SQLIniUIDKeyword + "=")      to SQLConnection.sUserID
86574>>>                    Get ParseKeyWord sConnectionString (CS_SQLIniPWDKeyword + "=")      to SQLConnection.sPassword
86575>>>                    
86575>>>                    Case Begin
86575>>>                        Case (sDriverID = MSSQLDRV_ID)
86577>>>                            Get ParseKeyWord sConnectionString (CS_SQLIniTrustedKeyword + "=") to sVal
86578>>>                            Move (If(Uppercase(sVal) = Uppercase(CS_SQLIniConnectionYes), True, False)) to bTrusted
86579>>>                            Move bTrusted                                               to SQLConnection.bTrusted
86580>>>                            Case Break
86581>>>                        Case (sDriverID = DB2_DRV_ID)
86584>>>                            Get ParseKeyWord sConnectionString (CS_SQLIniDSNKeyword + "=") to SQLConnection.sServer
86585>>>                            Case Break
86586>>>                        Case (sDriverID = ODBC_DRV_ID)
86589>>>                            Get ParseKeyWord sConnectionString (CS_SQLIniDSNKeyword + "=") to SQLConnection.sServer
86590>>>                            Case Break
86591>>>                        Case (sDriverID = SQLFLEX)
86594>>>                            Get ParseKeyWord sConnectionString (CS_SQLIniDSNKeyword + "=") to SQLConnection.sServer 
86595>>>                            Move (CS_SQLIniServerKeyword + "=" + SQLConnection.sServer)    to sConnectionString
86596>>>                            If (SQLConnection.bTrusted = True) Begin
86598>>>                                Move (sConnectionString + ";" + CS_SQLIniTrustedKeyword + "=" + CS_SQLIniConnectionYes) to sConnectionString
86599>>>                            End
86599>>>>
86599>>>                            Else Begin
86600>>>                                Get ParseKeyWord sConnectionString (CS_SQLIniUIDKeyword + "=")    to sVal
86601>>>                                Move (sConnectionString + ";" + CS_SQLIniUIDKeyword + "=" + sVal) to sConnectionString
86602>>>                                Get ParseKeyWord sConnectionString (CS_SQLIniPWDKeyword + "=")    to sVal
86603>>>                                Move (sConnectionString + ";" + CS_SQLIniPWDKeyword + "=" + sVal) to sConnectionString
86604>>>                            End
86604>>>>
86604>>>                            Move sConnectionString                                         to SQLConnection.sConnectionString
86605>>>                            Case Break
86606>>>                        Case (sDriverID = MDSMySQL)
86609>>>                            Get ParseKeyWord sConnectionString (CS_SQLIniDSNKeyword + "=") to SQLConnection.sServer 
86610>>>                            Move (CS_SQLIniServerKeyword + "=" + SQLConnection.sServer)    to sConnectionString
86611>>>                            If (SQLConnection.bTrusted = True) Begin
86613>>>                                Move (sConnectionString + ";" + CS_SQLIniTrustedKeyword + "=" + CS_SQLIniConnectionYes) to sConnectionString
86614>>>                            End
86614>>>>
86614>>>                            Else Begin
86615>>>                                Get ParseKeyWord sConnectionString (CS_SQLIniUIDKeyword + "=")    to sVal
86616>>>                                Move (sConnectionString + ";" + CS_SQLIniUIDKeyword + "=" + sVal) to sConnectionString
86617>>>                                Get ParseKeyWord sConnectionString (CS_SQLIniPWDKeyword + "=")    to sVal
86618>>>                                Move (sConnectionString + ";" + CS_SQLIniPWDKeyword + "=" + sVal) to sConnectionString
86619>>>                            End
86619>>>>
86619>>>                            Move sConnectionString                                         to SQLConnection.sConnectionString
86620>>>                            Case Break
86621>>>                        Case (sDriverID = MDSPgSQL)
86624>>>                            Get ParseKeyWord sConnectionString (CS_SQLIniDSNKeyword + "=") to SQLConnection.sServer 
86625>>>                            Move (CS_SQLIniServerKeyword + "=" + SQLConnection.sServer)    to sConnectionString
86626>>>                            If (SQLConnection.bTrusted = True) Begin
86628>>>                                Move (sConnectionString + ";" + CS_SQLIniTrustedKeyword + "=" + CS_SQLIniConnectionYes) to sConnectionString
86629>>>                            End
86629>>>>
86629>>>                            Else Begin
86630>>>                                Get ParseKeyWord sConnectionString (CS_SQLIniUIDKeyword + "=")    to sVal
86631>>>                                Move (sConnectionString + ";" + CS_SQLIniUIDKeyword + "=" + sVal) to sConnectionString
86632>>>                                Get ParseKeyWord sConnectionString (CS_SQLIniPWDKeyword + "=")    to sVal
86633>>>                                Move (sConnectionString + ";" + CS_SQLIniPWDKeyword + "=" + sVal) to sConnectionString
86634>>>                            End
86634>>>>
86634>>>                            Move sConnectionString                                                to SQLConnection.sConnectionString
86635>>>                            Case Break
86636>>>                        
86636>>>                        Case (sDriverID = ORAFLEX)
86639>>>                            Get ParseKeyWord sConnectionString (CS_SQLIniDSNKeyword + "=")      to SQLConnection.sServer 
86640>>>                            Move (CS_SQLIniServerKeyword + "=" + SQLConnection.sServer)         to sConnectionString
86641>>>                            Get ParseKeyWord sConnectionString (CS_SQLIniDatabaseKeyword + "=") to sDatabase
86642>>>                            If (sDatabase <> "" and (not(SQLConnection.sServer contains "/"))) Begin
86644>>>                                Move (SQLConnection.sServer + "/" + sDatabase)                  to SQLConnection.sServer
86645>>>                            End
86645>>>>
86645>>>                            If (SQLConnection.bTrusted = True) Begin
86647>>>                                Move (sConnectionString + ";" + CS_SQLIniTrustedKeyword + "=" + CS_SQLIniConnectionYes) to sConnectionString
86648>>>                            End
86648>>>>
86648>>>                            Else Begin
86649>>>                                Get ParseKeyWord sConnectionString (CS_SQLIniUIDKeyword + "=")    to sVal
86650>>>                                Move (sConnectionString + ";" + CS_SQLIniUIDKeyword + "=" + sVal) to sConnectionString
86651>>>                                Get ParseKeyWord sConnectionString (CS_SQLIniPWDKeyword + "=")    to sVal
86652>>>                                Move (sConnectionString + ";" + CS_SQLIniPWDKeyword + "=" + sVal) to sConnectionString
86653>>>                            End
86653>>>>
86653>>>                            Move sConnectionString                                         to SQLConnection.sConnectionString
86654>>>                            Case Break
86655>>>                        Case Else
86655>>>                            Error ("Wrong driver ID passed:" * sDriverID)
86656>>>>
86656>>>                            Case Break
86657>>>                    Case End                    
86657>>>                End
86657>>>>
86657>>>            Loop
86658>>>>
86658>>>            Send Destroy of hoCLI
86659>>>        End
86659>>>>
86659>>>        
86659>>>        Function_Return SQLConnection
86660>>>    End_Function
