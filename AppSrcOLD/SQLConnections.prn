85939>>>>>    // Returns the full path of the Application (no trailing "\")
85939>>>>>    Function ApplicationPath Returns String
85941>>>>>        String sApplicationFileName sPath
85941>>>>>        Integer iNumChars iRetval
85941>>>>>
85941>>>>>        Move (Repeat(Character(0), 1024))    to sApplicationFileName
85942>>>>>        Move (GetModuleFileName(0, AddressOf(sApplicationFileName), 1024)) to iNumChars
85943>>>>>        Move (CString(sApplicationFileName)) to sApplicationFileName
85944>>>>>        Move (PathRemoveFileSpec(AddressOf(sApplicationFileName))) to iRetval
85945>>>>>        Move (CString(sApplicationFileName)) to sPath
85946>>>>>
85946>>>>>        Function_Return sPath
85947>>>>>    End_Function
