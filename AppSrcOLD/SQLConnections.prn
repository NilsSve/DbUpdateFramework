97505>>>>>    Function MoveStringArrayToSQLConnection String[] sConnectionData Returns tSQLConnection
97508>>>>>        tSQLConnection SQLConnection
97508>>>>>        tSQLConnection SQLConnection
97508>>>>>        String sValue
97508>>>>>        
97508>>>>>        Move sConnectionData[1]  to SQLConnection.bEnabled
97509>>>>>        Move sConnectionData[2]  to SQLConnection.sConnectionID
97510>>>>>        Get SqlUtilDbTypeToInteger of ghoDbUpdateFunctionLibrary sConnectionData[3] to SQLConnection.iDbType
97511>>>>>        Move sConnectionData[4]  to SQLConnection.sDriverID
97512>>>>>        Move sConnectionData[5]  to SQLConnection.sServer
97513>>>>>        Move sConnectionData[6]  to SQLConnection.sDatabase
97514>>>>>
97514>>>>>        Move sConnectionData[8]  to SQLConnection.bTrusted
97515>>>>>        Move sConnectionData[9]  to SQLConnection.sUserID
97516>>>>>
97516>>>>>        If (sConnectionData[10] <> "" and pbDFConnId(Self) = False) Begin 
97518>>>>>            Move sConnectionData[10] to SQLConnection.sPassword
97519>>>>>        End
97519>>>>>>
97519>>>>>        // In case of we're dealing with a DfConnID.ini file (DF 19+) we don't want to change the password
97519>>>>>        // as DAW's 'Managed Connections' program has a different password encryption/decryption algorithm.
