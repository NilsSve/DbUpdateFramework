88787>>>    // Returns a string array with all table names the passed table handle has relation ships with.
88787>>>    // The format of the array is "TableName.FieldName"
88787>>>    Function SqlUtilEnumerateRelations String sTableName String sDriverID Returns tSQLRelation[]
88789>>>        String[] sFileNameArray sFieldNameArray
88791>>>        tSQLRelation[] sRelationsArray
88791>>>        tSQLRelation[] sRelationsArray
88792>>>        String sServer sConnectionString sSelect sSchema sFileName sFieldName sVal
88792>>>        Boolean bOK  
88792>>>        Integer iCount iSize iLength iPos 
88792>>>        Integer iFileNumber iFieldNumber
88792>>>        
88792>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
88793>>>        If (bOK = False) Begin
88795>>>            Error DFERR_PROGRAM ("Unsupported driver. A list of table columns could not be retrieved for:" * sDriverID + ".")
88796>>>>
88796>>>            Function_Return sRelationsArray
88797>>>        End   
88797>>>>
88797>>>       
88797>>>        Get psConnectionString to sConnectionString  
88798>>>        Get psSchema to sSchema
88799>>>        
88799>>>        Case Begin
88799>>>            Case (sDriverID = MSSQLDRV_ID)    
88801>>>                Move ("SELECT object_name(parent_object_id), object_name(referenced_object_id), name from sys.foreign_keys WHERE parent_object_id = object_id( '" + sTableName + "')") to sSelect
88802>>>                Get SqlEnumerateEsqlDAW sSelect 2 to sFileNameArray
88803>>>                Get SqlEnumerateEsqlDAW sSelect 3 to sFieldNameArray
88804>>>                Case Break
88805>>>
88805>>>            Case (sDriverID = DB2_DRV_ID) 
88808>>>                Error "Not implemented yet! The select statement has not been finalized."
88809>>>>
88809>>>//                Move () to sSelect
88809>>>//                Get SqlEnumerateEsqlDAW sSelect 2 to sReturnArray
88809>>>//                Get SqlEnumerateEsqlDAW sSelect 3 to sFieldNameArray
88809>>>                Case Break
88810>>>
88810>>>            Case (sDriverID = SQLFLEX)
88813>>>                Error "Not implemented yet! The select statement has not been finalized."
88814>>>>
88814>>>//                Move () to sSelect
88814>>>//                Get SqlEnumerateEsqlMertech sSelect 2 to sReturnArray
88814>>>//                Get SqlEnumerateEsqlDAW sSelect 3 to sFieldNameArray
88814>>>                Case Break
88815>>>            
88815>>>            Case (sDriverID = MDSMySQL) 
88818>>>                Error "Not implemented yet! The select statement has not been finalized."
88819>>>>
88819>>>//                Move () to sSelect
88819>>>//                Get SqlEnumerateEsqlMertech sSelect 2 to sReturnArray
88819>>>//                Get SqlEnumerateEsqlDAW sSelect 3 to sFieldNameArray
88819>>>                Case Break
88820>>>            
88820>>>            Case (sDriverID = MDSPgSQL) 
88823>>>                Error "Not implemented yet! The select statement has not been finalized."
88824>>>>
88824>>>//                Move () to sSelect
88824>>>//                Get SqlEnumerateEsqlMertech sSelect 2 to sReturnArray
88824>>>//                Get SqlEnumerateEsqlDAW sSelect 3 to sFieldNameArray
88824>>>                Case Break            
88825>>>            
88825>>>            Case (sDriverID = ORAFLEX) 
88828>>>                Error "Not implemented yet! The select statement has not been finalized."
88829>>>>
88829>>>//                Move () to sSelect
88829>>>//                Get SqlEnumerateEsqlMertech sSelect to sReturnArray
88829>>>//                Get SqlEnumerateEsqlDAW sSelect 3 to sFieldNameArray
88829>>>                Case Break
88830>>>                            
88830>>>            Case Else     
88830>>>                Error DFERR_PROGRAM "Unsupported driver passed to the SqlUtilEnumerateRelations function."
88831>>>>
88831>>>                Case Break
88832>>>        Case End   
88832>>>        
88832>>>        Move (Length(sTableName)) to iLength
88833>>>        Move (iLength + 4)        to iLength // The related to field key has the format "FK_TableName + FieldName"
88834>>>        Move (SizeOfArray(sFileNameArray)) to iSize
88835>>>        Decrement iSize
88836>>>        For iCount from 0 to iSize
88842>>>>
88842>>>            If (Trim(sFileNameArray[iCount]) <> "") Begin
88844>>>                Move sFileNameArray[iCount]         to sFileName 
88845>>>                Move sFieldNameArray[iCount]        to sFieldName
88846>>>                Move (Mid(sFieldName, 99, iLength)) to sFieldName
88847>>>                Move sFileName  to sRelationsArray[iCount].sFileName
88848>>>                Move sFieldName to sRelationsArray[iCount].sFieldName
88849>>>            End
88849>>>>
88849>>>        Loop
88850>>>>
88850>>>        
88850>>>        Function_Return sRelationsArray
88851>>>    End_Function  
