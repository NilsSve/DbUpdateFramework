90770>>>    // Removes the passed table name completely from disk, filelist (& Sql Server if an Sql-driver)
90770>>>    Function ApiTableRemove Handle hTable Returns Boolean
90772>>>        String sTableName sDriverID  
90772>>>        Boolean bOk     
90772>>>        String sDataPath
90772>>>        
90772>>>        Get AutoConnectionIDLogin to bOK
90773>>>        Move False to Err 
90774>>>        Get psDriverID to sDriverID
90775>>>        Get UtilTableHandleToString hTable sDriverID to sTableName
90776>>>        If (sTableName = "") Begin
90778>>>            Function_Return False
90779>>>        End                      
90779>>>>
90779>>>        
90779>>>        Send Ignore_Error of Error_Object_Id DFERR_CANT_DELETE_FILE
90780>>>        Delete_db sTableName 
90781>>>        Send Trap_Error of Error_Object_Id DFERR_CANT_DELETE_FILE 
90782>>>        
90782>>>        If (sDriverID <> DATAFLEX_ID) Begin
90784>>>            Get SqlTableRemoveByTableName sDriverID sTableName to bOk   
90785>>>            Get psDataPathFirstPart to sDataPath
90786>>>            Get vDeleteFile (sDataPath + sTableName + ".int") to bOk
90787>>>        End
90787>>>>
90787>>>        // Also remove table from filelist.cfg in case the physical file didn't exist.  
90787>>>        If (hTable <> 0) Begin
90789>>>            Set_Attribute DF_FILE_ROOT_NAME     of hTable to ""
90792>>>            Set_Attribute DF_FILE_DISPLAY_NAME  of hTable to ""
90795>>>            Set_Attribute DF_FILE_LOGICAL_NAME  of hTable to ""  
90798>>>        End
90798>>>>
90798>>>        
90798>>>        Function_Return (hTable <> 0)
90799>>>    End_Function
