95665>>>
95665>>>// *************************************************************************
95665>>>//  Public message. It is expected that you will send this message (most
95665>>>//  likely from Activate_About. This creates an about object, activates it
95665>>>//  and destroys it when done. It is not exepected that you will augment this.
95665>>>// *************************************************************************
95665>>>// Sample usage:
95665>>>//   The first two params will automatically be filled from the application settings if not provided.
95665>>>//   Send DoAbout "" "" ("Copyright: 2013" * psCompany(ghoApplication)) "Created by: Your Name" "YourAppBitmap.bmp" "Internet: http://www.YourWebAddress.com" "E-mail: mailto:support@YourEmailAddress.com" "Some other description of choice" "9th param" "and last param"
95665>>>
95665>>>Procedure DoAbout String sTitle String sVersion String sCopyRight String sAuthor String sBitmap ;                  String sParam6 String sParam7 String sParam8 String sParam9 String sParam10
95668>>>        Integer hoObj hoMain iArgs
95668>>>        String sValue
95668>>>
95668>>>        // Create object
95668>>>        Object About is an AboutDialog
95670>>>            // Uncomment these two lines if you would like to have a resizable About object.
95670>>>//            Set Border_Style to Border_Thick
95670>>>//            Set peAnchors to anAll
95670>>>
95670>>>            // Add checking for the number of arguments passed to avoid runtime errors
95670>>>            // if one of them is not passed. This makes the interface
95670>>>            // more flexible.
95670>>>            Move num_arguments to iArgs
95671>>>
95671>>>            // If no title is passed use the label of the main panel (if a main panel exists).
95671>>>            If (iArgs > 0 and sTitle = "") Begin
95673>>>                Get Main_Window of Desktop to hoMain
95674>>>                If hoMain Get Label of hoMain to sValue
95677>>>            End
95677>>>>
95677>>>            Else If (iArgs > 0 and sTitle <> "") Begin
95680>>>                Move sTitle to sValue
95681>>>            End
95681>>>>
95681>>>            Else If (iArgs = 0) Begin
95684>>>                Get Main_Window of Desktop to hoMain
95685>>>                If hoMain Get Label of hoMain to sValue
95688>>>            End
95688>>>>
95688>>>
95688>>>            If (sValue <> "") Send Add_LineLn sValue
95691>>>            Move "" to sValue
95692>>>
95692>>>            // If the passed sVersion value is blank, the info will be retrieved from the cApplication object.
95692>>>            // For this to work the Project Properties Version must have been set in the Studio.
95692>>>            If (iArgs < 2) Begin
95694>>>                Move "" to sValue
95695>>>            End
95695>>>>
95695>>>            Else Begin
95696>>>                Move sVersion to sValue
95697>>>            End
95697>>>>
95697>>>            Set Version to sValue
95698>>>
95698>>>            If (iArgs > 2 and sCopyRight <> "") Send Add_LineLn sCopyRight
95701>>>
95701>>>            // If only the five "standard" params were passed we don't add an extra linefeed;
95701>>>            // else we do.
95701>>>            If (iArgs > 3 and iArgs < 6 and sAuthor <> "") Begin
95703>>>                Send Add_Line sAuthor
95704>>>            End
95704>>>>
95704>>>            Else If (iArgs > 5 and sAuthor <> "") Begin
95707>>>                Send Add_LineLn sAuthor
95708>>>            End
95708>>>>
95708>>>
95708>>>            // Square bitmaps of 80x80 works best
95708>>>            If (iArgs > 4 and sBitmap <> "") Begin
95710>>>               Set Logo to sBitMap
95711>>>            End
95711>>>>
95711>>>
95711>>>            // Here starts handling of the five optional params:
95711>>>            If (iArgs = 6 and sParam6  <> "") Begin
95713>>>                Send Add_Line sParam6
95714>>>            End
95714>>>>
95714>>>            Else If (iArgs > 6 and sParam6  <> "") Begin
95717>>>                Send Add_LineLn sParam6
95718>>>            End
95718>>>>
95718>>>
95718>>>            If (iArgs = 7 and sParam7  <> "") Begin
95720>>>                Send Add_Line sParam7
95721>>>            End
95721>>>>
95721>>>            Else If (iArgs > 7 and sParam7  <> "") Begin
95724>>>                Send Add_LineLn sParam7
95725>>>            End
95725>>>>
95725>>>
95725>>>            If (iArgs = 8 and sParam8  <> "") Begin
95727>>>                Send Add_Line sParam8
95728>>>            End
95728>>>>
95728>>>            Else If (iArgs > 8 and sParam8  <> "") Begin
95731>>>                Send Add_LineLn sParam8
95732>>>            End
95732>>>>
95732>>>
95732>>>            If (iArgs = 9 and sParam9  <> "") Begin
95734>>>                Send Add_Line sParam9
95735>>>            End
95735>>>>
95735>>>            Else If (iArgs > 9 and sParam9  <> "") Begin
95738>>>                Send Add_LineLn sParam9
95739>>>            End
95739>>>>
95739>>>
95739>>>            If (iArgs = 10 and sParam10 <> "") Begin
95741>>>                Send Add_Line sParam10
95742>>>            End
95742>>>>
95742>>>
95742>>>            Move Self to hoObj
95743>>>        End_Object
95744>>>
95744>>>        Send Popup   of hoObj // Popup the about object
95745>>>        Send Destroy of hoObj // When done, it will be destroyed
95746>>>End_Procedure
