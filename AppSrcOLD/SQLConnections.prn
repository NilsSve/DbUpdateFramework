89647>>>    // Formats a columns iLenght & iDecimal parameters as SQL expects them in a string. 
89647>>>    // E.g. (4,2), where 4 is the iLength and 2 the iDecimals param.
89647>>>    Function _SqlFormatLengthAndDecimalAsString Integer iLength Integer iDecimals Returns String
89649>>>        String sRetval
89649>>>        If (iLength <> 0) Begin
89651>>>            Move ("(" + String(iLength)) to sRetval
89652>>>            If (iDecimals <> 0) Begin
89654>>>                Move (sRetval + "," + String(iDecimals)) to sRetval
89655>>>            End
89655>>>>
89655>>>            Move (sRetval + ")") to sRetval
89656>>>        End
89656>>>>
89656>>>        Function_Return sRetval
89657>>>    End_Function
