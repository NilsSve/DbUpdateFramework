93172>>>    // Internal usage. Use the UtilColumnTypeXXX functions instead.
93172>>>    Function _UtilColumnType String sDriverID Integer iDbType Integer iType String sType Boolean bIntegerInputType Returns tColumnType
93174>>>        Integer iValue iSize iCount iStart
93174>>>        tColumnType[] ColumnTypeArray   
93174>>>        tColumnType[] ColumnTypeArray   
93175>>>        tColumnType RetvalType 
93175>>>        tColumnType RetvalType 
93175>>>        String sValue
93175>>>        
93175>>>        Move "Undefined" to RetvalType.sType 
93176>>>        Move -1999       to RetvalType.iType
93177>>>        
93177>>>        Move 0 to iStart
93178>>>        Move (Uppercase(sType)) to sType            
93179>>>        
93179>>>        If (iType <= -1500) Begin
93181>>>            Move EN_dbTypeDataFlex to iDbType
93182>>>            Move DATAFLEX_ID       to sDriverID
93183>>>        End
93183>>>>
93183>>>
93183>>>        Get UtilEnumerateColumnTypes sDriverID iDbType to ColumnTypeArray
93184>>>        
93184>>>        Move (SizeOfArray(ColumnTypeArray)) to iSize 
93185>>>        Decrement iSize
93186>>>        
93186>>>        for iCount from iStart to iSize
93192>>>>
93192>>>            Move ColumnTypeArray[iCount].iType to iValue
93193>>>            Move ColumnTypeArray[iCount].sType to sValue 
93194>>>            If (bIntegerInputType = True) Begin
93196>>>                If (iValue = iType) Begin
93198>>>                    Move ColumnTypeArray[iCount].sType          to RetvalType.sType  
93199>>>                    Move iType                                  to RetvalType.iType
93200>>>                    Move ColumnTypeArray[iCount].sDataFlexType  to RetvalType.sDataFlexType
93201>>>                    Move ColumnTypeArray[iCount].iDataFlexType  to RetvalType.iDataFlexType
93202>>>                    Move ColumnTypeArray[iCount].sPrecision     to RetvalType.sPrecision
93203>>>                    Move ColumnTypeArray[iCount].bFixedSize     to RetvalType.bFixedSize
93204>>>                    Move iSize to iCount // We're done!
93205>>>                End
93205>>>>
93205>>>            End
93205>>>>
93205>>>            Else Begin
93206>>>                Move (Uppercase(sValue)) to sValue
93207>>>                If (sValue = sType) Begin
93209>>>                    Move sType                                  to RetvalType.sType
93210>>>                    Move ColumnTypeArray[iCount].iType          to RetvalType.iType 
93211>>>                    Move ColumnTypeArray[iCount].sDataFlexType  to RetvalType.sDataFlexType
93212>>>                    Move ColumnTypeArray[iCount].iDataFlexType  to RetvalType.iDataFlexType
93213>>>                    Move ColumnTypeArray[iCount].sPrecision     to RetvalType.sPrecision
93214>>>                    Move ColumnTypeArray[iCount].bFixedSize     to RetvalType.bFixedSize
93215>>>                    Move iSize to iCount // We're done!
93216>>>                End
93216>>>>
93216>>>            End
93216>>>>
93216>>>        Loop
93217>>>>
93217>>>        
93217>>>        Function_Return RetvalType
93218>>>    End_Function
93219>>>    
93219>>>    // *** Miscellaneous other functions ***
93219>>>    // Some of which can be used by both "Sqlxxx" and "Apixxx" functions.
93219>>>    //
93219>>>    
93219>>>    // Callback functionality used when e.g. calling driver functions directly.
93219>>>    Function Callback String sCallback_Text Integer iCallback_Type Returns Integer
93221>>>        Integer iRetval iPos iPerc
93221>>>        String sVal1 sVal2 
93221>>>        Number nReady nTotal 
93221>>>        
93221>>>        Send DoAdvance of ghoProgressBar           
93222>>>        
93222>>>        If (sCallback_Text contains "Copy records") Begin
93224>>>            Move CS_SQLCopyingData to sCallback_Text
93225>>>        End                                        
93225>>>>
93225>>>        If (sCallback_Text contains "Dropping index" or sCallback_Text contains "Temporary delete of all indices of table") Begin
93227>>>            Move (Replace("Dropping index", sCallback_Text, CS_SQLDeletingIndex)) to sCallback_Text 
93228>>>            Move (Replace("Temporary delete of all indices of table", sCallback_Text, CS_SQLDeletingIndex)) to sCallback_Text
93229>>>        End
93229>>>>
93229>>>        If (sCallback_Text contains "Creating index") Begin
93231>>>            Move (Replace("Creating index", sCallback_Text, CS_SQLCreatingIndex)) to sCallback_Text
93232>>>        End                                               
93232>>>>
93232>>>        
93232>>>        Case Begin
93232>>>            Case (iCallback_Type = DF_Message_Text) 
93234>>>                Set Message_Text of ghoStatusPanel to sCallback_Text  
93235>>>                Set Action_Text  of ghoStatusPanel to ""
93236>>>                Case Break
93237>>>            Case (iCallback_Type = DF_Message_Heading_1) 
93240>>>                Set Message_Text of ghoStatusPanel to sCallback_Text 
93241>>>                Set Action_Text  of ghoStatusPanel to ""
93242>>>                Case Break
93243>>>            Case (iCallback_Type = DF_Message_Heading_2) 
93246>>>                Set Message_Text of ghoStatusPanel to sCallback_Text 
93247>>>                Set Action_Text  of ghoStatusPanel to ""
93248>>>                Case Break
93249>>>            Case (iCallback_Type = DF_Message_Heading_3) 
93252>>>                Set Message_Text of ghoStatusPanel to sCallback_Text 
93253>>>                Set Action_Text  of ghoStatusPanel to ""
93254>>>                Case Break
93255>>>            Case (iCallback_Type = DF_Message_Heading_4) 
93258>>>                Set Message_Text of ghoStatusPanel to sCallback_Text 
93259>>>                Set Action_Text  of ghoStatusPanel to ""
93260>>>                Case Break
93261>>>            Case (iCallback_Type = DF_Message_Heading_5) 
93264>>>                Set Message_Text of ghoStatusPanel to sCallback_Text 
93265>>>                Set Action_Text  of ghoStatusPanel to ""
93266>>>                Case Break
93267>>>            Case (iCallback_Type = DF_Message_Warning) 
93270>>>                Send None
93271>>>                Case Break
93272>>>            Case (iCallback_Type = DF_Message_Progress_Title) 
93275>>>                Set Message_Text of ghoStatusPanel to sCallback_Text 
93276>>>                Set Action_Text  of ghoStatusPanel to ""
93277>>>                Case Break
93278>>>            Case (iCallback_Type = DF_Message_Progress_Value) 
93281>>>                //*** Interpret numbers
93281>>>                Move (Left(sCallback_Text, (Pos(",", sCallback_Text) - 1)))                       to nReady
93282>>>                Move (Right(sCallback_Text, (Length(sCallback_Text) - Pos(",", sCallback_Text)))) to nTotal
93283>>>                Move ((nReady / nTotal) * 100)                                                    to iPerc
93284>>>                Set Action_Text of ghoStatusPanel to (String(iPerc) * String("% (Total:") * String(nTotal) + ")")
93285>>>                Case Break
93286>>>            Case Else
93286>>>                Set Message_Text to ""
93287>>>                Set Action_Text  to ""    
93288>>>        Case End
93288>>>
93288>>>        Send ProcessEvents of ghoStatusPanel
93289>>>        Function_Return False
93290>>>    End_Function
93291>>>    
