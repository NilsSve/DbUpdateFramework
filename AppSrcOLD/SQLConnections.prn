89635>>>    // L„s f”rst .int fil och spara alla FIELD_INDEX + FIELD_NUMBER + FIELD_RELATED_FILE + FIELD_RELATED_FIELD i en struct array,
89635>>>    // INDEX_NUMBER + INDEX_NAME (string)
89635>>>    // samt spara undan .int "header rader" s† de kan skrivas ut senare.
89635>>>    // Check if index exists:    
89635>>>    //IF EXISTS (
89635>>>    //   SELECT 'X'
89635>>>    //   from sysindexes
89635>>>    //   WHERE id = (SELECT OBJECT_ID('accounts'))
89635>>>    //     and name = 'idx_acct_no'
89635>>>    //)          
89635>>>    //
89635>>>    // Helper function to create a SQL statement like;
89635>>>    // "SELECT * FROM SYS.INDEXES WHERE NAME = MyIndexName AND OBJECT_ID = OBJECT_ID([MySchmaName].[MyTableName])"
89635>>>    // Used for checking if an index exists.
89635>>>    Function _SqlQueryIfIndexExists String sSchemaName String sTableName String sIndexName Returns String
89637>>>        String sRetval sSelect sFrom sSysIndexes sWhere sObjectID sAnd sName
89637>>>        
89637>>>        Get _SqlFindKeyWord CI_SQLSelect to sSelect
89638>>>        Get _SqlFindKeyWord CI_SQLFrom to sFrom
89639>>>        Get _SqlFindKeyWord CI_SQLSysIndexes to sSysIndexes
89640>>>        Get _SqlFindKeyWord CI_SQLWhere to sWhere
89641>>>        Get _SqlFindKeyWord CI_SQLObjectID to sObjectID
89642>>>        Get _SqlFindKeyWord CI_SQLAND to sAnd
89643>>>        Get _SqlFindKeyWord CI_SQLName to sName
89644>>>        
89644>>>        Move (sSelect * String("*") * sFrom * sSysIndexes * sWhere * sName * "=" * sIndexName * sAnd * sObjectID * "=([" + sSchemaName + "].[" + sTableName + "])") to sRetval
89645>>>        
89645>>>        Function_Return sRetval
89646>>>    End_Function  
