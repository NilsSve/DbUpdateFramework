90224>>>    Function ApiTableConvertToSQL_Ex Handle hTable String sDriverID Boolean bUseConnectionID Boolean bToAnsi Boolean bRecnum Boolean bCopyData Returns Boolean
90226>>>        Handle hToTable
90226>>>        Boolean bOK bExists bOpened bMertechDriver bDAWDriver
90226>>>        String sPhysicalName sRootName sDisplayName sEmpty sConnectionID sConnectionString
90226>>>        String sDBOKeyWord sANSI_OEM sSchema sBaseTableSpace sLongTableSpace sIndexTableSpace sDatabase
90226>>>        tSQLConnection SQLConnection
90226>>>        tSQLConnection SQLConnection
90226>>>        
90226>>>        If (ghoProgressBar <> 0) Begin
90228>>>            Send DoAdvance of ghoProgressBar
90229>>>        End
90229>>>>
90229>>>
90229>>>        Get SqlUtilCheckIfTableHandleExists hTable sDriverID to bExists
90230>>>        If (bExists = True) Begin
90232>>>            // ToDo: Should we do an "auto - attach" ??
90232>>>            // If table already exists on the SQL back-end - check if
90232>>>            // the filelist entry has a driver prefix; else attach it.
90232>>>//            Get UtilIsFilelistEntryDriverBased hTable sDriverID to bExists
90232>>>//            If (bExists = False) Begin
90232>>>//                Get ApiTableAttachToSQL hTable True to bOK
90232>>>//            End
90232>>>            Function_Return False
90233>>>        End                      
90233>>>>
90233>>>        
90233>>>        Move CS_ANSI_Txt to sANSI_OEM
90234>>>        If (bToAnsi = False) Begin
90236>>>            Move CS_OEM_Txt to sANSI_OEM
90237>>>        End                                       
90237>>>>
90237>>>        
90237>>>        Get IsDAWSQLDriver sDriverID to bDAWDriver
90238>>>        // Mertech drivers don't use Connection ID's; so if bUseConnectionID was
90238>>>        // passed as True, we adjust for that here.
90238>>>        Get IsMertechDriver sDriverID to bMertechDriver
90239>>>        If (bMertechDriver = True and bUseConnectionID = True) Begin
90241>>>            Move False to bUseConnectionID
90242>>>        End  
90242>>>>
90242>>>
90242>>>        Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection  
90243>>>        Move SQLConnection.sSchema           to sSchema
90244>>>        If (sSchema = "") Begin
90246>>>            Get _SqlFindKeyWord CI_SQLDBO    to sSchema  
90247>>>            Move (Lowercase(sSchema))        to sSchema      
90248>>>        End
90248>>>>
90248>>>
90248>>>        If (sDriverID = ORAFLEX) Begin
90250>>>            Move SQLConnection.sUserID       to sSchema
90251>>>        End
90251>>>>
90251>>>
90251>>>        Move SQLConnection.sDatabase         to sDatabase   
90252>>>        Move SQLConnection.sConnectionID     to sConnectionID
90253>>>        Move SQLConnection.sConnectionString to sConnectionString 
90254>>>        If (sConnectionID = "" or sConnectionString = "") Begin
90256>>>            Error DFERR_PROGRAM ("The SQL connection info has NOT been setup. Could not convert table:" * String(hTable) * "to SQL")
90257>>>>
90257>>>            Function_Return False
90258>>>        End  
90258>>>>
90258>>>        
90258>>>        Get AutoConnectionIDLogin to bOK
90259>>>        Open hTable
90261>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpened
90264>>>        If (bOpened = False) Begin 
