93632>>>    // The normal connection string looks something like this;
93632>>>    // SERVER=.\SQLEXPRESS; DATABASE=OrderEntry; TRUSTED_CONNECTION=Yes; ,0
93632>>>    // ...and the full connection string looks like this;
93632>>>    // DFConnectionId OrderEntry, SERVER=.\SQLEXPRESS; DATABASE=OrderEntry; TRUSTED_CONNECTION=Yes; ,0
93632>>>    Function psFullConnectionString Returns String
93634>>>        String sConnectionID sConnectionString
93634>>>        If (ghoSQLConnectionHandler = 0) Begin
93636>>>            Error DFERR_PROGRAM "ghoSQLConnectionHandler = 0! This indicates that NO ConnectionID has been setup by the programmer."
93637>>>>
93637>>>            Function_Return
93638>>>        End                                                                   
93638>>>>
93638>>>        Get psConnectionID     of ghoSQLConnectionHandler to sConnectionID                       
93639>>>        Move (Trim(sConnectionID)) to sConnectionID
93640>>>        Get psConnectionString of ghoSQLConnectionHandler to sConnectionString
93641>>>        Function_Return (CS_SQLConnectionIDText * sConnectionID + "," * String(sConnectionString))
93642>>>    End_Function
