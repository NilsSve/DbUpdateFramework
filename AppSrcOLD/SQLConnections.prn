89915>>>    Function _SqlDatabasesArrayODBC Returns String[]
89917>>>        String[] sReturnArray
89918>>>        String sDataSource
89918>>>        Handle hoSQLHandler
89918>>>        Integer iItem
89918>>>
89918>>>        Get phoODBCSQLHandler to hoSQLHandler
89919>>>        Send Ignore_Error of Error_Object_Id CLIERR_LOGIN_UNSUCCESSFUL
89920>>>
89920>>>        Send SeedDataSources of hoSQLHandler
89921>>>
89921>>>        Repeat
89921>>>>
89921>>>            Get DataSources of hoSQLHandler to sDataSource
89922>>>            If (Trim(sDataSource) <> "" and not(sDataSource contains "*.")) Begin
89924>>>                Move (Trim(sDataSource)) to sReturnArray[iItem]
89925>>>                Increment iItem
89926>>>            End
89926>>>>
89926>>>        Until (sDataSource = "")
89928>>>
89928>>>        Send Trap_Error of Error_Object_Id CLIERR_LOGIN_UNSUCCESSFUL
