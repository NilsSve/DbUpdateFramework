84066>>>>>>>>>>>        Set psProcName to sProcName
84067>>>>>>>>>>>        If (Num_Arguments >= 2) ;            Set psSchemaName to sSchemaArg
84070>>>>>>>>>>>        Else ;            Set psSchemaName to ""
84072>>>>>>>>>>>    End_Procedure
