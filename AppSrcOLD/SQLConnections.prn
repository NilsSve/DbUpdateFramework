92193>>>    Function _UtilEnumerateDB2Types Returns tColumnType[]
92195>>>        tColumnType[] ColumnType
92195>>>        tColumnType[] ColumnType
92196>>>        Integer i
92196>>>        
92196>>>        Move SQL_DBCLOB         to ColumnType[i].iType
92197>>>        Move "DBCLOB"           to ColumnType[i].sType
92198>>>        Move DF_TEXT            to ColumnType[i].iDataFlexType
92199>>>        Move "Text"             to ColumnType[i].sDataFlexType 
92200>>>        Move "16384"            to ColumnType[i].sPrecision
92201>>>        Increment i             
92202>>>
92202>>>        Move SQL_BIGINT         to ColumnType[i].iType
92203>>>        Move "BIGINT"           to ColumnType[i].sType
92204>>>        Move DF_BCD             to ColumnType[i].iDataFlexType
