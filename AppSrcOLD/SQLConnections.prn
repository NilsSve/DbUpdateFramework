91036>>>    //   Get ColumnRename Quote.File_Number "ID#" "ID" to bOK
91036>>>    Function ApiColumnRename Integer hTable String sOldFieldName String sNewFieldName Returns Boolean
91038>>>        Integer iField
91038>>>        Boolean bOK
91038>>>        
91038>>>        Get AutoConnectionIDLogin to bOK
91039>>>        Move False to Err
91040>>>        Open hTable Mode DF_EXCLUSIVE
91042>>>    
91042>>>        Send Ignore_Error of Error_Object_Id DFERR_CANT_FIND_FIELD
91043>>>        Send Ignore_Error of Error_Object_Id DFERR_DUPLICATE_FIELDNAME
91044>>>        Structure_Start hTable
91045>>>            Field_Map hTable sOldFieldName to iField
91047>>>            If (iField > 0) Begin
91049>>>                Set_Attribute DF_FIELD_NAME of hTable iField to sNewFieldName
91052>>>            End
91052>>>>
91052>>>            Else Begin
91053>>>                Move 0 to LastErr
91054>>>                Move False to Err
91055>>>            End
91055>>>>
91055>>>        Structure_End hTable
91057>>>    
91057>>>        Send Trap_Error of Error_Object_Id DFERR_CANT_FIND_FIELD
91058>>>        Send Trap_Error of Error_Object_Id DFERR_DUPLICATE_FIELDNAME
91059>>>        
91059>>>        Function_Return (Err = False)
91060>>>    End_Function
