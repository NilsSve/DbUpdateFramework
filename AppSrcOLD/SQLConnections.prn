90870>>>    //
90870>>>    // Adds a column name to the passed table number.
90870>>>    // Note: Types must be the standard DF_ASCII, DF_DATE etcetera and _cannot_ be any of the SQL_xxx types.
90870>>>    Function ApiColumnAdd Handle hTable String sFieldName Integer iType Integer iLength Integer iPrecision Returns Boolean
90872>>>        Integer iColumn iCount iFile
90872>>>        Boolean bExists bOK  
90872>>>        String sDdSrcPath sTableName
90872>>>    
90872>>>        Get UtilColumnExists hTable sFieldName to bExists
90873>>>        If (bExists = True) Begin
90875>>>            Function_Return False
90876>>>        End  
90876>>>>
90876>>>        If (iPrecision > 0) Begin
90878>>>            Move (iLength + iPrecision) to iLength
90879>>>        End
90879>>>>
90879>>>        
90879>>>        Get AutoConnectionIDLogin to bOK
90880>>>        Move False to Err   
90881>>>        // Structure_start will change the value of hTable...
90881>>>        Move hTable to iFile
90882>>>        Open iFile Mode DF_EXCLUSIVE
90884>>>        
90884>>>        Structure_Start iFile
90885>>>            Move 0 to iColumn
90886>>>            Create_Field hTable At iColumn
90887>>>            Set_Attribute DF_FIELD_NAME      of iFile iColumn to sFieldName
90890>>>            Set_Attribute DF_FIELD_TYPE      of iFile iColumn to iType
90893>>>            Set_Attribute DF_FIELD_LENGTH    of iFile iColumn to iLength
90896>>>            Set_Attribute DF_FIELD_PRECISION of iFile iColumn to iPrecision
90899>>>        Structure_End iFile
90901>>>        
90901>>>        // If in development environment; create .fd file:
90901>>>        Open hTable
90903>>>        Get psDdSrcPath of (phoWorkspace(ghoApplication)) to sDDSrcPath
90904>>>        Get CountOfPaths of (phoWorkspace(ghoApplication)) sDDSrcPath to iCount
90905>>>        If (iCount > 1) Begin
90907>>>            Get PathAtIndex of (phoWorkspace(ghoApplication)) sDDSrcPath 1 to sDDSrcPath    
90908>>>        End 
90908>>>>
90908>>>        Get vFolderExists sDDSrcPath to bExists
90909>>>        If (bExists = True) Begin                                   
90911>>>            Get vFolderFormat sDDSrcPath to sDDSrcPath 
90912>>>            Get_Attribute DF_FILE_ROOT_NAME of hTable to sTableName
90915>>>            Get _TableNameOnly sTableName to sTableName 
90916>>>            Output_Aux_File DF_AUX_FILE_FD for hTable to (sDDSrcPath + sTableName + ".fd")
90918>>>        End
90918>>>>
90918>>>        Close hTable
90919>>>
90919>>>        Function_Return (Err = False)
90920>>>    End_Function  
