98643>>>    Function Verify_Exit_Application Returns Integer
98646>>>        Integer iRetval
98646>>>        Boolean bChanged
98646>>>
98646>>>        Get Should_Save of oSQLConnections_grd to bChanged
98647>>>        If (bChanged = False) Begin
98649>>>            Function_Return False
98650>>>        End
98650>>>>
98650>>>        Else Begin
98651>>>            Get YesNoCancel_Box "Changes exists. Save changes first?" to iRetval
98652>>>            If (iRetval = MBR_Cancel) Begin
98654>>>                Function_Return True
98655>>>            End                     
98655>>>>
98655>>>            If (iRetval = MBR_Yes) Begin
98657>>>                Send KeyAction of oSave_btn
98658>>>                Send Exit_Application
98659>>>            End                      
98659>>>>
98659>>>            If (iRetval = MBR_No) Begin
98661>>>                Function_Return False    
98662>>>            End
98662>>>>
98662>>>        End
98662>>>>
98662>>>        Function_Return True
98663>>>    End_Function
