89847>>>                Send SqlCall             of hStmt      
89848>>>                Get SqlReturnValue       of hStmt to iRetval
89849>>>                If (iRetval = 0) Begin
89851>>>                    Repeat    
89851>>>>
89851>>>                        Get SqlStmtAttribute of hStmt SqlSTMTATTRIB_COLUMNCOUNT to iCols
89852>>>                        If (iCols > 0) Begin 
89854>>>                            Repeat
89854>>>>
89854>>>                                Get SqlFetch of hStmt to iFetchResult
89855>>>                                If (iFetchResult <> 0) Begin
89857>>>                                    Get SqlColumnValue of hStmt 1 to sValue    
89858>>>                                    Move (Trim(sValue)) to sReturnArray[SizeOfArray(sReturnArray)]
89859>>>                                End
89859>>>>
89859>>>                            Until (iFetchResult = 0)
89861>>>                        End
89861>>>>
89861>>>                        Get SqlNextResultSet of hStmt to iRetval
89862>>>                    Until (iRetval = 0) 
89864>>>                    Send SqlClose of hStmt
89865>>>                End
89865>>>>
89865>>>            End                       
89865>>>>
89865>>>            Send SqlDisconnect of hoSQLConnect
89866>>>        End                                                                         
89866>>>>
89866>>>        Function_Return sReturnArray
89867>>>    End_Function
89868>>>
89868>>>    Function SqlProcedureArrayMertech String sStmt String sArgument Returns String[]
89870>>>        String[] sReturnArray
89871>>>        String sValue sUserID sPassword 
89871>>>        Handle hoSQLHandler hoSQLConnect hStmt 
89871>>>        Integer iFetchResult iRetval
89871>>>        tSQLConnection SQLConnection
89871>>>        tSQLConnection SQLConnection
89871>>>        
89871>>>        Get _MertechSQLManagerHandle to hoSQLHandler
89872>>>        If (hoSQLHandler <> 0) Begin 
89874>>>            Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
89875>>>            Get SQLConnect of hoSQLHandler SQLConnection.sDriverID SQLConnection.sServer SQLConnection.sUserID SQLConnection.sPassword to hoSQLConnect
89876>>>            If (hoSQLConnect <> 0) Begin   
89878>>>                Get SQLOpen of hoSQLConnect to hStmt
89879>>>                If (hStmt <> 0) Begin
89881>>>                    Send SQLSetProcedureName of hStmt sStmt
89882>>>                    If (sArgument <> "") Begin
89884>>>                        Send SqlSetArgument  of hStmt 1 sArgument
89885>>>                    End
89885>>>>
89885>>>                    Send SQLCall of hStmt
89886>>>
89886>>>                    Get SqlReturnValue       of hStmt to iRetval
89887>>>                    If (iRetval = 0) Begin
89889>>>                        Repeat
89889>>>>
89889>>>                            Get SQLFetch of hStmt to iFetchResult
89890>>>                            If (iFetchResult <> 0) Begin
89892>>>                                Get SQLColumnValue of hStmt 1 to sValue
89893>>>                                Move (Trim(sValue)) to sReturnArray[SizeOfArray(sReturnArray)
89894>>>                            End
89894>>>>
89894>>>                        Until (iFetchResult = 0)
89896>>>                        Send SQLClose of hStmt
89897>>>                    End
89897>>>>
89897>>>                End
89897>>>>
89897>>>                Send SQLDisconnect of hoSQLConnect    
89898>>>            End
89898>>>>
89898>>>        End
89898>>>>
89898>>>
89898>>>        Function_Return sReturnArray
89899>>>    End_Function
