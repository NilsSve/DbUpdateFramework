80646>>>        Send ComAddWindowClass "cVdfProgressBar"         "msctls_progress32"
80647>>>        Send ComAddWindowClass "cVdfStatusBar"           "msctls_statusbar32"
80648>>>        Send ComAddWindowClass "cVdfToolbar"             "ToolbarWindow32"
80649>>>        Send ComAddWindowClass "cObsoleteVdfProgressBar" "msctls_progress32"
80650>>>        Send ComAddWindowClass "cVdfTrackBar"            "msctls_trackbar32"
