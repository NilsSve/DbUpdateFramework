84875>>>>>>>>>>>    //*** Purpose : Returns the major revision of the CK
84875>>>>>>>>>>>    //***
84875>>>>>>>>>>>
84875>>>>>>>>>>>    Function CKBuildRevision Returns Integer
84877>>>>>>>>>>>        Function_Return (ExtractPartFromRevision (Current_Object, 4, CKRevision(Current_Object)))
84878>>>>>>>>>>>    End_Function // CKBuildRevision
84879>>>>>>>>>>>
84879>>>>>>>>>>>
84879>>>>>>>>>>>
84879>>>>>>>>>>>    //***
84879>>>>>>>>>>>    //*** Function: IsMinimalRevision
84879>>>>>>>>>>>    //*** Purpose : Determines if the CK conforms to a passed minimal revsion.
84879>>>>>>>>>>>    //***
84879>>>>>>>>>>>
84879>>>>>>>>>>>    Function IsMinimalRevision Integer iMajor Integer iMinor Integer iRelease Integer iBuild Returns Integer
84881>>>>>>>>>>>        If (iMajor < CKMajorRevision(Current_object)) ;            Function_return (TRUE)
84884>>>>>>>>>>>        Else If (iMajor = CKMajorRevision(Current_object)) Begin
84887>>>>>>>>>>>            If (iMinor < CKMinorRevision(Current_object)) ;                Function_return (TRUE)
84890>>>>>>>>>>>            Else If (iMinor = CKMinorRevision(Current_object)) Begin
84893>>>>>>>>>>>                If (iRelease < CKReleaseRevision(Current_object)) ;                    Function_return (TRUE)
84896>>>>>>>>>>>                Else If (iRelease = CKReleaseRevision(Current_object) And iBuild <= CKBuildRevision(Current_object)) ;                    Function_return (TRUE)
84900>>>>>>>>>>>            End
84900>>>>>>>>>>>>
84900>>>>>>>>>>>        End
84900>>>>>>>>>>>>
84900>>>>>>>>>>>
84900>>>>>>>>>>>        Function_Return (FALSE)
84901>>>>>>>>>>>    End_Function // IsMinimalRevision
84902>>>>>>>>>>>
84902>>>>>>>>>>>    //   Functions to query the Pervasive.SQL version:
84902>>>>>>>>>>>    //       PSQLRequesterVersionInfo    Integer iFileNum Returns String
84902>>>>>>>>>>>    //       PSQLLocalEngineVersionInfo  Integer iFileNum Returns String
84902>>>>>>>>>>>    //       PSQLServerEngineVersionInfo Integer iFileNum Returns String
84902>>>>>>>>>>>    //
84902>>>>>>>>>>>    //   All 3 functions return the version of a Pervasive.SQL component
84902>>>>>>>>>>>    //   in the following format:
84902>>>>>>>>>>>    //       <version>.<revision>.<type>
84902>>>>>>>>>>>    //   possible values for <type>:
84902>>>>>>>>>>>    //       9 for 32-bit Windows workstation/workgroup engine or Linux
84902>>>>>>>>>>>    //         server using Workgroup authentication mode
84902>>>>>>>>>>>    //       C for client cache engine
84902>>>>>>>>>>>    //       D for DOS workstation
84902>>>>>>>>>>>    //       N for client Requester
84902>>>>>>>>>>>    //       S for NetWare server
84902>>>>>>>>>>>    //       T for 32-bit Windows server engine
84902>>>>>>>>>>>    //       U for Linux server using PAM or BTPASSWD authentication
84902>>>>>>>>>>>    //
84902>>>>>>>>>>>    //   example:
84902>>>>>>>>>>>    //       8.50.T
84902>>>>>>>>>>>    //   will be returned for a Pervasive.SQL 8.5 Server Engine running on
84902>>>>>>>>>>>    //   32-bits Windows server.
84902>>>>>>>>>>>    //
84902>>>>>>>>>>>    //   The FileNumber parameter must specify an opened table or 0.
84902>>>>>>>>>>>    //   For PSQLServerEngineVersionInfo the FileNumber can not be 0.
84902>>>>>>>>>>>    //
84902>>>>>>>>>>>    //   If the version information is not available or can not be obtained
84902>>>>>>>>>>>    //   the functions will return "0.0.0"
84902>>>>>>>>>>>
84902>>>>>>>>>>>
84902>>>>>>>>>>>    //***
84902>>>>>>>>>>>    //*** Function: PSQLRequesterVersionInfo
84902>>>>>>>>>>>    //*** Purpose : Returns the version information of the
84902>>>>>>>>>>>    //***           Pervasive.SQL Client requester.
84902>>>>>>>>>>>
84902>>>>>>>>>>>    Function PSQLRequesterVersionInfo Integer iFileNum Returns String
84904>>>>>>>>>>>
84904>>>>>>>>>>>        Local String  sDriverID
84904>>>>>>>>>>>        Local String  sVersion
84904>>>>>>>>>>>        Local String  sVoid
84904>>>>>>>>>>>        Local Integer iRetval
84904>>>>>>>>>>>
84904>>>>>>>>>>>        // Ignore error 20491 DFBTRERR_INVALID_DRIVER_FUNCTION_CALL.
84904>>>>>>>>>>>        // This error would otherwise be raised when we have an older
84904>>>>>>>>>>>        // DFBTRDRV version that has no DFBTRFN_CKREVISION function
84904>>>>>>>>>>>        Send Ignore_error To Error_object_Id 20491
84905>>>>>>>>>>>        Get psDriverID To sDriverID
84906>>>>>>>>>>>        Move (Repeat(" ", 255)) To sVersion
84907>>>>>>>>>>>        Call_Driver iFileNum sDRiverID Function DFBTRFN_PSQLREQUESTERVERSIONINFO Callback 0 Passing sVersion sVoid 0 Result iRetval
84912>>>>>>>>>>>        Send Trap_Error To Error_object_Id 20491
84913>>>>>>>>>>>        If (Trim(sVersion) = "") Begin
84915>>>>>>>>>>>            // Unable to get the revision. return all zeroes.
84915>>>>>>>>>>>            Move "0.0.0" To sVersion
84916>>>>>>>>>>>        End
84916>>>>>>>>>>>>
84916>>>>>>>>>>>        Function_Return sVersion
84917>>>>>>>>>>>    End_Function //  PSQLRequesterVersion
84918>>>>>>>>>>>
84918>>>>>>>>>>>    //***
84918>>>>>>>>>>>    //*** Function: PSQLLocalEngineVersionInfo
84918>>>>>>>>>>>    //*** Purpose : Returns the version information of the
84918>>>>>>>>>>>    //***           Pervasive.SQL Local Engine
84918>>>>>>>>>>>
84918>>>>>>>>>>>    Function PSQLLocalEngineVersionInfo Integer iFileNum Returns String
84920>>>>>>>>>>>
84920>>>>>>>>>>>        Local String  sDriverID
84920>>>>>>>>>>>        Local String  sVersion
84920>>>>>>>>>>>        Local String  sVoid
84920>>>>>>>>>>>        Local Integer iRetval
84920>>>>>>>>>>>
84920>>>>>>>>>>>        // Ignore error 20491 DFBTRERR_INVALID_DRIVER_FUNCTION_CALL.
84920>>>>>>>>>>>        // This error would otherwise be raised when we have an older
84920>>>>>>>>>>>        // DFBTRDRV version that has no DFBTRFN_CKREVISION function
84920>>>>>>>>>>>        Send Ignore_error To Error_object_Id 20491
84921>>>>>>>>>>>        Get psDriverID To sDriverID
84922>>>>>>>>>>>        Move (Repeat(" ", 255)) To sVersion
84923>>>>>>>>>>>        Call_Driver iFileNum sDRiverID Function DFBTRFN_PSQLLOCALENGINEVERSIONINFO Callback 0 Passing sVersion sVoid 0 Result iRetval
84928>>>>>>>>>>>        Send Trap_Error To Error_object_Id 20491
84929>>>>>>>>>>>        If (Trim(sVersion) = "") Begin
84931>>>>>>>>>>>            // Unable to get the revision. return all zeroes.
84931>>>>>>>>>>>            Move "0.0.0" To sVersion
84932>>>>>>>>>>>        End
84932>>>>>>>>>>>>
84932>>>>>>>>>>>        Function_Return sVersion
84933>>>>>>>>>>>    End_Function //  PSQLLocalEngineVersion
84934>>>>>>>>>>>
84934>>>>>>>>>>>    //***
84934>>>>>>>>>>>    //*** Function: PSQLServerEngineVersionInfo
84934>>>>>>>>>>>    //*** Purpose : Returns the version information of the
84934>>>>>>>>>>>    //***           Pervasive.SQL Server Engine
84934>>>>>>>>>>>
84934>>>>>>>>>>>    Function PSQLServerEngineVersionInfo Integer iFileNum Returns String
84936>>>>>>>>>>>
84936>>>>>>>>>>>        Local String  sDriverID
84936>>>>>>>>>>>        Local String  sVersion
84936>>>>>>>>>>>        Local String  sVoid
84936>>>>>>>>>>>        Local Integer iRetval
84936>>>>>>>>>>>
84936>>>>>>>>>>>        // Ignore error 20491 DFBTRERR_INVALID_DRIVER_FUNCTION_CALL.
84936>>>>>>>>>>>        // This error would otherwise be raised when we have an older
84936>>>>>>>>>>>        // DFBTRDRV version that has no DFBTRFN_CKREVISION function
84936>>>>>>>>>>>        Send Ignore_error To Error_object_Id 20491
84937>>>>>>>>>>>        Get psDriverID To sDriverID
84938>>>>>>>>>>>        Move (Repeat(" ", 255)) To sVersion
84939>>>>>>>>>>>        Call_Driver iFileNum sDRiverID Function DFBTRFN_PSQLSERVERENGINEVERSIONINFO Callback 0 Passing sVersion sVoid 0 Result iRetval
84944>>>>>>>>>>>        Send Trap_Error To Error_object_Id 20491
84945>>>>>>>>>>>        If (Trim(sVersion) = "") Begin
84947>>>>>>>>>>>            // Unable to get the revision. return all zeroes.
84947>>>>>>>>>>>            Move "0.0.0" To sVersion
84948>>>>>>>>>>>        End
84948>>>>>>>>>>>>
84948>>>>>>>>>>>        Function_Return sVersion
84949>>>>>>>>>>>    End_Function //  PSQLServerEngineVersion
84950>>>>>>>>>>>
84950>>>>>>>>>>>End_Class // cDfbtrdrvHandler
