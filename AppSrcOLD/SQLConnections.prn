80594>>>Class cCJSkinFramework is a cCJComSkinFramework
80595>>>    
80595>>>    Procedure Construct_Object
80597>>>        Forward Send Construct_Object
80599>>>        
80599>>>        Property String psSkinFile ""
80600>>>        Property String psSkinIni ""
80601>>>        Property Boolean pbLoadPreference False
80602>>>        
80602>>>        Set peAutoCreate to acAutoCreate
80603>>>        
80603>>>        Move Self to ghoSkinFramework
80604>>>    End_Procedure
80605>>>    
80605>>>    // return the default skin path, which is the programs directory.
80605>>>    // This requires an application object.
80605>>>    // If you want to different skin path, override this.
80605>>>    Function SkinPath Returns String
80607>>>        String sPath sPaths
80607>>>        Handle hoWorkspace
80607>>>        If ghoApplication Begin
80609>>>            Get phoWorkspace of ghoApplication to hoWorkspace
80610>>>            Get psProgramPath of hoWorkspace to sPaths
80611>>>            Get PathAtIndex of hoWorkspace sPaths 1 to sPath
80612>>>        End
80612>>>>
80612>>>        Else Begin
80613>>>            Error DFERR_PROGRAM C_$ApplicationObjectNotCreated
80614>>>>
80614>>>        End
80614>>>>
80614>>>        Function_Return sPath
80615>>>    End_Function
80616>>>    
80616>>>    // Returns the Qualified name of psSkinFile. If the file is already qualified it just
80616>>>    // returns itself. If it is not, it uses SkinPath to get the path.
80616>>>    Function SkinQFile Returns String
80618>>>        String sFile sPath sSep
80618>>>        Boolean bQualified
80618>>>        Get psSkinFile to sFile
80619>>>        If not (IsFileNameQualified(sFile)) Begin
80621>>>            Get SkinPath to sPath
80622>>>            Move (SysConf(SYSCONF_DIR_SEPARATOR)) to sSep
80623>>>            Move (sPath - sSep - sFile) to sFile
80624>>>        End
80624>>>>
80624>>>        Function_Return sFile
80625>>>    End_Function
80626>>>        
