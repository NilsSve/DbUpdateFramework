89699>>>    // Checks that the length parameter has been passed correctly.
89699>>>    // This is only of concern for certain SQL data types.
89699>>>    Function _SqlCheckLengthParamForDataType Integer iDataType Integer iLen Returns Boolean
89701>>>        Integer iLength 
89701>>>        Boolean bOK bCheckTypeLength 
89701>>>        
89701>>>        If (num_arguments > 1) Begin
89703>>>            Move iLen to iLength
89704>>>        End
89704>>>>
89704>>>        Move (iDataType = SQL_DECIMAL   or iDataType = SQL_NUMERIC or iDataType = SQL_FLOAT   or iDataType = SQL_INTEGER or;              iDataType = SQL_VARBINARY or iDataType = SQL_BINARY  or iDataType = SQL_VARCHAR or iDataType = SQL_CHAR or;              iDataType = SQL_BIGINT    or iDataType = SQL_REAL) to bCheckTypeLength
89705>>>        
89705>>>        If (bCheckTypeLength = True) Begin
89707>>>            Move (iLength > 0) to bOK
89708>>>        End
89708>>>>
89708>>>
89708>>>        Function_Return (bOK = True)
89709>>>    End_Function
