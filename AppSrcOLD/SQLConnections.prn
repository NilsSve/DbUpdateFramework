85949>>>Use cDbUpdateDatabaseDriver.pkg
85949>>>
85949>>>// The cConnection class is the new SQL connections class for DF 19.
85949>>>// If an object of the cConnection class hasn't been instantiated we use a "dummy" class in its place.
85949>>>
85949>>>// We're making references to this object handle so we need it defined
85949>>>// here as well as for the cDbUpdateHandler class
85949>>>
85949>>>    Global_Variable Handle ghoSQLConnectionHandler
85949>>>    
85949>>>Class cSQLConnectionHandler is a cObject  
85950>>>    
85950>>>    Procedure Construct_Object
85952>>>        Forward Send Construct_Object
85954>>>        Move Self to ghoSQLConnectionHandler
85955>>>        
85955>>>        Property Handle phoSQLConnectionIniFile (Create(Self,RefClass(cSQLConnectionIniFile))) 
85956>>>        
85956>>>        // Driver default value settings:
85956>>>        // Note: When the object is created the corresponding values
85956>>>        // from the driver .int files are read.
85956>>>        // Sample: Get_Attribute DF_DRIVER_DEFAULT_DEFAULT_NUMERIC of {driverNumber} to {StringVariable}
85956>>>        Property String psDriverDefaultValueASCII    ""
85957>>>        Property String psDriverDefaultValueBinary   ""
85958>>>        Property String psDriverDefaultValueDate     ""
85959>>>        Property String psDriverDefaultValueDateTime ""
85960>>>        Property String psDriverDefaultValueNumeric  ""
85961>>>        Property String psDriverDefaultValueText     ""
85962>>>        
85962>>>        // Driver "nullability" settings:
85962>>>        // Note: When the object is created the corresponding values
85962>>>        // from the driver .int files are read.
85962>>>        // Get_Attribute DF_DRIVER_DEFAULT_NULLABLE_ASCII of {driverNumber} to {BooleanVariable}
85962>>>        Property Boolean pbDriverDefaultNullableASCII    False
85963>>>        Property Boolean pbDriverDefaultNullableBinary   False
85964>>>        Property Boolean pbDriverDefaultNullableDate     False
85965>>>        Property Boolean pbDriverDefaultNullableDateTime False
85966>>>        Property Boolean pbDriverDefaultNullableNumeric  False
85967>>>        Property Boolean pbDriverDefaultNullableText     False
85968>>>
85968>>>        // *** This is the central point of connection data for the Database Update Framework ***
85968>>>        //     It is private because the get/set version also updates the DAW/Mertech
85968>>>        //     driver interfaces.
85968>>>        //     There are also procedure/function pairs to set/get individual data members
85968>>>        //     of the struct they are all routed throu this struct property.
85968>>>        Property tSQLConnection Private.pSQLConnection
85969>>>
85969>>>    End_Procedure
85970>>>    
85970>>>    Procedure End_Construct_Object             
85972>>>        Boolean bReadSettings 
85972>>>        tSQLConnection SQLConnection 
85972>>>        tSQLConnection SQLConnection 
85972>>>
85972>>>        Forward Send End_Construct_Object
85974>>>
85974>>>        // Now is the time to read and apply SQL connection settings.
85974>>>        Get SetupSQLConnection True to SQLConnection   
85975>>>        // ToDo: Should we use two pSQLConnection properties; one for the "from" database (in case of not Embedded);
85975>>>        //       and one for the "to" database??
85975>>>        Set Private.pSQLConnection to SQLConnection
85976>>>    End_Procedure    
85977>>>    
85977>>>    // *** Properties ***
85977>>>    // All connection related "properties" (get/set pairs) are really done by changing the
85977>>>    // private.pSQLConnection struct connection property. These "properties" are 
85977>>>    // merely here for conveniance.
85977>>>    //           
85977>>>    // The pSQLConnection get/set are here so we have a "central hub"
85977>>>    // where we update data to/from the DAW & Mertech driver interfaces and this framework.
85977>>>    // This struct property contains all the connection data.
85977>>>    //
85977>>>    Procedure Set pSQLConnection tSQLConnection SQLConnection
85979>>>        Boolean bIsDaw bIsMertech bOK
85979>>>        
85979>>>        Set Private.pSQLConnection to SQLConnection 
85980>>>        
85980>>>        // When starting a program we might not have a connection id yet:
85980>>>        If (SQLConnection.sConnectionID = "" or SQLConnection.sDriverID = DATAFLEX_ID) Begin
85982>>>            Procedure_Return
85983>>>        End                 
85983>>>>
85983>>>        
85983>>>        // After we have set the class property we need to tell the DAW/Mertech
85983>>>        // driver interfaces about the change & make a new login.
85983>>>        Get SQLLogin SQLConnection to bOK
85984>>>        If (bOK = False) Begin
85986>>>            Error DFERR_PROGRAM "Login error."       
85987>>>>
85987>>>        End 
85987>>>>
85987>>>        
85987>>>        // Now is the time to setup our driver default values by reading the driver .int file:
85987>>>        Send SetupDriverDefaults SQLConnection.sDriverID
85988>>>        
85988>>>    End_Procedure                 
85989>>>    
85989>>>    // Similar to _SqlCheckCurrentDriver but generates no error and it doesn't 
85989>>>    // attempt to load the driver.
85989>>>    // Returns true if the passed driver is SQL based.        
85989>>>    Function IsSQLDriver String sDriverID Returns Boolean
85991>>>        Boolean bOK                         
85991>>>        Integer iDriver
85991>>>        
85991>>>        Get IsDAWSQLDriver sDriverID to bOK
85992>>>
85992>>>        If (bOK = False) Begin
85994>>>            Get IsMertechDriver sDriverID to bOK
85995>>>        End                                     
85995>>>>
85995>>>
85995>>>        Function_Return bOK
85996>>>    End_Function
85997>>>            
85997>>>    // Reads the driver .int file and sets class properties of the cDbUpdateFunctionLibrary accordingly.
85997>>>    Procedure SetupDriverDefaults String sDriverID
85999>>>        String sAttributeValue                                               
85999>>>        Integer iDriverID
85999>>>        Boolean bNULL bSQLDriver
85999>>>        
85999>>>        Get IsSQLDriver sDriverID to bSQLDriver
86000>>>        If (bSQLDriver = False) Begin
86002>>>            Procedure_Return
86003>>>        End
86003>>>>
86003>>>            
86003>>>        Get DriverIndex sDriverID to iDriverID
86004>>>        
86004>>>        // Driver default values for various data types:
86004>>>        Get_Attribute DF_DRIVER_DEFAULT_DEFAULT_ASCII of iDriverID      to sAttributeValue
86007>>>        Set psDriverDefaultValueASCII                                   to sAttributeValue
86008>>>
86008>>>        Get_Attribute DF_DRIVER_DEFAULT_DEFAULT_BINARY of iDriverID     to sAttributeValue
86011>>>        Set psDriverDefaultValueBinary                                  to sAttributeValue
86012>>>
86012>>>        Get_Attribute DF_DRIVER_DEFAULT_DEFAULT_DATE of iDriverID       to sAttributeValue
86015>>>        Set psDriverDefaultValueDate                                    to sAttributeValue
86016>>>
86016>>>        Get_Attribute DF_DRIVER_DEFAULT_DEFAULT_DATETIME of iDriverID   to sAttributeValue
86019>>>        Set psDriverDefaultValueDateTime                                to sAttributeValue
86020>>>
86020>>>        Get_Attribute DF_DRIVER_DEFAULT_DEFAULT_NUMERIC of iDriverID    to sAttributeValue
86023>>>        Set psDriverDefaultValueNumeric                                 to sAttributeValue
86024>>>
86024>>>        Get_Attribute DF_DRIVER_DEFAULT_DEFAULT_TEXT of iDriverID       to sAttributeValue
86027>>>        Set psDriverDefaultValueText                                    to sAttributeValue
86028>>>        
86028>>>        // The default setting for the "nullability" of newly created ASCII columns.
86028>>>        Get_Attribute DF_DRIVER_DEFAULT_NULLABLE_ASCII      of iDriverID to bNULL
86031>>>        Set pbDriverDefaultNullableASCII to bNULL
86032>>>        
86032>>>        Get_Attribute DF_DRIVER_DEFAULT_NULLABLE_BINARY     of iDriverID to bNULL
86035>>>        Set pbDriverDefaultNullableBinary to bNULL
86036>>>        
86036>>>        Get_Attribute DF_DRIVER_DEFAULT_NULLABLE_DATE       of iDriverID to bNULL
86039>>>        Set pbDriverDefaultNullableDate to bNULL
86040>>>        
86040>>>        Get_Attribute DF_DRIVER_DEFAULT_NULLABLE_DATETIME   of iDriverID to bNULL
86043>>>        Set pbDriverDefaultNullableDateTime to bNULL
86044>>>        
86044>>>        Get_Attribute DF_DRIVER_DEFAULT_NULLABLE_NUMERIC    of iDriverID to bNULL
86047>>>        Set pbDriverDefaultNullableNumeric to bNULL
86048>>>        
86048>>>        Get_Attribute DF_DRIVER_DEFAULT_NULLABLE_TEXT       of iDriverID to bNULL
86051>>>        Set pbDriverDefaultNullableText to bNULL
86052>>>        
86052>>>    End_Procedure
86053>>>    
86053>>>    Function SQLLogin tSQLConnection SQLConnection Returns Boolean
86055>>>        Boolean bOK bIsDaw bIsMertech bTrusted 
86055>>>        String sConnectionString sServer sDatabase sUserId sPassword sDriverID sCheck
86055>>>        Handle hoErrorObj hoDriver hoIniFile 
86055>>>        Integer iDriverID
86055>>>        
86055>>>        Move False to bOK
86056>>>        
86056>>>        Get IsDAWSQLDriver SQLConnection.sDriverID to bIsDaw
86057>>>        If (bIsDaw = False) Begin
86059>>>            Get IsMertechDriver SQLConnection.sDriverID to bIsMertech
86060>>>            If (bIsMertech = False) Begin
86062>>>                Function_Return False
86063>>>            End
86063>>>>
86063>>>        End  
86063>>>>
86063>>>        
86063>>>        Move Error_Object_Id to hoErrorObj
86064>>>        Move Self to Error_Object_Id        
86065>>>        
86065>>>        Get phoSQLConnectionIniFile to hoIniFile
86066>>>        Get ConstructConnectionString SQLConnection.sDriverID SQLConnection.sServer SQLConnection.sDatabase SQLConnection.bTrusted SQLConnection.sUserID SQLConnection.sPassword to sConnectionString
86067>>>        Get DriverIndex SQLConnection.sDriverID to iDriverID
86068>>>        If (iDriverID = 0) Begin
86070>>>            Move hoErrorObj to Error_Object_Id
86071>>>            Function_Return False
86072>>>        End
86072>>>>
86072>>>        
86072>>>        // There's a bug in Mertech drivers creating "an Exception error" in the debugger (probably will crash an application too.)
86072>>>        If (bIsMertech = False) Begin
86074>>>            Set_Attribute DF_DRIVER_SILENT_LOGIN of iDriverID to SQLConnection.bSilentLogin
86077>>>        End
86077>>>>
86077>>>        
86077>>>        Get Create (RefClass(cDbUpdateDatabaseDriver)) to hoDriver
86078>>>        Set psDriverID of hoDriver to SQLConnection.sDriverID
86079>>>        Get DbLogin    of hoDriver sConnectionString SQLConnection.sServer SQLConnection.sDatabase SQLConnection.bTrusted SQLConnection.sUserID SQLConnection.sPassword to bOK
86080>>>        Send Destroy   of hoDriver
86081>>>        Move hoErrorObj to Error_Object_Id
86082>>>        
86082>>>        Function_Return bOK
86083>>>    End_Function
86084>>>    
86084>>>    Function pSQLConnection Returns tSQLConnection
86086>>>        tSQLConnection SQLConnection
86086>>>        tSQLConnection SQLConnection
86086>>>        Get Private.pSQLConnection to SQLConnection
86087>>>        Function_Return SQLConnection
86088>>>    End_Function
86089>>>    
86089>>>    Procedure Set psConnectionID String sValue
86091>>>        tSQLConnection SQLConnection                                       
86091>>>        tSQLConnection SQLConnection                                       
86091>>>        Integer iIndex
86091>>>        
86091>>>        Get Private.pSQLConnection to SQLConnection
86092>>>        If (SQLConnection.sConnectionID = "") Begin
86094>>>            Move sValue to SQLConnection.sConnectionID
86095>>>        End
86095>>>>
86095>>>        
86095>>>        // Else we might want to change the current connection ID
86095>>>        Else If (SQLConnection.sConnectionID <> "" and SQLConnection.sConnectionID <> sValue) Begin   
86098>>>            Move False to Err
86099>>>            Logout SQLConnection.sDriverID  
86100>>>            // This will also make a login to the new server.
86100>>>            Get SQLIniFileConnectionID of (phoSQLConnectionIniFile(Self)) sValue to SQLConnection
86101>>>        End
86101>>>>
86101>>>        Set pSQLConnection to SQLConnection
86102>>>    End_Procedure
86103>>>        
86103>>>    Function psConnectionID Returns String
86105>>>        tSQLConnection SQLConnection
86105>>>        tSQLConnection SQLConnection
86105>>>        Get Private.pSQLConnection to SQLConnection
86106>>>        Function_Return SQLConnection.sConnectionID
86107>>>    End_Procedure
86108>>>    
86108>>>    // Note: If the psDriverID + other connection properties are to be changed,
86108>>>    //       the psDriverID *must* be the first property that is changed!
86108>>>    //       Otherwise errors might be raised by the driver when e.g. the format
86108>>>    //       for a connection string has the wrong format for that driver.
86108>>>    Procedure Set psDriverID String sValue
86110>>>        tSQLConnection SQLConnection 
86110>>>        tSQLConnection SQLConnection 
86110>>>        Get pSQLConnection to SQLConnection
86111>>>        Move sValue        to SQLConnection.sDriverID 
86112>>>        Set pSQLConnection to SQLConnection
86113>>>        If (sValue <> DATAFLEX_ID) Begin
86115>>>            Get ConstructConnectionString SQLConnection.sDriverID SQLConnection.sServer SQLConnection.sDatabase SQLConnection.bTrusted SQLConnection.sUserID SQLConnection.sPassword to SQLConnection.sConnectionString
86116>>>        End
86116>>>>
86116>>>    End_Procedure
