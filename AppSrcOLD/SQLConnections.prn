90698>>>    Function ApiTableMoveToFileSlot Integer iFromFileSlot Integer iToFileSlot String sDriverID Returns Boolean
90700>>>        Boolean bTmp bErr bOK 
90700>>>        String sTableName sDisplayName sFileName sDBOKeyWord sVal
90700>>>        
90700>>>        // We preserve the value of the Err flag, by saving its current state and resetting it before end of function.
90700>>>        Move Err to bTmp
90701>>>        Move False to Err
90702>>>        
90702>>>        Get AutoConnectionIDLogin to bOK
90703>>>        // First get the info for the current filelist slot:
90703>>>        Open iFromFileSlot                      
90705>>>        Get_Attribute DF_FILE_OPENED of iFromFileSlot to bOK
90708>>>        If (bOK = True) Begin
90710>>>            Get_Attribute DF_FILE_ROOT_NAME    of iFromFileSlot to sFileName
90713>>>            Get_Attribute DF_FILE_LOGICAL_NAME of iFromFileSlot to sTableName
90716>>>            Get_Attribute DF_FILE_DISPLAY_NAME of iFromFileSlot to sDisplayName
90719>>>            
90719>>>            //...then move it.
90719>>>            Set_Attribute DF_FILE_ROOT_NAME    of iToFileSlot to sFileName
90722>>>            Set_Attribute DF_FILE_LOGICAL_NAME of iToFileSlot to sTableName
90725>>>            Set_Attribute DF_FILE_DISPLAY_NAME of iToFileSlot to sDisplayName
90728>>>            
90728>>>            //...and finally remove the old filelist values.
90728>>>            Set_Attribute DF_FILE_ROOT_NAME    of iFromFileSlot to ""
90731>>>            Set_Attribute DF_FILE_LOGICAL_NAME of iFromFileSlot to ""
90734>>>            Set_Attribute DF_FILE_DISPLAY_NAME of iFromFileSlot to ""
90737>>>        End
90737>>>>
90737>>>        Close iFromFileSlot
90738>>>        
90738>>>        Move Err to bErr                     
90739>>>        Move bTmp to Err
90740>>>        Function_Return (bErr = False)
90741>>>    End_Function
