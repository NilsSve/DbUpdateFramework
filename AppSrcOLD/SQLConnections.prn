91863>>>    // Returns True if the passed hTable (filelist slot number) is an Alias table.
91863>>>    // An Alias file/table is a filelist number that share the same Physical filename
91863>>>    // but which Logical name is different.
91863>>>    // Note: If the table cannot be opened; the table is not considered to be an Alias.
91863>>>    Function UtilTableIsAlias Handle hTable Returns Boolean
91865>>>        String sPhysicalName sPhysicalNameCompare     
91865>>>        Boolean bOpened bOK
91865>>>        
91865>>>        Open hTable
91867>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpened
91870>>>        If (bOpened = False) Begin
91872>>>            Function_Return False
91873>>>        End                      
91873>>>>
91873>>>        
91873>>>        Get_Attribute DF_FILE_PHYSICAL_NAME of hTable to sPhysicalName 
91876>>>        Get _TableNameOnly sPhysicalName to sPhysicalName
91877>>>        Close hTable
91878>>>        
91878>>>        Move 0 to hTable
91879>>>        Repeat
91879>>>>
91879>>>            Get_Attribute DF_FILE_NEXT_USED of hTable to hTable
91882>>>            If (hTable > 0) Begin         
91884>>>                Open hTable
91886>>>                Get_Attribute DF_FILE_OPENED of hTable to bOpened
91889>>>                If (bOpened = True) Begin
91891>>>                    Get_Attribute DF_FILE_PHYSICAL_NAME of hTable to sPhysicalNameCompare 
91894>>>                    Close hTable
91895>>>                    Get _TableNameOnly sPhysicalNameCompare to sPhysicalNameCompare
91896>>>                    If (Uppercase(sPhysicalName) = Uppercase(sPhysicalNameCompare)) Begin
91898>>>                        Function_Return True
91899>>>                    End
91899>>>>
91899>>>                End
91899>>>>
91899>>>            End
91899>>>>
91899>>>        Until (hTable = 0)
91901>>>        
91901>>>        Function_Return False
91902>>>    End_Function
91903>>>    
91903>>>    // To Open a table with any driver.
91903>>>    // Note: If the driver is <> DATAFLEX_ID  - login credentials are used; it is then assumed 
91903>>>    //       that the proper login properties has been setup properly with the cSQLConnections object.
91903>>>    //
91903>>>    // If the open command fails the Err flag will be reset to false, at the end of the function!
91903>>>    // The found flag is still used to indicate if the open was successful or not. The function
91903>>>    // returns a True if successful (table could be opened).
91903>>>    //
91903>>>    // Using the "Open As" syntax with drivers means that we don't need to rely on .int file settings.
91903>>>    // This is good because with DFConnectionID's those credentials doesn't need to be available in
91903>>>    // the .int file (and probably aren't). As long as the login properties of this object have been
91903>>>    // set properly we can open the table.
91903>>>    //
91903>>>    // DAW Driver Syntax:
91903>>>    //  <CKId>:<Schema>#<Table>@<ConnectString>|<Filename>.int
91903>>>    //  Now the @<ConnectString> can be followed by a pipe character '|' followed by the name of the INT file.
91903>>>    //  Doing so, the driver will apply the information from the .INT file to the passed direct Open String.
91903>>>    //  Note that when an INT file has been passed, it will skip the keyword DRIVER_NAME, SERVER_NAME,
91903>>>    //  DATABASE_NAME and SCHEMA_NAME from the INT file because those are supposed to be supplied in the String already. 
91903>>>    //  Open mode; iMode = DF_SHARE or DF_EXCLUSIVE.
91903>>>    //
91903>>>    // DAW Driver Sample:
91903>>>    //   Open "MSSQLDRV:dbo#MyFile@SERVER=(local)\SQLEXPRESS;Trusted_Connection=yes;DATABASE=OrderEntry|options|intfile=MyFile.int"
91903>>>    //
91903>>>    // Mertech Driver Samples:
91903>>>    //   SQLFlex:   Open "sql_drv:\\<serverName>\<database>*<owner>*<tableName>=<numberFieds>" as table 
91903>>>    //   MySQLFlex: Open "mdsmysql:\\<serverName>\<database>*<tableName>=<numberFieds>" as table 
91903>>>    //   PgFlex:    Open "mdspgsql:\\<serverName>\<database>*<schema>*<tableName>=<numberFieds>" as table 
91903>>>    //   ORAFlex:   Open "ora_drv:\\<serverName>\<owner>*<tableName>=<numberFieds>" as table 
91903>>>    Function UtilTableOpen Integer hTable String sTableName Integer iMode Returns Boolean
91905>>>        String sDriverID sConnection sSchema sExt sTableNameShort sTableNameOrg
91905>>>        Boolean bOpen bMertechDriver
91905>>>        Integer iRetval              
91905>>>        tSQLConnection SQLConnection
91905>>>        tSQLConnection SQLConnection
91905>>>
91905>>>        Move sTableName to sTableNameOrg
91906>>>        If (hTable > 0 and Trim(sTableName) = "") Begin
91908>>>            Send Ignore_Error of Error_Object_Id 20529
91909>>>            Send Ignore_Error of Error_Object_Id DFERR_CANT_OPEN_DATA_FILE
91910>>>            Send Ignore_Error of Error_Object_Id CLIERR_CONNECTIONIDNOTFOUND
91911>>>            Open hTable
91913>>>            Send Trap_Error of Error_Object_Id 20529
91914>>>            Send Trap_Error of Error_Object_Id DFERR_CANT_OPEN_DATA_FILE
91915>>>            Send Trap_Error of Error_Object_Id CLIERR_CONNECTIONIDNOTFOUND
91916>>>            Function_Return (Found = True)
91917>>>        End
91917>>>>
91917>>>        
91917>>>        Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
91918>>>        Move SQLConnection.sDriverID to sDriverID
91919>>>        Get IsMertechDriver sDriverID to bMertechDriver
91920>>>        Move SQLConnection.sConnectionString to sConnection
91921>>>        Move SQLConnection.sSchema to sSchema
91922>>>        If (sSchema = "") Begin 
91924>>>            Get _SqlFindKeyWord CI_SQLDBO to sSchema 
91925>>>        End
91925>>>>
91925>>>
91925>>>        // We need to remove the ".int" part of the table name because
91925>>>        // the table name after the "#" in the connection syntax below wants the
91925>>>        // "bare" table name without any extension.
91925>>>        If (sDriverID <> DATAFLEX_ID) Begin
91927>>>            If (Lowercase(sTableName) contains ".int") Begin
91929>>>                Get ParseFileExtension sTableName to sExt
91930>>>                Move (Replace(("." + sExt), sTableName, "")) to sTableNameShort
91931>>>            End                                                                
91931>>>>
91931>>>            Else Begin
91932>>>                Move sTableName to sTableNameShort  
91933>>>                Move (Append(sTableName, ".int")) to sTableName
91934>>>            End   
91934>>>>
91934>>>            If (bMertechDriver = False) Begin
91936>>>                Move (sDriverID + ":" + sSchema + "#" + sTableNameShort + "@" + sConnection + "|options|intfile=" + sTableName) to sConnection
91937>>>                Move sConnection to sTableName
91938>>>            End
91938>>>>
91938>>>        End
91938>>>>
91938>>>
91938>>>        Send Ignore_Error of Error_Object_Id CLIERR_LOGIN_UNSUCCESSFUL
91939>>>        Send Ignore_Error of Error_Info_Object DFERR_FILE_ACCESS_VIOLATION 
91940>>>        If (hTable = 0) Begin
91942>>>            Get NextFreeFilelistSlot to hTable
91943>>>        End
91943>>>>
91943>>>
91943>>>        Case Begin
91943>>>            Case (sDriverID = MSSQLDRV_ID)
91945>>>                // If not df_exclusive mode, we use the "Open As" syntax.
91945>>>                If (iMode <> DF_EXCLUSIVE) Begin
91947>>>                    Open sTableName as hTable
91949>>>                End
91949>>>>
91949>>>                Else Begin
91950>>>                    Open hTable mode DF_Exclusive
91952>>>                End
91952>>>>
91952>>>                Case Break
91953>>>
91953>>>            Case (sDriverID = DB2_DRV_ID)
91956>>>                // If not df_exclusive mode, we use the "Open As" syntax.
91956>>>                If (iMode <> DF_EXCLUSIVE) Begin
91958>>>                    Open sTableName as hTable
91960>>>                End
91960>>>>
91960>>>                Else Begin
91961>>>                    Open hTable mode DF_Exclusive
91963>>>                End
91963>>>>
91963>>>                Case Break
91964>>>
91964>>>            Case (sDriverID = ODBC_DRV_ID)
91967>>>                // If not df_exclusive mode, we use the "Open As" syntax.
91967>>>                If (iMode <> DF_EXCLUSIVE) Begin
91969>>>                    Open sTableName as hTable
91971>>>                End
91971>>>>
91971>>>                Else Begin
91972>>>                    Open hTable mode DF_Exclusive
91974>>>                End
91974>>>>
91974>>>                Case Break 
91975>>>                
91975>>>            Case (sDriverID = SQLFLEX)                                                                               
91978>>>                // ToDo: What is the <owner>? Same as Schema?
91978>>>                // SQLFlex:   Open "sql_drv:\\<serverName>\<database>*<owner>*<tableName>=<numberFieds>" as table 
91978>>>                Move (SQLFLEX + ":\\" + SQLConnection.sServer + "\" + SQLConnection.sDatabase + SQLConnection.sSchema + "*" + sTableNameOrg) to sTableName
91979>>>                // If not df_exclusive mode, we use the "Open As" syntax.
91979>>>                If (iMode <> DF_EXCLUSIVE) Begin
91981>>>                    Open sTableName as hTable
91983>>>                End
91983>>>>
91983>>>                Else Begin
91984>>>                    Open hTable mode DF_Exclusive
91986>>>                End
91986>>>>
91986>>>                Case Break
91987>>>
91987>>>            Case (sDriverID = MDSMySQL)
91990>>>                // MySQLFlex: Open "mdsmysql:\\<serverName>\<database>*<tableName>=<numberFieds>" as table 
91990>>>                Move (MDSMySQL + ":\\" + SQLConnection.sServer + "\" + SQLConnection.sDatabase + "*" + sTableNameOrg) to sTableName
91991>>>                // If not df_exclusive mode, we use the "Open As" syntax.
91991>>>                If (iMode <> DF_EXCLUSIVE) Begin
91993>>>                    Open sTableName as hTable
91995>>>                End
91995>>>>
91995>>>                Else Begin
91996>>>                    Open hTable mode DF_Exclusive
91998>>>                End
91998>>>>
91998>>>                Case Break
91999>>>
91999>>>            Case (sDriverID = MDSPgSQL)
92002>>>                // PgFlex: Open "mdspgsql:\\<serverName>\<database>*<schema>*<tableName>=<numberFieds>" as table 
92002>>>                Move (MDSPgSQL + ":\\" + SQLConnection.sServer + "\" + SQLConnection.sDatabase + "*" + SQLConnection.sSchema + "*" + sTableNameOrg) to sTableName
92003>>>                // If not df_exclusive mode, we use the "Open As" syntax.
92003>>>                If (iMode <> DF_EXCLUSIVE) Begin
92005>>>                    Open sTableName as hTable
92007>>>                End
92007>>>>
92007>>>                Else Begin
92008>>>                    Open hTable mode DF_Exclusive
92010>>>                End
92010>>>>
92010>>>                Case Break
92011>>>
92011>>>            Case (sDriverID = ORAFLEX)
92014>>>                // ToDo: What is the <owner>? Same as Schema?
92014>>>                // ORAFlex: Open "ora_drv:\\<serverName>\<owner>*<tableName>=<numberFieds>" as table 
92014>>>                Move (ORAFLEX + ":\\" + SQLConnection.sServer + "\" + SQLConnection.sSchema + "*" + sTableName) to sTableName
92015>>>                // If not df_exclusive mode, we use the "Open As" syntax.
92015>>>                If (iMode <> DF_EXCLUSIVE) Begin
92017>>>                    Open sTableName as hTable
92019>>>                End
92019>>>>
92019>>>                Else Begin
92020>>>                    Open hTable mode DF_Exclusive
92022>>>                End
92022>>>>
92022>>>                Case Break
92023>>>
92023>>>            Case (sDriverID = DATAFLEX_ID)
92026>>>                If (sTableName <> "" and iMode <> DF_EXCLUSIVE) Begin
92028>>>                    Open sTableName as hTable
92030>>>                End
92030>>>>
92030>>>                Else If (iMode = DF_EXCLUSIVE) Begin
92033>>>                    Open hTable mode DF_Exclusive
92035>>>                End
92035>>>>
92035>>>                Else Begin
92036>>>                    Open hTable
92038>>>                End
92038>>>>
92038>>>                Case Break
92039>>>                
92039>>>            // ToDo: Logic needs to be expanded for Mertech drivers!
92039>>>
92039>>>            Case Else
92039>>>                Error DFERR_PROGRAM ("Invalid driver:" * sDriverID)
92040>>>>
92040>>>        Case End
92040>>>
92040>>>        Send Trap_Error of Error_Object_Id CLIERR_LOGIN_UNSUCCESSFUL 
92041>>>        Send Trap_Error of Error_Info_Object DFERR_FILE_ACCESS_VIOLATION
92042>>>        If (LastErr = CLIERR_LOGIN_UNSUCCESSFUL) Begin
92044>>>            Move False to Found
92045>>>        End
92045>>>>
92045>>>        // If open failed, the Err is set to true,
92045>>>        // but we don't want that because it could end our loop.
92045>>>        Move False to Err
92046>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpen
92049>>>
92049>>>        Function_Return bOpen
92050>>>    End_Function
92051>>>    
92051>>>    // Pass a table handle
92051>>>    // Returns True if the table exists in filelist.cfg.
92051>>>    Function UtilTableNumberIsInUse Handle hCheckTable Returns Boolean
92053>>>        Handle hTable
92053>>>        Boolean bFound
92053>>>        
92053>>>        Move False to bFound
92054>>>        Move 0 to hTable              
92055>>>        Repeat
92055>>>>
92055>>>            Get_Attribute DF_FILE_NEXT_USED of hTable to hTable
92058>>>            If (hTable > 0) Begin
92060>>>                If (hTable = hCheckTable) Begin
92062>>>                    Move True to bFound
92063>>>                End
92063>>>>
92063>>>            End
92063>>>>
92063>>>            If (bFound = True) Break
92066>>>        Until (hTable = 0)
92068>>>    
92068>>>        Function_Return (bFound = True)
92069>>>    End_Function
