89307>>>    
89307>>>    // *** Helper Functions ***
89307>>>    // They all start with an underscore: "_" in the function name.
89307>>>    //
89307>>>    // Reads a SQL script file that has been compiled into the .exe program as a resource.
89307>>>    // Pass: The memory resource reference and a boolean True if you want to create the file on disk (in the Home folder).
89307>>>    // Returns: A tSQLScriptArray Struct with the Sql script as an uChar Array will be returned along with the a bError boolean.
89307>>>    Function SqlUtilReadResource String sMemFileName Returns tSQLScriptArray
89309>>>        Integer iChannel iArgumentSize iOut iChunk iPointer iCount iSize
89309>>>        Number nByteCount
89309>>>        String sCharacter sSQLScript 
89309>>>        Boolean bSeqEof
89309>>>        tSQLScriptArray SqlScriptArray
89309>>>        tSQLScriptArray SqlScriptArray
89309>>>        UChar[] uCharData
89310>>>        
89310>>>        Move False to Err
89311>>>        Get Seq_New_Channel to iChannel
89312>>>        If (iChannel = DF_SEQ_CHANNEL_NOT_AVAILABLE) Begin
89314>>>            Error DFERR_PROGRAM 'No channel available...'
89315>>>>
89315>>>            Move True to SqlScriptArray.bError
89316>>>            Function_Return SqlScriptArray
89317>>>        End                    
89317>>>>
89317>>>        
89317>>>        // First decide the size of the script
89317>>>        Direct_Input channel iChannel ("Resource: " + sMemFileName)
89319>>>        Read_Block channel iChannel uCharData -1 // -1 means that all data should be read.
89321>>>        Close_Input channel iChannel
89323>>>
89323>>>        Move (SizeOfArray(uCharData)) to nByteCount 
89324>>>        If (nByteCount  < 1) Begin
89326>>>            Send Seq_Release_Channel iChannel  
89327>>>            Move True to SqlScriptArray.bError
89328>>>            Function_Return SqlScriptArray
89329>>>        End
89329>>>>
89329>>>        
89329>>>        // If necessary change the string argument_size
89329>>>        Get_Argument_Size to iArgumentSize
89330>>>        If (nByteCount >= iArgumentSize) Begin
89332>>>            Move (nByteCount + 2048) to nByteCount
89333>>>            Set_Argument_Size nByteCount // Set new argument size just a bit higher than "needed" for overhead margin.
89334>>>>
89334>>>            Move True          to SqlScriptArray.bArgumentSizeChanged
89335>>>            Move iArgumentSize to SqlScriptArray.iOrgArgumentSize
89336>>>        End                         
89336>>>>
89336>>>        Else Begin
89337>>>            Move False to SqlScriptArray.bArgumentSizeChanged
89338>>>        End
89338>>>>
89338>>>        
89338>>>        // Read the script file from memory line-by-line
89338>>>        Direct_Input channel iChannel ("Resource: " + sMemFileName) 
89340>>>            Move 0 to iCount
89341>>>            Repeat
89341>>>>
89341>>>                Readln channel iChannel sSQLScript
89343>>>                Move sSQLScript to SqlScriptArray.sSQLScriptArray[iCount]
89344>>>                Increment iCount
89345>>>            Until (SeqEof = True)
89347>>>        Close_Input channel iChannel
89349>>>        Send Seq_Release_Channel iChannel 
89350>>>        
89350>>>        // Finally "sanitize" the script by removing all comments.
89350>>>        Get _SqlUtilSanitizeScript SqlScriptArray to SqlScriptArray  
89351>>>
89351>>>        Function_Return SqlScriptArray
89352>>>    End_Function 
89353>>>    
89353>>>    Function SqlUtilExecuteEmbeddedScript tSQLScriptArray SQLScriptArray String sDriverID Boolean bCreateScriptFile String sMemFileName Boolean bShowProgr Returns Boolean
89355>>>        String sSQLVal sStmt sCR sDebugFileName sTmp sGOKeyWord sNoCountKeyWord sMessage sExportFile
89355>>>        Handle hoSql hoSQLConnect hoStmt hoError
89355>>>        Integer i iMsgs iFetchResult iResultCount iRows iRowType iCount iChunkCounter iChunkMax iPos iOut iNextSet iMessage
89355>>>        String[] sMsg aSQLQueryMessages
89357>>>        DateTime dtQueryExecStart dtQueryExecEnd
89357>>>        TimeSpan tsQuery
89357>>>        tSqlErrorArray aSqlErrorArray  
89357>>>        tSqlErrorArray aSqlErrorArray  
89357>>>        tSQLConnection SQLConnection
89357>>>        tSQLConnection SQLConnection
89357>>>        Boolean bOK bMertechDriver bShowProgress
89357>>>        
89357>>>        If (num_arguments > 4) Begin
89359>>>            Move bShowProgr to bShowProgress
89360>>>        End
89360>>>>
89360>>>        Get IsMertechDriver sDriverID to bMertechDriver
89361>>>        If (bMertechDriver = False) Begin
89363>>>            Get phoSQLManager to hoSql
89364>>>        End 
89364>>>>
89364>>>        Else Begin
89365>>>            Get _MertechSQLManagerHandle to hoSql
89366>>>        End
89366>>>>
89366>>>            
89366>>>        Get _SqlFindKeyWord CI_SQLGO to sGOKeyWord
89367>>>        // There seems to be a problem to pass strings when their value gets really big, aka
89367>>>        // above the argument_size level. It isn't clear when these problems starts but sooner
89367>>>        // or later SqlExecDirect stops working correctly with no error messages!
89367>>>        // To guard from this we set a max number of lines (iChunkMax) that can be processed
89367>>>        // at a time. Testing with the Create Chinook Database script; 500 seems like a number that works fine. 
89367>>>        // A bonus of this is that it turns out that it is actually faster to run in chunks!
89367>>>        Get piChunkMax to iChunkMax    
89368>>>        Move 0 to iChunkCounter                                 
89369>>>        Move "" to sStmt   
89370>>>
89370>>>        Get _SqlFindKeyWord CI_SQLSetNoCountOn to sNoCountKeyWord
89371>>>        Move (Character(13) + Character(10)) to sCR
89372>>>
89372>>>        Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
89373>>>        
89373>>>        If (bMertechDriver = True) Begin
89375>>>            Get _MertechSQLConnect sDriverID SQLConnection.sServer SQLConnection.sUserID SQLConnection.sPassword to hoSQLConnect
89376>>>        End
89376>>>>
89376>>>        If (bMertechDriver = False) Begin
89378>>>            Get phoSQLManager  to hoSQL
89379>>>            Send SqlSetConnect of hoSQL sDriverID SQLConnection.sConnectionString
89380>>>            Get SqlConnect     of hoSQL "" "" to hoSQLConnect
89381>>>        End
89381>>>>
89381>>>
89381>>>        If (hoSQLConnect <> 0) Begin 
89383>>>            Move False to Err
89384>>>            Get SqlOpen of hoSQLConnect to hoStmt
89385>>>            If (hoStmt <> 0) Begin
89387>>>
89387>>>                // If the embedded resource should be written as a script file to disk:
89387>>>                If (bCreateScriptFile = True) Begin
89389>>>                    Get psHome of (phoWorkspace(ghoApplication)) to sExportFile
89390>>>                    Get vFolderFormat sExportFile to sExportFile
89391>>>                    Move (sExportFile + sMemFileName) to sExportFile
89392>>>                    Get Seq_New_Channel to iOut 
89393>>>                    If (iOut <> DF_SEQ_CHANNEL_NOT_AVAILABLE) Begin
89395>>>                        Direct_Output channel iOut sExportFile  
89397>>>                    End
89397>>>>
89397>>>                End
89397>>>>
89397>>>        
89397>>>                // Record starting date/time stamp
89397>>>                Move (CurrentDateTime()) to dtQueryExecStart
89398>>>                // Turn on error handling if enabled
89398>>>                If (pbHandleQueryErrors(Self)) Begin
89400>>>                    Set pbSqlError to False  
89401>>>                    Set paSqlErrorArray to aSqlErrorArray
89402>>>                    Move Error_Object_Id to hoError
89403>>>                    Move Self to Error_Object_Id
89404>>>                End                                                    
89404>>>>
89404>>>                
89404>>>                Move (SizeOfArray(SQLScriptArray.sSQLScriptArray)) to iRows  
89405>>>                Decrement iRows
89406>>>                Move (sNoCountKeyWord + sCR) to sStmt
89407>>>
89407>>>                For iCount from 0 to iRows   
89413>>>>
89413>>>                    Move (SQLScriptArray.sSQLScriptArray[iCount]) to sSQLVal
89414>>>                    
89414>>>                    If (Uppercase(sSQLVal) <> sGOKeyWord) Begin
89416>>>                        If (sSQLVal <> "") Begin
89418>>>                            Move (sSQLVal + sCR) to sSQLVal
89419>>>                        End
89419>>>>
89419>>>                        Move (Append(sStmt, (sSQLVal))) to sStmt
89420>>>                    End
89420>>>>
89420>>>                    
89420>>>                    // - Each time we encounter a "GO" statement we execute it,
89420>>>                    // or if at the very end of the script.
89420>>>                    If (Uppercase(sSQLVal) = sGOKeyWord or iChunkCounter >= iChunkMax or iCount = iRows) Begin 
89422>>>                        
89422>>>                        // - It turns out it can be at least 10 times faster to execute SQL statements in chunks,
89422>>>                        // instead of all in one go. 
89422>>>                        Send SqlExecDirect of hoStmt sStmt 
89423>>>                        
89423>>>                        If (bCreateScriptFile = True) Begin
89425>>>                            Write channel iOut sStmt
89427>>>                        End
89427>>>>
89427>>>                        Move "" to sStmt   
89428>>>                        Move 0 to iChunkCounter
89429>>>                    End
89429>>>>
89429>>>                    Increment iChunkCounter
89430>>>                Loop
89431>>>>
89431>>>                       
89431>>>                Repeat
89431>>>>
89431>>>                    If (pbHandleQueryErrors(Self)) Begin
89433>>>                        Move hoError to Error_Object_Id
89434>>>                    End
89434>>>>
89434>>>                    Move (CurrentDateTime()) to dtQueryExecEnd  
89435>>>                    
89435>>>                    Send _SqlColumnInfo hoStmt
89436>>>                    Get SqlStmtAttribute of hoStmt SqlSTMTATTRIB_ROWCOUNT to iRows
89437>>>                    Get SqlStmtAttribute of hoStmt SqlSTMTATTRIB_ROWCOUNT_TYPE to iRowType
89438>>>                    Get SqlStmtAttribute of hoStmt SqlSTMTATTRIB_NUMMESSAGES to iMsgs
89439>>>                    Set piRows    to iRows
89440>>>                    Set piRowType to iRowType
89441>>>                   
89441>>>                    If (iMsgs <> 0) Begin
89443>>>                        If (ghoDbUpdateHandler > 0) Begin
89445>>>                            Get paSQLQueryMessages of ghoDbUpdateHandler to aSQLQueryMessages
89446>>>                        End
89446>>>>
89446>>>                        For i from 1 to iMsgs
89452>>>>
89452>>>                            Get SqlGetMessage of hoStmt i to sMessage     
89453>>>                            Get RemoveComponentIdentifier of hoStmt sMessage to sMessage   
89454>>>                            If (bShowProgress = True) Begin
89456>>>                                If (Active_State(ghoStatusPanel)) Begin
89458>>>                                    Send Update_StatusPanel of ghoStatusPanel (Sformat("  SQLGetMessage iMessage %1 returned [%2]", iMessage, sMessage))
89459>>>                                End                                                   
89459>>>>
89459>>>                                Else Begin
89460>>>                                    Showln (Sformat("  SQLGetMessage iMessage %1 returned [%2]", iMessage, sMessage))
89462>>>                                End
89462>>>>
89462>>>                            End
89462>>>>
89462>>>                            Move sMessage to sMsg[SizeOfArray(sMsg)]
89463>>>                            Move sMessage to aSQLQueryMessages[SizeOfArray(aSQLQueryMessages)]
89464>>>                        Loop   
89465>>>>
89465>>>                    
89465>>>                    
89465>>>                        If (ghoDbUpdateHandler > 0) Begin
89467>>>                            Set paSQLQueryMessages of ghoDbUpdateHandler to aSQLQueryMessages
89468>>>                        End
89468>>>>
89468>>>                        Set paQueryMessages to sMsg
89469>>>                    End
89469>>>>
89469>>>
89469>>>                    Get SQLNextResultSet of hoStmt to iNextSet
89470>>>                Until (iNextSet = 0)
89472>>>                
89472>>>                Move (CurrentDateTime()) to dtQueryExecEnd
89473>>>            End 
89473>>>>
89473>>>            
89473>>>            Move (dtQueryExecEnd - dtQueryExecStart) to tsQuery
89474>>>            Set ptsQueryExec to tsQuery  
89475>>>            Send SqlClose of hoStmt
89476>>>
89476>>>            If (bCreateScriptFile = True) Begin
89478>>>                Close_Output channel iOut
89480>>>                Send Seq_Release_Channel iOut
89481>>>            End
89481>>>>
89481>>>        End
89481>>>>
89481>>>        Send SqlDisconnect of hoSQLConnect
89482>>>
89482>>>        Function_Return (hoSQLConnect <> 0 and Err = False)
89483>>>    End_Function
