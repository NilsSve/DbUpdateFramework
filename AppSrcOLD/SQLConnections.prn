90656>>>    // ToDo: Needs to be revised
90656>>>    Procedure ApiTableCreateFromDEF String sPath String sFileName String sTableName String sDisplayName Integer iFilelistSlot
90658>>>        Handle hTable 
90658>>>        String sDEFName sDataPath sDriverID
90658>>>        Boolean bExists
90658>>>        
90658>>>        // Do nothing if MSSQL Driver.
90658>>>//        Get IsMSSQLDriver to bExists
90658>>>//        If (bExists = True) Begin
90658>>>//            Procedure_Return
90658>>>//        End
90658>>>        
90658>>>        Get psDataPathFirstPart to sDataPath
90659>>>        Get vFilePathExists (sDataPath + sFileName + ".dat") to bExists
90660>>>        If (bExists = True) Begin      
90662>>>            // We also needs to check if it is an Alias file, in case the sFileName.dat exists, but it may
90662>>>            // still be missing from the filelist and needs to be added.
90662>>>            Get UtilTableNumberIsInUse iFilelistSlot to bExists
90663>>>            If (bExists = True) Begin
90665>>>                Procedure_Return
90666>>>            End 
90666>>>>
90666>>>            // Do _not_ use the DEF file if an alias, it will overwrite the base table data.
90666>>>            Else Begin
90667>>>                Set_Attribute DF_FILE_ROOT_NAME    of iFilelistSlot to sFileName
90670>>>                Set_Attribute DF_FILE_LOGICAL_NAME of iFilelistSlot to sTableName
90673>>>                Set_Attribute DF_FILE_DISPLAY_NAME of iFilelistSlot to sDisplayName
90676>>>                Procedure_Return
90677>>>            End
90677>>>>
90677>>>        End
90677>>>>
90677>>>    
90677>>>        Move (sPath + sFileName + ".def") to sDEFName
90678>>>        Move 0 to hTable
90679>>>        Move False to Err
90680>>>    
90680>>>        Structure_Start hTable DATAFLEX_ID
90681>>>            Load_Def sDEFName Onto hTable
90682>>>            Set_Attribute DF_FILE_PHYSICAL_NAME of hTable to sFileName
90685>>>        Structure_End hTable DF_STRUCTEND_OPT_NONE
90687>>>    
90687>>>        Move iFilelistSlot to hTable
90688>>>        Set_Attribute DF_FILE_ROOT_NAME    of hTable to sFileName
90691>>>        Set_Attribute DF_FILE_LOGICAL_NAME of hTable to sTableName
90694>>>        Set_Attribute DF_FILE_DISPLAY_NAME of hTable to sDisplayName
90697>>>    
90697>>>    End_Procedure      
