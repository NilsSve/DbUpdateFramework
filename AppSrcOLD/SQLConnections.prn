81359>>>>>>>>>>>>>///
81359>>>>>>>>>>>>>/// String sIndexUnique
81359>>>>>>>>>>>>>///
81359>>>>>>>>>>>>>/// Get_Attribute DF_INDEX_UNIQUE of Customer.File_Number 1 to sIndexUnique
81359>>>>>>>>>>>>>Define DF_INDEX_UNIQUE                              For (DF_INDEX_KEY_LENGTH+6)
