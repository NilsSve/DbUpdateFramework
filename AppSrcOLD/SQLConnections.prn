98326>>>        Function ReadIniFile Returns tSQLConnection[]
98329>>>            tSQLConnection[] SQLConnectionsArray
98329>>>            tSQLConnection[] SQLConnectionsArray
98330>>>            Handle ho
98330>>>
98330>>>            Get phoSQLConnectionIniFile of ghoSQLConnectionHandler to ho
98331>>>            Get SQLIniFileReadConnections of ho to SQLConnectionsArray
98332>>>
98332>>>            Function_Return SQLConnectionsArray
98333>>>        End_Function
98334>>>
98334>>>        Procedure WriteIniFile
98337>>>            Integer iCount iSize
98337>>>            Handle hoDataSource ho
98337>>>            tDataSourceRow[] TheData
98337>>>            tDataSourceRow[] TheData
98338>>>            tDataSourceRow TheRow
98338>>>            tDataSourceRow TheRow
98338>>>            tSQLConnection[] SQLConnectionArray
98338>>>            tSQLConnection[] SQLConnectionArray
98339>>>            tSQLConnection SQLConnection
98339>>>            tSQLConnection SQLConnection
98339>>>            Boolean bIsOneActive bOK 
98339>>>            String sPath sFileName
98339>>>
98339>>>            Get IsOneItemActive to bIsOneActive
98340>>>            If (bIsOneActive = False) Begin
98342>>>                Send Info_Box "Sorry, you need to set one connection as active before changes can be saved."
98343>>>                Procedure_Return
98344>>>            End
98344>>>>
98344>>>
98344>>>            Move 0 to iCount
98345>>>            Get phoSQLConnectionIniFile of ghoSQLConnectionHandler to ho
98346>>>            Get phoDataSource to hoDataSource
98347>>>            Get DataSource of hoDataSource to TheData
98348>>>            Move (SizeOfArray(TheData)) to iSize
98349>>>            Decrement iSize
98350>>>
98350>>>            // Load data from the grid datasource array to SQLConnection array
98350>>>            For iCount from 0 to iSize
98356>>>>
98356>>>                Move TheData[iCount] to TheRow
98357>>>                Get MoveGridRowToSQLConnection TheRow to SQLConnection
98358>>>                Move SQLConnection to SQLConnectionArray[iCount]
98359>>>            Loop                                                
98360>>>>
98360>>>            
98360>>>            Get SQLIniFileWriteConnections of ho SQLConnectionArray to bOK
98361>>>            If (bOK = False) Begin
98363>>>                Send ChangeStatusRowText "Sorry, an error occured while saving the file and changes were not saved."
98364>>>                Procedure_Return
98365>>>            End
98365>>>>
98365>>>            
98365>>>            // Update the view property with the newly saved values. (Used to check if anything has changed)
98365>>>            Set pTheData to TheData
98366>>>            Send ChangeHeaderText
98367>>>            Send ChangeStatusRowText "Ready! File saved."
98368>>>        End_Procedure
98369>>>
98369>>>        Procedure OnHeaderClick Integer iCol
98372>>>            String sPath sFileName
98372>>>            Handle ho 
98372>>>            
98372>>>            Forward Send OnHeaderClick iCol 
98374>>>            
98374>>>            Get vSelect_File "SQLConnections ini-files (*.ini)|SQLConnections.ini|All Ini Files (*.ini)|*.ini|All Files (*.*)|*.*" "Select a connection ini-file" "" to sFileName
98375>>>            If (sFileName <> "") Begin
98377>>>                Get phoSQLConnectionIniFile of ghoSQLConnectionHandler to ho
98378>>>                Get ParseFolderName sFileName to sPath
98379>>>                Set psIniFilePath of ho to sPath
98380>>>                Get ParseFileName sFileName to sFileName
98381>>>                Set psIniFileName of ho to sFilename    
98382>>>                Set pbDFConnId of ho to (sFileName <> CS_SQLIniFileName)
98383>>>                Send LoadData of oSQLConnections_grd
98384>>>            End
98384>>>>
98384>>>        End_Procedure                           
