91141>>>                Set_Attribute DF_INDEX_SEGMENT_FIELD of hTable iIndex 3 to iSegment3
91144>>>            End
91144>>>>
91144>>>            If (iSegment4 <> -1) Begin
91146>>>                Set_Attribute DF_INDEX_SEGMENT_FIELD of hTable iIndex 4 to iSegment4
91149>>>            End
91149>>>>
91149>>>            If (iSegment5 <> -1) Begin
91151>>>                Set_Attribute DF_INDEX_SEGMENT_FIELD of hTable iIndex 5 to iSegment5
91154>>>            End
91154>>>>
91154>>>            If (iSegment6 <> -1) Begin
91156>>>                Set_Attribute DF_INDEX_SEGMENT_FIELD of hTable iIndex 6 to iSegment6
91159>>>            End
91159>>>>
91159>>>            If (iSegment7 <> -1) Begin
91161>>>                Set_Attribute DF_INDEX_SEGMENT_FIELD of hTable iIndex 7 to iSegment7
91164>>>            End
91164>>>>
91164>>>            If (iSegment8 <> -1) Begin
91166>>>                Set_Attribute DF_INDEX_SEGMENT_FIELD of hTable iIndex 8 to iSegment8
91169>>>            End
91169>>>>
91169>>>            If (iSegment9 <> -1) Begin
