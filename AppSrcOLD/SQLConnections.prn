91534>>>    // The default value used for a datatype as specified in the driver int file.
91534>>>    Function UtilDataTypeDefaultValue String sDriverID Integer iDbType Integer iDataType Returns String
91536>>>        String sRetval sServer
91536>>>        tColumnType RetvalType 
91536>>>        tColumnType RetvalType 
91536>>>        Integer iDriver iDataFlexType
91536>>>        Handle hDatabase
91536>>>        
91536>>>        Get _UtilColumnType sDriverID iDbType iDataType "" True to RetvalType 
91537>>>        Move RetvalType.iDataFlexType to iDataFlexType
91538>>>        Get DriverIndex sDriverID to iDriver
91539>>>        Get psServer to sServer
91540>>>        Get SqlUtilDatabaseHandle sDriverID sServer to hDatabase 
91541>>>        If (hDatabase = 0) Begin
91543>>>            Function_Return ""
91544>>>        End                   
91544>>>>
91544>>>        
91544>>>        Case Begin
91544>>>            Case (iDataFlexType = DF_ASCII)
91546>>>                Get_Attribute DF_DATABASE_DEFAULT_DEFAULT_ASCII     of iDriver hDatabase to sRetval
91549>>>                Case Break
91550>>>            Case (iDataFlexType = DF_BCD)
91553>>>                Get_Attribute DF_DATABASE_DEFAULT_DEFAULT_NUMERIC   of iDriver hDatabase to sRetval
91556>>>                Case Break
91557>>>            Case (iDataFlexType = DF_BINARY)
91560>>>                Get_Attribute DF_DATABASE_DEFAULT_DEFAULT_BINARY    of iDriver hDatabase to sRetval
91563>>>                Case Break
91564>>>            Case (iDataFlexType = DF_DATE)
91567>>>                Get_Attribute DF_DATABASE_DEFAULT_DEFAULT_DATE      of iDriver hDatabase to sRetval
91570>>>                Case Break
91571>>>            Case (iDataFlexType = DF_DATETIME)
91574>>>                Get_Attribute DF_DATABASE_DEFAULT_DEFAULT_DATETIME  of iDriver hDatabase to sRetval
91577>>>                Case Break
91578>>>            Case (iDataFlexType = DF_TEXT)
91581>>>                Get_Attribute DF_DATABASE_DEFAULT_DEFAULT_TEXT      of iDriver hDatabase to sRetval
91584>>>                Case Break
91585>>>            Case Else
91585>>>                Move "" to sRetval            
91586>>>        Case End
91586>>>        
91586>>>        Function_Return sRetval
91587>>>    End_Function  
