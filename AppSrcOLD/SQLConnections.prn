97446>>>>>    // Transfers data between a tSQLConnection struct and a grid data row.
97446>>>>>    Function MoveSQLConnectionToGridRow tSQLConnection SQLConnection Returns tDataSourceRow
97449>>>>>        tDataSourceRow TheRow
97449>>>>>        tDataSourceRow TheRow
97449>>>>>        Integer iDbType
97449>>>>>        String sValue
97449>>>>>
97449>>>>>        Move 0                                  to TheRow.sValue[0]
97450>>>>>        Move SQLConnection.bEnabled             to TheRow.sValue[1]
97451>>>>>        Move SQLConnection.sConnectionID        to TheRow.sValue[2]
97452>>>>>        Move SQLConnection.sDriverID            to TheRow.sValue[3]
97453>>>>>
97453>>>>>        // We only show three asterisks ("***") instead of the password in the grid.
97453>>>>>        Move (Replace(SQLConnection.sPassword, SQLConnection.sConnectionString, "***")) to sValue
97454>>>>>        Move sValue                             to TheRow.sValue[4]
97455>>>>>
97455>>>>>        Move SQLConnection.iDbType to iDbType
97456>>>>>        Get SqlUtilDbTypeToString of ghoDbUpdateFunctionLibrary iDbType to sValue
97457>>>>>        Move sValue                             to TheRow.sValue[5]
97458>>>>>        Move SQLConnection.sServer              to TheRow.sValue[6]
97459>>>>>        Move SQLConnection.sDatabase            to TheRow.sValue[7]
97460>>>>>
97460>>>>>        // Hidden columns (to make Should_Save function work)
97460>>>>>        Move SQLConnection.sConnectionString    to TheRow.sValue[8] // "Untouched" connection string.
97461>>>>>        Move SQLConnection.bTrusted             to TheRow.sValue[9]
97462>>>>>        Move SQLConnection.sUserID              to TheRow.sValue[10]
97463>>>>>        Move SQLConnection.sPassword            to TheRow.sValue[11]
97464>>>>>        Move SQLConnection.sSchema              to TheRow.sValue[12]
97465>>>>>        Move SQLConnection.sBaseTableSpace      to TheRow.sValue[13]
97466>>>>>        Move SQLConnection.sLongTableSpace      to TheRow.sValue[14]
97467>>>>>        Move SQLConnection.sIndexTableSpace     to TheRow.sValue[15]
97468>>>>>        Move SQLConnection.bSilentLogin         to TheRow.sValue[16]
97469>>>>>//        Move SQLConnection.bDisabled            to TheRow.sValue[17]
97469>>>>>//        Move SQLConnection.iDriverIndex         to TheRow.sValue[18]
97469>>>>>
97469>>>>>        Function_Return TheRow
97470>>>>>    End_Function
