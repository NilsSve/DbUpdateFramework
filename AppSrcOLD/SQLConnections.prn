86506>>>    End_Procedure
86507>>>    
86507>>>    // This is needed when e.g. the connection id we have specified in the program code
86507>>>    // also exists in e.g. the MSSQLDRV.ini file (can either be local in the Data folder
86507>>>    // or the one in the DataFlex Bin folder.)
86507>>>    // We then need to delete the current one before creating a new one.
86507>>>    // This is because the parameters may differ between the program code and the
86507>>>    // MSSQLDRV.ini file in a deployed environment. Also DataFlex will generate an error
86507>>>    // when one tries to create a Connection ID that already exists.
86507>>>    Procedure RemoveExistingConnectionID String sDriverID String sConnectionID
86509>>>        Integer iResult iDriver iNumConn iConn
86509>>>        Handle hoCLI
86509>>>        String sID   
86509>>>        
86509>>>        If (sDriverID = "" or sConnectionID = "") Begin
86511>>>            Procedure_Return
86512>>>        End                 
86512>>>>
86512>>>        
86512>>>        Move 0 to iResult
86513>>>        Get Create U_cCLIHandler to hoCLI
86514>>>        If (hoCLI <> 0) Begin
86516>>>            Set psDriverID of hoCLI to sDriverID   
86517>>>            Get DriverIndex sDriverID to iDriver
86518>>>            Get_Attribute DF_DRIVER_NUMBER_CONNECTION_IDS of iDriver to iNumConn 
86521>>>            Decrement iNumConn
86522>>>            For iConn from 0 to iNumConn
86528>>>>
86528>>>                Get_Attribute DF_DRIVER_CONNECTION_ID of iDriver iConn to sID
86531>>>                If (Uppercase(sID) = Uppercase(sConnectionID)) Begin
86533>>>                    Get DeleteConnectionID of hoCLI sConnectionID -1 to iResult
86534>>>                End
86534>>>>
86534>>>            Loop
86535>>>>
86535>>>            Send Destroy of hoCLI
86536>>>        End
86536>>>>
86536>>>    
86536>>>    End_Procedure   
