83548>>>>>>>>>>>
83548>>>>>>>>>>>    Procedure SQLBindFile Integer iFileNum
83550>>>>>>>>>>>        tColumnMap tColumnMap
83550>>>>>>>>>>>        tColumnMap tColumnMap
83550>>>>>>>>>>>        String[] sBindFileColumns
83551>>>>>>>>>>>        Integer[] iBufferColumn
83552>>>>>>>>>>>        Integer iColCnt i iDateFormat iResultColumnType iBindFileColumnType
83552>>>>>>>>>>>        String sColumnName
83552>>>>>>>>>>>        Variant vFieldValue
83552>>>>>>>>>>>        Boolean isRecnumTable
83552>>>>>>>>>>>
83552>>>>>>>>>>>        SQL_SET_CURRENT_CURSOR_STMT to (piCursorNum(Self))
83566>>>>>>>>>>>>
83566>>>>>>>>>>>        
83566>>>>>>>>>>>        Get_Attribute DF_FILE_RECNUM_TABLE of iFileNum to isRecnumTable
83569>>>>>>>>>>>        Get ptColumnMap to tColumnMap
83570>>>>>>>>>>>        
83570>>>>>>>>>>>        If (tColumnMap.iFileNum <> iFileNum) Begin
83572>>>>>>>>>>>            Move iFileNum to tColumnMap.iFileNum
83573>>>>>>>>>>>            
83573>>>>>>>>>>>            // First we build an array of the column names (in order) from the file buffer to bind to
83573>>>>>>>>>>>            Get_Attribute DF_FILE_NUMBER_FIELDS of iFileNum to iColCnt
83576>>>>>>>>>>>            For i from 0 to iColCnt
83582>>>>>>>>>>>>
83582>>>>>>>>>>>                If (isRecnumTable) Get_Attribute DF_FIELD_NAME of iFileNum i to sColumnName
83587>>>>>>>>>>>                Else Move "" to sColumnName
83589>>>>>>>>>>>                
83589>>>>>>>>>>>                Move (Uppercase(sColumnName)) to sBindFileColumns[i]
83590>>>>>>>>>>>            Loop
83591>>>>>>>>>>>>
83591>>>>>>>>>>>
83591>>>>>>>>>>>            // Next we iterate over the columns in the resultset.  Any column names that match we 
83591>>>>>>>>>>>            // set its match location into an array that maps each resultset column to its matching
83591>>>>>>>>>>>            // column number in the file buffer.  If there is no match, we set that resultset
83591>>>>>>>>>>>            // column mappped column to -1.
83591>>>>>>>>>>>            //
83591>>>>>>>>>>>            // Since Arrays are zero based and columns are numbered from 1, when we actually map
83591>>>>>>>>>>>            // to set the value, we need to add 1 to array indexer to get the proper resultset
83591>>>>>>>>>>>            // column AND we need to add 1 to the mapped-to column since it was loaded into a zero
83591>>>>>>>>>>>            // based array also.  (Ex: vResultColumn[0] = 2 means column 1 from the resultset maps
83591>>>>>>>>>>>            // to Column 3 of the file buffer)
83591>>>>>>>>>>>            
83591>>>>>>>>>>>            
83591>>>>>>>>>>>            SQL_GET_NUM_COLS to iColCnt
83601>>>>>>>>>>>>
83601>>>>>>>>>>>            For i from 1 to iColCnt
83607>>>>>>>>>>>>
83607>>>>>>>>>>>                SQL_GET_COL_NAME i to sColumnName
83623>>>>>>>>>>>>
83623>>>>>>>>>>>                // Because SearchArray returns -1 if there isn't a match, we don't need to do
83623>>>>>>>>>>>                // anything to make an "unmapped column" have a value of -1.
83623>>>>>>>>>>>                Move (SearchArray(Uppercase(sColumnName), sBindFileColumns)) to tColumnMap.vResultColumn[i-1]
83624>>>>>>>>>>>                
83624>>>>>>>>>>>                // If the types don't match between the columns, then "unmap" the column.  This
83624>>>>>>>>>>>                // should only occur when you're not mapping to the same file as the resultset.
83624>>>>>>>>>>>                // In this case, sql.pkg silently does nothing, so we need to duplicate this instead
83624>>>>>>>>>>>                // of generating an error.  If the mapping is to a string, then any type can be
83624>>>>>>>>>>>                // converted to a string so its okay.
83624>>>>>>>>>>>                If (tColumnMap.vResultColumn[i-1] <> -1) Begin
83626>>>>>>>>>>>                    SQL_GET_COL_ATTRIBUTE of i DFTYPE to iResultColumnType
83643>>>>>>>>>>>>
83643>>>>>>>>>>>                    Get_Attribute DF_FIELD_TYPE of iFileNum (tColumnMap.vResultColumn[i-1]) to iBindFileColumnType
83646>>>>>>>>>>>                    
83646>>>>>>>>>>>                    // If the conversion is to string (even if the resultset column is something
83646>>>>>>>>>>>                    // else) its ok, so Break out of the If block before we muck things up.
83646>>>>>>>>>>>                    If (iBindFileColumnType = DF_ASCII) Break
83649>>>>>>>>>>>
83649>>>>>>>>>>>                    // Otherwise, break the mapping
83649>>>>>>>>>>>                    If (iResultColumnType <> iBindFileColumnType) Move -1 to tColumnMap.vResultColumn[i-1]
83652>>>>>>>>>>>                End
83652>>>>>>>>>>>>
83652>>>>>>>>>>>            Loop
83653>>>>>>>>>>>>
83653>>>>>>>>>>>            
83653>>>>>>>>>>>            Set ptColumnMap to tColumnMap
83654>>>>>>>>>>>        End
83654>>>>>>>>>>>>
83654>>>>>>>>>>>        
83654>>>>>>>>>>>        Get SQL_USE_DATAFLEX_DATEFORMAT to iDateFormat
83655>>>>>>>>>>>        Set SQL_USE_DATAFLEX_DATEFORMAT to True
83656>>>>>>>>>>>        Clear iFileNum
83657>>>>>>>>>>>        For i from 0 to (SizeOfArray(tColumnMap.vResultColumn)-1)
83663>>>>>>>>>>>>
83663>>>>>>>>>>>            If (tColumnMap.vResultColumn[i] > -1) Begin
83665>>>>>>>>>>>                SQL_FETCH_COLUMN (i+1) into vFieldValue
83670>>>>>>>>>>>                Set_Field_Value iFileNum (tColumnMap.vResultColumn[i]) to vFieldValue
83673>>>>>>>>>>>            End
83673>>>>>>>>>>>>
83673>>>>>>>>>>>        Loop
83674>>>>>>>>>>>>
83674>>>>>>>>>>>        Set_Attribute DF_FILE_STATUS of iFileNum to DF_FILE_ACTIVE
83677>>>>>>>>>>>        Set SQL_USE_DATAFLEX_DATEFORMAT to iDateFormat
83678>>>>>>>>>>>    End_Procedure
83679>>>>>>>>>>>    
83679>>>>>>>>>>>    Function SQLGetData Integer iCol Integer iLen Returns String
83681>>>>>>>>>>>        String data
83681>>>>>>>>>>>        Integer retlen
83681>>>>>>>>>>>
83681>>>>>>>>>>>        SQL_SET_CURRENT_CURSOR_STMT to (piCursorNum(Self))
83695>>>>>>>>>>>>
83695>>>>>>>>>>>        
83695>>>>>>>>>>>        SQL_SET_CHUNK_SIZE to iLen
83712>>>>>>>>>>>>
83712>>>>>>>>>>>        SQL_GET_DATA_CHUNK COLUMN iCol OFFSET (piDataChunkOffset(Self)) to data retlen
83722>>>>>>>>>>>>
83722>>>>>>>>>>>        Set piDataChunkOffset to (piDataChunkOffset(Self)+retlen)
83723>>>>>>>>>>>        
83723>>>>>>>>>>>        Function_Return data
83724>>>>>>>>>>>    End_Function
83725>>>>>>>>>>>
83725>>>>>>>>>>>    Function SQLColumnMap String sColname Returns Integer
83727>>>>>>>>>>>        Integer iNumColumns i iIndex
83727>>>>>>>>>>>        String[] cols
83728>>>>>>>>>>>
83728>>>>>>>>>>>        SQL_SET_CURRENT_CURSOR_STMT to (piCursorNum(Self))
83742>>>>>>>>>>>>
83742>>>>>>>>>>>        
83742>>>>>>>>>>>        Get SQLStmtAttribute SQLSTMTATTRIB_COLUMNCOUNT to iNumColumns
83743>>>>>>>>>>>        
83743>>>>>>>>>>>        For i from 1 to iNumColumns
83749>>>>>>>>>>>>
83749>>>>>>>>>>>            SQL_GET_COL_NAME i to cols[i-1]
83765>>>>>>>>>>>>
83765>>>>>>>>>>>            Move (trim(Uppercase(cols[i-1]))) to cols[i-1]
83766>>>>>>>>>>>        Loop
83767>>>>>>>>>>>>
83767>>>>>>>>>>>
83767>>>>>>>>>>>        Move (trim(Uppercase(sColname))) to sColname
83768>>>>>>>>>>>        Move (SearchArray(sColname, cols)) to iIndex
83769>>>>>>>>>>>        Function_Return (iIndex+1)  // even if searcharray returns -1 (not found) this expects 0 for not found, so it's ok
83770>>>>>>>>>>>    End_Function
83771>>>>>>>>>>>
83771>>>>>>>>>>>    Function SQLStmtAttribute Integer iAttribId Returns String
83773>>>>>>>>>>>        Integer iCnt
83773>>>>>>>>>>>
83773>>>>>>>>>>>        SQL_SET_CURRENT_CURSOR_STMT to (piCursorNum(Self))
83787>>>>>>>>>>>>
83787>>>>>>>>>>>
83787>>>>>>>>>>>        Case Begin
83787>>>>>>>>>>>            Case (iAttribId = SQLSTMTATTRIB_COLUMNCOUNT)
83789>>>>>>>>>>>                SQL_GET_NUM_COLS to iCnt
83799>>>>>>>>>>>>
83799>>>>>>>>>>>                Function_Return iCnt
83800>>>>>>>>>>>                Case Break
83801>>>>>>>>>>>            Case (iAttribId = SQLSTMTATTRIB_ROWCOUNT)
83804>>>>>>>>>>>                SQL_GET_NUM_ROWS to iCnt
83814>>>>>>>>>>>>
83814>>>>>>>>>>>
83814>>>>>>>>>>>                //DAC Driver doesn't know the rowcount before the first fetch.
83814>>>>>>>>>>>                If (giSQLCompatibilityMode=SQL_DAC_HIGH_COMPATABILITY) Begin 
83816>>>>>>>>>>>                    If (pisBeforeFetch(Self)) Function_Return -1
83819>>>>>>>>>>>                End
83819>>>>>>>>>>>>
83819>>>>>>>>>>>
83819>>>>>>>>>>>                Function_Return iCnt
83820>>>>>>>>>>>                Case Break
83821>>>>>>>>>>>            Case (iAttribId = SQLSTMTATTRIB_ROWCOUNT_TYPE)
83824>>>>>>>>>>>                // TODO: Need something to indicate the quality of the SQL_GET_NUM_ROWS, or fake till I make it
83824>>>>>>>>>>>                Case Break
83825>>>>>>>>>>>            Case (iAttribId = SQLSTMTATTRIB_NUMMESSAGES)
83828>>>>>>>>>>>                Function_Return -1
83829>>>>>>>>>>>                // TODO: Are the messages returned in SQLGetMessage from the driver, or from the underlying connection?
83829>>>>>>>>>>>                Case Break
83830>>>>>>>>>>>            Case Else
83830>>>>>>>>>>>        Case End
83830>>>>>>>>>>>        
83830>>>>>>>>>>>    End_Function
83831>>>>>>>>>>>
83831>>>>>>>>>>>    Function SQLColAttribute Integer iCol Integer iAttribId Returns String
83833>>>>>>>>>>>        String sValue
83833>>>>>>>>>>>        Integer iSQLType
83833>>>>>>>>>>>        Integer iDFType
83833>>>>>>>>>>>
83833>>>>>>>>>>>        SQL_SET_CURRENT_CURSOR_STMT to (piCursorNum(Self))
83847>>>>>>>>>>>>
83847>>>>>>>>>>>        SQL_GET_COL_ATTRIBUTE of iCol SQLTYPE to iSQLType
83864>>>>>>>>>>>>
83864>>>>>>>>>>>        SQL_GET_COL_ATTRIBUTE of iCol DFTYPE to iDFType
83881>>>>>>>>>>>>
83881>>>>>>>>>>>        
83881>>>>>>>>>>>        Case Begin
83881>>>>>>>>>>>            Case (iAttribId = SQLCOLATTRIB_SIZE)
83883>>>>>>>>>>>                SQL_GET_COL_ATTRIBUTE of iCol SIZE to sValue
83900>>>>>>>>>>>>
83900>>>>>>>>>>>
83900>>>>>>>>>>>                //DAC Driver uses different values. 
83900>>>>>>>>>>>                If (giSQLCompatibilityMode=SQL_DAC_HIGH_COMPATABILITY) Begin 
83902>>>>>>>>>>>                    If (iSQLType=12) Move (Integer(sValue-1)) to sValue
83905>>>>>>>>>>>                    If (iDFType=5) Move "0" to sValue
83908>>>>>>>>>>>                    If (iSQLType=40)  Move "10" to sValue
83911>>>>>>>>>>>                End 
83911>>>>>>>>>>>>
83911>>>>>>>>>>>                
83911>>>>>>>>>>>                Case Break
83912>>>>>>>>>>>            Case (iAttribId = SQLCOLATTRIB_PRECISION)
83915>>>>>>>>>>>                SQL_GET_COL_ATTRIBUTE of iCol DECIMALS to sValue
83932>>>>>>>>>>>>
83932>>>>>>>>>>>                Case Break
83933>>>>>>>>>>>            Case (iAttribId = SQLCOLATTRIB_LABEL)
83936>>>>>>>>>>>                SQL_GET_COL_ATTRIBUTE of iCol COLUMN_NAME to sValue
83953>>>>>>>>>>>>
83953>>>>>>>>>>>                Case Break
83954>>>>>>>>>>>            Case (iAttribId = SQLCOLATTRIB_BASECOLUMNNAME)
83957>>>>>>>>>>>                SQL_GET_COL_ATTRIBUTE of iCol COLUMN_NAME to sValue
83974>>>>>>>>>>>>
83974>>>>>>>>>>>
83974>>>>>>>>>>>                //DAC Driver doesn't use Base Column Name. 
83974>>>>>>>>>>>                If (giSQLCompatibilityMode=SQL_DAC_HIGH_COMPATABILITY) Begin 
83976>>>>>>>>>>>                    Move "" to sValue   
83977>>>>>>>>>>>                End 
83977>>>>>>>>>>>>
83977>>>>>>>>>>>                
83977>>>>>>>>>>>                Case Break
83978>>>>>>>>>>>            Case (iAttribId = SQLCOLATTRIB_BASETABLENAME)
83981>>>>>>>>>>>                SQL_GET_COL_ATTRIBUTE of iCol TABLE_NAME to sValue
83998>>>>>>>>>>>>
83998>>>>>>>>>>>                Case Break
83999>>>>>>>>>>>            Case (iAttribId = SQLCOLATTRIB_SQLTYPE)
84002>>>>>>>>>>>                Move iSQLType to sValue
84003>>>>>>>>>>>
84003>>>>>>>>>>>                //DAC Driver uses different values. 
84003>>>>>>>>>>>                If (giSQLCompatibilityMode=SQL_DAC_HIGH_COMPATABILITY) Begin 
84005>>>>>>>>>>>                    If (iSQLType=2) Move "3" to sValue
84008>>>>>>>>>>>                    If (iSQLType=-99) Move "12" to sValue
84011>>>>>>>>>>>                    If (iSQLType=40)  Move "91" to sValue
84014>>>>>>>>>>>                End 
84014>>>>>>>>>>>>
84014>>>>>>>>>>>                
84014>>>>>>>>>>>                Case Break
84015>>>>>>>>>>>            Case (iAttribId = SQLCOLATTRIB_NULLABLE)
84018>>>>>>>>>>>                SQL_GET_COL_ATTRIBUTE of iCol NULLABLE to sValue
84035>>>>>>>>>>>>
84035>>>>>>>>>>>                Case Break
84036>>>>>>>>>>>            Case (iAttribId = SQLCOLATTRIB_DFTYPE)
84039>>>>>>>>>>>                SQL_GET_COL_ATTRIBUTE of iCol DFTYPE to sValue
84056>>>>>>>>>>>>
84056>>>>>>>>>>>
84056>>>>>>>>>>>                //DAC Driver uses different values. 
84056>>>>>>>>>>>                If (giSQLCompatibilityMode=SQL_DAC_HIGH_COMPATABILITY) Begin 
84058>>>>>>>>>>>                    If (iDFType = 5) Move "0" to sValue
84061>>>>>>>>>>>                End 
84061>>>>>>>>>>>>
84061>>>>>>>>>>>                Case Break
84062>>>>>>>>>>>        Case End
84062>>>>>>>>>>>        
84062>>>>>>>>>>>        Function_Return sValue
84063>>>>>>>>>>>    End_Function
84064>>>>>>>>>>>
