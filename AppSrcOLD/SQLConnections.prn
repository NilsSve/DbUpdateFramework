95090>>>>>    // 2013-08-14 NGS
95090>>>>>    // Unformatted numeric values shown doesn't look good. These looks much better.
95090>>>>>    Procedure Show_Systemresources
95092>>>>>        tWinMemoryStatusEx MemoryStatusInfo
95092>>>>>        tWinMemoryStatusEx MemoryStatusInfo
95092>>>>>        Integer iRetval
95092>>>>>        Number nValue
95092>>>>>        String sValue
95092>>>>>
95092>>>>>        Move (SizeOfType (tWinMemoryStatusEx)) to MemoryStatusInfo.dwLength
95093>>>>>        Move (GlobalMemoryStatusEx (AddressOf (MemoryStatusInfo))) to iRetval
95094>>>>>        If (iRetval = 0) Begin
95096>>>>>            Move (ShowLastError ()) to iRetval
95097>>>>>            Procedure_Return
95098>>>>>        End
95098>>>>>>
95098>>>>>
95098>>>>>        Send AppendTextLn ""
95099>>>>>        Move MemoryStatusInfo.ullTotalPhys to nValue
95100>>>>>
95100>>>>>        // Show memory in Gigabytes:
95100>>>>>        Move (nValue/1024/1024/1024) to nValue
95101>>>>>        Move (Round(nValue)) to nValue
95102>>>>>        Get FormatNumber nValue 2 to sValue
95103>>>>>        Send AppendTextLn (SFormat (C_$AvailableMemory, (sValue * "GB")))
95104>>>>>        Send AppendTextLn (SFormat (C_$MemoryUtilization, String(MemoryStatusInfo.dwMemoryLoad) * "%"))
95105>>>>>
95105>>>>>//        Send AppendTextLn (SFormat (C_$AvailablePhysicalMemory, Real (MemoryStatusInfo.ullAvailPhys) / Real (MemoryStatusInfo.ullTotalPhys) * 100.0))
95105>>>>>        Move (Real(MemoryStatusInfo.ullAvailPhys) / Real(MemoryStatusInfo.ullTotalPhys) * 100.0) to nValue
95106>>>>>        Move (Round(nValue)) to nValue
95107>>>>>        Get FormatNumber nValue 0 to sValue
95108>>>>>        Send AppendTextLn (SFormat (C_$AvailablePhysicalMemory, (sValue * "%")))
95109>>>>>
95109>>>>>//        Send AppendTextLn (SFormat (C_$AvailablePagefileSpace, Real (MemoryStatusInfo.ullAvailPageFile) / Real (MemoryStatusInfo.ullTotalPageFile) * 100.0))
95109>>>>>        Move (Real(MemoryStatusInfo.ullAvailPageFile) / Real(MemoryStatusInfo.ullTotalPageFile) * 100.0) to nValue
95110>>>>>        Move (Round(nValue)) to nValue
95111>>>>>        Get FormatNumber nValue 0 to sValue
95112>>>>>        Send AppendTextLn (SFormat (C_$AvailablePagefileSpace, (sValue * "%")))
95113>>>>>
95113>>>>>//        Send AppendTextLn (SFormat (C_$AvailableVirtualMemory, Real (MemoryStatusInfo.ullAvailVirtual) / Real (MemoryStatusInfo.ullTotalVirtual) * 100.0))
95113>>>>>        Move (Real(MemoryStatusInfo.ullAvailVirtual) / Real(MemoryStatusInfo.ullTotalVirtual) * 100.0) to nValue
95114>>>>>        Move (Round(nValue)) to nValue
95115>>>>>        Get FormatNumber nValue 0 to sValue
95116>>>>>        Send AppendTextLn (SFormat (C_$AvailableVirtualMemory, (sValue * "%")))
95117>>>>>
95117>>>>>        // Add an empty row after the memory information:
95117>>>>>        Send AppendTextLn ""
95118>>>>>    End_Procedure
95119>>>>>
95119>>>>>    Procedure Show_Registration
95121>>>>>        String sRegName
95121>>>>>        Integer iSN iUsersMax iUserCount
95121>>>>>
95121>>>>>        Registration sRegName iSN
95122>>>>>>
95122>>>>>        Get_Licensed_Max_Users to iUsersMax
95123>>>>>        Get_Current_User_Count to iUserCount
95124>>>>>
95124>>>>>        Send AppendTextLn (SFormat (C_$Serial, iSN))
95125>>>>>        Send AppendTextLn (SFormat (C_$RegName, sRegName))
95126>>>>>        Send AppendTextLn (SFormat (C_$Current_User_Count, iUserCount))
95127>>>>>        Send AppendTextLn (SFormat (C_$Max_Licensed_User_Count, iUsersMax))
95128>>>>>    End_Procedure
95129>>>>>
95129>>>>>    //****************************************************************************
95129>>>>>    // If workspaces are used, we will send the message EnumerateWorkspaceData
95129>>>>>    // To the workspace object passing the an object and message To send back
95129>>>>>    // To this object. It is expected that the workspace object will send this
95129>>>>>    // message for every line Of information it wants displayed (passing the
95129>>>>>    // information To be displayed
95129>>>>>    //****************************************************************************
95129>>>>>    Register_Procedure EnumerateWorkspaceData Integer hObjId Integer hmMessId
95129>>>>>
95129>>>>>    Procedure Show_ServicePack
95131>>>>>        String sKey sVersion sDataFlex
95131>>>>>        Handle hoRegistry
95131>>>>>        Boolean bExists bOpened
95131>>>>>
95131>>>>>        Move "DataFlex"        to sDataFlex
95132>>>>>
95132>>>>>        Get Create U_cRegistry to hoRegistry
95133>>>>>        Set phRootKey of hoRegistry to HKEY_LOCAL_MACHINE
95134>>>>>        Set pfAccessRights of hoRegistry to KEY_READ
95135>>>>>        Get KeyExists of hoRegistry "SOFTWARE\Wow6432Node" to bExists
95136>>>>>
95136>>>>>        If (bExists) Begin
95138>>>>>            Move ("SOFTWARE\Wow6432Node\Data Access Worldwide\" + sDataFlex + "\" + SysConf (SYSCONF_DATAFLEX_REV)) to sKey
95139>>>>>        End
95139>>>>>>
95139>>>>>        Else Begin
95140>>>>>            Move ("SOFTWARE\Data Access Worldwide\"             + sDataFlex + "\" + SysConf (SYSCONF_DATAFLEX_REV)) to sKey
95141>>>>>        End
95141>>>>>>
95141>>>>>        Get KeyExists of hoRegistry sKey to bExists
95142>>>>>        If (bExists) Begin
95144>>>>>            Get OpenKey of hoRegistry sKey to bOpened
95145>>>>>            If (bOpened) Begin
95147>>>>>                Get ValueExists of hoRegistry "CurrentVersionDescription" to bExists
95148>>>>>                If (bExists) Begin
95150>>>>>                    Get ReadString of hoRegistry "CurrentVersionDescription" to sVersion
95151>>>>>                End
95151>>>>>>
95151>>>>>                Send CloseKey of hoRegistry
95152>>>>>            End
95152>>>>>>
95152>>>>>        End
95152>>>>>>
95152>>>>>        Send Destroy of hoRegistry
95153>>>>>
95153>>>>>        If (sVersion <> "") Begin
95155>>>>>           Send AppendTextLn sVersion
95156>>>>>           Send AppendTextLn ""
95157>>>>>        End
95157>>>>>>
95157>>>>>    End_Procedure
95158>>>>>
95158>>>>>    Procedure Show_WorkspaceInformation
95160>>>>>        Integer hoWorkspace
95160>>>>>
95160>>>>>        If (ghoApplication <> 0) Begin
95162>>>>>            Get phoWorkspace of ghoApplication to hoWorkspace
95163>>>>>            If (hoWorkspace <> 0) Begin
95165>>>>>                Send EnumerateWorkspaceData of hoWorkspace Self msg_AppendTextLn
95166>>>>>            End
95166>>>>>>
95166>>>>>        End
95166>>>>>>
95166>>>>>    End_Procedure
95167>>>>>
95167>>>>>    //****************************************************************************
95167>>>>>    // If connection ids are used, we will send the message EnumerateConnections
95167>>>>>    // to the connection manager object passing the an object and message to send 
95167>>>>>    // back to this object. It is expected that the connection manager object will 
95167>>>>>    // send this message for every line Of information it wants displayed (passing 
95167>>>>>    // the information To be displayed
95167>>>>>    //****************************************************************************
95167>>>>>    Register_Procedure EnumerateConnections Integer hObjId Integer hmMessId
95167>>>>>
95167>>>>>    Procedure Show_ConnectionIdInformation
95169>>>>>        If (ghoConnection > 0) Begin
95171>>>>>            Send EnumerateConnections of ghoConnection Self (RefProc(AppendTextLn))
95172>>>>>            Send AppendTextLn ""
95173>>>>>        End
95173>>>>>>
95173>>>>>    End_Procedure
95174>>>>>
95174>>>>>    Function VersionStr Integer iVer Integer iRev Integer iBld Returns String
95176>>>>>        Function_Return (String (iVer) - "." - String (iRev) - "." - String (iBld))
95177>>>>>    End_Function
95178>>>>>
95178>>>>>    Procedure Show_Versions
95180>>>>>        Integer iVersion iRevision iBuild
95180>>>>>
95180>>>>>        Version_information iVersion iRevision iBuild
95182>>>>>
95182>>>>>        Send AppendTextLn (SFormat (C_$RuntimeVersion, VersionStr(self,iVersion,iRevision,iBuild) ))
95183>>>>>        Send AppendTextLn (SFormat (C_$PackageVersion, VersionStr(self,PKG_VERSION, PKG_REVISION, PKG_BUILD) ))
95184>>>>>        Send AppendTextLn (SFormat (C_$FMACVersion, VersionStr(self,FMAC_VERSION, FMAC_REVISION, FMAC_BUILD) ))
95185>>>>>    End_Procedure                                           
95186>>>>>    
95186>>>>>    Function IsDAWSQLDriver String sDriverID Returns Boolean
95188>>>>>        Boolean bOK
95188>>>>>        Move (sDriverID = MSSQLDRV_ID or sDriverID = DB2_DRV_ID or sDriverID = ODBC_DRV_ID) to bOK
95189>>>>>        Function_Return bOK
95190>>>>>    End_Function
95191>>>>>
95191>>>>>    Function IsMertechDriver String sDriverID Returns Boolean
95193>>>>>        Boolean bOK   
95193>>>>>        Move (sDriverID = SQLFLEX or sDriverID = ORAFLEX or sDriverID = MDSPgSQL or sDriverID = MySQLFlex) to bOK
95194>>>>>        Function_Return bOK
95195>>>>>    End_Function
95196>>>>>
95196>>>>>    //***
95196>>>>>    //*** BW
95196>>>>>    //*** Procedure: Show_Drivers
95196>>>>>    //*** Purpose  : Show loaded database drivers
95196>>>>>    //***
95196>>>>>
95196>>>>>    Procedure Show_Drivers
95198>>>>>        String sDriverID sVersion sClient sMertechSQLFlexVersion sValue
95198>>>>>        Integer iNumberOfDrivers iDriver iClient iUsersMax iSerialNo iNumServers iCount
95198>>>>>        Handle hoCLIHandler hoBtrvHandler
95198>>>>>        Boolean bStudioLicense bIsDAWDriver bIsMertechDriver
95198>>>>>
95198>>>>>        Move False to bStudioLicense
95199>>>>>
95199>>>>>        Get Create U_cCLIHandler      to hoCLIHandler
95200>>>>>        Get Create U_cDFBtrDrvHandler to hoBtrvHandler 
95201>>>>>
95201>>>>>        // For testing purposes:        
95201>>>>>//        Send Ignore_Error of Error_Object_Id DFERR_CANT_LOAD_DLL
95201>>>>>//        Load_Driver MSSQLDRV_ID
95201>>>>>//        Load_Driver ODBC_DRV_ID
95201>>>>>//        Load_Driver DB2_DRV_ID
95201>>>>>//        Send Trap_Error of Error_Object_Id DFERR_CANT_LOAD_DLL
95201>>>>>//
95201>>>>>//        #IFDEF DUF_Use_Mertech_Drivers  
95201>>>>>//            Send Ignore_Error of Error_Object_Id DFERR_CANT_LOAD_DLL
95201>>>>>//            Load_Driver SQLFLEX 
95201>>>>>//            Load_Driver MDSPgSQL
95201>>>>>//            Load_Driver MDSMySQL
95201>>>>>//            Load_Driver ORAFLEX
95201>>>>>//            Send Trap_Error of Error_Object_Id DFERR_CANT_LOAD_DLL
95201>>>>>//        #ENDIF
95201>>>>>        Move False to Err
95202>>>>>        
95202>>>>>        // Loop through all loaded drivers.
95202>>>>>        Get_Attribute DF_NUMBER_DRIVERS to iNumberOfDrivers
95205>>>>>        If (iNumberOfDrivers > 1) Begin
95207>>>>>            Send AppendTextLn ""
95208>>>>>        End
95208>>>>>>
95208>>>>>        For iDriver from 1 to iNumberOfDrivers           
95214>>>>>>
95214>>>>>            // For some weird reason it can happen that - when using Mertech drivers - that the driver index
95214>>>>>            // was increased in the CLI array, but it has no value. In that case a "Bad parameter..." error
95214>>>>>            // would be thrown, so we safeguard from that here.
95214>>>>>            Send Ignore_Error of Error_Object_Id DFERR_BAD_PARAMETER
95215>>>>>            Get_Attribute DF_DRIVER_NAME of iDriver to sDriverID
95218>>>>>            Send Trap_Error of Error_Object_Id DFERR_BAD_PARAMETER
95219>>>>>            Get IsDAWSQLDriver sDriverID to bIsDAWDriver
95220>>>>>            Get IsMertechDriver sDriverID to bIsMertechDriver
95221>>>>>
95221>>>>>            If (sDriverID = DFBTRDRV_ID or bIsDAWDriver = True or bIsMertechDriver = True) Begin
95223>>>>>
95223>>>>>                // Pervasive/Btrieve database
95223>>>>>                If (sDriverID = DFBTRDRV_ID) Begin
95225>>>>>                    Get CKRevision of hoBtrvHandler to sVersion
95226>>>>>                    Get PSQLLocalEngineVersionInfo of hoBtrvHandler 0 to sClient
95227>>>>>                    If (sClient <> "0.0.0") Begin
95229>>>>>                        Send AppendTextLn (SFormat (C_$Pervasive_Local_Engine_Version, sClient))
95230>>>>>                    End
95230>>>>>>
95230>>>>>                    Get PSQLServerEngineVersionInfo of hoBtrvHandler 0 to sClient
95231>>>>>                    If (sClient <> "0.0.0") Begin
95233>>>>>                        Send AppendTextLn (SFormat (C_$Pervasive_Server_Engine_Version, sClient))
95234>>>>>                    End
95234>>>>>>
95234>>>>>                End
95234>>>>>>
95234>>>>>
95234>>>>>                Else Begin
95235>>>>>                    Set psDriverID of hoCLIHandler to sDriverID 
95236>>>>>                    Move 0 to iNumServers
95237>>>>>                    If (sDriverID <> DATAFLEX_ID) Begin
95239>>>>>                        Get_Attribute DF_DRIVER_NUMBER_SERVERS of iDriver to iNumServers
95242>>>>>                    End
95242>>>>>>
95242>>>>>                    
95242>>>>>                    If (bIsDAWDriver = True) Begin
95244>>>>>                        If (sDriverID = MSSQLDRV_ID) Begin
95246>>>>>                            // This info is only available for the MS SQL driver:
95246>>>>>                            Get_Attribute DF_DRIVER_SQLSERVER_CLIENT_VERSION of iDriver to iClient
95249>>>>>                            If (iClient = 13) Move C_$SQLSERVER2016DRVRSTR              to sClient
95252>>>>>                            If (iClient = 12) Move C_$SQLSERVER2014DRVRSTR              to sClient
95255>>>>>                            If (iClient = 11) Move C_$SQL_Server_Native_Client_11_0     to sClient
95258>>>>>                            If (iClient = 10) Move C_$SQL_Server_Native_Client_10_0     to sClient
95261>>>>>                            If (iClient = 9)  Move C_$SQL_Native_Client                 to sClient
95264>>>>>                            If (iClient = 8)  Move C_$SQL_Server_SQL_Server_2000_client to sClient
95267>>>>>                            If (sClient <> "") Begin
95269>>>>>                                Move ("    " + sClient) to sClient
95270>>>>>                            End
95270>>>>>>
95270>>>>>                        End
95270>>>>>>
95270>>>>>                    
95270>>>>>                        Get CKRevision of hoCLIHandler to sVersion 
95271>>>>>                    End
95271>>>>>>
95271>>>>>                    
95271>>>>>                    If (bIsMertechDriver = True) Begin
95273>>>>>                        GET_DRIVER_REVISION to sVersion
95286>>>>>>
95286>>>>>                    End
95286>>>>>>
95286>>>>>                    
95286>>>>>                    // If the serialnumber is = 0, it means that the
95286>>>>>                    // Studio licens is in use and there is no
95286>>>>>                    // number of max users defined because the driver is
95286>>>>>                    // relying on the info from the VDF license.
95286>>>>>                    If (bStudioLicense = False) Begin
95288>>>>>                        Get SerialNumber of hoCLIHandler to iSerialNo
95289>>>>>                        Move (iSerialNo = 0) to bStudioLicense
95290>>>>>                    End
95290>>>>>>
95290>>>>>                End
95290>>>>>>
95290>>>>>                Send AppendTextLn (SFormat (C_$DatabaseDriver, (sDriverID * "-" * (C_$Version + ": " + sVersion))))
95291>>>>>                If (iNumServers <> 0) Begin
95293>>>>>                    For iCount from 1 to iNumServers
95299>>>>>>
95299>>>>>                        Get_Attribute DF_DRIVER_SERVER_NAME of iDriver iCount to sValue 
95302>>>>>                        Send AppendTextLn ("    " + "Server/DSN:" * sValue)
95303>>>>>                    Loop
95304>>>>>>
95304>>>>>                End
95304>>>>>>
95304>>>>>                If (sClient <> "" and sDriverID = MSSQLDRV_ID) Begin
95306>>>>>                    Send AppendTextLn sClient
95307>>>>>                End  
95307>>>>>>
95307>>>>>            End
95307>>>>>>
95307>>>>>        Loop
95308>>>>>>
95308>>>>>
95308>>>>>        Send AppendTextLn ""
95309>>>>>        If (bStudioLicense = False) Begin
95311>>>>>            Get MaxUsers of hoCLIHandler to iUsersMax 
95312>>>>>            Send AppendTextLn (SFormat (C_$Max_DbDriver_Licensed_User_Count, iUsersMax))
95313>>>>>        End
95313>>>>>>
95313>>>>>        Else Begin
95314>>>>>            Send AppendTextLn C_$VDF_Studio_License_Text
95315>>>>>        End
95315>>>>>>
95315>>>>>        Send Destroy of hoCLIHandler
95316>>>>>        Send Destroy of hoBtrvHandler
95317>>>>>    End_Procedure
95318>>>>>
95318>>>>>    Procedure Show_HelpFile
95320>>>>>        String sHelpFile
95320>>>>>        Integer eHelpType
95320>>>>>
95320>>>>>        If (ghoApplication <> 0) Begin
95322>>>>>            Get peHelpType Of ghoApplication To eHelpType
95323>>>>>            If (eHelpType = htHtmlHelp and ghoHtmlHelp) Begin
95325>>>>>                Get GetHelpFile Of ghoHtmlHelp To sHelpFile
95326>>>>>            End
95326>>>>>>
95326>>>>>            Else If (eHelpType = htWinHelp and Help_object_id) Begin
95329>>>>>                Get Help_filename Of Help_object_id To sHelpFile
95330>>>>>            End
95330>>>>>>
95330>>>>>            Else Begin
95331>>>>>                Move C_$ThereIsNoHelpfileDefined To sHelpFile
95332>>>>>            End
95332>>>>>>
95332>>>>>
95332>>>>>            Send AppendTextLn (SFormat (C_$HelpFile, sHelpFile))
95333>>>>>        End
95333>>>>>>
95333>>>>>    End_Procedure
95334>>>>>
95334>>>>>    Procedure Show_EnterAsTab
95336>>>>>        Boolean bEnterKeyAsTabKey
95336>>>>>        String sText
95336>>>>>
95336>>>>>        If (ghoApplication <> 0) Begin
95338>>>>>            Get pbEnterKeyAsTabKey Of ghoApplication To bEnterKeyAsTabKey
95339>>>>>            If (bEnterKeyAsTabKey) Begin
95341>>>>>                Move "True" To sText
95342>>>>>            End
95342>>>>>>
95342>>>>>            Else Begin
95343>>>>>                Move "False" To sText
95344>>>>>            End
95344>>>>>>
95344>>>>>            Send AppendTextLn (SFormat (C_$EnterKeyNavForward, sText))
95345>>>>>        End
95345>>>>>>
95345>>>>>    End_Procedure
95346>>>>>
95346>>>>>    //****************************************************************************
95346>>>>>    // $Module type: PROCEDURE
95346>>>>>    // $Module name: Add_Focus
95346>>>>>    // $Author     : VOO
95346>>>>>    // Created     : 24-09-96 @ 19:43
95346>>>>>    //
95346>>>>>    // Description
95346>>>>>    //    During activation we will remove the old information and add the newly
95346>>>>>    //    found systeminformation
95346>>>>>    //
95346>>>>>    // $Rev History
95346>>>>>    //    24-09-96  Module header created
95346>>>>>    //****************************************************************************
95346>>>>>    Procedure Add_Focus Integer hoRoot
95348>>>>>        Forward Send Add_Focus hoRoot
95350>>>>>
95350>>>>>        Send Delete_Data
95351>>>>>
95351>>>>>        Set Changed_State To False
95352>>>>>        Set Read_Only_State To True
95353>>>>>
95353>>>>>        Send Show_Registration
95354>>>>>        Send Show_Drivers
95355>>>>>        Send AppendTextLn ""
95356>>>>>
95356>>>>>        Send Show_ServicePack
95357>>>>>        If (ghoApplication <> 0) Begin
95359>>>>>            Send Show_WorkSpaceInformation
95360>>>>>            Send Show_HelpFile
95361>>>>>            Send AppendTextLn ""
95362>>>>>        End
95362>>>>>>
95362>>>>>        Else Begin
95363>>>>>            Send AppendTextLn ""
95364>>>>>        End
95364>>>>>>
95364>>>>>
95364>>>>>        If (ghoConnection <> 0) Begin
95366>>>>>            Send Show_ConnectionIdInformation
95367>>>>>        End
95367>>>>>>
95367>>>>>        
95367>>>>>        Send Show_Current_User
95368>>>>>        Send Show_Windows_Directory
95369>>>>>        Send Show_Current_Directory
95370>>>>>
95370>>>>>        // This is already shown in the workspace details,
95370>>>>>        // unless no workspace object is present:
95370>>>>>        If (ghoApplication = 0) Begin
95372>>>>>            Send Show_Filelist_Name
95373>>>>>        End
95373>>>>>>
95373>>>>>
95373>>>>>        If (ghoApplication <> 0) Begin
95375>>>>>            Send AppendTextLn ""
95376>>>>>            Send Show_EnterAsTab
95377>>>>>        End
95377>>>>>>
95377>>>>>
95377>>>>>        Send Show_Versions
95378>>>>>        Send Show_Screen_Size
95379>>>>>        Send Show_Page_Size
95380>>>>>        Send Show_Number_Format
95381>>>>>        Send Show_Date_Format
95382>>>>>        Send Show_Lock_Delay
95383>>>>>        Send Show_Lock_Timeout
95384>>>>>        Send Show_Date
95385>>>>>        Send Show_Systemresources
95386>>>>>        Send Beginning_of_Data
95387>>>>>
95387>>>>>        Set Icon to 'default.ico'
95388>>>>>    End_Procedure
95389>>>>>End_Class
