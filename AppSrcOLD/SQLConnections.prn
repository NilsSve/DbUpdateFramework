79678>>>>>// Added optional default filename as suggested by Nils
79678>>>>>Function vSelectSaveFile Global String sSupportedFileTypes String sCaptionText String sInitialFolder String sDefaultFileName Returns String
79680>>>>>  String sSelectedFile
79680>>>>>  Integer hoDialog
79680>>>>>  
79680>>>>>  Move "" To sSelectedFile
79681>>>>>  Get Create U_cvSaveAsDialog To hoDialog
79682>>>>>  If (hoDialog) Begin
79684>>>>>    //Set NoChangeDir_State Of hoDialog To True
79684>>>>>    Set Dialog_Caption    Of hoDialog To sCaptionText
79685>>>>>    Set Filter_String     Of hoDialog To sSupportedFileTypes
79686>>>>>    Set Initial_Folder    Of hoDialog To sInitialFolder
79687>>>>>    If (Num_Arguments = 4) Begin
79689>>>>>      Set File_Title        of hoDialog to sDefaultFileName
79690>>>>>    End
79690>>>>>>
79690>>>>>    Get SelectedFileName  Of hoDialog To sSelectedFile
79691>>>>>    Send Destroy Of hoDialog
79692>>>>>  End
79692>>>>>>
79692>>>>>  Function_Return sSelectedFile
79693>>>>>End_Function // vSelectSaveFile
