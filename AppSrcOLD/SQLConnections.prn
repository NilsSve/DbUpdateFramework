97679>>>>>                    Break
97680>>>>>                Case (iRetval = cx_RegKeyCreated)
97683>>>>>                    Move ("Success. The tool was added to the" * sStudioVersion *  "DataFlex Studios Tools menu.") to sText
97684>>>>>                    Break
97685>>>>>                Case (iRetval = cx_RegkeyFailed)
97688>>>>>                    Move "Failed. Could not create the registry key for adding the program to the DataFlex Studio's Tools menu." to sText
97689>>>>>                    Break
97690>>>>>                Case (iRetval = cx_RegKeyVDFKeyDoesNotExist)
97693>>>>>                    Move ("Could not find the Studio registry key. Is DataFlex Studio version" * sStudioVersion * "really installed on this machine?") to sText
