95966>>>>>>>    // if we use auto-ordering, change the order when the column changes
95966>>>>>>>    Procedure ColumnChanged Integer iOld Integer iNew
95968>>>>>>>        Boolean bAutoOrder
95968>>>>>>>        Forward Send ColumnChanged iOld iNew
95970>>>>>>>        Get pbAutoOrdering to bAutoOrder
95971>>>>>>>        If bAutoOrder Begin
95973>>>>>>>            // will be reordered in idle event
95973>>>>>>>            Set pbNeedsNewOrdering to True
95974>>>>>>>        End
95974>>>>>>>>
95974>>>>>>>    End_Procedure
95975>>>>>>>    
95975>>>>>>>
95975>>>>>>>    Procedure Add_Focus Handle hoParent Returns Integer
95977>>>>>>>        Integer eMode
95977>>>>>>>        Integer[] SelRowsIndexes
95978>>>>>>>        Set pbCanceled to True // assume cancel unless changed
95979>>>>>>>        Set pSelectedRows to SelRowsIndexes // empty
95980>>>>>>>        Get peUpdateMode to eMode
95981>>>>>>>        If (eMode<>umPromptNonInvoking) Begin
95983>>>>>>>            Send OnStoreDefaults
95984>>>>>>>        End
95984>>>>>>>>
95984>>>>>>>        Send InitializePromptList
95985>>>>>>>        Forward Send Add_Focus hoParent
95987>>>>>>>        Send LoadData
95988>>>>>>>        Set psSeedValue to ""
95989>>>>>>>    End_Procedure
95990>>>>>>>    
95990>>>>>>>    // called before the list is activated. 
95990>>>>>>>    Procedure InitializePromptList
95992>>>>>>>        Integer hoInvokingObject
95992>>>>>>>        Boolean bAutoColumn bAutoSeed 
95992>>>>>>>        Integer i iOldMode eUpdateMode
95992>>>>>>>        String sValue
95992>>>>>>>        
95992>>>>>>>        Get peUpdateMode to eUpdateMode
95993>>>>>>>        If (eUpdateMode<>umPromptNonInvoking) Begin
95995>>>>>>>            Get Focus of Desktop to hoInvokingObject
95996>>>>>>>            If (hoInvokingObject<=Desktop) Begin
95998>>>>>>>                Error DFERR_PROGRAM "Prompt list has no invoking object"
95999>>>>>>>>
95999>>>>>>>                Procedure_Return
96000>>>>>>>            End
96000>>>>>>>>
96000>>>>>>>
96000>>>>>>>            Set phoInvokingObject to hoInvokingObject
96001>>>>>>>
96001>>>>>>>            Send Prompt_Callback to hoInvokingObject Self
96002>>>>>>>            Get peUpdateMode to eUpdateMode
96003>>>>>>>        End
96003>>>>>>>>
96003>>>>>>>
96003>>>>>>>        Send ClearSearchRequest // clear the search keys
96004>>>>>>>        Set pbNeedsNewOrdering to False
96005>>>>>>>
96005>>>>>>>        Get pbAutoSeed to bAutoSeed
96006>>>>>>>
96006>>>>>>>        If (eUpdateMode=umPromptValue) Begin // else not used here intentionally
96008>>>>>>>            Get Value of hoInvokingObject to sValue
96009>>>>>>>            Set psSeedValue to sValue
96010>>>>>>>        End
96010>>>>>>>>
96010>>>>>>>        
96010>>>>>>>    End_Procedure
96011>>>>>>>    
96011>>>>>>>    // called after list is created and active. Load Data, seed list, select start column, etc.
96011>>>>>>>    Procedure LoadData
96013>>>>>>>        Handle hoInvokingObject hoDataSource hoInitialColumn
96013>>>>>>>        Integer iUpdateColumn iRows iInitialColumn iInitialOrder
96013>>>>>>>        Integer eUpdateMode
96013>>>>>>>        Boolean bAutoSeed bAutoColumn bCancel bSubFocus bAutoOrder 
96013>>>>>>>        
96013>>>>>>>        Get phoDataSource to hoDataSource
96014>>>>>>>        Get peUpdateMode to eUpdateMode
96015>>>>>>>        Get phoInvokingObject to hoInvokingObject
96016>>>>>>>        Get pbAutoSeed to bAutoSeed
96017>>>>>>>        Get piInitialColumn to iInitialColumn
96018>>>>>>>        Get piUpdateColumn to iUpdateColumn
96019>>>>>>>        Get RowCount of hoDataSource to iRows
96020>>>>>>>        
96020>>>>>>>        // We need an initial column. if you specified an initial column that will get used for the start column
96020>>>>>>>        // and the initial sort order. If you did not, which is typical, it will use the update column
96020>>>>>>>        If (iInitialColumn=-1) Begin
96022>>>>>>>            Move iUpdateColumn to iInitialColumn
96023>>>>>>>        End
96023>>>>>>>>
96023>>>>>>>        If (iInitialColumn>=0) Begin
96025>>>>>>>            Get ColumnObject iInitialColumn to hoInitialColumn
96026>>>>>>>            Set pbVisible of hoInitialColumn to True // initial column should be visible
96027>>>>>>>        End
96027>>>>>>>>
96027>>>>>>>        Send OnSeedData // find a good starting place for the row
96028>>>>>>>        Get pbFocusSubItems to bSubFocus
96029>>>>>>>        If bSubFocus Begin
96031>>>>>>>            // if column focus, which is normal, go to initialcolumn       
96031>>>>>>>            If hoInitialColumn Begin
96033>>>>>>>                Get MoveToColumnObject hoInitialColumn to bCancel
96034>>>>>>>            End
96034>>>>>>>>
96034>>>>>>>            Else Begin
96035>>>>>>>                Send MoveToFirstEnterableColumn
96036>>>>>>>            End
96036>>>>>>>>
96036>>>>>>>        End
96036>>>>>>>>
96036>>>>>>>
96036>>>>>>>    End_Procedure
96037>>>>>>>    
96037>>>>>>>    // This is only called in a successful close
96037>>>>>>>    Procedure ClosePromptList
96039>>>>>>>        Handle hoDataSource hoInvokingObject
96039>>>>>>>        Handle hmCallBack
96039>>>>>>>        Integer iRow eUpdateMode
96039>>>>>>>        Integer[] SelRowsIndexes
96040>>>>>>>        
96040>>>>>>>        Get phoDataSource to hoDataSource
96041>>>>>>>        Get phoInvokingObject to hoInvokingObject
96042>>>>>>>        
96042>>>>>>>        If (pbMultipleSelection(Self)) Begin
96044>>>>>>>            Get GetIndexesForSelectedRows to SelRowsIndexes
96045>>>>>>>        End
96045>>>>>>>>
96045>>>>>>>        Else Begin
96046>>>>>>>            Get SelectedRow of hoDataSource to iRow
96047>>>>>>>            If (iRow<>-1) Begin
96049>>>>>>>                Move iRow to SelRowsIndexes[0]
96050>>>>>>>            End
96050>>>>>>>>
96050>>>>>>>        End
96050>>>>>>>>
96050>>>>>>>        
96050>>>>>>>        Set pbCanceled to False
96051>>>>>>>        Set pSelectedRows to SelRowsIndexes
96052>>>>>>>        
96052>>>>>>>        Get peUpdateMode to eUpdateMode
96053>>>>>>>        // if non-invoking there is by definition, no move value out
96053>>>>>>>        If (eUpdateMode<>umPromptNonInvoking) Begin
96055>>>>>>>            
96055>>>>>>>            If (eUpdateMode=umPromptValue) Begin
96057>>>>>>>                Send OnMoveValueOutByValue
96058>>>>>>>            End
96058>>>>>>>>
96058>>>>>>>            Else If (eUpdateMode=umPromptCustom) Begin
96061>>>>>>>                Send OnMoveValueOutByCustom
96062>>>>>>>            End
96062>>>>>>>>
96062>>>>>>>                Get phmPromptUpdateCallback to hmCallBack
96063>>>>>>>                If hmCallBack Begin
96065>>>>>>>                    Send hmCallBack of hoInvokingObject Self
96066>>>>>>>                End
96066>>>>>>>>
96066>>>>>>>        End
96066>>>>>>>>
96066>>>>>>>
96066>>>>>>>        Send Close_Panel
96067>>>>>>>    End_Procedure
96068>>>>>>>
96068>>>>>>>    // augment to send OnRestoreDefaults.
96068>>>>>>>    Procedure Release_Focus
96070>>>>>>>        Integer eUpdateMode
96070>>>>>>>        Get peUpdateMode to eUpdateMode
96071>>>>>>>        Forward Send Release_Focus
96073>>>>>>>        If (eUpdateMode<>umPromptNonInvoking) Begin
96075>>>>>>>            Send OnRestoreDefaults
96076>>>>>>>        End
96076>>>>>>>>
96076>>>>>>>    End_Procedure
96077>>>>>>>    
96077>>>>>>>    Function SelectedRowIds Returns RowID[]
96079>>>>>>>        RowID[] SelectedRowids
96080>>>>>>>        Integer[] SelectedRows
96081>>>>>>>        Integer i iRows
96081>>>>>>>        Handle hoDataSource
96081>>>>>>>        Get phoDataSource to hoDataSource
96082>>>>>>>        Get pSelectedRows to SelectedRows
96083>>>>>>>        Move (SizeOfArray(SelectedRows)) to iRows
96084>>>>>>>        For i from 0 to (iRows-1)
96090>>>>>>>>
96090>>>>>>>            Get RowTag of hoDataSource SelectedRows[i] to SelectedRowIds[i]
96091>>>>>>>        Loop
96092>>>>>>>>
96092>>>>>>>        Function_Return SelectedRowids
96093>>>>>>>    End_Function
96094>>>>>>>
96094>>>>>>>    Function SelectedColumnValues Integer iCol Returns String[]
96096>>>>>>>        String[] SelectedValues
96097>>>>>>>        Integer[] SelectedRows
96098>>>>>>>        Integer i iRows
96098>>>>>>>        Handle hoCol
96098>>>>>>>        Get ColumnObject iCol to hoCol
96099>>>>>>>        Get pSelectedRows to SelectedRows
96100>>>>>>>        Move (SizeOfArray(SelectedRows)) to iRows
96101>>>>>>>        For i from 0 to (iRows-1)
96107>>>>>>>>
96107>>>>>>>            Get RowValue of hoCol SelectedRows[i] to SelectedValues[i]
96108>>>>>>>        Loop
96109>>>>>>>>
96109>>>>>>>        Function_Return SelectedValues
96110>>>>>>>    End_Function
96111>>>>>>>
96111>>>>>>>    Procedure Ok Returns Integer
96113>>>>>>>        Send ClosePromptList
