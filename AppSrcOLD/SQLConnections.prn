88852>>>    Function SqlUtilEnumerateLoggedInUsers String sDriverID String sDatabase Returns tSQLLoggedInUser[]
88854>>>        tSQLLoggedInUser[] SQLLoggedInUser
88854>>>        tSQLLoggedInUser[] SQLLoggedInUser
88855>>>        String[] sUsers sPrograms
88857>>>        String sSelect 
88857>>>        Integer iSize iCount
88857>>>        
88857>>>        Case Begin
88857>>>            Case (sDriverID = MSSQLDRV_ID)
88859>>>                Move ("SELECT RTRIM(SP.nt_username) AS Inlog, RTRIM(SP.program_name) as Programma from master.dbo.sysprocesses SP INNER JOIN master.dbo.sysdatabases SD ON SP.dbid = SD.dbid WHERE (SP.nt_username <> '') and (SP.nt_username <> 'SYSTEM') and (SD.name = '" ;                + sDatabase + "') ORDER by Inlog") to sSelect
88860>>>                Get SqlEnumerateEsqlDAW sSelect 1 to sUsers
88861>>>                Get SqlEnumerateEsqlDAW sSelect 2 to sPrograms
88862>>>                Case Break
88863>>>            Case (sDriverID = SQLFLEX)
88866>>>                Move ("SELECT RTRIM(SP.nt_username) AS Inlog, RTRIM(SP.program_name) as Programma from master.dbo.sysprocesses SP INNER JOIN master.dbo.sysdatabases SD ON SP.dbid = SD.dbid WHERE (SP.nt_username <> '') and (SP.nt_username <> 'SYSTEM') and (SD.name = '" ;                + sDatabase + "') ORDER by Inlog") to sSelect
88867>>>                Get SqlEnumerateEsqlMertech sSelect 1 to sUsers
88868>>>                Get SqlEnumerateEsqlMertech sSelect 2 to sPrograms
88869>>>                Case Break                 
88870>>>            Case Else
88870>>>                Error DFERR_PROGRAM ("Not implemented yet for this driver (" + sDriverID + ")")
88871>>>>
88871>>>        Case End
88871>>>        
88871>>>        Move (SizeOfArray(sUsers)) to iSize
88872>>>        Decrement iSize
88873>>>        For iCount from 0 to iSize
88879>>>>
88879>>>            Move sUsers[iCount]    to SQLLoggedInUser[iCount].sUser
88880>>>            Move sPrograms[iCount] to SQLLoggedInUser[iCount].sProgram
88881>>>        Loop
88882>>>>
88882>>>        
88882>>>        Function_Return SQLLoggedInUser
88883>>>    End_Function 
