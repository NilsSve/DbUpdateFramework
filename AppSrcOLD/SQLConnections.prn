89710>>>    Function _SqlProperTableName String sTableName Returns String
89712>>>        String sVal sSchema sDriverID sValue
89712>>>        Handle hTable  
89712>>>        Integer iDbType
89712>>>        
89712>>>        If (Trim(sTableName) = "") Begin
89714>>>            Function_Return ""
89715>>>        End
89715>>>>
89715>>>
89715>>>        Get psDriverID to sDriverID
89716>>>        Get piDbType   to iDbType
89717>>>        If (iDbType = EN_dbTypeOracle) Begin
89719>>>            Get psUserID to sSchema
89720>>>            // Not sure about this uppercasing but it seems like Oracle wants that?
89720>>>            Move (Uppercase(sSchema)) to sSchema
89721>>>            Move ('"' + sSchema + '"."' + sTableName + '"') to sTableName
89722>>>            Function_Return sTableName
89723>>>        End 
89723>>>>
89723>>>        If (iDbType = EN_DbTypeMySQL) Begin
89725>>>            Get psDatabase to sVal
89726>>>            Move (sVal + "." + sTableName) to sTableName
89727>>>            Function_Return sTableName
89728>>>        End 
89728>>>>
89728>>>        If (iDbType = EN_DbTypePostgre) Begin
89730>>>            Move ('"' + sTableName + '"') to sTableName
89731>>>            Function_Return sTableName
89732>>>        End
89732>>>>
89732>>>        
89732>>>        Get psSchema to sSchema   
89733>>>        If (sSchema = "") Begin
89735>>>            Get _SqlFindKeyWord CI_SQLDBO to sSchema
89736>>>        End
89736>>>>
89736>>>
89736>>>        Move (Uppercase(sTableName)) to sVal
89737>>>        If (not(sVal contains (sSchema + "."))) Begin  
89739>>>            If (iDbType = EN_dbTypeDB2) Begin
89741>>>                Move (Lowercase(sSchema) + "." + sTableName) to sTableName
89742>>>            End 
89742>>>>
89742>>>            Else Begin
89743>>>                Move (sSchema + "." + sTableName) to sTableName
89744>>>            End
89744>>>>
89744>>>        End    
89744>>>>
89744>>>
89744>>>        Function_Return sTableName
89745>>>    End_Function
89746>>>    
89746>>>    // SQL column names can be case-sensitive. This function is used to check that
89746>>>    // the passed sFieldName has the correct spelling.                            
89746>>>    // Used with Embedded SQL statement calls.
89746>>>    // If the spelling or fieldname doesn't exist, the return value is "" (blank).
89746>>>    Function _SqlFindColumnName String sTableName String sColumnName Returns String
89748>>>        String sRetval sValue sConnectionString sDriverID 
89748>>>        String[] sColumnNamesArray
89749>>>        Integer iCount iColumns
89749>>>
89749>>>        Move "" to sRetval
89750>>>        Get psDriverID to sDriverID
89751>>>        Get SqlUtilEnumerateColumns sDriverID sTableName to sColumnNamesArray
89752>>>        Move (SizeOfArray(sColumnNamesArray)) to iColumns
89753>>>        Decrement iColumns
89754>>>        
89754>>>        For iCount from 0 to iColumns
89760>>>>
89760>>>            Move sColumnNamesArray[iCount] to sValue
89761>>>            If (Uppercase(sColumnName) = Uppercase(sValue)) Begin
89763>>>                Move sValue to sRetval
89764>>>                Move iColumns to iCount // We're done.
89765>>>            End
89765>>>>
89765>>>        Loop                           
89766>>>>
89766>>>        
89766>>>        Function_Return sRetval
89767>>>    End_Function
