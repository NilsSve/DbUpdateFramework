95926>>>>>>>    // augment to popup a search window when allowed
95926>>>>>>>    Procedure OnComKeyDown Short ByRef llKeyCode Short llShift
95928>>>>>>>        Boolean bSubFocus bAutoSearch bChar
95928>>>>>>>        Integer iVal
95928>>>>>>>        
95928>>>>>>>        Get pbFocusSubItems to bSubFocus
95929>>>>>>>        Get pbAutoSearch to bAutoSearch
95930>>>>>>>        Forward Send OnComKeyDown llKeyCode llShift
95932>>>>>>>        If (bAutoSearch and not(bSubFocus)) Begin
95934>>>>>>>            If ((llShift iand 6)=0) Begin // skip alt and ctrl
95936>>>>>>>                Get GetVKeyToAnsi llKeyCode llShift to iVal
95937>>>>>>>                Move (iVal<>0) to bChar
95938>>>>>>>            End
95938>>>>>>>>
95938>>>>>>>            If bChar Begin
95940>>>>>>>                // this can get called multiple times before a search dialog pops up
95940>>>>>>>                Send AddToSearchKeys llKeyCode llShift
95941>>>>>>>            End
95941>>>>>>>>
95941>>>>>>>        End
95941>>>>>>>>
95941>>>>>>>    End_Procedure
95942>>>>>>>    
95942>>>>>>>    Procedure OnComRequestEdit Variant llRow Variant llColumn Variant llItem Boolean ByRef llCancel
95944>>>>>>>        Boolean bAutoSearch
