86690>>>    // This will update connection settings of the cCLIHandler object with that passed struct values.
86690>>>    Procedure UpdateConnectionString tSQLConnection SQLConnection
86692>>>        String sRetval sDriverID sConnectionID sConnectionString sServer sDatabase sUserID sPassword
86692>>>        Boolean bTrusted bSilent  
86692>>>        Integer iConnOptions
86692>>>        
86692>>>        Move SQLConnection.sDriverID     to sDriverID
86693>>>        Move SQLConnection.sConnectionID to sConnectionID
86694>>>        Move SQLConnection.sServer       to sServer
86695>>>        Move SQLConnection.sDatabase     to sDatabase
86696>>>        Move SQLConnection.bTrusted      to bTrusted
86697>>>        Move SQLConnection.sUserID       to sUserID
86698>>>        Move SQLConnection.sPassword     to sPassword  
86699>>>        Move SQLConnection.bSilentLogin  to bSilent
86700>>>        
86700>>>        // Note that this message will first delete the current ConnectionID if it exists; which is needed by the cCLIHandler logic.
86700>>>        Send CreateSQLConnection sDriverID sConnectionID sServer sDatabase bTrusted sUserID sPassword bSilent
86701>>>        
86701>>>    End_Procedure
86702>>>
86702>>>    // Called when the object is constructed.
86702>>>    // It will check the psDriverID for a ConnectionID and save it
86702>>>    // as psConnectionID property. It is later used whenever a login to
86702>>>    // the database is needed.
86702>>>    Procedure AutoSetConnectionID
86704>>>        String sConnectionID sValue sDriverID sConnectionString
86704>>>        Integer iDriver iNumConn iConn iConnOptions iRetval
86704>>>        Handle hoCLI                 
86704>>>        Boolean bOK bSilent bMertechDriver
86704>>>        
86704>>>        Get pbSilentLogin      to bSilent
86705>>>        Get psConnectionID     to sConnectionID                            
86706>>>        Get psConnectionString to sConnectionString
86707>>>        // Get the driver Connection ID string & set the psConnectionString property.
86707>>>        Get psDriverID to sDriverID
86708>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
86709>>>        If (bOK = False) Begin
86711>>>            Procedure_Return              
86712>>>        End                 
86712>>>>
86712>>>        
86712>>>        // Mertech drivers can't use connection ID's.
86712>>>        Get IsMertechDriver sDriverID to bMertechDriver    
86713>>>        If (bMertechDriver = True) Begin         
86715>>>            // This ensures that the correct Server & Database attributes are set both for 
86715>>>            // embedded SQL calls and "normal" database commands like e.g. "Open".
86715>>>            Get _MertechSQLManagerHandle to hoCLI
86716>>>            Procedure_Return
86717>>>        End
86717>>>>
86717>>>        
86717>>>        Get DriverIndex sDriverID          to iDriver
86718>>>        // If driver not loaded; load it.
86718>>>        If (iDriver = 0) Begin
86720>>>            Load_Driver sDriverID
86721>>>            Get DriverIndex sDriverID      to iDriver
86722>>>        End                      
86722>>>>
86722>>>        // This shouldn't be possible; unless the driver.dll file is missing or something...
86722>>>        If (iDriver = 0) Begin
86724>>>            Error DFERR_PROGRAM ("The database driver could not be loaded! Connection to database failed." * sDriverID)
86725>>>>
86725>>>            Procedure_Return
86726>>>        End
86726>>>>
86726>>>
86726>>>        Get Create (RefClass(cCLIHandler)) to hoCLI
86727>>>        Set psDriverID of hoCLI            to sDriverID   
86728>>>        // Delete the connection first; in case it exists
86728>>>//        Get DeleteConnectionID of hoCLI sConnectionID -1 to iRetval
86728>>>        Get CreateConnectionID of hoCLI sConnectionID sConnectionString bSilent to iRetval
86729>>>
86729>>>        Send Destroy of hoCLI 
86730>>>    End_Procedure
86731>>>
86731>>>    // Returns the handle of the Mertech SQL handler.
86731>>>    // It also ensures that the correct Server & Database attributes are set both for 
86731>>>    // embedded SQL calls and "normal" database commands like e.g. "Open".  
86731>>>    // Note: This does _not_ return a proper CLI handler handle as it is not in this class.
86731>>>    //       So the return value is of no use! But we don't need the handle for this class.
86731>>>    Function _MertechSQLManagerHandle Returns Handle
86733>>>        Handle hoSQLHandler
86733>>>        String sDriverID sServer sDatabase
86733>>>        
86733>>>        Move 0 to hoSQLHandler
86734>>>        Get psDriverID to sDriverID       
86735>>>        Get psServer   to sServer
86736>>>        Get psDatabase to sDatabase
86737>>>        // This command is used to set the server to be used when opening tables   
86737>>>        SET_CURRENT_SQL_SERVER to sServer  
86756>>>>
86756>>>        // This command is used to specify which server to use for embedded SQL statements,
86756>>>        // but it has been constructed rather studidly as only constants and not variables
86756>>>        // are allowed...
86756>>>        If (sDriverID = MDSPgSQL) Begin
86758>>>            SET_CURRENT_SQL_SERVER_CONNECTION of MDSPgSQL to sServer
86774>>>        End
86774>>>>
86774>>>        If (sDriverID = MDSMySQL) Begin
86776>>>            SET_CURRENT_SQL_SERVER_CONNECTION of MDSMySQL to sServer
86792>>>        End
86792>>>>
86792>>>        If (sDriverID = ORAFLEX) Begin
86794>>>            SET_CURRENT_SQL_SERVER_CONNECTION of ORAFLEX to sServer
86810>>>        End
86810>>>>
86810>>>        If (sDriverID = SQLFLEX) Begin
86812>>>            SET_CURRENT_SQL_SERVER_CONNECTION of SQLFLEX to sServer
86828>>>        End
86828>>>>
86828>>>        
86828>>>        // This command is used to specify which database is used for embedded SQL statements.
86828>>>        SQL_USE_DATABASE sDatabase
86842>>>>
86842>>>        SET_DATABASE_NAME to sDatabase
86856>>>>
86856>>>        
86856>>>        // Can't have this here because the property is defined for the cDbUpdateFunctionLibrary class,
86856>>>        // which object may or may not have been created at this point. So don't use the return
86856>>>        // value for this function!
86856>>>        //Get phoSQLManagerMT to hoSQLHandler  
86856>>>        
86856>>>        Function_Return hoSQLHandler
86857>>>    End_Function
