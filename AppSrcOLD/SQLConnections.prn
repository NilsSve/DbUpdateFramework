98232>>>        Procedure AddConnection tDataSourceRow TheRow 
98235>>>            Integer iSize iCount
98235>>>            Handle hoDataSource
98235>>>            tDataSourceRow[] TheData
98235>>>            tDataSourceRow[] TheData
98236>>>            Boolean bEnabled
98236>>>
98236>>>            Get phoDataSource to hoDataSource
98237>>>            Get DataSource    of hoDataSource to TheData
98238>>>
98238>>>            Move (SizeOfArray(TheData)) to iSize
98239>>>            Move (TheRow.sValue[piColumnid(oActive_Col(Self))]) to bEnabled
98240>>>            If (bEnabled = True) Begin
98242>>>                // Then bEnabled state have changed; deactivate all current rows.
98242>>>                For iCount from 0 to (iSize -1)
98248>>>>
98248>>>                    Move False to TheData[iCount].sValue[piColumnId(oActive_Col(Self))]
98249>>>                Loop
98250>>>>
98250>>>            End
98250>>>>
98250>>>
98250>>>            Move TheRow to TheData[iSize]
98251>>>
98251>>>            // Initialize Grid with new data
98251>>>            Send InitializeData TheData True
98252>>>            Move (SizeOfArray(TheData)) to iSize
98253>>>            Send MoveToLastRow
98254>>>
98254>>>            Set psFooterText of oConnectionString_Col to ("Number of connections:" * String(iSize))
98255>>>        End_Procedure
98256>>>
98256>>>        Procedure UpdateConnection tDataSourceRow TheRow
98259>>>            Integer iRow iSize iCount
98259>>>            Handle hoDataSource
98259>>>            tDataSourceRow[] TheData
98259>>>            tDataSourceRow[] TheData
98260>>>            String sValue
98260>>>            Boolean bEnabled
98260>>>
98260>>>            Get phoDataSource to hoDataSource
98261>>>            Get SelectedRow of hoDataSource to iRow
98262>>>            If (iRow <> -1) Begin
98264>>>                Get DataSource of hoDataSource to TheData
98265>>>
98265>>>                // If bEnabled state has changed; deactivate all rows.
98265>>>                Move (TheRow.sValue[piColumnId(oActive_Col(Self))]) to bEnabled
98266>>>                If (bEnabled = True) Begin
98268>>>                    Move (SizeOfArray(TheData)) to iSize
98269>>>                    Decrement iSize
98270>>>                    For iCount from 0 to iSize
98276>>>>
98276>>>                        Move False to TheData[iCount].sValue[piColumnId(oActive_Col(Self))]
98277>>>                    Loop
98278>>>>
98278>>>                End
98278>>>>
98278>>>
98278>>>                Move TheRow to TheData[iRow]
98279>>>            End
98279>>>>
98279>>>
98279>>>            // Initialize Grid with new data
98279>>>            Send ReInitializeData TheData True
98280>>>            Move (SizeOfArray(TheData)) to iSize
98281>>>            Set psFooterText of oConnectionString_Col to ("Number of connections:" * String(iSize))
98282>>>        End_Procedure
