92111>>>    // Returns a struct array with all data types for the passed driver & dbtype.
92111>>>    Function UtilEnumerateColumnTypes String sDriverID Integer iDbType Returns tColumnType[]
92113>>>        tColumnType[] ColumnType               
92113>>>        tColumnType[] ColumnType               
92114>>>            
92114>>>        Case Begin
92114>>>            Case (iDbType = EN_dbTypeDataFlex)  
92116>>>                Get _UtilEnumerateDataFlexTypes to ColumnType
92117>>>                Case Break
92118>>>                
92118>>>            Case (iDbType = EN_DbTypeDB2)
92121>>>                Get _UtilEnumerateDB2Types to ColumnType
92122>>>                Case Break
92123>>>                
92123>>>            Case (iDbType = EN_DbTypeMSSQL)
92126>>>                Get _UtilEnumerateMSSQLTypes sDriverID to ColumnType
92127>>>                Case Break
92128>>>            
92128>>>            Case (sDriverID = MDSMySQL)            
92131>>>                Get _UtilEnumerateMySQLTypes to ColumnType
92132>>>                Case Break
92133>>>            
92133>>>            Case (sDriverID = ORAFLEX)
92136>>>                Get _UtilEnumerateOracleTypes to ColumnType
92137>>>                Case Break
92138>>>
92138>>>            Case (sDriverID = MDSPgSQL)   
92141>>>                Get _UtilEnumeratePostgreSQLTypes to ColumnType
92142>>>                Case Break
92143>>>        Case End
92143>>>        
92143>>>        Function_Return ColumnType
92144>>>    End_Function
92145>>>
92145>>>    // DataFlex Embedded Database Data Types:
92145>>>    // Helper function for UtilEnumerateColumnTypes
92145>>>    Function _UtilEnumerateDataFlexTypes Returns tColumnType[]
92147>>>        tColumnType[] ColumnType               
92147>>>        tColumnType[] ColumnType               
92148>>>        Integer i
92148>>>        
92148>>>        Move DF_ASCII           to ColumnType[i].iType
92149>>>        Move "ASCII"            to ColumnType[i].sType
92150>>>        Move DF_ASCII           to ColumnType[i].iDataFlexType
92151>>>        Move "ASCII"            to ColumnType[i].sDataFlexType
92152>>>        Move "254"              to ColumnType[i].sPrecision
92153>>>        Increment i 
92154>>>        
92154>>>        Move DF_BCD             to ColumnType[i].iType
92155>>>        Move "Numeric"          to ColumnType[i].sType
92156>>>        Move DF_BCD             to ColumnType[i].iDataFlexType
92157>>>        Move "Numeric"          to ColumnType[i].sDataFlexType
92158>>>        Move "14.8"             to ColumnType[i].sPrecision
92159>>>        Increment i             
92160>>>        
92160>>>        Move DF_DATE            to ColumnType[i].iType
92161>>>        Move "Date"             to ColumnType[i].sType
92162>>>        Move DF_DATE            to ColumnType[i].iDataFlexType
92163>>>        Move "Date"             to ColumnType[i].sDataFlexType
92164>>>        Move "6.0"              to ColumnType[i].sPrecision 
92165>>>        Move True               to ColumnType[i].bFixedSize
92166>>>        Increment i 
92167>>>        
92167>>>        Move DF_TEXT            to ColumnType[i].iType
92168>>>        Move "Text"             to ColumnType[i].sType
92169>>>        Move DF_TEXT            to ColumnType[i].iDataFlexType
92170>>>        Move "Text"             to ColumnType[i].sDataFlexType
92171>>>        Move "16384"            to ColumnType[i].sPrecision
92172>>>        Increment i 
92173>>>        
92173>>>        Move DF_BINARY          to ColumnType[i].iType
92174>>>        Move "Binary"           to ColumnType[i].sType
92175>>>        Move DF_BINARY          to ColumnType[i].iDataFlexType
92176>>>        Move "Binary"           to ColumnType[i].sDataFlexType
92177>>>        Move "16384"            to ColumnType[i].sPrecision
92178>>>        Increment i             
92179>>>        
92179>>>        Move DF_DATETIME        to ColumnType[i].iType
92180>>>        Move "DateTime"         to ColumnType[i].sType
92181>>>        Move DF_DATETIME        to ColumnType[i].iDataFlexType
92182>>>        Move "DateTime"         to ColumnType[i].sDataFlexType
92183>>>        Move "23"               to ColumnType[i].sPrecision
92184>>>        Move True               to ColumnType[i].bFixedSize
92185>>>        Increment i 
92186>>>        
92186>>>        Move DF_OVERLAP         to ColumnType[i].iType
92187>>>        Move "Overlap"          to ColumnType[i].sType
92188>>>        Move DF_OVERLAP         to ColumnType[i].iDataFlexType
92189>>>        Move "Overlap"          to ColumnType[i].sDataFlexType
92190>>>        Move "0.0"              to ColumnType[i].sPrecision 
92191>>>        
92191>>>        Function_Return ColumnType
92192>>>    End_Function
