95390>>>>>//****************************************************************************
95390>>>>>// $Module type: OBJECT
95390>>>>>// $Module name: Sysinfo_Dialog
95390>>>>>// $Author     : VOO
95390>>>>>// Created     : 24-09-96 @ 18:47
95390>>>>>//
95390>>>>>// Description
95390>>>>>//    This object shows the systeminformation on the screen
95390>>>>>//
95390>>>>>// $Rev History
95390>>>>>//    24-09-96  Module header created
95390>>>>>//****************************************************************************
95390>>>>>Class SysInfoDialog is a ModalPanel
95391>>>>>    Procedure Construct_Object
95393>>>>>        Forward Send Construct_Object
95395>>>>>
95395>>>>>        Set Label to C_$SystemInformation
95396>>>>>        Set Size to 140 267
95397>>>>>        Set Locate_Mode to CENTER_ON_PARENT
95398>>>>>        Set Border_Style to Border_Thick
95399>>>>>        Set Sysmenu_Icon to False
95400>>>>>
95400>>>>>        // "+1" will make the panel to paint correctly.
95400>>>>>        Set piMinSize to (Hi(Size(Self))) (Low(Size(Self)) +1)
95401>>>>>
95401>>>>>        // 2014-09-14 NGS
95401>>>>>        // Added a container object around the cTexteditor
95401>>>>>        // object to get a border around the text.
95401>>>>>        Object oSysinfoDisplayContainer is a Container3d
95403>>>>>            Set Location to 2 4
95404>>>>>            Set Size to 110 255
95405>>>>>            Set Border_Style to Border_ClientEdge
95406>>>>>            Set Color to clWhite
95407>>>>>            Set peAnchors to anAll
95408>>>>>
95408>>>>>            Object oSysinfoDisplay is a SysInfoDisplay
95410>>>>>            End_Object
95411>>>>>
95411>>>>>        End_Object
95412>>>>>
95412>>>>>        Object oCloseButton is a Button
95414>>>>>            Set Label to C_$Close
95415>>>>>            Set Location to 120 210
95416>>>>>            Set Message item 0 to msg_Close_Panel
95417>>>>>            Set Default_State To True
95418>>>>>            // In case someone likes to make the AboutDialog's Border_Style to thick,
95418>>>>>            // and changes its peAnchors, we might as well prepare this object
95418>>>>>            // for that situation.
95418>>>>>            Set peAnchors to anBottomRight
95419>>>>>        End_Object
95420>>>>>
95420>>>>>        Object oCopyButton is a cCopyEditorContentButton
95422>>>>>            On_Item C_$Copy Send CopyToWindowsClipboard
95423>>>>>            Set Size to 14 50
95424>>>>>            Set Location to 120 158
95425>>>>>            // In case someone wants to set the AboutDialog's Border_Style to thick,
95425>>>>>            // we might as well prepare the object for it.
95425>>>>>            Set peAnchors to anBottomRight
95426>>>>>            Set phoEditorHandle to (oSysinfoDisplay(Self))
95427>>>>>        End_Object
95428>>>>>
95428>>>>>        On_Key kCancel Send Close_Panel
95429>>>>>    End_Procedure
95430>>>>>
95430>>>>>    Procedure Page Integer iPageObject
95432>>>>>        Handle hMenu
95432>>>>>        Integer iPrevState
95432>>>>>
95432>>>>>        Forward Send Page iPageObject
95434>>>>>
95434>>>>>        // Ok, this seems to have been fixed in VDF 17.1!
95434>>>>>        //
95434>>>>>    End_Procedure
95435>>>>>
95435>>>>>End_Class
95436>>>>>
95436>>>>>Class cAboutEdit is an cRichEdit
95437>>>>>    Procedure Construct_Object
95439>>>>>        Forward Send Construct_Object
95441>>>>>
95441>>>>>        Set Size to 57 153
95442>>>>>        Set Location to 8 60
95443>>>>>
95443>>>>>        Set Read_Only_State to True
95444>>>>>        Set Skip_State to True
95445>>>>>        // Font size is calculated in "Twips", which are 1/1440 of an inch,
95445>>>>>        // or 1/20 of a printer's point.
95445>>>>>//        Set piFontSize    to (9 * 20)
95445>>>>>        Set piRightMargin to (0.1 * 1440)
95446>>>>>        Set Border_Style  to Border_None
95447>>>>>    End_Procedure
95448>>>>>
95448>>>>>    // Adds a line of text to the edit object
95448>>>>>    Procedure Add_Line String sVal
95450>>>>>        String sText
95450>>>>>        Address aAddress
95450>>>>>        Get paValue to aAddress
95451>>>>>        Move aAddress to sText
95452>>>>>        Move (sText + String(sVal)) to sVal
95453>>>>>        GetAddress of sVal to aAddress
95454>>>>>        Set paValue to aAddress
95455>>>>>    End_Procedure
95456>>>>>
95456>>>>>    // Compared to Add_Line above, this adds an extra empty line after the passed value.
95456>>>>>    // Note that we use the paValue interface,
95456>>>>>    // because the object isn't paged yet when we add the
95456>>>>>    // values and the COM edit object needs to be paged
95456>>>>>    // for the "Set Value" interface to be used.
95456>>>>>    Procedure Add_LineLn String sVal
95458>>>>>        String sText
95458>>>>>        Address aAddress
95458>>>>>        Get paValue to aAddress
95459>>>>>        Move aAddress to sText
95460>>>>>        Move (sText + String(sVal) + Character(10) + Character(13)) to sVal
95461>>>>>        GetAddress of sVal to aAddress
95462>>>>>        Set paValue to aAddress
95463>>>>>    End_Procedure
95464>>>>>
95464>>>>>    Procedure OnLinkClicked Integer iPositionStart Integer iPositionEnd
95466>>>>>        String sLinkText
95466>>>>>        Get TextRange iPositionStart iPositionEnd to sLinkText
95467>>>>>        Send Show_HomePage sLinkText
95468>>>>>    End_Procedure
95469>>>>>
95469>>>>>End_Class
