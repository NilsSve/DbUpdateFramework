93299>>>    // For debugging purposes. To print Sql statements as they are build...
93299>>>    Procedure DebugPrint String sStmt String sFileName
93301>>>        Integer iCh
93301>>>        Get Seq_Append_Output_Channel sFileName to iCh
93302>>>            Write channel iCh sStmt  
93304>>>        Send Seq_Close_Channel iCh
93305>>>    End_Procedure
93306>>>        
93306>>>    // Returns the integer number for the passed Driver ID that is 
93306>>>    // needed by some database API calls.
93306>>>    Function DriverIndex String sDriverID Returns Integer
93308>>>        String  sCurrentDriver
93308>>>        Integer iNumberOfDrivers iDriver iCount
93308>>>    
93308>>>        Move 0 to iDriver
93309>>>    
93309>>>        Get_Attribute DF_NUMBER_DRIVERS to iNumberOfDrivers
93312>>>        for iCount from 1 to iNumberOfDrivers
93318>>>>
93318>>>    
93318>>>            Get_Attribute DF_DRIVER_NAME of iCount to sCurrentDriver
93321>>>            If ( Uppercase(sCurrentDriver) = Uppercase(sDriverID) ) Begin
93323>>>                Move iCount to iDriver
93324>>>            End
93324>>>>
93324>>>        Loop
93325>>>>
93325>>>        
93325>>>        // In case it was not found, it wasn't loaded so we do that now.
93325>>>        If (iDriver = 0) Begin
93327>>>            Move False to Err
93328>>>            Load_Driver sDriverID
93329>>>            If (Err = False) Begin
93331>>>                Move 1 to iDriver
93332>>>            End
93332>>>>
93332>>>        End
93332>>>>
93332>>>    
93332>>>        Function_Return iDriver
93333>>>    End_Function 
93334>>>    
93334>>>    // Scans to see if all tables can be opened exclusivly. I.e. that nobody else is running the application.
93334>>>    // Returns: False if nobody else is running
93334>>>    //          True if at least one table is open by another process (e.g. another user is running the application) 
93334>>>    // N.B! Only works for Embedded DataFlex Tables! It will _not_ work for Sql tables because; these
93334>>>    //      tables are not locked as DataFlex tables are.
93334>>>    Function IsDatabaseInUse Returns Boolean
93336>>>        Handle  hTable
93336>>>        Integer iTemp
93336>>>        String  sRootName sOrgOpenPath sOrgFileList
93336>>>        Boolean bOpen bErr bAlias bOK bIsSQLTable
93336>>>
93336>>>        Get AutoConnectionIDLogin to bOK
93337>>>        Move 0 to hTable
93338>>>        Get_Attribute DF_FILE_NEXT_USED of hTable to hTable
93341>>>        Move False to bErr
93342>>>        Send Ignore_Error of Error_Object_Id DFERR_FILE_ACCESS_VIOLATION
93343>>>
93343>>>        Repeat
93343>>>>
93343>>>            Get_Attribute DF_FILE_ROOT_NAME of hTable to sRootName
93346>>>            
93346>>>            // This test is only applicable for DataFlex embedded tables; so skip test if driver based table.
93346>>>            Get UtilTableIsSQLByRootName sRootName to bIsSQLTable
93347>>>            Move False to bOpen
93348>>>            
93348>>>            // Don't bother about FlexErrs (Table 50)
93348>>>            If (bIsSQLTable = False and hTable <> 0 and hTable <> 50) Begin
93350>>>                Set Error_Report_Mode to DUF_ERROR_NO_REPORT
93351>>>                Open hTable 
93353>>>                Get_Attribute DF_FILE_OPENED of hTable to bOpen
93356>>>                Set Error_Report_Mode to DUF_ERROR_REPORT
93357>>>                If (bOpen = True) Begin                        
93359>>>                    // We cannot open an Alias file exclusive as it will generate an error (4177 - "File in use")
93359>>>                    Get UtilTableIsAlias hTable to bAlias
93360>>>                    If (bAlias = False) Begin
93362>>>                        Open hTable mode DF_EXCLUSIVE   
93364>>>                        Get_Attribute DF_FILE_OPENED of hTable to bOpen
93367>>>                        If (bOpen = False) Begin
93369>>>                            Move True to bErr
93370>>>                        End
93370>>>>
93370>>>                    End
93370>>>>
93370>>>                End
93370>>>>
93370>>>            End
93370>>>>
93370>>>            Get_Attribute DF_FILE_NEXT_USED of hTable to hTable
93373>>>            If (bOpen = False) Break
93376>>>        Until (not(hTable))
93378>>>
93378>>>        Send Trap_Error of Error_Object_Id DFERR_FILE_ACCESS_VIOLATION
93379>>>        Move False to Err
93380>>>        
93380>>>        Function_Return bErr
93381>>>    End_Function  
93382>>>    
93382>>>    // Checks if the passed connection id exists in the CLI interface.
93382>>>    // This might be needed by API-methods when a connection id is to be used and
93382>>>    // the connection id hasn't been established with the driver's CLI interface.
93382>>>    // NOTE: Only applicable for DAW drivers.
93382>>>    Function IsConnectionID String sConnectionID String sDriverID Returns Boolean
93384>>>        String sID 
93384>>>        Integer iDriver iNumConn iCount
93384>>>        Handle hoCLI                                            
93384>>>        Boolean bOK
93384>>>        
93384>>>        Get IsDAWSQLDriver sDriverID to bOK
93385>>>        If (bOK = False) Begin
93387>>>            Error DFERR_PROGRAM "Connection ID's can only be used with DAW drivers (not Mertech)."
93388>>>>
93388>>>            Function_Return False
93389>>>        End
93389>>>>
93389>>>        
93389>>>        Move False to bOK
93390>>>        Get phoCLIHandler to hoCLI 
93391>>>        If (hoCLI <> 0) Begin
93393>>>            Set psDriverID of hoCLI to sDriverID
93394>>>            Get DriverIndex of hoCLI sDriverID to iDriver
93395>>>            
93395>>>            // If driver not loaded; load it.
93395>>>            If (iDriver = 0) Begin
93397>>>                Load_Driver sDriverID
93398>>>                Get DriverIndex sDriverID to iDriver
93399>>>            End                      
93399>>>>
93399>>>            If (iDriver <> 0) Begin
93401>>>                Get_Attribute DF_DRIVER_NUMBER_CONNECTION_IDS of iDriver to iNumConn
93404>>>                Decrement iNumConn
93405>>>                For iCount from 0 to iNumConn
93411>>>>
93411>>>                    Get_Attribute DF_DRIVER_CONNECTION_ID of iDriver iCount to sID
93414>>>                    If (sID = sConnectionID) Move True to bOK
93417>>>                Loop
93418>>>>
93418>>>            End
93418>>>>
93418>>>        End
93418>>>>
93418>>>        
93418>>>        Function_Return bOK
93419>>>    End_Function                   
93420>>>    
93420>>>    Function IsDAWSQLDriver String sDriverID Returns Boolean
93422>>>        Boolean bOK
93422>>>        Move (sDriverID = MSSQLDRV_ID or sDriverID = DB2_DRV_ID or sDriverID = ODBC_DRV_ID) to bOK
93423>>>        Function_Return bOK
93424>>>    End_Function
93425>>>
93425>>>    Function IsMertechDriver String sDriverID Returns Boolean
93427>>>        Boolean bOK
93427>>>        Move False to bOK
93428>>>        Move (sDriverID = SQLFLEX or sDriverID = ORAFLEX or sDriverID = MDSPgSQL or sDriverID = MDSMySQL) to bOK
93429>>>        Function_Return bOK
93430>>>    End_Function
93431>>>            
93431>>>    Function IsMSSQLDriver Returns Boolean
93433>>>        Handle ho
93433>>>        Integer iDriverIndex
93433>>>        
93433>>>        Get DriverIndex MSSQLDRV_ID to iDriverIndex
93434>>>        
93434>>>        Function_Return (iDriverIndex <> 0)
93435>>>    End_Function
93436>>>        
93436>>>    // Similar to _SqlCheckCurrentDriver but generates no error and it doesn't 
93436>>>    // attempt to load the driver.
93436>>>    // Returns true if the passed driver is SQL based.        
93436>>>    Function IsSQLDriver String sDriverID Returns Boolean
93438>>>        Boolean bOK                         
93438>>>        Integer iDriver
93438>>>        
93438>>>        Get IsDAWSQLDriver sDriverID to bOK
93439>>>
93439>>>        If (bOK = False) Begin
93441>>>            Get IsMertechDriver sDriverID to bOK
93442>>>        End                                     
93442>>>>
93442>>>
93442>>>        Function_Return bOK
93443>>>    End_Function
93444>>>            
93444>>>    // *** Error Handler ***
93444>>>    //
93444>>>    // Note: If the cDbUpdateHandler & cDbUpdateVersion classes are used this error handler is _not_
93444>>>    //       used. Instead the Error_Report in the cDbUpdateHandler i used.
93444>>>    Procedure Error_Report Integer iErrorNumber Integer iErrorLine String sErrorText
93446>>>        String sText
93446>>>        Integer iSize iErrorMode
93446>>>        tSqlErrorArray aSqlErrorArray
93446>>>        tSqlErrorArray aSqlErrorArray
93446>>>        
93446>>>        If (pbProcessingError(Self)) Begin
93448>>>            Procedure_Return
93449>>>        End 
93449>>>>
93449>>>        
93449>>>        Get Error_Report_Mode to iErrorMode
93450>>>        If (iErrorMode = DUF_ERROR_NO_REPORT) Begin
93452>>>            Procedure_Return
93453>>>        End
93453>>>>
93453>>>
93453>>>        Set pbProcessingError to True
93454>>>        Set pbSqlError to True
93455>>>        Get paSqlErrorArray      to aSqlErrorArray
93456>>>        Move (SizeOfArray(aSqlErrorArray.sSqlErrorArray)) to iSize
93457>>>        Move sErrorText          to aSqlErrorArray.sSqlErrorArray[iSize]
93458>>>        Get psSQLStatementString to aSqlErrorArray.sSqlStatementArray[iSize]
93459>>>        Move iErrorNumber        to aSqlErrorArray.iSqlErrorArray[iSize]
93460>>>        Set paSqlErrorArray      to aSqlErrorArray
93461>>>        Set pbProcessingError to False
93462>>>    End_Procedure
93463>>>
93463>>>    // *** Miscellanous Helper Functions ***
93463>>>    //
93463>>>    // Helper function. Takes a DF_FILE_XXXX_NAME value as parameter and 
93463>>>    // returns the table name only; stripped of any path or filename extension.
93463>>>    Function _TableNameOnly String sName Returns String
93465>>>        String sPath sExt
93465>>>        
93465>>>        Get ParseFolderName sName to sPath
93466>>>        If (sPath <> "") Begin
93468>>>            Move (Replace(sPath, sName, "")) to sName
93469>>>        End                                                  
93469>>>>
93469>>>        Get ParseFileExtension sName to sExt
93470>>>        If (sExt <> "") Begin
93472>>>            Move (Replace(("." + sExt), sName, "")) to sName
93473>>>        End
93473>>>>
93473>>>        
93473>>>        Function_Return sName
93474>>>    End_Function
93475>>>
93475>>>    // Returns the first datapath found in the psDataPath property.
93475>>>    // The returned path always ends with a "\"
93475>>>    Function psDataPathFirstPart Returns String
93477>>>        String sDataPath
93477>>>        Integer iCount
93477>>>        
93477>>>        Get psDataPath of (phoWorkspace(ghoApplication)) to sDataPath
93478>>>        Get CountOfPaths of (phoWorkspace(ghoApplication)) sDataPath to iCount
93479>>>        If (iCount > 1) Begin
93481>>>            Get PathAtIndex of (phoWorkspace(ghoApplication)) sDataPath 1 to sDataPath    
93482>>>        End             
93482>>>>
93482>>>        If (sDataPath <> "") Begin
93484>>>            Get vFolderFormat sDataPath to sDataPath
93485>>>        End
93485>>>>
93485>>>        
93485>>>        Function_Return sDataPath
93486>>>    End_Function
