90757>>>            If (iColumnTo <> 0) Begin
90759>>>                Set_Attribute DF_FIELD_RELATED_FIELD of hTable iColumnFrom to iColumnTo
90762>>>            End
90762>>>>
90762>>>        Structure_End hTable DF_STRUCTEND_OPT_IN_PLACE
90764>>>    
