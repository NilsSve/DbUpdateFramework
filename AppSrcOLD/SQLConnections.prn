85541>>>>>    Function SQLIniFileDeleteConnection Integer iItem Returns Boolean
85543>>>>>        Integer iCount 
85543>>>>>        String sSection 
85543>>>>>        Boolean bExists
85543>>>>>        
85543>>>>>        Move False to Err
85544>>>>>        Move 1 to iCount
85545>>>>>        Get psIniSectionName to sSection
85546>>>>>        Get KeyExists sSection CS_SQLIniConnectionIdKeyword to bExists
85547>>>>>        While (bExists = True)
85551>>>>>            If (iCount = iItem) Begin   
85553>>>>>                Send DeleteSection sSection
85554>>>>>//                Set IniFileValue sSection (CS_SQLIniSectionName + String(iCount)) to ""
85554>>>>>                Move 9999 to iCount // Just some ridiculously high number to get out of the loop as we're done.
85555>>>>>            End
85555>>>>>>
85555>>>>>            Increment iCount
85556>>>>>            Get KeyExists sSection (CS_SQLIniSectionName + String(iCount)) to bExists
85557>>>>>        Loop
85558>>>>>>
85558>>>>>        
85558>>>>>        Function_Return (Err = False)
85559>>>>>    End_Function
85560>>>>>    
85560>>>>>    // Returns all connection details for the passed Connection ID as a tSQLConnection
85560>>>>>    // If it fails the returned struct member SQLConnection.bError = True. 
85560>>>>>    Function SQLIniFileConnectionID String sConnectionID Returns tSQLConnection
85562>>>>>        tSQLConnection[] SQLConnectionsArray
85562>>>>>        tSQLConnection[] SQLConnectionsArray
85563>>>>>        tSQLConnection   SQLConnection
85563>>>>>        tSQLConnection   SQLConnection
85563>>>>>        Integer iIndex
85563>>>>>        
85563>>>>>        Get SQLIniFileConnectionIDIndex sConnectionID to iIndex
85564>>>>>        If (iIndex = -1) Begin
85566>>>>>            Move True to SQLConnection.bError
85567>>>>>            Function_Return SQLConnection
85568>>>>>        End
85568>>>>>>
85568>>>>>
85568>>>>>        Get SQLIniFileReadConnections to SQLConnectionsArray
85569>>>>>        Move SQLConnectionsArray[iIndex -1] to SQLConnection
85570>>>>>        
85570>>>>>        Function_Return SQLConnection    
85571>>>>>    End_Function
85572>>>>>            
85572>>>>>    // Returns -1 if the passed connection ID was not found, else the item number.
85572>>>>>    Function SQLIniFileConnectionIDIndex String sConnectionID Returns Integer
85574>>>>>        tSQLConnection[] SQLConnectionsArray
85574>>>>>        tSQLConnection[] SQLConnectionsArray
85575>>>>>        Integer iRetval iCount iSize
85575>>>>>        String sValue
85575>>>>>        Boolean bExists
85575>>>>>        
85575>>>>>        Move -1 to iRetval
85576>>>>>
85576>>>>>        Get SQLIniFileReadConnections to SQLConnectionsArray
85577>>>>>        Move (SizeOfArray(SQLConnectionsArray)) to iSize
85578>>>>>        Decrement iSize
85579>>>>>        For iCount from 0 to iSize
85585>>>>>>
85585>>>>>            Move SQLConnectionsArray[iCount].sConnectionID to sValue 
85586>>>>>            Move (Uppercase(sValue) = Uppercase(sConnectionID)) to bExists
85587>>>>>            If (bExists) Begin
85589>>>>>                Move (iCount + 1) to iRetval // The [ConnectionX] keys are one-based (starts at 1) but the loop starts at zero.
85590>>>>>                Move iSize to iCount         // We're done!
85591>>>>>            End
85591>>>>>>
85591>>>>>        Loop
85592>>>>>>
85592>>>>>                
85592>>>>>        Function_Return iRetval
85593>>>>>    End_Function       
85594>>>>>    
85594>>>>>    // Checks if the passed sConnectionID exists more than once in the passed struct array.
85594>>>>>    // Used to check that ConnectionID's are unique.
85594>>>>>    Function IsConnectionIDDuplicate String sConnectionID Returns Boolean
85596>>>>>        Integer iCount iSize iItems
85596>>>>>        String sValue
85596>>>>>        Boolean bExists                                   
85596>>>>>        tSQLConnection[] SQLConnectionsArray 
85596>>>>>        tSQLConnection[] SQLConnectionsArray 
85597>>>>>        
85597>>>>>        Move 0 to iItems                     
85598>>>>>        Get SQLIniFileReadConnections to SQLConnectionsArray
85599>>>>>        Move (SizeOfArray(SQLConnectionsArray)) to iSize
85600>>>>>        Decrement iSize
85601>>>>>        For iCount from 0 to iSize
85607>>>>>>
85607>>>>>            Move SQLConnectionsArray[iCount].sConnectionID to sValue 
85608>>>>>            Move (sValue = sConnectionID) to bExists
85609>>>>>            If (bExists) Begin
85611>>>>>                Increment iItems
85612>>>>>            End
85612>>>>>>
85612>>>>>        Loop
85613>>>>>>
85613>>>>>                
85613>>>>>        Function_Return (iItems > 1)
85614>>>>>    End_Function       
85615>>>>>    
85615>>>>>    // To update the SQLConnections.ini file with a new default Connection ID.
85615>>>>>    Function SQLIniFileSetDefaultConnection String sConnectionID Returns Boolean
85617>>>>>        Boolean bRetval bOK
85617>>>>>        Integer iItem iSize iCount
85617>>>>>        tSQLConnection[] SQLConnectionsArray
85617>>>>>        tSQLConnection[] SQLConnectionsArray
85618>>>>>        tSQLConnection SQLConnection
85618>>>>>        tSQLConnection SQLConnection
85618>>>>>        String sConnectionString
85618>>>>>        
85618>>>>>        Move False to Err     
85619>>>>>        Get psConnectionString to sConnectionString             
85620>>>>>        
85620>>>>>        Get SQLIniFileReadConnections to SQLConnectionsArray
85621>>>>>        Move (SizeOfArray(SQLConnectionsArray)) to iSize
85622>>>>>        Decrement iSize
85623>>>>>        // Set all current connection to inactive.
85623>>>>>        For iCount from 0 to iSize
85629>>>>>>
85629>>>>>            Move False to SQLConnectionsArray[iCount].bEnabled
85630>>>>>        Loop                                              
85631>>>>>>
85631>>>>>        
85631>>>>>        Get SQLIniFileConnectionID sConnectionID to SQLConnection
85632>>>>>        Move True              to SQLConnection.bEnabled
85633>>>>>        Move sConnectionString to SQLConnection.sConnectionString
85634>>>>>        Move (InsertInArray(SQLConnectionsArray, 0, SQLConnection)) to SQLConnectionsArray
85635>>>>>        Get SQLIniFileWriteConnections SQLConnectionsArray to bOK
85636>>>>>        
85636>>>>>        Function_Return (bOK = True)
85637>>>>>    End_Function
85638>>>>>    
85638>>>>>    // Used for updating an existing connection with new data.
85638>>>>>    // Returns True if successful.
85638>>>>>    Function SQLIniFileUpdateConnection tSQLConnection SQLConnection Returns Boolean
85640>>>>>        Boolean bRetval bOK
85640>>>>>        Integer iItem iSize iCount
85640>>>>>        tSQLConnection[] SQLConnectionsArray
85640>>>>>        tSQLConnection[] SQLConnectionsArray
85641>>>>>        
85641>>>>>        Move False to Err           
85642>>>>>        Move -1 to iItem  
85643>>>>>        Get SQLIniFileReadConnections to SQLConnectionsArray
85644>>>>>        Move (SizeOfArray(SQLConnectionsArray)) to iSize
85645>>>>>        Decrement iSize
85646>>>>>        // Set all current connection to inactive.
85646>>>>>        For iCount from 0 to iSize
85652>>>>>>
85652>>>>>            Move False to SQLConnectionsArray[iCount].bEnabled 
85653>>>>>            If (SQLConnectionsArray[iCount].sConnectionID = SQLConnection.sConnectionID) Begin
85655>>>>>                Move iCount to iItem
85656>>>>>            End
85656>>>>>>
85656>>>>>        Loop                                              
85657>>>>>>
85657>>>>>        
85657>>>>>        If (iItem <> -1) Begin
85659>>>>>            Move True to SQLConnection.bEnabled
85660>>>>>            Move SQLConnection to SQLConnectionsArray[iItem]
85661>>>>>            Get SQLIniFileWriteConnections SQLConnectionsArray to bOK
85662>>>>>        End
85662>>>>>>
85662>>>>>        
85662>>>>>        Function_Return (bOK = True)
85663>>>>>    End_Function
85664>>>>>    
85664>>>>>    Function SQLIniFileReadConnections Returns tSQLConnection[]
85666>>>>>        tSQLConnection[] SQLConnectionsArray
85666>>>>>        tSQLConnection[] SQLConnectionsArray
85667>>>>>        String sSection sValue
85667>>>>>        Integer iCount
85667>>>>>        Boolean bExists bEnabled
85667>>>>>        
85667>>>>>        Get psIniSectionName to sSection
85668>>>>>        Get SectionExists sSection to bExists
85669>>>>>        If (bExists = False) Begin   
85671>>>>>            Function_Return SQLConnectionsArray
85672>>>>>        End                                  
85672>>>>>>
85672>>>>>        Get SectionExists CS_SQLIniConnectionSection to bExists
85673>>>>>        If (bExists = True) Begin
85675>>>>>            Error DFERR_PROGRAM "Sorry, the format for the SQLConnections.ini file has been changed and this file has the old format that is no longer valid and thus cannot be read. You need to re-enter your connection(s)."
85676>>>>>>
85676>>>>>        End
85676>>>>>>
85676>>>>>                
85676>>>>>        Move 1 to iCount // The section name "[ConnectionXX]" starts with "1"
85677>>>>>        Get SectionExists (CS_SQLIniSectionName + String(iCount)) to bExists 
85678>>>>>        
85678>>>>>        While (bExists = True)
85682>>>>>            // We always put the enabled/active connection at the top
85682>>>>>            Move (iCount = 1) to bEnabled
85683>>>>>            Move bEnabled to SQLConnectionsArray[iCount].bEnabled
85684>>>>>            
85684>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniConnectionIdKeyword ""        to SQLConnectionsArray[iCount].sConnectionID
85685>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniDriverKeyword       ""        to SQLConnectionsArray[iCount].sDriverID
85686>>>>>
85686>>>>>            // The iDbType might be missing from the ini-file. This is e.g. the case when a DAW Managed Connection "DFConnId.ini" file is read.
85686>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniDbTypeKeyword       "99"      to sValue
85687>>>>>            If (sValue = "99") Begin
85689>>>>>                Get SqlUtilDbTypeFromDriver SQLConnectionsArray[iCount].sDriverID to sValue
85690>>>>>            End
85690>>>>>>
85690>>>>>            Move sValue                                                                                     to SQLConnectionsArray[iCount].iDbType
85691>>>>>
85691>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniConnectionKeyWord   ""        to SQLConnectionsArray[iCount].sConnectionString
85692>>>>>            Get ParseKeyWord SQLConnectionsArray[iCount].sConnectionString (CS_SQLIniServerKeyword + "=")   to SQLConnectionsArray[iCount].sServer
85693>>>>>            If (SQLConnectionsArray[iCount].sServer = "") Begin
85695>>>>>                Get ParseKeyWord SQLConnectionsArray[iCount].sConnectionString (CS_SQLIniDSNKeyword +"=")   to SQLConnectionsArray[iCount].sServer
85696>>>>>            End
85696>>>>>>
85696>>>>>            Get ParseKeyWord SQLConnectionsArray[iCount].sConnectionString (CS_SQLIniDatabaseKeyword + "=") to SQLConnectionsArray[iCount].sDatabase
85697>>>>>
85697>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniTrustedKeyword      ""        to sValue
85698>>>>>            Move (If(Uppercase(sValue) = "YES", True, False))                                               to SQLConnectionsArray[iCount].bTrusted
85699>>>>>
85699>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniUIDKeyword          ""        to SQLConnectionsArray[iCount].sUserID
85700>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniDFPWDKeyword        ""        to sValue
85701>>>>>            If (pbDFConnId(Self) = False and sValue <> "") Begin
85703>>>>>                Get DecryptPassword sValue to sValue    
85704>>>>>            End
85704>>>>>>
85704>>>>>            Move sValue                                                                                     to SQLConnectionsArray[iCount].sPassword
85705>>>>>            
85705>>>>>            // Here we reconstruct the connection string to be complete with all params;
85705>>>>>            Get ConstructConnectionString SQLConnectionsArray[iCount].sDriverID SQLConnectionsArray[iCount].sServer SQLConnectionsArray[iCount].sDatabase ;                                          SQLConnectionsArray[iCount].bTrusted SQLConnectionsArray[iCount].sUserID SQLConnectionsArray[iCount].sPassword ;                                          to SQLConnectionsArray[iCount].sConnectionString    
85706>>>>>            
85706>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniSchemaKeyword          ""     to SQLConnectionsArray[iCount].sSchema
85707>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniBaseTableSpaceKeyword  ""     to SQLConnectionsArray[iCount].sBaseTableSpace
85708>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniLongTableSpaceKeyword  ""     to SQLConnectionsArray[iCount].sLongTableSpace
85709>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniIndexTableSpaceKeyword ""     to SQLConnectionsArray[iCount].sIndexTableSpace
85710>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniSilentLoginKeyword     ""     to SQLConnectionsArray[iCount].bSilentLogin  
85711>>>>>//            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniDisabledKeyword        ""     to SQLConnectionsArray[iCount].bDisabled
85711>>>>>
85711>>>>>            Increment iCount
85712>>>>>            Get SectionExists (CS_SQLIniSectionName + String(iCount)) to bExists
85713>>>>>        Loop
85714>>>>>>
85714>>>>>        
85714>>>>>        // Lastly, we remove the very first array item as it is empty (we started at 1 because that is the first [Connection#])
85714>>>>>        If (SizeOfArray(SQLConnectionsArray) > 0) Begin
85716>>>>>            Move (RemoveFromArray(SQLConnectionsArray, 0)) to SQLConnectionsArray
85717>>>>>        End
85717>>>>>>
85717>>>>>        
85717>>>>>        Function_Return SQLConnectionsArray
85718>>>>>    End_Function 
85719>>>>>        
85719>>>>>    Function SQLIniFileWriteConnections tSQLConnection[] SQLConnectionsArray Returns Boolean
85721>>>>>        Integer iCount iSize iItem
85721>>>>>        Boolean bIsOneActive bEnabled bExists bOK
85721>>>>>        String sConnectionString sSection sValue
85721>>>>>        
85721>>>>>        // First we need to _remove_ all current connections in the ini-file, we
85721>>>>>        // do that by setting their values to "".
85721>>>>>        Move 0 to iCount  
85722>>>>>        Get SQLIniFileDeleteAllConnections to bOK
85723>>>>>        If (bOK = False) Begin
85725>>>>>            Function_Return False
85726>>>>>        End                 
85726>>>>>>
85726>>>>>        
85726>>>>>        Move False to Err
85727>>>>>        Get psIniSectionName to sSection                                                          
85728>>>>>        // Sorting will make sure we have the active connection record as the first connection item in the ini-file.
85728>>>>>        Move (SortArray(SQLConnectionsArray, Self, (RefFunc(SortActiveFirst)))) to SQLConnectionsArray
85729>>>>>        Move (SizeOfArray(SQLConnectionsArray)) to iSize
85730>>>>>        Decrement iSize       
85731>>>>>        
85731>>>>>        For iCount from 0 to iSize
85737>>>>>>
85737>>>>>            // DF 19 compatible settings:
85737>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniConnectionIdKeyword   to SQLConnectionsArray[iCount].sConnectionID
85738>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniDriverKeyword         to SQLConnectionsArray[iCount].sDriverID
85739>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniUIDKeyword            to SQLConnectionsArray[iCount].sUserID
85740>>>>>            
85740>>>>>            Move SQLConnectionsArray[iCount].sPassword to sValue
85741>>>>>            If (pbDFConnId(Self) = False and sValue <> "") Begin
85743>>>>>                Get EncryptPassword sValue to sValue    
85744>>>>>            End
85744>>>>>>
85744>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniDFPWDKeyword          to sValue
85745>>>>>
85745>>>>>            If (SQLConnectionsArray[iCount].bTrusted = True) Begin
85747>>>>>                Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniTrustedKeyword    to CS_SQLIniConnectionYes
85748>>>>>            End                                                                
85748>>>>>>
85748>>>>>            
85748>>>>>            Get ConstructShortConnectionString SQLConnectionsArray[iCount].sDriverID SQLConnectionsArray[iCount].sServer SQLConnectionsArray[iCount].sDatabase ;                                            to SQLConnectionsArray[iCount].sConnectionString
85749>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniConnectionKeyWord     to SQLConnectionsArray[iCount].sConnectionString
85750>>>>>            
85750>>>>>            // The Database Update Framework extended settings:
85750>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniDbTypeKeyword          to SQLConnectionsArray[iCount].iDbType
85751>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniSchemaKeyword          to SQLConnectionsArray[iCount].sSchema
85752>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniBaseTableSpaceKeyword  to SQLConnectionsArray[iCount].sBaseTableSpace
85753>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniLongTableSpaceKeyword  to SQLConnectionsArray[iCount].sLongTableSpace
85754>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniIndexTableSpaceKeyword to SQLConnectionsArray[iCount].sIndexTableSpace
85755>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniSilentLoginKeyword     to SQLConnectionsArray[iCount].bSilentLogin
85756>>>>>        Loop                 
85757>>>>>>
85757>>>>>        
85757>>>>>        Function_Return (bOK and Err = False)
85758>>>>>    End_Function
85759>>>>>
85759>>>>>    // *** DbType conversion routines - Converts between string/integer and driver ID values ***
85759>>>>>    //
85759>>>>>    // SQL utility function that returns a database type (string) constant
85759>>>>>    // corresponding to the passed iDbType.
85759>>>>>    Function SqlUtilDbTypeToString Integer iDbType Returns String
85761>>>>>        String sRetval
85761>>>>>        If (iDbType = EN_dbTypeMSSQL)       Move CS_dbTypeMSSQL     to sRetval
85764>>>>>        If (iDbType = EN_dbTypeMySQL)       Move CS_dbTypeMySQL     to sRetval
85767>>>>>        If (iDbType = EN_dbTypeOracle)      Move CS_dbTypeOracle    to sRetval
85770>>>>>        If (iDbType = EN_dbTypeDB2)         Move CS_dbTypeDB2       to sRetval
85773>>>>>        If (iDbType = EN_dbTypePostgre)     Move CS_dbTypePostgre   to sRetval
85776>>>>>        Function_Return sRetval
85777>>>>>    End_Function
85778>>>>>    
85778>>>>>    // SQL utility function that returns a database type constant (integer)
85778>>>>>    // corresponding to the passed sDbType string constant.
85778>>>>>    Function SqlUtilDbTypeToInteger String sDbType  Returns Integer
85780>>>>>        Integer iRetval
85780>>>>>        If (sDbType = CS_dbTypeMSSQL)       Move EN_dbTypeMSSQL     to iRetval
85783>>>>>        If (sDbType = CS_dbTypeMySQL)       Move EN_dbTypeMySQL     to iRetval
85786>>>>>        If (sDbType = CS_dbTypeOracle)      Move EN_dbTypeOracle    to iRetval
85789>>>>>        If (sDbType = CS_dbTypeDB2)         Move EN_dbTypeDB2       to iRetval
85792>>>>>        If (sDbType = CS_dbTypePostgre)     Move EN_dbTypePostgre   to iRetval
85795>>>>>        Function_Return iRetval
85796>>>>>    End_Function    
85797>>>>>    
85797>>>>>    // Pass an integer DbType and function returns the database type integer as a string value.
85797>>>>>    // Used e.g. when reading a connection ini-file to display the database type in
85797>>>>>    // the SQL Connection program's grid.
