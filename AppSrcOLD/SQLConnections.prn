91588>>>    Function SQLUtilDefaultNullValue String sDriverID Integer iDbType Integer iDataType Returns String
91590>>>        String sNotNull sRetval sDefaultValue
91590>>>        Boolean bOK
91590>>>        
91590>>>        Get IsSQLDriver sDriverID to bOK
91591>>>        If (bOK = False) Begin
91593>>>            Function_Return ""
91594>>>        End                   
91594>>>>
91594>>>        
91594>>>        Get UtilDataTypeDefaultValue sDriverID iDbType iDataType to sDefaultValue
91595>>>        Get _SqlFindKeyWord CI_SQLNotNull to sNotNull
91596>>>        
91596>>>        Case Begin
91596>>>            Case (iDbType = EN_dbTypeMSSQL)
91598>>>                Move ("DEFAULT" * String(sDefaultValue) * String(sNotNull)) to sRetval
91599>>>                Case Break
91600>>>            Case (iDbType = EN_dbTypeMySQL)
91603>>>                Move (String(sNotNull) * "DEFAULT" * String(sDefaultValue)) to sRetval
91604>>>                Case Break
91605>>>            Case (iDbType = EN_dbTypePostgre)
91608>>>                Move (String(sNotNull) * "DEFAULT" * String(sDefaultValue)) to sRetval
91609>>>                Case Break
91610>>>            Case (iDbType = EN_dbTypeDB2)
91613>>>                Move (String(sNotNull))                                     to sRetval
91614>>>                Case Break
91615>>>            
91615>>>            // Seems like Oracle can't handle setting a new column to 'NOT NULL' if the table exists with data(!)
91615>>>            // ToDo: We need to look deeper into how Oracle handles NULL
91615>>>            Case (iDbType = EN_dbTypeOracle)
91618>>>                Move  ""                                                    to sRetval
91619>>>                Case Break                                              
91620>>>
91620>>>            Case Else
91620>>>                Move  ""                                                    to sRetval
91621>>>        Case End        
91621>>>        
91621>>>        Function_Return sRetval
91622>>>    End_Function
