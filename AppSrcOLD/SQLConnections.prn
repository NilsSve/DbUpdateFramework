98541>>>    Function IsDFConnId Returns Boolean
98544>>>        Boolean bDFConnId
98544>>>        Handle ho
98544>>>        String sFileName
98544>>>
98544>>>        Get phoSQLConnectionIniFile of ghoSQLConnectionHandler to ho
98545>>>        Get psIniFileName of ho to sFileName
98546>>>        Move (Uppercase(sFileName) = Uppercase(CS_SQLDF19IniFileName)) to bDFConnId 
98547>>>        Set pbDFConnId of ho to bDFConnId
98548>>>
98548>>>        Function_Return bDFConnId
98549>>>    End_Function
98550>>>
98550>>>    Procedure OnFileDropped String sFilename Boolean bLast
98553>>>        Boolean bHasChange
98553>>>        Handle ho hoGrid
98553>>>        Integer iRetval
98553>>>        String sPath
98553>>>
98553>>>        Forward Send OnFileDropped sFilename bLast
98555>>>
98555>>>        If (bLast = True) Begin
98557>>>            Move (oSQLConnections_grd(Self)) to hoGrid
98558>>>            Get ParseFolderName sFilename to sPath
98559>>>            Get ParseFileName   sFilename to sFilename
98560>>>            If (Uppercase(sFilename) <> Uppercase(CS_SQLIniFileName) and Uppercase(sFilename) <> Uppercase(CS_SQLDF19IniFileName)) Begin
98562>>>                Send Info_Box ("Sorry, only" * CS_SQLIniFileName * "files can be dropped!")
98563>>>                Procedure_Return
98564>>>            End
98564>>>>
98564>>>            Get Should_Save of hoGrid to bHasChange
98565>>>            If (bHasChange = True) Begin
98567>>>                Get YesNo_Box "Changes exist! Do you still want to load the new file?" to iRetval
98568>>>                If (iRetval <> MBR_Yes) Begin
98570>>>                    Procedure_Return
98571>>>                End
98571>>>>
98571>>>            End
98571>>>>
98571>>>            Get phoSQLConnectionIniFile of ghoSQLConnectionHandler to ho
98572>>>            Set psIniFilePath of ho to sPath
98573>>>            Set psIniFileName of ho to sFilename
98574>>>            Send LoadData of oSQLConnections_grd
98575>>>        End
98575>>>>
98575>>>    End_Procedure
98576>>>
98576>>>    // This is only being called where no SQLConnections.ini file exists;
98576>>>    // thus a new active/enabled DFConnection ID needs to be established.
98576>>>    Procedure ConnectionDoesNotExist
98579>>>        tSQLConnection SQLConnection
98579>>>        tSQLConnection SQLConnection
98579>>>        Boolean bChanged bDFConnId bEnabled
98579>>>        Handle ho
98579>>>        tDataSourceRow TheRow
98579>>>        tDataSourceRow TheRow
98579>>>        Handle hoDataSource
98579>>>        tDataSourceRow[] TheData
98579>>>        tDataSourceRow[] TheData
98580>>>
98580>>>        Get IsDFConnId to bDFConnId
98581>>>
98581>>>        Move (oSQLMaintainConnections_dg(Self)) to ho
98582>>>        Move True to bEnabled
98583>>>        Set pbNew to True
98584>>>        Set pbNew of ho to True
98585>>>
98585>>>        Get phoDataSource of oSQLConnections_grd to hoDataSource
98586>>>        Get DataSource of hoDataSource to TheData
98587>>>
98587>>>        Send Activate_SQLMaintainConnections_dg of (Client_Id(phoMainPanel(ghoApplication))) (pbNew(Self)) -1 (&SQLConnection) (&bChanged) bDFConnId TheData
98588>>>        If (bChanged = True) Begin
98590>>>            // We also need to tell the main connection object that we now have
98590>>>            // created a connection.           
98590>>>            Set pSQLConnection            of ghoSQLConnectionHandler to SQLConnection
98591>>>//            Set psConnectionID            of ghoSQLConnectionHandler to SQLConnection.sConnectionID
98591>>>//            Send UpdateConnectionString   of ghoSQLConnectionHandler SQLConnection
98591>>>//            Set psConnectionString        of ghoSQLConnectionHandler to SQLConnection.sConnectionString
98591>>>            // And add the data to the grid.
98591>>>            Get MoveSQLConnectionToGridRow of oSQLConnections_grd SQLConnection to TheRow
98592>>>            Send AddConnection of oSQLConnections_grd TheRow
98593>>>            // Not new anymore.
98593>>>            Set pbNew to False
98594>>>            Set pbNew of ho to False
98595>>>        End
98595>>>>
98595>>>    End_Procedure
