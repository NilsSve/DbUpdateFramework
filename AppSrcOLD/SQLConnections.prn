91174>>>            End
91174>>>>
91174>>>            If (iSegment10 <> -1) Begin
91176>>>                Set_Attribute DF_INDEX_SEGMENT_FIELD of hTable iIndex 10 to iSegment10
91179>>>            End
91179>>>>
91179>>>        Structure_End hTable DF_STRUCTEND_OPT_NONE
91181>>>    
91181>>>        Send Trap_Error of Error_Object_Id CLIERR_GENERAL_ERROR
91182>>>        
91182>>>        Function_Return (Err = False)
