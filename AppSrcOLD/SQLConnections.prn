87832>>>    // Drop column by its table handle 
87832>>>    Function SqlColumnRemove Handle hTable String sColumnName Returns Boolean
87834>>>        Integer iColumn idbType
87834>>>        String sDriverID sStmt sAlterTable sDropColumn sVal sTableName 
87834>>>        Boolean bExists bOK
87834>>>        
87834>>>        Get psDriverID to sDriverID
87835>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
87836>>>        If (bOK = False) Begin
87838>>>            Function_Return False
87839>>>        End
87839>>>>
87839>>>        
87839>>>        Get UtilTableHandleToString hTable to sTableName
87840>>>        If (sTableName = "") Begin
87842>>>            Function_Return False
87843>>>        End  
87843>>>>
87843>>>        
