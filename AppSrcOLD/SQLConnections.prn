85841>>>>>>Function ParseKeyWord String sConnect String sKeyWord Returns String
85843>>>>>>    Integer iStart iEnd
85843>>>>>>    String sRetval
85843>>>>>>
85843>>>>>>    Move (Trim(sConnect)) to sConnect
85844>>>>>>    Move (Pos(Uppercase(sKeyWord), Uppercase(sConnect)))  to iStart
85845>>>>>>    If (iStart = 0) Begin
85847>>>>>>        Function_Return ""
85848>>>>>>    End
85848>>>>>>>
85848>>>>>>    Move (Left(sConnect, (iStart -1 + Length(sKeyWord)))) to sRetval
85849>>>>>>    Move (Replace(sRetval, sConnect, "")) to sRetval 
85850>>>>>>    If (sKeyWord = Uppercase(CS_SQLConnectionIDText)) Begin
85852>>>>>>        Move (Pos(",", sRetval))          to iEnd
85853>>>>>>    End
85853>>>>>>>
85853>>>>>>    Else Begin
85854>>>>>>        Move (Pos(";", sRetval))          to iEnd
85855>>>>>>    End                                          
85855>>>>>>>
85855>>>>>>    If (iEnd = 0 and (sRetval contains ",")) Begin
85857>>>>>>        Move (Pos(",", sRetval))          to iEnd 
85858>>>>>>        Decrement iEnd
85859>>>>>>    End
85859>>>>>>>
85859>>>>>>    If (iEnd <> 0) Begin
85861>>>>>>        Move (Left(sRetval, (iEnd -1)))   to sRetval
85862>>>>>>    End
85862>>>>>>>
85862>>>>>>    Move (Replace("=", sRetval, ""))      to sRetval
85863>>>>>>
85863>>>>>>    Function_Return (Trim(sRetval))
85864>>>>>>End_Function
