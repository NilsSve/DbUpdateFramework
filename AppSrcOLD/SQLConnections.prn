89519>>>    // To enumerate SQL database resources with ESQL and return the result as a string array,
89519>>>    // for DAW drivers.
89519>>>    // Returns: A string array.
89519>>>    Function SqlEnumerateEsqlDAW String sStmt Integer iColumn Returns String[]
89521>>>        String[] sReturnArray
89522>>>        String sValue sPrevious
89522>>>        Handle hoSQLHandler hoSQLConnect hstmt
89522>>>        Integer iFetchResult iRows
89522>>>        tSQLConnection SQLConnection
89522>>>        tSQLConnection SQLConnection
89522>>>        
89522>>>        Get phoSQLManager to hoSQLHandler
89523>>>                
89523>>>        If (hoSQLHandler <> 0) Begin 
89525>>>            Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
89526>>>            Get SQLConnect of hoSQLHandler SQLConnection.sDriverID SQLConnection.sConnectionString to hoSQLConnect
89527>>>            
89527>>>            If (hoSQLConnect <> 0) Begin   
89529>>>                Get SQLOpen of hoSQLConnect to hstmt
89530>>>                If (hstmt <> 0) Begin                                   
89532>>>                    Send SqlExecDirect of hstmt sStmt                                             
89533>>>                    Get SqlStmtAttribute of hstmt SqlSTMTATTRIB_ROWCOUNT to iRows 
89534>>>                    Repeat
89534>>>>
89534>>>                        Get SQLFetch of hstmt to iFetchResult
89535>>>                        If (iFetchResult <> 0) Begin
89537>>>                            Get SQLColumnValue of hstmt iColumn to sValue
89538>>>                            If (sValue <> sPrevious) Begin
89540>>>                                Move (Trim(sValue)) to sReturnArray[SizeOfArray(sReturnArray)
89541>>>                            End
89541>>>>
89541>>>                            Move sValue to sPrevious
89542>>>                        End
89542>>>>
89542>>>                    Until (iFetchResult = 0)
89544>>>                    Send SQLClose of hstmt
89545>>>                End
89545>>>>
89545>>>                Send SQLDisconnect of hoSQLConnect    
89546>>>            End
89546>>>>
89546>>>        End
89546>>>>
89546>>>    
89546>>>        Function_Return sReturnArray
89547>>>    End_Function   
