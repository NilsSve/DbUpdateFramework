79978>>>Class cShellFileOperations Is a Array
79979>>>
79979>>>  Procedure Construct_Object
79981>>>    Forward Send Construct_Object
79983>>>    Property Integer piDeleteFlags        Public 0
79984>>>    Property Integer piCopyFlags          Public 0
79985>>>    Property Integer piMoveFlags          Public 0
79986>>>    Property Integer piRenameFlags        Public 0
79987>>>    
79987>>>    Set piDeleteFlags To (vFOF_SILENT Ior vFOF_NOCONFIRMATION)
79988>>>    Set piCopyFlags   To (vFOF_SILENT iOr vFOF_NOCONFIRMMKDIR Ior vFOF_NOCONFIRMATION)
79989>>>    Set piMoveFlags   To (vFOF_SILENT iOr vFOF_NOCONFIRMMKDIR iOr vFOF_NOCONFIRMATION)
79990>>>    Set piRenameFlags To (vFOF_SILENT Ior vFOF_NOCONFIRMATION)
79991>>>  End_Procedure // Construct_Object
79992>>>  
79992>>>  
79992>>>  // This function uses the shell API to perform a file operation on the
79992>>>  // files supplied.
79992>>>  //
79992>>>  Function FileOperation String sSource String sDestination Integer iOperation Integer iFlags Returns Integer
79994>>>    String   sShFileOp
79994>>>    Pointer  lpShFileOp
79994>>>    Pointer  lpsSource
79994>>>    Pointer  lpsDestination
79994>>>    Integer  iRetVal
79994>>>    Integer  bUserAbort
79994>>>             
79994>>>    ZeroType vtShFileOpStruct To sShFileOp
79995>>>    Move (ToAnsi(sSource)+Character(0)+Character(0))      To sSource
79996>>>    Move (ToAnsi(sDestination)+Character(0)+Character(0)) To sDestination
79997>>>    GetAddress Of sSource    To lpsSource
79998>>>    If iOperation Ne vFO_DELETE Begin
80000>>>      GetAddress Of sDestination      To lpsDestination
80001>>>      Put lpsDestination To sShFileOp At vtShFileOpStruct.pTo
80002>>>    End
80002>>>>
80002>>>  
80002>>>    Put iOperation     To sShFileOp At vtShFileOpStruct.wFunc
80003>>>    Put lpsSource      To sShFileOp At vtShFileOpStruct.pFrom
80004>>>    Put iFlags         To sShFileOp At vtShFileOpStruct.fFlags
80005>>>  
80005>>>    GetAddress Of sShFileOp To lpShFileOp
80006>>>  
80006>>>    Move (vWin32_SHFileOperation(lpShFileOp)) To iRetVal
80007>>>    GetBuff From sShFileOp At vtShFileOpStruct.fAnyOperationsAborted To bUserAbort
80008>>>    If (bUserAbort <> 0) Begin
80010>>>      Move 80 To iRetVal  // file Operation Aborted by USER
80011>>>    End
80011>>>>
80011>>>    Function_Return (iRetVal)
80012>>>  End_Function // FileOperation
80013>>>    
