89931>>>
89931>>>    // We might have a split Sql script where the info about which database to use is
89931>>>    // put on top of the Sql script, we then need to save it to be able to retrieve it later and
89931>>>    // insert it for scriplets to come after the first one.
89931>>>    Function _SqlFormatStatement String sStmt Returns String
89933>>>        String sUseDatabase sTmp sUseKeyWord sCreateViewKeyWord sDBOKeyWord sNoCountKeyWord sDriverID
89933>>>        Integer iStart iEnd iDbType
89933>>>        Boolean bOK
89933>>>        
89933>>>        Get piDbType to iDbType 
89934>>>        Get psDriverID to sDriverID
89935>>>        Get _SqlFindKeyWord CI_SQLUse          to sUseKeyWord  
89936>>>        Get _SqlFindKeyWord CI_SQLSetNoCountOn to sNoCountKeyWord
89937>>>        Get _SqlFindKeyWord CI_SQLCreateView   to sCreateViewKeyWord            
89938>>>        Get _SqlFindKeyWord CI_SQLDBO          to sDBOKeyWord 
89939>>>        Move (Replaces(" ", sStmt, "")) to sTmp
89940>>>        If (Uppercase(sTmp) contains (sUseKeyWord +"[")) Begin
89942>>>            Move (Pos("[", (Uppercase(sTmp)))) to iStart
89943>>>            Move (Pos("]", sTmp)) to iEnd
89944>>>            Move (Mid(sTmp, (iEnd -iStart +1), iStart)) to sUseDatabase
89945>>>            Move (sUseKeyWord * sUseDatabase + " ") to sUseDatabase
89946>>>            Set Private.psUseDatabase to sUseDatabase
89947>>>        End
89947>>>>
89947>>>        Else Begin   
89948>>>            Move (Uppercase(sStmt)) to sTmp
89949>>>
89949>>>            // A "Create View" statement _must_ be the very first words in a Sql statement.
89949>>>            If (not(sTmp contains sCreateViewKeyWord)) Begin
89951>>>                Get Private.psUseDatabase to sUseDatabase
89952>>>                Move (Insert(sUseDatabase, sStmt, 1)) to sStmt
89953>>>            End 
89953>>>>
89953>>>            
89953>>>            // This is a bit special to place here but was done so because it was easier that way.
89953>>>            // We will get an error when trying to create a view if it already exists.
89953>>>            // So to avoid such errors; we first remove it & then recreate it.
89953>>>            Else If (sTmp contains sCreateViewKeyWord) Begin 
89956>>>                // Make sure we only have one space between statements/words.  
89956>>>                Move (Replaces("  ", sTmp, " ")) to sTmp
89957>>>                Move (Replace(sCreateViewKeyWord, sTmp, "")) to sTmp
89958>>>                Move (Trim(sTmp)) to sTmp
89959>>>                Move (Pos(" ", sTmp)) to iEnd
89960>>>                Move (Left(sTmp, iEnd)) to sTmp
89961>>>                If ((not(sTmp contains ("[" + sDBOKeyWord + "]."))) and (not(sTmp contains (sDBOKeyWord + ".")))) Begin
89963>>>                    Move (sDBOKeyWord + "." + Trim(sTmp)) to sTmp
89964>>>                End  
89964>>>>
89964>>>                Move (Trim(sTmp)) to sTmp
89965>>>                // Remove data view as it already exists!
89965>>>                Get SqlViewRemove sDriverID sTmp to bOK
89966>>>            End
89966>>>>
89966>>>        End
89966>>>>
89966>>>
89966>>>        Function_Return sStmt    
89967>>>    End_Function
89968>>>    
89968>>>    // Returns the proper Sql language key word(s) for the passed SQL key-word constant
89968>>>    Function _SqlFindKeyWord Integer iSQLKeywordConstant Returns String
89970>>>        String sRetval         
89970>>>        Integer iDbType iSize iItem iIndex
89970>>>        tSQLKeyWords[] SQLKeywordArray 
89970>>>        tSQLKeyWords[] SQLKeywordArray 
89971>>>        tSQLKeyWords   SQLKeyWords
89971>>>        tSQLKeyWords   SQLKeyWords
89971>>>        
89971>>>        // Sql back-end type. E.g. MS-SQL, MySQL, Oracle, DB2...
89971>>>        Get piDbType to iDbType
89972>>>        Move iDbType             to SQLKeyWords.iSQLDbType
89973>>>        Move iSQLKeywordConstant to SQLKeyWords.iSQLWord
89974>>>         
89974>>>        Get paSQLKeywordArray to SQLKeywordArray
89975>>>        Move (SearchArray(SQLKeyWords, SQLKeywordArray, Self, RefFunc(CompareFindSQLKeyWords))) to iIndex
89976>>>        Move SQLKeywordArray[iIndex].sSQLPhrase to sRetval
89977>>>
89977>>>        Function_Return sRetval
89978>>>    End_Function
89979>>>    
89979>>>    // Function will "clean/sanitize" the script by removing all comments and blank lines.
89979>>>    Function _SqlUtilSanitizeScript tSQLScriptArray SqlScriptArray Returns tSQLScriptArray[] 
89981>>>        String[] sSQLScriptArray
89982>>>        String sText sLine sTmp sCommentStart sCommentEnd sDashComment
89982>>>        Integer iCh iSize iArgSize iPos iCount
89982>>>        Boolean bCommentStart bCommentEnd bDashComment
89982>>>        
89982>>>        Move False to bCommentStart
89983>>>        Move False to bCommentEnd 
89984>>>        Move False to bDashComment                                    
89985>>>        Move "/*"  to sCommentStart   // These are the standard comment start & stop tokens...
89986>>>        Move "*/"  to sCommentEnd
89987>>>        Move "--"  to sDashComment    // ...but a comment can also start with two dashes "--".
89988>>>
89988>>>        Move (SizeOfArray(SqlScriptArray.sSQLScriptArray)) to iSize
89989>>>        Decrement iSize
89990>>>        Move "" to sText  
89991>>>        
89991>>>        For iCount from 0 to iSize
89997>>>>
89997>>>            Move SqlScriptArray.sSQLScriptArray[iCount] to sLine
89998>>>            Move (Trim(sLine)) to sTmp
89999>>>            If (sTmp <> "") Begin
90001>>>                Move (Left(sTmp, 2) = sDashComment) to bDashComment
90002>>>                If (bCommentStart = False) Begin
90004>>>                    Move (Left(sTmp, 2) = sCommentStart) to bCommentStart
90005>>>                    If (bCommentStart = False) Begin
90007>>>                    End
90007>>>>
90007>>>                End
90007>>>>
90007>>>                Move (sTmp contains sCommentEnd) to bCommentEnd
90008>>>                If (bCommentEnd = True) Begin
90010>>>                    Move False to bCommentStart
90011>>>                End
90011>>>>
90011>>>                If (bDashComment = False and bCommentStart = False and bCommentEnd = False) Begin
90013>>>                    Move sLine to sSQLScriptArray[SizeOfArray(sSQLScriptArray)] 
90014>>>                End
90014>>>>
90014>>>            End
90014>>>>
90014>>>        Loop 
90015>>>>
90015>>>        
90015>>>        // Update the retval struct array:    
90015>>>        Move sSQLScriptArray to SqlScriptArray.sSQLScriptArray
90016>>>        Function_Return SqlScriptArray
90017>>>    End_Function
90018>>>
90018>>>    // *** Database API Functions: ***
90018>>>    // Instead of using Sql Scripts (ESQL), we can opt to use the DataFlex Database API's to 
90018>>>    // make changes/updates to the database.
90018>>>    //
90018>>>    //
90018>>>    // This might not do what you think - Here's what it does:
90018>>>    // It checks that the passed hTable TableName in filelist.cfg is exactly the same as at the SQL back-end.
90018>>>    // If that is True; it creates an .int file for it and changes Filelist.cfg to point
90018>>>    // to the SQL table.
90018>>>    // Typical usage for this function is when an entry exists in the Filelist for a table and the table
90018>>>    // already exists in SQL. 
90018>>>    // This is a bit fiddly as the DF_FILE_PHYSICAL_NAME attribute can only be set inside a 
90018>>>    // Structure_Start ... Structure_End operation when creating a NEW table. Thus it cannot be set when 
90018>>>    // restructuring an existing table.
90018>>>    Function ApiTableAttachToSQL Handle hTable Boolean bUseConnID Returns Boolean
90020>>>        Boolean bExists bOpened bOK bSystemFile bMertechDriver bUseConnectionID
90020>>>        String sDriverID sTableName sConnectionID sConnectionString sDisplayName sRootName sLogicalName sPhysicalName sSchema
90020>>>        Handle hToTable 
90020>>>        Integer iPos
90020>>>        
90020>>>        Move True to bUseConnectionID
90021>>>        If (num_arguments > 1) Begin
90023>>>            Move bUseConnID to bUseConnectionID
90024>>>        End                                    
90024>>>>
90024>>>        
90024>>>        Get psDriverID to sDriverID
90025>>>        // If the table doesn't exist on the SQL back-end we do nothing.
90025>>>        Get SqlUtilCheckIfTableHandleExists hTable sDriverID to bExists
90026>>>        If (bExists = False) Begin
90028>>>            Function_Return False
90029>>>        End
90029>>>>
90029>>>        
90029>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
90030>>>        If (bOK = False) Begin
90032>>>            Function_Return False
90033>>>        End
90033>>>>
90033>>>        
90033>>>        // Then we need to check that the function hasn't been called before; which in case
90033>>>        // we do nothing
90033>>>        Get SQLUtilTableIsAttached sDriverID hTable to bExists
90034>>>        If (bExists = True) Begin
90036>>>            Function_Return False
90037>>>        End
90037>>>>
90037>>>        
90037>>>        Get psConnectionID     to sConnectionID
90038>>>        Get psConnectionString to sConnectionString 
90039>>>        If (sConnectionID = "" or sConnectionString = "") Begin
90041>>>            Error DFERR_PROGRAM ("An SQL connection has NOT been setup correctly. Could not attach table:" * String(hTable) * "to SQL")
90042>>>>
90042>>>            Function_Return False
90043>>>        End                      
90043>>>>
90043>>>
90043>>>        Get psSchema to sSchema
90044>>>        If (sSchema = "") Begin
90046>>>            Get _SqlFindKeyWord CI_SQLDBO to sSchema  
90047>>>        End
90047>>>>
90047>>>
90047>>>        Get IsMertechDriver sDriverID to bMertechDriver
90048>>>        
90048>>>        // Mertech drivers don't use connection id's, so if the passed bUseConnectionID = True that
90048>>>        // was a programmer's error and we adjust for it here.
90048>>>        If (bMertechDriver = True) Begin
90050>>>            Move False to bUseConnectionID
90051>>>        End
90051>>>>
90051>>>            
90051>>>        // If we should use a connection id we need to check it exists; 
90051>>>        // else we create it before attempting creating the table
90051>>>        If (bUseConnectionID = True) Begin  
90053>>>            Get AutoConnectionIDLogin to bOK
90054>>>            If (bOk = False) Begin
90056>>>                Error DFERR_PROGRAM ("The Connection ID:" * sConnectionID * "could not be created and therefor the table can't be created.")
90057>>>>
90057>>>                Function_Return False
90058>>>            End
90058>>>>
90058>>>        End
90058>>>>
90058>>>            
90058>>>        Get_Attribute DF_FILE_ROOT_NAME of hTable to sRootName
90061>>>        Get _TableNameOnly sRootName to sRootName             
90062>>>        If (sRootName = "") Begin
90064>>>            Function_Return False
90065>>>        End
90065>>>>
90065>>>        Move (sRootName + ".int")                    to sPhysicalName       
90066>>>        Get_Attribute DF_FILE_LOGICAL_NAME of hTable to sLogicalName
90069>>>        Get_Attribute DF_FILE_DISPLAY_NAME of hTable to sDisplayName
90072>>>        If (sDisplayName contains ".") Begin
90074>>>            Move (Pos(".", sDisplayName)) to iPos  
90075>>>            Move (Mid(sDisplayName, 200 ,(iPos + 1))) to sDisplayName
90076>>>            Move (sSchema + "." + sDisplayName)       to sDisplayName
90077>>>        End
90077>>>>
90077>>>        If (not(Lowercase(sDisplayName) contains Lowercase(sSchema + "."))) Begin
90079>>>            Move (Lowercase(sSchema) + "." + sDisplayName) to sDisplayName
90080>>>        End
90080>>>>
90080>>>        
90080>>>        // ToDo: Needs to be revised. Should be able to connect to SQL without table already exist?
90080>>>        Open hTable Mode DF_EXCLUSIVE
90082>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpened
90085>>>        If (bOpened = False) Begin 
90087>>>            Error DFERR_PROGRAM ("Function ApiTableAttachToSQL - Could not open table number:" * String(hTable) * sLogicalName)
90088>>>>
90088>>>            Function_Return False
90089>>>        End                      
90089>>>>
90089>>>        
90089>>>        If (ghoProgressBar <> 0) Begin
90091>>>            Send DoAdvance of ghoProgressBar
90092>>>        End
90092>>>>
90092>>>        // Note: The hToTable will get changed by the Structure_xxx command...
90092>>>        Move hTable to hToTable 
90093>>>        Move False to Err       
90094>>>        
90094>>>        // We now create a stub .int file and after Structure_end and also change the Filelist.cfg,
90094>>>        // then we do a pseudo .int file change with the "SqlUtilUpdateIntFile" function. After that we have
90094>>>        // a proper and updated .int file.
90094>>>        Get_Attribute DF_FILE_IS_SYSTEM_FILE of hTable to bSystemFile  
90097>>>        Get SqlUtilCreateIntFile hTable sDriverID sConnectionID True bSystemFile to bOK
90098>>>        
90098>>>        Structure_Start hToTable sDriverID
90099>>>            If (bUseConnectionID = True) Begin  
90101>>>                Set_Attribute DF_FILE_LOGIN     of hToTable to (CS_DFCONNID + "=" + sConnectionID)
90104>>>            End
90104>>>>
90104>>>            Else Begin
90105>>>                Set_Attribute DF_FILE_LOGIN     of hToTable to sConnectionString
90108>>>            End
90108>>>>
90108>>>            Set_Attribute DF_FILE_OWNER         of hToTable to (Lowercase(sSchema))
90111>>>            // For unknown reason the above sometimes triggers an error and it doesn't help to try to trap the error; so we cheat...
90111>>>            Move False to Err
90112>>>            Move 0 to LastErr
90113>>>        Structure_End hToTable 
90115>>>        
90115>>>        Move (not(Err)) to bOK
90116>>>        If (bOK = True) Begin
90118>>>            // The attributes set above will always trigger an error
90118>>>            // We also adjust the Filelist entries
90118>>>            Set_Attribute DF_FILE_ROOT_NAME    of hTable to (sDriverID + ":" + sRootName)
90121>>>            Set_Attribute DF_FILE_LOGICAL_NAME of hTable to sLogicalName
90124>>>            Set_Attribute DF_FILE_DISPLAY_NAME of hTable to sDisplayName
90127>>>            
90127>>>            // This pseudo updates the .int file to make it up-to-date with the SQL back-end.
90127>>>            Get SqlUtilUpdateIntFile hTable to bOK
90128>>>        End
90128>>>>
90128>>>          
90128>>>        Function_Return (bOK = True)
90129>>>    End_Function
90130>>>    
90130>>>    // Sample usage:    
90130>>>    //    Get ApiTableChangeAttribute SysInfo.File_Number DF_FILE_IS_SYSTEM_FILE True to bOK
90130>>>    //    Get ApiTableChangeAttribute OrderHea.File_Number DF_FILE_REUSE_DELETED DF_FILE_DELETED_NOREUSE to bOK
90130>>>    Function ApiTableChangeAttribute Handle hTable Integer iAttribute Integer iValue Returns Boolean
90132>>>        Boolean bOK
90132>>>        
90132>>>        Get AutoConnectionIDLogin to bOK
90133>>>        Move False to Err
90134>>>        Open hTable Mode DF_EXCLUSIVE
90136>>>        Structure_Start hTable
90137>>>            Set_Attribute iAttribute of hTable to iValue
90140>>>        Structure_End hTable 
90142>>>
90142>>>        Function_Return (Err = False)
90143>>>    End_Function
90144>>>    
90144>>>    // To use a filelist slot for the passed FileName, TableName & DisplayName,
90144>>>    // or to change the filelist slot names.    
90144>>>    Function ApiTableChangeFileListSlot String sRootName String sLogicalName String sDisplayName Handle hTable String sDriverID Returns Boolean       
90146>>>        Move False to Err
90147>>>        Boolean bExists
90147>>>        
90147>>>        Move False to Err
90148>>>        Get UtilTableNumberIsInUse hTable to bExists
90149>>>        If (bExists = False) Begin
90151>>>            Function_Return False
90152>>>        End
90152>>>>
90152>>>
90152>>>        If (ghoProgressBar <> 0) Begin
90154>>>            Send DoAdvance of ghoProgressBar
90155>>>        End
90155>>>>
90155>>>        // If all strings are empty it means that we should remove this entry from filelist.
90155>>>        If (sRootName = "" and sLogicalName = "" and sDisplayName = "") Begin
90157>>>            Set_Attribute DF_FILE_ROOT_NAME     of hTable to ""
90160>>>            Set_Attribute DF_FILE_LOGICAL_NAME  of hTable to ""
90163>>>            Set_Attribute DF_FILE_DISPLAY_NAME  of hTable to ""
90166>>>            Function_Return (Err = False) // And we're done.
90167>>>        End
90167>>>>
90167>>>        
90167>>>        If (sDriverID <> DATAFLEX_ID) Begin
90169>>>            Set_Attribute DF_FILE_ROOT_NAME of hTable to (sDriverID + ":" + sRootName)
90172>>>        End 
90172>>>>
90172>>>        Else Begin
90173>>>            Set_Attribute DF_FILE_ROOT_NAME of hTable to sRootName
90176>>>        End
90176>>>>
90176>>>            
90176>>>        Set_Attribute DF_FILE_LOGICAL_NAME  of hTable to sLogicalName
90179>>>        
90179>>>        If (sDriverID <> DATAFLEX_ID and not(Uppercase(sDisplayName) contains "DBO.")) Begin
90181>>>            Set_Attribute DF_FILE_DISPLAY_NAME  of hTable to ("dbo." + sDisplayName)
90184>>>        End
90184>>>>
90184>>>        Else Begin
90185>>>            Set_Attribute DF_FILE_DISPLAY_NAME  of hTable to sDisplayName
90188>>>        End
90188>>>>
90188>>>        
90188>>>        Function_Return (Err = False)
90189>>>    End_Function
90190>>>    
90190>>>    Function ApiTableChangeRecordLength Handle hTable Integer iRecordLength Returns Boolean
90192>>>        Boolean bOK
90192>>>        
90192>>>        Get AutoConnectionIDLogin to bOK
90193>>>        Move False to Err
