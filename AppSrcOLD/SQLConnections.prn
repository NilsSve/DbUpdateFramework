85294>>>>>>>Class cDbUpdateORAFLEXDriver is a cDbUpdateGenericDatabaseDriver
85295>>>>>>>    Function DbLogin String sConnectionString String sServer String sDatabase Boolean bTrusted String sUserID String sPassword Returns Boolean
85297>>>>>>>        Boolean bLoginSuccessful
85297>>>>>>>        String sDriverID sErrorMsg
85297>>>>>>>        String sVal
85297>>>>>>>        Integer iPos
85297>>>>>>>
85297>>>>>>>        Get psDriverID to sDriverID
85298>>>>>>>        Move (Pos("/", sServer)) to iPos
85299>>>>>>>        If (iPos = 0) Begin
85301>>>>>>>            If (sDatabase <> "") Begin
85303>>>>>>>                Move (sServer + "/" + sDatabase) to sServer        
85304>>>>>>>            End
85304>>>>>>>>
85304>>>>>>>        End
85304>>>>>>>>
85304>>>>>>>        // For the Mertech driver, using the Err indicator is the sanctioned way
85304>>>>>>>        Move False to Err
85305>>>>>>>        // For Oracle I don't believe "Trusted" doesn't exist.
85305>>>>>>>        Login sServer sUserId sPassword sDriverID
85307>>>>>>>        
85307>>>>>>>        Move (not(Err)) to bLoginSuccessful
85308>>>>>>>        Function_Return bLoginSuccessful
85309>>>>>>>    End_Function
85310>>>>>>>End_Class
