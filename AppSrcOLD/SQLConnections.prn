84998>>>>>>>>>    // Custom array find function. It compares both the iSQLWord & iSQLDbType params.
84998>>>>>>>>>    Function CompareFindSQLKeyWords tSQLKeyWords SQLKeywords1 tSQLKeyWords SQLKeywords2 Returns Integer
85000>>>>>>>>>        If (SQLKeywords1.iSQLWord = SQLKeywords2.iSQLWord and SQLKeywords1.iSQLDbType = SQLKeywords2.iSQLDbType) Begin
85002>>>>>>>>>            Function_Return (EQ)
85003>>>>>>>>>        End
85003>>>>>>>>>>
85003>>>>>>>>>        Function_Return (NE)
85004>>>>>>>>>    End_Function
85005>>>>>>>>>    
85005>>>>>>>>>    // Custom array sort function. It compares both the iSQLWord & iSQLDbType params.
85005>>>>>>>>>    Function CompareSortSQLKeyWords tSQLKeyWords SQLKeywords1 tSQLKeyWords SQLKeywords2 Returns Integer
85007>>>>>>>>>        If (SQLKeywords1.iSQLWord   < SQLKeywords2.iSQLWord) Begin
85009>>>>>>>>>            Function_Return (LT)
85010>>>>>>>>>        End
85010>>>>>>>>>>
85010>>>>>>>>>        If (SQLKeywords1.iSQLWord   > SQLKeywords2.iSQLWord) Begin
85012>>>>>>>>>            Function_Return (GT)
85013>>>>>>>>>        End
85013>>>>>>>>>>
85013>>>>>>>>>        If (SQLKeywords1.iSQLDbType < SQLKeywords2.iSQLDbType) Begin
85015>>>>>>>>>            Function_Return (LT)
85016>>>>>>>>>        End
85016>>>>>>>>>>
85016>>>>>>>>>        If (SQLKeywords1.iSQLDbType > SQLKeywords2.iSQLDbType) Begin
85018>>>>>>>>>            Function_Return (GT)
85019>>>>>>>>>        End
85019>>>>>>>>>>
85019>>>>>>>>>
85019>>>>>>>>>        Function_Return (EQ)    
85020>>>>>>>>>    End_Function
