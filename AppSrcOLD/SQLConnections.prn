95910>>>>>>>
95910>>>>>>>    Procedure OnMoveValueOutByValue
95912>>>>>>>        String sValue
95912>>>>>>>        Handle hoInvokingObject hoCol  hoDataSource
95912>>>>>>>        Integer iRow iCol
95912>>>>>>>        Integer[] SelRowsIndexes
95913>>>>>>>
95913>>>>>>>        Get phoInvokingObject to hoInvokingObject
95914>>>>>>>        Get pSelectedRows to SelRowsIndexes
95915>>>>>>>        If (SizeOfArray(SelRowsIndexes)>0) Begin
95917>>>>>>>            Get piUpdateColumn to iCol
95918>>>>>>>            Get ColumnObject iCol to hoCol
95919>>>>>>>            Get RowValue of hoCol SelRowsIndexes[0] to sValue
95920>>>>>>>            Set Value of hoInvokingObject to sValue
95921>>>>>>>            Set Item_Changed_State of hoInvokingObject to True
95922>>>>>>>        End
95922>>>>>>>>
95922>>>>>>>    End_Procedure
