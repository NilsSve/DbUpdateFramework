97714>>>>>    Function AddProgramToStudioToolsMenu String sStudioVersion Returns Integer
97717>>>>>        Boolean bOk bExists bOpen
97717>>>>>        String sKey sValue sProgramPath sProgram sProduct sStudioPath
97717>>>>>        Handle hoReg hoArray
97717>>>>>        Integer i iItems iCreated iRetval
97717>>>>>
97717>>>>>        Move False to bOk
97718>>>>>        Move (CS_StudioPath + (Trim(sStudioVersion)))  to sStudioPath
97719>>>>>        If (sStudioVersion > "17.1") Begin
97721>>>>>            Move (Replace("Visual ", sStudioPath, "")) to sStudioPath
97722>>>>>        End
97722>>>>>>
97722>>>>>
97722>>>>>        Get psProgramPath of (phoWorkspace(ghoApplication)) to sProgramPath
97723>>>>>        Get PathAtIndex of (phoWorkspace(ghoApplication)) sProgramPath 1 to sProgramPath
97724>>>>>        Get vFolderFormat sProgramPath to sProgramPath
97725>>>>>        Get psProduct     of (phoWorkspace(ghoApplication)) to sProduct
97726>>>>>        Get Module_Name to sProgram
97727>>>>>        Get Create U_cRegistry to hoReg
97728>>>>>        Set phRootKey of hoReg to HKEY_CURRENT_USER
97729>>>>>
97729>>>>>        // First check if the DataFlex version is installed
97729>>>>>        Get KeyExists of hoReg sStudioPath to bExists
97730>>>>>        If (bExists = False) Begin
97732>>>>>            Send Destroy of hoReg
97733>>>>>            Function_Return cx_RegKeyVDFKeyDoesNotExist
97734>>>>>        End
97734>>>>>>
97734>>>>>
97734>>>>>        // Then check if any tools have been installed in the Tools Menu.
97734>>>>>        // If no tools created yet, create the Tools registry key.
97734>>>>>        Move (sStudioPath + CS_StudioTools) to sStudioPath
97735>>>>>        Get KeyExists of hoReg sStudioPath to bExists
97736>>>>>        If (bExists = False) Begin
97738>>>>>            Set pfAccessRights of hoReg to KEY_ALL_ACCESS
97739>>>>>            Get CreateKey of hoReg sStudioPath to iCreated
97740>>>>>            If (iCreated <> 0) Begin
97742>>>>>                Move cx_RegkeyFailed to iRetval
97743>>>>>            End
97743>>>>>>
97743>>>>>            Else Begin
97744>>>>>                Move True to bExists
97745>>>>>            End
97745>>>>>>
97745>>>>>        End
97745>>>>>>
97745>>>>>
97745>>>>>        If (bExists = True) Begin
97747>>>>>            Get OpenKey of hoReg sStudioPath to bOk
97748>>>>>            If (bOk = True) Begin
97750>>>>>                Get Create U_Array to hoArray
97751>>>>>                Get GetSubkeys of hoReg hoArray to iItems
97752>>>>>                Decrement iItems
97753>>>>>                Move False to bExists
97754>>>>>                Set pfAccessRights of hoReg to KEY_READ
97755>>>>>                // Check if the key already exists:
97755>>>>>                For i from 0 to iItems
97761>>>>>>
97761>>>>>                    Get Value of hoArray item i to sKey
97762>>>>>                    Move (sStudioPath + "\" + sKey) to sKey
97763>>>>>                    Get OpenKey of hoReg sKey to bOpen
97764>>>>>                    If (bOpen = True) Begin
97766>>>>>                        Get ReadString of hoReg CS_Name to sValue
97767>>>>>                        If (sValue = sProduct) Move True to bExists
97770>>>>>                    End
97770>>>>>>
97770>>>>>                Loop
97771>>>>>>
97771>>>>>                Send Destroy of hoArray
97772>>>>>                If (bExists = False) Begin
97774>>>>>                    Set pfAccessRights of hoReg to KEY_ALL_ACCESS
97775>>>>>                    // We need to create the next key number:
97775>>>>>                    // The studio expect tools menu items to be numbered 1,2,3...n
97775>>>>>                    Increment iItems
97776>>>>>                    Increment iItems
97777>>>>>                    Get CreateKey of hoReg (sStudioPath + "\" + String(iItems)) to iCreated
97778>>>>>                    If (iCreated = 0) Begin
97780>>>>>                        Send WriteString of hoReg CS_Name sProduct
97781>>>>>                        // From DataFlex 16 and up the params for the Studio's Tools menu changed slightly:
97781>>>>>                        If (sStudioVersion >= "16.0") Begin
97783>>>>>                            Send WriteString of hoReg CS_Command (sProgramPath + sProgram)
97784>>>>>                            Send WriteString of hoReg CS_CommandLine (psTag(Self))
97785>>>>>                        End
97785>>>>>>
97785>>>>>                        Else Begin
97786>>>>>                            Send WriteString of hoReg CS_CommandLine ('"' + sProgramPath + sProgram + ".exe" + '"' * psTag(Self))
97787>>>>>                            Move CX_InstalledOkVdfUnder16 to iRetval
97788>>>>>                        End
97788>>>>>>
97788>>>>>                        Send WriteDword  of hoReg CS_Separator 1
97789>>>>>                        Move cx_RegKeyCreated to iRetval
97790>>>>>                    End
97790>>>>>>
97790>>>>>                    Else Begin
97791>>>>>                        Move cx_RegkeyFailed to iRetval
97792>>>>>                    End
97792>>>>>>
97792>>>>>                End
97792>>>>>>
97792>>>>>                Else Begin
97793>>>>>                    Move cx_RegKeyAlreadyExist to iRetval
97794>>>>>                End
97794>>>>>>
97794>>>>>                Send CloseKey of hoReg
97795>>>>>            End
97795>>>>>>
97795>>>>>        End
97795>>>>>>
97795>>>>>
97795>>>>>        Send Destroy of hoReg
97796>>>>>        Function_Return iRetval
97797>>>>>    End_Function
