84761>>>>>>>>>>>        Function_Return hSQL
84762>>>>>>>>>>>    End_Function
84763>>>>>>>>>>>    
84763>>>>>>>>>>>    Procedure SQLSetConnect String sDriver String sConnect
84765>>>>>>>>>>>        Set psDefaultDriver to sDriver
84766>>>>>>>>>>>        Set psDefaultConnection to sConnect
84767>>>>>>>>>>>    End_Procedure
84768>>>>>>>>>>>    
84768>>>>>>>>>>>    Function SQLConnect String sDriver String sConnect String sUsername String sPassword Returns Handle
84770>>>>>>>>>>>        Handle hSql
84770>>>>>>>>>>>        Boolean bOK
84770>>>>>>>>>>>  
84770>>>>>>>>>>>        Get CreateHandle to hSql
84771>>>>>>>>>>>        
84771>>>>>>>>>>>        If (sDriver = "" and sConnect = "") Begin
84773>>>>>>>>>>>            Move (psDefaultDriver(Self)) to sDriver
84774>>>>>>>>>>>            Move (psDefaultConnection(Self)) to sConnect
84775>>>>>>>>>>>        End
84775>>>>>>>>>>>>
84775>>>>>>>>>>>        
84775>>>>>>>>>>>        If (num_arguments>2) Begin
84777>>>>>>>>>>>            Set psUsername of hSql to sUsername
84778>>>>>>>>>>>            Set psPassword of hSql to sPassword
84779>>>>>>>>>>>        End
84779>>>>>>>>>>>>
84779>>>>>>>>>>>        
84779>>>>>>>>>>>        Get SQLConnect of hSql sDriver sConnect to bOK
84780>>>>>>>>>>>        If (not(bOK)) Begin
84782>>>>>>>>>>>            Send FreeHandle of hSQL
84783>>>>>>>>>>>            Function_Return 0
84784>>>>>>>>>>>        End
84784>>>>>>>>>>>>
84784>>>>>>>>>>>        
84784>>>>>>>>>>>        Function_Return hSql
84785>>>>>>>>>>>    End_Function
84786>>>>>>>>>>>
84786>>>>>>>>>>>    Function SQLFileConnect Integer iFileNum Returns Integer
84788>>>>>>>>>>>        Handle hSql
84788>>>>>>>>>>>        Boolean bOK
84788>>>>>>>>>>>
84788>>>>>>>>>>>        //*** Allocate a new handle
84788>>>>>>>>>>>        Get CreateHandle to hSql
84789>>>>>>>>>>>        Get SQLFileConnect of hSql iFileNum to bOK
84790>>>>>>>>>>>
84790>>>>>>>>>>>        //*** If failure, kill the handle and return a 0 handle
84790>>>>>>>>>>>        If (not(bOK)) Begin
84792>>>>>>>>>>>            Send FreeHandle of hSql
84793>>>>>>>>>>>            Function_Return 0
84794>>>>>>>>>>>        End
84794>>>>>>>>>>>>
84794>>>>>>>>>>>
84794>>>>>>>>>>>        Function_Return hSql
84795>>>>>>>>>>>    End_Function // SQLFileConnect
84796>>>>>>>>>>>    
84796>>>>>>>>>>>End_Class
