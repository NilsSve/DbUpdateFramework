86858>>>    Function _SqlCheckCurrentDriver String sDriverID Returns Boolean
86860>>>        Boolean bOK bMertechDriver
86860>>>        
86860>>>        Get IsDAWSQLDriver sDriverID to bOK
86861>>>
86861>>>        If (bOK = False) Begin
86863>>>            Get IsMertechDriver sDriverID to bOK
86864>>>        End                                     
86864>>>>
86864>>>
86864>>>        If (bOK = False) Begin        
86866>>>            Get IsMertechDriver sDriverID to bMertechDriver
86867>>>            If (bMertechDriver = True) Begin
86869>>>                Error DFERR_PROGRAM "Driver needs to be one of MSSQLDRV_ID, DB2_DRV_ID, ODBC_DRV_ID, SQLFLEX, ORAFLEX, MDSPgSQL or MDSMYSQL"
86870>>>>
86870>>>            End
86870>>>>
86870>>>            Else Begin
86871>>>                Error DFERR_PROGRAM "Driver needs to be one of MSSQLDRV_ID, DB2_DRV_ID or ODBC_DRV_ID"
86872>>>>
86872>>>            End
86872>>>>
86872>>>            Function_Return False
86873>>>        End
86873>>>>
86873>>>        
86873>>>        Function_Return True
86874>>>    End_Function
86875>>>            
86875>>>    Function IsDAWSQLDriver String sDriverID Returns Boolean
86877>>>        Boolean bOK
86877>>>        Move (sDriverID = MSSQLDRV_ID or sDriverID = DB2_DRV_ID or sDriverID = ODBC_DRV_ID) to bOK
