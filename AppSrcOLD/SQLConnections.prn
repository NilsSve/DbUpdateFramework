89680>>>    Function _SqlCheckCurrentDriver String sDriverID Returns Boolean
89682>>>        Boolean bOK                         
89682>>>        Integer iDriver
89682>>>        
89682>>>        If (sDriverID = DATAFLEX_ID) Begin
89684>>>            Function_Return False
89685>>>        End                      
89685>>>>
