89688>>>            Get IsMertechDriver sDriverID to bOK
89689>>>        End   
89689>>>>
89689>>>        
89689>>>        If (bOK = False) Begin        
89691>>>            Error DFERR_PROGRAM "Driver needs to be one of MSSQLDRV, DB2_DRV, ODBC_DRV, SQLFLEX, ORAFLEX, MDSPgSQL or MDSMySQL"
89692>>>>
