93967>>>    
93967>>>    // When dropping columns on some SQL back-ends they doesn't reclaim the space taken up by the columns dropped. 
93967>>>    // For data types that are stored inline in the rows (int for example) it may even take up space on 
93967>>>    // the new rows added after the alter statement. to get around this you need to create a clustered 
93967>>>    // index on the table _or_ rebuild the clustered Index if it already has one. Rebuilding the index 
93967>>>    // can be done with a REBUILD command after modifying the table. But be warned this can be slow on very big tables.
93967>>>    //   ALTER TABLE MyTable
93967>>>    //       REBUILD
93967>>>    Function _SqlUtilRemoveTableColumnMSSQL String sTableName String sColumnName Returns Boolean
93969>>>        Boolean bOK  
93969>>>        
93969>>>        If (Trim(sTableName) = "" or Trim(sColumnName) = "") Begin
93971>>>            Function_Return False
93972>>>        End                             
93972>>>>
93972>>>        
93972>>>        SQLIncludeScriptFile ..\Scripts\DropConstraintAndColumnNameMSSQL.sql as DropConstraintAndColumnNameMSSQL.sql
93972>>>        Get _SqlUtilRemoveTableColumnByScript "DropConstraintAndColumnNameMSSQL.sql" sTableName sColumnName to bOK
93973>>>        
93973>>>        Function_Return (bOK = True)
93974>>>    End_Function
93975>>>
93975>>>
93975>>>    // *** Helper functions with compiled sql script code ***
93975>>>    //  
93975>>>    // When dropping columns SQL Sever does not reclaim the space taken up by the columns dropped. 
93975>>>    // For data types that are stored inline in the rows (int for example) it may even take up space on 
93975>>>    // the new rows added after the alter statement. To get around this you need to create a clustered 
93975>>>    // index on the table or rebuild the clustered Index if it already has one. Rebuilding the index 
93975>>>    // can be done with a REBUILD command after modifying the table. But be warned this can be slow on very big tables.
93975>>>    //   ALTER TABLE MyTable
93975>>>    //       REBUILD
93975>>>    Function _SqlUtilRemoveTableColumnByScript String sMemScriptFile String sTableName String sColumnName Returns Boolean
93977>>>        tSQLScriptArray SQLScriptArray                      
93977>>>        tSQLScriptArray SQLScriptArray                      
93977>>>        String sDriverID sVal
93977>>>        Boolean bOK  
93977>>>        Integer iSize iCount
93977>>>        
93977>>>        If (Trim(sTableName) = "" or Trim(sColumnName) = "") Begin
93979>>>            Function_Return False
93980>>>        End                             
93980>>>>
93980>>>        
93980>>>        Get psDriverID to sDriverID
93981>>>        Get SqlUtilReadResource sMemScriptFile to SQLScriptArray
93982>>>        If (SQLScriptArray.bError = True) Begin
93984>>>            Function_Return False
93985>>>        End                     
93985>>>>
93985>>>        
93985>>>        Move (SizeOfArray(SQLScriptArray.sSQLScriptArray)) to iSize
93986>>>        Decrement iSize
93987>>>        
93987>>>        for iCount from 0 to iSize   
93993>>>>
93993>>>            If (SQLScriptArray.sSQLScriptArray[iCount] contains "TABLE_NAME_XXX") Begin
93995>>>                Move (Replaces("TABLE_NAME_XXX",  SQLScriptArray.sSQLScriptArray[iCount], String(sTableName))) to SQLScriptArray.sSQLScriptArray[iCount]
93996>>>            End
93996>>>>
93996>>>            If (SQLScriptArray.sSQLScriptArray[iCount] contains "COLUMN_NAME_XXX") Begin
93998>>>                Move (Replaces("COLUMN_NAME_XXX", SQLScriptArray.sSQLScriptArray[iCount], String(sColumnName))) to SQLScriptArray.sSQLScriptArray[iCount]
93999>>>            End
93999>>>>
93999>>>        Loop
94000>>>>
94000>>>        
94000>>>        Get SqlUtilExecuteEmbeddedScript SQLScriptArray sDriverID False "" to bOK
94001>>>        
94001>>>        Function_Return (bOK = True)
94002>>>    End_Function
