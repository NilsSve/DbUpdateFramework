86892>>>
86892>>>    // Sample sConnString: "SERVER=(local)\SQLEXPRESS;UID=dbuser;PWD=secret;DATABASE=OrderEntry;, 0"
86892>>>    // Pass a complete driver connection string
86892>>>    // Returns the following as a struct:
86892>>>    //   sServer, sDatabase, sUser, sPassword & True if Trusted_Connection is used.
86892>>>    // Finally also returns a boolean TRUE if trusted_connection=yes, else false is returned. 
86892>>>    //
86892>>>    Function DeComposeConnectionString String sDriverID String sConnectionString Returns tSQLConnection
86894>>>        tSQLConnection SQLConnection
86894>>>        tSQLConnection SQLConnection
86894>>>        String sValue sConnectionID sServer sDatabase sUserID sPassword
86894>>>        Boolean bTrusted bSilent bOK
86894>>>        Integer iPos
86894>>>        
86894>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
86895>>>        If (bOK = False) Begin
86897>>>            Function_Return SQLConnection
86898>>>        End
86898>>>>
86898>>>        
86898>>>        Move False to bTrusted  
86899>>>        Move False to bSilent         
86900>>>
86900>>>        Case Begin
86900>>>            Case (sDriverID = MSSQLDRV_ID) 
86902>>>                Get ParseKeyWord sConnectionString (CS_SQLIniServerKeyword + "=")   to sServer
86903>>>                Get ParseKeyWord sConnectionString (CS_SQLIniDatabaseKeyword + "=") to sDatabase
86904>>>                Get ParseKeyWord sConnectionString (CS_SQLIniTrustedKeyword + "=")  to sValue
86905>>>                Move (If(Uppercase(sValue) = "YES", True, False))                   to bTrusted
86906>>>                If (bTrusted = False) Begin
86908>>>                    Get ParseKeyWord sConnectionString (CS_SQLIniUIDKeyword + "=")  to sUserID
86909>>>                    Get ParseKeyWord sConnectionString (CS_SQLIniPWDKeyword + "=")  to sPassword
86910>>>                End
86910>>>>
86910>>>                Case Break
86911>>>                                     
86911>>>            Case (sDriverID = ODBC_DRV_ID)
86914>>>                Get ParseKeyWord sConnectionString (CS_SQLIniDSNKeyword + "=")      to sServer
86915>>>                Get ParseKeyWord sConnectionString (CS_SQLIniTrustedKeyword + "=")  to sValue
86916>>>                Move (If(Uppercase(sValue) = "YES", True, False))                   to bTrusted
86917>>>                If (bTrusted = False) Begin
86919>>>                    Get ParseKeyWord sConnectionString (CS_SQLIniUIDKeyword + "=")  to sUserID
86920>>>                    Get ParseKeyWord sConnectionString (CS_SQLIniPWDKeyword + "=")  to sPassword
86921>>>                End
86921>>>>
86921>>>                Case Break
86922>>>                 
86922>>>            Case (sDriverID = DB2_DRV_ID)
86925>>>                Get ParseKeyWord sConnectionString (CS_SQLIniDSNKeyword + "=")      to sServer
86926>>>                Get ParseKeyWord sConnectionString (CS_SQLIniUIDKeyword + "=")      to sUserID
86927>>>                Get ParseKeyWord sConnectionString (CS_SQLIniPWDKeyword + "=")      to sPassword
86928>>>                Case Break
86929>>>                 
86929>>>            Case (sDriverID = SQLFLEX) 
86932>>>                Get ParseKeyWord sConnectionString (CS_SQLIniServerKeyword + "=")   to sServer
86933>>>                Get ParseKeyWord sConnectionString (CS_SQLIniTrustedKeyword + "=")  to sValue
86934>>>                Move (If(Uppercase(sValue) = "YES", True, False))                   to bTrusted
86935>>>                If (bTrusted = False) Begin
86937>>>                    Get ParseKeyWord sConnectionString (CS_SQLIniUIDKeyword + "=")  to sUserID
86938>>>                    Get ParseKeyWord sConnectionString (CS_SQLIniPWDKeyword + "=")  to sPassword
86939>>>                End
86939>>>>
86939>>>                Case Break
86940>>>                                     
86940>>>            Case (sDriverID = ORAFLEX)
86943>>>                Get ParseKeyWord sConnectionString (CS_SQLIniDSNKeyword + "=")      to sServer
86944>>>                Get ParseKeyWord sConnectionString (CS_SQLIniDatabaseKeyword + "=") to sDatabase
86945>>>                If (sDatabase <> "" and (not(sServer contains "/"))) Begin
86947>>>                    Move (sServer + "/" + sDatabase)                                to sServer
86948>>>                End
86948>>>>
86948>>>                Get ParseKeyWord sConnectionString (CS_SQLIniUIDKeyword + "=")      to sUserID
86949>>>                Get ParseKeyWord sConnectionString (CS_SQLIniPWDKeyword + "=")      to sPassword
86950>>>                Case Break
86951>>>            
86951>>>            Case (sDriverID = MDSPgSQL)
86954>>>                Get ParseKeyWord sConnectionString (CS_SQLIniDSNKeyword + "=")      to sServer
86955>>>                Get ParseKeyWord sConnectionString (CS_SQLIniDatabaseKeyword + "=") to sDatabase
86956>>>                Get ParseKeyWord sConnectionString (CS_SQLIniUIDKeyword + "=")      to sUserID
86957>>>                Get ParseKeyWord sConnectionString (CS_SQLIniPWDKeyword + "=")      to sPassword
86958>>>                Case Break
86959>>>            
86959>>>            Case (sDriverID = MDSMySQL)
86962>>>                Get ParseKeyWord sConnectionString (CS_SQLIniDSNKeyword + "=")      to sServer
86963>>>                Get ParseKeyWord sConnectionString (CS_SQLIniDatabaseKeyword + "=") to sDatabase
86964>>>                Get ParseKeyWord sConnectionString (CS_SQLIniUIDKeyword + "=")      to sUserID
86965>>>                Get ParseKeyWord sConnectionString (CS_SQLIniPWDKeyword + "=")      to sPassword
86966>>>                Case Break
