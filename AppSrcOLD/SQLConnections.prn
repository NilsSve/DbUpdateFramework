88398>>>        Get UtilTableHandleToString hTable to sTableName
88399>>>        Get SqlUtilEnumerateTables sDriverID to sTablesArray  
88400>>>        Move (SizeOfArray(sTablesArray)) to iSize
88401>>>        Decrement iSize
88402>>>        For iCount from 0 to iSize
88408>>>>
88408>>>            Move sTablesArray[iCount] to sVal
88409>>>            If (Uppercase(sVal) = Uppercase(sTableName)) Begin
88411>>>                Move True to bExists
88412>>>                Move iSize to iCount // We're done!
88413>>>            End
88413>>>>
88413>>>        Loop
88414>>>>
88414>>>    
88414>>>        Function_Return bExists
88415>>>    End_Function   
88416>>>    
