81160>>>>>>>>>    // Procedure : Construct_Object
81160>>>>>>>>>    // Purpose   : Object constructor
81160>>>>>>>>>    Procedure Construct_Object
81162>>>>>>>>>        Forward Send Construct_Object
81164>>>>>>>>>
81164>>>>>>>>>        Property String     psProvider  MS_ENHANCED_PROV
81165>>>>>>>>>        Property Integer    piProvider  PROV_RSA_FULL
81166>>>>>>>>>        Property Integer    piCipher    CALG_RC4
81167>>>>>>>>>        Property Integer    piHash      CALG_MD5
81168>>>>>>>>>        
81168>>>>>>>>>        // Private properties
81168>>>>>>>>>        Property Handle     Private_phProv
81169>>>>>>>>>    End_Procedure
81170>>>>>>>>>    
81170>>>>>>>>>    
81170>>>>>>>>>    // Function : AcquireContext
81170>>>>>>>>>    // Purpose  : Acquire key container handle
81170>>>>>>>>>    Function AcquireContext Returns Handle
81172>>>>>>>>>        Integer iProvider
81172>>>>>>>>>        String sProvider
81172>>>>>>>>>        Handle hProv
81172>>>>>>>>>        Boolean bOk
81172>>>>>>>>>        Address addrProv
81172>>>>>>>>>        
81172>>>>>>>>>        Move 0 to hProv
81173>>>>>>>>>        Get piProvider to iProvider
81174>>>>>>>>>        Get psProvider to sProvider
81175>>>>>>>>>        
81175>>>>>>>>>        //  Determine address to be passed as provider
81175>>>>>>>>>        If (Trim(sProvider) <> "") Begin
81177>>>>>>>>>            Move (AddressOf(sProvider)) to addrProv
81178>>>>>>>>>        End
81178>>>>>>>>>>
81178>>>>>>>>>        Else Begin
81179>>>>>>>>>            Move 0 to addrProv
81180>>>>>>>>>        End
81180>>>>>>>>>>
81180>>>>>>>>>        
81180>>>>>>>>>        //  Acquire Crypto Context
81180>>>>>>>>>        Move (CryptAcquireContext(AddressOf(hProv),0,addrProv,iProvider,CRYPT_VERIFYCONTEXT)) to bOk
81181>>>>>>>>>        If (not(bOk) or hProv = 0) Begin
81183>>>>>>>>>            Move (CryptAcquireContext(AddressOf(hProv),0,addrProv,iProvider,CRYPT_NEWKEYSET ior CRYPT_VERIFYCONTEXT)) to bOk
81184>>>>>>>>>        End
81184>>>>>>>>>>
81184>>>>>>>>>        
81184>>>>>>>>>        If (not(bOk) or hProv = 0) Begin
81186>>>>>>>>>            // Fallback to original
81186>>>>>>>>>            Move (CryptAcquireContext(AddressOf(hProv),0,addrProv,iProvider,0)) to bOk
81187>>>>>>>>>            
81187>>>>>>>>>            If (not(bOk) or hProv = 0) Begin
81189>>>>>>>>>                Move (CryptAcquireContext(AddressOf(hProv),0,addrProv,iProvider,CRYPT_NEWKEYSET)) to bOk
81190>>>>>>>>>            End
81190>>>>>>>>>>
81190>>>>>>>>>        End
81190>>>>>>>>>>
81190>>>>>>>>>        Set Private_phProv to hProv
81191>>>>>>>>>        
81191>>>>>>>>>        Function_Return hProv
81192>>>>>>>>>    End_Function
81193>>>>>>>>>    
81193>>>>>>>>>    // Function : ReleaseContext
81193>>>>>>>>>    // Purpose  : Releases key container handle
81193>>>>>>>>>    Function ReleaseContext Handle hProv Returns Boolean
81195>>>>>>>>>        Function_Return (CryptReleaseContext(hProv,0))
81196>>>>>>>>>    End_Function
81197>>>>>>>>>    
81197>>>>>>>>>    // Function : CreateHash
81197>>>>>>>>>    // Purpose  : Creates hash object
81197>>>>>>>>>    Function CreateHash Handle hProv Returns Handle
81199>>>>>>>>>        Integer iAlgorithm
81199>>>>>>>>>        Handle hHash
81199>>>>>>>>>        Boolean bOk
81199>>>>>>>>>        
81199>>>>>>>>>        Move 0 to hHash
81200>>>>>>>>>        Get piHash to iAlgorithm
81201>>>>>>>>>        Move (CryptCreateHash(hProv,iAlgorithm,0,0,AddressOf(hHash))) to bOk
81202>>>>>>>>>        
81202>>>>>>>>>        Function_Return hHash
81203>>>>>>>>>    End_Function
81204>>>>>>>>>    
81204>>>>>>>>>    // Function : DestroyHash
81204>>>>>>>>>    // Purpose  : Destroys the hash object
