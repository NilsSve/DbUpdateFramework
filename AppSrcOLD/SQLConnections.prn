89574>>>    // Backs up an SQL database to a folder of choice. If no path is passed the SQL default backup folder
89574>>>    // will be used.
89574>>>    Function SqlUtilBackupDatabaseToDisk String sDatabase String sBackupName String sPath Boolean bShowProg Returns Boolean
89576>>>        Boolean bOK bExists bShowProgress      
89576>>>        String sStatement sDriverID 
89576>>>        tSQLScriptArray SQLScriptArray SQLScriptArrayPercentReady
89576>>>        tSQLScriptArray SQLScriptArray SQLScriptArrayPercentReady
89576>>>        Integer iDbType
89576>>>        
89576>>>        If (sDatabase = "") Begin
89578>>>            Error DFERR_PROGRAM "The database name was not passed as a parameter to the 'SqlUtilBackupDatabaseToDisk' function"
89579>>>>
89579>>>            Function_Return False
89580>>>        End
89580>>>>
89580>>>        If (sBackupName = "") Begin
89582>>>            Error DFERR_PROGRAM "The database backup name was not passed as a parameter to the 'SqlUtilBackupDatabaseToDisk' function"
89583>>>>
89583>>>            Function_Return False
89584>>>        End
89584>>>>
89584>>>            
89584>>>        // Create backup-folder if it doesn't exist
89584>>>        Get vFolderExists sPath to bExists
89585>>>        If (bExists = False) Begin
89587>>>            Get vCreateDirectory sPath to bOK
89588>>>            If (bOK = False) Begin
89590>>>                Error DFERR_PROGRAM ("Could not create database backup folder:" * sPath)
89591>>>>
89591>>>                Function_Return False
89592>>>            End
89592>>>>
89592>>>        End                     
89592>>>>
89592>>>        // Make sure the path ends with a back-slash
89592>>>        If (sPath <> "") Begin
89594>>>            Get vFolderFormat sPath to sPath
89595>>>        End
89595>>>>
89595>>>        
89595>>>        Get psDriverID to sDriverID  
89596>>>        Get piDbType   to iDbType        
89597>>>        If (num_arguments > 3) Begin
89599>>>            Move bShowProg to bShowProgress
89600>>>        End
89600>>>>
89600>>>        
89600>>>        Case Begin
89600>>>            Case (iDbType = EN_DbTypeMSSQL)
89602>>>                SQLIncludeScriptFile ..\Scripts\BackupMSSQLDatabase.sql as BackupMSSQLDatabase.sql
89602>>>                SQLIncludeScriptFile ..\Scripts\GetPercentageBackupCompletionMSSQL.sql as GetPercentageBackupCompletionMSSQL.sql
89602>>>                Get SqlUtilReadResource of ghoDbUpdateFunctionLibrary "BackupMSSQLDatabase.sql" sDriverID False to SQLScriptArray
89603>>>                Get SqlUtilReadResource of ghoDbUpdateFunctionLibrary "GetPercentageBackupCompletionMSSQL.sql" sDriverID False to SQLScriptArrayPercentReady
89604>>>                
89604>>>                Move SQLScriptArray.sSQLScriptArray[0] to sStatement
89605>>>                Move (Replaces("DATABASE_NAME_XXX", sStatement, sDatabase))   to sStatement
89606>>>                Move (Replaces("BACKUP_PATH_XXX",   sStatement, sPath))       to sStatement
89607>>>                Move (Replaces("BACKUP_NAME_XXX",   sStatement, sBackupName)) to sStatement
89608>>>                Move sStatement to SQLScriptArray.sSQLScriptArray[0]    
89609>>>                Get SqlUtilExecuteEmbeddedScript of ghoDbUpdateFunctionLibrary SQLScriptArray sDriverID False "" bShowProgress to bOK
89610>>>                Case Break
89611>>>            Case Else
89611>>>                Send Info_Box ("The SqlUtilBackupDatabaseToDisk function is currently not implemented for the driver:" * sDriverID + ". It would be great if you could spend a couple of minutes and add a little ESQL code snippet to make it work for that driver! Thanks for helping out.")
89612>>>        Case End
89612>>>        
89612>>>        Function_Return bOK    
89613>>>    End_Function
89614>>>
89614>>>    // Reads a resource that has been embedded by the compiler and writes it to disk.
89614>>>    // Pass the memory resource file reference and the filename to be created,
89614>>>    // including full path.
89614>>>    Procedure SqlUtilCreateFileFromMemory String sMemFileName String sFileName
89616>>>        String sText
89616>>>        Integer iCh iSize iArgSize  
89616>>>        
89616>>>        Move ("Resource:" + sMemFileName) to sMemFileName
89617>>>        Get Seq_Open_Input_Channel sMemFileName to iCh
89618>>>            Get_Channel_Size iCh to iSize
89619>>>            Get_Argument_Size to iArgSize
89620>>>            If (iSize > iArgSize) Begin
89622>>>                Set_Argument_Size iSize
89623>>>>
89623>>>            End
89623>>>>
89623>>>            Read_Block channel iCh sText iSize
89625>>>        Send Seq_Close_Channel iCh
89626>>>    
89626>>>        Get Seq_Open_Output_Channel sFileName to iCh
89627>>>            Write channel iCh sText
89629>>>        Send Seq_Close_Channel iCh
89630>>>    
89630>>>        If (iSize <> iArgSize) Begin
89632>>>            Set_Argument_Size iArgSize
89633>>>>
89633>>>        End
89633>>>>
89633>>>    
89633>>>        // Wait for file to be written to disk.
89633>>>        Sleep 2
89634>>>    End_Procedure 
