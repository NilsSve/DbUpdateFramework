95893>>>>>>>    // finds the target seed value in the updatecolumn. If we autoseed and there is a
95893>>>>>>>    // seed value (psSeedValue), attempt to find GE that value, else move to first row
95893>>>>>>>    // Suitable for augmentation
95893>>>>>>>    Procedure OnSeedData
95895>>>>>>>        Integer iUpdateColumn iSortColumn
95895>>>>>>>        Boolean bSeed bAuto
95895>>>>>>>        String sValue
95895>>>>>>>        Handle hoCol
95895>>>>>>>
95895>>>>>>>        Get piUpdateColumn to iUpdateColumn
95896>>>>>>>        Get psSeedValue to sValue
95897>>>>>>>        Get pbAutoSeed to bSeed
95898>>>>>>>        Get piSortColumn to iSortColumn
95899>>>>>>>        Get pbAutoOrdering to bAuto
95900>>>>>>>        // if not yet sorted and this is auto ordering we will
95900>>>>>>>        // sort the data for the search column. We do this to make the
95900>>>>>>>        // column search GE logic work properly. 
95900>>>>>>>        If (bSeed and bAuto and iUpdateColumn<>-1 and iSortColumn<>iUpdateColumn) Begin
95902>>>>>>>            Get ColumnObject iUpdateColumn to hoCol
95903>>>>>>>            Send SortGridByColumn hoCol False
95904>>>>>>>        End
95904>>>>>>>>
95904>>>>>>>
95904>>>>>>>        If (bSeed and sValue<>"" and iUpdateColumn<>-1) Begin
95906>>>>>>>            Send RequestFindColumnValue iUpdateColumn sValue True 0  
95907>>>>>>>        End
95907>>>>>>>>
95907>>>>>>>        Else Begin
95908>>>>>>>            Send MovetoFirstRow
95909>>>>>>>        End
95909>>>>>>>>
95909>>>>>>>
