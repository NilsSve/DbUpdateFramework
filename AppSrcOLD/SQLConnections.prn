90466>>>    Procedure SetAllIndexesToBatch Handle hTable
90468>>>        Integer iLastIndex iIndex iNumSegments iIndexType
90468>>>        String sTable
90468>>>    
90468>>>        If (hTable > 0) Begin
90470>>>            Close hTable
90471>>>            Open hTable Mode DF_EXCLUSIVE
90473>>>            Get_Attribute DF_FILE_LAST_INDEX_NUMBER of hTable to iLastIndex
90476>>>            for iIndex from 1 to iLastIndex
90482>>>>
90482>>>                Get_Attribute DF_INDEX_NUMBER_SEGMENTS of hTable iIndex to iNumSegments
90485>>>                If (iNumSegments > 0) Begin
90487>>>                    Set_Attribute DF_INDEX_TYPE of hTable iIndex to DF_INDEX_TYPE_BATCH
90490>>>                End
90490>>>>
90490>>>            Loop
90491>>>>
90491>>>            Close hTable
90492>>>        End
90492>>>>
90492>>>    End_Procedure 
