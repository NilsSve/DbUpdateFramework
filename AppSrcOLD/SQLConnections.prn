86273>>>    
86273>>>    // ************************************        
86273>>>    Function SetupSQLConnection Boolean bReadSettings Returns tSQLConnection
86275>>>        tSQLConnection SQLConnection 
86275>>>        tSQLConnection SQLConnection 
86275>>>        
86275>>>        // If this object was created by the cDbUpdateHandler class we will
86275>>>        // deferr reading SQL connection values until later.
86275>>>        If (bReadSettings = True) Begin
86277>>>            // This is the new SQL login logic for DF 19 and up; "Managed Connections"
86277>>>            If (ghoConnection > 0) Begin
86279>>>                Get ReadcConnections to SQLConnection
86280>>>            End
86280>>>>
86280>>>            
86280>>>            // In addition to the above; there might be other values set even if a cConnection
86280>>>            // object is used.
86280>>>            Get ReadSQLConnectionsIniSettings to SQLConnection
86281>>>        End     
86281>>>>
86281>>>        
86281>>>        Function_Return SQLConnection
86282>>>    End_Function
86283>>>    
86283>>>    // This is for the new cConnection class used by DF 19 and up (only).
86283>>>    Function ReadcConnections Returns tSQLConnection
86285>>>        tConnection Connection                 
86285>>>        tConnection Connection                 
86285>>>        tSQLConnection SQLConnection SQLConnectionEmpty
86285>>>        tSQLConnection SQLConnection SQLConnectionEmpty
86285>>>        Integer iCount iSize iRetval iDbType
86285>>>        Boolean bOK bEnabled bConnected bVal
86285>>>        String sConnectionID sSchema
86285>>>        
86285>>>            // - If the DF 19 cConnection class has been used in the cApplication object
86285>>>            // - and there are multiple connection id's defined for the same driver. This is
86285>>>            //   because otherwise we can't possibly know which connection id to use... So
86285>>>            //   we then generate an error and abort the program...
86285>>>            Get IsSinglecConnection (&sConnectionID) to bOK                                     
86286>>>            If (bOK = False) Begin
86288>>>                Error DFERR_PROGRAM ("Programming error. The psConnectionID must be set in the cDbUpdateVersion object when a cConnect object is used in the cApplication object, and there are multiple connections defined. Program will now exit!")
86289>>>>
86289>>>                Abort
86290>>>>
86290>>>            End  
86290>>>>
86290>>>            
86290>>>            Move 0 to iRetval
86291>>>            // DAW DF19 connection info: 
86291>>>            // We first check that the connection is OK:  
86291>>>            Get ConnectionIdIndex of ghoConnection sConnectionID to iRetval
86292>>>            // It might happen that no connection has been setup although the object exists, in case we do nothing.
86292>>>            If (iRetval = -1) Begin
86294>>>                Function_Return SQLConnectionEmpty
86295>>>            End                                 
86295>>>>
86295>>>
86295>>>            If (sConnectionID <> "") Begin
86297>>>                Get ConnectionIdInfo of ghoConnection sConnectionID to Connection  
86298>>>            End
86298>>>>
86298>>>            If (Connection.sId = "") Begin
86300>>>                Move True to SQLConnectionEmpty.bError
86301>>>                Function_Return SQLConnectionEmpty
86302>>>            End
86302>>>>
86302>>>            
86302>>>            Move Connection.sId to sConnectionID  
86303>>>            Get IsConnectionIdLoggedIn of ghoConnection sConnectionID to bConnected
86304>>>    
86304>>>            If (bConnected = False) Begin
86306>>>                Get LoginConnectionId of ghoConnection to iRetval    
86307>>>                If (iRetval <> 0) Begin 
86309>>>                    Send UserError CS_DUF_CannotLoginToServer
86310>>>                    Send Exit_Application    
86311>>>                End
86311>>>>
86311>>>            End
86311>>>>
86311>>>            
86311>>>            // DUF connection info struct property:
86311>>>            Get Private.pSQLConnection                       to SQLConnection   
86312>>>            Move True                                        to SQLConnection.bEnabled
86313>>>            Move Connection.bTrustedConnection               to SQLConnection.bTrusted
86314>>>    
86314>>>            // Not used in DUF:
86314>>>            // Move Connection.iDriverIndex                    to SQLConnection.iDriverIndex
86314>>>    
86314>>>            Move (If(Connection.iOptions = 0, False, True))  to SQLConnection.bSilentLogin
86315>>>            Move Connection.sConnectionString                to SQLConnection.sConnectionString
86316>>>            Move Connection.sDriver                          to SQLConnection.sDriverID
86317>>>            Move Connection.sId                              to SQLConnection.sConnectionID
86318>>>            Move Connection.sUID                             to SQLConnection.sUserID
86319>>>            Move Connection.sPWD                             to SQLConnection.sPassword
86320>>>    
86320>>>            // Not used in DUF:
86320>>>            // Move Connection.sSection to SQLConnection.xxx
86320>>>            
86320>>>            // The rest of the properties of the SQLConnection struct should have been
86320>>>            // setup in the cDbUpdateHandler object, and we should be able to reach them through delegation:
86320>>>            If (Connection.sDriver <> ODBC_DRV_ID) Begin
86322>>>                Get ParseKeyWord Connection.sString CS_SQLIniServerKeyword to SQLConnection.sServer
86323>>>            End
86323>>>>
86323>>>            If (Connection.sDriver = ODBC_DRV_ID) Begin
86325>>>                Get ParseKeyWord Connection.sString CS_SQLIniDSNKeyword    to SQLConnection.sServer
86326>>>            End
86326>>>>
86326>>>            Get ParseKeyWord Connection.sString CS_SQLIniDatabaseKeyword   to SQLConnection.sDatabase  
86327>>>            
86327>>>            // The DbType is a bit special. If the piDbType has _not_ been setup in object code we try to derave
86327>>>            // the value from the driver id:
86327>>>            Get SqlUtilDbTypeFromDriver of (phoSQLConnectionIniFile(Self)) Connection.sDriver to SQLConnection.iDbType
86328>>>            // ...but in case it has been explicitly set in the object we use that value.
86328>>>            Get piDbType                                     to iDbType
86329>>>            If (iDbType <> SQLConnection.iDbType) Begin
86331>>>                Move iDbType to SQLConnection.iDbType
86332>>>            End
86332>>>>
86332>>>            Get psBaseTableSpace                             to SQLConnection.sBaseTableSpace
86333>>>            Get psLongTableSpace                             to SQLConnection.sLongTableSpace
86334>>>            Get psIndexTableSpace                            to SQLConnection.sIndexTableSpace
86335>>>            Get psSchema                                     to SQLConnection.sSchema
86336>>>            
86336>>>            // We finally set the struct property to the newly fetched values.
86336>>>            Set pSQLConnection to SQLConnection
86337>>>        
86337>>>        Function_Return SQLConnection
86338>>>    End_Function
86339>>>    
86339>>>    // Returns True if the psConnectionID has been set in the cDbUpateHandler object,
86339>>>    // or the DAW cConnect array of registered connection only contains one active/enabled
86339>>>    // connection id for a particular driver.
86339>>>    // So either the psConnectionID or the psDriverID can have been set in the cDbUpdateHandler
86339>>>    // object. We can then match a connection id from the DAW cConnect class array.
86339>>>    // Returns False if there are multiple connections that are enabled or the psConnectionID has
86339>>>    // been set in the cDbUpdateHandler object but it cannot be found amongst the registered 
86339>>>    // connections of the DAW cConnect class.
86339>>>    Function IsSinglecConnection String ByRef sConnectionID Returns Boolean
86341>>>        tConnection[] ConnIdArray
86341>>>        tConnection[] ConnIdArray
86342>>>        Integer iCount iSize iConnectionIDCounter
86342>>>        Boolean bOK bEnabled bFound
86342>>>        String sConnectionID2 sDriverID sDriverConn
86342>>>        
86342>>>        Move False to bFound
86343>>>        If (ghoConnection > 0) Begin           
86345>>>            
86345>>>            // The property of the cDbUpdateHandler container object
86345>>>            Get psDriverID to sDriverID
86346>>>            
86346>>>            Move 0 to iConnectionIDCounter 
86347>>>            // This is the the DAW cConnect array with all registered connection id's.
86347>>>                Get ConnectionIDs of ghoConnection to ConnIdArray
86348>>>            Move (SizeOfArray(ConnIdArray)) to iSize
86349>>>            Decrement iSize
86350>>>            For iCount from 0 to iSize
86356>>>>
86356>>>                Move ConnIdArray[iCount].sDriver to sDriverConn
86357>>>                Move ConnIdArray[iCount].sId to sConnectionID2
86358>>>                Move (ConnIdArray[iCount].bDisabled = False) to bEnabled    
86359>>>                // If no psConnectionID specified in the cDbUpdateHandler, we check if there is a driver
86359>>>                // connection in the DAW cConnect object _and_ that there is only one!
86359>>>                If (sConnectionID = "") Begin
86361>>>                    Move (sDriverID = sDriverConn and bEnabled = True) to bFound 
86362>>>                End 
86362>>>>
86362>>>                Else Begin
86363>>>                    If (Uppercase(sConnectionID) = Uppercase(sConnectionID2)) Begin
86365>>>                        Move iSize to iCount // Then we've found what we were looking for and we're out of here... 
86366>>>                    End
86366>>>>
86366>>>                End
86366>>>>
86366>>>                    
86366>>>                If (bFound = True) Begin
86368>>>                    Increment iConnectionIDCounter
86369>>>                End
86369>>>>
86369>>>            Loop
86370>>>>
86370>>>            Move (iConnectionIDCounter <= 1 and sDriverConn <> "" and sConnectionID2 <> "") to bFound 
86371>>>            If (bFound = True) Begin
86373>>>                Move sConnectionID2 to sConnectionID
86374>>>            End
86374>>>>
86374>>>        End 
86374>>>>
86374>>>        
86374>>>        // Special case; a cConnection object has been setup in the cApplication,
86374>>>        // but no DFConn.ini record has been created.
86374>>>        If (iSize = -1) Begin
86376>>>            Move True to bFound
86377>>>        End
86377>>>>
86377>>>            
86377>>>        Function_Return bFound
86378>>>    End_Function
86379>>>    
86379>>>    // Send on object creation to read the default connection string settings, and
86379>>>    // create a connection to the server.
86379>>>    Function ReadSQLConnectionsIniSettings Returns tSQLConnection
86381>>>        String sPath sFileName sSection sConnectionString sPassword 
86381>>>        Boolean bExists
86381>>>        tSQLConnection[] SQLConnectionArray
86381>>>        tSQLConnection[] SQLConnectionArray
86382>>>        tSQLConnection SQLConnection SQLConnectionEmpty
86382>>>        tSQLConnection SQLConnection SQLConnectionEmpty
86382>>>        Handle hoIniFile
86382>>>        Integer iSize iCount
86382>>>        
86382>>>        Get psIniFilePath to sPath
86383>>>        Get phoSQLConnectionIniFile to hoIniFile
86384>>>        If (sPath = "") Begin
86386>>>            Get ApplicationPath of hoIniFile to sPath 
86387>>>            Set psIniFilePath   of hoIniFile to sPath 
86388>>>        End         
86388>>>>
86388>>>        Get vFolderFormat sPath to sPath
86389>>>        Get psIniFileName to sFileName    
86390>>>        Get vFilePathExists (sPath + sFileName) to bExists
86391>>>//        If (bExists = False) Begin   
86391>>>//            Move True to SQLConnection.bError
86391>>>//            Function_Return SQLConnectionEmpty 
86391>>>//        End                                                         
86391>>>        
86391>>>        Get SQLIniFileReadConnections of hoIniFile to SQLConnectionArray
86392>>>        Move (SizeOfArray(SQLConnectionArray)) to iSize
86393>>>        If (iSize = 0) Begin
86395>>>            // This may have been set by the "ReadcConnections" function,
86395>>>            // if a cConnection object has been setup for DataFlex 19 or later
86395>>>            // in the cApplication object.
86395>>>            Get pSQLConnection to SQLConnection
86396>>>            If (SQLConnection.sConnectionID = "") Begin
86398>>>                Function_Return SQLConnectionEmpty
86399>>>            End
86399>>>>
86399>>>            Move SQLConnection to SQLConnectionArray[0]
86400>>>        End
86400>>>>
86400>>>        
86400>>>        // The first connection should be the one that is active, but just in case...
86400>>>        Decrement iSize
86401>>>        For iCount from 0 to iSize
86407>>>>
86407>>>            Move SQLConnectionArray[iCount] to SQLConnection
86408>>>            If (SQLConnection.bEnabled = True) Begin
86410>>>                Move iSize to iCount // We've found the enabled item, so we're out of here.
86411>>>            End
86411>>>>
86411>>>        Loop
86412>>>>
86412>>>
86412>>>        Send CreateSQLConnection SQLConnection.sDriverID SQLConnection.sConnectionID ;             SQLConnection.sServer SQLConnection.sDatabase SQLConnection.bTrusted ;             SQLConnection.sUserID SQLConnection.sPassword SQLConnection.bSilentLogin   
86413>>>             
86413>>>        Set pSQLConnection to SQLConnection 
86414>>>        Send AutoSetConnectionID
86415>>>        
86415>>>        Function_Return SQLConnection
86416>>>    End_Function
86417>>>    
86417>>>    Procedure Set psIniFilePath String sPath
86419>>>        Set psIniFilePath of (phoSQLConnectionIniFile(Self)) to sPath
86420>>>    End_Procedure
