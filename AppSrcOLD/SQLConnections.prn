90388>>>    // Calls a driver function directly to copy data from one table to another (table structures needs to be the same).
90388>>>    // It will first drop all indicies, copy the data and then recreate indicies. 
90388>>>    // An error log file with the sRootname + ".err" will be created in the Data folder.
90388>>>    Function ApiTableCopyData Integer hFromTable String sPhysicalName String sRootName String sDriverID Returns Boolean
90390>>>        Boolean bOpened bOK
90390>>>        Integer hToTable iIndex iCount iRetval iVoid iOrgFreq
90390>>>        String sErrorFile sEmpty sPath
90390>>>        
90390>>>        Get_Attribute DF_FILE_NEXT_EMPTY of 0 to hToTable
90393>>>        Get AutoConnectionIDLogin to bOK
90394>>>        If (sDriverID = DATAFLEX_ID) Begin
90396>>>            Send IncreaseSortBufferSize  
90397>>>//            Send SetAllIndexesToBatch hToTable
90397>>>        End                          
90397>>>>
90397>>>
90397>>>        Move False to Err
90398>>>        Open sPhysicalName as hToTable
90400>>>        Get_Attribute DF_FILE_OPENED of hToTable to bOpened
90403>>>        If (bOpened = False) Begin
90405>>>            Function_Return False
90406>>>        End                      
90406>>>>
90406>>>        
90406>>>        Move "" to sEmpty 
90407>>>        Move False to Err   
90408>>>        Move True to bOK       
90409>>>        
90409>>>        Get_Attribute DF_RUNTIME_PROGRESS_FREQUENCY to iOrgFreq
90412>>>        Set_Attribute DF_RUNTIME_PROGRESS_FREQUENCY to 10        
90415>>>        If (sDriverID <> DATAFLEX_ID) Begin
90417>>>            // Remove all indices to speed up copying of data:
90417>>>            Call_Driver hToTable sDriverID Function CLI_DROPINDICES Callback Self Passing sEmpty sEmpty iVoid Result iRetval
90422>>>            If (iRetval <> 0) Begin
90424>>>                Error DFERR_PROGRAM ("Failed dropping indices for table:" * sRootName)
90425>>>>
90425>>>                Function_Return False
90426>>>            End
90426>>>>
90426>>>        End
90426>>>>
90426>>>        
90426>>>        Move (sRootName + ".err") to sErrorFile  
90427>>>        Move 0 to iIndex           
90428>>>        Move False to Err   
90429>>>        
90429>>>        Copy_Records hFromTable to hToTable using 0 Callback Self
90432>>>                  
90432>>>        If (Err = False) Begin             
90434>>>            Get psHome of (phoWorkspace(ghoApplication)) to sPath  
90435>>>            Get vDeleteFile (sPath + sErrorFile) to iRetval
90436>>>        End                                                          
90436>>>>
90436>>>        
90436>>>        If (sDriverID <> DATAFLEX_ID) Begin
90438>>>            // Recreate indices:
90438>>>            Call_Driver hToTable sDriverID Function CLI_CREATEINDICES Callback Self Passing sEmpty sEmpty iVoid Result iRetval
90443>>>        End
90443>>>>
90443>>>        
90443>>>        Close hToTable
90444>>>        Set_Attribute DF_RUNTIME_PROGRESS_FREQUENCY to iOrgFreq
90447>>>        
90447>>>        If (bOK = True) Begin
90449>>>            Move (not(Err)) to bOK
90450>>>        End
90450>>>>
90450>>>        
90450>>>        If (ghoStatusPanel <> 0) Begin
90452>>>            Set Message_Text of ghoStatusPanel to ""
90453>>>            Set Action_Text  of ghoStatusPanel to ""
90454>>>        End
90454>>>>
90454>>>        
90454>>>        Function_Return (bOK = True)
90455>>>    End_Function 
90456>>>
90456>>>    Procedure IncreaseSortBufferSize
90458>>>        String sNull
90458>>>        Integer iSortBufferSize
90458>>>        Boolean bBufferSet
90458>>>    
90458>>>        Move "" to sNull
90459>>>        Move (1024 * 128) to iSortBufferSize
90460>>>        Call_Driver 0 DATAFLEX_ID Function FLEX_SET_MAX_SORT_BUFFER Callback Self Passing sNull sNull iSortBufferSize Result bBufferSet
90465>>>    
90465>>>    End_Procedure     
