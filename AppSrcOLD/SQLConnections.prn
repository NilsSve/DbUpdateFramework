88444>>>    // Enumerate SQL Servers. 
88444>>>    // Pass a driver id. Returns a string array.                     
88444>>>    // The iDataSourceType (iDatSrcType) parameter is optional and is for the ODBC driver only.
88444>>>    // Note: Returns servers for MSSQLDRV; else data-sources on the machine.
88444>>>    Function SqlUtilEnumerateServers String sDriverID Integer iDatSrcType Returns String[]
88446>>>        String[] sReturnArray
88447>>>        Handle hoSQLHandler
88447>>>        String sServer
88447>>>        Integer iCount iNumItems iDataSourceType
88447>>>        Boolean bOK
88447>>>        
88447>>>        If (num_arguments > 1) Begin
88449>>>            Move iDatSrcType to iDataSourceType
88450>>>        End                                    
88450>>>>
88450>>>        
88450>>>        Case Begin
88450>>>            Case (sDriverID = MSSQLDRV_ID) 
88452>>>                Get phoMSSQLHandler to hoSQLHandler
88453>>>                    Get EnumerateServersLocal of hoSQLHandler to iNumItems
88454>>>                    If (iNumItems = 0) Begin
88456>>>                        Get EnumerateServers of hoSQLHandler to iNumItems
88457>>>                    End            
88457>>>>
88457>>>                For iCount from 0 to (iNumItems - 1)
88463>>>>
88463>>>                    Get String_Value of hoSQLHandler item iCount to sServer
88464>>>                    Move (Trim(sServer)) to sReturnArray[iCount]
88465>>>                Loop
88466>>>>
88466>>>                Case Break 
88467>>>    
88467>>>            Case (sDriverID = DB2_DRV_ID) 
88470>>>                Get phoDB2SQLHandler to hoSQLHandler
88471>>>                Send SeedDataSources of hoSQLHandler          
88472>>>                Move 0 to iCount
88473>>>                Repeat
88473>>>>
88473>>>                    Get DataSources of hoSQLHandler to sServer
88474>>>                    If (sServer <> "") Begin   
88476>>>                        Move (Replace(",", sServer, "")) to sServer
88477>>>                        Move sServer to sReturnArray[iCount]
88478>>>                    End
88478>>>>
88478>>>                    Increment iCount    
88479>>>                Until (sServer = "")
88481>>>                Case Break
88482>>>    
88482>>>            Case (sDriverID = ODBC_DRV_ID) 
88485>>>                Get phoODBCSQLHandler to hoSQLHandler
88486>>>                Set DataSourceType of hoSQLHandler to iDataSourceType       
88487>>>                Move 0 to iCount
88488>>>                Repeat
88488>>>>
88488>>>                    Get DataSources of hoSQLHandler to sServer
88489>>>                    If (sServer <> "") Begin   
88491>>>                        Move (Replace(",", sServer, ", ")) to sServer
88492>>>                        Move sServer to sReturnArray[iCount]
88493>>>                    End
88493>>>>
88493>>>                    Increment iCount    
88494>>>                Until (sServer = "")
88496>>>                Case Break    
88497>>>            
88497>>>            Case (sDriverID = SQLFLEX)  
88500>>>                Get _MertechEnumerateSQLFlexServers to sReturnArray
88501>>>                Case Break
88502>>>            
88502>>>            Case (sDriverID = ORAFLEX)          
88505>>>                Get _MertechEnumerateORAFLEXServers to sReturnArray
88506>>>                Case Break
88507>>>            
88507>>>            // There appearantly is no way to enumerate servers for this backend.
88507>>>            Case (sDriverID = MDSPgSQL)
88510>>>                Move "localhost" to sReturnArray[0]
88511>>>                Case Break
88512>>>            
88512>>>            // There appearantly is no way to enumerate servers for this backend.
88512>>>            Case (sDriverID = MDSMySQL)
88515>>>                Move "localhost" to sReturnArray[0]
88516>>>                Case Break
88517>>>            
88517>>>            Case Else
88517>>>                Error DFERR_PROGRAM "Unsupported DriverID passed to SqlUtilEnumerateServers function"
88518>>>>
88518>>>        Case End
88518>>>
88518>>>        Function_Return sReturnArray
88519>>>    End_Function
88520>>>    
88520>>>    // Returns all databases as a string array for the passed driver id.
88520>>>    Function SqlUtilEnumerateDatabases String sDriverID Returns String[]
88522>>>        String[] sReturnArray                                                    
88523>>>        String sUserID sPassword 
88523>>>        Boolean bOK
88523>>>        
88523>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
88524>>>        If (bOK = False) Begin
88526>>>            Function_Return sReturnArray
88527>>>        End    
88527>>>>
88527>>>        
88527>>>        Case Begin
88527>>>            Case (sDriverID = MSSQLDRV_ID)
88529>>>                Get _SqlDatabasesArrayMSSQL to sReturnArray
88530>>>                Case Break                                                            
88531>>>            Case (sDriverID = DB2_DRV_ID)
88534>>>                Get _SqlDatabasesArrayDB2 to sReturnArray
88535>>>                Case Break
88536>>>
88536>>>            // Enumeration of ODBC databases should be irrelevant as the database
88536>>>            // should have been specified when the ODBC source was setup with the ODBC manager.
88536>>>            Case (sDriverID = ODBC_DRV_ID)
88539>>>                Case Break
88540>>>
88540>>>            Case (sDriverID = SQLFLEX)
88543>>>                Get SqlProcedureArrayMertech "sp_databases" "" to sReturnArray
88544>>>                Case Break
88545>>>
88545>>>            Case (sDriverID = MDSPgSQL)
88548>>>                Get SqlEnumerateEsqlMertech "SELECT datname FROM pg_database" to sReturnArray
88549>>>                Case Break
88550>>>                 
88550>>>            Case (sDriverID = MDSMySQL)
88553>>>                Get SqlEnumerateEsqlMertech "show databases" to sReturnArray
88554>>>                Case Break 
88555>>>            
88555>>>            Case (sDriverID = ORAFLEX)  
88558>>>                Get SqlEnumerateEsqlMertech "SELECT NAME FROM v$database" to sReturnArray
88559>>>                Case Break
88560>>>
88560>>>            Case Else
88560>>>                Error DFERR_PROGRAM "Unsupported DriverID passed to SqlUtilEnumerateDatabases function"
88561>>>>
88561>>>        Case End  
88561>>>        
88561>>>        Function_Return sReturnArray
88562>>>    End_Function
88563>>>    
88563>>>    // Returns all table spaces as a string array for the passed driver id.
88563>>>    Function SqlUtilEnumerateTableSpaces String sDriverID Returns String[]
88565>>>        String[] sReturnArray                                                    
88566>>>        String sServer sUserID sPassword 
88566>>>        Boolean bOK
88566>>>        
88566>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
88567>>>        If (bOK = False) Begin
88569>>>            Function_Return sReturnArray
88570>>>        End    
88570>>>>
88570>>>        
88570>>>        Case Begin
88570>>>            Case (sDriverID = DB2_DRV_ID)
88572>>>                Get SqlEnumerateEsqlDAW "select tablespace_name from dba_tablespaces" 1 to sReturnArray
88573>>>                Case Break
88574>>>
88574>>>            Case (sDriverID = MDSPgSQL)
88577>>>                Get SqlEnumerateEsqlMertech "SELECT spcname FROM pg_tablespace" 1 to sReturnArray
88578>>>                Case Break
88579>>>
88579>>>            Case (sDriverID = ORAFLEX)  
88582>>>                Get SqlEnumerateEsqlMertech "SELECT TABLESPACE_NAME FROM USER_TABLESPACES" 1 to sReturnArray
88583>>>                Case Break 
88584>>>
88584>>>            Case Else     
88584>>>                Error DFERR_PROGRAM "Unsupported driver passed to SqlUtilEnumerateTableSpaces function."
88585>>>>
88585>>>                Case Break
88586>>>        Case End  
88586>>>        
88586>>>        Function_Return sReturnArray
88587>>>    End_Function
88588>>>    
88588>>>    // Returns all schemas as a string array for the passed driver id.
88588>>>    Function SqlUtilEnumerateSchemas String sDriverID Returns String[]
88590>>>        String[] sReturnArray                                                    
88591>>>        Boolean bOK
88591>>>        
88591>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
88592>>>        If (bOK = False) Begin
88594>>>            Function_Return sReturnArray
88595>>>        End    
88595>>>>
88595>>>        
88595>>>        Case Begin
88595>>>            Case (sDriverID = DB2_DRV_ID)
88597>>>                Get SqlEnumerateEsqlDAW "select schemaname from syscat.schemata" 1 to sReturnArray
88598>>>                Case Break
88599>>>
88599>>>            Case (sDriverID = MDSPgSQL)                                   
88602>>>                Get SqlEnumerateEsqlMertech "select schema_name from information_schema.schemata" 1 to sReturnArray
88603>>>                Case Break
88604>>>
88604>>>            Case (sDriverID = ORAFLEX)  
88607>>>                Get SqlEnumerateEsqlMertech "SELECT username from dba_users WHERE default_tablespace not in ('SYSTEM','SYSAUX')" 1 to sReturnArray
88608>>>                Case Break 
88609>>>
88609>>>            Case Else     
88609>>>                Error DFERR_PROGRAM "Unsupported driver passed to SqlUtilEnumerateSchemas function."
88610>>>>
88610>>>                Case Break
88611>>>        Case End  
88611>>>        
88611>>>        Function_Return sReturnArray
88612>>>    End_Function
88613>>>    
88613>>>    // Returns a string array with all tables for the current database.
88613>>>    Function SqlUtilEnumerateTables String sDriverID Returns String[]
88615>>>        String[] sReturnArray sArray
88617>>>        String sServer sDatabase sConnectionString sSelect sSchema     
88617>>>        Integer iSize iCount
88617>>>        Boolean bOK
88617>>>
88617>>>        If (sDriverID = DATAFLEX_ID) Begin
88619>>>            Function_Return sArray        
88620>>>        End                       
88620>>>>
88620>>>        
88620>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
88621>>>        If (bOK = False) Begin
88623>>>            Function_Return sReturnArray
88624>>>        End    
88624>>>>
88624>>>        
88624>>>        Get psConnectionString to sConnectionString
88625>>>        Get psDatabase to sDatabase                               
88626>>>        Get psSchema   to sSchema                                                                              
88627>>>                                                                                                              
88627>>>        Case Begin
88627>>>            Case (sDriverID = MSSQLDRV_ID)
88629>>>                Get _SqlTableArrayDAW to sReturnArray
88630>>>                Case Break                                                            
88631>>>            
88631>>>            Case (sDriverID = DB2_DRV_ID)
88634>>>                Get _SqlTableArrayDAW to sReturnArray
88635>>>                Case Break
88636>>>            
88636>>>            Case (sDriverID = ODBC_DRV_ID)
88639>>>                Get _SqlTableArrayDAW to sReturnArray
88640>>>                Case Break
88641>>>            
88641>>>            Case (sDriverID = SQLFLEX)
88644>>>                Move ("SELECT TABLE_NAME FROM" * sDatabase + ".INFORMATION_SCHEMA.TABLES WHERE TABLE_TYPE != 'VIEW'") to sSelect
88645>>>                Get SqlEnumerateEsqlMertech sSelect to sReturnArray
88646>>>                Case Break
88647>>>            
88647>>>            Case (sDriverID = MDSMySQL)                                   
88650>>>                Move ("SELECT TABLE_NAME from INFORMATION_SCHEMA.TABLES where TABLE_SCHEMA = '" + sDatabase + "' and TABLE_TYPE = 'BASE TABLE' order by TABLE_NAME") to sSelect
88651>>>                Get SqlEnumerateEsqlMertech sSelect to sReturnArray
88652>>>                Case Break
88653>>>            
88653>>>            Case (sDriverID = MDSPgSQL)                                          
88656>>>                Move "select tablename, schemaname from pg_catalog.pg_tables order by tablename"  to sSelect
88657>>>                Get SqlEnumerateEsqlMertech sSelect "" to sReturnArray
88658>>>                Case Break            
88659>>>            
88659>>>            Case (sDriverID = ORAFLEX)                                          
88662>>>                Move "SELECT table_name from user_tables" to sSelect  
88663>>>                Get SqlEnumerateEsqlMertech sSelect to sArray
88664>>>                Move (SizeOfArray(sArray)) to iSize
88665>>>                Decrement iSize
88666>>>                For iCount from 0 to iSize
88672>>>>
88672>>>                    If (not(sArray[iCount] contains "$")) Begin
88674>>>                        Move sArray[iCount] to sReturnArray[SizeOfArray(sReturnArray)]
88675>>>                    End
88675>>>>
88675>>>                Loop
88676>>>>
88676>>>                Case Break            
88677>>>
88677>>>            Case Else     
88677>>>                Error DFERR_PROGRAM "Unsupported driver passed to SqlUtilEnumerateTables function."
88678>>>>
88678>>>                Case Break
88679>>>        Case End
88679>>>        
88679>>>        Function_Return sReturnArray
88680>>>    End_Function
88681>>>    
88681>>>    // Returns a string array with all table columns/fields for the passed table handle and driver id.
88681>>>    Function SqlUtilEnumerateColumns String sDriverID String sTableName Returns String[]
88683>>>        String[] sReturnArray                                          
88684>>>        String sServer sConnectionString sSelect sSchema
88684>>>        Boolean bOK
88684>>>        
88684>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
88685>>>        If (bOK = False) Begin
88687>>>            Error DFERR_PROGRAM ("Unsupported driver. A list of table columns could not be retrieved for:" * sDriverID + ".")
88688>>>>
88688>>>            Function_Return sReturnArray
88689>>>        End   
88689>>>>
88689>>>       
88689>>>        Get psConnectionString to sConnectionString  
88690>>>        Get psSchema to sSchema
88691>>>        
88691>>>        Case Begin
88691>>>            Case (sDriverID = MSSQLDRV_ID)    
88693>>>                Move ("select name from sys.columns where [object_id] = object_id('dbo." + sTableName + "')") to sSelect
88694>>>                Get SqlEnumerateEsqlDAW sSelect 1 to sReturnArray
88695>>>                Case Break
88696>>>
88696>>>            Case (sDriverID = DB2_DRV_ID) 
88699>>>                Move ("SELECT colname from syscat.columns WHERE tabschema = '" + sSchema + "'" * "AND tabname = '" + sTableName + "'") to sSelect  
88700>>>                Get SqlEnumerateEsqlDAW sSelect 1 to sReturnArray
88701>>>                Case Break
88702>>>
88702>>>            Case (sDriverID = SQLFLEX)
88705>>>                Move ("select name from sys.columns where [object_id] = object_id('dbo." + sTableName + "')") to sSelect
88706>>>                Get SqlEnumerateEsqlMertech sSelect 1 to sReturnArray
88707>>>                Case Break
88708>>>            
88708>>>            Case (sDriverID = MDSMySQL) 
88711>>>                Move ("SHOW COLUMNS FROM" * sTableName) to sSelect
88712>>>                Get SqlEnumerateEsqlMertech sSelect 1 to sReturnArray
88713>>>                Case Break
88714>>>            
88714>>>            Case (sDriverID = MDSPgSQL) 
88717>>>                Move ("select column_name, data_type, character_maximum_length from INFORMATION_SCHEMA.COLUMNS where table_name = '" +sTableName + "'") to sSelect
88718>>>                Get SqlEnumerateEsqlMertech sSelect 1 to sReturnArray
88719>>>                Case Break            
88720>>>            
88720>>>            Case (sDriverID = ORAFLEX) 
88723>>>                Move ("SELECT column_name from user_tab_cols WHERE table_name = '" + sTableName + "'") to sSelect
88724>>>                Get SqlEnumerateEsqlMertech sSelect 1 to sReturnArray
88725>>>                Case Break
88726>>>                            
88726>>>            Case Else     
88726>>>                Error DFERR_PROGRAM "Unsupported driver passed to SqlUtilEnumerateColumns function."
88727>>>>
88727>>>                Case Break
88728>>>        Case End
88728>>>        
88728>>>        Function_Return sReturnArray
88729>>>    End_Function  
