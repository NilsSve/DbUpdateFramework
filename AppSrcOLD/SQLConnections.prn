87744>>>            Get NextFreeFilelistSlot to hTable
87745>>>        End
87745>>>>
87745>>>        Get SQLUtilColumnExists sTableName sColumnName to bExists
87746>>>        If (bExists = True) Begin
87748>>>            Function_Return False
87749>>>        End
87749>>>>
87749>>>
87749>>>        If (num_arguments > 3) Begin
87751>>>            Move iLen to iLength
87752>>>        End                     
87752>>>>
87752>>>        If (num_arguments > 4) Begin
87754>>>            Move iDec to iDecimals
87755>>>        End                
87755>>>>
87755>>>        
87755>>>        Get piDbType to iDbType
87756>>>        Get UtilColumnTypeToString sDriverID iDbType iDataType to sDataType
87757>>>        
87757>>>        Move False to Err   
87758>>>        Get _SqlProperTableName sTableName    to sTableName
87759>>>        Get _SqlFindKeyWord CI_SQLAlterTable  to sAlterTable
87760>>>        Get _SqlFindKeyWord CI_SQLAlterColumn to sAlterColumn
87761>>>        Get SQLUtilDefaultNullValue sDriverID iDbType iDataType to sNotNull
87762>>>
87762>>>        Get UtilColumnTypeFixed sDriverID iDbType iDataType to bFixed
87763>>>        If (bFixed = False) Begin
87765>>>            Get _SqlFormatLengthAndDecimalAsString iLength iDecimals to sLengthAndDecimals
87766>>>        End
87766>>>>
87766>>>        
87766>>>        Move (sAlterTable * sTableName * sAlterColumn * sColumnName * sDataType + sLengthAndDecimals * sNotNull) to sStmt
87767>>>        Send SqlUtilExecuteQuery sStmt sDriverID
87768>>>    
87768>>>        // We also need to remove the cache-file since the table has been changed
87768>>>        Get UtilDeleteCacheFile sTableName to bOK
87769>>>    
87769>>>        Function_Return (Err = False)    
87770>>>    End_Function    
87771>>>    
87771>>>    Function SqlColumnDefaultValue Handle hTable Integer iColumn String sValue Returns Boolean
87773>>>        Boolean bOK bErr bIsSQLDriver
87773>>>        String sDriverID
87773>>>        
87773>>>        Get psDriverID to sDriverID
87774>>>        Get IsSQLDriver sDriverID to bIsSQLDriver
87775>>>        If (bIsSQLDriver = False) Begin
87777>>>            Function_Return False
87778>>>        End
87778>>>>
87778>>>
87778>>>        Move Err to bErr
87779>>>        Move False to bErr                                      
87780>>>        
87780>>>        // There seems to be a problem with the ODBC_DRV driver that sometimes
87780>>>        // inserts randomly character(10) and spaces, so we correct from that here:
87780>>>        Move (Replaces(Character(10), Trim(sValue), "")) to sValue                   
87781>>>        
87781>>>        Set_Attribute DF_FIELD_DEFAULT_VALUE of hTable iColumn to sValue
87784>>>        Move (not(Err)) to bOK
87785>>>        Move bErr to Err
87786>>>        
87786>>>        Function_Return bOK
87787>>>    End_Function
87788>>>    
87788>>>    Function SqlColumnNullable Handle hTable Integer iColumn Boolean bNullable Returns Boolean
87790>>>        Boolean bOK bErr bCurrentState bOpen bIsSQLDriver
87790>>>        String sDriverID
87790>>>        
87790>>>        Get psDriverID to sDriverID
87791>>>        Get IsSQLDriver sDriverID to bIsSQLDriver
87792>>>        If (bIsSQLDriver = False) Begin
87794>>>            Function_Return False
87795>>>        End
87795>>>>
87795>>>        
87795>>>        Move Err to bErr
87796>>>        Move False to bErr
87797>>>        Get_Attribute DF_FIELD_NULL_ALLOWED of hTable iColumn to bCurrentState
87800>>>        If (bNullable = bCurrentState) Begin
87802>>>            Function_Return True
87803>>>        End                     
87803>>>>
87803>>>        
87803>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpen
87806>>>        If (bOpen = False) Begin                       
87808>>>            Get AutoConnectionIDLogin to bOK
87809>>>            Send Ignore_Error of Error_Object_Id DFERR_CANT_OPEN_DATA_FILE
87810>>>            Send Ignore_Error of Error_Object_Id DFERR_CANT_OPEN_INTERMEDIATE_FILE
87811>>>            Send Ignore_Error of Error_Object_Id CLIERR_GENERAL_ERROR
87812>>>            Open hTable
87814>>>            Send Trap_Error of Error_Object_Id DFERR_CANT_OPEN_DATA_FILE
87815>>>            Send Trap_Error of Error_Object_Id DFERR_CANT_OPEN_INTERMEDIATE_FILE
87816>>>            Send Trap_Error of Error_Object_Id CLIERR_GENERAL_ERROR
87817>>>            Get_Attribute DF_FILE_OPENED of hTable to bOpen
87820>>>        End
87820>>>>
87820>>>        If (bOpen = True) Begin
87822>>>            Structure_Start hTable sDriverID
87823>>>                Set_Attribute DF_FIELD_NULL_ALLOWED of hTable iColumn to bNullable
87826>>>            Structure_End hTable
87828>>>        End
87828>>>>
87828>>>
87828>>>        Move (not(Err)) to bOK
87829>>>        Move bErr to Err
87830>>>        
87830>>>        Function_Return bOK
87831>>>    End_Function
