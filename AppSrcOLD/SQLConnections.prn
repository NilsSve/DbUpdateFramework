96119>>>>>>>        
96119>>>>>>>    Procedure Search
96121>>>>>>>        Send Activate // give focus back to list so focus things are correct
96122>>>>>>>        Send Request_Search 0 0
96123>>>>>>>    End_Procedure
96124>>>>>>>    
96124>>>>>>>    // do a search using the current keys in the search key buffer for the sort column.
96124>>>>>>>    // Becaue this is called via an OnIdle it is possible to have multiple keys pressed before
96124>>>>>>>    // the OnIdle. These have been stored in pSearchKeys and will be passed to the popup dialog
96124>>>>>>>    Procedure Request_SearchEx
96126>>>>>>>        tGridKeyPair[] Keys
96126>>>>>>>        tGridKeyPair[] Keys
96127>>>>>>>        Integer iCol
96127>>>>>>>        Handle hoCol hoSearchDialog 
96127>>>>>>>        Boolean bOk
96127>>>>>>>        String sValue
96127>>>>>>>
96127>>>>>>>        Get piSortColumn to iCol
96128>>>>>>>        If (iCol<>-1) Begin
96130>>>>>>>            Get ColumnObject iCol to hoCol
96131>>>>>>>                Get pSearchKeys to Keys
96132>>>>>>>            Get CreateGridSearchDialogObject to hoSearchDialog
96133>>>>>>>            Get RequestGridSearchEx of hoSearchDialog Keys hoCol (&sValue) to bOk
96134>>>>>>>            If bOk Begin
96136>>>>>>>               Send RequestFindColumnValue iCol sValue True 0  
96137>>>>>>>            End
96137>>>>>>>>
96137>>>>>>>            Send Destroy of hoSearchDialog
96138>>>>>>>        End
96138>>>>>>>>
96138>>>>>>>        Send ClearSearchRequest // clear the search keys
96139>>>>>>>    End_Procedure
96140>>>>>>>    
96140>>>>>>>    // set pbRequestSearch to true and add the keys to the search buffer.
96140>>>>>>>    Procedure AddToSearchKeys Integer iKeyCode Integer iShiftCode
96142>>>>>>>        tGridKeyPair[] Keys
96142>>>>>>>        tGridKeyPair[] Keys
96143>>>>>>>        tGridKeyPair KeyPair
96143>>>>>>>        tGridKeyPair KeyPair
96143>>>>>>>        Set pbRequestSearch to True
96144>>>>>>>        Move iKeyCode to KeyPair.KeyCode
96145>>>>>>>        Move iShiftCode to KeyPair.ShiftCode
96146>>>>>>>        Get pSearchKeys to Keys                
96147>>>>>>>        Move KeyPair to Keys[SizeOfArray(Keys)]
96148>>>>>>>        Set pSearchKeys to Keys                
96149>>>>>>>    End_Procedure
96150>>>>>>>
96150>>>>>>>    Procedure ClearSearchRequest
96152>>>>>>>        tGridKeyPair[] SearchKeys
96152>>>>>>>        tGridKeyPair[] SearchKeys
96153>>>>>>>        Set pSearchKeys to SearchKeys
96154>>>>>>>        Set pbRequestSearch to False
96155>>>>>>>    End_Procedure
96156>>>>>>>    
96156>>>>>>>End_Class
