89498>>>>
89498>>>            Move sTablesArray[iCount] to sVal
89499>>>            If (Uppercase(sVal) = Uppercase(sTableName)) Begin
89501>>>                Move iCount to iIndex // We found it!
89502>>>                Move iSize to iCount  // End the loop    
89503>>>            End
89503>>>>
89503>>>        Loop                  
89504>>>>
89504>>>        
89504>>>        Function_Return iIndex
