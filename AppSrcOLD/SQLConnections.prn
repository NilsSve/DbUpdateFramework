86993>>>>Function ParseKeyWord String sConnect String sKeyWord Returns String
86995>>>>    Integer iStart iEnd
86995>>>>    String sRetval
86995>>>>
86995>>>>    Move (Trim(sConnect)) to sConnect
86996>>>>    Move (Pos(Uppercase(sKeyWord), Uppercase(sConnect)))  to iStart
86997>>>>    If (iStart = 0) Begin
86999>>>>        Function_Return ""
87000>>>>    End
87000>>>>>
87000>>>>    Move (Left(sConnect, (iStart -1 + Length(sKeyWord)))) to sRetval
87001>>>>    Move (Replace(sRetval, sConnect, "")) to sRetval 
87002>>>>    If (sKeyWord = Uppercase(CS_SQLConnectionIDText)) Begin
87004>>>>        Move (Pos(",", sRetval))          to iEnd
87005>>>>    End
87005>>>>>
87005>>>>    Else Begin
87006>>>>        Move (Pos(";", sRetval))          to iEnd
87007>>>>    End                                          
87007>>>>>
87007>>>>    If (iEnd = 0 and (sRetval contains ",")) Begin
87009>>>>        Move (Pos(",", sRetval))          to iEnd 
87010>>>>        Decrement iEnd
87011>>>>    End
87011>>>>>
87011>>>>    If (iEnd <> 0) Begin
87013>>>>        Move (Left(sRetval, (iEnd -1)))   to sRetval
87014>>>>    End
87014>>>>>
87014>>>>    Move (Replace("=", sRetval, ""))      to sRetval
87015>>>>
87015>>>>    Function_Return (Trim(sRetval))
87016>>>>End_Function
87017>>>>
