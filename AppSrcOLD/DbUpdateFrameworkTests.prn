89219>>>>>>>>>>>Class cDbUpdateORAFLEXDriver is a cDbUpdateGenericDatabaseDriver
89220>>>>>>>>>>>    Function DbLogin String sConnectionString String sServer String sDatabase Boolean bTrusted String sUserID String sPassword Returns Boolean
89222>>>>>>>>>>>        Boolean bLoginSuccessful
89222>>>>>>>>>>>        String sDriverID sErrorMsg
89222>>>>>>>>>>>        String sVal
89222>>>>>>>>>>>        Integer iPos
89222>>>>>>>>>>>
89222>>>>>>>>>>>        Get psDriverID to sDriverID
89223>>>>>>>>>>>        Move (Pos("/", sServer)) to iPos
89224>>>>>>>>>>>        If (iPos = 0) Begin
89226>>>>>>>>>>>            If (sDatabase <> "") Begin
89228>>>>>>>>>>>                Move (sServer + "/" + sDatabase) to sServer        
89229>>>>>>>>>>>            End
89229>>>>>>>>>>>>
89229>>>>>>>>>>>        End
89229>>>>>>>>>>>>
89229>>>>>>>>>>>        // For the Mertech driver, using the Err indicator is the sanctioned way
89229>>>>>>>>>>>        Move False to Err
89230>>>>>>>>>>>        // For Oracle I don't believe "Trusted" doesn't exist.
89230>>>>>>>>>>>        Login sServer sUserId sPassword sDriverID
89232>>>>>>>>>>>        
89232>>>>>>>>>>>        Move (not(Err)) to bLoginSuccessful
89233>>>>>>>>>>>        Function_Return bLoginSuccessful
89234>>>>>>>>>>>    End_Function
89235>>>>>>>>>>>End_Class
