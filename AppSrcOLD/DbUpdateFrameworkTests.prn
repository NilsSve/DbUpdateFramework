89798>>>>>>>>>    // Short connection string used when writing to ini-file. This is to be compatible with DF19 DFConnId.ini files that uses this short format.
89798>>>>>>>>>    Function ConstructShortConnectionString String sDriverID String sServer String sDatabase Returns String
89800>>>>>>>>>        String sConnect 
89800>>>>>>>>>        
89800>>>>>>>>>        Case Begin
89800>>>>>>>>>            Case (sDriverID = MSSQLDRV_ID or sDriverID = SQLFLEX)
89802>>>>>>>>>                Move (sConnect * CS_SQLIniServerKeyword + "=" + sServer) to sConnect
89803>>>>>>>>>                If (sDatabase <> "") Begin
89805>>>>>>>>>                    Move (sConnect * ";" + CS_SQLIniDatabaseKeyword + "=" + sDatabase) to sConnect
89806>>>>>>>>>                End
89806>>>>>>>>>>
89806>>>>>>>>>                Case Break
89807>>>>>>>>>
89807>>>>>>>>>            Case (sDriverID = ODBC_DRV_ID)
89810>>>>>>>>>                Move (sConnect * CS_SQLIniDSNKeyword + "=" + sServer) to sConnect
89811>>>>>>>>>                If (sDatabase <> "") Begin
89813>>>>>>>>>                    Move (sConnect * ";" + CS_SQLIniDatabaseKeyword + "=" + sDatabase) to sConnect
89814>>>>>>>>>                End
89814>>>>>>>>>>
89814>>>>>>>>>                Case Break
89815>>>>>>>>>
89815>>>>>>>>>            Case (sDriverID = DB2_DRV_ID)
89818>>>>>>>>>                Move (sConnect * CS_SQLIniDSNKeyword + "=" + sServer) to sConnect
89819>>>>>>>>>                If (sDatabase <> "") Begin
89821>>>>>>>>>                    Move (sConnect * ";" + CS_SQLIniDatabaseKeyword + "=" + sDatabase) to sConnect
89822>>>>>>>>>                End
89822>>>>>>>>>>
89822>>>>>>>>>                Case Break
89823>>>>>>>>>            
89823>>>>>>>>>            Case (sDriverID = ORAFLEX)
89826>>>>>>>>>                Move (sConnect * CS_SQLIniDSNKeyword + "=" + sServer) to sConnect
89827>>>>>>>>>                If (sDatabase <> "") Begin
89829>>>>>>>>>                    Move (sConnect * ";" + CS_SQLIniDatabaseKeyword + "=" + sDatabase) to sConnect
89830>>>>>>>>>                End
89830>>>>>>>>>>
89830>>>>>>>>>                Case Break
89831>>>>>>>>>
89831>>>>>>>>>            Case (sDriverID = MDSPgSQL)
89834>>>>>>>>>                Move (sConnect * CS_SQLIniDSNKeyword + "=" + sServer) to sConnect
89835>>>>>>>>>                If (sDatabase <> "") Begin
89837>>>>>>>>>                    Move (sConnect * ";" + CS_SQLIniDatabaseKeyword + "=" + sDatabase) to sConnect
89838>>>>>>>>>                End
89838>>>>>>>>>>
89838>>>>>>>>>                Case Break
89839>>>>>>>>>
89839>>>>>>>>>            Case (sDriverID = MDSMySQL)
89842>>>>>>>>>                Move (sConnect * CS_SQLIniDSNKeyword + "=" + sServer) to sConnect
89843>>>>>>>>>                If (sDatabase <> "") Begin
89845>>>>>>>>>                    Move (sConnect * ";" +CS_SQLIniDatabaseKeyword + "=" + sDatabase) to sConnect
89846>>>>>>>>>                End
89846>>>>>>>>>>
89846>>>>>>>>>                Case Break
89847>>>>>>>>>
89847>>>>>>>>>            Case (sDriverID = DATAFLEX_ID)    // Dummy stub.
89850>>>>>>>>>                Break
89851>>>>>>>>>
89851>>>>>>>>>            Case Else
89851>>>>>>>>>                Move "" to sConnect
89852>>>>>>>>>        Case End
89852>>>>>>>>>
89852>>>>>>>>>        Function_Return sConnect
89853>>>>>>>>>    End_Function
