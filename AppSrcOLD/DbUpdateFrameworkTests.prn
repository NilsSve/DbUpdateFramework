98124>>>>>>>
98124>>>>>>>    // augment to handle the scrolling area initialization.
98124>>>>>>>    Procedure Add_Focus Handle hoParent
98126>>>>>>>        Forward Send Add_Focus hoParent
98128>>>>>>>        // at this the scrolling container and client area should both be paged. 
98128>>>>>>>        // child objects ae also paged with initial anchors applied
98128>>>>>>>        Send CalculateAutoScrollMinimums
98129>>>>>>>    End_Procedure
98130>>>>>>>    
98130>>>>>>>    Procedure Page Integer iPage
98132>>>>>>>        Forward Send Page iPage
98134>>>>>>>        If iPage Begin
98136>>>>>>>            // at this the scrolling container and client area should both be paged
98136>>>>>>>            // but the child controls are not paged. We don't want scrollbars when
98136>>>>>>>            // the child items are paged (else they may get anchored oddly) 
98136>>>>>>>            // Prior to 19.0 these were set in Add_focus which meant that the child objects were
98136>>>>>>>            // already paged with scrollbars present. This would result in scrollbars appearing
98136>>>>>>>            // before they were really needed. This should be more accurate
98136>>>>>>>            Send SetScrollBarInfo True 0 0 0
98137>>>>>>>            Send SetScrollBarInfo False 0 0 0
98138>>>>>>>        End
98138>>>>>>>>
98138>>>>>>>    End_Procedure
98139>>>>>>>
98139>>>>>>>    // determine scrolling minimums and set the client area as required.
98139>>>>>>>    
98139>>>>>>>    Procedure CalculateAutoScrollMinimums
98141>>>>>>>        Integer iMinX iMinY iSiz iLoc iMargin
98141>>>>>>>        Integer iAutoMinX iAutoMinY
98141>>>>>>>        Boolean bAutoScroll
98141>>>>>>>        Handle hoNext hoFirst
98141>>>>>>>        
98141>>>>>>>        Get pbAutoScroll to bAutoScroll
98142>>>>>>>        Get piAutoScrollMinX to iAutoMinX
98143>>>>>>>        Get piAutoScrollMinY to iAutoMinY
98144>>>>>>>        Get DialogToGui iAutoMinY iAutoMinX to iSiz
98145>>>>>>>        Move (Hi(iSiz)) to iAutoMinY
98146>>>>>>>        Move (Low(iSiz)) to iAutoMinX
98147>>>>>>>        Set piMinimumHeight to iAutoMinY
98148>>>>>>>        Set piMinimumWidth to iAutoMinX
98149>>>>>>>        
98149>>>>>>>        If (bAutoScroll and (iAutoMinX=0 or iAutoMinY=0)) Begin
98151>>>>>>>        
98151>>>>>>>            Get Next_Level to hoFirst
98152>>>>>>>            Move hoFirst to hoNext
98153>>>>>>>            If (hoFirst) Begin
98155>>>>>>>                Repeat
98155>>>>>>>>
98155>>>>>>>                    Get GuiWindowSize of hoNext to iSiz
98156>>>>>>>                    Get GuiLocation of hoNext to iLoc
98157>>>>>>>                    Move (Hi(iLoc)+Hi(iSiz) max iMinY) to iMinY
98158>>>>>>>                    Move (Low(iLoc)+Low(iSiz) max iMinX) to iMinx
98159>>>>>>>                    Get Next_Focus of hoNext to hoNext
98160>>>>>>>                Until (hoNext=0 or hoNext=hoFirst)
98162>>>>>>>
98162>>>>>>>                If (iAutoMinY=0) Begin
98164>>>>>>>                    Get piAutoScrollMarginY to iMargin
98165>>>>>>>                    Set piMinimumHeight to (iMinY+iMargin)
98166>>>>>>>                End
98166>>>>>>>>
98166>>>>>>>
98166>>>>>>>                If (iAutoMinX=0) Begin
98168>>>>>>>                    Get piAutoScrollMarginX to iMargin
98169>>>>>>>                    Set piMinimumWidth to (iMinX+iMargin)
98170>>>>>>>
98170>>>>>>>                End
98170>>>>>>>>
98170>>>>>>>            End
98170>>>>>>>>
98170>>>>>>>        End
98170>>>>>>>>
98170>>>>>>>        
98170>>>>>>>        // before setting the client area, unset all anchors so DoApplyAnchors will not do anything
98170>>>>>>>        Broadcast Set pbAnchorCreated to False
98172>>>>>>>        Send ScrollClientArea
98173>>>>>>>        // after the scroll set up, reinitialize all anchors.
98173>>>>>>>        Broadcast Send DoCreateAnchors
98175>>>>>>>    End_Procedure
98176>>>>>>>    
98176>>>>>>>    // Scroll the client area and adjust the client area size as needed. This does all the
98176>>>>>>>    // work of scrolling.
98176>>>>>>>    
98176>>>>>>>    Procedure ScrollClientArea
98178>>>>>>>        Integer iSiz
98178>>>>>>>        Integer iHeight iHCur iHCuriDelta iOrig iRange bOk
98178>>>>>>>        Integer iWidth iWCur iWDelta iWOrig
98178>>>>>>>        Integer iSzY iSzX iLocX iLocY
98178>>>>>>>        
98178>>>>>>>        Delegate Get GuiClientSize to iSiz
98180>>>>>>>        Move (Hi(iSiz)) to iHeight
98181>>>>>>>        Move (Low(iSiz)) to iWidth
98182>>>>>>>
98182>>>>>>>        // Vertical scrolling
98182>>>>>>>        
98182>>>>>>>        Get piMinimumHeight to iOrig
98183>>>>>>>        Get piMinimumWidth to iWOrig
98184>>>>>>>        
98184>>>>>>>        If (iOrig<>0 or iWOrig<>0) Begin
98186>>>>>>>        
98186>>>>>>>            If (iOrig<>0) Begin
98188>>>>>>>                Get piCurrentVertScrolled to iHCur
98189>>>>>>>                // If the size got bigger and we've scrolled, we want to scroll up        
98189>>>>>>>                If (iHCur<>0 and (iHCur+iHeight>iOrig)) Begin
98191>>>>>>>                    Move (iOrig-iHeight max 0) to iHCur
98192>>>>>>>                    Set piCurrentVertScrolled to iHCur
98193>>>>>>>                End
98193>>>>>>>>
98193>>>>>>>                If (iHCur<>0 or iOrig>iHeight) Begin
98195>>>>>>>                    Send SetScrollBarInfo True 0 iOrig (iHeight min iOrig)
98196>>>>>>>                    Send SetScrollBarPosInfo True iHCur 
98197>>>>>>>                End
98197>>>>>>>>
98197>>>>>>>                Else Begin
98198>>>>>>>                    Send SetScrollBarInfo True 0 0 0 //iOrig (iHeight min iOrig)
98199>>>>>>>                End
98199>>>>>>>>
98199>>>>>>>            End
98199>>>>>>>>
98199>>>>>>>                
98199>>>>>>>            // Horiz scrolling
98199>>>>>>>            
98199>>>>>>>            Get piCurrentHorzScrolled to iWCur
98200>>>>>>>    //        If (iWCur<>0) Begin
98200>>>>>>>                // If the size got bigger and we've scrolled, we want to scroll left        
98200>>>>>>>                If (iWCur<>0 and (iWCur+iWidth>iWOrig)) Begin
98202>>>>>>>                    Move (iWOrig-iWidth max 0) to iWCur
98203>>>>>>>                    Set piCurrentHorzScrolled to iWCur
98204>>>>>>>                End
98204>>>>>>>>
98204>>>>>>>                If (iWCur<>0 or iWOrig>iWidth) Begin
98206>>>>>>>                    Send SetScrollBarInfo False 0 iWOrig (iWidth min iWOrig)
98207>>>>>>>                    Send SetScrollBarPosInfo False iWCur 
98208>>>>>>>                End
98208>>>>>>>>
98208>>>>>>>                Else Begin
98209>>>>>>>                    Send SetScrollBarInfo False 0 0 0 
98210>>>>>>>                End
98210>>>>>>>>
98210>>>>>>>    //        End
98210>>>>>>>        End
98210>>>>>>>>
98210>>>>>>>        
98210>>>>>>>        // this could change depending on scrollbars appearing or not    
98210>>>>>>>        Delegate Get GuiClientSize to iSiz
98212>>>>>>>        
98212>>>>>>>        // size of container is the the minimum allowed size (if scrolling is needed)
98212>>>>>>>        // or it is the actual size of the container (if scrolling not needed and it is bigger)
98212>>>>>>>        // This is required to make anchors work sensibly 
98212>>>>>>>        Move (hi(iSiz) max iOrig) to iSzY
98213>>>>>>>        Move (low(iSiz) max iWOrig) to iSzX
98214>>>>>>>        Move (-iHCur) to iLocY
98215>>>>>>>        Move (-iWCur) to iLocX
98216>>>>>>>
98216>>>>>>>        // Allow chance to make modifications
98216>>>>>>>        Send AdjustSizesLocs (&iSzY) (&iSzX) (&iLocY) (&iLocX)
98217>>>>>>>
98217>>>>>>>        Set GuiSize to iSzY iSzX
98218>>>>>>>        // if we've scrolled, we need to reposition the container
98218>>>>>>>        Set GuiLocation to iLocY iLocX  
98219>>>>>>>    End_Procedure
98220>>>>>>>
98220>>>>>>>    // note that scrolling never changes the size of the scrolling client.
98220>>>>>>>    // this way, it does not interfere with anchors.
98220>>>>>>>    
98220>>>>>>>    Procedure VScroll Integer iDelta
98222>>>>>>>        Integer iHeight iCur iOrig iSiz 
98222>>>>>>>        Delegate Get GuiClientSize to iSiz
98224>>>>>>>        Move (hi(iSiz)) to iHeight
98225>>>>>>>        Get piCurrentVertScrolled to iCur
98226>>>>>>>        Get piMinimumHeight to iOrig
98227>>>>>>>        If (iOrig=0 or  Hi(iSiz)>=iOrig) Begin
98229>>>>>>>            Procedure_Return
98230>>>>>>>        End
98230>>>>>>>>
98230>>>>>>>        // make sure delta is within range  
98230>>>>>>>        If (iDelta+iCur<0) Begin
98232>>>>>>>            Move (-iCur) to iDelta
98233>>>>>>>        End
98233>>>>>>>>
98233>>>>>>>        Else If (iDelta+iCur>iOrig - iHeight) Begin
98236>>>>>>>            Move (iOrig - iHeight - iCur) to iDelta
98237>>>>>>>        End
98237>>>>>>>>
98237>>>>>>>        If (iDelta=0) Procedure_Return
98240>>>>>>>        
98240>>>>>>>        Move (iCur + iDelta) to iCur 
98241>>>>>>>        Set piCurrentVertScrolled to iCur 
98242>>>>>>>        Send SetScrollBarPosInfo True iCur 
98243>>>>>>>        Get GuiLocation to iSiz
98244>>>>>>>        Set GuiLocation to (cast(hi(iSiz),Short)-iDelta) (cast(low(iSiz),Short))
98245>>>>>>>        Send ScrollClientArea
98246>>>>>>>    End_Procedure
98247>>>>>>>    
98247>>>>>>>    
98247>>>>>>>    Procedure HScroll Integer iDelta
98249>>>>>>>        Integer iHeight iCur iOrig iSiz
98249>>>>>>>        Delegate Get GuiClientSize to iSiz
98251>>>>>>>        Move (low(iSiz)) to iHeight
98252>>>>>>>        Get piCurrentHorzScrolled to iCur
98253>>>>>>>        Get piMinimumWidth to iOrig
98254>>>>>>>        If (iOrig=0 or  low(iSiz)>=iOrig) Begin
98256>>>>>>>            Procedure_Return
98257>>>>>>>        End
98257>>>>>>>>
98257>>>>>>>        If (iDelta+iCur<0) Begin
98259>>>>>>>            Move (-iCur) to iDelta
98260>>>>>>>        End
98260>>>>>>>>
98260>>>>>>>        Else If (iDelta+iCur>iOrig - iHeight) Begin
98263>>>>>>>            Move (iOrig - iHeight - iCur) to iDelta
98264>>>>>>>        End
98264>>>>>>>>
98264>>>>>>>        If (iDelta=0) Procedure_Return
98267>>>>>>>        
98267>>>>>>>        Move (iCur + iDelta) to iCur 
98268>>>>>>>        Set piCurrentHorzScrolled to iCur 
98269>>>>>>>        Send SetScrollBarPosInfo False iCur 
98270>>>>>>>        Get GuiLocation to iSiz
98271>>>>>>>        Set GuiLocation to (cast(hi(iSiz),Short)) (cast(low(iSiz),Short) -iDelta)
98272>>>>>>>        Send ScrollClientArea
98273>>>>>>>    End_Procedure
98274>>>>>>>    
98274>>>>>>>    // make sure client is a 0,0
98274>>>>>>>    Procedure ScrollHome
98276>>>>>>>        Send SetVScrollbox SB_TOP 0
98277>>>>>>>        Send SetHScrollbox SB_TOP 0
98278>>>>>>>    End_Procedure
98279>>>>>>>
98279>>>>>>>    // get relative GUI location of this object to the parent one passed.
98279>>>>>>>    Procedure LocationRelativeTo Handle hoContainer Handle hoControl Integer ByRef iLocY Integer ByRef iLocX
98281>>>>>>>        Integer ivoid
98281>>>>>>>        tWinRect Rect0 Rect1
98281>>>>>>>        tWinRect Rect0 Rect1
98281>>>>>>>        Move (GetWindowRect(window_handle(hoContainer),addressof(Rect0))) to ivoid
98282>>>>>>>        Move (GetWindowRect(window_handle(hoControl),addressof(Rect1))) to ivoid
98283>>>>>>>        Move ((Rect1.top) - (Rect0.top)) to iLocY
98284>>>>>>>        Move ((rect1.left) - (rect0.left)) to iLocX
98285>>>>>>>    End_Procedure
98286>>>>>>>    
98286>>>>>>>    // This scrolls this object into visual range. 
98286>>>>>>>    Procedure ScrollObjectInRange Handle hoControl
98288>>>>>>>        Handle hoScrollingContainer
98288>>>>>>>        Integer iCurrentVertScrolled iCurrentHorzScrolled
98288>>>>>>>        Integer iViewHeight iViewWidth
98288>>>>>>>        Integer iRelLocHeight iRelLocWidth
98288>>>>>>>        Integer iSize iControlHeight iControlWidth
98288>>>>>>>        Integer iScroll
98288>>>>>>>        Integer iMarginX iMarginY
98288>>>>>>>        Integer iScrollingContainerWindowSize iScrollingContainerClientSize
98288>>>>>>>        
98288>>>>>>>        Get piAutoScrollMarginX to iMarginX
98289>>>>>>>        Get piAutoScrollMarginY to iMarginY
98290>>>>>>>        
98290>>>>>>>        // the scrolling container 
98290>>>>>>>        Move Self to hoScrollingContainer
98291>>>>>>>        // the amount the SC is currently scrolled
98291>>>>>>>        Get piCurrentVertScrolled of hoScrollingContainer to iCurrentVertScrolled
98292>>>>>>>        Get piCurrentHorzScrolled of hoScrollingContainer to iCurrentHorzScrolled
98293>>>>>>>        
98293>>>>>>>        // size of view's client area (this is the viewport area)
98293>>>>>>>        Get GuiClientSize of (Parent(hoScrollingContainer)) to iSize
98294>>>>>>>        Move (hi(iSize)) to iViewHeight
98295>>>>>>>        Move (low(iSize)) to iViewWidth
98296>>>>>>>        
98296>>>>>>>        // get this object's location relative to the scrolling container
98296>>>>>>>        Send LocationRelativeTo hoScrollingContainer hoControl (&iRelLocHeight) (&iRelLocWidth)
98297>>>>>>>
98297>>>>>>>        // we expect that the client size is the window size but just in case
98297>>>>>>>        Get GuiWindowSize of hoScrollingContainer to iScrollingContainerWindowSize
98298>>>>>>>        Get GuiClientSize of hoScrollingContainer to iScrollingContainerClientSize
98299>>>>>>>        Move (iRelLocHeight - (Hi(iScrollingContainerWindowSize)-Hi(iScrollingContainerClientSize))) to iRelLocHeight 
98300>>>>>>>        Move (iRelLocWidth - (Low(iScrollingContainerWindowSize)-Low(iScrollingContainerClientSize))) to iRelLocWidth
98301>>>>>>>        
98301>>>>>>>        // the outer size of the control object
98301>>>>>>>        Get GUIWindowSize of hoControl to iSize
98302>>>>>>>        Move (hi(iSize)) to iControlHeight
98303>>>>>>>        Move (low(iSize)) to iControlWidth
98304>>>>>>>        
98304>>>>>>>        // the general idea is to make the control fully visible but to scroll as little as possible.
98304>>>>>>>
98304>>>>>>>        // Vertical Scroll
98304>>>>>>>        
98304>>>>>>>        // Vertical Scroll down
98304>>>>>>>        // if the bottom of the control plus a bottom margin does not fit make it fit at the bottom
98304>>>>>>>        If (iRelLocHeight + iControlHeight + iMarginY - iCurrentVertScrolled >iViewHeight) Begin
98306>>>>>>>           
98306>>>>>>>           // set scroll amount so that the bottom of the control is visible  
98306>>>>>>>           Move (iRelLocHeight + iControlHeight + iMarginY - iCurrentVertScrolled - iViewHeight ) to iScroll
98307>>>>>>>           
98307>>>>>>>           // See if this amount, scrolls the top out of range. If so just scroll enough so that the
98307>>>>>>>           // top of the object appears at the bottom 
98307>>>>>>>           If (iRelLocHeight - iCurrentVertScrolled < iScroll) Begin
98309>>>>>>>               Move (iRelLocHeight + iMarginY  - iCurrentVertScrolled - iViewHeight  ) to iScroll
98310>>>>>>>           End
98310>>>>>>>>
98310>>>>>>>           // if the scroll amnt is negative it's best to just keep it where it is.
98310>>>>>>>           If (iScroll>0) Begin
98312>>>>>>>                Send VScroll of hoScrollingContainer iScroll
98313>>>>>>>           End
98313>>>>>>>>
98313>>>>>>>        End
98313>>>>>>>>
98313>>>>>>>        // else vertical scroll up 
98313>>>>>>>        // We scroll if the top of the object is not visible.  
98313>>>>>>>        Else If (iRelLocHeight + iMarginY < iCurrentVertScrolled) Begin
98316>>>>>>>            // if we scroll we will scroll enough to see the top of the object.
98316>>>>>>>            Move (iRelLocHeight -iMarginY - iCurrentVertScrolled ) to iScroll
98317>>>>>>>            If (iScroll<0) Begin
98319>>>>>>>                Send VScroll of hoScrollingContainer (iScroll max (-iCurrentVertScrolled))
98320>>>>>>>            End
98320>>>>>>>>
98320>>>>>>>        End
98320>>>>>>>>
98320>>>>>>>
98320>>>>>>>        // Horizonal Scroll
98320>>>>>>>        
98320>>>>>>>        // if the right side of the control does not fit, scroll it so it fits
98320>>>>>>>        If (iRelLocWidth + iControlWidth + iMarginX - iCurrentHorzScrolled >iViewWidth) Begin
98322>>>>>>>           Move (iRelLocWidth + iControlWidth + iMarginX - iCurrentHorzScrolled - iViewWidth ) to iScroll
98323>>>>>>>           If (iRelLocWidth - iCurrentHorzScrolled - iScroll<0) Begin
98325>>>>>>>               Move (iRelLocWidth  - iCurrentHorzScrolled - iMarginX ) to iScroll
98326>>>>>>>           End
98326>>>>>>>>
98326>>>>>>>           If (iScroll>0) Begin
98328>>>>>>>                Send HScroll of hoScrollingContainer iScroll
98329>>>>>>>           End
98329>>>>>>>>
98329>>>>>>>        End
98329>>>>>>>>
98329>>>>>>>        If (iRelLocWidth - iMarginX  - iCurrentHorzScrolled <0) Begin
98331>>>>>>>            // if this can fit by moving all the way to left, do so.
98331>>>>>>>            If (iRelLocWidth + iControlWidth + iMarginX <= iViewWidth) Begin
98333>>>>>>>                Move (-iCurrentHorzScrolled) to iScroll
98334>>>>>>>            End
98334>>>>>>>>
98334>>>>>>>            Else Begin
98335>>>>>>>                Move (iRelLocWidth - iCurrentHorzScrolled - iMarginX) to iScroll
98336>>>>>>>            End
98336>>>>>>>>
98336>>>>>>>            If (iScroll<0) Begin
98338>>>>>>>                Send HScroll of hoScrollingContainer (iScroll max (-iCurrentHorzScrolled))
98339>>>>>>>            End
98339>>>>>>>>
98339>>>>>>>        End
98339>>>>>>>>
98339>>>>>>>
98339>>>>>>>
98339>>>>>>>    End_Procedure
98340>>>>>>>
98340>>>>>>>    // when we receive this message, we might need to scroll to bring the new focus in to view.
98340>>>>>>>    Procedure NotifyFocusSetInContainer Handle hoControl
98342>>>>>>>        Boolean bScrollOnFocus
98342>>>>>>>        Get pbAutoScrollFocus to bScrollOnFocus
98343>>>>>>>        If bScrollOnFocus Begin
98345>>>>>>>            Send ScrollObjectInRange hoControl
98346>>>>>>>        End
98346>>>>>>>>
98346>>>>>>>        Delegate Send NotifyFocusSetInContainer hoControl
98348>>>>>>>    End_Procedure
