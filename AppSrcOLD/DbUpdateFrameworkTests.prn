92814>>>>>    
92814>>>>>    // *** Helper Functions ***
92814>>>>>    // They all start with an underscore: "_" in the function name.
92814>>>>>    //
92814>>>>>    // Reads a SQL script file that has been compiled into the .exe program as a resource.
92814>>>>>    // Pass: The memory resource reference and a boolean True if you want to create the file on disk (in the Home folder).
92814>>>>>    // Returns: A tSQLScriptArray Struct with the Sql script as an uChar Array will be returned along with the a bError boolean.
92814>>>>>    Function SqlUtilReadResource String sMemFileName Returns tSQLScriptArray
92816>>>>>        Integer iChannel iArgumentSize iOut iChunk iPointer iCount iSize
92816>>>>>        Number nByteCount
92816>>>>>        String sCharacter sSQLScript 
92816>>>>>        Boolean bSeqEof
92816>>>>>        tSQLScriptArray SqlScriptArray
92816>>>>>        tSQLScriptArray SqlScriptArray
92816>>>>>        UChar[] uCharData
92817>>>>>        
92817>>>>>        Move False to Err
92818>>>>>        Get Seq_New_Channel to iChannel
92819>>>>>        If (iChannel = DF_SEQ_CHANNEL_NOT_AVAILABLE) Begin
92821>>>>>            Error DFERR_PROGRAM 'No channel available...'
92822>>>>>>
92822>>>>>            Move True to SqlScriptArray.bError
92823>>>>>            Function_Return SqlScriptArray
92824>>>>>        End                    
92824>>>>>>
92824>>>>>        
92824>>>>>        // First decide the size of the script
92824>>>>>        Direct_Input channel iChannel ("Resource: " + sMemFileName)
92826>>>>>        Read_Block channel iChannel uCharData -1 // -1 means that all data should be read.
92828>>>>>        Close_Input channel iChannel
92830>>>>>
92830>>>>>        Move (SizeOfArray(uCharData)) to nByteCount 
92831>>>>>        If (nByteCount  < 1) Begin
92833>>>>>            Send Seq_Release_Channel iChannel  
92834>>>>>            Move True to SqlScriptArray.bError
92835>>>>>            Function_Return SqlScriptArray
92836>>>>>        End
92836>>>>>>
92836>>>>>        
92836>>>>>        // If necessary change the string argument_size
92836>>>>>        Get_Argument_Size to iArgumentSize
92837>>>>>        If (nByteCount >= iArgumentSize) Begin
92839>>>>>            Move (nByteCount + 2048) to nByteCount
92840>>>>>            Set_Argument_Size nByteCount // Set new argument size just a bit higher than "needed" for overhead margin.
92841>>>>>>
92841>>>>>            Move True          to SqlScriptArray.bArgumentSizeChanged
92842>>>>>            Move iArgumentSize to SqlScriptArray.iOrgArgumentSize
92843>>>>>        End                         
92843>>>>>>
92843>>>>>        Else Begin
92844>>>>>            Move False to SqlScriptArray.bArgumentSizeChanged
92845>>>>>        End
92845>>>>>>
92845>>>>>        
92845>>>>>        // Read the script file from memory line-by-line
92845>>>>>        Direct_Input channel iChannel ("Resource: " + sMemFileName) 
92847>>>>>            Move 0 to iCount
92848>>>>>            Repeat
92848>>>>>>
92848>>>>>                Readln channel iChannel sSQLScript
92850>>>>>                Move sSQLScript to SqlScriptArray.sSQLScriptArray[iCount]
92851>>>>>                Increment iCount
92852>>>>>            Until (SeqEof = True)
92854>>>>>        Close_Input channel iChannel
92856>>>>>        Send Seq_Release_Channel iChannel 
92857>>>>>        
92857>>>>>        // Finally "sanitize" the script by removing all comments.
92857>>>>>        Get _SqlUtilSanitizeScript SqlScriptArray to SqlScriptArray  
92858>>>>>
92858>>>>>        Function_Return SqlScriptArray
92859>>>>>    End_Function 
92860>>>>>    
92860>>>>>    Function SqlUtilExecuteEmbeddedScript tSQLScriptArray SQLScriptArray String sDriverID Boolean bCreateScriptFile String sMemFileName Boolean bShowProgr Returns Boolean
92862>>>>>        String sSQLVal sStmt sCR sDebugFileName sTmp sGOKeyWord sNoCountKeyWord sMessage sExportFile
92862>>>>>        Handle hoSql hoSQLConnect hoStmt hoError
92862>>>>>        Integer i iMsgs iFetchResult iResultCount iRows iRowType iCount iChunkCounter iChunkMax iPos iOut iNextSet iMessage
92862>>>>>        String[] sMsg aSQLQueryMessages
92864>>>>>        DateTime dtQueryExecStart dtQueryExecEnd
92864>>>>>        TimeSpan tsQuery
92864>>>>>        tSqlErrorArray aSqlErrorArray  
92864>>>>>        tSqlErrorArray aSqlErrorArray  
92864>>>>>        tSQLConnection SQLConnection
92864>>>>>        tSQLConnection SQLConnection
92864>>>>>        Boolean bOK bMertechDriver bShowProgress
92864>>>>>        
92864>>>>>        If (num_arguments > 4) Begin
92866>>>>>            Move bShowProgr to bShowProgress
92867>>>>>        End
92867>>>>>>
92867>>>>>        Get IsMertechDriver sDriverID to bMertechDriver
92868>>>>>        If (bMertechDriver = False) Begin
92870>>>>>            Get phoSQLManager to hoSql
92871>>>>>        End 
92871>>>>>>
92871>>>>>        Else Begin
92872>>>>>            Get _MertechSQLManagerHandle to hoSql
92873>>>>>        End
92873>>>>>>
92873>>>>>            
92873>>>>>        Get _SqlFindKeyWord CI_SQLGO to sGOKeyWord
92874>>>>>        // There seems to be a problem to pass strings when their value gets really big, aka
92874>>>>>        // above the argument_size level. It isn't clear when these problems starts but sooner
92874>>>>>        // or later SqlExecDirect stops working correctly with no error messages!
92874>>>>>        // To guard from this we set a max number of lines (iChunkMax) that can be processed
92874>>>>>        // at a time. Testing with the Create Chinook Database script; 500 seems like a number that works fine. 
92874>>>>>        // A bonus of this is that it turns out that it is actually faster to run in chunks!
92874>>>>>        Get piChunkMax to iChunkMax    
92875>>>>>        Move 0 to iChunkCounter                                 
92876>>>>>        Move "" to sStmt   
92877>>>>>
92877>>>>>        Get _SqlFindKeyWord CI_SQLSetNoCountOn to sNoCountKeyWord
92878>>>>>        Move (Character(13) + Character(10)) to sCR
92879>>>>>
92879>>>>>        Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
92880>>>>>        
92880>>>>>        If (bMertechDriver = True) Begin
92882>>>>>            Get _MertechSQLConnect sDriverID SQLConnection.sServer SQLConnection.sUserID SQLConnection.sPassword to hoSQLConnect
92883>>>>>        End
92883>>>>>>
92883>>>>>        If (bMertechDriver = False) Begin
92885>>>>>            Get phoSQLManager  to hoSQL
92886>>>>>            Send SqlSetConnect of hoSQL sDriverID SQLConnection.sConnectionString
92887>>>>>            Get SqlConnect     of hoSQL "" "" to hoSQLConnect
92888>>>>>        End
92888>>>>>>
92888>>>>>
92888>>>>>        If (hoSQLConnect <> 0) Begin 
92890>>>>>            Move False to Err
92891>>>>>            Get SqlOpen of hoSQLConnect to hoStmt
92892>>>>>            If (hoStmt <> 0) Begin
92894>>>>>
92894>>>>>                // If the embedded resource should be written as a script file to disk:
92894>>>>>                If (bCreateScriptFile = True) Begin
92896>>>>>                    Get psHome of (phoWorkspace(ghoApplication)) to sExportFile
92897>>>>>                    Get vFolderFormat sExportFile to sExportFile
92898>>>>>                    Move (sExportFile + sMemFileName) to sExportFile
92899>>>>>                    Get Seq_New_Channel to iOut 
92900>>>>>                    If (iOut <> DF_SEQ_CHANNEL_NOT_AVAILABLE) Begin
92902>>>>>                        Direct_Output channel iOut sExportFile  
92904>>>>>                    End
92904>>>>>>
92904>>>>>                End
92904>>>>>>
92904>>>>>        
92904>>>>>                // Record starting date/time stamp
92904>>>>>                Move (CurrentDateTime()) to dtQueryExecStart
92905>>>>>                // Turn on error handling if enabled
92905>>>>>                If (pbHandleQueryErrors(Self)) Begin
92907>>>>>                    Set pbSqlError to False  
92908>>>>>                    Set paSqlErrorArray to aSqlErrorArray
92909>>>>>                    Move Error_Object_Id to hoError
92910>>>>>                    Move Self to Error_Object_Id
92911>>>>>                End                                                    
92911>>>>>>
92911>>>>>                
92911>>>>>                Move (SizeOfArray(SQLScriptArray.sSQLScriptArray)) to iRows  
92912>>>>>                Decrement iRows
92913>>>>>                Move (sNoCountKeyWord + sCR) to sStmt
92914>>>>>
92914>>>>>                For iCount from 0 to iRows   
92920>>>>>>
92920>>>>>                    Move (SQLScriptArray.sSQLScriptArray[iCount]) to sSQLVal
92921>>>>>                    
92921>>>>>                    If (Uppercase(sSQLVal) <> sGOKeyWord) Begin
92923>>>>>                        If (sSQLVal <> "") Begin
92925>>>>>                            Move (sSQLVal + sCR) to sSQLVal
92926>>>>>                        End
92926>>>>>>
92926>>>>>                        Move (Append(sStmt, (sSQLVal))) to sStmt
92927>>>>>                    End
92927>>>>>>
92927>>>>>                    
92927>>>>>                    // - Each time we encounter a "GO" statement we execute it,
92927>>>>>                    // or if at the very end of the script.
92927>>>>>                    If (Uppercase(sSQLVal) = sGOKeyWord or iChunkCounter >= iChunkMax or iCount = iRows) Begin 
92929>>>>>                        
92929>>>>>                        // - It turns out it can be at least 10 times faster to execute SQL statements in chunks,
92929>>>>>                        // instead of all in one go. 
92929>>>>>                        Send SqlExecDirect of hoStmt sStmt 
92930>>>>>                        
92930>>>>>                        If (bCreateScriptFile = True) Begin
92932>>>>>                            Write channel iOut sStmt
92934>>>>>                        End
92934>>>>>>
92934>>>>>                        Move "" to sStmt   
92935>>>>>                        Move 0 to iChunkCounter
92936>>>>>                    End
92936>>>>>>
92936>>>>>                    Increment iChunkCounter
92937>>>>>                Loop
92938>>>>>>
92938>>>>>                       
92938>>>>>                Repeat
92938>>>>>>
92938>>>>>                    If (pbHandleQueryErrors(Self)) Begin
92940>>>>>                        Move hoError to Error_Object_Id
92941>>>>>                    End
92941>>>>>>
92941>>>>>                    Move (CurrentDateTime()) to dtQueryExecEnd  
92942>>>>>                    
92942>>>>>                    Send _SqlColumnInfo hoStmt
92943>>>>>                    Get SqlStmtAttribute of hoStmt SqlSTMTATTRIB_ROWCOUNT to iRows
92944>>>>>                    Get SqlStmtAttribute of hoStmt SqlSTMTATTRIB_ROWCOUNT_TYPE to iRowType
92945>>>>>                    Get SqlStmtAttribute of hoStmt SqlSTMTATTRIB_NUMMESSAGES to iMsgs
92946>>>>>                    Set piRows    to iRows
92947>>>>>                    Set piRowType to iRowType
92948>>>>>                   
92948>>>>>                    If (iMsgs <> 0) Begin
92950>>>>>                        If (ghoDbUpdateHandler > 0) Begin
92952>>>>>                            Get paSQLQueryMessages of ghoDbUpdateHandler to aSQLQueryMessages
92953>>>>>                        End
92953>>>>>>
92953>>>>>                        For i from 1 to iMsgs
92959>>>>>>
92959>>>>>                            Get SqlGetMessage of hoStmt i to sMessage     
92960>>>>>                            Get RemoveComponentIdentifier of hoStmt sMessage to sMessage   
92961>>>>>                            If (bShowProgress = True) Begin
92963>>>>>                                If (Active_State(ghoStatusPanel)) Begin
92965>>>>>                                    Send Update_StatusPanel of ghoStatusPanel (Sformat("  SQLGetMessage iMessage %1 returned [%2]", iMessage, sMessage))
92966>>>>>                                End                                                   
92966>>>>>>
92966>>>>>                                Else Begin
92967>>>>>                                    Showln (Sformat("  SQLGetMessage iMessage %1 returned [%2]", iMessage, sMessage))
92969>>>>>                                End
92969>>>>>>
92969>>>>>                            End
92969>>>>>>
92969>>>>>                            Move sMessage to sMsg[SizeOfArray(sMsg)]
92970>>>>>                            Move sMessage to aSQLQueryMessages[SizeOfArray(aSQLQueryMessages)]
92971>>>>>                        Loop   
92972>>>>>>
92972>>>>>                    
92972>>>>>                    
92972>>>>>                        If (ghoDbUpdateHandler > 0) Begin
92974>>>>>                            Set paSQLQueryMessages of ghoDbUpdateHandler to aSQLQueryMessages
92975>>>>>                        End
92975>>>>>>
92975>>>>>                        Set paQueryMessages to sMsg
92976>>>>>                    End
92976>>>>>>
92976>>>>>
92976>>>>>                    Get SQLNextResultSet of hoStmt to iNextSet
92977>>>>>                Until (iNextSet = 0)
92979>>>>>                
92979>>>>>                Move (CurrentDateTime()) to dtQueryExecEnd
92980>>>>>            End 
92980>>>>>>
92980>>>>>            
92980>>>>>            Move (dtQueryExecEnd - dtQueryExecStart) to tsQuery
92981>>>>>            Set ptsQueryExec to tsQuery  
92982>>>>>            Send SqlClose of hoStmt
92983>>>>>
92983>>>>>            If (bCreateScriptFile = True) Begin
92985>>>>>                Close_Output channel iOut
92987>>>>>                Send Seq_Release_Channel iOut
92988>>>>>            End
92988>>>>>>
92988>>>>>        End
92988>>>>>>
92988>>>>>        Send SqlDisconnect of hoSQLConnect
92989>>>>>
92989>>>>>        Function_Return (hoSQLConnect <> 0 and Err = False)
92990>>>>>    End_Function
92991>>>>>        
92991>>>>>    // Returns the index for the passed sTableName
92991>>>>>    // Returns >= 0 if successful. It is e.g. needed to get the SchemaName for a table.
92991>>>>>    Function _SqlUtilEnumerateTableIndex String sTableName String sDriverID Returns Integer
92993>>>>>        Integer iIndex iSize iCount
92993>>>>>        String[] sTablesArray
92994>>>>>        String sVal sConnectionString
92994>>>>>        
92994>>>>>        Move -1 to iIndex            
92995>>>>>        Get psConnectionString to sConnectionString
92996>>>>>        Get SqlUtilEnumerateTables sDriverID to sTablesArray
92997>>>>>        Move (SizeOfArray(sTablesArray)) to iSize
92998>>>>>        Decrement iSize
92999>>>>>        For iCount from 0 to iSize
93005>>>>>>
93005>>>>>            Move sTablesArray[iCount] to sVal
93006>>>>>            If (Uppercase(sVal) = Uppercase(sTableName)) Begin
93008>>>>>                Move iCount to iIndex // We found it!
93009>>>>>                Move iSize to iCount  // End the loop    
93010>>>>>            End
93010>>>>>>
93010>>>>>        Loop                  
93011>>>>>>
93011>>>>>        
93011>>>>>        Function_Return iIndex
93012>>>>>    End_Function
93013>>>>>
93013>>>>>    // Helper function that builds a string like;
93013>>>>>    // "SELECT name from [Master].[sys].[databases] where name"
93013>>>>>    Function _SqlSelectFromWhereName Returns String
93015>>>>>        String sRetval sSelect sName sFrom sMaster sSys sDatabases sWhere sDBO
93015>>>>>        
93015>>>>>        Get _SqlFindKeyWord CI_SQLSelect       to sSelect
93016>>>>>        Get _SqlFindKeyWord CI_SQLName         to sName                             
93017>>>>>        Get _SqlFindKeyWord CI_SQLDBO          to sDBO
93018>>>>>        Get _SqlFindKeyWord CI_SQLFrom         to sFrom
93019>>>>>        Get _SqlFindKeyWord CI_SQLMaster       to sMaster
93020>>>>>        Get _SqlFindKeyWord CI_SQLSys          to sSys
93021>>>>>        Get _SqlFindKeyWord CI_SQLDatabases    to sDatabases
93022>>>>>        Get _SqlFindKeyWord CI_SQLWhere        to sWhere
93023>>>>>        Move (sSelect * sName * sFrom * "[" + sMaster + "].[" + sDBO + "].[" + sSys + sDatabases + "]" * sWhere * sName) to sRetval
93024>>>>>        Function_Return sRetval
93025>>>>>    End_Function  
93026>>>>>    
93026>>>>>    // To enumerate SQL database resources with ESQL and return the result as a string array,
93026>>>>>    // for DAW drivers.
93026>>>>>    // Returns: A string array.
93026>>>>>    Function SqlEnumerateEsqlDAW String sStmt Integer iColumn Returns String[]
93028>>>>>        String[] sReturnArray
93029>>>>>        String sValue sPrevious
93029>>>>>        Handle hoSQLHandler hoSQLConnect hstmt
93029>>>>>        Integer iFetchResult iRows
93029>>>>>        tSQLConnection SQLConnection
93029>>>>>        tSQLConnection SQLConnection
93029>>>>>        
93029>>>>>        Get phoSQLManager to hoSQLHandler
93030>>>>>                
93030>>>>>        If (hoSQLHandler <> 0) Begin 
93032>>>>>            Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
93033>>>>>            Get SQLConnect of hoSQLHandler SQLConnection.sDriverID SQLConnection.sConnectionString to hoSQLConnect
93034>>>>>            
93034>>>>>            If (hoSQLConnect <> 0) Begin   
93036>>>>>                Get SQLOpen of hoSQLConnect to hstmt
93037>>>>>                If (hstmt <> 0) Begin                                   
93039>>>>>                    Send SqlExecDirect of hstmt sStmt                                             
93040>>>>>                    Get SqlStmtAttribute of hstmt SqlSTMTATTRIB_ROWCOUNT to iRows 
93041>>>>>                    Repeat
93041>>>>>>
93041>>>>>                        Get SQLFetch of hstmt to iFetchResult
93042>>>>>                        If (iFetchResult <> 0) Begin
93044>>>>>                            Get SQLColumnValue of hstmt iColumn to sValue
93045>>>>>                            If (sValue <> sPrevious) Begin
93047>>>>>                                Move (Trim(sValue)) to sReturnArray[SizeOfArray(sReturnArray)
93048>>>>>                            End
93048>>>>>>
93048>>>>>                            Move sValue to sPrevious
93049>>>>>                        End
93049>>>>>>
93049>>>>>                    Until (iFetchResult = 0)
93051>>>>>                    Send SQLClose of hstmt
93052>>>>>                End
93052>>>>>>
93052>>>>>                Send SQLDisconnect of hoSQLConnect    
93053>>>>>            End
93053>>>>>>
93053>>>>>        End
93053>>>>>>
93053>>>>>    
93053>>>>>        Function_Return sReturnArray
93054>>>>>    End_Function   
93055>>>>>
93055>>>>>    // To enumerate SQL database resources with ESQL and return the result as a string array,
93055>>>>>    // for Mertech drivers.
