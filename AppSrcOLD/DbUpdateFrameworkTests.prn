93187>>>>>    // Checks that the passed sDriverID is defined.
93187>>>>>    // Also checks if the driver has been loaded; else it gets loaded.
93187>>>>>    Function _SqlCheckCurrentDriver String sDriverID Returns Boolean
93189>>>>>        Boolean bOK                         
93189>>>>>        Integer iDriver
93189>>>>>        
93189>>>>>        If (sDriverID = DATAFLEX_ID) Begin
93191>>>>>            Function_Return False
93192>>>>>        End                      
93192>>>>>>
93192>>>>>
93192>>>>>        Get IsDAWSQLDriver sDriverID to bOK
93193>>>>>
93193>>>>>        If (bOK = False) Begin
93195>>>>>            Get IsMertechDriver sDriverID to bOK
93196>>>>>        End   
93196>>>>>>
93196>>>>>        
93196>>>>>        If (bOK = False) Begin        
93198>>>>>            Error DFERR_PROGRAM "Driver needs to be one of MSSQLDRV, DB2_DRV, ODBC_DRV, SQLFLEX, ORAFLEX, MDSPgSQL or MDSMySQL"
93199>>>>>>
93199>>>>>            Function_Return False
93200>>>>>        End 
93200>>>>>>
93200>>>>>        
93200>>>>>        Get DriverIndex sDriverID to iDriver
93201>>>>>        If (iDriver = 0) Begin
93203>>>>>            Load_Driver sDriverID
93204>>>>>        End
93204>>>>>>
93204>>>>>        
93204>>>>>        Function_Return True
93205>>>>>    End_Function
