85126>>>                Send Add_LineLn sParam9
85127>>>            End
85127>>>>
85127>>>
85127>>>            If (iArgs = 10 and sParam10 <> "") Begin
85129>>>                Send Add_Line sParam10
85130>>>            End
85130>>>>
85130>>>
85130>>>            Move Self to hoObj
85131>>>        End_Object
