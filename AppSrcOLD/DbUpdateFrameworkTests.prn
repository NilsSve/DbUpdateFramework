94298>>>>>    // Removes the passed table name completely from disk, filelist (& Sql Server if an Sql-driver)
94298>>>>>    Function ApiTableRemove Handle hTable Returns Boolean
94300>>>>>        String sTableName sDriverID  
94300>>>>>        Boolean bOk     
94300>>>>>        String sDataPath
94300>>>>>        
94300>>>>>        Get AutoConnectionIDLogin to bOK
94301>>>>>        Move False to Err 
94302>>>>>        Get psDriverID to sDriverID
94303>>>>>        Get UtilTableHandleToString hTable sDriverID to sTableName
94304>>>>>        If (sTableName = "") Begin
94306>>>>>            Function_Return False
94307>>>>>        End                      
94307>>>>>>
94307>>>>>        
94307>>>>>        Send Ignore_Error of Error_Object_Id DFERR_CANT_DELETE_FILE
94308>>>>>        Delete_db sTableName 
94309>>>>>        Send Trap_Error of Error_Object_Id DFERR_CANT_DELETE_FILE 
94310>>>>>        
94310>>>>>        If (sDriverID <> DATAFLEX_ID) Begin
94312>>>>>            Get SqlTableRemoveByTableName sDriverID sTableName to bOk   
94313>>>>>            Get psDataPathFirstPart to sDataPath
94314>>>>>            Get vDeleteFile (sDataPath + sTableName + ".int") to bOk
94315>>>>>        End
94315>>>>>>
94315>>>>>        // Also remove table from filelist.cfg in case the physical file didn't exist.  
94315>>>>>        If (hTable <> 0) Begin
94317>>>>>            Set_Attribute DF_FILE_ROOT_NAME     of hTable to ""
94320>>>>>            Set_Attribute DF_FILE_DISPLAY_NAME  of hTable to ""
94323>>>>>            Set_Attribute DF_FILE_LOGICAL_NAME  of hTable to ""  
94326>>>>>        End
94326>>>>>>
94326>>>>>        
94326>>>>>        Function_Return (hTable <> 0)
94327>>>>>    End_Function
