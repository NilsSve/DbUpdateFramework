89450>>>>>>>>>    Function SQLIniFileDeleteAllConnections Returns Boolean
89452>>>>>>>>>        Integer iCount 
89452>>>>>>>>>        Boolean bExists 
89452>>>>>>>>>        String sSection
89452>>>>>>>>>        
89452>>>>>>>>>        Move False to Err
89453>>>>>>>>>        Move 1 to iCount
89454>>>>>>>>>        Get psIniSectionName to sSection
89455>>>>>>>>>        Get SectionExists (CS_SQLIniSectionName + String(iCount)) to bExists
89456>>>>>>>>>        While (bExists = True)
89460>>>>>>>>>            Send DeleteSection (CS_SQLIniSectionName + String(iCount))
89461>>>>>>>>>            Increment iCount
89462>>>>>>>>>            Get SectionExists (CS_SQLIniSectionName + String(iCount)) to bExists
89463>>>>>>>>>        Loop
89464>>>>>>>>>>
89464>>>>>>>>>        Function_Return (Err = False)
89465>>>>>>>>>    End_Function
89466>>>>>>>>>    
89466>>>>>>>>>    Function SQLIniFileDeleteConnection Integer iItem Returns Boolean
89468>>>>>>>>>        Integer iCount 
89468>>>>>>>>>        String sSection 
89468>>>>>>>>>        Boolean bExists
89468>>>>>>>>>        
89468>>>>>>>>>        Move False to Err
89469>>>>>>>>>        Move 1 to iCount
89470>>>>>>>>>        Get psIniSectionName to sSection
89471>>>>>>>>>        Get KeyExists sSection CS_SQLIniConnectionIdKeyword to bExists
89472>>>>>>>>>        While (bExists = True)
89476>>>>>>>>>            If (iCount = iItem) Begin   
89478>>>>>>>>>                Send DeleteSection sSection
89479>>>>>>>>>//                Set IniFileValue sSection (CS_SQLIniSectionName + String(iCount)) to ""
89479>>>>>>>>>                Move 9999 to iCount // Just some ridiculously high number to get out of the loop as we're done.
89480>>>>>>>>>            End
89480>>>>>>>>>>
89480>>>>>>>>>            Increment iCount
89481>>>>>>>>>            Get KeyExists sSection (CS_SQLIniSectionName + String(iCount)) to bExists
89482>>>>>>>>>        Loop
89483>>>>>>>>>>
89483>>>>>>>>>        
89483>>>>>>>>>        Function_Return (Err = False)
89484>>>>>>>>>    End_Function
89485>>>>>>>>>    
89485>>>>>>>>>    // Returns all connection details for the passed Connection ID as a tSQLConnection
89485>>>>>>>>>    // If it fails the returned struct member SQLConnection.bError = True. 
89485>>>>>>>>>    Function SQLIniFileConnectionID String sConnectionID Returns tSQLConnection
89487>>>>>>>>>        tSQLConnection[] SQLConnectionsArray
89487>>>>>>>>>        tSQLConnection[] SQLConnectionsArray
89488>>>>>>>>>        tSQLConnection   SQLConnection
89488>>>>>>>>>        tSQLConnection   SQLConnection
89488>>>>>>>>>        Integer iIndex
89488>>>>>>>>>        
89488>>>>>>>>>        Get SQLIniFileConnectionIDIndex sConnectionID to iIndex
89489>>>>>>>>>        If (iIndex = -1) Begin
89491>>>>>>>>>            Move True to SQLConnection.bError
89492>>>>>>>>>            Function_Return SQLConnection
89493>>>>>>>>>        End
89493>>>>>>>>>>
89493>>>>>>>>>
89493>>>>>>>>>        Get SQLIniFileReadConnections to SQLConnectionsArray
89494>>>>>>>>>        Move SQLConnectionsArray[iIndex -1] to SQLConnection
89495>>>>>>>>>        
89495>>>>>>>>>        Function_Return SQLConnection    
89496>>>>>>>>>    End_Function
89497>>>>>>>>>            
89497>>>>>>>>>    // Returns -1 if the passed connection ID was not found, else the item number.
89497>>>>>>>>>    Function SQLIniFileConnectionIDIndex String sConnectionID Returns Integer
89499>>>>>>>>>        tSQLConnection[] SQLConnectionsArray
89499>>>>>>>>>        tSQLConnection[] SQLConnectionsArray
89500>>>>>>>>>        Integer iRetval iCount iSize
89500>>>>>>>>>        String sValue
89500>>>>>>>>>        Boolean bExists
89500>>>>>>>>>        
89500>>>>>>>>>        Move -1 to iRetval
89501>>>>>>>>>
89501>>>>>>>>>        Get SQLIniFileReadConnections to SQLConnectionsArray
89502>>>>>>>>>        Move (SizeOfArray(SQLConnectionsArray)) to iSize
89503>>>>>>>>>        Decrement iSize
89504>>>>>>>>>        For iCount from 0 to iSize
89510>>>>>>>>>>
89510>>>>>>>>>            Move SQLConnectionsArray[iCount].sConnectionID to sValue 
89511>>>>>>>>>            Move (Uppercase(sValue) = Uppercase(sConnectionID)) to bExists
89512>>>>>>>>>            If (bExists) Begin
89514>>>>>>>>>                Move (iCount + 1) to iRetval // The [ConnectionX] keys are one-based (starts at 1) but the loop starts at zero.
89515>>>>>>>>>                Move iSize to iCount         // We're done!
89516>>>>>>>>>            End
89516>>>>>>>>>>
89516>>>>>>>>>        Loop
89517>>>>>>>>>>
89517>>>>>>>>>                
89517>>>>>>>>>        Function_Return iRetval
89518>>>>>>>>>    End_Function       
89519>>>>>>>>>    
89519>>>>>>>>>    // Checks if the passed sConnectionID exists more than once in the passed struct array.
89519>>>>>>>>>    // Used to check that ConnectionID's are unique.
89519>>>>>>>>>    Function IsConnectionIDDuplicate String sConnectionID Returns Boolean
89521>>>>>>>>>        Integer iCount iSize iItems
89521>>>>>>>>>        String sValue
89521>>>>>>>>>        Boolean bExists                                   
89521>>>>>>>>>        tSQLConnection[] SQLConnectionsArray 
89521>>>>>>>>>        tSQLConnection[] SQLConnectionsArray 
89522>>>>>>>>>        
89522>>>>>>>>>        Move 0 to iItems                     
89523>>>>>>>>>        Get SQLIniFileReadConnections to SQLConnectionsArray
89524>>>>>>>>>        Move (SizeOfArray(SQLConnectionsArray)) to iSize
89525>>>>>>>>>        Decrement iSize
89526>>>>>>>>>        For iCount from 0 to iSize
89532>>>>>>>>>>
89532>>>>>>>>>            Move SQLConnectionsArray[iCount].sConnectionID to sValue 
89533>>>>>>>>>            Move (sValue = sConnectionID) to bExists
89534>>>>>>>>>            If (bExists) Begin
89536>>>>>>>>>                Increment iItems
89537>>>>>>>>>            End
89537>>>>>>>>>>
89537>>>>>>>>>        Loop
89538>>>>>>>>>>
89538>>>>>>>>>                
89538>>>>>>>>>        Function_Return (iItems > 1)
89539>>>>>>>>>    End_Function       
89540>>>>>>>>>    
89540>>>>>>>>>    // To update the SQLConnections.ini file with a new default Connection ID.
89540>>>>>>>>>    Function SQLIniFileSetDefaultConnection String sConnectionID Returns Boolean
89542>>>>>>>>>        Boolean bRetval bOK
89542>>>>>>>>>        Integer iItem iSize iCount
89542>>>>>>>>>        tSQLConnection[] SQLConnectionsArray
89542>>>>>>>>>        tSQLConnection[] SQLConnectionsArray
89543>>>>>>>>>        tSQLConnection SQLConnection
89543>>>>>>>>>        tSQLConnection SQLConnection
89543>>>>>>>>>        String sConnectionString
89543>>>>>>>>>        
89543>>>>>>>>>        Move False to Err     
89544>>>>>>>>>        Get psConnectionString to sConnectionString             
89545>>>>>>>>>        
89545>>>>>>>>>        Get SQLIniFileReadConnections to SQLConnectionsArray
89546>>>>>>>>>        Move (SizeOfArray(SQLConnectionsArray)) to iSize
89547>>>>>>>>>        Decrement iSize
89548>>>>>>>>>        // Set all current connection to inactive.
89548>>>>>>>>>        For iCount from 0 to iSize
89554>>>>>>>>>>
89554>>>>>>>>>            Move False to SQLConnectionsArray[iCount].bEnabled
89555>>>>>>>>>        Loop                                              
89556>>>>>>>>>>
89556>>>>>>>>>        
89556>>>>>>>>>        Get SQLIniFileConnectionID sConnectionID to SQLConnection
89557>>>>>>>>>        Move True              to SQLConnection.bEnabled
89558>>>>>>>>>        Move sConnectionString to SQLConnection.sConnectionString
89559>>>>>>>>>        Move (InsertInArray(SQLConnectionsArray, 0, SQLConnection)) to SQLConnectionsArray
89560>>>>>>>>>        Get SQLIniFileWriteConnections SQLConnectionsArray to bOK
89561>>>>>>>>>        
89561>>>>>>>>>        Function_Return (bOK = True)
89562>>>>>>>>>    End_Function
89563>>>>>>>>>    
89563>>>>>>>>>    // Used for updating an existing connection with new data.
89563>>>>>>>>>    // Returns True if successful.
89563>>>>>>>>>    Function SQLIniFileUpdateConnection tSQLConnection SQLConnection Returns Boolean
89565>>>>>>>>>        Boolean bRetval bOK
89565>>>>>>>>>        Integer iItem iSize iCount
89565>>>>>>>>>        tSQLConnection[] SQLConnectionsArray
89565>>>>>>>>>        tSQLConnection[] SQLConnectionsArray
89566>>>>>>>>>        
89566>>>>>>>>>        Move False to Err           
89567>>>>>>>>>        Move -1 to iItem  
89568>>>>>>>>>        Get SQLIniFileReadConnections to SQLConnectionsArray
89569>>>>>>>>>        Move (SizeOfArray(SQLConnectionsArray)) to iSize
89570>>>>>>>>>        Decrement iSize
89571>>>>>>>>>        // Set all current connection to inactive.
89571>>>>>>>>>        For iCount from 0 to iSize
89577>>>>>>>>>>
89577>>>>>>>>>            Move False to SQLConnectionsArray[iCount].bEnabled 
89578>>>>>>>>>            If (SQLConnectionsArray[iCount].sConnectionID = SQLConnection.sConnectionID) Begin
89580>>>>>>>>>                Move iCount to iItem
89581>>>>>>>>>            End
89581>>>>>>>>>>
89581>>>>>>>>>        Loop                                              
89582>>>>>>>>>>
89582>>>>>>>>>        
89582>>>>>>>>>        If (iItem <> -1) Begin
89584>>>>>>>>>            Move True to SQLConnection.bEnabled
89585>>>>>>>>>            Move SQLConnection to SQLConnectionsArray[iItem]
89586>>>>>>>>>            Get SQLIniFileWriteConnections SQLConnectionsArray to bOK
89587>>>>>>>>>        End
89587>>>>>>>>>>
89587>>>>>>>>>        
89587>>>>>>>>>        Function_Return (bOK = True)
89588>>>>>>>>>    End_Function
89589>>>>>>>>>    
89589>>>>>>>>>    Function SQLIniFileReadConnections Returns tSQLConnection[]
89591>>>>>>>>>        tSQLConnection[] SQLConnectionsArray
89591>>>>>>>>>        tSQLConnection[] SQLConnectionsArray
89592>>>>>>>>>        String sSection sValue
89592>>>>>>>>>        Integer iCount
89592>>>>>>>>>        Boolean bExists bEnabled
89592>>>>>>>>>        
89592>>>>>>>>>        Get psIniSectionName to sSection
89593>>>>>>>>>        Get SectionExists sSection to bExists
89594>>>>>>>>>        If (bExists = False) Begin   
89596>>>>>>>>>            Function_Return SQLConnectionsArray
89597>>>>>>>>>        End                                  
89597>>>>>>>>>>
89597>>>>>>>>>        Get SectionExists CS_SQLIniConnectionSection to bExists
89598>>>>>>>>>        If (bExists = True) Begin
89600>>>>>>>>>            Error DFERR_PROGRAM "Sorry, the format for the SQLConnections.ini file has been changed and this file has the old format that is no longer valid and thus cannot be read. You need to re-enter your connection(s)."
89601>>>>>>>>>>
89601>>>>>>>>>        End
89601>>>>>>>>>>
89601>>>>>>>>>                
89601>>>>>>>>>        Move 1 to iCount // The section name "[ConnectionXX]" starts with "1"
89602>>>>>>>>>        Get SectionExists (CS_SQLIniSectionName + String(iCount)) to bExists 
89603>>>>>>>>>        
89603>>>>>>>>>        While (bExists = True)
89607>>>>>>>>>            // We always put the enabled/active connection at the top
89607>>>>>>>>>            Move (iCount = 1) to bEnabled
89608>>>>>>>>>            Move bEnabled to SQLConnectionsArray[iCount].bEnabled
89609>>>>>>>>>            
89609>>>>>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniConnectionIdKeyword ""        to SQLConnectionsArray[iCount].sConnectionID
89610>>>>>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniDriverKeyword       ""        to SQLConnectionsArray[iCount].sDriverID
89611>>>>>>>>>
89611>>>>>>>>>            // The iDbType might be missing from the ini-file. This is e.g. the case when a DAW Managed Connection "DFConnId.ini" file is read.
89611>>>>>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniDbTypeKeyword       "99"      to sValue
89612>>>>>>>>>            If (sValue = "99") Begin
89614>>>>>>>>>                Get SqlUtilDbTypeFromDriver SQLConnectionsArray[iCount].sDriverID to sValue
89615>>>>>>>>>            End
89615>>>>>>>>>>
89615>>>>>>>>>            Move sValue                                                                                     to SQLConnectionsArray[iCount].iDbType
89616>>>>>>>>>
89616>>>>>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniConnectionKeyWord   ""        to SQLConnectionsArray[iCount].sConnectionString
89617>>>>>>>>>            Get ParseKeyWord SQLConnectionsArray[iCount].sConnectionString (CS_SQLIniServerKeyword + "=")   to SQLConnectionsArray[iCount].sServer
89618>>>>>>>>>            If (SQLConnectionsArray[iCount].sServer = "") Begin
89620>>>>>>>>>                Get ParseKeyWord SQLConnectionsArray[iCount].sConnectionString (CS_SQLIniDSNKeyword +"=")   to SQLConnectionsArray[iCount].sServer
89621>>>>>>>>>            End
89621>>>>>>>>>>
89621>>>>>>>>>            Get ParseKeyWord SQLConnectionsArray[iCount].sConnectionString (CS_SQLIniDatabaseKeyword + "=") to SQLConnectionsArray[iCount].sDatabase
89622>>>>>>>>>
89622>>>>>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniTrustedKeyword      ""        to sValue
89623>>>>>>>>>            Move (If(Uppercase(sValue) = "YES", True, False))                                               to SQLConnectionsArray[iCount].bTrusted
89624>>>>>>>>>
89624>>>>>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniUIDKeyword          ""        to SQLConnectionsArray[iCount].sUserID
89625>>>>>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniDFPWDKeyword        ""        to sValue
89626>>>>>>>>>            If (pbDFConnId(Self) = False and sValue <> "") Begin
89628>>>>>>>>>                Get DecryptPassword sValue to sValue    
89629>>>>>>>>>            End
89629>>>>>>>>>>
89629>>>>>>>>>            Move sValue                                                                                     to SQLConnectionsArray[iCount].sPassword
89630>>>>>>>>>            
89630>>>>>>>>>            // Here we reconstruct the connection string to be complete with all params;
89630>>>>>>>>>            Get ConstructConnectionString SQLConnectionsArray[iCount].sDriverID SQLConnectionsArray[iCount].sServer SQLConnectionsArray[iCount].sDatabase ;                                          SQLConnectionsArray[iCount].bTrusted SQLConnectionsArray[iCount].sUserID SQLConnectionsArray[iCount].sPassword ;                                          to SQLConnectionsArray[iCount].sConnectionString    
89631>>>>>>>>>            
89631>>>>>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniSchemaKeyword          ""     to SQLConnectionsArray[iCount].sSchema
89632>>>>>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniBaseTableSpaceKeyword  ""     to SQLConnectionsArray[iCount].sBaseTableSpace
89633>>>>>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniLongTableSpaceKeyword  ""     to SQLConnectionsArray[iCount].sLongTableSpace
89634>>>>>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniIndexTableSpaceKeyword ""     to SQLConnectionsArray[iCount].sIndexTableSpace
89635>>>>>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniSilentLoginKeyword     ""     to SQLConnectionsArray[iCount].bSilentLogin  
89636>>>>>>>>>//            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniDisabledKeyword        ""     to SQLConnectionsArray[iCount].bDisabled
89636>>>>>>>>>
89636>>>>>>>>>            Increment iCount
89637>>>>>>>>>            Get SectionExists (CS_SQLIniSectionName + String(iCount)) to bExists
89638>>>>>>>>>        Loop
89639>>>>>>>>>>
89639>>>>>>>>>        
89639>>>>>>>>>        // Lastly, we remove the very first array item as it is empty (we started at 1 because that is the first [Connection#])
89639>>>>>>>>>        If (SizeOfArray(SQLConnectionsArray) > 0) Begin
89641>>>>>>>>>            Move (RemoveFromArray(SQLConnectionsArray, 0)) to SQLConnectionsArray
89642>>>>>>>>>        End
89642>>>>>>>>>>
89642>>>>>>>>>        
89642>>>>>>>>>        Function_Return SQLConnectionsArray
89643>>>>>>>>>    End_Function 
89644>>>>>>>>>        
89644>>>>>>>>>    Function SQLIniFileWriteConnections tSQLConnection[] SQLConnectionsArray Returns Boolean
89646>>>>>>>>>        Integer iCount iSize iItem
89646>>>>>>>>>        Boolean bIsOneActive bEnabled bExists bOK
89646>>>>>>>>>        String sConnectionString sSection sValue
89646>>>>>>>>>        
89646>>>>>>>>>        // First we need to _remove_ all current connections in the ini-file, we
89646>>>>>>>>>        // do that by setting their values to "".
89646>>>>>>>>>        Move 0 to iCount  
89647>>>>>>>>>        Get SQLIniFileDeleteAllConnections to bOK
89648>>>>>>>>>        If (bOK = False) Begin
89650>>>>>>>>>            Function_Return False
89651>>>>>>>>>        End                 
89651>>>>>>>>>>
89651>>>>>>>>>        
89651>>>>>>>>>        Move False to Err
89652>>>>>>>>>        Get psIniSectionName to sSection                                                          
89653>>>>>>>>>        // Sorting will make sure we have the active connection record as the first connection item in the ini-file.
89653>>>>>>>>>        Move (SortArray(SQLConnectionsArray, Self, (RefFunc(SortActiveFirst)))) to SQLConnectionsArray
89654>>>>>>>>>        Move (SizeOfArray(SQLConnectionsArray)) to iSize
89655>>>>>>>>>        Decrement iSize       
89656>>>>>>>>>        
89656>>>>>>>>>        For iCount from 0 to iSize
89662>>>>>>>>>>
89662>>>>>>>>>            // DF 19 compatible settings:
89662>>>>>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniConnectionIdKeyword   to SQLConnectionsArray[iCount].sConnectionID
89663>>>>>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniDriverKeyword         to SQLConnectionsArray[iCount].sDriverID
89664>>>>>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniUIDKeyword            to SQLConnectionsArray[iCount].sUserID
89665>>>>>>>>>            
89665>>>>>>>>>            Move SQLConnectionsArray[iCount].sPassword to sValue
89666>>>>>>>>>            If (pbDFConnId(Self) = False and sValue <> "") Begin
89668>>>>>>>>>                Get EncryptPassword sValue to sValue    
89669>>>>>>>>>            End
89669>>>>>>>>>>
89669>>>>>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniDFPWDKeyword          to sValue
89670>>>>>>>>>
89670>>>>>>>>>            If (SQLConnectionsArray[iCount].bTrusted = True) Begin
89672>>>>>>>>>                Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniTrustedKeyword    to CS_SQLIniConnectionYes
89673>>>>>>>>>            End                                                                
89673>>>>>>>>>>
89673>>>>>>>>>            
89673>>>>>>>>>            Get ConstructShortConnectionString SQLConnectionsArray[iCount].sDriverID SQLConnectionsArray[iCount].sServer SQLConnectionsArray[iCount].sDatabase ;                                            to SQLConnectionsArray[iCount].sConnectionString
89674>>>>>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniConnectionKeyWord     to SQLConnectionsArray[iCount].sConnectionString
89675>>>>>>>>>            
89675>>>>>>>>>            // The Database Update Framework extended settings:
89675>>>>>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniDbTypeKeyword          to SQLConnectionsArray[iCount].iDbType
89676>>>>>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniSchemaKeyword          to SQLConnectionsArray[iCount].sSchema
89677>>>>>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniBaseTableSpaceKeyword  to SQLConnectionsArray[iCount].sBaseTableSpace
89678>>>>>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniLongTableSpaceKeyword  to SQLConnectionsArray[iCount].sLongTableSpace
89679>>>>>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniIndexTableSpaceKeyword to SQLConnectionsArray[iCount].sIndexTableSpace
89680>>>>>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniSilentLoginKeyword     to SQLConnectionsArray[iCount].bSilentLogin
89681>>>>>>>>>        Loop                 
89682>>>>>>>>>>
89682>>>>>>>>>        
89682>>>>>>>>>        Function_Return (bOK and Err = False)
89683>>>>>>>>>    End_Function
