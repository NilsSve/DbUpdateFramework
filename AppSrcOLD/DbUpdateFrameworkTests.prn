93058>>>>>        tSQLConnection SQLConnection
93058>>>>>        
93058>>>>>        Get _MertechSQLManagerHandle to hoSQLHandler
93059>>>>>
93059>>>>>        If (hoSQLHandler <> 0) Begin 
93061>>>>>            Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
93062>>>>>            Get SQLConnect of hoSQLHandler SQLConnection.sDriverID SQLConnection.sServer SQLConnection.sUserID SQLConnection.sPassword to hoSQLConnect
93063>>>>>            
93063>>>>>            If (hoSQLConnect <> 0) Begin   
93065>>>>>                Get SQLOpen of hoSQLConnect to hStmt
93066>>>>>                If (hStmt <> 0) Begin                                   
93068>>>>>                    Send SqlExecDirect of hStmt sStmt                                             
93069>>>>>                    Get SqlStmtAttribute of hStmt SqlSTMTATTRIB_ROWCOUNT to iRows
93070>>>>>                    Repeat
93070>>>>>>
93070>>>>>                        Get SQLFetch of hStmt to iFetchResult
93071>>>>>                        If (iFetchResult <> 0) Begin
93073>>>>>                            Get SQLColumnValue of hStmt 1 to sValue
93074>>>>>                            Move (Trim(sValue)) to sReturnArray[SizeOfArray(sReturnArray)
93075>>>>>                        End
93075>>>>>>
93075>>>>>                    Until (iFetchResult = 0)
93077>>>>>                    Send SQLClose of hStmt
93078>>>>>                End
93078>>>>>>
93078>>>>>                Send SQLDisconnect of hoSQLConnect    
93079>>>>>            End
93079>>>>>>
93079>>>>>        End
93079>>>>>>
93079>>>>>    
93079>>>>>        Function_Return sReturnArray
93080>>>>>    End_Function 
