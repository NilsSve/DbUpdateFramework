91409>>>>>    // Rename a field/column by table name.
91409>>>>>    Function SqlColumnRenameByTableName String sTableName String sColumnName String sNewColumnName Returns Boolean
91411>>>>>        Integer iColumn iDbType iDataType
91411>>>>>        String sDriverID sStmt sAlterTable sRenameColumn sVal sColumnKeyWord sOrgTableName sDatabase sDataType
91411>>>>>        Boolean bExists bOK bRetval                                        
91411>>>>>        Handle hTable
91411>>>>>        
91411>>>>>        Move sTableName to sOrgTableName
91412>>>>>        Get psDriverID to sDriverID
91413>>>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
91414>>>>>        If (bOK = False) Begin
91416>>>>>            Function_Return False
91417>>>>>        End
91417>>>>>>
91417>>>>>        
91417>>>>>        Get _SqlFindColumnName sTableName sColumnName to sVal
91418>>>>>        If (sVal = "") Begin
91420>>>>>            Function_Return False
91421>>>>>        End                          
91421>>>>>>
91421>>>>>        
91421>>>>>        Get piDbType to iDbType
91422>>>>>        Get _SqlFindKeyWord CI_SQLColumn       to sColumnKeyWord
91423>>>>>        Get _SqlProperTableName sTableName     to sTableName
91424>>>>>        Get _SqlFindKeyWord CI_SQLAlterTable   to sAlterTable
91425>>>>>        Get _SqlFindKeyWord CI_SQLRenameColumn to sRenameColumn
91426>>>>>        
91426>>>>>        Case Begin
91426>>>>>            Case (iDbType = EN_dbTypeMSSQL) 
91428>>>>>                Move (sRenameColumn * "'" + sTableName + "." + sColumnName + "'," * "'" + sNewColumnName + "'," * "'" + sColumnKeyWord + "'") to sStmt
91429>>>>>                Case Break
91430>>>>>            // Alter table "SYS"."Customer" rename column "Comments" to "NewColumnName"    
91430>>>>>            Case (iDbType = EN_dbTypeOracle) 
91433>>>>>                Move (sAlterTable * '"' + sTableName + '"' * sRenameColumn * '"' + sColumnName + '"' * "TO" * '"' + sNewColumnName + '"') to sStmt
91434>>>>>                Case Break  
91435>>>>>            // ALTER TABLE Schema.TableName RENAME COLUMN "deptnumb" TO "deptnum"
91435>>>>>            Case (iDbType = EN_dbTypeDB2)
91438>>>>>                Move (sAlterTable *  sTableName * sRenameColumn * '"' + sColumnName + '"' * "TO" * '"' + sNewColumnName + '"') to sStmt
91439>>>>>                Case Break
91440>>>>>            // ALTER TABLE "Customer" RENAME COLUMN "Comments" TO "NewColumnName"
91440>>>>>            Case (iDbType = EN_dbTypePostgre) 
91443>>>>>                Move sOrgTableName to sTableName
91444>>>>>                Move (sAlterTable * '"' + sTableName + '"' * sRenameColumn * '"' + sColumnName + '"' * "TO" * '"' + sNewColumnName + '"') to sStmt
91445>>>>>                Case Break  
91446>>>>>            Case (iDbType = EN_dbTypeMySQL)
91449>>>>>                // ALTER TABLE orderentry.customer CHANGE Comments NewColumnName text // Note: The last token is the column type!
91449>>>>>                Move sOrgTableName to sTableName
91450>>>>>                Get psDatabase to sDatabase 
91451>>>>>                Get UtilTableNameToHandle sTableName to hTable
91452>>>>>                If (hTable = 0) Begin
91454>>>>>                    Get UtilTableOpen hTable sTableName DF_SHARE to bOK
91455>>>>>                    If (bOK = False) Begin
91457>>>>>                        Function_Return False 
91458>>>>>                    End
91458>>>>>>
91458>>>>>                    Get NextFreeFilelistSlot to hTable
91459>>>>>                End
91459>>>>>>
91459>>>>>                Else Begin
91460>>>>>                    Open hTable
91462>>>>>                End          
91462>>>>>>
91462>>>>>                Get SQLColumnType sDriverID hTable sTableName sColumnName to iDataType
91463>>>>>                Get UtilColumnTypeToString sDriverID iDbType iDataType    to sDataType
91464>>>>>                Move (sAlterTable * sDatabase + "." + sTableName * sRenameColumn * sColumnName * sNewColumnName * sDataType) to sStmt
91465>>>>>                Case Break  
91466>>>>>            Case Else 
91466>>>>>                Move (sAlterTable * "'" + sTableName + "'" * sRenameColumn * "'" + sTableName + "." + sColumnName + "'" * "TO" * "'" + sNewColumnName + "'") to sStmt
91467>>>>>        Case End
91467>>>>>        
91467>>>>>        Move False to Err   
91468>>>>>        Send SqlUtilExecuteQuery sStmt sDriverID
91469>>>>>        Move (Err = False) to bRetval
91470>>>>>        // We also need to remove the cache-file since the table has been changed
91470>>>>>        Get UtilDeleteCacheFile sTableName to bOK
91471>>>>>    
91471>>>>>        Function_Return bRetval
91472>>>>>    End_Function    
91473>>>>>
91473>>>>>    Function SqlColumnType String sDriverID Handle hTable String sTableName String sColumnName Returns Integer
91475>>>>>        Handle hoSQLHandler hSQLConnect hStmt
91475>>>>>        Boolean bMertechDriver                                     
91475>>>>>        Integer iNumCols iCount iSQLType iDataType
91475>>>>>        String sValue 
91475>>>>>        
91475>>>>>        Get IsMertechDriver sDriverID to bMertechDriver
91476>>>>>        If (bMertechDriver = False) Begin
91478>>>>>            Get phoSQLManager to hoSQLHandler
91479>>>>>        End                                  
91479>>>>>>
91479>>>>>        Else Begin
91480>>>>>            Get _MertechSQLManagerHandle to hoSQLHandler
91481>>>>>        End                                    
91481>>>>>>
91481>>>>>        
91481>>>>>        Get SQLFileConnect of hoSQLHandler hTable to hSQLConnect
91482>>>>>        If (hSQLConnect <> 0) Begin
91484>>>>>            Get SQLOpen of hSQLConnect to hStmt
91485>>>>>            If (hStmt <> 0) Begin
91487>>>>>                Send SQLExecDirect of hStmt ("select * from" * sTableName)
91488>>>>>        
91488>>>>>                Get SQLStmtAttribute of hStmt SQLSTMTATTRIB_COLUMNCOUNT to iNumCols
91489>>>>>                For iCount from 1 to iNumCols
91495>>>>>>
91495>>>>>                    Get SQLColAttribute of hStmt iCount SQLCOLATTRIB_LABEL to sValue
91496>>>>>                    If (Lowercase(sValue) = Lowercase(sColumnName)) Begin
91498>>>>>                        Get SQLColAttribute of hStmt iCount SQLCOLATTRIB_SQLTYPE to iDataType
91499>>>>>                        Move iNumCols to iCount // We're out of here
91500>>>>>                    End
91500>>>>>>
91500>>>>>                Loop                                                
91501>>>>>>
91501>>>>>                
91501>>>>>                Send SQLClose of hStmt
91502>>>>>            End
91502>>>>>>
91502>>>>>            Send SQLDisconnect of hSQLConnect    
91503>>>>>        End
91503>>>>>>
91503>>>>>        
91503>>>>>        Function_Return iDataType
91504>>>>>    End_Function
91505>>>>>        
91505>>>>>    
91505>>>>>    // *** SQL Utility Messages ***
91505>>>>>    // They are not geared at making database changes.
91505>>>>>    //
91505>>>>>
91505>>>>>    // Will create an SQL table with the passed sTableName & sColumnName as Numeric 4.2 to keep
91505>>>>>    // the DbUpdateVersion database revision in.  
91505>>>>>    // Also pass the file number of the current (embedded?) table number used in development.
91505>>>>>    // It will first create the SQL Table & column, then create the .int file and change Filelist.cfg
91505>>>>>    Function SQLCreateDbVersionTable Handle hTable String sColumnName String sDriverID Returns Boolean
91507>>>>>        Boolean bOK bOpened
91507>>>>>        String sTableName sDataType sAlterTable sAddColumn sLengthAndDecimals sStmt sDropColumn
91507>>>>>        
91507>>>>>        Get_Attribute DF_FILE_ROOT_NAME of hTable to sTableName
91510>>>>>        Get _TableNameOnly sTableName to sTableName   
91511>>>>>        If (sTableName = "") Begin
91513>>>>>            Function_Return False
91514>>>>>        End 
91514>>>>>>
91514>>>>>        
91514>>>>>        // This just creates the table and a "dummy" column.
91514>>>>>        Get SqlTableCreate hTable sDriverID to bOK
91515>>>>>        If (bOK = False) Begin
91517>>>>>            Function_Return False 
91518>>>>>        End                      
91518>>>>>>
91518>>>>>        
91518>>>>>        Close hTable
91519>>>>>        Move False to Err
91520>>>>>        
91520>>>>>        Get _SqlFindKeyWord CI_SQLAlterTable to sAlterTable
91521>>>>>        Get _SqlFindKeyWord CI_SQLAdd        to sAddColumn
91522>>>>>        Move "Decimal" to sDataType
91523>>>>>        Get _SqlFormatLengthAndDecimalAsString 4 2 to sLengthAndDecimals
91524>>>>>        
91524>>>>>        // Adds the "sColumnName" passed to the function
91524>>>>>        Move (sAlterTable * sTableName * sAddColumn * sColumnName * sDataType + sLengthAndDecimals) to sStmt 
91525>>>>>        Send SqlUtilExecuteQuery sStmt sDriverID
91526>>>>>        
91526>>>>>        // Now we can delete the dummy column:
91526>>>>>        Get SqlColumnRemoveByTableName sTableName "Dummy" to bOK
91527>>>>>        
91527>>>>>        // Finally, we attach to the newly created table.
91527>>>>>        If (Err = False) Begin    
91529>>>>>            Get ApiTableAttachToSQL hTable True to bOK
91530>>>>>        End
91530>>>>>>
91530>>>>>        Open hTable                                                  
91532>>>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpened
91535>>>>>        
91535>>>>>        Function_Return (Err = False and bOK = True and bOpened = True)
91536>>>>>    End_Function
91537>>>>>    
91537>>>>>    // Checks if a column/field name exists in a SQL table definition
91537>>>>>    // Returns True if it does
91537>>>>>    // Sample:
91537>>>>>    //   Get SQLUtilColumnExists "MySQLTable" "MyColumnName" to bExists
91537>>>>>    Function SQLUtilColumnExists String sTableName String sFieldName Returns Boolean
91539>>>>>        Integer iNumColumns iColumn
91539>>>>>        String sColumn sDriverID
91539>>>>>        String[] sColumnsArray
91540>>>>>        Boolean bExists bOK
91540>>>>>    
91540>>>>>        Move False to bExists  
91541>>>>>        Get AutoConnectionIDLogin to bOK
91542>>>>>        Get psDriverID to sDriverID
91543>>>>>        
91543>>>>>        Get SqlUtilEnumerateColumns sDriverID sTableName to sColumnsArray
91544>>>>>        Move (SizeOfArray(sColumnsArray)) to iNumColumns
91545>>>>>        Decrement iNumColumns
91546>>>>>        For iColumn from 0 to iNumColumns
91552>>>>>>
91552>>>>>            Move sColumnsArray[iColumn] to sColumn
91553>>>>>            If (Uppercase(sFieldName) = Uppercase(sColumn)) Begin
91555>>>>>                Move True to bExists
91556>>>>>                Move iNumColumns to iColumn // We're out of here
91557>>>>>            End
91557>>>>>>
91557>>>>>        Loop
91558>>>>>>
91558>>>>>    
91558>>>>>        Function_Return bExists
91559>>>>>    End_Function
91560>>>>>    
91560>>>>>    Function SQLUtilConvertColumnTypesToSQL2008 Handle hTable Returns Boolean
91562>>>>>        Integer iNumColumns iColumn iDFType iNativeType
91562>>>>>        Boolean bOpened bOK
91562>>>>>        String sColumnName sNativeTypeName
91562>>>>>        
91562>>>>>        Get AutoConnectionIDLogin to bOK
91563>>>>>        Open hTable Mode DF_EXCLUSIVE
91565>>>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpened
91568>>>>>        If (bOpened = False) Begin
91570>>>>>            Error DFERR_PROGRAM ("Function SQLUtilConvertColumnTypesToSQL2008; Could not open table" * String(hTable))
91571>>>>>>
91571>>>>>            Function_Return False 
91572>>>>>        End
91572>>>>>>
91572>>>>>        
91572>>>>>        Move False to Err                               
91573>>>>>        
91573>>>>>        Structure_Start hTable
91574>>>>>            Get_Attribute DF_FILE_NUMBER_FIELDS of hTable to iNumColumns
91577>>>>>        
91577>>>>>            For iColumn from 1 to iNumColumns
91583>>>>>>
91583>>>>>                Get_Attribute DF_FIELD_TYPE             of hTable iColumn to iDfType
91586>>>>>                Get_Attribute DF_FIELD_NAME             of hTable iColumn to sColumnName
91589>>>>>                Get_Attribute DF_FIELD_NATIVE_TYPE      of hTable iColumn to iNativeType
91592>>>>>                Get_Attribute DF_FIELD_NATIVE_TYPE_Name of hTable iColumn to sNativeTypeName
91595>>>>>                
91595>>>>>                Case Begin
91595>>>>>                    Case (iDFType = DF_DATE) 
91597>>>>>                        If (iNativeType = SQL_TYPE_TIMESTAMP) Begin
91599>>>>>                            // Convert datetime to date
91599>>>>>                            Set_Attribute DF_FIELD_NATIVE_TYPE of hTable iColumn to SQL_TYPE_DATE
91602>>>>>                        End
91602>>>>>>
91602>>>>>                        Case Break
91603>>>>>                    Case (iDFType = DF_DATETIME) 
91606>>>>>                        If (iNativeType = SQL_TYPE_TIMESTAMP) Begin
91608>>>>>                            // Convert datetime to datetime2
91608>>>>>                            Set_Attribute DF_FIELD_NATIVE_TYPE of hTable iColumn to SQL_TYPE_TIMESTAMP2
91611>>>>>                        End
91611>>>>>>
91611>>>>>                        Case Break
91612>>>>>                    Case (iDFType = DF_ASCII) 
91615>>>>>                        If (iNativeType = SQL_CHAR) Begin
91617>>>>>                            // Convert char to varchar
91617>>>>>                            Set_Attribute DF_FIELD_NATIVE_TYPE of hTable iColumn to SQL_VARCHAR
91620>>>>>                        End
91620>>>>>>
91620>>>>>                        Case Break
91621>>>>>                    Case (iDFType = DF_TEXT) 
91624>>>>>                        If (iNativeType = SQL_LONGVARCHAR) Begin 
91626>>>>>                            // Convert text to varchar(max)
91626>>>>>                            Set_Attribute DF_FIELD_NATIVE_TYPE of hTable iColumn to SQL_VARCHAR
91629>>>>>                        End
91629>>>>>>
91629>>>>>                        Case Break
91630>>>>>                    Case (iDFType = DF_BINARY) 
91633>>>>>                        If (iNativeType = SQL_LONGVARBINARY) Begin
91635>>>>>                            // Convert image to varbinary(max)
91635>>>>>                            Set_Attribute DF_FIELD_NATIVE_TYPE of hTable iColumn to SQL_VARBINARY
91638>>>>>                        End
91638>>>>>>
91638>>>>>                        Case Break
91639>>>>>                Case End
91639>>>>>            Loop
91640>>>>>>
91640>>>>>        Structure_End hTable
91642>>>>>    
91642>>>>>        Function_Return (Err = False)    
91643>>>>>    End_Function  
91644>>>>>    
91644>>>>>    // Does three things with auxilirary files;
91644>>>>>    // 1) Deletes the cache file in the first Data folder of the psDataPath property as the table at the SQL end has been changed.
91644>>>>>    // 2) Adds the sColumnName to the TableName.tag file in the first Data folder of the psDataPath property
91644>>>>>    // 3) Creates a new TableName.fd file if the DdSrc folder is available (if this is a development environment)
91644>>>>>    Function SqlUtilAdjustAuxFiles Handle hTable String sTableName String sColumnName Returns Boolean
91646>>>>>        String sDataPath sDDSrcPath sVal sDriverID
91646>>>>>        Boolean bOK bExists bMertechDriver
91646>>>>>        Integer iCount iItems iCh iPos
91646>>>>>        
91646>>>>>        // If table name equals e.g. "dbo.MyTable" we need to remove the prefix.
91646>>>>>        If (sTableName contains ".") Begin
91648>>>>>            Move (Pos(".", sTableName)) to iPos
91649>>>>>            Move (Mid(sTableName, 999, (iPos +1))) to sTableName    
91650>>>>>        End                                                     
91650>>>>>>
91650>>>>>        
91650>>>>>        Get psDriverID to sDriverID
91651>>>>>        Get psDataPathFirstPart to sDataPath 
91652>>>>>        Get vFolderExists sDataPath to bOK
91653>>>>>        If (bOK = False) Begin
91655>>>>>            Error DFERR_PROGRAM "Function SqlUtilAdjustAuxFiles; psDataPath not found!"
91656>>>>>>
91656>>>>>            Function_Return False    
91657>>>>>        End                      
91657>>>>>>
91657>>>>>        
91657>>>>>        Get IsMertechDriver sDriverID to bMertechDriver
91658>>>>>        // First delete the cache file:
91658>>>>>        Get UtilDeleteCacheFile sTableName to bOK
91659>>>>>            
91659>>>>>        Get Seq_New_Channel to iCh  
91660>>>>>        If (iCh = DF_SEQ_CHANNEL_NOT_AVAILABLE) Begin
91662>>>>>            Function_Return False
91663>>>>>        End                      
91663>>>>>>
91663>>>>>        
91663>>>>>        Get vFilePathExists (sDataPath + sTableName + ".tag") to bExists
91664>>>>>        If (bExists = False) Begin
91666>>>>>            Function_Return False
91667>>>>>        End                      
91667>>>>>>
91667>>>>>        
91667>>>>>        // Add the new column name to the .tag file: 
91667>>>>>        Append_Output channel iCh (sDataPath + sTableName + ".tag")
91669>>>>>            Writeln channel iCh sColumnName
91672>>>>>        Close_Output
91673>>>>>        
91673>>>>>        // If in development environment; output new .fd file:
91673>>>>>        Get psDdSrcPath of (phoWorkspace(ghoApplication)) to sDDSrcPath
91674>>>>>        Get CountOfPaths of (phoWorkspace(ghoApplication)) sDDSrcPath to iCount
91675>>>>>        If (iCount > 1) Begin
91677>>>>>            Get PathAtIndex of (phoWorkspace(ghoApplication)) sDDSrcPath 1 to sDDSrcPath    
91678>>>>>        End 
91678>>>>>>
91678>>>>>        Get vFolderExists sDDSrcPath to bExists
91679>>>>>        If (bExists = True) Begin                                   
91681>>>>>            Get vFolderFormat sDDSrcPath to sDDSrcPath  
91682>>>>>            Move False to Err 
91683>>>>>            Get AutoConnectionIDLogin to bOK
91684>>>>>            If (hTable <> 0) Begin
91686>>>>>                Open hTable
91688>>>>>            End 
91688>>>>>>
91688>>>>>            Else Begin
91689>>>>>                Get UtilTableOpen hTable sTableName DF_SHARE to bOK
91690>>>>>            End
91690>>>>>>
91690>>>>>                
91690>>>>>            Get_Attribute DF_FILE_OPENED of hTable to bOK
91693>>>>>            If (bOK = True) Begin
91695>>>>>                Output_Aux_File DF_AUX_FILE_FD for hTable to (sDDSrcPath + sTableName + ".fd")
91697>>>>>            End
91697>>>>>>
91697>>>>>            If (Err = True) Begin
91699>>>>>                Move False to bOK
91700>>>>>            End
91700>>>>>>
91700>>>>>        End
91700>>>>>>
91700>>>>>        
91700>>>>>        Function_Return (bOK = True)
91701>>>>>    End_Function  
91702>>>>>    
91702>>>>>    // The table must already exist in the filelist for this function to work.
91702>>>>>    // It creates a rudimentary .int file in the first Data folder of the psDataPath property.
91702>>>>>    Function SqlUtilCreateIntFile Handle hTable String sDriverID String sConnectionID Boolean bAnsi Boolean bSysFile Returns Boolean
91704>>>>>        Boolean bOK bExists bUseConnectionID bMertech
91704>>>>>        String sDataPath sRootName sPhysicalFileName sConnectionString sDatabaseName sSchemaName sANSI_OEM
91704>>>>>        String[] sIndexArray
91705>>>>>        Integer iCount iCh iSize
91705>>>>>        
91705>>>>>        Move (Trim(sConnectionID) <> "") to bUseConnectionID
91706>>>>>        Get psConnectionString to sConnectionString
91707>>>>>
91707>>>>>        Move CS_ANSI_Txt to sANSI_OEM
91708>>>>>        If (bANSI = False) Begin
91710>>>>>            Move CS_OEM_Txt to sANSI_OEM
91711>>>>>        End
91711>>>>>>
91711>>>>>        
91711>>>>>        Get psDataPathFirstPart to sDataPath
91712>>>>>        Get vFolderExists sDataPath to bOK
91713>>>>>        If (bOK = False) Begin
91715>>>>>            Error DFERR_PROGRAM "Function SqlUtilCreateIntFile; psDataPath not found!"
91716>>>>>>
91716>>>>>            Function_Return False    
91717>>>>>        End                      
91717>>>>>>
91717>>>>>        Get vFolderFormat sDataPath to sDataPath 
91718>>>>>
91718>>>>>        Get_Attribute DF_FILE_ROOT_NAME of hTable to sRootName
91721>>>>>        Get _TableNameOnly sRootName to sDatabaseName
91722>>>>>        Move sDatabaseName to sPhysicalFileName
91723>>>>>        Move (sPhysicalFileName + ".int") to sPhysicalFileName
91724>>>>>
91724>>>>>        Get IsMertechDriver sDriverID to bMertech
91725>>>>>        If (bMertech = True) Begin       
91727>>>>>            Get _MertechSqlUtilCreateIntFile hTable sDataPath sPhysicalFileName to bOK
91728>>>>>            Function_Return (bOK = True)
91729>>>>>        End
91729>>>>>>
91729>>>>>        
91729>>>>>        Get psSchema hTable to sSchemaName
91730>>>>>        If (sSchemaName = "") Begin   
91732>>>>>            Get _SqlFindKeyWord CI_SQLDBO to sSchemaName
91733>>>>>        End
91733>>>>>>
91733>>>>>
91733>>>>>        // If the .int file already exists; we rename it to "FileName" + ".bak"
91733>>>>>        Get vFilePathExists (sDataPath + sPhysicalFileName) to bExists
91734>>>>>        If (bExists = True) Begin            
91736>>>>>            Get vRenameFile (sDataPath + sPhysicalFileName) (sDataPath + sPhysicalFileName + ".bak") to bOK 
91737>>>>>        End
91737>>>>>>
91737>>>>>        
91737>>>>>        Get UtilDeleteCacheFile sRootName to bOK
91738>>>>>        Get SqlUtilEnumerateIndexes sRootName sDriverID to sIndexArray
91739>>>>>        
91739>>>>>        Get Seq_Open_Output_Channel (sDataPath + sPhysicalFileName) to iCh
91740>>>>>            Writeln channel iCh CS_DRIVER_NAME     " " sDriverID 
91745>>>>>            If (bUseConnectionID = True) Begin
91747>>>>>                Writeln channel iCh CS_SERVER_NAME " " CS_DFCONNID "=" sConnectionID
91754>>>>>            End 
91754>>>>>>
91754>>>>>            Else Begin
91755>>>>>                Writeln channel iCh CS_SERVER_NAME " " CS_SERVER "=" sConnectionString
91762>>>>>            End                                                      
91762>>>>>>
91762>>>>>            Writeln channel iCh CS_DATABASE_NAME          " " sDatabaseName
91767>>>>>            Writeln channel iCh CS_SCHEMA_NAME            " " (Lowercase(sSchemaName))
91772>>>>>            // There seems to be a new order how these are set from DF19.
91772>>>>>            If (bSysFile = True) Begin
91774>>>>>                Writeln channel iCh CS_RECNUM_TABLE       " " "NO"
91779>>>>>            End 
91779>>>>>>
91779>>>>>            Writeln channel iCh CS_TABLE_CHARACTER_FORMAT " " sANSI_OEM
91784>>>>>            Writeln channel iCh CS_USE_DUMMY_ZERO_DATE    " " "YES" // ToDo: We maybe need to paramerize this setting?  
91789>>>>>            If (bSysFile = True) Begin
91791>>>>>                Writeln channel iCh CS_SYSTEM_FILE        " " "YES" 
91796>>>>>            End  
91796>>>>>>
91796>>>>>            
91796>>>>>            If (bSysFile = False) Begin
91798>>>>>                Move (SizeOfArray(sIndexArray)) to iSize  
91799>>>>>                Move (SortArray(sIndexArray)) to sIndexArray
91800>>>>>                If (iSize > 0) Begin
91802>>>>>                    Writeln channel iCh (CS_PRIMARY_INDEX * String("0"))
91805>>>>>                    Writeln channel iCh // Just an empty line
91807>>>>>                End
91807>>>>>>
91807>>>>>                Decrement iSize                              
91808>>>>>                For iCount from 0 to iSize
91814>>>>>>
91814>>>>>                    Writeln channel iCh (CS_INDEX_NUMBER * String(iCount))
91817>>>>>                    Writeln channel iCh (CS_INDEX_NAME   * String(sIndexArray[iCount]))
91820>>>>>                    Writeln channel iCh
91822>>>>>                Loop
91823>>>>>>
91823>>>>>            End
91823>>>>>>
91823>>>>>        Send Seq_Close_Channel iCh 
91824>>>>>        
91824>>>>>        // Wait a sec for Windows to finish writing the file:
91824>>>>>        Sleep 1
91825>>>>>        
91825>>>>>        Function_Return (bOK = True)
91826>>>>>    End_Function
91827>>>>>    
91827>>>>>    // Message for changing .int files to use connection ID's
91827>>>>>    //
91827>>>>>    // Changes all ".int" files for the passed sDataPath to use a sConnectionID,
91827>>>>>    // OR changes an existing connection id to a new id.
91827>>>>>    // Pass the full path to the data folder and the name of the connection id (string value). 
91827>>>>>    // Pass a True for the bShowResult parameter to show work in progress (showln's).
91827>>>>>    Procedure SqlUtilChangeIntFilesToConnectionIDs String sDataPath String sConnectionID Boolean bShowResult
91829>>>>>        String sFileName sDriverID sDriverFile sConnectionString
91829>>>>>        String[] sFilesData
91830>>>>>        Boolean bExists bOK                               
91830>>>>>        Integer iSize iCount
91830>>>>>        
91830>>>>>        Get SqlUtilEnumerateIntFiles sDataPath to sFilesData
91831>>>>>        Move (SizeOfArray(sFilesData))    to iSize
91832>>>>>        If (iSize = 0) Begin
91834>>>>>            Send Info_Box "No .int files found! Nothing was changed."
91835>>>>>            Procedure_Return
91836>>>>>        End                                                          
91836>>>>>>
91836>>>>>        
91836>>>>>        Move (Trim(sConnectionID)) to sConnectionID
91837>>>>>        Get vFolderFormat sDataPath to sDataPath
91838>>>>>        Decrement iSize
91839>>>>>        For iCount from 0 to iSize
91845>>>>>>
91845>>>>>            Move sFilesData[iCount] to sFileName                                   
91846>>>>>            // This makes sure that we also can change an existing connection id to something new:
91846>>>>>            Get UtilChangeSourceCodeLine (sDataPath + sFileName) CS_SERVER_NAME (CS_SERVER_NAME * CS_DFCONNID + "=" + sConnectionID) bShowResult to bOK 
91847>>>>>        Loop                      
91848>>>>>>
91848>>>>>        
91848>>>>>        Get psDriverID to sDriverID
91849>>>>>        
91849>>>>>         // Finally also change the driver file e.g. MSSQLDRV.int file in the Data folder in case it has a "DFconnectionID xxxxID,SERVER..."
91849>>>>>        Move "" to sFileName
91850>>>>>        If (sDriverID = MSSQLDRV_ID) Begin
91852>>>>>            Move "MSSQLDrv.int" to sFileName
91853>>>>>        End                 
91853>>>>>>
91853>>>>>        If (sDriverID = DB2_DRV_ID) Begin
91855>>>>>            Move "DB2_Drv.int" to sFileName
91856>>>>>        End                                
91856>>>>>>
91856>>>>>        If (sDriverID = ODBC_DRV_ID) Begin
91858>>>>>            Move "ODBC_Drv.int" to sFileName
91859>>>>>        End                                 
91859>>>>>>
91859>>>>>        If (sFileName <> "") Begin     
91861>>>>>            Move "" to sDriverFile
91862>>>>>            Get_File_Path sFileName to sDriverFile
91863>>>>>            If (sDriverFile <> "") Begin                        
91865>>>>>                Get psConnectionString to sConnectionString
91866>>>>>                Get UtilChangeSourceCodeLine sDriverFile CS_SQLConnectionIDText (CS_SQLConnectionIDText * String(sConnectionID) + "," * String(sConnectionString) * String(",0")) bShowResult to bOK
91867>>>>>            End
91867>>>>>>
91867>>>>>        End
91867>>>>>>
91867>>>>>    End_Procedure
91868>>>>>
91868>>>>>    // Checks if the database exists in SQL. Returns = True if it does.
91868>>>>>    Function SqlUtilCheckIfDatabaseExists String sDatabase Returns Boolean
91870>>>>>        String[] sDatabaseArray
91871>>>>>        String sVal sServer sDriverID
91871>>>>>        Integer iCount iSize iPos
91871>>>>>        Boolean bExists            
91871>>>>>        tSQLConnection SQLConnection
91871>>>>>        tSQLConnection SQLConnection
91871>>>>>        
91871>>>>>        Move False to bExists                              
91872>>>>>        Get psDriverID to sDriverID
91873>>>>>        // DB2 doesn't need to have a "Database" name, so we always return True.
91873>>>>>        If (sDriverID = DB2_DRV_ID) Begin
91875>>>>>            Function_Return bExists
91876>>>>>        End                     
91876>>>>>>
91876>>>>>        
91876>>>>>        Get SqlUtilEnumerateDatabases sDriverID to sDatabaseArray
91877>>>>>        If (SizeOfArray(sDatabaseArray) = 0) Begin
91879>>>>>            Function_Return False
91880>>>>>        End
91880>>>>>>
91880>>>>>        
91880>>>>>        Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
91881>>>>>        Get ParseKeyWord SQLConnection.sConnectionString (CS_SQLIniDSNKeyword + "=") to sServer
91882>>>>>        If (sServer contains "/") Begin
91884>>>>>            Move (Pos("/", sServer)) to iPos
91885>>>>>            Move (Mid(sServer, 999, (iPos +1)))                        to sDatabase
91886>>>>>        End
91886>>>>>>
91886>>>>>        
91886>>>>>        Move (SizeOfArray(sDatabaseArray)) to iSize
91887>>>>>        Decrement iSize
91888>>>>>        For iCount from 0 to iSize
91894>>>>>>
91894>>>>>            Move sDatabaseArray[iCount] to sVal
91895>>>>>            If (Uppercase(sVal) = Uppercase(sDatabase)) Begin
91897>>>>>                Move True to bExists
91898>>>>>            End
91898>>>>>>
91898>>>>>        Loop
91899>>>>>>
91899>>>>>        
91899>>>>>        Function_Return bExists
91900>>>>>    End_Function
91901>>>>>        
91901>>>>>    // Checks if a table exists as an SQL table. Returns = True if it does.
91901>>>>>    Function SqlUtilCheckIfTableHandleExists Handle hTable String sDriverID Returns Boolean
91903>>>>>        String sTableName sVal
91903>>>>>        Boolean bExists  
91903>>>>>        String[] sTablesArray                                 
91904>>>>>        Integer iSize iCount
91904>>>>>        
91904>>>>>        Move False to bExists
91905>>>>>        Get UtilTableHandleToString hTable to sTableName
91906>>>>>        Get SqlUtilEnumerateTables sDriverID to sTablesArray  
91907>>>>>        Move (SizeOfArray(sTablesArray)) to iSize
91908>>>>>        Decrement iSize
91909>>>>>        For iCount from 0 to iSize
91915>>>>>>
91915>>>>>            Move sTablesArray[iCount] to sVal
91916>>>>>            If (Uppercase(sVal) = Uppercase(sTableName)) Begin
91918>>>>>                Move True to bExists
91919>>>>>                Move iSize to iCount // We're done!
91920>>>>>            End
91920>>>>>>
91920>>>>>        Loop
91921>>>>>>
91921>>>>>    
91921>>>>>        Function_Return bExists
91922>>>>>    End_Function   
