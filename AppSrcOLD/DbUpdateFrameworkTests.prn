92637>>>>>                If (sDriverID = MSSQLDRV_ID or sDriverID = DB2_DRV_ID or sDriverID = ODBC_DRV_ID) Begin
92639>>>>>                    Get_Attribute DF_FILE_ROOT_NAME of hTable to sRoot
92642>>>>>                    If (Uppercase(sRoot) contains ".INT" or Uppercase(sRoot) contains MSSQLDRV_ID or Uppercase(sRoot) contains DB2_DRV_ID or Uppercase(sRoot) contains ODBC_DRV_ID) Begin
92644>>>>>                        Open hTable
92646>>>>>                    End
92646>>>>>>
92646>>>>>                End
92646>>>>>>
92646>>>>>            End
92646>>>>>>
92646>>>>>    
92646>>>>>        Until (hTable = 0)
