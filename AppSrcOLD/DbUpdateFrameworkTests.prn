98361>>>>>>>    Function ParentView Returns Handle
98363>>>>>>>        Function_Return (Parent(Parent(Self)))
98364>>>>>>>    End_Function
98365>>>>>>>    
98365>>>>>>>    Procedure AdjustTabWorkspaceView Integer ByRef iHeight Integer ByRef iWidth Integer ByRef iLocY Integer ByRef iLocX
98367>>>>>>>        Integer iSize iMax iDiff
98367>>>>>>>        Handle hoView
98367>>>>>>>        Boolean bCenter bModal
98367>>>>>>>        Get ParentView to hoView
98368>>>>>>>        Get Block_Mouse_State of hoView to bModal
98369>>>>>>>        If not bModal Begin
98371>>>>>>>            Get CenterTabWorkspaceView to bCenter
98372>>>>>>>            Get GuiSize of hoView to iSize
98373>>>>>>>            Get piMaxSize of hoView to iMax
98374>>>>>>>            Get DialogToGui (Hi(iMax)) (Low(iMax)) to iMax
98375>>>>>>>            If (Low(iMax) and Low(iMax)<=Low(isize)) Begin
98377>>>>>>>                If bCenter Begin
98379>>>>>>>                    Move ((Low(iSize)-Low(iMax))/2) to iLocX
98380>>>>>>>                End
98380>>>>>>>>
98380>>>>>>>                Move (Low(iMax)) to iWidth
98381>>>>>>>            End
98381>>>>>>>>
98381>>>>>>>            If (Hi(iMax) and Hi(iMax)<=Hi(iSize)) Begin
98383>>>>>>>                If bCenter Begin
98385>>>>>>>                    Move ((Hi(iSize)-Hi(iMax))/2) to iLocY
98386>>>>>>>                    Move (iLocy min 25) to  iLocY
98387>>>>>>>                End
98387>>>>>>>>
98387>>>>>>>                Move (Hi(imax)) to iHeight
98388>>>>>>>            End
98388>>>>>>>>
98388>>>>>>>        End
98388>>>>>>>>
98388>>>>>>>    End_Procedure
98389>>>>>>>
98389>>>>>>>    // Automatically determine if this is a scrolling tabbed workspace view
98389>>>>>>>    // If determines this by checking pbAutoSetTabWorkspaceView is set (it can be
98389>>>>>>>    // set to stop this), if we have a global commandbar object and we are using tabbed
98389>>>>>>>    // workspaces. We also make sure that the expected view object is a framework view class
98389>>>>>>>    // This should almost always yield the right answer.
98389>>>>>>>    // This is called by the scrolling container's end_constructor
98389>>>>>>>    Procedure AutoSetTabWorkspaceView
98391>>>>>>>        Boolean bTabView bIsView bAutoSetTabWorkspaceView
98391>>>>>>>        Handle hoParent
98391>>>>>>>        Integer iSize
98391>>>>>>>        Get pbAutoSetTabWorkspaceView to bAutoSetTabWorkspaceView  
98392>>>>>>>        If (ghoCommandBars and bAutoSetTabWorkspaceView) Begin
98394>>>>>>>            Get pbTabbedWorkspaces of ghoCommandBars to bTabView
98395>>>>>>>            // not that pbTabbedWorkspaces is a designtime only property. You can not
98395>>>>>>>            // change this after the commandbar is paged.
98395>>>>>>>            If (bTabView) Begin
98397>>>>>>>                Get ParentView to hoParent
98398>>>>>>>                Get IsObjectOfClass of hoParent (RefClass(MdiDialog)) to bIsView
98399>>>>>>>                If (bIsView) Begin
98401>>>>>>>                    // set this as a tab workspace view
98401>>>>>>>                    Set pbTabWorkspaceView to True
98402>>>>>>>                    // when tab workspaces are enabled we always enable auto-scrolling
98402>>>>>>>                    // when tab workspaces are not enabled, pbScroll is whatever it is
98402>>>>>>>                    Set pbAutoScroll to True
98403>>>>>>>                    
98403>>>>>>>//                    // if piMaxSize is not set, we will do it for you by setting it
98403>>>>>>>//                    // to the current size.
98403>>>>>>>//                    Get piMaxSize of hoParent to iSize
98403>>>>>>>//                    If (iSize=0) Begin
98403>>>>>>>//                        Get Size of hoParent to iSize
98403>>>>>>>//                        Set piMaxSize of hoParent to (Hi(iSize)) (Low(iSize))
98403>>>>>>>//                    End
98403>>>>>>>                End
98403>>>>>>>>
98403>>>>>>>            End
98403>>>>>>>>
98403>>>>>>>        End
98403>>>>>>>>
98403>>>>>>>    End_Procedure
98404>>>>>>>
98404>>>>>>>End_Class
