82135>>>>>>>>>Class cFormatter is an cObject
82136>>>>>>>>>
82136>>>>>>>>>    Procedure Construct_object
82138>>>>>>>>>        Integer iCh
82138>>>>>>>>>        forward send construct_object
82140>>>>>>>>>        Property String  psCurrencySymbol
82141>>>>>>>>>        Set psCurrencySymbol to (Default_Currency_Symbol())
82142>>>>>>>>>
82142>>>>>>>>>        Property string  psLeft
82143>>>>>>>>>        Property string  psright
82144>>>>>>>>>        Property integer pbThousandsSep
82145>>>>>>>>>        Property integer piPoints
82146>>>>>>>>>
82146>>>>>>>>>        Property string  psCurPosLeft
82147>>>>>>>>>        Property string  psCurPosright
82148>>>>>>>>>        Property integer pbCurPosThousandsSep
82149>>>>>>>>>        Property integer piCurPosPoints
82150>>>>>>>>>
82150>>>>>>>>>        Property string  psCurNegLeft
82151>>>>>>>>>        Property string  psCurNegright
82152>>>>>>>>>        Property integer pbCurNegThousandsSep
82153>>>>>>>>>        Property integer piCurNegPoints
82154>>>>>>>>>
82154>>>>>>>>>        Property string  psNumPosLeft
82155>>>>>>>>>        Property string  psNumPosright
82156>>>>>>>>>        Property integer pbNumPosThousandsSep
82157>>>>>>>>>        Property integer piNumPosPoints
82158>>>>>>>>>
82158>>>>>>>>>        Property string  psNumNegLeft
82159>>>>>>>>>        Property string  psNumNegright
82160>>>>>>>>>        Property integer pbNumNegThousandsSep
82161>>>>>>>>>        Property integer piNumNegPoints
82162>>>>>>>>>
82162>>>>>>>>>        Send SetFormat "$,#.##;($,#.##)" true  // currency
82163>>>>>>>>>        Send SetFormat  ",#.*"           false // numeric
82164>>>>>>>>>
82164>>>>>>>>>    end_procedure
82165>>>>>>>>>
82165>>>>>>>>>    // internal
82165>>>>>>>>>    // parse passed format string and set temporary properties with result
82165>>>>>>>>>    //
82165>>>>>>>>>    Procedure ParseFormat string sFmt
82167>>>>>>>>>
82167>>>>>>>>>        string sLeft sRight sDigit
82167>>>>>>>>>        integer bSep iPos i iDigits
82167>>>>>>>>>
82167>>>>>>>>>        // replace any literals. A "/" followed by anything.
82167>>>>>>>>>        // some literals are special. $ . , / #
82167>>>>>>>>>        Move (Replaces("/$",sFmt,Character(1)))    to sFmt
82168>>>>>>>>>        Move (Replaces("/.",sFmt,Character(2)))    to sFmt
82169>>>>>>>>>        Move (Replaces("/,",sFmt,Character(3)))    to sFmt
82170>>>>>>>>>        Move (Replaces("/"+"/",sFmt,Character(4))) to sFmt
82171>>>>>>>>>        Move (Replaces("/#",sFmt,Character(5)))    to sFmt
82172>>>>>>>>>        Move (Character(9)) to sDigit
82173>>>>>>>>>        Move (Replaces("#",sFmt,sDigit))           to sFmt
82174>>>>>>>>>        Move (Replaces("/",sFmt,""))               to sFmt // replace all others
82175>>>>>>>>>
82175>>>>>>>>>        Move (Pos(",",sFmt))                 to bSep // if we have any , we use thousand seps
82176>>>>>>>>>        If bSep Move (Replaces(",",sFmt,"")) to sFmt // remove all ,
82179>>>>>>>>>
82179>>>>>>>>>        Move (Replaces("$",sFmt,psCurrencySymbol(self))) to sFmt // replace any $ with currency symbol
82180>>>>>>>>>
82180>>>>>>>>>        Move (Pos(".",sFmt)) to iPos                 // position of decimal
82181>>>>>>>>>
82181>>>>>>>>>        // Move all the special literals back into place before parsing
82181>>>>>>>>>        Move (Replaces(Character(1),sFmt,"$")) to sFmt
82182>>>>>>>>>        Move (Replaces(Character(2),sFmt,".")) to sFmt
82183>>>>>>>>>        Move (Replaces(Character(3),sFmt,",")) to sFmt
82184>>>>>>>>>        Move (Replaces(Character(4),sFmt,"/")) to sFmt
82185>>>>>>>>>        Move (Replaces(Character(5),sFmt,"#")) to sFmt
82186>>>>>>>>>
82186>>>>>>>>>        If (iPos>0) Begin                      // if we have a decimanl point
82188>>>>>>>>>            Move 1 to i                        // look for first non # to right and count the #s
82189>>>>>>>>>            If (mid(sFmt,1,iPos+i)="*") Begin  // the "*" is special. It means as many as you want
82191>>>>>>>>>               Move -2 to iDigits
82192>>>>>>>>>               increment i
82193>>>>>>>>>            end
82193>>>>>>>>>>
82193>>>>>>>>>            While (mid(sFmt,1,iPos+i)=sDigit)
82197>>>>>>>>>                 Increment i
82198>>>>>>>>>            end
82199>>>>>>>>>>
82199>>>>>>>>>            Move (Mid(sFmt,255,iPos+i)) to sRight // everything to the right of the last # is format stuff
82200>>>>>>>>>            If (iDigits=0) Move (i-1) to iDigits
82203>>>>>>>>>            //
82203>>>>>>>>>            Move 1 to i                           // find the first non-# to the left of the point
82204>>>>>>>>>            While (mid(sFmt,1,iPos-i)=sDigit)     // everything to the left is format stuff
82208>>>>>>>>>                 increment i
82209>>>>>>>>>            end
82210>>>>>>>>>>
82210>>>>>>>>>            Move (left(sFmt,iPos-i)) to sLeft
82211>>>>>>>>>        end
82211>>>>>>>>>>
82211>>>>>>>>>        else begin                             // we have no decinal
82212>>>>>>>>>            Move 0 to iDigits                  // so points is none
82213>>>>>>>>>            Move (Pos(sDigit,sFmt)) to iPos    // find first #.
82214>>>>>>>>>            If (iPos=0) Begin                  // if none, entire string is left format stuff..wierd!
82216>>>>>>>>>                Move sFmt to sLeft
82217>>>>>>>>>                Move ""   to sRight
82218>>>>>>>>>            end
82218>>>>>>>>>>
82218>>>>>>>>>            else begin
82219>>>>>>>>>                Move (left(sFmt,iPos-1)) to sLeft // all char to left of first # is left format stuff
82220>>>>>>>>>                Move 1 to i
82221>>>>>>>>>                While (mid(sFmt,1,iPos+i)=sDigit) // find last #, all char to right is right format
82225>>>>>>>>>                    Increment i
82226>>>>>>>>>                end
82227>>>>>>>>>>
82227>>>>>>>>>                Move (Mid(sFmt,255,i+iPos)) to sRight
82228>>>>>>>>>            end
82228>>>>>>>>>>
82228>>>>>>>>>        end
82228>>>>>>>>>>
82228>>>>>>>>>        // set temporary format properties and exit
82228>>>>>>>>>        Set pbThousandsSep to bSep
82229>>>>>>>>>        set psLeft         to sLeft
82230>>>>>>>>>        set psRight        to sRight
82231>>>>>>>>>        Set piPoints       to iDigits
82232>>>>>>>>>     End_procedure
82233>>>>>>>>>
82233>>>>>>>>>    // Public: Sets a format string. Pass full format for Positve and negative in sFmt. Pass
82233>>>>>>>>>    //         bCurrency true is this is a currency format, false if a numeric format
82233>>>>>>>>>    //
82233>>>>>>>>>    //  e.g. Send SetFormat "$,#.##;($,#.##)" True
82233>>>>>>>>>    //
82233>>>>>>>>>    Procedure SetFormat string sFmt integer bCurrency
82235>>>>>>>>>        string sPos sNeg
82235>>>>>>>>>        integer iPos
82235>>>>>>>>>
82235>>>>>>>>>        Move (Pos(";",sFmt)) to iPos
82236>>>>>>>>>        If iPos begin
82238>>>>>>>>>            Move (left(sFmt,iPos-1))    to sPos
82239>>>>>>>>>            Move (mid(sFmt,255,iPos+1)) to sNeg
82240>>>>>>>>>        end
82240>>>>>>>>>>
82240>>>>>>>>>        else Begin
82241>>>>>>>>>            Move sFmt         to sPos
82242>>>>>>>>>            Move ("-" + sFmt) to sNeg
82243>>>>>>>>>        end
82243>>>>>>>>>>
82243>>>>>>>>>        Send ParseFormat sPos
82244>>>>>>>>>        If bCurrency begin
82246>>>>>>>>>            Set pbCurPosThousandsSep to (pbThousandsSep(self))
82247>>>>>>>>>            set psCurPosLeft         to (psLeft(self))
82248>>>>>>>>>            set psCurPosRight        to (psRight(self))
82249>>>>>>>>>            Set piCurPosPoints       to (piPoints(self))
82250>>>>>>>>>        End
82250>>>>>>>>>>
82250>>>>>>>>>        else Begin
82251>>>>>>>>>            Set pbNumPosThousandsSep to (pbThousandsSep(self))
82252>>>>>>>>>            set psNumPosLeft         to (psLeft(self))
82253>>>>>>>>>            set psNumPosRight        to (psRight(self))
82254>>>>>>>>>            Set piNumPosPoints       to (piPoints(self))
82255>>>>>>>>>        end
82255>>>>>>>>>>
82255>>>>>>>>>
82255>>>>>>>>>        Send ParseFormat sNeg
82256>>>>>>>>>        If bCurrency begin
82258>>>>>>>>>            Set pbCurNegThousandsSep to (pbThousandsSep(self))
82259>>>>>>>>>            set psCurNegLeft         to (psLeft(self))
82260>>>>>>>>>            set psCurNegRight        to (psRight(self))
82261>>>>>>>>>            Set piCurNegPoints       to (piPoints(self))
82262>>>>>>>>>        End
82262>>>>>>>>>>
82262>>>>>>>>>        else Begin
82263>>>>>>>>>            Set pbNumNegThousandsSep to (pbThousandsSep(self))
82264>>>>>>>>>            set psNumNegLeft         to (psLeft(self))
82265>>>>>>>>>            set psNumNegRight        to (psRight(self))
82266>>>>>>>>>            Set piNumNegPoints       to (piPoints(self))
82267>>>>>>>>>        end
82267>>>>>>>>>>
82267>>>>>>>>>    End_procedure
82268>>>>>>>>>
82268>>>>>>>>>    // low level formatting. Pass parameters
82268>>>>>>>>>    Function Format_Num number nNumber integer iPoints integer bSep ;                       string sPrefix string sSuffix returns string
82270>>>>>>>>>        string  sLeft sRight sNumber sSep sDec
82270>>>>>>>>>        integer bIsNegative iDec iLen iCh
82270>>>>>>>>>
82270>>>>>>>>>        Get_Attribute DF_DECIMAL_SEPARATOR to iCh
82273>>>>>>>>>        Move (Character(iCh)) to sDec
82274>>>>>>>>>
82274>>>>>>>>>        Move (abs(nNumber)) to sNumber
82275>>>>>>>>>        Move (Pos(sDec,sNumber)) to iDec
82276>>>>>>>>>        Move (If(iDec=0, sNumber, left(sNumber,iDec-1))) to sLeft
82277>>>>>>>>>        Move (If(iDec=0, "", mid(sNumber,255,iDec+1)))   to sRight
82278>>>>>>>>>        // format for decimal separator
82278>>>>>>>>>        If (iPoints>=0) ; // if -2, leave it alone, it should not be -1            Move (left(sRight+repeat("0",iPoints),iPoints)) to sRight
82281>>>>>>>>>
82281>>>>>>>>>        // format for thousand sep.
82281>>>>>>>>>        If bSep Begin
82283>>>>>>>>>            Get_Attribute DF_THOUSANDS_SEPARATOR to iCh
82286>>>>>>>>>            Move (Character(iCh)) to sSep
82287>>>>>>>>>            Move (Length(sLeft)) to iLen
82288>>>>>>>>>            While (iLen>3)
82292>>>>>>>>>                Move (insert(sSep,sLeft,iLen-2)) to sLeft
82293>>>>>>>>>                Move (iLen-3) to iLen
82294>>>>>>>>>            End
82295>>>>>>>>>>
82295>>>>>>>>>        End
82295>>>>>>>>>>
82295>>>>>>>>>        // if decimal points or -2 (allow anything) and there are points to show
82295>>>>>>>>>        If (iPoints>0 OR (iPoints=-2 AND sRight<>"")) ;            Move (sLeft + sDec + sright) to sLeft
82298>>>>>>>>>        Function_return (sPrefix + sLeft+ sSuffix)
82299>>>>>>>>>    End_Function
82300>>>>>>>>>
82300>>>>>>>>>    // Public: Format for currency
82300>>>>>>>>>    //
82300>>>>>>>>>    Function FormatCur number nNumber integer iPoints returns string
82302>>>>>>>>>        string  sLeft sRight
82302>>>>>>>>>        integer bSep
82302>>>>>>>>>        If (nNumber<0) Begin
82304>>>>>>>>>            get pbCurNegThousandsSep to bSep
82305>>>>>>>>>            get psCurNegLeft         to sLeft
82306>>>>>>>>>            get psCurNegRight        to sRight
82307>>>>>>>>>            If (iPoints=-1) get piCurNegPoints       to iPoints
82310>>>>>>>>>        end
82310>>>>>>>>>>
82310>>>>>>>>>        Else Begin
82311>>>>>>>>>            get pbCurPosThousandsSep to bSep
82312>>>>>>>>>            get psCurPosLeft         to sLeft
82313>>>>>>>>>            get psCurPosRight        to sRight
82314>>>>>>>>>            If (iPoints=-1) get piCurPosPoints       to iPoints
82317>>>>>>>>>        end
82317>>>>>>>>>>
82317>>>>>>>>>        Function_return (Format_Num(self, nNumber,iPoints,bSep,sLeft,sRight))
82318>>>>>>>>>    End_function
82319>>>>>>>>>
82319>>>>>>>>>    // Public: Format for numeric
82319>>>>>>>>>    //
82319>>>>>>>>>    Function FormatNum number nNumber integer iPoints returns string
82321>>>>>>>>>        string  sLeft sRight
82321>>>>>>>>>        integer bSep
82321>>>>>>>>>        If (nNumber<0) Begin
82323>>>>>>>>>            get pbNumNegThousandsSep to bSep
82324>>>>>>>>>            get psNumNegLeft         to sLeft
82325>>>>>>>>>            get psNumNegRight        to sRight
82326>>>>>>>>>            If (iPoints=-1) get piNumNegPoints       to iPoints
82329>>>>>>>>>        end
82329>>>>>>>>>>
82329>>>>>>>>>        Else Begin
82330>>>>>>>>>            get pbNumPosThousandsSep to bSep
82331>>>>>>>>>            get psNumPosLeft         to sLeft
82332>>>>>>>>>            get psNumPosRight        to sRight
82333>>>>>>>>>            If (iPoints=-1) get piNumPosPoints       to iPoints
82336>>>>>>>>>        end
82336>>>>>>>>>>
82336>>>>>>>>>        Function_return (Format_Num(self, nNumber,iPoints,bSep,sLeft,sRight))
82337>>>>>>>>>    End_function
82338>>>>>>>>>
82338>>>>>>>>>
82338>>>>>>>>>    // Public: Format passing format string
82338>>>>>>>>>    //
82338>>>>>>>>>    Function FormatVal number nNumber string sFmt returns string
82340>>>>>>>>>        integer iPos bIsNeg
82340>>>>>>>>>        string  sLeft sRight
82340>>>>>>>>>        integer iPoints bSep
82340>>>>>>>>>        Move (nNumber<0) to bIsNeg
82341>>>>>>>>>        Move (Pos(";",sFmt)) to iPos
82342>>>>>>>>>        Case Begin
82342>>>>>>>>>            Case (iPos and Not(bIsNeg))      Move (left(sFmt,iPos-1))    to sFmt
82345>>>>>>>>>            Case (iPos and bIsNeg)           Move (mid(sFmt,255,iPos+1)) to sFmt
82349>>>>>>>>>            Case (not(iPos) and not(bIsNeg)) Move sFmt                   to sFmt
82353>>>>>>>>>            Case else                        Move ("-" + sFmt)           to sFmt
82355>>>>>>>>>        case end
82355>>>>>>>>>        Send ParseFormat sFmt
82356>>>>>>>>>        get pbThousandsSep to bSep
82357>>>>>>>>>        get psLeft         to sLeft
82358>>>>>>>>>        get psRight        to sRight
82359>>>>>>>>>        get piPoints       to iPoints
82360>>>>>>>>>        Function_return (Format_Num(self, nNumber,iPoints,bSep,sLeft,sRight))
82361>>>>>>>>>    end_function
82362>>>>>>>>>
82362>>>>>>>>>End_Class
