98444>>>>>>>    // augmented to adjust its size to the size of the parent client area.
98444>>>>>>>    // After this is set, anchors will handle any further resizing.
98444>>>>>>>    Procedure Page Integer iState
98446>>>>>>>        Integer iSiz iHeight iWidth
98446>>>>>>>        Integer iTop iBottom iLeft iRight iFontSize
98446>>>>>>>        Boolean bGroup
98446>>>>>>>        Handle hoClient
98446>>>>>>>        If (iState =1) Begin
98448>>>>>>>            Delegate Get Window_Style BS_GROUPBOX to bGroup
98450>>>>>>>            // We have special code to support groups because they
98450>>>>>>>            // draw a border inside of the client rectangle
98450>>>>>>>            If bGroup Begin
98452>>>>>>>                Get Physical_FontSize to iFontSize
98453>>>>>>>                Move (Hi(iFontSize)) to iTop
98454>>>>>>>                Move 2 to iLeft
98455>>>>>>>                Move 2 to iRight
98456>>>>>>>                Move 2 to iBottom
98457>>>>>>>            End
98457>>>>>>>>
98457>>>>>>>            // We use GetContainerClientSize instead of GuiClientSize because
98457>>>>>>>            // GetContainerClientSize has a special augmentation in tab pages that
98457>>>>>>>            // makes anchors work properly with unpaged tab-pages
98457>>>>>>>            Delegate Get GetContainerClientSize to iSiz
98459>>>>>>>            Set GuiSize to (Hi(iSiz)-(iTop+iBottom)) (Low(iSiz)-(iLeft+iRight))
98460>>>>>>>            Set GuiLocation to iTop iLeft
98461>>>>>>>            Send Adjust_Logicals
98462>>>>>>>        End
98462>>>>>>>>
98462>>>>>>>        Forward Send Page iState
98464>>>>>>>    End_Procedure
98465>>>>>>>    
