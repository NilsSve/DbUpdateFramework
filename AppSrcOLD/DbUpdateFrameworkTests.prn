92649>>>>>    // This function allows you to put an Sql script in a CM Image. It makes it easier to
92649>>>>>    // copy and paste between a DataFlex program and an Sql Editor.
92649>>>>>    Function SqlUtilLoadImageFile String sFileName Returns String
92651>>>>>        Integer iChannel iPos
92651>>>>>        String sTextValue sLine sPath
92651>>>>>        Boolean bSeqEof
92651>>>>>        
92651>>>>>        Move "" to sTextValue        
92652>>>>>        Get ParseFolderName sFileName to sPath
92653>>>>>        If (Trim(sPath) = "") Begin
92655>>>>>            Get psDataPathFirstPart to sPath
92656>>>>>            Move (sPath + sFileName) to sFileName
92657>>>>>        End
92657>>>>>>
92657>>>>>        
92657>>>>>        Get Seq_New_Channel to iChannel
92658>>>>>        If (iChannel = DF_SEQ_CHANNEL_NOT_AVAILABLE) Begin
92660>>>>>            Error DFERR_PROGRAM "No channel available..."
92661>>>>>>
92661>>>>>        End
92661>>>>>>
92661>>>>>        Else Begin        
92662>>>>>            Direct_Input channel iChannel sFileName
92664>>>>>            Move (SeqEof) to bSeqEof
92665>>>>>            If (bSeqEof = True) Begin
92667>>>>>                Send Seq_Release_Channel iChannel 
92668>>>>>                Set psSQLStatementString to ""  
92669>>>>>                Error DFERR_PROGRAM ("The Sql script file:\n" + sFileName + "\nCould not be found.")
92670>>>>>>
92670>>>>>                Function_Return "" 
92671>>>>>            End
92671>>>>>>
92671>>>>>    
92671>>>>>            While (not(bSeqEof))
92675>>>>>                Readln channel iChannel sLine 
92677>>>>>                Move (Pos("/", sLine)) to iPos
92678>>>>>                Move (SeqEol) to bSeqEof
92679>>>>>                If (not(bSeqEof) and iPos <> 1) Begin
92681>>>>>                    Move (sTextValue + sLine + Character(13)) to sTextValue
92682>>>>>                End
92682>>>>>>
92682>>>>>            Loop
92683>>>>>>
92683>>>>>            Send Seq_Release_Channel iChannel
92684>>>>>        End
92684>>>>>>
92684>>>>>        
92684>>>>>        Set psSQLStatementString to sTextValue
92685>>>>>        Function_Return sTextValue
92686>>>>>    End_Function  
92687>>>>>    
92687>>>>>    // Reads an Sql script that have been compiled into the program as an "image" (/MyImageName) and returns the full script as a string.
92687>>>>>    // Usage: Get SqlUtilReadScriptFromCMImage of ghoDbUpdateFunctionLibrary CreatevwWorkflowInbox.n  
92687>>>>>    //
92687>>>>>    // This is a trick to use an old DataFlex feature/syntax to include "image names" at the top
92687>>>>>    // of a file. Each such section must end with a "/*".
92687>>>>>    // Note: Sql script files remarks/comments cannot be handled by the DataFlex compiler. All Sql comment 
92687>>>>>    //       sections in the "xxx.pkg.sql" file _must_ be removed.
92687>>>>>//    Function SqlUtilReadScriptFromCMImage Integer iImg Returns tSQLScriptResult 
92687>>>>>//        Integer iChannel iPos
92687>>>>>//        String sTextValue sLine
92687>>>>>//        Boolean bSeqEof
92687>>>>>//        tSQLScriptResult SqlScriptResult
92687>>>>>//        
92687>>>>>//        Move "" to sTextValue
92687>>>>>//        
92687>>>>>//        Get Seq_New_Channel to iChannel
92687>>>>>//        If (iChannel = DF_SEQ_CHANNEL_NOT_AVAILABLE) Begin
92687>>>>>//            Error DFERR_PROGRAM "No channel available..."
92687>>>>>//            Function_Return ""
92687>>>>>//        End                                       
92687>>>>>//        
92687>>>>>//        Get SqlUtilCheckScriptSize False "" iImg True to SqlScriptResult
92687>>>>>//        
92687>>>>>//        Direct_Input channel iChannel ("image: " + String(iImg))
92687>>>>>//        Move (SeqEof) to bSeqEof
92687>>>>>//        While (not(bSeqEof))
92687>>>>>//            Readln channel iChannel sLine
92687>>>>>//            Move (SeqEol) to bSeqEof
92687>>>>>//            If (not(bSeqEof)) Begin                                                                      
92687>>>>>//                Move (Trim(sLine)) to sLine
92687>>>>>//                If (Left(sLine, 2) <> (Character(47) + Character(47))) Begin // ASCII 47 = "/" (Comments)
