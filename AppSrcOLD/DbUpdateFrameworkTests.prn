93438>>>>>
93438>>>>>    // We might have a split Sql script where the info about which database to use is
93438>>>>>    // put on top of the Sql script, we then need to save it to be able to retrieve it later and
93438>>>>>    // insert it for scriplets to come after the first one.
93438>>>>>    Function _SqlFormatStatement String sStmt Returns String
93440>>>>>        String sUseDatabase sTmp sUseKeyWord sCreateViewKeyWord sDBOKeyWord sNoCountKeyWord sDriverID
93440>>>>>        Integer iStart iEnd iDbType
93440>>>>>        Boolean bOK
93440>>>>>        
93440>>>>>        Get piDbType to iDbType 
93441>>>>>        Get psDriverID to sDriverID
93442>>>>>        Get _SqlFindKeyWord CI_SQLUse          to sUseKeyWord  
93443>>>>>        Get _SqlFindKeyWord CI_SQLSetNoCountOn to sNoCountKeyWord
93444>>>>>        Get _SqlFindKeyWord CI_SQLCreateView   to sCreateViewKeyWord            
93445>>>>>        Get _SqlFindKeyWord CI_SQLDBO          to sDBOKeyWord 
93446>>>>>        Move (Replaces(" ", sStmt, "")) to sTmp
93447>>>>>        If (Uppercase(sTmp) contains (sUseKeyWord +"[")) Begin
93449>>>>>            Move (Pos("[", (Uppercase(sTmp)))) to iStart
93450>>>>>            Move (Pos("]", sTmp)) to iEnd
93451>>>>>            Move (Mid(sTmp, (iEnd -iStart +1), iStart)) to sUseDatabase
93452>>>>>            Move (sUseKeyWord * sUseDatabase + " ") to sUseDatabase
93453>>>>>            Set Private.psUseDatabase to sUseDatabase
93454>>>>>        End
93454>>>>>>
93454>>>>>        Else Begin   
93455>>>>>            Move (Uppercase(sStmt)) to sTmp
93456>>>>>
93456>>>>>            // A "Create View" statement _must_ be the very first words in a Sql statement.
93456>>>>>            If (not(sTmp contains sCreateViewKeyWord)) Begin
93458>>>>>                Get Private.psUseDatabase to sUseDatabase
93459>>>>>                Move (Insert(sUseDatabase, sStmt, 1)) to sStmt
93460>>>>>            End 
93460>>>>>>
93460>>>>>            
93460>>>>>            // This is a bit special to place here but was done so because it was easier that way.
93460>>>>>            // We will get an error when trying to create a view if it already exists.
93460>>>>>            // So to avoid such errors; we first remove it & then recreate it.
93460>>>>>            Else If (sTmp contains sCreateViewKeyWord) Begin 
93463>>>>>                // Make sure we only have one space between statements/words.  
93463>>>>>                Move (Replaces("  ", sTmp, " ")) to sTmp
93464>>>>>                Move (Replace(sCreateViewKeyWord, sTmp, "")) to sTmp
93465>>>>>                Move (Trim(sTmp)) to sTmp
93466>>>>>                Move (Pos(" ", sTmp)) to iEnd
93467>>>>>                Move (Left(sTmp, iEnd)) to sTmp
93468>>>>>                If ((not(sTmp contains ("[" + sDBOKeyWord + "]."))) and (not(sTmp contains (sDBOKeyWord + ".")))) Begin
93470>>>>>                    Move (sDBOKeyWord + "." + Trim(sTmp)) to sTmp
93471>>>>>                End  
93471>>>>>>
93471>>>>>                Move (Trim(sTmp)) to sTmp
93472>>>>>                // Remove data view as it already exists!
93472>>>>>                Get SqlViewRemove sDriverID sTmp to bOK
93473>>>>>            End
93473>>>>>>
93473>>>>>        End
93473>>>>>>
93473>>>>>
93473>>>>>        Function_Return sStmt    
93474>>>>>    End_Function
93475>>>>>    
93475>>>>>    // Returns the proper Sql language key word(s) for the passed SQL key-word constant
93475>>>>>    Function _SqlFindKeyWord Integer iSQLKeywordConstant Returns String
93477>>>>>        String sRetval         
93477>>>>>        Integer iDbType iSize iItem iIndex
93477>>>>>        tSQLKeyWords[] SQLKeywordArray 
93477>>>>>        tSQLKeyWords[] SQLKeywordArray 
93478>>>>>        tSQLKeyWords   SQLKeyWords
93478>>>>>        tSQLKeyWords   SQLKeyWords
93478>>>>>        
93478>>>>>        // Sql back-end type. E.g. MS-SQL, MySQL, Oracle, DB2...
93478>>>>>        Get piDbType to iDbType
93479>>>>>        Move iDbType             to SQLKeyWords.iSQLDbType
93480>>>>>        Move iSQLKeywordConstant to SQLKeyWords.iSQLWord
93481>>>>>         
93481>>>>>        Get paSQLKeywordArray to SQLKeywordArray
93482>>>>>        Move (SearchArray(SQLKeyWords, SQLKeywordArray, Self, RefFunc(CompareFindSQLKeyWords))) to iIndex
93483>>>>>        Move SQLKeywordArray[iIndex].sSQLPhrase to sRetval
93484>>>>>
93484>>>>>        Function_Return sRetval
93485>>>>>    End_Function
93486>>>>>    
93486>>>>>    // Function will "clean/sanitize" the script by removing all comments and blank lines.
93486>>>>>    Function _SqlUtilSanitizeScript tSQLScriptArray SqlScriptArray Returns tSQLScriptArray[] 
93488>>>>>        String[] sSQLScriptArray
93489>>>>>        String sText sLine sTmp sCommentStart sCommentEnd sDashComment
93489>>>>>        Integer iCh iSize iArgSize iPos iCount
93489>>>>>        Boolean bCommentStart bCommentEnd bDashComment
93489>>>>>        
93489>>>>>        Move False to bCommentStart
93490>>>>>        Move False to bCommentEnd 
93491>>>>>        Move False to bDashComment                                    
93492>>>>>        Move "/*"  to sCommentStart   // These are the standard comment start & stop tokens...
93493>>>>>        Move "*/"  to sCommentEnd
93494>>>>>        Move "--"  to sDashComment    // ...but a comment can also start with two dashes "--".
93495>>>>>
93495>>>>>        Move (SizeOfArray(SqlScriptArray.sSQLScriptArray)) to iSize
93496>>>>>        Decrement iSize
93497>>>>>        Move "" to sText  
93498>>>>>        
93498>>>>>        For iCount from 0 to iSize
93504>>>>>>
93504>>>>>            Move SqlScriptArray.sSQLScriptArray[iCount] to sLine
93505>>>>>            Move (Trim(sLine)) to sTmp
93506>>>>>            If (sTmp <> "") Begin
93508>>>>>                Move (Left(sTmp, 2) = sDashComment) to bDashComment
93509>>>>>                If (bCommentStart = False) Begin
93511>>>>>                    Move (Left(sTmp, 2) = sCommentStart) to bCommentStart
93512>>>>>                    If (bCommentStart = False) Begin
93514>>>>>                    End
93514>>>>>>
93514>>>>>                End
93514>>>>>>
93514>>>>>                Move (sTmp contains sCommentEnd) to bCommentEnd
93515>>>>>                If (bCommentEnd = True) Begin
93517>>>>>                    Move False to bCommentStart
93518>>>>>                End
93518>>>>>>
93518>>>>>                If (bDashComment = False and bCommentStart = False and bCommentEnd = False) Begin
93520>>>>>                    Move sLine to sSQLScriptArray[SizeOfArray(sSQLScriptArray)] 
93521>>>>>                End
93521>>>>>>
93521>>>>>            End
93521>>>>>>
93521>>>>>        Loop 
93522>>>>>>
93522>>>>>        
93522>>>>>        // Update the retval struct array:    
93522>>>>>        Move sSQLScriptArray to SqlScriptArray.sSQLScriptArray
93523>>>>>        Function_Return SqlScriptArray
93524>>>>>    End_Function
93525>>>>>
93525>>>>>    // *** Database API Functions: ***
93525>>>>>    // Instead of using Sql Scripts (ESQL), we can opt to use the DataFlex Database API's to 
93525>>>>>    // make changes/updates to the database.
93525>>>>>    //
93525>>>>>    //
93525>>>>>    // This might not do what you think - Here's what it does:
93525>>>>>    // It checks that the passed hTable TableName in filelist.cfg is exactly the same as at the SQL back-end.
93525>>>>>    // If that is True; it creates an .int file for it and changes Filelist.cfg to point
93525>>>>>    // to the SQL table.
93525>>>>>    // Typical usage for this function is when an entry exists in the Filelist for a table and the table
93525>>>>>    // already exists in SQL. 
93525>>>>>    // This is a bit fiddly as the DF_FILE_PHYSICAL_NAME attribute can only be set inside a 
93525>>>>>    // Structure_Start ... Structure_End operation when creating a NEW table. Thus it cannot be set when 
93525>>>>>    // restructuring an existing table.
93525>>>>>    Function ApiTableAttachToSQL Handle hTable Boolean bUseConnID Returns Boolean
93527>>>>>        Boolean bExists bOpened bOK bSystemFile bMertechDriver bUseConnectionID
93527>>>>>        String sDriverID sTableName sConnectionID sConnectionString sDisplayName sRootName sLogicalName sPhysicalName sSchema
93527>>>>>        Handle hToTable 
93527>>>>>        Integer iPos
93527>>>>>        
93527>>>>>        Move True to bUseConnectionID
93528>>>>>        If (num_arguments > 1) Begin
93530>>>>>            Move bUseConnID to bUseConnectionID
93531>>>>>        End                                    
93531>>>>>>
93531>>>>>        
93531>>>>>        Get psDriverID to sDriverID
93532>>>>>        // If the table doesn't exist on the SQL back-end we do nothing.
93532>>>>>        Get SqlUtilCheckIfTableHandleExists hTable sDriverID to bExists
93533>>>>>        If (bExists = False) Begin
93535>>>>>            Function_Return False
93536>>>>>        End
93536>>>>>>
93536>>>>>        
93536>>>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
93537>>>>>        If (bOK = False) Begin
93539>>>>>            Function_Return False
93540>>>>>        End
93540>>>>>>
93540>>>>>        
93540>>>>>        // Then we need to check that the function hasn't been called before; which in case
93540>>>>>        // we do nothing
93540>>>>>        Get SQLUtilTableIsAttached sDriverID hTable to bExists
93541>>>>>        If (bExists = True) Begin
93543>>>>>            Function_Return False
93544>>>>>        End
93544>>>>>>
93544>>>>>        
93544>>>>>        Get psConnectionID     to sConnectionID
93545>>>>>        Get psConnectionString to sConnectionString 
93546>>>>>        If (sConnectionID = "" or sConnectionString = "") Begin
93548>>>>>            Error DFERR_PROGRAM ("An SQL connection has NOT been setup correctly. Could not attach table:" * String(hTable) * "to SQL")
93549>>>>>>
93549>>>>>            Function_Return False
93550>>>>>        End                      
93550>>>>>>
93550>>>>>
93550>>>>>        Get psSchema to sSchema
93551>>>>>        If (sSchema = "") Begin
93553>>>>>            Get _SqlFindKeyWord CI_SQLDBO to sSchema  
93554>>>>>        End
93554>>>>>>
93554>>>>>
93554>>>>>        Get IsMertechDriver sDriverID to bMertechDriver
93555>>>>>        
93555>>>>>        // Mertech drivers don't use connection id's, so if the passed bUseConnectionID = True that
93555>>>>>        // was a programmer's error and we adjust for it here.
93555>>>>>        If (bMertechDriver = True) Begin
93557>>>>>            Move False to bUseConnectionID
93558>>>>>        End
93558>>>>>>
93558>>>>>            
93558>>>>>        // If we should use a connection id we need to check it exists; 
93558>>>>>        // else we create it before attempting creating the table
93558>>>>>        If (bUseConnectionID = True) Begin  
93560>>>>>            Get AutoConnectionIDLogin to bOK
93561>>>>>            If (bOk = False) Begin
93563>>>>>                Error DFERR_PROGRAM ("The Connection ID:" * sConnectionID * "could not be created and therefor the table can't be created.")
93564>>>>>>
93564>>>>>                Function_Return False
93565>>>>>            End
93565>>>>>>
93565>>>>>        End
93565>>>>>>
93565>>>>>            
93565>>>>>        Get_Attribute DF_FILE_ROOT_NAME of hTable to sRootName
93568>>>>>        Get _TableNameOnly sRootName to sRootName             
93569>>>>>        If (sRootName = "") Begin
93571>>>>>            Function_Return False
93572>>>>>        End
93572>>>>>>
93572>>>>>        Move (sRootName + ".int") to sPhysicalName       
93573>>>>>        Get_Attribute DF_FILE_LOGICAL_NAME of hTable to sLogicalName
93576>>>>>        Get_Attribute DF_FILE_DISPLAY_NAME of hTable to sDisplayName
93579>>>>>        If (sDisplayName contains ".") Begin
93581>>>>>            Move (Pos(".", sDisplayName)) to iPos  
93582>>>>>            Move (Mid(sDisplayName, 200 ,(iPos + 1))) to sDisplayName
93583>>>>>            Move (sSchema + "." + sDisplayName)       to sDisplayName
93584>>>>>        End
93584>>>>>>
93584>>>>>        If (not(Lowercase(sDisplayName) contains Lowercase(sSchema + "."))) Begin
93586>>>>>            Move (Lowercase(sSchema) + "." + sDisplayName) to sDisplayName
93587>>>>>        End
93587>>>>>>
93587>>>>>        
93587>>>>>        // ToDo: Needs to be revised. Should be able to connect to SQL without table already exist?
93587>>>>>        Open hTable Mode DF_EXCLUSIVE
93589>>>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpened
93592>>>>>        If (bOpened = False) Begin 
93594>>>>>            Error DFERR_PROGRAM ("Function ApiTableAttachToSQL - Could not open table number:" * String(hTable) * sLogicalName)
93595>>>>>>
93595>>>>>            Function_Return False
93596>>>>>        End                      
93596>>>>>>
93596>>>>>        
93596>>>>>        If (ghoProgressBar <> 0) Begin
93598>>>>>            Send DoAdvance of ghoProgressBar
93599>>>>>        End
93599>>>>>>
93599>>>>>        // Note: The hToTable will get changed by the Structure_xxx command...
93599>>>>>        Move hTable to hToTable 
93600>>>>>        Move False to Err       
93601>>>>>        
93601>>>>>        // We now create a stub .int file and after Structure_end and also change the Filelist.cfg,
93601>>>>>        // then we do a pseudo .int file change with the "SqlUtilUpdateIntFile" function. After that we have
93601>>>>>        // a proper and updated .int file.
93601>>>>>        Get_Attribute DF_FILE_IS_SYSTEM_FILE of hTable to bSystemFile  
93604>>>>>        Get SqlUtilCreateIntFile hTable sDriverID sConnectionID True bSystemFile to bOK
93605>>>>>        
93605>>>>>        Structure_Start hToTable sDriverID
93606>>>>>            If (bUseConnectionID = True) Begin  
93608>>>>>                Set_Attribute DF_FILE_LOGIN     of hToTable to (CS_DFCONNID + "=" + sConnectionID)
93611>>>>>            End
93611>>>>>>
93611>>>>>            Else Begin
93612>>>>>                Set_Attribute DF_FILE_LOGIN     of hToTable to sConnectionString
93615>>>>>            End
93615>>>>>>
93615>>>>>            Set_Attribute DF_FILE_OWNER         of hToTable to (Lowercase(sSchema))
93618>>>>>            // For unknown reason the above sometimes triggers an error and it doesn't help to try to trap the error; so we cheat...
93618>>>>>            Move False to Err
93619>>>>>            Move 0 to LastErr
93620>>>>>        Structure_End hToTable 
93622>>>>>        
93622>>>>>        Move (not(Err)) to bOK
93623>>>>>        If (bOK = True) Begin
93625>>>>>            // The attributes set above will always trigger an error
93625>>>>>            // We also adjust the Filelist entries
93625>>>>>            Set_Attribute DF_FILE_ROOT_NAME    of hTable to (sDriverID + ":" + sRootName)
93628>>>>>            Set_Attribute DF_FILE_LOGICAL_NAME of hTable to sLogicalName
93631>>>>>            Set_Attribute DF_FILE_DISPLAY_NAME of hTable to sDisplayName
93634>>>>>            
93634>>>>>            // This pseudo updates the .int file to make it up-to-date with the SQL back-end.
93634>>>>>            Get SqlUtilUpdateIntFile hTable to bOK
93635>>>>>        End
93635>>>>>>
93635>>>>>          
93635>>>>>        Function_Return (bOK = True)
93636>>>>>    End_Function
93637>>>>>    
93637>>>>>    // Sample usage:    
93637>>>>>    //    Get ApiTableChangeAttribute SysInfo.File_Number DF_FILE_IS_SYSTEM_FILE True to bOK
93637>>>>>    //    Get ApiTableChangeAttribute OrderHea.File_Number DF_FILE_REUSE_DELETED DF_FILE_DELETED_NOREUSE to bOK
93637>>>>>    Function ApiTableChangeAttribute Handle hTable Integer iAttribute Integer iValue Returns Boolean
93639>>>>>        Boolean bOK
93639>>>>>        
93639>>>>>        Get AutoConnectionIDLogin to bOK
93640>>>>>        Move False to Err
93641>>>>>        Open hTable Mode DF_EXCLUSIVE
93643>>>>>        Structure_Start hTable
93644>>>>>            Set_Attribute iAttribute of hTable to iValue
93647>>>>>        Structure_End hTable 
93649>>>>>
93649>>>>>        Function_Return (Err = False)
93650>>>>>    End_Function
93651>>>>>    
93651>>>>>    // To use a filelist slot for the passed FileName, TableName & DisplayName,
93651>>>>>    // or to change the filelist slot names.    
93651>>>>>    Function ApiTableChangeFileListSlot String sRootName String sLogicalName String sDisplayName Handle hTable String sDriverID Returns Boolean       
93653>>>>>        Move False to Err
93654>>>>>        Boolean bExists
93654>>>>>        
93654>>>>>        Move False to Err
93655>>>>>        Get UtilTableNumberIsInUse hTable to bExists
93656>>>>>        If (bExists = False) Begin
93658>>>>>            Function_Return False
93659>>>>>        End
93659>>>>>>
93659>>>>>
93659>>>>>        If (ghoProgressBar <> 0) Begin
93661>>>>>            Send DoAdvance of ghoProgressBar
93662>>>>>        End
