83018>>>>>>>    Integer MertechInc_iArg            //Replaces _LLONG#
83018>>>>>>>    Integer MertechInc_iCallBack       //Replaces _CALLBACK#
83018>>>>>>>    Integer MertechInc_iCount          //General loop limit integer
83018>>>>>>>    Integer MertechInc_iDecSep         //Holds the decimal seperator
83018>>>>>>>    Integer MertechInc_iFunction       //Replaces _FID#    ??? check is this is need when tidy is complete
83018>>>>>>>    Integer MertechInc_iLoop           //General loop integer
