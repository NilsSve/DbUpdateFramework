82473>>>>>>>    //***
82473>>>>>>>    //*** Function: IsMinimalRevision
82473>>>>>>>    //*** Purpose : Determines if the CK conforms to a passed minimal revsion.
82473>>>>>>>    //***
82473>>>>>>>
82473>>>>>>>    Function IsMinimalRevision Integer iMajor Integer iMinor Integer iRelease Integer iBuild Returns Integer
82475>>>>>>>        If (iMajor < CKMajorRevision(Current_object)) ;            Function_return (TRUE)
82478>>>>>>>        Else If (iMajor = CKMajorRevision(Current_object)) Begin
82481>>>>>>>            If (iMinor < CKMinorRevision(Current_object)) ;                Function_return (TRUE)
82484>>>>>>>            Else If (iMinor = CKMinorRevision(Current_object)) Begin
82487>>>>>>>                If (iRelease < CKReleaseRevision(Current_object)) ;                    Function_return (TRUE)
82490>>>>>>>                Else If (iRelease = CKReleaseRevision(Current_object) And iBuild <= CKBuildRevision(Current_object)) ;                    Function_return (TRUE)
82494>>>>>>>            End
82494>>>>>>>>
82494>>>>>>>        End
82494>>>>>>>>
82494>>>>>>>
82494>>>>>>>        Function_Return (FALSE)
82495>>>>>>>    End_Function // IsMinimalRevision
82496>>>>>>>
82496>>>>>>>    //   Functions to query the Pervasive.SQL version:
82496>>>>>>>    //       PSQLRequesterVersionInfo    Integer iFileNum Returns String
82496>>>>>>>    //       PSQLLocalEngineVersionInfo  Integer iFileNum Returns String
82496>>>>>>>    //       PSQLServerEngineVersionInfo Integer iFileNum Returns String
82496>>>>>>>    //
82496>>>>>>>    //   All 3 functions return the version of a Pervasive.SQL component
82496>>>>>>>    //   in the following format:
82496>>>>>>>    //       <version>.<revision>.<type>
82496>>>>>>>    //   possible values for <type>:
82496>>>>>>>    //       9 for 32-bit Windows workstation/workgroup engine or Linux
82496>>>>>>>    //         server using Workgroup authentication mode
82496>>>>>>>    //       C for client cache engine
82496>>>>>>>    //       D for DOS workstation
82496>>>>>>>    //       N for client Requester
82496>>>>>>>    //       S for NetWare server
82496>>>>>>>    //       T for 32-bit Windows server engine
82496>>>>>>>    //       U for Linux server using PAM or BTPASSWD authentication
82496>>>>>>>    //
82496>>>>>>>    //   example:
82496>>>>>>>    //       8.50.T
82496>>>>>>>    //   will be returned for a Pervasive.SQL 8.5 Server Engine running on
82496>>>>>>>    //   32-bits Windows server.
82496>>>>>>>    //
82496>>>>>>>    //   The FileNumber parameter must specify an opened table or 0.
82496>>>>>>>    //   For PSQLServerEngineVersionInfo the FileNumber can not be 0.
82496>>>>>>>    //
82496>>>>>>>    //   If the version information is not available or can not be obtained
82496>>>>>>>    //   the functions will return "0.0.0"
82496>>>>>>>
82496>>>>>>>
82496>>>>>>>    //***
82496>>>>>>>    //*** Function: PSQLRequesterVersionInfo
82496>>>>>>>    //*** Purpose : Returns the version information of the
82496>>>>>>>    //***           Pervasive.SQL Client requester.
82496>>>>>>>
82496>>>>>>>    Function PSQLRequesterVersionInfo Integer iFileNum Returns String
82498>>>>>>>
82498>>>>>>>        Local String  sDriverID
82498>>>>>>>        Local String  sVersion
82498>>>>>>>        Local String  sVoid
82498>>>>>>>        Local Integer iRetval
82498>>>>>>>
82498>>>>>>>        // Ignore error 20491 DFBTRERR_INVALID_DRIVER_FUNCTION_CALL.
82498>>>>>>>        // This error would otherwise be raised when we have an older
82498>>>>>>>        // DFBTRDRV version that has no DFBTRFN_CKREVISION function
82498>>>>>>>        Send Ignore_error To Error_object_Id 20491
82499>>>>>>>        Get psDriverID To sDriverID
82500>>>>>>>        Move (Repeat(" ", 255)) To sVersion
82501>>>>>>>        Call_Driver iFileNum sDRiverID Function DFBTRFN_PSQLREQUESTERVERSIONINFO Callback 0 Passing sVersion sVoid 0 Result iRetval
82506>>>>>>>        Send Trap_Error To Error_object_Id 20491
82507>>>>>>>        If (Trim(sVersion) = "") Begin
82509>>>>>>>            // Unable to get the revision. return all zeroes.
82509>>>>>>>            Move "0.0.0" To sVersion
82510>>>>>>>        End
82510>>>>>>>>
82510>>>>>>>        Function_Return sVersion
82511>>>>>>>    End_Function //  PSQLRequesterVersion
82512>>>>>>>
82512>>>>>>>    //***
82512>>>>>>>    //*** Function: PSQLLocalEngineVersionInfo
82512>>>>>>>    //*** Purpose : Returns the version information of the
82512>>>>>>>    //***           Pervasive.SQL Local Engine
82512>>>>>>>
82512>>>>>>>    Function PSQLLocalEngineVersionInfo Integer iFileNum Returns String
82514>>>>>>>
82514>>>>>>>        Local String  sDriverID
82514>>>>>>>        Local String  sVersion
82514>>>>>>>        Local String  sVoid
82514>>>>>>>        Local Integer iRetval
82514>>>>>>>
82514>>>>>>>        // Ignore error 20491 DFBTRERR_INVALID_DRIVER_FUNCTION_CALL.
82514>>>>>>>        // This error would otherwise be raised when we have an older
82514>>>>>>>        // DFBTRDRV version that has no DFBTRFN_CKREVISION function
82514>>>>>>>        Send Ignore_error To Error_object_Id 20491
82515>>>>>>>        Get psDriverID To sDriverID
82516>>>>>>>        Move (Repeat(" ", 255)) To sVersion
82517>>>>>>>        Call_Driver iFileNum sDRiverID Function DFBTRFN_PSQLLOCALENGINEVERSIONINFO Callback 0 Passing sVersion sVoid 0 Result iRetval
82522>>>>>>>        Send Trap_Error To Error_object_Id 20491
82523>>>>>>>        If (Trim(sVersion) = "") Begin
82525>>>>>>>            // Unable to get the revision. return all zeroes.
82525>>>>>>>            Move "0.0.0" To sVersion
82526>>>>>>>        End
82526>>>>>>>>
82526>>>>>>>        Function_Return sVersion
82527>>>>>>>    End_Function //  PSQLLocalEngineVersion
82528>>>>>>>
82528>>>>>>>    //***
82528>>>>>>>    //*** Function: PSQLServerEngineVersionInfo
82528>>>>>>>    //*** Purpose : Returns the version information of the
82528>>>>>>>    //***           Pervasive.SQL Server Engine
82528>>>>>>>
82528>>>>>>>    Function PSQLServerEngineVersionInfo Integer iFileNum Returns String
82530>>>>>>>
82530>>>>>>>        Local String  sDriverID
82530>>>>>>>        Local String  sVersion
82530>>>>>>>        Local String  sVoid
82530>>>>>>>        Local Integer iRetval
82530>>>>>>>
82530>>>>>>>        // Ignore error 20491 DFBTRERR_INVALID_DRIVER_FUNCTION_CALL.
82530>>>>>>>        // This error would otherwise be raised when we have an older
82530>>>>>>>        // DFBTRDRV version that has no DFBTRFN_CKREVISION function
82530>>>>>>>        Send Ignore_error To Error_object_Id 20491
82531>>>>>>>        Get psDriverID To sDriverID
82532>>>>>>>        Move (Repeat(" ", 255)) To sVersion
82533>>>>>>>        Call_Driver iFileNum sDRiverID Function DFBTRFN_PSQLSERVERENGINEVERSIONINFO Callback 0 Passing sVersion sVoid 0 Result iRetval
82538>>>>>>>        Send Trap_Error To Error_object_Id 20491
82539>>>>>>>        If (Trim(sVersion) = "") Begin
82541>>>>>>>            // Unable to get the revision. return all zeroes.
82541>>>>>>>            Move "0.0.0" To sVersion
82542>>>>>>>        End
82542>>>>>>>>
82542>>>>>>>        Function_Return sVersion
82543>>>>>>>    End_Function //  PSQLServerEngineVersion
82544>>>>>>>
82544>>>>>>>End_Class // cDfbtrdrvHandler
