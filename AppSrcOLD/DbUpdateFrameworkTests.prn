84743>>>>>        Send AppendTextLn ""
84744>>>>>
84744>>>>>        Send Show_ServicePack
84745>>>>>        If (ghoApplication <> 0) Begin
84747>>>>>            Send Show_WorkSpaceInformation
84748>>>>>            Send Show_HelpFile
84749>>>>>            Send AppendTextLn ""
84750>>>>>        End
84750>>>>>>
84750>>>>>        Else Begin
84751>>>>>            Send AppendTextLn ""
84752>>>>>        End
84752>>>>>>
84752>>>>>
84752>>>>>        If (ghoConnection <> 0) Begin
84754>>>>>            Send Show_ConnectionIdInformation
84755>>>>>        End
84755>>>>>>
84755>>>>>        
84755>>>>>        Send Show_Current_User
84756>>>>>        Send Show_Windows_Directory
84757>>>>>        Send Show_Current_Directory
84758>>>>>
84758>>>>>        // This is already shown in the workspace details,
84758>>>>>        // unless no workspace object is present:
84758>>>>>        If (ghoApplication = 0) Begin
84760>>>>>            Send Show_Filelist_Name
84761>>>>>        End
84761>>>>>>
84761>>>>>
84761>>>>>        If (ghoApplication <> 0) Begin
84763>>>>>            Send AppendTextLn ""
84764>>>>>            Send Show_EnterAsTab
84765>>>>>        End
84765>>>>>>
84765>>>>>
84765>>>>>        Send Show_Versions
84766>>>>>        Send Show_Screen_Size
84767>>>>>        Send Show_Page_Size
84768>>>>>        Send Show_Number_Format
84769>>>>>        Send Show_Date_Format
84770>>>>>        Send Show_Lock_Delay
84771>>>>>        Send Show_Lock_Timeout
84772>>>>>        Send Show_Date
84773>>>>>        Send Show_Systemresources
84774>>>>>        Send Beginning_of_Data
84775>>>>>
84775>>>>>        Set Icon to 'default.ico'
84776>>>>>    End_Procedure
