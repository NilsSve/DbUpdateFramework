83018>>>>>>>/// @Name        DF_FILE_OEM_TRANSLATION
83018>>>>>>>/// @Description There are two sets of code pages used in windows, ANSI and
83018>>>>>>>/// OEM. ANSI is what is commonly used now, but some data still uses the OEM
83018>>>>>>>/// code pages. When migrating data, this attribute is used to determine whether
83018>>>>>>>/// the OEM data will be translated to ANSI during the migration. For example,
83018>>>>>>>/// migrating passwords with special characters may call for different code pages.
83018>>>>>>>/// Setting this attribute to true will convert the OEM data to ANSI, setting it
83018>>>>>>>/// to false will not.
83018>>>>>>>///
83018>>>>>>>/// @Assumptions
83018>>>>>>>/// @Status      Public
83018>>>>>>>/// @Drivers     All
83018>>>>>>>/// @VersionNote Last Revised: 2013-08-15 by Aaron Gulack
83018>>>>>>>/// @See
83018>>>>>>>/// @INTOPT
83018>>>>>>>///
83018>>>>>>>/// @Syntax Set_Attribute DF_FILE_OEM_TRANSLATION of {FileNumber} to {variable}
83018>>>>>>>/// @Syntax Get_Attribute DF_FILE_OEM_TRANSLATION of {FileNumber} to {variable}
83018>>>>>>>/// @Param  FileNumber            Number of the file
83018>>>>>>>/// @Param  variable              Indicates if OEM data will be converted to ANSI. True converts it, false does not.
83018>>>>>>>/// @Example
83018>>>>>>>/// open Customer
83018>>>>>>>///
83018>>>>>>>/// Handle hFile
83018>>>>>>>/// Boolean bTranslate
83018>>>>>>>///
83018>>>>>>>/// Move Customer.File_Number to hFile
83018>>>>>>>///
83018>>>>>>>/// Structure_Start hFile
83018>>>>>>>///     Set_Attribute DF_FILE_OEM_TRANSLATION of hFile to True
83018>>>>>>>///     Get_Attribute DF_FILE_OEM_TRANSLATION of hFile to bTranslate
83018>>>>>>>/// Structure_End hFile
83018>>>>>>>Define DF_FILE_OEM_TRANSLATION                      For (DF_FILE_RECORD_REREAD+51)
83018>>>>>>>
83018>>>>>>>//=============================================================================
83018>>>>>>>/// @Name        DF_FILE_EPOCH_YEAR
83018>>>>>>>/// @Description When dealing with two-digit years, an epoch year must be used
83018>>>>>>>/// to determine which century the date is referring to. For example if the
83018>>>>>>>/// epoch year is set to 30, then any two digit year greater than 30 will be
83018>>>>>>>/// considered in the 20th Century, anything less than or equal to 30 will be
83018>>>>>>>/// considered in the 21st Century.  This attribute is used to turn on or off
83018>>>>>>>/// this feature. To use this feature, set this attribute to whatever the epoch
83018>>>>>>>/// year is expected to be. To disable this feature, set this attribute to 0
83018>>>>>>>/// or false. Note that setting this attribute must be done at table creation
83018>>>>>>>/// or inside of a Structure_Start.
83018>>>>>>>///
83018>>>>>>>/// @Assumptions
83018>>>>>>>/// @Status      Public
83018>>>>>>>/// @Drivers     All
83018>>>>>>>/// @VersionNote Last Revised: 2013-08-15 by Aaron Gulack
83018>>>>>>>/// @See
83018>>>>>>>/// @INTOPT      EPOCH_YEAR
83018>>>>>>>///
83018>>>>>>>/// @Syntax Set_Attribute DF_FILE_EPOCH_YEAR of {FileNumber} to {variable}
83018>>>>>>>/// @Syntax Get_Attribute DF_FILE_EPOCH_YEAR of {FileNumber} to {variable}
83018>>>>>>>/// @Param  FileNumber            Number of the file
83018>>>>>>>/// @Param  variable              Indicates what the epoch year is. 0 to disable
83018>>>>>>>/// @Example
83018>>>>>>>/// open Customer
83018>>>>>>>///
83018>>>>>>>/// Handle hFile
83018>>>>>>>/// Boolean bEpoch
83018>>>>>>>///
83018>>>>>>>/// Move Customer.File_Number to hFile
83018>>>>>>>///
83018>>>>>>>/// Structure_Start hFile
83018>>>>>>>///     Set_Attribute DF_FILE_EPOCH_YEAR of hFile to 30
83018>>>>>>>///     Get_Attribute DF_FILE_EPOCH_YEAR of hFile to bEpoch
83018>>>>>>>/// Structure_End hFile
83018>>>>>>>Define DF_FILE_EPOCH_YEAR                           For (DF_FILE_RECORD_REREAD+53)
83018>>>>>>>
