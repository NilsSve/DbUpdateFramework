88956>>>>>>>    // Creates a struct array with all SQL keywords
88956>>>>>>>    // for all EN_xxx SQL back-ends. Various back-ends can
88956>>>>>>>    // have slightly different wording.
88956>>>>>>>    // If a new EN_dbTypexxx type is added; additions
88956>>>>>>>    // needs to be done for every keyword group below.
88956>>>>>>>    Procedure SetupSQLKeywordArray
88958>>>>>>>        tSQLKeyWords[] SQLKeywordArray SQLKeywordArraySorted
88958>>>>>>>        tSQLKeyWords[] SQLKeywordArray SQLKeywordArraySorted
88960>>>>>>>        
88960>>>>>>>        // This should only be called once; but in case it is
88960>>>>>>>        // we delete the array first.                        
88960>>>>>>>        Set paSQLKeywordArray to SQLKeywordArray 
88961>>>>>>>       
88961>>>>>>>        // ToDo: *** These SQL Key-words needs to be checked for other backends than MS-SQL! ***
88961>>>>>>>        //
88961>>>>>>>        Send Add_Element CI_SQLAlterTable EN_dbTypeMSSQL    "ALTER TABLE"
88962>>>>>>>        Send Add_Element CI_SQLAlterTable EN_dbTypeMySQL    "ALTER TABLE"
88963>>>>>>>        Send Add_Element CI_SQLAlterTable EN_dbTypeOracle   "ALTER TABLE"
88964>>>>>>>        Send Add_Element CI_SQLAlterTable EN_dbTypeDB2      "ALTER TABLE"
88965>>>>>>>        Send Add_Element CI_SQLAlterTable EN_dbTypePostgre  "ALTER TABLE"
88966>>>>>>>    
88966>>>>>>>        Send Add_Element CI_SQLAdd EN_dbTypeMSSQL           "ADD"
88967>>>>>>>        Send Add_Element CI_SQLAdd EN_dbTypeMySQL           "ADD"
88968>>>>>>>        Send Add_Element CI_SQLAdd EN_dbTypeOracle          "ADD"
88969>>>>>>>        Send Add_Element CI_SQLAdd EN_dbTypeDB2             "ADD"
88970>>>>>>>        Send Add_Element CI_SQLAdd EN_dbTypePostgre         "ADD"
88971>>>>>>>                                                                        
88971>>>>>>>        Send Add_Element CI_SQLUpdate EN_dbTypeMSSQL        "UPDATE"
88972>>>>>>>        Send Add_Element CI_SQLUpdate EN_dbTypeMySQL        "UPDATE"
88973>>>>>>>        Send Add_Element CI_SQLUpdate EN_dbTypeOracle       "UPDATE"
88974>>>>>>>        Send Add_Element CI_SQLUpdate EN_dbTypeDB2          "UPDATE"
88975>>>>>>>        Send Add_Element CI_SQLUpdate EN_dbTypePostgre      "UPDATE"
88976>>>>>>>                                                                        
88976>>>>>>>        Send Add_Element CI_SQLNotNull EN_dbTypeMSSQL       "NOT NULL"
88977>>>>>>>        Send Add_Element CI_SQLNotNull EN_dbTypeMySQL       "NOT NULL"
88978>>>>>>>        Send Add_Element CI_SQLNotNull EN_dbTypeOracle      "" // Seems like Oracle can't handle setting a new column to 'NOT NULL' if the table exists with data(!)
88979>>>>>>>        Send Add_Element CI_SQLNotNull EN_dbTypeDB2         "SET NOT NULL"
88980>>>>>>>        Send Add_Element CI_SQLNotNull EN_dbTypePostgre     "NOT NULL"
88981>>>>>>>                                                                        
