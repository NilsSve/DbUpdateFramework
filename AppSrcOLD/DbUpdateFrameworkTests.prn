92573>>>>>    // Removes all driver identifications (e.g. "MSSQLDRV;MyTable" or "MyTable.MSSQLDRV"
92573>>>>>    // from the passed filelist.
92573>>>>>    // Returns the number of tables affected.
92573>>>>>    Function SqlUtilFilelistRemoveDriverInfo String sFilelist Returns Integer
92575>>>>>        String sCurrentFileList sRootName sDisplayName sLogicalName sVal
92575>>>>>        Integer iRetval
92575>>>>>        Handle hTable
92575>>>>>        
92575>>>>>        // We first save the current filelist as the passed filelist name
92575>>>>>        // may come from another workspace, to restore it when we're ready.
92575>>>>>        Get_Attribute DF_FILELIST_NAME to sCurrentFileList
92578>>>>>        Set_Attribute DF_FILELIST_NAME to sFilelist
92581>>>>>        Move 0 to hTable
92582>>>>>        Move 0 to iRetval
92583>>>>>        
92583>>>>>        Repeat
92583>>>>>>
92583>>>>>            Get_Attribute DF_FILE_NEXT_USED of hTable to hTable
92586>>>>>            If (hTable <> 0) Begin
92588>>>>>                Get_Attribute DF_FILE_ROOT_NAME    of hTable to sRootName
92591>>>>>                Get_Attribute DF_FILE_DISPLAY_NAME of hTable to sDisplayName
92594>>>>>                Get_Attribute DF_FILE_LOGICAL_NAME of hTable to sLogicalName
92597>>>>>                Move (Uppercase(sRootName)) to sVal
92598>>>>>                If (sVal contains MSSQLDRV_ID or sVal contains DB2_DRV_ID or sVal contains ODBC_DRV_ID) Begin
92600>>>>>                    // Prefixes:
92600>>>>>                    Move (Replace((MSSQLDRV_ID + ":"), sRootName, "")) to sRootName
92601>>>>>                    Move (Replace((DB2_DRV_ID  + ":"), sRootName, "")) to sRootName
92602>>>>>                    Move (Replace((ODBC_DRV_ID + ":"), sRootName, "")) to sRootName
92603>>>>>                    // Suffixes:
92603>>>>>                    Move (Replace(("." + MSSQLDRV_ID), sRootName, "")) to sRootName
92604>>>>>                    Move (Replace(("." + DB2_DRV_ID),  sRootName, "")) to sRootName
92605>>>>>                    Move (Replace(("." + ODBC_DRV_ID), sRootName, "")) to sRootName
92606>>>>>                    
92606>>>>>                    // Change Filelist entry:
92606>>>>>                    Set_Attribute DF_FILE_ROOT_NAME of hTable          to sRootName
92609>>>>>
92609>>>>>                    Move (Lowercase(sDisplayName)) to sVal
92610>>>>>                    If (sVal contains "dbo.") Begin
92612>>>>>                        Move (Replace("dbo.", sDisplayName, ""))       to sDisplayName
92613>>>>>                        
92613>>>>>                        // Change Filelist entry:
92613>>>>>                        Set_Attribute DF_FILE_DISPLAY_NAME of hTable   to sDisplayName
92616>>>>>                    End
92616>>>>>>
92616>>>>>                    Increment iRetval
92617>>>>>                End
92617>>>>>>
92617>>>>>            End
92617>>>>>>
92617>>>>>        Until (hTable = 0)
92619>>>>>        
92619>>>>>        Set_Attribute DF_FILELIST_NAME to sCurrentFileList
92622>>>>>        
92622>>>>>        Function_Return iRetval
92623>>>>>    End_Function
