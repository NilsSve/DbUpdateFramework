90198>>>>>>>    
90198>>>>>>>    // ************************************        
90198>>>>>>>    Function SetupSQLConnection Boolean bReadSettings Returns tSQLConnection
90200>>>>>>>        tSQLConnection SQLConnection 
90200>>>>>>>        tSQLConnection SQLConnection 
90200>>>>>>>        
90200>>>>>>>        // If this object was created by the cDbUpdateHandler class we will
90200>>>>>>>        // deferr reading SQL connection values until later.
90200>>>>>>>        If (bReadSettings = True) Begin
90202>>>>>>>            // This is the new SQL login logic for DF 19 and up; "Managed Connections"
90202>>>>>>>            If (ghoConnection > 0) Begin
90204>>>>>>>                Get ReadcConnections to SQLConnection
90205>>>>>>>            End
90205>>>>>>>>
90205>>>>>>>            
90205>>>>>>>            // In addition to the above; there might be other values set even if a cConnection
90205>>>>>>>            // object is used.
90205>>>>>>>            Get ReadSQLConnectionsIniSettings to SQLConnection
90206>>>>>>>        End     
90206>>>>>>>>
90206>>>>>>>        
90206>>>>>>>        Function_Return SQLConnection
90207>>>>>>>    End_Function
90208>>>>>>>    
90208>>>>>>>    // This is for the new cConnection class used by DF 19 and up (only).
90208>>>>>>>    Function ReadcConnections Returns tSQLConnection
90210>>>>>>>        tConnection Connection                 
90210>>>>>>>        tConnection Connection                 
90210>>>>>>>        tSQLConnection SQLConnection SQLConnectionEmpty
90210>>>>>>>        tSQLConnection SQLConnection SQLConnectionEmpty
90210>>>>>>>        Integer iCount iSize iRetval iDbType
90210>>>>>>>        Boolean bOK bEnabled bConnected bVal
90210>>>>>>>        String sConnectionID sSchema
90210>>>>>>>        
90210>>>>>>>            // - If the DF 19 cConnection class has been used in the cApplication object
90210>>>>>>>            // - and there are multiple connection id's defined for the same driver. This is
90210>>>>>>>            //   because otherwise we can't possibly know which connection id to use... So
90210>>>>>>>            //   we then generate an error and abort the program...
90210>>>>>>>            Get IsSinglecConnection (&sConnectionID) to bOK                                     
90211>>>>>>>            If (bOK = False) Begin
90213>>>>>>>                Error DFERR_PROGRAM ("Programming error. The psConnectionID must be set in the cDbUpdateVersion object when a cConnect object is used in the cApplication object, and there are multiple connections defined. Program will now exit!")
90214>>>>>>>>
90214>>>>>>>                Abort
90215>>>>>>>>
90215>>>>>>>            End  
90215>>>>>>>>
90215>>>>>>>            
90215>>>>>>>            Move 0 to iRetval
90216>>>>>>>            // DAW DF19 connection info: 
90216>>>>>>>            // We first check that the connection is OK:  
90216>>>>>>>            Get ConnectionIdIndex of ghoConnection sConnectionID to iRetval
90217>>>>>>>            // It might happen that no connection has been setup although the object exists, in case we do nothing.
90217>>>>>>>            If (iRetval = -1) Begin
90219>>>>>>>                Function_Return SQLConnectionEmpty
90220>>>>>>>            End                                 
90220>>>>>>>>
90220>>>>>>>
90220>>>>>>>            If (sConnectionID <> "") Begin
90222>>>>>>>                Get ConnectionIdInfo of ghoConnection sConnectionID to Connection  
90223>>>>>>>            End
90223>>>>>>>>
90223>>>>>>>            If (Connection.sId = "") Begin
90225>>>>>>>                Move True to SQLConnectionEmpty.bError
90226>>>>>>>                Function_Return SQLConnectionEmpty
90227>>>>>>>            End
90227>>>>>>>>
90227>>>>>>>            
90227>>>>>>>            Move Connection.sId to sConnectionID  
90228>>>>>>>            Get IsConnectionIdLoggedIn of ghoConnection sConnectionID to bConnected
90229>>>>>>>    
90229>>>>>>>            If (bConnected = False) Begin
90231>>>>>>>                Get LoginConnectionId of ghoConnection to iRetval    
90232>>>>>>>                If (iRetval <> 0) Begin 
90234>>>>>>>                    Send UserError CS_DUF_CannotLoginToServer
90235>>>>>>>                    Send Exit_Application    
90236>>>>>>>                End
90236>>>>>>>>
90236>>>>>>>            End
90236>>>>>>>>
90236>>>>>>>            
90236>>>>>>>            // DUF connection info struct property:
90236>>>>>>>            Get Private.pSQLConnection                       to SQLConnection   
90237>>>>>>>            Move True                                        to SQLConnection.bEnabled
90238>>>>>>>            Move Connection.bTrustedConnection               to SQLConnection.bTrusted
90239>>>>>>>    
90239>>>>>>>            // Not used in DUF:
90239>>>>>>>            // Move Connection.iDriverIndex                    to SQLConnection.iDriverIndex
90239>>>>>>>    
90239>>>>>>>            Move (If(Connection.iOptions = 0, False, True))  to SQLConnection.bSilentLogin
90240>>>>>>>            Move Connection.sConnectionString                to SQLConnection.sConnectionString
90241>>>>>>>            Move Connection.sDriver                          to SQLConnection.sDriverID
90242>>>>>>>            Move Connection.sId                              to SQLConnection.sConnectionID
90243>>>>>>>            Move Connection.sUID                             to SQLConnection.sUserID
90244>>>>>>>            Move Connection.sPWD                             to SQLConnection.sPassword
90245>>>>>>>    
90245>>>>>>>            // Not used in DUF:
90245>>>>>>>            // Move Connection.sSection to SQLConnection.xxx
90245>>>>>>>            
90245>>>>>>>            // The rest of the properties of the SQLConnection struct should have been
90245>>>>>>>            // setup in the cDbUpdateHandler object, and we should be able to reach them through delegation:
90245>>>>>>>            If (Connection.sDriver <> ODBC_DRV_ID) Begin
90247>>>>>>>                Get ParseKeyWord Connection.sString CS_SQLIniServerKeyword to SQLConnection.sServer
90248>>>>>>>            End
90248>>>>>>>>
90248>>>>>>>            If (Connection.sDriver = ODBC_DRV_ID) Begin
90250>>>>>>>                Get ParseKeyWord Connection.sString CS_SQLIniDSNKeyword    to SQLConnection.sServer
90251>>>>>>>            End
90251>>>>>>>>
90251>>>>>>>            Get ParseKeyWord Connection.sString CS_SQLIniDatabaseKeyword   to SQLConnection.sDatabase  
90252>>>>>>>            
90252>>>>>>>            // The DbType is a bit special. If the piDbType has _not_ been setup in object code we try to derave
90252>>>>>>>            // the value from the driver id:
90252>>>>>>>            Get SqlUtilDbTypeFromDriver of (phoSQLConnectionIniFile(Self)) Connection.sDriver to SQLConnection.iDbType
90253>>>>>>>            // ...but in case it has been explicitly set in the object we use that value.
90253>>>>>>>            Get piDbType                                     to iDbType
90254>>>>>>>            If (iDbType <> SQLConnection.iDbType) Begin
90256>>>>>>>                Move iDbType to SQLConnection.iDbType
90257>>>>>>>            End
90257>>>>>>>>
90257>>>>>>>            Get psBaseTableSpace                             to SQLConnection.sBaseTableSpace
90258>>>>>>>            Get psLongTableSpace                             to SQLConnection.sLongTableSpace
90259>>>>>>>            Get psIndexTableSpace                            to SQLConnection.sIndexTableSpace
90260>>>>>>>            Get psSchema                                     to SQLConnection.sSchema
90261>>>>>>>            
90261>>>>>>>            // We finally set the struct property to the newly fetched values.
90261>>>>>>>            Set pSQLConnection to SQLConnection
90262>>>>>>>        
90262>>>>>>>        Function_Return SQLConnection
90263>>>>>>>    End_Function
90264>>>>>>>    
90264>>>>>>>    // Returns True if the psConnectionID has been set in the cDbUpateHandler object,
90264>>>>>>>    // or the DAW cConnect array of registered connection only contains one active/enabled
90264>>>>>>>    // connection id for a particular driver.
90264>>>>>>>    // So either the psConnectionID or the psDriverID can have been set in the cDbUpdateHandler
90264>>>>>>>    // object. We can then match a connection id from the DAW cConnect class array.
90264>>>>>>>    // Returns False if there are multiple connections that are enabled or the psConnectionID has
90264>>>>>>>    // been set in the cDbUpdateHandler object but it cannot be found amongst the registered 
90264>>>>>>>    // connections of the DAW cConnect class.
90264>>>>>>>    Function IsSinglecConnection String ByRef sConnectionID Returns Boolean
90266>>>>>>>        tConnection[] ConnIdArray
90266>>>>>>>        tConnection[] ConnIdArray
90267>>>>>>>        Integer iCount iSize iConnectionIDCounter
90267>>>>>>>        Boolean bOK bEnabled bFound
90267>>>>>>>        String sConnectionID2 sDriverID sDriverConn
90267>>>>>>>        
90267>>>>>>>        Move False to bFound
90268>>>>>>>        If (ghoConnection > 0) Begin           
90270>>>>>>>            
90270>>>>>>>            // The property of the cDbUpdateHandler container object
90270>>>>>>>            Get psDriverID to sDriverID
90271>>>>>>>            
90271>>>>>>>            Move 0 to iConnectionIDCounter 
90272>>>>>>>            // This is the the DAW cConnect array with all registered connection id's.
90272>>>>>>>                Get ConnectionIDs of ghoConnection to ConnIdArray
90273>>>>>>>            Move (SizeOfArray(ConnIdArray)) to iSize
90274>>>>>>>            Decrement iSize
90275>>>>>>>            For iCount from 0 to iSize
90281>>>>>>>>
90281>>>>>>>                Move ConnIdArray[iCount].sDriver to sDriverConn
90282>>>>>>>                Move ConnIdArray[iCount].sId to sConnectionID2
90283>>>>>>>                Move (ConnIdArray[iCount].bDisabled = False) to bEnabled    
90284>>>>>>>                // If no psConnectionID specified in the cDbUpdateHandler, we check if there is a driver
90284>>>>>>>                // connection in the DAW cConnect object _and_ that there is only one!
90284>>>>>>>                If (sConnectionID = "") Begin
90286>>>>>>>                    Move (sDriverID = sDriverConn and bEnabled = True) to bFound 
90287>>>>>>>                End 
90287>>>>>>>>
90287>>>>>>>                Else Begin
90288>>>>>>>                    If (Uppercase(sConnectionID) = Uppercase(sConnectionID2)) Begin
90290>>>>>>>                        Move iSize to iCount // Then we've found what we were looking for and we're out of here... 
90291>>>>>>>                    End
90291>>>>>>>>
90291>>>>>>>                End
90291>>>>>>>>
90291>>>>>>>                    
90291>>>>>>>                If (bFound = True) Begin
90293>>>>>>>                    Increment iConnectionIDCounter
90294>>>>>>>                End
90294>>>>>>>>
90294>>>>>>>            Loop
90295>>>>>>>>
90295>>>>>>>            Move (iConnectionIDCounter <= 1 and sDriverConn <> "" and sConnectionID2 <> "") to bFound 
90296>>>>>>>            If (bFound = True) Begin
90298>>>>>>>                Move sConnectionID2 to sConnectionID
90299>>>>>>>            End
90299>>>>>>>>
90299>>>>>>>        End 
90299>>>>>>>>
90299>>>>>>>        
90299>>>>>>>        // Special case; a cConnection object has been setup in the cApplication,
90299>>>>>>>        // but no DFConn.ini record has been created.
90299>>>>>>>        If (iSize = -1) Begin
90301>>>>>>>            Move True to bFound
90302>>>>>>>        End
90302>>>>>>>>
90302>>>>>>>            
90302>>>>>>>        Function_Return bFound
90303>>>>>>>    End_Function
90304>>>>>>>    
90304>>>>>>>    // Send on object creation to read the default connection string settings, and
90304>>>>>>>    // create a connection to the server.
90304>>>>>>>    Function ReadSQLConnectionsIniSettings Returns tSQLConnection
90306>>>>>>>        String sPath sFileName sSection sConnectionString sPassword 
90306>>>>>>>        Boolean bExists
90306>>>>>>>        tSQLConnection[] SQLConnectionArray
90306>>>>>>>        tSQLConnection[] SQLConnectionArray
90307>>>>>>>        tSQLConnection SQLConnection SQLConnectionEmpty
90307>>>>>>>        tSQLConnection SQLConnection SQLConnectionEmpty
90307>>>>>>>        Handle hoIniFile
90307>>>>>>>        Integer iSize iCount
90307>>>>>>>        
90307>>>>>>>        Get psIniFilePath to sPath
90308>>>>>>>        Get phoSQLConnectionIniFile to hoIniFile
90309>>>>>>>        If (sPath = "") Begin
90311>>>>>>>            Get ApplicationPath of hoIniFile to sPath 
90312>>>>>>>            Set psIniFilePath   of hoIniFile to sPath 
90313>>>>>>>        End         
90313>>>>>>>>
90313>>>>>>>        Get vFolderFormat sPath to sPath
90314>>>>>>>        Get psIniFileName to sFileName    
90315>>>>>>>        Get vFilePathExists (sPath + sFileName) to bExists
90316>>>>>>>//        If (bExists = False) Begin   
90316>>>>>>>//            Move True to SQLConnection.bError
90316>>>>>>>//            Function_Return SQLConnectionEmpty 
90316>>>>>>>//        End                                                         
90316>>>>>>>        
90316>>>>>>>        Get SQLIniFileReadConnections of hoIniFile to SQLConnectionArray
90317>>>>>>>        Move (SizeOfArray(SQLConnectionArray)) to iSize
90318>>>>>>>        If (iSize = 0) Begin
90320>>>>>>>            // This may have been set by the "ReadcConnections" function,
90320>>>>>>>            // if a cConnection object has been setup for DataFlex 19 or later
90320>>>>>>>            // in the cApplication object.
90320>>>>>>>            Get pSQLConnection to SQLConnection
90321>>>>>>>            If (SQLConnection.sConnectionID = "") Begin
90323>>>>>>>                Function_Return SQLConnectionEmpty
90324>>>>>>>            End
90324>>>>>>>>
90324>>>>>>>            Move SQLConnection to SQLConnectionArray[0]
90325>>>>>>>        End
90325>>>>>>>>
90325>>>>>>>        
90325>>>>>>>        // The first connection should be the one that is active, but just in case...
90325>>>>>>>        Decrement iSize
90326>>>>>>>        For iCount from 0 to iSize
90332>>>>>>>>
90332>>>>>>>            Move SQLConnectionArray[iCount] to SQLConnection
90333>>>>>>>            If (SQLConnection.bEnabled = True) Begin
90335>>>>>>>                Move iSize to iCount // We've found the enabled item, so we're out of here.
90336>>>>>>>            End
90336>>>>>>>>
90336>>>>>>>        Loop
90337>>>>>>>>
90337>>>>>>>
90337>>>>>>>        Send CreateSQLConnection SQLConnection.sDriverID SQLConnection.sConnectionID ;             SQLConnection.sServer SQLConnection.sDatabase SQLConnection.bTrusted ;             SQLConnection.sUserID SQLConnection.sPassword SQLConnection.bSilentLogin   
90338>>>>>>>             
90338>>>>>>>        Set pSQLConnection to SQLConnection 
90339>>>>>>>        Send AutoSetConnectionID
90340>>>>>>>        
90340>>>>>>>        Function_Return SQLConnection
90341>>>>>>>    End_Function
