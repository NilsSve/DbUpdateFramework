90829>>>>>>>                Get ParseKeyWord sConnectionString (CS_SQLIniDatabaseKeyword + "=") to sDatabase
90830>>>>>>>                Get ParseKeyWord sConnectionString (CS_SQLIniTrustedKeyword + "=")  to sValue
90831>>>>>>>                Move (If(Uppercase(sValue) = "YES", True, False))                   to bTrusted
90832>>>>>>>                If (bTrusted = False) Begin
90834>>>>>>>                    Get ParseKeyWord sConnectionString (CS_SQLIniUIDKeyword + "=")  to sUserID
90835>>>>>>>                    Get ParseKeyWord sConnectionString (CS_SQLIniPWDKeyword + "=")  to sPassword
90836>>>>>>>                End
90836>>>>>>>>
90836>>>>>>>                Case Break
90837>>>>>>>                                     
90837>>>>>>>            Case (sDriverID = ODBC_DRV_ID)
90840>>>>>>>                Get ParseKeyWord sConnectionString (CS_SQLIniDSNKeyword + "=")      to sServer
90841>>>>>>>                Get ParseKeyWord sConnectionString (CS_SQLIniTrustedKeyword + "=")  to sValue
90842>>>>>>>                Move (If(Uppercase(sValue) = "YES", True, False))                   to bTrusted
90843>>>>>>>                If (bTrusted = False) Begin
90845>>>>>>>                    Get ParseKeyWord sConnectionString (CS_SQLIniUIDKeyword + "=")  to sUserID
90846>>>>>>>                    Get ParseKeyWord sConnectionString (CS_SQLIniPWDKeyword + "=")  to sPassword
90847>>>>>>>                End
90847>>>>>>>>
90847>>>>>>>                Case Break
90848>>>>>>>                 
90848>>>>>>>            Case (sDriverID = DB2_DRV_ID)
90851>>>>>>>                Get ParseKeyWord sConnectionString (CS_SQLIniDSNKeyword + "=")      to sServer
90852>>>>>>>                Get ParseKeyWord sConnectionString (CS_SQLIniUIDKeyword + "=")      to sUserID
90853>>>>>>>                Get ParseKeyWord sConnectionString (CS_SQLIniPWDKeyword + "=")      to sPassword
90854>>>>>>>                Case Break
90855>>>>>>>                 
90855>>>>>>>            Case (sDriverID = SQLFLEX) 
