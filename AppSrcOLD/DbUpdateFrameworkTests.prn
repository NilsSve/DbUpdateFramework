85047>>>>>//            If (ghoApplication <> 0) Begin
85047>>>>>//                Get phoVersionInfo of ghoApplication to hoVersionInfo
85047>>>>>//                If (hoVersionInfo <> 0) Begin
85047>>>>>//                    Get pbIncluded of hoVersionInfo to bIncluded
85047>>>>>//                    If (bIncluded) Begin
85047>>>>>//                        Get piVersionMajor of hoVersionInfo to iMajor
85047>>>>>//                        Get piVersionMinor of hoVersionInfo to iMinor
85047>>>>>//                        Get piVersionRelease of hoVersionInfo to iRelease
85047>>>>>//                        Get piVersionBuild of hoVersionInfo to iBuild
85047>>>>>//                        Move (SFormat (C_$VERSION + ": %1.%2.%3.%4", iMajor, iMinor, iRelease, iBuild)) to sLabel
85047>>>>>//                        Set Version to sLabel
85047>>>>>//                    End
85047>>>>>//                End
85047>>>>>//            End
85047>>>>>//        End
85047>>>>>//
85047>>>>>//        Forward Send End_Construct_Object
