94344>>>>>    Function ApiTableRename Integer hTable String sRootName String sDisplayName String sLogicalName Returns Boolean
94346>>>>>        String sPhysicalName sDataPath sDriverID
94346>>>>>        Boolean bOK bExists
94346>>>>>        Integer iRetval
94346>>>>>        
94346>>>>>        Move False to Err
94347>>>>>        Get psDataPathFirstPart to sDataPath
94348>>>>>        Get_Attribute DF_FILE_PHYSICAL_NAME of hTable to sPhysicalName
94351>>>>>        
94351>>>>>        Get_Attribute DF_FILE_DRIVER of hTable to sDriverID
94354>>>>>        Close hTable  
94355>>>>>        If (sDriverID = DATAFLEX_ID) Begin                    
94357>>>>>            Get vFilePathExists (sDataPath + sRootName + ".dat") to bExists
94358>>>>>            If (bExists = True) Begin
94360>>>>>                If (Uppercase(sPhysicalName) = Uppercase(sRootName)) Begin
94362>>>>>                    Function_Return False
94363>>>>>                End
94363>>>>>>
94363>>>>>
94363>>>>>                // ToDo: How do we handle this when the library has been imported into 
94363>>>>>                // the cDbUpdateVersion Class?
94363>>>>>                // Get YesNo_Box ("The table:\n" + (sDataPath + sPhysicalName) + "\nis to be renamed to:\n" + (sDataPath + sRootName) + "\nBut the destination already exists. Overwrite?") to iRetval
94363>>>>>                If (iRetval <> MBR_Yes) Begin
94365>>>>>                    Function_Return False
94366>>>>>                End                      
94366>>>>>>
94366>>>>>            End                                           
94366>>>>>>
94366>>>>>            Copy_db (sDataPath + sPhysicalName) to (sDataPath + sRootName) 
94369>>>>>        End
94369>>>>>>
94369>>>>>        
94369>>>>>        If (sDriverID <> DATAFLEX_ID) Begin
94371>>>>>            Move (sDriverID + ":" + sRootName) to sRootName
94372>>>>>        End
94372>>>>>>
94372>>>>>
94372>>>>>        Set_Attribute DF_FILE_ROOT_NAME     of hTable to sRootName
94375>>>>>        Set_Attribute DF_FILE_DISPLAY_NAME  of hTable to sDisplayName
94378>>>>>        Set_Attribute DF_FILE_LOGICAL_NAME  of hTable to sLogicalName
94381>>>>>        
94381>>>>>        // We need a short break here before attempting to delete the physical file or Windows
94381>>>>>        // might report "File in use..." and the deletion will fail.
94381>>>>>        Sleep 2
94382>>>>>        If (sDriverID = DATAFLEX_ID) Begin                    
94384>>>>>            Get vDeleteFile (sDataPath + sPhysicalName + ".*") to bOK
94385>>>>>        End
94385>>>>>>
94385>>>>>        
94385>>>>>        Function_Return (Err = False)
94386>>>>>    End_Function
