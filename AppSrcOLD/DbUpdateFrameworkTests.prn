85048>>>
85048>>>// *************************************************************************
85048>>>//  Public message. This is the default message. It is expected that you will
85048>>>//   create your own message to override this
85048>>>// *************************************************************************
85048>>>
85048>>>Procedure Activate_About
85051>>>   Send DoAbout "" "" "" "" ""
85052>>>End_Procedure
85053>>>
85053>>>// *************************************************************************
85053>>>//  Public message. It is expected that you will send this message (most
85053>>>//  likely from Activate_About. This creates an about object, activates it
85053>>>//  and destroys it when done. It is not exepected that you will augment this.
85053>>>// *************************************************************************
85053>>>// Sample usage:
85053>>>//   The first two params will automatically be filled from the application settings if not provided.
85053>>>//   Send DoAbout "" "" ("Copyright: 2013" * psCompany(ghoApplication)) "Created by: Your Name" "YourAppBitmap.bmp" "Internet: http://www.YourWebAddress.com" "E-mail: mailto:support@YourEmailAddress.com" "Some other description of choice" "9th param" "and last param"
85053>>>
85053>>>Procedure DoAbout String sTitle String sVersion String sCopyRight String sAuthor String sBitmap ;                  String sParam6 String sParam7 String sParam8 String sParam9 String sParam10
85056>>>        Integer hoObj hoMain iArgs
85056>>>        String sValue
85056>>>
85056>>>        // Create object
85056>>>        Object About is an AboutDialog
85058>>>            // Uncomment these two lines if you would like to have a resizable About object.
85058>>>//            Set Border_Style to Border_Thick
85058>>>//            Set peAnchors to anAll
85058>>>
85058>>>            // Add checking for the number of arguments passed to avoid runtime errors
85058>>>            // if one of them is not passed. This makes the interface
85058>>>            // more flexible.
85058>>>            Move num_arguments to iArgs
85059>>>
85059>>>            // If no title is passed use the label of the main panel (if a main panel exists).
85059>>>            If (iArgs > 0 and sTitle = "") Begin
85061>>>                Get Main_Window of Desktop to hoMain
85062>>>                If hoMain Get Label of hoMain to sValue
85065>>>            End
85065>>>>
85065>>>            Else If (iArgs > 0 and sTitle <> "") Begin
85068>>>                Move sTitle to sValue
85069>>>            End
85069>>>>
85069>>>            Else If (iArgs = 0) Begin
85072>>>                Get Main_Window of Desktop to hoMain
85073>>>                If hoMain Get Label of hoMain to sValue
85076>>>            End
85076>>>>
85076>>>
85076>>>            If (sValue <> "") Send Add_LineLn sValue
85079>>>            Move "" to sValue
85080>>>
85080>>>            // If the passed sVersion value is blank, the info will be retrieved from the cApplication object.
85080>>>            // For this to work the Project Properties Version must have been set in the Studio.
85080>>>            If (iArgs < 2) Begin
85082>>>                Move "" to sValue
85083>>>            End
85083>>>>
85083>>>            Else Begin
85084>>>                Move sVersion to sValue
85085>>>            End
85085>>>>
85085>>>            Set Version to sValue
85086>>>
85086>>>            If (iArgs > 2 and sCopyRight <> "") Send Add_LineLn sCopyRight
85089>>>
85089>>>            // If only the five "standard" params were passed we don't add an extra linefeed;
85089>>>            // else we do.
85089>>>            If (iArgs > 3 and iArgs < 6 and sAuthor <> "") Begin
85091>>>                Send Add_Line sAuthor
85092>>>            End
85092>>>>
85092>>>            Else If (iArgs > 5 and sAuthor <> "") Begin
85095>>>                Send Add_LineLn sAuthor
85096>>>            End
85096>>>>
85096>>>
85096>>>            // Square bitmaps of 80x80 works best
85096>>>            If (iArgs > 4 and sBitmap <> "") Begin
85098>>>               Set Logo to sBitMap
85099>>>            End
85099>>>>
85099>>>
85099>>>            // Here starts handling of the five optional params:
85099>>>            If (iArgs = 6 and sParam6  <> "") Begin
85101>>>                Send Add_Line sParam6
85102>>>            End
85102>>>>
85102>>>            Else If (iArgs > 6 and sParam6  <> "") Begin
85105>>>                Send Add_LineLn sParam6
85106>>>            End
85106>>>>
85106>>>
85106>>>            If (iArgs = 7 and sParam7  <> "") Begin
85108>>>                Send Add_Line sParam7
85109>>>            End
85109>>>>
85109>>>            Else If (iArgs > 7 and sParam7  <> "") Begin
85112>>>                Send Add_LineLn sParam7
85113>>>            End
85113>>>>
85113>>>
