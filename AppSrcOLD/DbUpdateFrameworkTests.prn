84824>>>>>Class cAboutEdit is an cRichEdit
84825>>>>>    Procedure Construct_Object
84827>>>>>        Forward Send Construct_Object
84829>>>>>
84829>>>>>        Set Size to 57 153
84830>>>>>        Set Location to 8 60
84831>>>>>
84831>>>>>        Set Read_Only_State to True
84832>>>>>        Set Skip_State to True
84833>>>>>        // Font size is calculated in "Twips", which are 1/1440 of an inch,
84833>>>>>        // or 1/20 of a printer's point.
84833>>>>>//        Set piFontSize    to (9 * 20)
84833>>>>>        Set piRightMargin to (0.1 * 1440)
84834>>>>>        Set Border_Style  to Border_None
84835>>>>>    End_Procedure
84836>>>>>
84836>>>>>    // Adds a line of text to the edit object
84836>>>>>    Procedure Add_Line String sVal
84838>>>>>        String sText
84838>>>>>        Address aAddress
84838>>>>>        Get paValue to aAddress
84839>>>>>        Move aAddress to sText
84840>>>>>        Move (sText + String(sVal)) to sVal
84841>>>>>        GetAddress of sVal to aAddress
84842>>>>>        Set paValue to aAddress
84843>>>>>    End_Procedure
84844>>>>>
84844>>>>>    // Compared to Add_Line above, this adds an extra empty line after the passed value.
84844>>>>>    // Note that we use the paValue interface,
84844>>>>>    // because the object isn't paged yet when we add the
84844>>>>>    // values and the COM edit object needs to be paged
84844>>>>>    // for the "Set Value" interface to be used.
84844>>>>>    Procedure Add_LineLn String sVal
84846>>>>>        String sText
84846>>>>>        Address aAddress
84846>>>>>        Get paValue to aAddress
84847>>>>>        Move aAddress to sText
84848>>>>>        Move (sText + String(sVal) + Character(10) + Character(13)) to sVal
84849>>>>>        GetAddress of sVal to aAddress
84850>>>>>        Set paValue to aAddress
84851>>>>>    End_Procedure
84852>>>>>
