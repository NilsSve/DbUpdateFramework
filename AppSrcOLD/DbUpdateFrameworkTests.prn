96688>>>>>        Move True               to ColumnType[i].bFixedSize
96689>>>>>        Increment i
96690>>>>>
96690>>>>>        Move ePgSQL_VARCHAR     to ColumnType[i].iType
96691>>>>>        Move "varchar"          to ColumnType[i].sType
96692>>>>>        Move DF_TEXT            to ColumnType[i].iDataFlexType
96693>>>>>        Move "DF_TEXT"          to ColumnType[i].sDataFlexType
96694>>>>>        Move "16384"            to ColumnType[i].sPrecision
96695>>>>>        Increment i
96696>>>>>
96696>>>>>        Function_Return ColumnType                              
96697>>>>>    End_Function
96698>>>>>    
96698>>>>>    // Internal usage. Use the UtilColumnTypeXXX functions instead.
96698>>>>>    Function _UtilColumnType String sDriverID Integer iDbType Integer iType String sType Boolean bIntegerInputType Returns tColumnType
96700>>>>>        Integer iValue iSize iCount iStart
96700>>>>>        tColumnType[] ColumnTypeArray   
96700>>>>>        tColumnType[] ColumnTypeArray   
96701>>>>>        tColumnType RetvalType 
96701>>>>>        tColumnType RetvalType 
96701>>>>>        String sValue
96701>>>>>        
96701>>>>>        Move "Undefined" to RetvalType.sType 
96702>>>>>        Move -1999       to RetvalType.iType
96703>>>>>        
96703>>>>>        Move 0 to iStart
96704>>>>>        Move (Uppercase(sType)) to sType            
96705>>>>>        
96705>>>>>        If (iType <= -1500) Begin
96707>>>>>            Move EN_dbTypeDataFlex to iDbType
96708>>>>>            Move DATAFLEX_ID       to sDriverID
96709>>>>>        End
96709>>>>>>
96709>>>>>
96709>>>>>        Get UtilEnumerateColumnTypes sDriverID iDbType to ColumnTypeArray
96710>>>>>        
96710>>>>>        Move (SizeOfArray(ColumnTypeArray)) to iSize 
96711>>>>>        Decrement iSize
96712>>>>>        
96712>>>>>        for iCount from iStart to iSize
96718>>>>>>
96718>>>>>            Move ColumnTypeArray[iCount].iType to iValue
96719>>>>>            Move ColumnTypeArray[iCount].sType to sValue 
96720>>>>>            If (bIntegerInputType = True) Begin
96722>>>>>                If (iValue = iType) Begin
96724>>>>>                    Move ColumnTypeArray[iCount].sType          to RetvalType.sType  
96725>>>>>                    Move iType                                  to RetvalType.iType
96726>>>>>                    Move ColumnTypeArray[iCount].sDataFlexType  to RetvalType.sDataFlexType
96727>>>>>                    Move ColumnTypeArray[iCount].iDataFlexType  to RetvalType.iDataFlexType
96728>>>>>                    Move ColumnTypeArray[iCount].sPrecision     to RetvalType.sPrecision
96729>>>>>                    Move ColumnTypeArray[iCount].bFixedSize     to RetvalType.bFixedSize
96730>>>>>                    Move iSize to iCount // We're done!
96731>>>>>                End
96731>>>>>>
96731>>>>>            End
96731>>>>>>
96731>>>>>            Else Begin
96732>>>>>                Move (Uppercase(sValue)) to sValue
96733>>>>>                If (sValue = sType) Begin
96735>>>>>                    Move sType                                  to RetvalType.sType
96736>>>>>                    Move ColumnTypeArray[iCount].iType          to RetvalType.iType 
96737>>>>>                    Move ColumnTypeArray[iCount].sDataFlexType  to RetvalType.sDataFlexType
96738>>>>>                    Move ColumnTypeArray[iCount].iDataFlexType  to RetvalType.iDataFlexType
96739>>>>>                    Move ColumnTypeArray[iCount].sPrecision     to RetvalType.sPrecision
96740>>>>>                    Move ColumnTypeArray[iCount].bFixedSize     to RetvalType.bFixedSize
96741>>>>>                    Move iSize to iCount // We're done!
96742>>>>>                End
96742>>>>>>
96742>>>>>            End
96742>>>>>>
96742>>>>>        Loop
96743>>>>>>
96743>>>>>        
96743>>>>>        Function_Return RetvalType
96744>>>>>    End_Function
96745>>>>>    
96745>>>>>    // *** Miscellaneous other functions ***
96745>>>>>    // Some of which can be used by both "Sqlxxx" and "Apixxx" functions.
96745>>>>>    //
96745>>>>>    
96745>>>>>    // Callback functionality used when e.g. calling driver functions directly.
96745>>>>>    Function Callback String sCallback_Text Integer iCallback_Type Returns Integer
96747>>>>>        Integer iRetval iPos iPerc
96747>>>>>        String sVal1 sVal2 
96747>>>>>        Number nReady nTotal 
96747>>>>>        
96747>>>>>        Send DoAdvance of ghoProgressBar           
96748>>>>>        
96748>>>>>        If (sCallback_Text contains "Copy records") Begin
96750>>>>>            Move CS_SQLCopyingData to sCallback_Text
96751>>>>>        End                                        
96751>>>>>>
96751>>>>>        If (sCallback_Text contains "Dropping index" or sCallback_Text contains "Temporary delete of all indices of table") Begin
96753>>>>>            Move (Replace("Dropping index", sCallback_Text, CS_SQLDeletingIndex)) to sCallback_Text 
96754>>>>>            Move (Replace("Temporary delete of all indices of table", sCallback_Text, CS_SQLDeletingIndex)) to sCallback_Text
96755>>>>>        End
96755>>>>>>
96755>>>>>        If (sCallback_Text contains "Creating index") Begin
96757>>>>>            Move (Replace("Creating index", sCallback_Text, CS_SQLCreatingIndex)) to sCallback_Text
96758>>>>>        End                                               
96758>>>>>>
96758>>>>>        
96758>>>>>        Case Begin
96758>>>>>            Case (iCallback_Type = DF_Message_Text) 
96760>>>>>                Set Message_Text of ghoStatusPanel to sCallback_Text  
96761>>>>>                Set Action_Text  of ghoStatusPanel to ""
96762>>>>>                Case Break
96763>>>>>            Case (iCallback_Type = DF_Message_Heading_1) 
96766>>>>>                Set Message_Text of ghoStatusPanel to sCallback_Text 
96767>>>>>                Set Action_Text  of ghoStatusPanel to ""
96768>>>>>                Case Break
96769>>>>>            Case (iCallback_Type = DF_Message_Heading_2) 
96772>>>>>                Set Message_Text of ghoStatusPanel to sCallback_Text 
96773>>>>>                Set Action_Text  of ghoStatusPanel to ""
96774>>>>>                Case Break
96775>>>>>            Case (iCallback_Type = DF_Message_Heading_3) 
96778>>>>>                Set Message_Text of ghoStatusPanel to sCallback_Text 
96779>>>>>                Set Action_Text  of ghoStatusPanel to ""
96780>>>>>                Case Break
96781>>>>>            Case (iCallback_Type = DF_Message_Heading_4) 
96784>>>>>                Set Message_Text of ghoStatusPanel to sCallback_Text 
96785>>>>>                Set Action_Text  of ghoStatusPanel to ""
96786>>>>>                Case Break
96787>>>>>            Case (iCallback_Type = DF_Message_Heading_5) 
96790>>>>>                Set Message_Text of ghoStatusPanel to sCallback_Text 
96791>>>>>                Set Action_Text  of ghoStatusPanel to ""
96792>>>>>                Case Break
96793>>>>>            Case (iCallback_Type = DF_Message_Warning) 
96796>>>>>                Send None
96797>>>>>                Case Break
96798>>>>>            Case (iCallback_Type = DF_Message_Progress_Title) 
96801>>>>>                Set Message_Text of ghoStatusPanel to sCallback_Text 
96802>>>>>                Set Action_Text  of ghoStatusPanel to ""
96803>>>>>                Case Break
96804>>>>>            Case (iCallback_Type = DF_Message_Progress_Value) 
96807>>>>>                //*** Interpret numbers
96807>>>>>                Move (Left(sCallback_Text, (Pos(",", sCallback_Text) - 1)))                       to nReady
96808>>>>>                Move (Right(sCallback_Text, (Length(sCallback_Text) - Pos(",", sCallback_Text)))) to nTotal
96809>>>>>                Move ((nReady / nTotal) * 100)                                                    to iPerc
96810>>>>>                Set Action_Text of ghoStatusPanel to (String(iPerc) * String("% (Total:") * String(nTotal) + ")")
96811>>>>>                Case Break
96812>>>>>            Case Else
96812>>>>>                Set Message_Text to ""
96813>>>>>                Set Action_Text  to ""    
96814>>>>>        Case End
96814>>>>>
96814>>>>>        Send ProcessEvents of ghoStatusPanel
96815>>>>>        Function_Return False
96816>>>>>    End_Function
96817>>>>>    
96817>>>>>    Function NextFreeFilelistSlot Returns Handle
96819>>>>>        Handle hTable
96819>>>>>        
96819>>>>>        Move 0 to hTable              
96820>>>>>        Get_Attribute DF_FILE_NEXT_EMPTY to hTable
96823>>>>>        
96823>>>>>        Function_Return hTable
96824>>>>>    End_Function
