100651>
100651>    // All of the code below are methods and augmentations which makes this work well as a test program. This:
100651>    // 1. Supports an auto-activate feature where all dialogs in the view and report menu are activated upon startup
100651>    // 2. forces the panel to resize if it is not large enough to accomodate all of the views.
100651>    // This code was placed directly in the testproject template and, therefore, directly in the .src file so
100651>    // a developer can easily modify this to fit their own needs. It is not expected that these techniques would
100651>    // get used in actual deployed projects.
100651>
100651>    // special test component code to activate all views and reports. For testing we assume
100651>    // that you want to see everything.
100651>
100651>    Procedure AutoActivate
100654>        Handle hoMenu
100654>
100654>        // this activates all views from the view menu
100654>        Get phoViewMenu to hoMenu
100655>        If hoMenu Begin
100657>           Broadcast Send Execute of hoMenu
100659>        End
100659>
100659>        // this activates all views from the report view menu
100659>        Get phoReportMenu to hoMenu
100660>        If hoMenu Begin
100662>           Broadcast Send Execute of hoMenu
100664>        End
100664>    End_Procedure
100665>
100665>    // This checks all views within the client area to make sure that they fit within
100665>    // the client area. If not we will adjust the main panel so everything fits. This
100665>    // can only be done after the objects are all activated.
100665>
100665>    Procedure MakeGoodPanelSize
100668>        Handle hoView hoClient
100668>        Integer iSize iLoc iHeight iWidth iOldHeight iOldWidth 
100668>        Integer iLeft iTop iRight iBottom
100668>        Get Client_Id to hoClient
100669>        If hoClient Begin
100671>            
100671>            // if not using commandbars or for some reason they are not created yet we
100671>            // will use whatever the client size is
100671>            If (ghoCommandBars=0 or not(IsComObjectCreated(ghoCommandBars))) Begin
100673>                Get GuiSize of hoClient to iSize  // starting size of client area
100674>                Move (Hi(iSize)) to iOldHeight
100675>                Move (Low(iSize)) to iOldWidth
100676>            End
100676>            Else Begin
100677>               // if commandbars are created, the actual size of the client area must be obtained
100677>               // from the commandbar 
100677>               Send ComGetClientRect of ghoCommandBars (&iLeft) (&iTop) (&iRight) (&iBottom)
100678>               Move (iRight-iLeft) to iOldWidth
100679>               Move (iBottom-iTop) to iOldHeight
100680>            End
100680>            
100680>            Move iOldHeight to iHeight
100681>            Move iOldWidth to iWidth
100682>            
100682>            // for each mdi client see if it fits, keep track of largest size needed
100682>            Get Next_Mdi_Dialog of hoClient True to hoView // find first
100683>            While (hoView)
100687>                Get GuiWindowSize of hoView to iSize    // size of view
100688>                Get GuiLocation of hoView to iLoc // location of view
100689>                Move (hi(iSize)+hi(iLoc)+10 max iHeight)  to iHeight // max height needed (+10 pixels is small border)
100690>                Move (low(iSize)+low(iLoc)+10 max iWidth) to iWidth  // max width needed
100691>                Get Next_Mdi_Dialog of hoClient False to hoView // find next view
100692>            Loop
100693>            Move (iHeight-iOldHeight  max 0) to iHeight // get delta compared to old size. We want delta
100694>            Move (iWidth-iOldWidth max 0) to iWidth     // only if the new size is bigger (i.e., > 0)
100695>            If  (iHeight>0 or iWidth>0) Begin
100697>                Get GuiSize to iSize // now add the delta to the panel size
100698>                Set GuiSize to (hi(iSize)+iHeight) (low(iSize)+iWidth)
100699>                Send Adjust_Logicals // adjust from gui to regular size
100700>            End
100700>        End
100700>    End_Procedure
100701>    
100701>    // Note that we have overriden the cHtmlHelp "GetHelpFile" function
100701>    // in the oHtmlHelp object, so we need to explitetly send the message
100701>    // to that object.
100701>    Procedure ShowProgramHelp
100704>        Send DoDisplayKeyword of oHtmlHelp "cDbUpdateFunctionLibrary"
100705>    End_Procedure
100706>
100706>    On_Key Key_F1 Send ShowProgramHelp
