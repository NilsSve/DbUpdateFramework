83018>>>>>>>/// @Name        DF_FILE_RECNUM_TABLE
83018>>>>>>>/// @Description Dataflex's embedded database, by default, uses a Recnum column
83018>>>>>>>/// as the unique identifier for a table instead of a primary key. A table can
83018>>>>>>>/// easily be changed to use another column though and this attribute gets or
83018>>>>>>>/// sets whether the Recnum is being used for a table. Getting the value of this
83018>>>>>>>/// attribute can be done at any time for any driver. The setting of this attribute,
83018>>>>>>>/// however, can only be done in certain situations. Only if an alternative primary
83018>>>>>>>/// key is set up already can this attribute be set to false and only during a
83018>>>>>>>/// Structure_Start. Also, the attribute can only be turned off (set to false),
83018>>>>>>>/// it can not be turned back on (set to True).
83018>>>>>>>///
83018>>>>>>>/// Note: In Postgres, this attribute is a ReadOnly attribute and can not be set.
83018>>>>>>>///
83018>>>>>>>/// @Assumptions
83018>>>>>>>/// @Status      Public (PGFlex ReadOnly)
83018>>>>>>>/// @Drivers     All
83018>>>>>>>/// @VersionNote Last Revised: 2013-08-12 by Aaron Gulack
83018>>>>>>>/// @See                 DF_FILE_RECNUM_NAME DF_FILE_PRIMARY_INDEX
83018>>>>>>>/// @INTOPT
83018>>>>>>>///
83018>>>>>>>/// @Syntax Get_Attribute DF_FILE_RECNUM_TABLE of {FileNumber} to {variable}
83018>>>>>>>/// @Syntax Set_Attribute DF_FILE_RECNUM_TABLE of {FileNumber} to {variable}
83018>>>>>>>/// @Param  FileNumber            Number of the file
83018>>>>>>>/// @Param  variable              Boolean variable indicating if recnum is used
83018>>>>>>>/// @Example
83018>>>>>>>/// Open Customer
83018>>>>>>>///
83018>>>>>>>/// Boolean bRecnum
83018>>>>>>>/// Handle hFile
83018>>>>>>>///
83018>>>>>>>/// Move Customer.File_Number to hFile
83018>>>>>>>///
83018>>>>>>>/// Structure_Start hFile
83018>>>>>>>///     Set_Attribute DF_FILE_RECNUM_TABLE of Customer.File_Number to False
83018>>>>>>>///     Get_Attribute DF_FILE_RECNUM_TABLE of Customer.File_Number to bRecnum
83018>>>>>>>/// Structure_End hFile
83018>>>>>>>Define DF_FILE_RECNUM_TABLE                         For 1401
83018>>>>>>>
83018>>>>>>>//=============================================================================
83018>>>>>>>/// @Name        DF_FILE_PRIMARY_INDEX
83018>>>>>>>/// @Description This attribute gets or sets the index which is used as the
83018>>>>>>>/// primary key for a table. The variable used for this attribute is an integer
83018>>>>>>>/// containing the numbered index used. Getting the value of this attribute can
83018>>>>>>>/// be done at any time, whereas setting can only be done at table creation or
83018>>>>>>>/// during a Structure_Start. If a RECNUM is used as the unique identifier then
83018>>>>>>>/// 0 is returned.
83018>>>>>>>///
83018>>>>>>>/// Note: In Postgres this attribute is ReadOnly, so it can only be used to get
83018>>>>>>>/// the index used as the primary key.
83018>>>>>>>///
83018>>>>>>>/// @Assumptions
83018>>>>>>>/// @Status      Public (PGFlex ReadOnly)
83018>>>>>>>/// @Drivers     All
83018>>>>>>>/// @VersionNote Last Revised: 2013-08-12 by Aaron Gulack
83018>>>>>>>/// @See                 DF_FILE_RECNUM_NAME
83018>>>>>>>/// @INTOPT
83018>>>>>>>///
83018>>>>>>>/// @Syntax Get_Attribute DF_FILE_PRIMARY_INDEX of {FileNumber} to {variable}
83018>>>>>>>/// @Syntax Set_Attribute DF_FILE_PRIMARY_INDEX of {FileNumber} to {variable}
83018>>>>>>>/// @Param  FileNumber            Number of the file
83018>>>>>>>/// @Param  variable              Boolean variable indicating if a primary key is used
83018>>>>>>>/// @Example
83018>>>>>>>/// Open Customer
83018>>>>>>>///
83018>>>>>>>/// Boolean bPrimary
83018>>>>>>>/// Handle hFile
83018>>>>>>>///
83018>>>>>>>/// Move Customer.File_Number to hFile
83018>>>>>>>///
83018>>>>>>>/// Structure_Start hFile
83018>>>>>>>///     Set_Attribute DF_FILE_PRIMARY_INDEX of Customer.File_Number to False
83018>>>>>>>///     Get_Attribute DF_FILE_PRIMARY_INDEX of Customer.File_Number to bPrimary
83018>>>>>>>/// Structure_End hFile
83018>>>>>>>Define DF_FILE_PRIMARY_INDEX                        For 1402
83018>>>>>>>
