93165>>>>>    Procedure _SqlColumnInfo Handle hoStmt
93167>>>>>        Integer i iCols iItem
93167>>>>>        tSqlColumnNew[] aQueryColumns
93167>>>>>        tSqlColumnNew[] aQueryColumns
93168>>>>>
93168>>>>>        Get SqlStmtAttribute of hoStmt SqlSTMTATTRIB_COLUMNCOUNT to iCols
93169>>>>>        For i from 1 to iCols
93175>>>>>>
93175>>>>>            Move (SizeOfArray(aQueryColumns)) to iItem
93176>>>>>            Get SqlColAttribute of hoStmt i SqlCOLATTRIB_BASECOLUMNNAME to aQueryColumns[iItem].sBaseColumnName
93177>>>>>            Get SqlColAttribute of hoStmt i SqlCOLATTRIB_BASETABLENAME  to aQueryColumns[iItem].sBaseTableName
93178>>>>>            Get SqlColAttribute of hoStmt i SqlCOLATTRIB_LABEL          to aQueryColumns[iItem].sLabel
93179>>>>>            Get SqlColAttribute of hoStmt i SqlCOLATTRIB_SQLTYPE        to aQueryColumns[iItem].iSqlType
93180>>>>>            Get SqlColAttribute of hoStmt i SqlCOLATTRIB_DFTYPE         to aQueryColumns[iItem].iDFType
93181>>>>>            Get SqlColAttribute of hoStmt i SqlCOLATTRIB_SIZE           to aQueryColumns[iItem].iSize
93182>>>>>            Get SqlColAttribute of hoStmt i SqlCOLATTRIB_PRECISION      to aQueryColumns[iItem].iPrecision
93183>>>>>        Loop
93184>>>>>>
93184>>>>>        Set piColumns to iCols
93185>>>>>        Set paQueryColumns to aQueryColumns
93186>>>>>    End_Procedure
