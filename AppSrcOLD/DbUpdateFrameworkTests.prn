80248>>>
80248>>>Class cSkinComboBoxCJMenuItem is a cCJMenuItem
80249>>>    
80249>>>    Procedure Construct_Object
80251>>>        Forward Send Construct_Object
80253>>>        
80253>>>        Set peControlType to xtpControlComboBox
80254>>>        
80254>>>        Property tSkinInformation[] pSkins
80255>>>
80255>>>    End_Procedure
80256>>>
80256>>>    Procedure End_Construct_Object
80258>>>        Forward Send End_Construct_Object 
80260>>>    End_Procedure
80261>>>
80261>>>    // Custom array sort for the tSkinInformation struct array.
80261>>>    // Used by LoadSkins message to sort the skin array alphabetically after it has been loaded.
80261>>>    // Why?
80261>>>    // First of all, structs can't be used with the standard SortArray function, that is why we need to
80261>>>    // create a custom sort algorithm.
80261>>>    // Secondly the list of skins would else be sorted in the alphabetical order by the file names.
80261>>>    // However, it is not always the case that the skin description (sName) is the same as the file name.
80261>>>    // If it isn't (which is almost always the case if you have many skin files) the list will look
80261>>>    // randomly ordered. This custom sort method will take care of that.
80261>>>    Function SkinSort tSkinInformation sDescription tSkinInformation sSearchDescription Returns Integer
80263>>>        Integer iRetVal
80263>>>        If ((sDescription.sName * sDescription.sSkinIni) > (sSearchDescription.sName * sSearchDescription.sSkinIni)) Function_Return (GT)
80266>>>        If ((sDescription.sName * sDescription.sSkinIni) < (sSearchDescription.sName * sSearchDescription.sSkinIni)) Function_Return (LT)
80269>>>        Function_Return (EQ)
80270>>>    End_Function  
80271>>>    
80271>>>    Procedure OnCreateControl Handle hoObj
80273>>>        Forward Send OnCreateControl hoObj
80275>>>        
80275>>>        Set ComDropDownWidth of hoObj to 150
80276>>>        Set ComWidth         of hoObj to 150
80277>>>        Send LoadSkins
80278>>>        Send FillComboList hoObj
80279>>>    End_Procedure
80280>>>
80280>>>    // Load all skins. We will only look for skins in expected
80280>>>    // directory which is the Programs folder.
80280>>>    // Important: When loading skins they will be sorted alphabetically. (See Skinsort function above).
80280>>>    // This is not the case with the 'standard' VDF behaviour.
80280>>>    Procedure LoadSkins   
80282>>>        Integer iCount iItems iRow iSize  
80282>>>        Boolean bFound
80282>>>        String sFile sIni sSkin
80282>>>        tSkinInformation[] SkinsArray SkinsArrayNoLarge
80282>>>        tSkinInformation[] SkinsArray SkinsArrayNoLarge
80284>>>        tSkinInformation NoneRow
80284>>>        tSkinInformation NoneRow
80284>>>        
80284>>>        If (ghoSkinFramework > 0) Begin
80286>>>            Get EnumerateSkins of ghoSkinFramework "" True   to SkinsArray
80287>>>
80287>>>            Move (SortArray(SkinsArray, Self, get_SkinSort)) to SkinsArray
80288>>>            Move CS_NoSkinShort to NoneRow.sName
80289>>>            Move CS_NoSkinLong  to NoneRow.sSkinfile
80290>>>            Move CS_NoSkinLong  to NoneRow.sSkinIni
80291>>>            Move (InsertInArray(SkinsArray, 0, NoneRow))     to SkinsArray
80292>>>                    
80292>>>            // Get the currently loaded skin.
80292>>>            Get psSkinFile of ghoSkinFramework to sFile
80293>>>            Get psSkinIni  of ghoSkinFramework to sIni
80294>>>
80294>>>            // Remove all Extra Large and Large skins from the array.
80294>>>            Move (SizeOfArray(SkinsArray)) to iItems
80295>>>            Decrement iItems
80296>>>            For iCount from 0 to iItems
80302>>>>
80302>>>                Move SkinsArray[iCount].sSkinIni to sSkin
80303>>>                Move (Uppercase(sSkin) contains " LARGE") to bFound
80304>>>                If (bFound = False) Begin    
80306>>>                    Move (SizeOfArray(SkinsArrayNoLarge)) to iSize
80307>>>                    Move SkinsArray[iCount].sName         to SkinsArrayNoLarge[iSize].sName
80308>>>                    Move SkinsArray[iCount].sSkinfile     to SkinsArrayNoLarge[iSize].sSkinfile
80309>>>                    Move SkinsArray[iCount].sSkinIni      to SkinsArrayNoLarge[iSize].sSkinIni
80310>>>                End
80310>>>>
80310>>>            Loop
80311>>>>
80311>>>            Set pSkins to SkinsArrayNoLarge
80312>>>        End
80312>>>>
80312>>>    End_Procedure 
80313>>>    
80313>>>    // Fills the CodeJock combobox with all skins from the current Programs folder.
80313>>>    Procedure FillComboList Handle hoCombo
80315>>>        Integer iCount iItems iCurrent iTxtEntentSize
80315>>>        String  sFile sIni sCurrSkin
80315>>>        String  sSkin sSkinText
80315>>>        tSkinInformation[] SkinsArray
80315>>>        tSkinInformation[] SkinsArray
80316>>>        Integer iSize
80316>>>
80316>>>        If (ghoSkinFramework < 1) Procedure_Return
80319>>>
80319>>>        // Get the currently loaded skin.
80319>>>        Get psSkinFile of ghoSkinFramework to sFile
80320>>>        Get psSkinIni  of ghoSkinFramework to sIni
80321>>>        Get pSkins to SkinsArray
80322>>>        Move (SizeOfArray(SkinsArray)) to iItems
80323>>>        Decrement iItems
80324>>>        Send ComClear of hoCombo
80325>>>        
80325>>>        For iCount from 0 to iItems    
80331>>>>
80331>>>            Move SkinsArray[iCount].sSkinIni  to sSkin  
80332>>>            Move (Replace(".ini", sSkin, "")) to sSkin 
80333>>>            Move (SkinsArray[iCount].sName * "-" * sSkin) to sSkinText
80334>>>            Send ComAddItem of hoCombo sSkinText (iCount +1)
80335>>>            Get Text_Extent sSkinText to iSize
80336>>>            If (iSize > iTxtEntentSize) Begin
80338>>>                Move iSize to iTxtEntentSize
80339>>>            End
80339>>>>
80339>>>            Move (SkinsArray[iCount].sSkinFile * "-" * SkinsArray[iCount].sSkinIni) to sCurrSkin 
80340>>>            If (sCurrSkin = (sFile * "-" * sIni)) Begin
80342>>>                Move iCount to iCurrent
80343>>>            End
80343>>>>
80343>>>        Loop
80344>>>>
80344>>>        
80344>>>        Move (Low(iTxtEntentSize) + 30)  to iSize  
80345>>>        Set ComDropDownWidth of hoCombo  to iSize
80346>>>        Set ComWidth         of hoCombo  to iSize
80347>>>        Set ComListIndex     of hoCombo  to (iCurrent +1)
80348>>>    End_Procedure
80349>>>
80349>>>    // Event for when an item is selected from the comboform
80349>>>    Procedure OnExecute Variant vCommandBarControl
80351>>>        Handle  hoCombo
80351>>>        Integer iSelection
80351>>>        String  sSkinFile sSkinIni
80351>>>        tSkinInformation[] SkinsArray
80351>>>        tSkinInformation[] SkinsArray
80352>>>
80352>>>        // Create and bind proxy control
80352>>>        Get CreateProxyControl vCommandBarControl to hoCombo
80353>>>        // Get the current selection
80353>>>        Get ComListIndex of hoCombo to iSelection
80354>>>        Decrement iSelection  
80355>>>        Get pSkins to SkinsArray
80356>>>        Move SkinsArray[iSelection].sSkinfile to sSkinFile
80357>>>        Move SkinsArray[iSelection].sSkinIni  to sSkinIni
80358>>>        
80358>>>        Send DoChangeSkin sSkinFile sSkinIni
80359>>>
80359>>>        // Dispose of the proxy control
80359>>>        Send Destroy of hoCombo
80360>>>    End_Procedure
80361>>>    
80361>>>    // Send this message to change the current skin.
80361>>>    Procedure DoChangeSkin String sSkinFile String sSkinIni 
80363>>>        Handle hoClient
80363>>>        
80363>>>        Set psSkinFile of ghoSkinFramework to sSkinFile
80364>>>        Set psSkinIni  of ghoSkinFramework to sSkinIni
80365>>>        Send ApplySkin of ghoSkinFramework
80366>>>
80366>>>        // Note: The following line is essential for the resizing logic
80366>>>        // to function properly when changing a skin and a view is maximized.                                  
80366>>>        Move (Client_Id(phoMainPanel(ghoApplication))) to hoClient
80367>>>        Set Size of hoClient to (Hi(Size(hoClient))) (Low(Size(hoClient) +2))
80368>>>        Set Size of hoClient to (Hi(Size(hoClient))) (Low(Size(hoClient) -2))
80369>>>    End_Procedure
80370>>>
80370>>>    // Returns: DPI setting as an integer.
80370>>>    //  Normal DPI setting: iDPI=96  is "Normal setting" 100%
80370>>>    //                      iDPI=120 is "Medium setting" 125%
80370>>>    //                      iDPI= 144 is "Large setting" 150%
80370>>>    Function GetCurrentDPI Returns Integer
80372>>>        Handle hDC
80372>>>        Integer iPixelsX
80372>>>        Move (GetDC(0)) to hDC
80373>>>        Move (GetDeviceCaps(hDC, LOGPIXELSX)) to iPixelsX
80374>>>        Move (ReleaseDC(0, hDC)) to hDC
80375>>>        Function_Return iPixelsX
80376>>>    End_Function
80377>>>
80377>>>End_Class             
