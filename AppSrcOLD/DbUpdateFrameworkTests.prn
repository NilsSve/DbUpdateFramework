84574>>>>>    
84574>>>>>    Function IsDAWSQLDriver String sDriverID Returns Boolean
84576>>>>>        Boolean bOK
84576>>>>>        Move (sDriverID = MSSQLDRV_ID or sDriverID = DB2_DRV_ID or sDriverID = ODBC_DRV_ID) to bOK
84577>>>>>        Function_Return bOK
84578>>>>>    End_Function
84579>>>>>
84579>>>>>    Function IsMertechDriver String sDriverID Returns Boolean
84581>>>>>        Boolean bOK   
84581>>>>>        Move (sDriverID = SQLFLEX or sDriverID = ORAFLEX or sDriverID = MDSPgSQL or sDriverID = MySQLFlex) to bOK
84582>>>>>        Function_Return bOK
84583>>>>>    End_Function
84584>>>>>
84584>>>>>    //***
84584>>>>>    //*** BW
84584>>>>>    //*** Procedure: Show_Drivers
84584>>>>>    //*** Purpose  : Show loaded database drivers
84584>>>>>    //***
84584>>>>>
84584>>>>>    Procedure Show_Drivers
84586>>>>>        String sDriverID sVersion sClient sMertechSQLFlexVersion sValue
84586>>>>>        Integer iNumberOfDrivers iDriver iClient iUsersMax iSerialNo iNumServers iCount
84586>>>>>        Handle hoCLIHandler hoBtrvHandler
84586>>>>>        Boolean bStudioLicense bIsDAWDriver bIsMertechDriver
84586>>>>>
84586>>>>>        Move False to bStudioLicense
84587>>>>>
84587>>>>>        Get Create U_cCLIHandler      to hoCLIHandler
84588>>>>>        Get Create U_cDFBtrDrvHandler to hoBtrvHandler 
84589>>>>>
84589>>>>>        // For testing purposes:        
84589>>>>>//        Send Ignore_Error of Error_Object_Id DFERR_CANT_LOAD_DLL
84589>>>>>//        Load_Driver MSSQLDRV_ID
84589>>>>>//        Load_Driver ODBC_DRV_ID
84589>>>>>//        Load_Driver DB2_DRV_ID
84589>>>>>//        Send Trap_Error of Error_Object_Id DFERR_CANT_LOAD_DLL
84589>>>>>//
84589>>>>>//        #IFDEF DF_Use_Mertech_Drivers  
84589>>>>>//            Send Ignore_Error of Error_Object_Id DFERR_CANT_LOAD_DLL
84589>>>>>//            Load_Driver SQLFLEX 
84589>>>>>//            Load_Driver MDSPgSQL
84589>>>>>//            Load_Driver MDSMySQL
84589>>>>>//            Load_Driver ORAFLEX
84589>>>>>//            Send Trap_Error of Error_Object_Id DFERR_CANT_LOAD_DLL
84589>>>>>//        #ENDIF
84589>>>>>        Move False to Err
84590>>>>>        
84590>>>>>        // Loop through all loaded drivers.
84590>>>>>        Get_Attribute DF_NUMBER_DRIVERS to iNumberOfDrivers
84593>>>>>        If (iNumberOfDrivers > 1) Begin
84595>>>>>            Send AppendTextLn ""
84596>>>>>        End
84596>>>>>>
84596>>>>>        For iDriver from 1 to iNumberOfDrivers           
84602>>>>>>
84602>>>>>            // For some weird reason it can happen that - when using Mertech drivers - that the driver index
84602>>>>>            // was increased in the CLI array, but it has no value. In that case a "Bad parameter..." error
84602>>>>>            // would be thrown, so we safeguard from that here.
84602>>>>>            Send Ignore_Error of Error_Object_Id DFERR_BAD_PARAMETER
84603>>>>>            Get_Attribute DF_DRIVER_NAME of iDriver to sDriverID
84606>>>>>            Send Trap_Error of Error_Object_Id DFERR_BAD_PARAMETER
84607>>>>>            Get IsDAWSQLDriver sDriverID to bIsDAWDriver
84608>>>>>            Get IsMertechDriver sDriverID to bIsMertechDriver
84609>>>>>
84609>>>>>            If (sDriverID = DFBTRDRV_ID or bIsDAWDriver = True or bIsMertechDriver = True) Begin
84611>>>>>
84611>>>>>                // Pervasive/Btrieve database
84611>>>>>                If (sDriverID = DFBTRDRV_ID) Begin
84613>>>>>                    Get CKRevision of hoBtrvHandler to sVersion
84614>>>>>                    Get PSQLLocalEngineVersionInfo of hoBtrvHandler 0 to sClient
84615>>>>>                    If (sClient <> "0.0.0") Begin
84617>>>>>                        Send AppendTextLn (SFormat (C_$Pervasive_Local_Engine_Version, sClient))
84618>>>>>                    End
84618>>>>>>
84618>>>>>                    Get PSQLServerEngineVersionInfo of hoBtrvHandler 0 to sClient
84619>>>>>                    If (sClient <> "0.0.0") Begin
84621>>>>>                        Send AppendTextLn (SFormat (C_$Pervasive_Server_Engine_Version, sClient))
84622>>>>>                    End
84622>>>>>>
84622>>>>>                End
84622>>>>>>
84622>>>>>
84622>>>>>                Else Begin
84623>>>>>                    Set psDriverID of hoCLIHandler to sDriverID 
84624>>>>>                    Move 0 to iNumServers
84625>>>>>                    If (sDriverID <> DATAFLEX_ID) Begin
84627>>>>>                        Get_Attribute DF_DRIVER_NUMBER_SERVERS of iDriver to iNumServers
84630>>>>>                    End
84630>>>>>>
84630>>>>>                    
84630>>>>>                    If (bIsDAWDriver = True) Begin
84632>>>>>                        If (sDriverID = MSSQLDRV_ID) Begin
84634>>>>>                            // This info is only available for the MS SQL driver:
84634>>>>>                            Get_Attribute DF_DRIVER_SQLSERVER_CLIENT_VERSION of iDriver to iClient
84637>>>>>                            If (iClient = 13) Move C_$SQLSERVER2016DRVRSTR              to sClient
84640>>>>>                            If (iClient = 12) Move C_$SQLSERVER2014DRVRSTR              to sClient
84643>>>>>                            If (iClient = 11) Move C_$SQL_Server_Native_Client_11_0     to sClient
84646>>>>>                            If (iClient = 10) Move C_$SQL_Server_Native_Client_10_0     to sClient
84649>>>>>                            If (iClient = 9)  Move C_$SQL_Native_Client                 to sClient
84652>>>>>                            If (iClient = 8)  Move C_$SQL_Server_SQL_Server_2000_client to sClient
84655>>>>>                            If (sClient <> "") Begin
84657>>>>>                                Move ("    " + sClient) to sClient
84658>>>>>                            End
84658>>>>>>
84658>>>>>                        End
84658>>>>>>
84658>>>>>                    
84658>>>>>                        Get CKRevision of hoCLIHandler to sVersion 
84659>>>>>                    End
84659>>>>>>
84659>>>>>                    
84659>>>>>                    If (bIsMertechDriver = True) Begin
84661>>>>>                        GET_DRIVER_REVISION to sVersion
84674>>>>>>
84674>>>>>                    End
84674>>>>>>
84674>>>>>                    
84674>>>>>                    // If the serialnumber is = 0, it means that the
84674>>>>>                    // Studio licens is in use and there is no
84674>>>>>                    // number of max users defined because the driver is
84674>>>>>                    // relying on the info from the VDF license.
84674>>>>>                    If (bStudioLicense = False) Begin
84676>>>>>                        Get SerialNumber of hoCLIHandler to iSerialNo
84677>>>>>                        Move (iSerialNo = 0) to bStudioLicense
84678>>>>>                    End
84678>>>>>>
84678>>>>>                End
84678>>>>>>
84678>>>>>                Send AppendTextLn (SFormat (C_$DatabaseDriver, (sDriverID * "-" * (C_$Version + ": " + sVersion))))
84679>>>>>                If (iNumServers <> 0) Begin
84681>>>>>                    For iCount from 1 to iNumServers
84687>>>>>>
84687>>>>>                        Get_Attribute DF_DRIVER_SERVER_NAME of iDriver iCount to sValue 
84690>>>>>                        Send AppendTextLn ("    " + "Server/DSN:" * sValue)
84691>>>>>                    Loop
84692>>>>>>
84692>>>>>                End
84692>>>>>>
84692>>>>>                If (sClient <> "" and sDriverID = MSSQLDRV_ID) Begin
84694>>>>>                    Send AppendTextLn sClient
84695>>>>>                End  
84695>>>>>>
84695>>>>>            End
84695>>>>>>
84695>>>>>        Loop
84696>>>>>>
84696>>>>>
84696>>>>>        Send AppendTextLn ""
84697>>>>>        If (bStudioLicense = False) Begin
84699>>>>>            Get MaxUsers of hoCLIHandler to iUsersMax 
84700>>>>>            Send AppendTextLn (SFormat (C_$Max_DbDriver_Licensed_User_Count, iUsersMax))
84701>>>>>        End
84701>>>>>>
84701>>>>>        Else Begin
84702>>>>>            Send AppendTextLn C_$VDF_Studio_License_Text
84703>>>>>        End
84703>>>>>>
84703>>>>>        Send Destroy of hoCLIHandler
84704>>>>>        Send Destroy of hoBtrvHandler
84705>>>>>    End_Procedure
84706>>>>>
84706>>>>>    Procedure Show_HelpFile
84708>>>>>        String sHelpFile
84708>>>>>        Integer eHelpType
84708>>>>>
84708>>>>>        If (ghoApplication <> 0) Begin
84710>>>>>            Get peHelpType Of ghoApplication To eHelpType
84711>>>>>            If (eHelpType = htHtmlHelp and ghoHtmlHelp) Begin
84713>>>>>                Get GetHelpFile Of ghoHtmlHelp To sHelpFile
84714>>>>>            End
84714>>>>>>
84714>>>>>            Else If (eHelpType = htWinHelp and Help_object_id) Begin
84717>>>>>                Get Help_filename Of Help_object_id To sHelpFile
84718>>>>>            End
84718>>>>>>
84718>>>>>            Else Begin
84719>>>>>                Move C_$ThereIsNoHelpfileDefined To sHelpFile
84720>>>>>            End
84720>>>>>>
84720>>>>>
84720>>>>>            Send AppendTextLn (SFormat (C_$HelpFile, sHelpFile))
84721>>>>>        End
84721>>>>>>
84721>>>>>    End_Procedure
84722>>>>>
84722>>>>>    Procedure Show_EnterAsTab
84724>>>>>        Boolean bEnterKeyAsTabKey
84724>>>>>        String sText
84724>>>>>
84724>>>>>        If (ghoApplication <> 0) Begin
84726>>>>>            Get pbEnterKeyAsTabKey Of ghoApplication To bEnterKeyAsTabKey
84727>>>>>            If (bEnterKeyAsTabKey) Begin
84729>>>>>                Move "True" To sText
84730>>>>>            End
84730>>>>>>
84730>>>>>            Else Begin
84731>>>>>                Move "False" To sText
84732>>>>>            End
84732>>>>>>
84732>>>>>            Send AppendTextLn (SFormat (C_$EnterKeyNavForward, sText))
84733>>>>>        End
84733>>>>>>
84733>>>>>    End_Procedure
