86131>>>>>>>>>>>>>Define TIME_NOMIHUTESORSECONDS  For |CI$0000000l  //  do not use minutes or seconds
86131>>>>>>>>>>>>>Define TIME_NOSECONDS           For |CI$00000002  //  do not use seconds
86131>>>>>>>>>>>>>Define TIME_NOTIMEMARKER        For |CI$00000004  //  do not use time marker
86131>>>>>>>>>>>>>Define TIME_FORCE24HOURFORMAT   For |CI$00000008  //  always use 24 hour format
86131>>>>>>>>>>>>>
