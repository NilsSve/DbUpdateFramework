89450>>>>>>>>>    // The normal connection string looks something like this;
89450>>>>>>>>>    // "SERVER=.\SQLEXPRESS; DATABASE=OrderEntry; TRUSTED_CONNECTION=Yes; ,0"
89450>>>>>>>>>    // ...but the full connection string looks like this;
89450>>>>>>>>>    // "DFConnectionId OrderEntry, SERVER=.\SQLEXPRESS; DATABASE=OrderEntry; TRUSTED_CONNECTION=Yes; ,0"
89450>>>>>>>>>//    Function SQLIniFileAddConnection String sFullConnectionString Returns Boolean
89450>>>>>>>>>//        String sSection
89450>>>>>>>>>//        Integer iCount
89450>>>>>>>>>//        
89450>>>>>>>>>//        Move False to Err
89450>>>>>>>>>//        Get psIniSectionName to sSection
89450>>>>>>>>>//        Get SQLIniFileNumberOfConnections to iCount
89450>>>>>>>>>//        Increment iCount
89450>>>>>>>>>//        Set IniFileValue sSection (CS_SQLIniSectionName + String(iCount)) to sFullConnectionString
89450>>>>>>>>>//        
89450>>>>>>>>>//        Function_Return (Err = False)
89450>>>>>>>>>//    End_Function
