90031>>>>>>>        Function_Return SQLConnection.sConnectionID
90032>>>>>>>    End_Procedure
90033>>>>>>>    
90033>>>>>>>    // Note: If the psDriverID + other connection properties are to be changed,
90033>>>>>>>    //       the psDriverID *must* be the first property that is changed!
90033>>>>>>>    //       Otherwise errors might be raised by the driver when e.g. the format
90033>>>>>>>    //       for a connection string has the wrong format for that driver.
90033>>>>>>>    Procedure Set psDriverID String sValue
90035>>>>>>>        tSQLConnection SQLConnection 
90035>>>>>>>        tSQLConnection SQLConnection 
90035>>>>>>>        Get pSQLConnection to SQLConnection
90036>>>>>>>        Move sValue        to SQLConnection.sDriverID 
90037>>>>>>>        Set pSQLConnection to SQLConnection
90038>>>>>>>        If (sValue <> DATAFLEX_ID) Begin
90040>>>>>>>            Get ConstructConnectionString SQLConnection.sDriverID SQLConnection.sServer SQLConnection.sDatabase SQLConnection.bTrusted SQLConnection.sUserID SQLConnection.sPassword to SQLConnection.sConnectionString
90041>>>>>>>        End
90041>>>>>>>>
90041>>>>>>>    End_Procedure
