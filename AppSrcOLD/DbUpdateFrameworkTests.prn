95389>>>>>    
95389>>>>>    // Returns True if the passed hTable (filelist slot number) is an Alias table.
95389>>>>>    // An Alias file/table is a filelist number that share the same Physical filename
95389>>>>>    // but which Logical name is different.
95389>>>>>    // Note: If the table cannot be opened; the table is not considered to be an Alias.
95389>>>>>    Function UtilTableIsAlias Handle hTable Returns Boolean
95391>>>>>        String sPhysicalName sPhysicalNameCompare     
95391>>>>>        Boolean bOpened bOK
95391>>>>>        
95391>>>>>        Open hTable
95393>>>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpened
95396>>>>>        If (bOpened = False) Begin
95398>>>>>            Function_Return False
95399>>>>>        End                      
95399>>>>>>
95399>>>>>        
95399>>>>>        Get_Attribute DF_FILE_PHYSICAL_NAME of hTable to sPhysicalName 
95402>>>>>        Get _TableNameOnly sPhysicalName to sPhysicalName
95403>>>>>        Close hTable
95404>>>>>        
95404>>>>>        Move 0 to hTable
95405>>>>>        Repeat
95405>>>>>>
95405>>>>>            Get_Attribute DF_FILE_NEXT_USED of hTable to hTable
95408>>>>>            If (hTable > 0) Begin         
95410>>>>>                Open hTable
95412>>>>>                Get_Attribute DF_FILE_OPENED of hTable to bOpened
95415>>>>>                If (bOpened = True) Begin
95417>>>>>                    Get_Attribute DF_FILE_PHYSICAL_NAME of hTable to sPhysicalNameCompare 
95420>>>>>                    Close hTable
95421>>>>>                    Get _TableNameOnly sPhysicalNameCompare to sPhysicalNameCompare
95422>>>>>                    If (Uppercase(sPhysicalName) = Uppercase(sPhysicalNameCompare)) Begin
95424>>>>>                        Function_Return True
95425>>>>>                    End
95425>>>>>>
95425>>>>>                End
95425>>>>>>
95425>>>>>            End
95425>>>>>>
95425>>>>>        Until (hTable = 0)
95427>>>>>        
95427>>>>>        Function_Return False
95428>>>>>    End_Function
95429>>>>>    
95429>>>>>    // To Open a table with any driver.
95429>>>>>    // Note: If the driver is <> DATAFLEX_ID  - login credentials are used; it is then assumed 
95429>>>>>    //       that the proper login properties has been setup properly with the cSQLConnections object.
95429>>>>>    //
95429>>>>>    // If the open command fails the Err flag will be reset to false, at the end of the function!
95429>>>>>    // The found flag is still used to indicate if the open was successful or not. The function
95429>>>>>    // returns a True if successful (table could be opened).
95429>>>>>    //
95429>>>>>    // Using the "Open As" syntax with drivers means that we don't need to rely on .int file settings.
95429>>>>>    // This is good because with DFConnectionID's those credentials doesn't need to be available in
95429>>>>>    // the .int file (and probably aren't). As long as the login properties of this object have been
95429>>>>>    // set properly we can open the table.
95429>>>>>    //
95429>>>>>    // DAW Driver Syntax:
95429>>>>>    //  <CKId>:<Schema>#<Table>@<ConnectString>|<Filename>.int
95429>>>>>    //  Now the @<ConnectString> can be followed by a pipe character '|' followed by the name of the INT file.
95429>>>>>    //  Doing so, the driver will apply the information from the .INT file to the passed direct Open String.
95429>>>>>    //  Note that when an INT file has been passed, it will skip the keyword DRIVER_NAME, SERVER_NAME,
95429>>>>>    //  DATABASE_NAME and SCHEMA_NAME from the INT file because those are supposed to be supplied in the String already. 
95429>>>>>    //  Open mode; iMode = DF_SHARE or DF_EXCLUSIVE.
95429>>>>>    //
95429>>>>>    // DAW Driver Sample:
95429>>>>>    //   Open "MSSQLDRV:dbo#MyFile@SERVER=(local)\SQLEXPRESS;Trusted_Connection=yes;DATABASE=OrderEntry|options|intfile=MyFile.int"
95429>>>>>    //
95429>>>>>    // Mertech Driver Samples:
95429>>>>>    //   SQLFlex:   Open "sql_drv:\\<serverName>\<database>*<owner>*<tableName>=<numberFieds>" as table 
95429>>>>>    //   MySQLFlex: Open "mdsmysql:\\<serverName>\<database>*<tableName>=<numberFieds>" as table 
95429>>>>>    //   PgFlex:    Open "mdspgsql:\\<serverName>\<database>*<schema>*<tableName>=<numberFieds>" as table 
95429>>>>>    //   ORAFlex:   Open "ora_drv:\\<serverName>\<owner>*<tableName>=<numberFieds>" as table 
95429>>>>>    Function UtilTableOpen Integer hTable String sTableName Integer iMode Returns Boolean
95431>>>>>        String sDriverID sConnection sSchema sExt sTableNameShort sTableNameOrg
95431>>>>>        Boolean bOpen bMertechDriver
95431>>>>>        Integer iRetval              
95431>>>>>        tSQLConnection SQLConnection
95431>>>>>        tSQLConnection SQLConnection
95431>>>>>
95431>>>>>        Move sTableName to sTableNameOrg
95432>>>>>        If (hTable > 0 and Trim(sTableName) = "") Begin
95434>>>>>            Send Ignore_Error of Error_Object_Id 20529
95435>>>>>            Send Ignore_Error of Error_Object_Id DFERR_CANT_OPEN_DATA_FILE
95436>>>>>            Send Ignore_Error of Error_Object_Id CLIERR_CONNECTIONIDNOTFOUND
95437>>>>>            Open hTable
95439>>>>>            Send Trap_Error of Error_Object_Id 20529
95440>>>>>            Send Trap_Error of Error_Object_Id DFERR_CANT_OPEN_DATA_FILE
95441>>>>>            Send Trap_Error of Error_Object_Id CLIERR_CONNECTIONIDNOTFOUND
95442>>>>>            Function_Return (Found = True)
95443>>>>>        End
95443>>>>>>
95443>>>>>        
95443>>>>>        Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
95444>>>>>        Move SQLConnection.sDriverID to sDriverID
95445>>>>>        Get IsMertechDriver sDriverID to bMertechDriver
95446>>>>>        Move SQLConnection.sConnectionString to sConnection
95447>>>>>        Move SQLConnection.sSchema to sSchema
95448>>>>>        If (sSchema = "") Begin 
95450>>>>>            Get _SqlFindKeyWord CI_SQLDBO to sSchema 
95451>>>>>        End
95451>>>>>>
95451>>>>>
95451>>>>>        // We need to remove the ".int" part of the table name because
95451>>>>>        // the table name after the "#" in the connection syntax below wants the
95451>>>>>        // "bare" table name without any extension.
95451>>>>>        If (sDriverID <> DATAFLEX_ID) Begin
95453>>>>>            If (Lowercase(sTableName) contains ".int") Begin
95455>>>>>                Get ParseFileExtension sTableName to sExt
95456>>>>>                Move (Replace(("." + sExt), sTableName, "")) to sTableNameShort
95457>>>>>            End                                                                
95457>>>>>>
95457>>>>>            Else Begin
95458>>>>>                Move sTableName to sTableNameShort  
95459>>>>>                Move (Append(sTableName, ".int")) to sTableName
95460>>>>>            End   
95460>>>>>>
95460>>>>>            If (bMertechDriver = False) Begin
95462>>>>>                Move (sDriverID + ":" + sSchema + "#" + sTableNameShort + "@" + sConnection + "|options|intfile=" + sTableName) to sConnection
95463>>>>>                Move sConnection to sTableName
95464>>>>>            End
95464>>>>>>
95464>>>>>        End
95464>>>>>>
95464>>>>>
95464>>>>>        Send Ignore_Error of Error_Object_Id CLIERR_LOGIN_UNSUCCESSFUL
95465>>>>>        Send Ignore_Error of Error_Info_Object DFERR_FILE_ACCESS_VIOLATION 
95466>>>>>        If (hTable = 0) Begin
95468>>>>>            Get NextFreeFilelistSlot to hTable
95469>>>>>        End
95469>>>>>>
95469>>>>>
95469>>>>>        Case Begin
95469>>>>>            Case (sDriverID = MSSQLDRV_ID)
95471>>>>>                // If not df_exclusive mode, we use the "Open As" syntax.
95471>>>>>                If (iMode <> DF_EXCLUSIVE) Begin
95473>>>>>                    Open sTableName as hTable
95475>>>>>                End
95475>>>>>>
95475>>>>>                Else Begin
95476>>>>>                    Open hTable mode DF_Exclusive
95478>>>>>                End
95478>>>>>>
95478>>>>>                Case Break
95479>>>>>
95479>>>>>            Case (sDriverID = DB2_DRV_ID)
95482>>>>>                // If not df_exclusive mode, we use the "Open As" syntax.
95482>>>>>                If (iMode <> DF_EXCLUSIVE) Begin
95484>>>>>                    Open sTableName as hTable
95486>>>>>                End
95486>>>>>>
95486>>>>>                Else Begin
95487>>>>>                    Open hTable mode DF_Exclusive
95489>>>>>                End
95489>>>>>>
95489>>>>>                Case Break
95490>>>>>
95490>>>>>            Case (sDriverID = ODBC_DRV_ID)
95493>>>>>                // If not df_exclusive mode, we use the "Open As" syntax.
95493>>>>>                If (iMode <> DF_EXCLUSIVE) Begin
95495>>>>>                    Open sTableName as hTable
95497>>>>>                End
95497>>>>>>
95497>>>>>                Else Begin
95498>>>>>                    Open hTable mode DF_Exclusive
95500>>>>>                End
95500>>>>>>
95500>>>>>                Case Break 
95501>>>>>                
95501>>>>>            Case (sDriverID = SQLFLEX)                                                                               
95504>>>>>                // ToDo: What is the <owner>? Same as Schema?
95504>>>>>                // SQLFlex:   Open "sql_drv:\\<serverName>\<database>*<owner>*<tableName>=<numberFieds>" as table 
95504>>>>>                Move (SQLFLEX + ":\\" + SQLConnection.sServer + "\" + SQLConnection.sDatabase + SQLConnection.sSchema + "*" + sTableNameOrg) to sTableName
95505>>>>>                // If not df_exclusive mode, we use the "Open As" syntax.
95505>>>>>                If (iMode <> DF_EXCLUSIVE) Begin
95507>>>>>                    Open sTableName as hTable
95509>>>>>                End
95509>>>>>>
95509>>>>>                Else Begin
95510>>>>>                    Open hTable mode DF_Exclusive
95512>>>>>                End
95512>>>>>>
95512>>>>>                Case Break
95513>>>>>
95513>>>>>            Case (sDriverID = MDSMySQL)
95516>>>>>                // MySQLFlex: Open "mdsmysql:\\<serverName>\<database>*<tableName>=<numberFieds>" as table 
95516>>>>>                Move (MDSMySQL + ":\\" + SQLConnection.sServer + "\" + SQLConnection.sDatabase + "*" + sTableNameOrg) to sTableName
95517>>>>>                // If not df_exclusive mode, we use the "Open As" syntax.
95517>>>>>                If (iMode <> DF_EXCLUSIVE) Begin
95519>>>>>                    Open sTableName as hTable
95521>>>>>                End
95521>>>>>>
95521>>>>>                Else Begin
95522>>>>>                    Open hTable mode DF_Exclusive
95524>>>>>                End
95524>>>>>>
95524>>>>>                Case Break
95525>>>>>
95525>>>>>            Case (sDriverID = MDSPgSQL)
95528>>>>>                // PgFlex: Open "mdspgsql:\\<serverName>\<database>*<schema>*<tableName>=<numberFieds>" as table 
95528>>>>>                Move (MDSPgSQL + ":\\" + SQLConnection.sServer + "\" + SQLConnection.sDatabase + "*" + SQLConnection.sSchema + "*" + sTableNameOrg) to sTableName
95529>>>>>                // If not df_exclusive mode, we use the "Open As" syntax.
95529>>>>>                If (iMode <> DF_EXCLUSIVE) Begin
95531>>>>>                    Open sTableName as hTable
95533>>>>>                End
95533>>>>>>
95533>>>>>                Else Begin
95534>>>>>                    Open hTable mode DF_Exclusive
95536>>>>>                End
95536>>>>>>
95536>>>>>                Case Break
95537>>>>>
95537>>>>>            Case (sDriverID = ORAFLEX)
95540>>>>>                // ToDo: What is the <owner>? Same as Schema?
95540>>>>>                // ORAFlex: Open "ora_drv:\\<serverName>\<owner>*<tableName>=<numberFieds>" as table 
95540>>>>>                Move (ORAFLEX + ":\\" + SQLConnection.sServer + "\" + SQLConnection.sSchema + "*" + sTableName) to sTableName
95541>>>>>                // If not df_exclusive mode, we use the "Open As" syntax.
95541>>>>>                If (iMode <> DF_EXCLUSIVE) Begin
95543>>>>>                    Open sTableName as hTable
95545>>>>>                End
95545>>>>>>
95545>>>>>                Else Begin
95546>>>>>                    Open hTable mode DF_Exclusive
95548>>>>>                End
95548>>>>>>
95548>>>>>                Case Break
95549>>>>>
95549>>>>>            Case (sDriverID = DATAFLEX_ID)
95552>>>>>                If (sTableName <> "" and iMode <> DF_EXCLUSIVE) Begin
95554>>>>>                    Open sTableName as hTable
95556>>>>>                End
95556>>>>>>
95556>>>>>                Else If (iMode = DF_EXCLUSIVE) Begin
95559>>>>>                    Open hTable mode DF_Exclusive
95561>>>>>                End
95561>>>>>>
95561>>>>>                Else Begin
95562>>>>>                    Open hTable
95564>>>>>                End
95564>>>>>>
95564>>>>>                Case Break
95565>>>>>                
95565>>>>>            // ToDo: Logic needs to be expanded for Mertech drivers!
95565>>>>>
95565>>>>>            Case Else
95565>>>>>                Error DFERR_PROGRAM ("Invalid driver:" * sDriverID)
95566>>>>>>
95566>>>>>        Case End
95566>>>>>
95566>>>>>        Send Trap_Error of Error_Object_Id CLIERR_LOGIN_UNSUCCESSFUL 
95567>>>>>        Send Trap_Error of Error_Info_Object DFERR_FILE_ACCESS_VIOLATION
95568>>>>>        If (LastErr = CLIERR_LOGIN_UNSUCCESSFUL) Begin
95570>>>>>            Move False to Found
95571>>>>>        End
95571>>>>>>
95571>>>>>        // If open failed, the Err is set to true,
95571>>>>>        // but we don't want that because it could end our loop.
95571>>>>>        Move False to Err
95572>>>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpen
95575>>>>>
95575>>>>>        Function_Return bOpen
95576>>>>>    End_Function
95577>>>>>    
95577>>>>>    // Pass a table handle
95577>>>>>    // Returns True if the table exists in filelist.cfg.
95577>>>>>    Function UtilTableNumberIsInUse Handle hCheckTable Returns Boolean
95579>>>>>        Handle hTable
95579>>>>>        Boolean bFound
95579>>>>>        
95579>>>>>        Move False to bFound
95580>>>>>        Move 0 to hTable              
95581>>>>>        Repeat
95581>>>>>>
95581>>>>>            Get_Attribute DF_FILE_NEXT_USED of hTable to hTable
95584>>>>>            If (hTable > 0) Begin
95586>>>>>                If (hTable = hCheckTable) Begin
95588>>>>>                    Move True to bFound
95589>>>>>                End
95589>>>>>>
95589>>>>>            End
95589>>>>>>
95589>>>>>            If (bFound = True) Break
95592>>>>>        Until (hTable = 0)
95594>>>>>    
95594>>>>>        Function_Return (bFound = True)
95595>>>>>    End_Function
95596>>>>>    
95596>>>>>    Function UtilEnumerateOverlapFields Integer hTable Integer iField Returns String[]
95598>>>>>        String  sRetval sColumnName
95598>>>>>        String[] sOverlapFieldsArray
95599>>>>>        Integer iType iColumn iColumns 
95599>>>>>        Boolean bOpen bOverlap
95599>>>>>        
95599>>>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpen
95602>>>>>        If (bOpen = False) Begin
95604>>>>>            Open hTable
95606>>>>>        End
95606>>>>>>
95606>>>>>        
95606>>>>>        Move "" to sRetval
95607>>>>>        
95607>>>>>        Get_Attribute DF_FILE_NUMBER_FIELDS of hTable to iColumns
95610>>>>>        
95610>>>>>        for iColumn from 0 to iColumns
95616>>>>>>
95616>>>>>            Get_Attribute DF_FIELD_TYPE of hTable iColumn to iType
95619>>>>>            If (iField <> iColumn and iType <> DF_OVERLAP) Begin
95621>>>>>                Get_Attribute DF_FIELD_OVERLAP of hTable iField iColumn to bOverlap
95624>>>>>                If (bOverlap) Begin
95626>>>>>                    If (sRetval <> "") Begin
95628>>>>>                        Append sRetval ","
95629>>>>>                    End
95629>>>>>>
95629>>>>>                    Append sRetval iColumn
95630>>>>>                End
95630>>>>>>
95630>>>>>            End
95630>>>>>>
95630>>>>>        Loop
95631>>>>>>
95631>>>>>        
95631>>>>>        If (bOpen = False) Begin
95633>>>>>            Close hTable
95634>>>>>        End    
95634>>>>>>
95634>>>>>        
95634>>>>>        Move (StrSplitToArray(sRetval, ",")) to sOverlapFieldsArray
95635>>>>>        
95635>>>>>        Function_Return sOverlapFieldsArray
95636>>>>>    End_Function
95637>>>>>    
95637>>>>>    // Returns a struct array with all data types for the passed driver & dbtype.
95637>>>>>    Function UtilEnumerateColumnTypes String sDriverID Integer iDbType Returns tColumnType[]
95639>>>>>        tColumnType[] ColumnType               
95639>>>>>        tColumnType[] ColumnType               
95640>>>>>            
95640>>>>>        Case Begin
95640>>>>>            Case (iDbType = EN_dbTypeDataFlex)  
95642>>>>>                Get _UtilEnumerateDataFlexTypes to ColumnType
95643>>>>>                Case Break
95644>>>>>                
95644>>>>>            Case (iDbType = EN_DbTypeDB2)
95647>>>>>                Get _UtilEnumerateDB2Types to ColumnType
95648>>>>>                Case Break
95649>>>>>                
95649>>>>>            Case (iDbType = EN_DbTypeMSSQL)
95652>>>>>                Get _UtilEnumerateMSSQLTypes sDriverID to ColumnType
95653>>>>>                Case Break
95654>>>>>            
95654>>>>>            Case (sDriverID = MDSMySQL)            
95657>>>>>                Get _UtilEnumerateMySQLTypes to ColumnType
95658>>>>>                Case Break
95659>>>>>            
95659>>>>>            Case (sDriverID = ORAFLEX)
95662>>>>>                Get _UtilEnumerateOracleTypes to ColumnType
95663>>>>>                Case Break
95664>>>>>
95664>>>>>            Case (sDriverID = MDSPgSQL)   
95667>>>>>                Get _UtilEnumeratePostgreSQLTypes to ColumnType
95668>>>>>                Case Break
95669>>>>>        Case End
95669>>>>>        
95669>>>>>        Function_Return ColumnType
95670>>>>>    End_Function
