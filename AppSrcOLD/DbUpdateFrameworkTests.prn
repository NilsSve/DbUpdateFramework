89203>>>>>>>>>>>Class cDbUpdateSQLFLEXDriver is a cDbUpdateGenericDatabaseDriver
89204>>>>>>>>>>>    Function DbLogin String sConnectionString String sServer String sDatabase Boolean bTrusted String sUserID String sPassword Returns Boolean
89206>>>>>>>>>>>        Boolean bLoginSuccessful
89206>>>>>>>>>>>        String sDriverID 
89206>>>>>>>>>>>        
89206>>>>>>>>>>>        Get psDriverID to sDriverID
89207>>>>>>>>>>>        //For the Mertech driver, using the Err indicator is the sanctioned way
89207>>>>>>>>>>>        Move False to Err
89208>>>>>>>>>>>        If (bTrusted = False) Begin
89210>>>>>>>>>>>            Login sServer sUserId sPassword sDriverID
89212>>>>>>>>>>>        End 
89212>>>>>>>>>>>>
89212>>>>>>>>>>>        Else Begin
89213>>>>>>>>>>>            Login sServer "" "" sDriverID
89215>>>>>>>>>>>        End
89215>>>>>>>>>>>>
89215>>>>>>>>>>>        Move (not(Err)) to bLoginSuccessful
89216>>>>>>>>>>>        
89216>>>>>>>>>>>        Function_Return bLoginSuccessful
89217>>>>>>>>>>>    End_Function
