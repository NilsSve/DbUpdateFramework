91316>>>>>            Send Ignore_Error of Error_Object_Id DFERR_CANT_OPEN_INTERMEDIATE_FILE
91317>>>>>            Send Ignore_Error of Error_Object_Id CLIERR_GENERAL_ERROR
91318>>>>>            Open hTable
91320>>>>>            Send Trap_Error of Error_Object_Id DFERR_CANT_OPEN_DATA_FILE
91321>>>>>            Send Trap_Error of Error_Object_Id DFERR_CANT_OPEN_INTERMEDIATE_FILE
91322>>>>>            Send Trap_Error of Error_Object_Id CLIERR_GENERAL_ERROR
91323>>>>>            Get_Attribute DF_FILE_OPENED of hTable to bOpen
91326>>>>>        End
91326>>>>>>
91326>>>>>        If (bOpen = True) Begin
91328>>>>>            Structure_Start hTable sDriverID
91329>>>>>                Set_Attribute DF_FIELD_NULL_ALLOWED of hTable iColumn to bNullable
91332>>>>>            Structure_End hTable
91334>>>>>        End
91334>>>>>>
