86713>>>>>>>>>>>Function vWin32_APIFileSize Global string sFileName returns integer
86715>>>>>>>>>>>     dWord dwFileSizeHigh dwFileSizeLow
86715>>>>>>>>>>>     integer iFileSize iVoid
86715>>>>>>>>>>>     handle hFindFile
86715>>>>>>>>>>>     pointer lpsFilePath lpsWin32FindData
86715>>>>>>>>>>>     string sWin32FindData
86715>>>>>>>>>>>
86715>>>>>>>>>>>     GetAddress of sFileName to lpsFilePath
86716>>>>>>>>>>>
86716>>>>>>>>>>>     ZeroType vWin32_Find_Data to sWin32FindData
86717>>>>>>>>>>>     GetAddress of sWin32FindData to lpsWin32FindData
86718>>>>>>>>>>>
86718>>>>>>>>>>>     move (vWin32_FindFirstFile (lpsFilePath, lpsWin32FindData)) to hFindFile
86719>>>>>>>>>>>     if (hFindFile<>vINVALID_HANDLE_VALUE) begin
86721>>>>>>>>>>>         GetBuff From sWin32FindData At vWin32_Find_Data.nFileSizeHigh To dwFileSizeHigh
86722>>>>>>>>>>>         GetBuff From sWin32FindData At vWin32_Find_Data.nFileSizeLow To dwFileSizeLow
86723>>>>>>>>>>>     end
86723>>>>>>>>>>>>
86723>>>>>>>>>>>     move (vWin32_FindClose (hFindFile)) to iVoid
86724>>>>>>>>>>>
86724>>>>>>>>>>>     moveInt ((dwFileSizeHigh * vMaxDword) + dwFileSizeLow) to iFileSize
86725>>>>>>>>>>>>
86725>>>>>>>>>>>
86725>>>>>>>>>>>     function_return iFileSize
86726>>>>>>>>>>>End_Function  // vWin32_APIFileSize
