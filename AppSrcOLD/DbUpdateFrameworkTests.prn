92544>>>>>    // *** Main message for executing an SQL script that has been compiled into the program as a resource ***
92544>>>>>    // Use the SQLIncludeScriptFile command to include an SQL script into the program.
92544>>>>>    // Returns False if no error occured.
92544>>>>>    Function SqlUtilExecuteResource String sMemFileName String sDriverID Boolean bCreateScriptFile Boolean bShowProgr Returns Boolean
92546>>>>>        Boolean bOK bShowProgress                               
92546>>>>>        tSQLScriptArray SQLScriptArray                      
92546>>>>>        tSQLScriptArray SQLScriptArray                      
92546>>>>>        Integer iOut iRows iCount
92546>>>>>        DateTime dtTotalQueryStart dtTotalQueryEnd
92546>>>>>        TimeSpan tsTotalTime  
92546>>>>>        String sMessage
92546>>>>>        
92546>>>>>        Move (CurrentDateTime()) to dtTotalQueryStart
92547>>>>>        Get SqlUtilReadResource sMemFileName to SQLScriptArray
92548>>>>>        If (SQLScriptArray.bError = True) Begin
92550>>>>>            Function_Return False
92551>>>>>        End
92551>>>>>>
92551>>>>>
92551>>>>>        If (num_arguments > 3) Begin
92553>>>>>            Move bShowProgr to bShowProgress
92554>>>>>        End
92554>>>>>>
92554>>>>>
92554>>>>>        Set Error_Report_Mode to DUF_ERROR_NO_REPORT
92555>>>>>        Get SqlUtilExecuteEmbeddedScript SQLScriptArray sDriverID bCreateScriptFile sMemFileName bShowProgress to bOK
92556>>>>>        Set Error_Report_Mode to DUF_ERROR_REPORT 
92557>>>>>        
92557>>>>>        If (SQLScriptArray.bArgumentSizeChanged = True) Begin
92559>>>>>            Set_Argument_Size SQLScriptArray.iOrgArgumentSize
92560>>>>>>
92560>>>>>        End
92560>>>>>>
92560>>>>>
92560>>>>>        Move (CurrentDateTime()) to dtTotalQueryEnd
92561>>>>>        Move (dtTotalQueryEnd - dtTotalQueryStart) to tsTotalTime
92562>>>>>        Set ptsTotalQueryTime to tsTotalTime
92563>>>>>        
92563>>>>>        Function_Return bOK
92564>>>>>    End_Procedure
