86572>>>>>>>>>>>  Pointer lpsFolder
86572>>>>>>>>>>>  Handle  hWnd
86572>>>>>>>>>>>  Move (Window_Handle(focus(desktop))) To hWnd
86573>>>>>>>>>>>
86573>>>>>>>>>>>  Move (Repeat(Character(0), vMAX_PATH)) To sFolder
86574>>>>>>>>>>>  GetAddress Of sFolder To lpsFolder
86575>>>>>>>>>>>
86575>>>>>>>>>>>  Move (vWin32_SHGetFolderPath(hWnd,eFolder, 0, 0,lpsFolder)) To iVoid
86576>>>>>>>>>>>  Function_Return (CString(sFolder))
86577>>>>>>>>>>>End_Function // vSHGetFolderPath
86578>>>>>>>>>>>
86578>>>>>>>>>>>
86578>>>>>>>>>>>
86578>>>>>>>>>>>// Courtesy Of Vincent Oorsprong
86578>>>>>>>>>>>Function vConvertFileDateTime Global Dword dwLowDateTime Dword dwHighDateTime Returns String
86580>>>>>>>>>>>  String  sftTime sSystemTime sFormattedTime sFormattedDate
86580>>>>>>>>>>>  Pointer lpsftTime lpsSystemTime lpsFormattedTime lpsFormattedDate
86580>>>>>>>>>>>  Integer iSuccess iLenCcTime iDataLength iLenCcDate
86580>>>>>>>>>>>
86580>>>>>>>>>>>  ZeroType vFileTime  To sftTime
86581>>>>>>>>>>>  Put dwLowDateTime  To sftTime At vFileTime.dwLowDateTime
86582>>>>>>>>>>>  Put dwHighDateTime To sftTime At vFileTime.dwHighDateTime
86583>>>>>>>>>>>  GetAddress Of sftTime To lpsftTime
86584>>>>>>>>>>>
86584>>>>>>>>>>>  ZeroType vSystemTime To sSystemTime
86585>>>>>>>>>>>  GetAddress Of sSystemTime To lpsSystemTime
86586>>>>>>>>>>>
86586>>>>>>>>>>>  Moveint (vWin32_FileTimeToSystemTime (lpsftTime, lpsSystemTime)) To iSuccess
86587>>>>>>>>>>>>
86587>>>>>>>>>>>  If iSuccess Eq DfTrue Begin
86589>>>>>>>>>>>    ZeroString 255 To sFormattedTime
86590>>>>>>>>>>>    GetAddress Of sFormattedTime To lpsFormattedTime
86591>>>>>>>>>>>    Length sFormattedTime To iLenCcTime
86592>>>>>>>>>>>>
86592>>>>>>>>>>>    Moveint (vWin32_GetTimeFormat (LOCALE_USER_DEFAULT, 0, lpsSystemTime, 0, ;                             lpsFormattedTime, iLenCcTime)) To iDataLength
86593>>>>>>>>>>>>
86593>>>>>>>>>>>    ZeroString 255 To sFormattedDate
86594>>>>>>>>>>>    GetAddress Of sFormattedDate To lpsFormattedDate
86595>>>>>>>>>>>    Length sFormattedDate To iLenCcDate
86596>>>>>>>>>>>>
86596>>>>>>>>>>>    Moveint (vWin32_GetDateFormat (LOCALE_USER_DEFAULT, 0, lpsSystemTime, 0, ;                             lpsFormattedDate, iLenCcDate)) To iDataLength
86597>>>>>>>>>>>>
86597>>>>>>>>>>>    Function_Return (Cstring (sFormattedDate)  * Cstring (sFormattedTime))
86598>>>>>>>>>>>  End // iSuccess
86598>>>>>>>>>>>>
86598>>>>>>>>>>>End_Function // vConvertFileDateTime
86599>>>>>>>>>>>
86599>>>>>>>>>>>
86599>>>>>>>>>>>// **WvA Removed, See the cFileSet class for an alternative
86599>>>>>>>>>>>//Procedure DoBrowseDir String sFilePath
86599>>>>>>>>>>>//End_Procedure // DoBrowseDir
86599>>>>>>>>>>>
86599>>>>>>>>>>>// **WvA:
86599>>>>>>>>>>>// A windows replacement for the standard function FileExists.
86599>>>>>>>>>>>// This version will also return (true) for a file when it is open by an application.
86599>>>>>>>>>>>// Note that you can apply normal windows mask-signs in the filename such as * and ?
86599>>>>>>>>>>>// Example: Get vFilePathExists "C:\config.sy?"
86599>>>>>>>>>>>// This will return true if you have a file matching these conditions. (aka config.sys)
86599>>>>>>>>>>>Function vFilePathExists Global String sFilePathMask Returns Integer
86601>>>>>>>>>>>  String  sWin32FindData
86601>>>>>>>>>>>  String  sDirSep
86601>>>>>>>>>>>  Pointer lpsFilePathMask lpsWin32FindData
86601>>>>>>>>>>>  Handle  hFindFile
86601>>>>>>>>>>>  Integer iVoid
86601>>>>>>>>>>>
86601>>>>>>>>>>>  Move vINVALID_HANDLE_VALUE To hFindFile
86602>>>>>>>>>>>  Move (ToANSI(trim(sFilePathMask))) To sFilePathMask
86603>>>>>>>>>>>  
86603>>>>>>>>>>>  If (length(sFilePathMask)>0) Begin
86605>>>>>>>>>>>    // 2014-09-29 NGS Remove any trailing dir separators, as they make the function fail.
86605>>>>>>>>>>>    Move (sysconf(SYSCONF_DIR_SEPARATOR)) to sDirSep
86606>>>>>>>>>>>    While (Right(sFilePathMask, 1) = sDirSep)
86610>>>>>>>>>>>      Move (Left(sFilePathMask, Length(sFilePathMask) -1)) to sFilePathMask
86611>>>>>>>>>>>    Loop
86612>>>>>>>>>>>>
86612>>>>>>>>>>>    
86612>>>>>>>>>>>    GetAddress Of sFilePathMask To lpsFilePathMask
86613>>>>>>>>>>>    ZeroType vWin32_Find_Data To sWin32FindData
86614>>>>>>>>>>>    GetAddress Of sWin32FindData To lpswin32FindData
86615>>>>>>>>>>>    Move (vWin32_FindFirstFile (lpsFilePathMask, lpsWin32FindData)) To hFindFile
86616>>>>>>>>>>>    Move (vWin32_FindClose (hFindFile)) To iVoid
86617>>>>>>>>>>>  End
86617>>>>>>>>>>>>
86617>>>>>>>>>>>  Function_Return (hFindFile <> vINVALID_HANDLE_VALUE)
86618>>>>>>>>>>>End_Function // vFilePathExists
86619>>>>>>>>>>>
86619>>>>>>>>>>>
86619>>>>>>>>>>>// **WvA
86619>>>>>>>>>>>// Formats a foldername by first trimming it and after that by sticking a
86619>>>>>>>>>>>// directory separator (/\) to the end if it doesn't have one there already.
86619>>>>>>>>>>>// The folder may contain a drive letter or UNC encoding.
86619>>>>>>>>>>>Function vFolderFormat Global String sFolderName Returns String
86621>>>>>>>>>>>  String sDirSep
86621>>>>>>>>>>>  Move (sysconf(SYSCONF_DIR_SEPARATOR)) To sDirSep  // normally \ (backslash)
86622>>>>>>>>>>>  Move (Trim(sFolderName)) To sFolderName
86623>>>>>>>>>>>  If (Right(sFolderName,1)<>sDirSep) Begin
86625>>>>>>>>>>>    Move (sFolderName+sDirSep) To sFolderName
86626>>>>>>>>>>>  End
86626>>>>>>>>>>>>
86626>>>>>>>>>>>  Function_Return sFolderName
86627>>>>>>>>>>>End_Function // vFolderFormat
86628>>>>>>>>>>>//
86628>>>>>>>>>>>// Returns the amount of files in the folder (if it exists)
86628>>>>>>>>>>>// Returns -1 if folder doesn't exist.
86628>>>>>>>>>>>// The files "." and ".." are not counted.
86628>>>>>>>>>>>//
86628>>>>>>>>>>>Function vFolderFileCount Global String sFolderName Returns Integer
86630>>>>>>>>>>>  Boolean bFound
86630>>>>>>>>>>>  Handle  hFindFile
86630>>>>>>>>>>>  Integer iCount  iVoid
86630>>>>>>>>>>>  Integer iSuccess
86630>>>>>>>>>>>  Pointer lpsFolderName lpsWin32FindData
86630>>>>>>>>>>>  String  sWin32FindData
86630>>>>>>>>>>>  String  sFileName
86630>>>>>>>>>>>  
86630>>>>>>>>>>>  Move -1 To iCount
86631>>>>>>>>>>>  Get vFolderFormat sFolderName To sFolderName
86632>>>>>>>>>>>  Move (sFolderName+"*") To sFolderName // match any filename in the folder
86633>>>>>>>>>>>  GetAddress Of sFolderName To lpsFolderName
86634>>>>>>>>>>>  ZeroType vWin32_Find_Data To sWin32FindData
86635>>>>>>>>>>>  GetAddress Of sWin32FindData To lpswin32FindData
86636>>>>>>>>>>>  Move (vWin32_FindFirstFile (lpsFolderName, lpsWin32FindData)) To hFindFile
86637>>>>>>>>>>>  Move (hFindFile<>vINVALID_HANDLE_VALUE) To bFound
86638>>>>>>>>>>>  If (bFound) Move 0 To iCount
86641>>>>>>>>>>>  While (bFound)
86645>>>>>>>>>>>    Increment iCount
86646>>>>>>>>>>>    GetBuff_String From sWin32FindData At vWin32_Find_Data.cFileName To sFileName
86647>>>>>>>>>>>    If (sFileName="." or sFileName="..") Decrement iCount
86650>>>>>>>>>>>    Move (vWin32_FindNextFile(hFindFile, lpsWin32FindData)) To iSuccess
86651>>>>>>>>>>>    Move (iSuccess<>0) To bFound
86652>>>>>>>>>>>  Loop
86653>>>>>>>>>>>>
86653>>>>>>>>>>>  Move (vWin32_FindClose (hFindFile)) To iVoid
86654>>>>>>>>>>>  Function_Return iCount
86655>>>>>>>>>>>End_Function // vFolderFileCount
86656>>>>>>>>>>>   
86656>>>>>>>>>>>
86656>>>>>>>>>>>//
86656>>>>>>>>>>>// Gets the parent path of the currently supplied path
86656>>>>>>>>>>>// Returns "" when we are at the root folder.
86656>>>>>>>>>>>//
86656>>>>>>>>>>>Function vParentPath Global String sPath Returns String
86658>>>>>>>>>>>  String sStrip
86658>>>>>>>>>>>  
86658>>>>>>>>>>>  If (Right(sPath,1)="\") Begin
86660>>>>>>>>>>>    Move (Left(sPath,Length(sPath)-1)) To sPath
86661>>>>>>>>>>>  End
86661>>>>>>>>>>>>
86661>>>>>>>>>>>  If (Pos("\",sPath)) Begin
86663>>>>>>>>>>>    Move (StringFromRightOfChar(sPath,"\")) To sStrip
86664>>>>>>>>>>>    Move (Replace(sStrip,sPath,"")) To sPath
86665>>>>>>>>>>>  End
86665>>>>>>>>>>>>
86665>>>>>>>>>>>  Else Begin
86666>>>>>>>>>>>    Move "" To sPath
86667>>>>>>>>>>>  End
86667>>>>>>>>>>>>
86667>>>>>>>>>>>  Function_Return sPath
86668>>>>>>>>>>>End_Function // vParentPath
86669>>>>>>>>>>>
86669>>>>>>>>>>>// Create the folder, including intermediate directories.
86669>>>>>>>>>>>// Don't panic if the folder already exists.
86669>>>>>>>>>>>// Michael Mullan June 2009.
86669>>>>>>>>>>>Function vshCreateDirectoryEX Global String sNewFolder Returns Integer
86671>>>>>>>>>>>  String  sFolder sSA
86671>>>>>>>>>>>  Pointer lpsFolder lpsSecurity_Attributes
86671>>>>>>>>>>>  Integer iRetval bFolderCreated bInheritHandle
86671>>>>>>>>>>>  Move (False) to bFolderCreated
86672>>>>>>>>>>>  // fill string variable with null characters
86672>>>>>>>>>>>  ZeroType vtSecurity_attributes to sSA
86673>>>>>>>>>>>  // null MAX_PATH chars into var (make space)
86673>>>>>>>>>>>  Move (Repeat(Character(0), vMAX_PATH)) to sFolder
86674>>>>>>>>>>>  If (sNewFolder <> "") Begin
86676>>>>>>>>>>>    Move dfTrue to  bInheritHandle
86677>>>>>>>>>>>    // Setting this to NULL is already done by the zerotype command
86677>>>>>>>>>>>    // Move NULL   To  lpDescriptor
86677>>>>>>>>>>>    Put (length(sSA))   to sSA At vtSecurity_attributes.nLength
86678>>>>>>>>>>>    //Put lpDescriptor To sSA at vtSecurity_attributes.lpDescriptor
86678>>>>>>>>>>>    Put bInheritHandle to sSA At vtSecurity_attributes.bInheritHandle
86679>>>>>>>>>>>    GetAddress of sSA to lpsSecurity_Attributes
86680>>>>>>>>>>>    //
86680>>>>>>>>>>>    Move sNewFolder to sFolder
86681>>>>>>>>>>>    GetAddress of sFolder to lpsFolder
86682>>>>>>>>>>>    Move (vWin32_SHCreateDirectoryEx(0,lpsFolder, lpsSecurity_Attributes)) to bFolderCreated
86683>>>>>>>>>>>  End
86683>>>>>>>>>>>>
86683>>>>>>>>>>> 
86683>>>>>>>>>>>  If (bFolderCreated <> 0) Begin
86685>>>>>>>>>>>    Move 1 to iRetVal
86686>>>>>>>>>>>   
86686>>>>>>>>>>>    If (bFolderCreated = 161 ) Error DFERR_OPERATOR ("Path " + sNewFolder + " is Not Valid (ERROR_BAD_PATHNAME)")
86689>>>>>>>>>>>    Else If (bFolderCreated = 206 ) Error DFERR_OPERATOR ("Path " + sNewFolder + " is Not Valid (ERROR_FILENAME_EXCED_RANGE)")
86693>>>>>>>>>>>    Else If (bFolderCreated = 3   ) Error DFERR_OPERATOR ("Path " + sNewFolder + " is Not Valid (ERROR_PATH_NOT_FOUND)")
86697>>>>>>>>>>>    Else If (bFolderCreated = 80  ) Move 0 to iRetval // "ERROR_FILE_EXISTS"     not really an error
86701>>>>>>>>>>>    Else If (bFolderCreated = 183 ) Move 0 to iRetval //  "ERROR_ALREADY_EXISTS"     not really an error
86705>>>>>>>>>>>    Else If (bFolderCreated = 1223) Error DFERR_OPERATOR ("Path " + sNewFolder + " is Not Valid (ERROR_CANCELLED)")
86709>>>>>>>>>>>    Else Error DFERR_OPERATOR ("Folder Creation Error # " + String(bfoldercreated) + "\n" + sNewFolder + "(FILE_CREATION_ERROR)")
86711>>>>>>>>>>>  End
86711>>>>>>>>>>>>
86711>>>>>>>>>>>  Function_Return iRetVal
86712>>>>>>>>>>>End_Function // vshCreateDirectoryEX
