98354>>>>>>>    Procedure AdjustSizesLocs Integer ByRef iHeight Integer ByRef iWidth Integer ByRef iLocY Integer ByRef iLocX
98356>>>>>>>        Boolean bTabWorkspaceView
98356>>>>>>>        Get pbTabWorkspaceView to bTabWorkspaceView 
98357>>>>>>>        If bTabWorkspaceView Begin
98359>>>>>>>            Send AdjustTabWorkspaceView (&iHeight) (&iWidth) (&iLocY) (&iLocX)
98360>>>>>>>        End
