85653>>>>>>>>>        If (iState = 0) Begin
85655>>>>>>>>>            Send RequestDeleteToolTip
85656>>>>>>>>>        End 
85656>>>>>>>>>>
85656>>>>>>>>>        Else Begin
85657>>>>>>>>>            Send RequestAddToolTip
85658>>>>>>>>>        End
85658>>>>>>>>>>
85658>>>>>>>>>    End_Procedure
85659>>>>>>>>>
85659>>>>>>>>>    Procedure Page Integer iState
85661>>>>>>>>>        Forward Send Page iState
85663>>>>>>>>>        If (iState =1) Send private_DoInitWindow
85666>>>>>>>>>    End_Procedure
