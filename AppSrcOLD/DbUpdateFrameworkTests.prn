93081>>>>>    // Backs up an SQL database to a folder of choice. If no path is passed the SQL default backup folder
93081>>>>>    // will be used.
93081>>>>>    Function SqlUtilBackupDatabaseToDisk String sDatabase String sBackupName String sPath Boolean bShowProg Returns Boolean
93083>>>>>        Boolean bOK bExists bShowProgress      
93083>>>>>        String sStatement sDriverID 
93083>>>>>        tSQLScriptArray SQLScriptArray SQLScriptArrayPercentReady
93083>>>>>        tSQLScriptArray SQLScriptArray SQLScriptArrayPercentReady
93083>>>>>        Integer iDbType
93083>>>>>        
93083>>>>>        If (sDatabase = "") Begin
93085>>>>>            Error DFERR_PROGRAM "The database name was not passed as a parameter to the 'SqlUtilBackupDatabaseToDisk' function"
93086>>>>>>
93086>>>>>            Function_Return False
93087>>>>>        End
93087>>>>>>
93087>>>>>        If (sBackupName = "") Begin
93089>>>>>            Error DFERR_PROGRAM "The database backup name was not passed as a parameter to the 'SqlUtilBackupDatabaseToDisk' function"
93090>>>>>>
93090>>>>>            Function_Return False
93091>>>>>        End
93091>>>>>>
93091>>>>>            
93091>>>>>        // Create backup-folder if it doesn't exist
93091>>>>>        Get vFolderExists sPath to bExists
93092>>>>>        If (bExists = False) Begin
93094>>>>>            Get vCreateDirectory sPath to bOK
93095>>>>>            If (bOK = False) Begin
93097>>>>>                Error DFERR_PROGRAM ("Could not create database backup folder:" * sPath)
93098>>>>>>
93098>>>>>                Function_Return False
93099>>>>>            End
93099>>>>>>
93099>>>>>        End                     
93099>>>>>>
93099>>>>>        // Make sure the path ends with a back-slash
93099>>>>>        If (sPath <> "") Begin
93101>>>>>            Get vFolderFormat sPath to sPath
93102>>>>>        End
93102>>>>>>
93102>>>>>        
93102>>>>>        Get psDriverID to sDriverID  
93103>>>>>        Get piDbType   to iDbType        
93104>>>>>        If (num_arguments > 3) Begin
93106>>>>>            Move bShowProg to bShowProgress
93107>>>>>        End
93107>>>>>>
93107>>>>>        
93107>>>>>        Case Begin
93107>>>>>            Case (iDbType = EN_DbTypeMSSQL)
93109>>>>>                SQLIncludeScriptFile ..\Scripts\BackupMSSQLDatabase.sql as BackupMSSQLDatabase.sql
93109>>>>>                SQLIncludeScriptFile ..\Scripts\GetPercentageBackupCompletionMSSQL.sql as GetPercentageBackupCompletionMSSQL.sql
93109>>>>>                Get SqlUtilReadResource of ghoDbUpdateFunctionLibrary "BackupMSSQLDatabase.sql" sDriverID False to SQLScriptArray
93110>>>>>                Get SqlUtilReadResource of ghoDbUpdateFunctionLibrary "GetPercentageBackupCompletionMSSQL.sql" sDriverID False to SQLScriptArrayPercentReady
93111>>>>>                
93111>>>>>                Move SQLScriptArray.sSQLScriptArray[0] to sStatement
93112>>>>>                Move (Replaces("DATABASE_NAME_XXX", sStatement, sDatabase))   to sStatement
93113>>>>>                Move (Replaces("BACKUP_PATH_XXX",   sStatement, sPath))       to sStatement
93114>>>>>                Move (Replaces("BACKUP_NAME_XXX",   sStatement, sBackupName)) to sStatement
93115>>>>>                Move sStatement to SQLScriptArray.sSQLScriptArray[0]    
93116>>>>>                Get SqlUtilExecuteEmbeddedScript of ghoDbUpdateFunctionLibrary SQLScriptArray sDriverID False "" bShowProgress to bOK
93117>>>>>                Case Break
93118>>>>>            Case Else
93118>>>>>                Send Info_Box ("The SqlUtilBackupDatabaseToDisk function is currently not implemented for the driver:" * sDriverID + ". It would be great if you could spend a couple of minutes and add a little ESQL code snippet to make it work for that driver! Thanks for helping out.")
93119>>>>>        Case End
93119>>>>>        
93119>>>>>        Function_Return bOK    
93120>>>>>    End_Function
93121>>>>>
93121>>>>>    // Reads a resource that has been embedded by the compiler and writes it to disk.
93121>>>>>    // Pass the memory resource file reference and the filename to be created,
93121>>>>>    // including full path.
93121>>>>>    Procedure SqlUtilCreateFileFromMemory String sMemFileName String sFileName
93123>>>>>        String sText
93123>>>>>        Integer iCh iSize iArgSize  
93123>>>>>        
93123>>>>>        Move ("Resource:" + sMemFileName) to sMemFileName
93124>>>>>        Get Seq_Open_Input_Channel sMemFileName to iCh
93125>>>>>            Get_Channel_Size iCh to iSize
93126>>>>>            Get_Argument_Size to iArgSize
93127>>>>>            If (iSize > iArgSize) Begin
93129>>>>>                Set_Argument_Size iSize
93130>>>>>>
93130>>>>>            End
93130>>>>>>
93130>>>>>            Read_Block channel iCh sText iSize
93132>>>>>        Send Seq_Close_Channel iCh
93133>>>>>    
93133>>>>>        Get Seq_Open_Output_Channel sFileName to iCh
93134>>>>>            Write channel iCh sText
93136>>>>>        Send Seq_Close_Channel iCh
93137>>>>>    
93137>>>>>        If (iSize <> iArgSize) Begin
93139>>>>>            Set_Argument_Size iArgSize
93140>>>>>>
93140>>>>>        End
93140>>>>>>
93140>>>>>    
93140>>>>>        // Wait for file to be written to disk.
93140>>>>>        Sleep 2
93141>>>>>    End_Procedure 
