79581>>>>>Class cCJMDIWindowsMenuItem is a cCJMenuItem
79582>>>>>    
79582>>>>>    Procedure Construct_Object
79584>>>>>        Forward Send Construct_Object
79586>>>>>        Property Handle[] phArrayOfWindows
79587>>>>>        Set peControlType to xtpControlPopup
79588>>>>>        Set psCategory to C_$CategoryWindow
79589>>>>>    End_Procedure
79590>>>>>    
79590>>>>>     // This adds MDI windows to the existing menu items.
79590>>>>>     // This removes any existing windows menus and always adds a new set to the end
79590>>>>>
79590>>>>>     Procedure OnPopupInit Variant vCommandBarControl Handle hCommandBarControls
79592>>>>>        Handle  hClientArea hView
79592>>>>>        String  sLabel
79592>>>>>        Integer i iWindows
79592>>>>>        Handle[] hArrayOfWindows
79593>>>>>        Variant vItem
79593>>>>>        
79593>>>>>        // delete all windows actions and menu items. Assume we have an array of DF action objects for the windows
79593>>>>>        // also assume that destroying an action removes all menu instances of that action
79593>>>>>        Get phArrayOfWindows to hArrayOfWindows
79594>>>>>        Move (SizeOfArray(hArrayOfWindows)) to iWindows
79595>>>>>        For i from 0 to (iWindows-1)
79601>>>>>>
79601>>>>>            Send Destroy of hArrayOfWindows[i] // assume this removes all menu items of this action
79602>>>>>        Loop
79603>>>>>>
79603>>>>>        Move (ResizeArray(hArrayOfWindows,0)) to hArrayOfWindows
79604>>>>>
79604>>>>>        // Add all views to this menu. Create the action and add the item
79604>>>>>        Move 0 to i
79605>>>>>        Get Client_Id to hClientArea // object id of client area
79606>>>>>        If (hClientArea > 0) Begin
79608>>>>>            Get Next_Mdi_Dialog of hClientArea True to hView // find first view
79609>>>>>            While (hView <> 0)
79613>>>>>                If (Active_State(hView)) Begin
79615>>>>>                    // create the action
79615>>>>>                    Get Create U_cCJMDIWindowItem to hArrayOfWindows[i]
79616>>>>>                    Get Label of hView to sLabel // caption bar (name) of view
79617>>>>>                    Set psCaption of hArrayOfWindows[i] to sLabel
79618>>>>>                    Set psDescription of hArrayOfWindows[i] to ("Make this view (" - trim(sLabel) - ") the active window.")
79619>>>>>                    If (current_scope(desktop)=hView and View_mode(hView)<>VIEWMODE_ICONIZE) Begin
79621>>>>>                        Set pbChecked of hArrayOfWindows[i] to True
79622>>>>>                    End
79622>>>>>>
79622>>>>>                    Set phWindow of hArrayOfWindows[i] to hView // used by custom OnExecute
79623>>>>>                    If (i=0) Begin
79625>>>>>                        Set pbControlBeginGroup of hArrayOfWindows[i] to True
79626>>>>>                    End
79626>>>>>>
79626>>>>>                    // Create a menu item for this action
79626>>>>>                    Get AddDynamicControl of hArrayOfWindows[i] hCommandBarControls to vItem
79627>>>>>                    Increment i
79628>>>>>                End
79628>>>>>>
79628>>>>>                Get Next_Mdi_Dialog of hClientArea False to hView // find next
79629>>>>>            Loop
79630>>>>>>
79630>>>>>        End
79630>>>>>>
79630>>>>>
79630>>>>>        Set phArrayOfWindows to hArrayOfWindows
79631>>>>>
79631>>>>>     End_Procedure
79632>>>>>     
79632>>>>>End_Class
