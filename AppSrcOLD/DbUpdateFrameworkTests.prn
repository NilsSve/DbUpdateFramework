96825>>>>>    // For debugging purposes. To print Sql statements as they are build...
96825>>>>>    Procedure DebugPrint String sStmt String sFileName
96827>>>>>        Integer iCh
96827>>>>>        Get Seq_Append_Output_Channel sFileName to iCh
96828>>>>>            Write channel iCh sStmt  
96830>>>>>        Send Seq_Close_Channel iCh
96831>>>>>    End_Procedure
96832>>>>>        
96832>>>>>    // Returns the integer number for the passed Driver ID that is 
96832>>>>>    // needed by some database API calls.
96832>>>>>    Function DriverIndex String sDriverID Returns Integer
96834>>>>>        String  sCurrentDriver
96834>>>>>        Integer iNumberOfDrivers iDriver iCount
96834>>>>>    
96834>>>>>        Move 0 to iDriver
96835>>>>>    
96835>>>>>        Get_Attribute DF_NUMBER_DRIVERS to iNumberOfDrivers
96838>>>>>        for iCount from 1 to iNumberOfDrivers
96844>>>>>>
96844>>>>>    
96844>>>>>            Get_Attribute DF_DRIVER_NAME of iCount to sCurrentDriver
96847>>>>>            If ( Uppercase(sCurrentDriver) = Uppercase(sDriverID) ) Begin
96849>>>>>                Move iCount to iDriver
96850>>>>>            End
96850>>>>>>
96850>>>>>        Loop
96851>>>>>>
96851>>>>>        
96851>>>>>        // In case it was not found, it wasn't loaded so we do that now.
96851>>>>>        If (iDriver = 0) Begin
96853>>>>>            Move False to Err
96854>>>>>            Load_Driver sDriverID
96855>>>>>            If (Err = False) Begin
96857>>>>>                Move 1 to iDriver
96858>>>>>            End
96858>>>>>>
96858>>>>>        End
96858>>>>>>
96858>>>>>    
96858>>>>>        Function_Return iDriver
96859>>>>>    End_Function 
96860>>>>>    
96860>>>>>    // Scans to see if all tables can be opened exclusivly. I.e. that nobody else is running the application.
96860>>>>>    // Returns: False if nobody else is running
96860>>>>>    //          True if at least one table is open by another process (e.g. another user is running the application) 
96860>>>>>    // N.B! Only works for Embedded DataFlex Tables! It will _not_ work for Sql tables because; these
96860>>>>>    //      tables are not locked as DataFlex tables are.
96860>>>>>    Function IsDatabaseInUse Returns Boolean
96862>>>>>        Handle  hTable
96862>>>>>        Integer iTemp
96862>>>>>        String  sRootName sOrgOpenPath sOrgFileList
96862>>>>>        Boolean bOpen bErr bAlias bOK bIsSQLTable
96862>>>>>
96862>>>>>        Get AutoConnectionIDLogin to bOK
96863>>>>>        Move 0 to hTable
96864>>>>>        Get_Attribute DF_FILE_NEXT_USED of hTable to hTable
96867>>>>>        Move False to bErr
96868>>>>>        Send Ignore_Error of Error_Object_Id DFERR_FILE_ACCESS_VIOLATION
96869>>>>>
96869>>>>>        Repeat
96869>>>>>>
96869>>>>>            Get_Attribute DF_FILE_ROOT_NAME of hTable to sRootName
96872>>>>>            
96872>>>>>            // This test is only applicable for DataFlex embedded tables; so skip test if driver based table.
96872>>>>>            Get UtilTableIsSQLByRootName sRootName to bIsSQLTable
96873>>>>>            Move False to bOpen
96874>>>>>            
96874>>>>>            // Don't bother about FlexErrs (Table 50)
96874>>>>>            If (bIsSQLTable = False and hTable <> 0 and hTable <> 50) Begin
96876>>>>>                Set Error_Report_Mode to DUF_ERROR_NO_REPORT
96877>>>>>                Open hTable 
96879>>>>>                Get_Attribute DF_FILE_OPENED of hTable to bOpen
96882>>>>>                Set Error_Report_Mode to DUF_ERROR_REPORT
96883>>>>>                If (bOpen = True) Begin                        
96885>>>>>                    // We cannot open an Alias file exclusive as it will generate an error (4177 - "File in use")
96885>>>>>                    Get UtilTableIsAlias hTable to bAlias
96886>>>>>                    If (bAlias = False) Begin
96888>>>>>                        Open hTable mode DF_EXCLUSIVE   
96890>>>>>                        Get_Attribute DF_FILE_OPENED of hTable to bOpen
96893>>>>>                        If (bOpen = False) Begin
96895>>>>>                            Move True to bErr
96896>>>>>                        End
96896>>>>>>
96896>>>>>                    End
96896>>>>>>
96896>>>>>                End
96896>>>>>>
96896>>>>>            End
96896>>>>>>
96896>>>>>            Get_Attribute DF_FILE_NEXT_USED of hTable to hTable
96899>>>>>            If (bOpen = False) Break
96902>>>>>        Until (not(hTable))
96904>>>>>
96904>>>>>        Send Trap_Error of Error_Object_Id DFERR_FILE_ACCESS_VIOLATION
96905>>>>>        Move False to Err
96906>>>>>        
96906>>>>>        Function_Return bErr
96907>>>>>    End_Function  
96908>>>>>    
96908>>>>>    // Checks if the passed connection id exists in the CLI interface.
96908>>>>>    // This might be needed by API-methods when a connection id is to be used and
96908>>>>>    // the connection id hasn't been established with the driver's CLI interface.
96908>>>>>    // NOTE: Only applicable for DAW drivers.
96908>>>>>    Function IsConnectionID String sConnectionID String sDriverID Returns Boolean
96910>>>>>        String sID 
96910>>>>>        Integer iDriver iNumConn iCount
96910>>>>>        Handle hoCLI                                            
96910>>>>>        Boolean bOK
96910>>>>>        
96910>>>>>        Get IsDAWSQLDriver sDriverID to bOK
96911>>>>>        If (bOK = False) Begin
96913>>>>>            Error DFERR_PROGRAM "Connection ID's can only be used with DAW drivers (not Mertech)."
96914>>>>>>
96914>>>>>            Function_Return False
96915>>>>>        End
96915>>>>>>
96915>>>>>        
96915>>>>>        Move False to bOK
96916>>>>>        Get phoCLIHandler to hoCLI 
96917>>>>>        If (hoCLI <> 0) Begin
96919>>>>>            Set psDriverID of hoCLI to sDriverID
96920>>>>>            Get DriverIndex of hoCLI sDriverID to iDriver
96921>>>>>            
96921>>>>>            // If driver not loaded; load it.
96921>>>>>            If (iDriver = 0) Begin
96923>>>>>                Load_Driver sDriverID
96924>>>>>                Get DriverIndex sDriverID to iDriver
96925>>>>>            End                      
96925>>>>>>
96925>>>>>            If (iDriver <> 0) Begin
96927>>>>>                Get_Attribute DF_DRIVER_NUMBER_CONNECTION_IDS of iDriver to iNumConn
96930>>>>>                Decrement iNumConn
96931>>>>>                For iCount from 0 to iNumConn
96937>>>>>>
96937>>>>>                    Get_Attribute DF_DRIVER_CONNECTION_ID of iDriver iCount to sID
96940>>>>>                    If (sID = sConnectionID) Move True to bOK
96943>>>>>                Loop
96944>>>>>>
96944>>>>>            End
96944>>>>>>
96944>>>>>        End
96944>>>>>>
96944>>>>>        
96944>>>>>        Function_Return bOK
96945>>>>>    End_Function                   
96946>>>>>    
96946>>>>>    Function IsDAWSQLDriver String sDriverID Returns Boolean
96948>>>>>        Boolean bOK
96948>>>>>        Move (sDriverID = MSSQLDRV_ID or sDriverID = DB2_DRV_ID or sDriverID = ODBC_DRV_ID) to bOK
96949>>>>>        Function_Return bOK
96950>>>>>    End_Function
96951>>>>>
96951>>>>>    Function IsMertechDriver String sDriverID Returns Boolean
96953>>>>>        Boolean bOK
96953>>>>>        Move False to bOK
96954>>>>>        Move (sDriverID = SQLFLEX or sDriverID = ORAFLEX or sDriverID = MDSPgSQL or sDriverID = MDSMySQL) to bOK
96955>>>>>        Function_Return bOK
96956>>>>>    End_Function
96957>>>>>            
96957>>>>>    Function IsMSSQLDriver Returns Boolean
96959>>>>>        Handle ho
96959>>>>>        Integer iDriverIndex
96959>>>>>        
96959>>>>>        Get DriverIndex MSSQLDRV_ID to iDriverIndex
96960>>>>>        
96960>>>>>        Function_Return (iDriverIndex <> 0)
96961>>>>>    End_Function
96962>>>>>        
96962>>>>>    // Similar to _SqlCheckCurrentDriver but generates no error and it doesn't 
96962>>>>>    // attempt to load the driver.
96962>>>>>    // Returns true if the passed driver is SQL based.        
96962>>>>>    Function IsSQLDriver String sDriverID Returns Boolean
96964>>>>>        Boolean bOK                         
96964>>>>>        Integer iDriver
96964>>>>>        
96964>>>>>        Get IsDAWSQLDriver sDriverID to bOK
96965>>>>>
96965>>>>>        If (bOK = False) Begin
96967>>>>>            Get IsMertechDriver sDriverID to bOK
96968>>>>>        End                                     
96968>>>>>>
96968>>>>>
96968>>>>>        Function_Return bOK
96969>>>>>    End_Function
96970>>>>>            
96970>>>>>    // *** Error Handler ***
96970>>>>>    //
96970>>>>>    // Note: If the cDbUpdateHandler & cDbUpdateVersion classes are used this error handler is _not_
96970>>>>>    //       used. Instead the Error_Report in the cDbUpdateHandler i used.
96970>>>>>    Procedure Error_Report Integer iErrorNumber Integer iErrorLine String sErrorText
96972>>>>>        String sText
96972>>>>>        Integer iSize iErrorMode
96972>>>>>        tSqlErrorArray aSqlErrorArray
96972>>>>>        tSqlErrorArray aSqlErrorArray
96972>>>>>        
96972>>>>>        If (pbProcessingError(Self)) Begin
96974>>>>>            Procedure_Return
96975>>>>>        End 
96975>>>>>>
96975>>>>>        
96975>>>>>        Get Error_Report_Mode to iErrorMode
96976>>>>>        If (iErrorMode = DUF_ERROR_NO_REPORT) Begin
96978>>>>>            Procedure_Return
96979>>>>>        End
96979>>>>>>
96979>>>>>
96979>>>>>        Set pbProcessingError to True
96980>>>>>        Set pbSqlError to True
96981>>>>>        Get paSqlErrorArray      to aSqlErrorArray
96982>>>>>        Move (SizeOfArray(aSqlErrorArray.sSqlErrorArray)) to iSize
96983>>>>>        Move sErrorText          to aSqlErrorArray.sSqlErrorArray[iSize]
96984>>>>>        Get psSQLStatementString to aSqlErrorArray.sSqlStatementArray[iSize]
96985>>>>>        Move iErrorNumber        to aSqlErrorArray.iSqlErrorArray[iSize]
96986>>>>>        Set paSqlErrorArray      to aSqlErrorArray
96987>>>>>        Set pbProcessingError to False
96988>>>>>    End_Procedure
96989>>>>>
