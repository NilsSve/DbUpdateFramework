92391>>>>>    // Returns an array with all ".int" files for the passed sDataPath, _except_ for the driver .int files;
92391>>>>>    // "MSSQLDRV.int", "DB2_DRV.int" & "ODBC_DRV.int".
92391>>>>>    Function SqlUtilEnumerateIntFiles String sDataPath Returns String[]
92393>>>>>        String[] sFilesData
92394>>>>>        Boolean bExists
92394>>>>>        Integer iCh
92394>>>>>        String sFileName sExt
92394>>>>>        
92394>>>>>        Get vFolderExists sDataPath to bExists
92395>>>>>        If (bExists = True) Begin
92397>>>>>            Move (ToANSI(Trim(sDataPath))) to sDataPath
92398>>>>>            Move ("dir:" + sDataPath)      to sDataPath
92399>>>>>            Get Seq_New_Channel to iCh  // get free channel for input
92400>>>>>            Direct_Input channel iCh sDataPath
92402>>>>>                Repeat
92402>>>>>>
92402>>>>>                    Readln channel iCh sFileName
92404>>>>>                    Get ParseFileExtension sFileName to sExt
92405>>>>>                    If (Uppercase(sExt) = "INT") Begin
92407>>>>>                        If (not(Uppercase(sFileName) contains "MSSQLDRV" and Uppercase(sFileName) contains "DB2_DRV" and Uppercase(sFileName) contains "ODBC_DRV")) Begin
92409>>>>>                            Move sFileName to sFilesData[SizeOfArray(sFilesData)]
92410>>>>>                        End
92410>>>>>>
92410>>>>>                    End
92410>>>>>>
92410>>>>>                Until (SeqEof = True)
92412>>>>>            Close_Input channel iCh
92414>>>>>        End
92414>>>>>>
92414>>>>>        Function_Return sFilesData
92415>>>>>    End_Function                                  
