82063>>>    Procedure SetNonOptimalWarnings
82066>>>        Integer iValue
82066>>>        Boolean bChecked
82066>>>        Get Checked_State of oNonOptimalWarnings to bChecked
82067>>>        Get Value of oNonOptFinds to iValue
82068>>>        Move (if(bChecked,iValue,0)) to giNonOptimalFindCount
82069>>>        Set Enabled_state of oNonOptFinds to bChecked
82070>>>    End_procedure
82071>>>
82071>>>    Procedure RefreshNewDD
82074>>>        Integer hDD
82074>>>        get phoCurrentDD to hDD
82075>>>        Send Fill_list of oDDRelatesTo
82076>>>        set checked_state of oAutoFill to (Auto_Fill_State(hDD)<>0)
82077>>>        set checked_state of oInherit  to (pbInheritConstraints(hDD))
82078>>>        set checked_state of oFillFromTop to (pbAutoFillFromFirst(hDD))
82079>>>        Send RefreshAll   to (phoMiscEditId(self))
82080>>>        Send RefreshAll   to (phoConstraintsEditId(Self))
82081>>>        Send RefreshAll
82082>>>
82082>>>        Send RefreshNewDD of oDDOrdering
82083>>>        Send RefreshNewDD of oFindGP
82084>>>        Set  Ordering     of oDDOrdering to (ordering(hDD))
82085>>>    End_procedure
