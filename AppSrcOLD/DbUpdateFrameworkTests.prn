92416>>>>>    // Returns a handle to the SQL server associated with the passed driver ID.
92416>>>>>    // Pass e.g. the psServer property to determine the current connection server.
92416>>>>>    // Returns a handle to the database connection, or a zero (0) if it fails.
92416>>>>>    // This handle can be used to obtain attributes about the server, such as default
92416>>>>>    // column types.
92416>>>>>    Function SqlUtilDatabaseHandle String sDriverID String sServer Returns Handle
92418>>>>>        Handle hDatabase
92418>>>>>        Integer iDriver iServers iCount
92418>>>>>        String sValue
92418>>>>>        
92418>>>>>        If (sServer = "") Begin
92420>>>>>            Function_Return 0
92421>>>>>        End 
92421>>>>>>
92421>>>>>        
92421>>>>>        Get DriverIndex sDriverID to iDriver
92422>>>>>        If (iDriver = 0) Begin
92424>>>>>            Function_Return 0
92425>>>>>        End                  
92425>>>>>>
92425>>>>>        
92425>>>>>        Get_Attribute DF_DRIVER_NUMBER_SERVERS of iDriver to iServers
92428>>>>>        For iCount from 1 to iServers
92434>>>>>>
92434>>>>>            Get_Attribute DF_DRIVER_SERVER_NAME of iDriver iCount to sValue
92437>>>>>            If (Uppercase(sValue) contains Uppercase(sServer)) Begin
92439>>>>>                Get_Attribute DF_DATABASE_ID of iDriver iCount to hDatabase
92442>>>>>            End
92442>>>>>>
92442>>>>>        Loop
92443>>>>>>
92443>>>>>                
92443>>>>>        Function_Return hDatabase
92444>>>>>    End_Function
