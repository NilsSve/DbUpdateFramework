88982>>>>>>>        Send Add_Element CI_SQLSet EN_dbTypeMySQL           "SET"
88983>>>>>>>        Send Add_Element CI_SQLSet EN_dbTypeOracle          "SET"
88984>>>>>>>        Send Add_Element CI_SQLSet EN_dbTypeDB2             "SET"
88985>>>>>>>        Send Add_Element CI_SQLSet EN_dbTypePostgre         "SET"
