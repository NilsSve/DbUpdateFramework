83018>>>>>>>//=============================================================================
83018>>>>>>>/// @Name        DF_FILE_CACHE_MODE
83018>>>>>>>/// @Description Activates or deactivates the local cache for set-oriented searches.
83018>>>>>>>///
83018>>>>>>>/// Through the DF_FILE_CACHE_MODE attribute, we can activate or deactivate the
83018>>>>>>>/// local cache. When the cache is active in a set-oriented search, a fixed
83018>>>>>>>/// number of records are pre-fetched and kept in the local cache. If a record
83018>>>>>>>/// is not found in the local cache, a new set is fetched. The number of records
83018>>>>>>>/// fetched is controlled via the DF_FILE_MAX_ROWS attribute. Set-mode vs. one-row
83018>>>>>>>/// mode is controlled via the DF_FILE_SET_MODE attribute.
83018>>>>>>>///
83018>>>>>>>/// Note: Turning off the cache can have significant detrimental effects on performance.
83018>>>>>>>///
83018>>>>>>>/// Default value: True
83018>>>>>>>///
83018>>>>>>>/// @Assumptions
83018>>>>>>>/// @Status      Public
83018>>>>>>>/// @Drivers     All
83018>>>>>>>/// @VersionNote Last Revised: 2013-07-15 by Oliver Nelson
83018>>>>>>>/// @See         DF_FILE_MAX_ROWS DF_FILE_SET_MODE
83018>>>>>>>///
83018>>>>>>>/// @Syntax Set_Attribute DF_FILE_CACHE_MODE of {FileNumber} to {variable}
83018>>>>>>>/// @Syntax Get_Attribute DF_FILE_CACHE_MODE of {FileNumber} to {variable}
83018>>>>>>>/// @Param  FileNumber            Number of the file
83018>>>>>>>/// @Param  variable              Mode for FileNumber. True for active. False for inactive.
83018>>>>>>>/// @Example
83018>>>>>>>/// Open Orderhea
83018>>>>>>>/// Set_Attribute DF_FILE_CACHE_MODE of Orderhea.File_Number to True
83018>>>>>>>/// Get_Attribute DF_FILE_CACHE_MODE of Orderhea.File_Number to boolVal
83018>>>>>>>Define DF_FILE_CACHE_MODE                           For (DF_FILE_RECORD_REREAD+9)
83018>>>>>>>
83018>>>>>>>//Currently Unsupported Attribute
83018>>>>>>>Define DF_FILE_STORAGE_BASE                         For (DF_FILE_RECORD_REREAD+10)
83018>>>>>>>
83018>>>>>>>//=============================================================================
83018>>>>>>>/// @Name        DF_FILE_STATIC
83018>>>>>>>/// @Description Activates or deactivates a special table mode where all rows
83018>>>>>>>/// from the table are loaded into a local cache. When active, all searches are
83018>>>>>>>/// done in memory and the actual table is not accessed.  The driver does not allow
83018>>>>>>>/// editing of a table in static mode.  This is a very useful feature especially
83018>>>>>>>/// when a table contains configuration or static information used in
83018>>>>>>>/// calculations, (i.e., Tax Rate tables, etc.) By keeping this table locally
83018>>>>>>>/// in memory, network round trips are saved resulting in significant
83018>>>>>>>/// performance improvements. This attribute is also useful for batch
83018>>>>>>>/// processes that make extensive table IO requests for reading static information.
83018>>>>>>>///
83018>>>>>>>/// Note: Because the entire table is loaded into memory, it is inadvisable to use
83018>>>>>>>/// this on very large tables.
83018>>>>>>>///
83018>>>>>>>/// Default value: False
83018>>>>>>>///
83018>>>>>>>/// @Assumptions
83018>>>>>>>/// @Status      Public
83018>>>>>>>/// @Drivers     All
83018>>>>>>>/// @VersionNote Last Revised: 2013-07-15 by Oliver Nelson
83018>>>>>>>/// @See
83018>>>>>>>///
83018>>>>>>>/// @Syntax Set_Attribute DF_FILE_STATIC of {FileNumber} to {variable}
83018>>>>>>>/// @Param  FileNumber            Number of the file
83018>>>>>>>/// @Param  variable              Static Mode for FileNumber. True for static. False for dynamic.
83018>>>>>>>/// @Example
83018>>>>>>>/// Open Orderhea
83018>>>>>>>/// Set_Attribute DF_FILE_STATIC of Orderhea.File_Number to True
83018>>>>>>>/// Get_Attribute DF_FILE_STATIC of Orderhea.File_Number to boolVal
83018>>>>>>>Define DF_FILE_STATIC                               For (DF_FILE_RECORD_REREAD+11)
83018>>>>>>>
83018>>>>>>>//=============================================================================
83018>>>>>>>/// @Name        DF_FILE_SERVER_NAME
83018>>>>>>>/// @Description Use this attribute to set or get the name of the database server
83018>>>>>>>/// corresponding to the specified file number. In a restructure operation
83018>>>>>>>/// this attribute may be used to permanently change the server that a filelist
83018>>>>>>>/// entry is pointing to.
83018>>>>>>>///
83018>>>>>>>/// @Assumptions
