94186>>>>>        
94186>>>>>        Get psDataPathFirstPart to sDataPath
94187>>>>>        Get vFilePathExists (sDataPath + sFileName + ".dat") to bExists
94188>>>>>        If (bExists = True) Begin      
94190>>>>>            // We also needs to check if it is an Alias file, in case the sFileName.dat exists, but it may
94190>>>>>            // still be missing from the filelist and needs to be added.
94190>>>>>            Get UtilTableNumberIsInUse iFilelistSlot to bExists
94191>>>>>            If (bExists = True) Begin
94193>>>>>                Procedure_Return
94194>>>>>            End 
94194>>>>>>
94194>>>>>            // Do _not_ use the DEF file if an alias, it will overwrite the base table data.
94194>>>>>            Else Begin
94195>>>>>                Set_Attribute DF_FILE_ROOT_NAME    of iFilelistSlot to sFileName
94198>>>>>                Set_Attribute DF_FILE_LOGICAL_NAME of iFilelistSlot to sTableName
94201>>>>>                Set_Attribute DF_FILE_DISPLAY_NAME of iFilelistSlot to sDisplayName
94204>>>>>                Procedure_Return
94205>>>>>            End
94205>>>>>>
94205>>>>>        End
94205>>>>>>
94205>>>>>    
94205>>>>>        Move (sPath + sFileName + ".def") to sDEFName
94206>>>>>        Move 0 to hTable
94207>>>>>        Move False to Err
94208>>>>>    
94208>>>>>        Structure_Start hTable DATAFLEX_ID
94209>>>>>            Load_Def sDEFName Onto hTable
94210>>>>>            Set_Attribute DF_FILE_PHYSICAL_NAME of hTable to sFileName
94213>>>>>        Structure_End hTable DF_STRUCTEND_OPT_NONE
94215>>>>>    
94215>>>>>        Move iFilelistSlot to hTable
94216>>>>>        Set_Attribute DF_FILE_ROOT_NAME    of hTable to sFileName
94219>>>>>        Set_Attribute DF_FILE_LOGICAL_NAME of hTable to sTableName
94222>>>>>        Set_Attribute DF_FILE_DISPLAY_NAME of hTable to sDisplayName
94225>>>>>    
94225>>>>>    End_Procedure      
94226>>>>>    
94226>>>>>    Function ApiTableMoveToFileSlot Integer iFromFileSlot Integer iToFileSlot String sDriverID Returns Boolean
94228>>>>>        Boolean bTmp bErr bOK 
94228>>>>>        String sTableName sDisplayName sFileName sDBOKeyWord sVal
94228>>>>>        
94228>>>>>        // We preserve the value of the Err flag, by saving its current state and resetting it before end of function.
94228>>>>>        Move Err to bTmp
94229>>>>>        Move False to Err
94230>>>>>        
94230>>>>>        Get AutoConnectionIDLogin to bOK
94231>>>>>        // First get the info for the current filelist slot:
94231>>>>>        Open iFromFileSlot                      
94233>>>>>        Get_Attribute DF_FILE_OPENED of iFromFileSlot to bOK
94236>>>>>        If (bOK = True) Begin
94238>>>>>            Get_Attribute DF_FILE_ROOT_NAME    of iFromFileSlot to sFileName
94241>>>>>            Get_Attribute DF_FILE_LOGICAL_NAME of iFromFileSlot to sTableName
94244>>>>>            Get_Attribute DF_FILE_DISPLAY_NAME of iFromFileSlot to sDisplayName
94247>>>>>            
94247>>>>>            //...then move it.
94247>>>>>            Set_Attribute DF_FILE_ROOT_NAME    of iToFileSlot to sFileName
94250>>>>>            Set_Attribute DF_FILE_LOGICAL_NAME of iToFileSlot to sTableName
94253>>>>>            Set_Attribute DF_FILE_DISPLAY_NAME of iToFileSlot to sDisplayName
94256>>>>>            
94256>>>>>            //...and finally remove the old filelist values.
94256>>>>>            Set_Attribute DF_FILE_ROOT_NAME    of iFromFileSlot to ""
94259>>>>>            Set_Attribute DF_FILE_LOGICAL_NAME of iFromFileSlot to ""
94262>>>>>            Set_Attribute DF_FILE_DISPLAY_NAME of iFromFileSlot to ""
94265>>>>>        End
94265>>>>>>
94265>>>>>        Close iFromFileSlot
94266>>>>>        
94266>>>>>        Move Err to bErr                     
94267>>>>>        Move bTmp to Err
94268>>>>>        Function_Return (bErr = False)
94269>>>>>    End_Function
