85410>>>>>        If (eUpdateMode<>umPromptNonInvoking) Begin
85412>>>>>            
85412>>>>>            If (eUpdateMode=umPromptValue) Begin
85414>>>>>                Send OnMoveValueOutByValue
85415>>>>>            End
85415>>>>>>
85415>>>>>            Else If (eUpdateMode=umPromptCustom) Begin
85418>>>>>                Send OnMoveValueOutByCustom
85419>>>>>            End
85419>>>>>>
85419>>>>>                Get phmPromptUpdateCallback to hmCallBack
85420>>>>>                If hmCallBack Begin
85422>>>>>                    Send hmCallBack of hoInvokingObject Self
85423>>>>>                End
85423>>>>>>
85423>>>>>        End
85423>>>>>>
85423>>>>>
85423>>>>>        Send Close_Panel
85424>>>>>    End_Procedure
