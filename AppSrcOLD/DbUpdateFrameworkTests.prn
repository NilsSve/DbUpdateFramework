84517>>>>>
84517>>>>>    //****************************************************************************
84517>>>>>    // If workspaces are used, we will send the message EnumerateWorkspaceData
84517>>>>>    // To the workspace object passing the an object and message To send back
84517>>>>>    // To this object. It is expected that the workspace object will send this
84517>>>>>    // message for every line Of information it wants displayed (passing the
84517>>>>>    // information To be displayed
84517>>>>>    //****************************************************************************
84517>>>>>    Register_Procedure EnumerateWorkspaceData Integer hObjId Integer hmMessId
84517>>>>>
84517>>>>>    Procedure Show_ServicePack
84519>>>>>        String sKey sVersion sDataFlex
84519>>>>>        Handle hoRegistry
84519>>>>>        Boolean bExists bOpened
84519>>>>>
84519>>>>>        Move "DataFlex"        to sDataFlex
84520>>>>>
84520>>>>>        Get Create U_cRegistry to hoRegistry
84521>>>>>        Set phRootKey of hoRegistry to HKEY_LOCAL_MACHINE
84522>>>>>        Set pfAccessRights of hoRegistry to KEY_READ
84523>>>>>        Get KeyExists of hoRegistry "SOFTWARE\Wow6432Node" to bExists
84524>>>>>
84524>>>>>        If (bExists) Begin
84526>>>>>            Move ("SOFTWARE\Wow6432Node\Data Access Worldwide\" + sDataFlex + "\" + SysConf (SYSCONF_DATAFLEX_REV)) to sKey
84527>>>>>        End
84527>>>>>>
84527>>>>>        Else Begin
84528>>>>>            Move ("SOFTWARE\Data Access Worldwide\"             + sDataFlex + "\" + SysConf (SYSCONF_DATAFLEX_REV)) to sKey
84529>>>>>        End
84529>>>>>>
84529>>>>>        Get KeyExists of hoRegistry sKey to bExists
84530>>>>>        If (bExists) Begin
84532>>>>>            Get OpenKey of hoRegistry sKey to bOpened
84533>>>>>            If (bOpened) Begin
84535>>>>>                Get ValueExists of hoRegistry "CurrentVersionDescription" to bExists
84536>>>>>                If (bExists) Begin
84538>>>>>                    Get ReadString of hoRegistry "CurrentVersionDescription" to sVersion
84539>>>>>                End
84539>>>>>>
84539>>>>>                Send CloseKey of hoRegistry
84540>>>>>            End
84540>>>>>>
84540>>>>>        End
84540>>>>>>
84540>>>>>        Send Destroy of hoRegistry
84541>>>>>
84541>>>>>        If (sVersion <> "") Begin
84543>>>>>           Send AppendTextLn sVersion
84544>>>>>           Send AppendTextLn ""
84545>>>>>        End
84545>>>>>>
84545>>>>>    End_Procedure
84546>>>>>
84546>>>>>    Procedure Show_WorkspaceInformation
84548>>>>>        Integer hoWorkspace
84548>>>>>
84548>>>>>        If (ghoApplication <> 0) Begin
84550>>>>>            Get phoWorkspace of ghoApplication to hoWorkspace
84551>>>>>            If (hoWorkspace <> 0) Begin
84553>>>>>                Send EnumerateWorkspaceData of hoWorkspace Self msg_AppendTextLn
84554>>>>>            End
84554>>>>>>
84554>>>>>        End
84554>>>>>>
84554>>>>>    End_Procedure
84555>>>>>
84555>>>>>    //****************************************************************************
84555>>>>>    // If connection ids are used, we will send the message EnumerateConnections
84555>>>>>    // to the connection manager object passing the an object and message to send 
84555>>>>>    // back to this object. It is expected that the connection manager object will 
84555>>>>>    // send this message for every line Of information it wants displayed (passing 
84555>>>>>    // the information To be displayed
84555>>>>>    //****************************************************************************
84555>>>>>    Register_Procedure EnumerateConnections Integer hObjId Integer hmMessId
84555>>>>>
84555>>>>>    Procedure Show_ConnectionIdInformation
84557>>>>>        If (ghoConnection > 0) Begin
84559>>>>>            Send EnumerateConnections of ghoConnection Self (RefProc(AppendTextLn))
84560>>>>>            Send AppendTextLn ""
84561>>>>>        End
84561>>>>>>
84561>>>>>    End_Procedure
