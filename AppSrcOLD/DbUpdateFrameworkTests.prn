85837>>>>>>>    Integer iFileDummyUpdateColumn // Init value to -1 if not exists (value can be in range 1 - number of columns)  
85837>>>>>>>    Integer iFileBlockSize         // Init value to -1 if not exists  
85837>>>>>>>    Integer iFileMaxRowsFetched    // Init value to -1 if not exists  
85837>>>>>>>    Integer iFileGetRidAfterCreate // Init value to -1. But is boolean! 
85837>>>>>>>    Integer iFileJitBinding        // Init value to -1. But is boolean!  
85837>>>>>>>    String sRefindAfterSave        // Yes or No (how to handle?) 
85837>>>>>>>    String sSystemFile             // Yes or No (how to handle?) 
85837>>>>>>>    String sFileIndexTablespace  
85837>>>>>>>    String sFileLongTablespace
85837>>>>>>>    String sTableTablespace
