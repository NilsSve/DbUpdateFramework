90011>>>>>>>        Get Private.pSQLConnection to SQLConnection
90012>>>>>>>        Function_Return SQLConnection
90013>>>>>>>    End_Function
90014>>>>>>>    
90014>>>>>>>    Procedure Set psConnectionID String sValue
90016>>>>>>>        tSQLConnection SQLConnection                                       
90016>>>>>>>        tSQLConnection SQLConnection                                       
90016>>>>>>>        Integer iIndex
90016>>>>>>>        
90016>>>>>>>        Get Private.pSQLConnection to SQLConnection
90017>>>>>>>        If (SQLConnection.sConnectionID = "") Begin
90019>>>>>>>            Move sValue to SQLConnection.sConnectionID
90020>>>>>>>        End
90020>>>>>>>>
90020>>>>>>>        
90020>>>>>>>        // Else we might want to change the current connection ID
90020>>>>>>>        Else If (SQLConnection.sConnectionID <> "" and SQLConnection.sConnectionID <> sValue) Begin   
90023>>>>>>>            Move False to Err
90024>>>>>>>            Logout SQLConnection.sDriverID  
90025>>>>>>>            // This will also make a login to the new server.
90025>>>>>>>            Get SQLIniFileConnectionID of (phoSQLConnectionIniFile(Self)) sValue to SQLConnection
90026>>>>>>>        End
90026>>>>>>>>
90026>>>>>>>        Set pSQLConnection to SQLConnection
90027>>>>>>>    End_Procedure
