93142>>>>>    // L„s f”rst .int fil och spara alla FIELD_INDEX + FIELD_NUMBER + FIELD_RELATED_FILE + FIELD_RELATED_FIELD i en struct array,
93142>>>>>    // INDEX_NUMBER + INDEX_NAME (string)
93142>>>>>    // samt spara undan .int "header rader" s† de kan skrivas ut senare.
93142>>>>>    // Check if index exists:    
93142>>>>>    //IF EXISTS (
93142>>>>>    //   SELECT 'X'
93142>>>>>    //   from sysindexes
93142>>>>>    //   WHERE id = (SELECT OBJECT_ID('accounts'))
93142>>>>>    //     and name = 'idx_acct_no'
93142>>>>>    //)          
93142>>>>>    //
93142>>>>>    // Helper function to create a SQL statement like;
93142>>>>>    // "SELECT * FROM SYS.INDEXES WHERE NAME = MyIndexName AND OBJECT_ID = OBJECT_ID([MySchmaName].[MyTableName])"
93142>>>>>    // Used for checking if an index exists.
93142>>>>>    Function _SqlQueryIfIndexExists String sSchemaName String sTableName String sIndexName Returns String
93144>>>>>        String sRetval sSelect sFrom sSysIndexes sWhere sObjectID sAnd sName
93144>>>>>        
93144>>>>>        Get _SqlFindKeyWord CI_SQLSelect to sSelect
93145>>>>>        Get _SqlFindKeyWord CI_SQLFrom to sFrom
93146>>>>>        Get _SqlFindKeyWord CI_SQLSysIndexes to sSysIndexes
93147>>>>>        Get _SqlFindKeyWord CI_SQLWhere to sWhere
93148>>>>>        Get _SqlFindKeyWord CI_SQLObjectID to sObjectID
93149>>>>>        Get _SqlFindKeyWord CI_SQLAND to sAnd
93150>>>>>        Get _SqlFindKeyWord CI_SQLName to sName
93151>>>>>        
93151>>>>>        Move (sSelect * String("*") * sFrom * sSysIndexes * sWhere * sName * "=" * sIndexName * sAnd * sObjectID * "=([" + sSchemaName + "].[" + sTableName + "])") to sRetval
93152>>>>>        
93152>>>>>        Function_Return sRetval
93153>>>>>    End_Function  
93154>>>>>    
93154>>>>>    // Formats a columns iLenght & iDecimal parameters as SQL expects them in a string. 
93154>>>>>    // E.g. (4,2), where 4 is the iLength and 2 the iDecimals param.
93154>>>>>    Function _SqlFormatLengthAndDecimalAsString Integer iLength Integer iDecimals Returns String
93156>>>>>        String sRetval
93156>>>>>        If (iLength <> 0) Begin
93158>>>>>            Move ("(" + String(iLength)) to sRetval
93159>>>>>            If (iDecimals <> 0) Begin
93161>>>>>                Move (sRetval + "," + String(iDecimals)) to sRetval
93162>>>>>            End
93162>>>>>>
93162>>>>>            Move (sRetval + ")") to sRetval
93163>>>>>        End
93163>>>>>>
93163>>>>>        Function_Return sRetval
93164>>>>>    End_Function
