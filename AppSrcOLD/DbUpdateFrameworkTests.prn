93667>>>>>            Set_Attribute DF_FILE_LOGICAL_NAME  of hTable to ""
93670>>>>>            Set_Attribute DF_FILE_DISPLAY_NAME  of hTable to ""
93673>>>>>            Function_Return (Err = False) // And we're done.
93674>>>>>        End
93674>>>>>>
93674>>>>>        
93674>>>>>        If (sDriverID <> DATAFLEX_ID) Begin
93676>>>>>            Set_Attribute DF_FILE_ROOT_NAME of hTable to (sDriverID + ":" + sRootName)
93679>>>>>        End 
93679>>>>>>
93679>>>>>        Else Begin
93680>>>>>            Set_Attribute DF_FILE_ROOT_NAME of hTable to sRootName
93683>>>>>        End
93683>>>>>>
93683>>>>>            
93683>>>>>        Set_Attribute DF_FILE_LOGICAL_NAME  of hTable to sLogicalName
93686>>>>>        
93686>>>>>        If (sDriverID <> DATAFLEX_ID and not(Uppercase(sDisplayName) contains "DBO.")) Begin
93688>>>>>            Set_Attribute DF_FILE_DISPLAY_NAME  of hTable to ("dbo." + sDisplayName)
93691>>>>>        End
93691>>>>>>
93691>>>>>        Else Begin
93692>>>>>            Set_Attribute DF_FILE_DISPLAY_NAME  of hTable to sDisplayName
93695>>>>>        End
93695>>>>>>
93695>>>>>        
93695>>>>>        Function_Return (Err = False)
93696>>>>>    End_Function
