97972>>>>>>>
97972>>>>>>>    // low level event sent from windows.
97972>>>>>>>    Procedure OnWmMouseWheel Integer wParam Integer lParam
97974>>>>>>>        Integer iWheelDelta iKeys iDelta iClicks
97974>>>>>>>        Move (low(abs(wParam))) to iKeys           // any keys down when pressed
97975>>>>>>>        Move (hi(abs(wParam))) to iDelta           // number of click units
97976>>>>>>>        If (wParam<0) Begin
97978>>>>>>>            Move (-iDelta) to iDelta     // can be up or down
97979>>>>>>>        End
97979>>>>>>>>
97979>>>>>>>        Get  piWheelDelta to iWheelDelta           // Current accumulated micro clicks
97980>>>>>>>        Move (iWheelDelta+iDelta) to iWheelDelta
97981>>>>>>>        // C_WHEELDATA is 120 as defined by MS as the delta to react to. Once click is usually 120
97981>>>>>>>        Move (iWheelDelta/C_WHEELDELTA) to iClicks // Number of clicks to react to
97982>>>>>>>        Set  piWheelDelta to (mod(iWheelDelta,C_WHEELDELTA)) // remainder unused microclicks
97983>>>>>>>        // If we have enough Clicks send OnMouseWheel
97983>>>>>>>        If (iClicks<>0) Begin
97985>>>>>>>            Send OnMouseWheel iClicks iKeys
97986>>>>>>>        End
97986>>>>>>>>
97986>>>>>>>        // tell windows that we've handled the event.    
97986>>>>>>>        Set Windows_Override_State to True    
97987>>>>>>>    End_Procedure
97988>>>>>>>
97988>>>>>>>
97988>>>>>>>    // should be sent by DF message OnWMMouseWheel , which is sent by WM_MOUSEWHEEL
97988>>>>>>>    Procedure OnMouseWheel Integer iClicks Integer iKey
97990>>>>>>>        Integer iLineScrollUnit
97990>>>>>>>        Get piLineScrollUnit to iLineScrollUnit
97991>>>>>>>        Send VScroll (-iClicks*iLineScrollUnit*2) // (If(iClicks>0,False,True)) (abs(iClicks))
97992>>>>>>>    End_Procedure
