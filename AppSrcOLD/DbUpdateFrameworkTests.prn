84318>>>>>// *** Struct Declarations: ***
84318>>>>>Struct tWinMemoryStatusEx
84318>>>>>    UInteger dwLength
84318>>>>>    UInteger dwMemoryLoad
84318>>>>>    UBigInt ullTotalPhys
84318>>>>>    UBigInt ullAvailPhys
84318>>>>>    UBigInt ullTotalPageFile
84318>>>>>    UBigInt ullAvailPageFile
84318>>>>>    UBigInt ullTotalVirtual
