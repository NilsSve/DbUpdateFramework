85115>>>                Send Add_Line sParam8
85116>>>            End
85116>>>>
85116>>>            Else If (iArgs > 8 and sParam8  <> "") Begin
85119>>>                Send Add_LineLn sParam8
85120>>>            End
85120>>>>
85120>>>
85120>>>            If (iArgs = 9 and sParam9  <> "") Begin
