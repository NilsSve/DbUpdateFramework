90919>>>>>>>>Function ParseKeyWord String sConnect String sKeyWord Returns String
90921>>>>>>>>    Integer iStart iEnd
90921>>>>>>>>    String sRetval
90921>>>>>>>>
90921>>>>>>>>    Move (Trim(sConnect)) to sConnect
90922>>>>>>>>    Move (Pos(Uppercase(sKeyWord), Uppercase(sConnect)))  to iStart
90923>>>>>>>>    If (iStart = 0) Begin
90925>>>>>>>>        Function_Return ""
90926>>>>>>>>    End
90926>>>>>>>>>
90926>>>>>>>>    Move (Left(sConnect, (iStart -1 + Length(sKeyWord)))) to sRetval
90927>>>>>>>>    Move (Replace(sRetval, sConnect, "")) to sRetval 
90928>>>>>>>>    If (sKeyWord = Uppercase(CS_SQLConnectionIDText)) Begin
90930>>>>>>>>        Move (Pos(",", sRetval))          to iEnd
90931>>>>>>>>    End
90931>>>>>>>>>
90931>>>>>>>>    Else Begin
90932>>>>>>>>        Move (Pos(";", sRetval))          to iEnd
90933>>>>>>>>    End                                          
90933>>>>>>>>>
90933>>>>>>>>    If (iEnd = 0 and (sRetval contains ",")) Begin
90935>>>>>>>>        Move (Pos(",", sRetval))          to iEnd 
90936>>>>>>>>        Decrement iEnd
90937>>>>>>>>    End
90937>>>>>>>>>
90937>>>>>>>>    If (iEnd <> 0) Begin
90939>>>>>>>>        Move (Left(sRetval, (iEnd -1)))   to sRetval
90940>>>>>>>>    End
90940>>>>>>>>>
90940>>>>>>>>    Move (Replace("=", sRetval, ""))      to sRetval
90941>>>>>>>>
90941>>>>>>>>    Function_Return (Trim(sRetval))
90942>>>>>>>>End_Function
