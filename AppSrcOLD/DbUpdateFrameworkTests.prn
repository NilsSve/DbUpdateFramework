92120>>>>>    // Returns a string array with all tables for the current database.
92120>>>>>    Function SqlUtilEnumerateTables String sDriverID Returns String[]
92122>>>>>        String[] sReturnArray sArray
92124>>>>>        String sServer sDatabase sConnectionString sSelect sSchema     
92124>>>>>        Integer iSize iCount
92124>>>>>        Boolean bOK
92124>>>>>
92124>>>>>        If (sDriverID = DATAFLEX_ID) Begin
92126>>>>>            Function_Return sArray        
92127>>>>>        End                       
92127>>>>>>
92127>>>>>        
92127>>>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
92128>>>>>        If (bOK = False) Begin
92130>>>>>            Function_Return sReturnArray
92131>>>>>        End    
92131>>>>>>
92131>>>>>        
92131>>>>>        Get psConnectionString to sConnectionString
92132>>>>>        Get psDatabase to sDatabase                               
92133>>>>>        Get psSchema   to sSchema                                                                              
92134>>>>>                                                                                                              
92134>>>>>        Case Begin
92134>>>>>            Case (sDriverID = MSSQLDRV_ID)
92136>>>>>                Get _SqlTableArrayDAW to sReturnArray
92137>>>>>                Case Break                                                            
92138>>>>>            
92138>>>>>            Case (sDriverID = DB2_DRV_ID)
92141>>>>>                Get _SqlTableArrayDAW to sReturnArray
92142>>>>>                Case Break
92143>>>>>            
92143>>>>>            Case (sDriverID = ODBC_DRV_ID)
92146>>>>>                Get _SqlTableArrayDAW to sReturnArray
92147>>>>>                Case Break
92148>>>>>            
92148>>>>>            Case (sDriverID = SQLFLEX)
92151>>>>>                Move ("SELECT TABLE_NAME FROM" * sDatabase + ".INFORMATION_SCHEMA.TABLES WHERE TABLE_TYPE != 'VIEW'") to sSelect
92152>>>>>                Get SqlEnumerateEsqlMertech sSelect to sReturnArray
92153>>>>>                Case Break
92154>>>>>            
92154>>>>>            Case (sDriverID = MDSMySQL)                                   
92157>>>>>                Move ("SELECT TABLE_NAME from INFORMATION_SCHEMA.TABLES where TABLE_SCHEMA = '" + sDatabase + "' and TABLE_TYPE = 'BASE TABLE' order by TABLE_NAME") to sSelect
92158>>>>>                Get SqlEnumerateEsqlMertech sSelect to sReturnArray
92159>>>>>                Case Break
92160>>>>>            
92160>>>>>            Case (sDriverID = MDSPgSQL)                                          
92163>>>>>                Move "select tablename, schemaname from pg_catalog.pg_tables order by tablename"  to sSelect
92164>>>>>                Get SqlEnumerateEsqlMertech sSelect "" to sReturnArray
92165>>>>>                Case Break            
92166>>>>>            
92166>>>>>            Case (sDriverID = ORAFLEX)                                          
92169>>>>>                Move "SELECT table_name from user_tables" to sSelect  
92170>>>>>                Get SqlEnumerateEsqlMertech sSelect to sArray
92171>>>>>                Move (SizeOfArray(sArray)) to iSize
92172>>>>>                Decrement iSize
92173>>>>>                For iCount from 0 to iSize
92179>>>>>>
92179>>>>>                    If (not(sArray[iCount] contains "$")) Begin
92181>>>>>                        Move sArray[iCount] to sReturnArray[SizeOfArray(sReturnArray)]
92182>>>>>                    End
92182>>>>>>
92182>>>>>                Loop
92183>>>>>>
92183>>>>>                Case Break            
92184>>>>>
92184>>>>>            Case Else     
92184>>>>>                Error DFERR_PROGRAM "Unsupported driver passed to SqlUtilEnumerateTables function."
92185>>>>>>
92185>>>>>                Case Break
92186>>>>>        Case End
92186>>>>>        
92186>>>>>        Function_Return sReturnArray
92187>>>>>    End_Function
