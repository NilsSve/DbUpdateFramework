91280>>>>>        Get IsSQLDriver sDriverID to bIsSQLDriver
91281>>>>>        If (bIsSQLDriver = False) Begin
91283>>>>>            Function_Return False
91284>>>>>        End
91284>>>>>>
91284>>>>>
91284>>>>>        Move Err to bErr
91285>>>>>        Move False to bErr                                      
91286>>>>>        
91286>>>>>        // There seems to be a problem with the ODBC_DRV driver that sometimes
91286>>>>>        // inserts randomly character(10) and spaces, so we correct from that here:
91286>>>>>        Move (Replaces(Character(10), Trim(sValue), "")) to sValue                   
91287>>>>>        
91287>>>>>        Set_Attribute DF_FIELD_DEFAULT_VALUE of hTable iColumn to sValue
91290>>>>>        Move (not(Err)) to bOK
