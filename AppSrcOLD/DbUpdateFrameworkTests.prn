95235>>>>>    Function UtilDeleteCacheFile String sTableName Returns Boolean
95237>>>>>        String sDataPath sDriverID
95237>>>>>        Boolean bMertechDriver bOK  
95237>>>>>        Integer iPos
95237>>>>>        
95237>>>>>        If (sTableName contains ".") Begin
95239>>>>>            Move (Pos(".", sTableName)) to iPos
95240>>>>>            Move (Mid(sTableName, 999, (iPos +1))) to sTableName    
95241>>>>>        End                                                     
95241>>>>>>
95241>>>>>        
95241>>>>>        Get psDriverID to sDriverID
95242>>>>>        Get psDataPathFirstPart to sDataPath 
95243>>>>>        Get IsMertechDriver sDriverID to bMertechDriver
95244>>>>>        // First delete the cache file:
95244>>>>>        If (bMertechDriver = False) Begin
95246>>>>>            Get vDeleteFile (sDataPath + sTableName + ".cch") to bOK
95247>>>>>        End 
95247>>>>>>
95247>>>>>        Else Begin
95248>>>>>            Get _MertechDeleteTDFile sTableName to bOK
95249>>>>>        End                
95249>>>>>>
95249>>>>>        
95249>>>>>        Function_Return bOK
95250>>>>>    End_Function
95251>>>>>
95251>>>>>    // Changes source code files.
95251>>>>>    // Pass a file name with full path and a value to search for, together with the value
95251>>>>>    // to change to. Can e.g. be used for changing all .int files from using a fixed server name,
95251>>>>>    // to use a Connection ID. 
95251>>>>>    // Sample: Get UtilChangeSourceCodeLine "C:\DataFlex 18.2 Examples\Order Entry\Data\Order.int" "SERVER_NAME SERVER=(local)\SQLEXPRESS1" "SERVER_NAME DFCONNID=ChinookDb"
95251>>>>>    // Pass "True" for the bShowResult if you want to see the result while it works. Showln will then be used for output
95251>>>>>    // Returns True if no errors occured. 
95251>>>>>    Function UtilChangeSourceCodeLine String sFileName String sChangeFrom String sChangeTo Boolean bShowResult Returns Boolean
95253>>>>>        Integer iCh iRow iItems iCount
95253>>>>>        String sValue sRow
95253>>>>>        String[] sFileArray
95254>>>>>        Boolean bExists
95254>>>>>    
95254>>>>>        Move False to Err
95255>>>>>        Move 0 to iRow
95256>>>>>    
95256>>>>>        Get vFilePathExists sFileName to bExists
95257>>>>>        If (bExists = False) Begin
95259>>>>>            If (bShowResult = True) Begin
95261>>>>>                Showln "File does not exist: " sFileName
95264>>>>>            End
95264>>>>>>
95264>>>>>            Function_Return False
95265>>>>>        End
95265>>>>>>
95265>>>>>    
95265>>>>>        Get Seq_Open_Input_Channel sFileName to iCh
95266>>>>>        If (iCh < 1) Begin
95268>>>>>            Function_Return False
95269>>>>>        End
95269>>>>>>
95269>>>>>        
95269>>>>>        If (bShowResult = True) Begin  
95271>>>>>            Showln ""
95273>>>>>            Showln "sFileName = " sFileName
95276>>>>>            Showln "sChangeFrom = " sChangeFrom " sChangeTo = " sChangeTo
95281>>>>>        End
95281>>>>>>
95281>>>>>        
95281>>>>>        While (not(SeqEof))
95285>>>>>            Readln channel iCh sRow
95287>>>>>            If (Uppercase(sRow) contains Uppercase(sChangeFrom)) Begin 
95289>>>>>                If (bShowResult = True) Begin
95291>>>>>                    Showln "Changed from: " sRow " to: " sChangeTo
95296>>>>>                End
95296>>>>>>
95296>>>>>                // Change the whole line to the new connection id:
95296>>>>>                Move sChangeTo to sRow
95297>>>>>                // Move (Replaces(sChangeFrom, sRow, sChangeTo)) to sValue
95297>>>>>            End
95297>>>>>>
95297>>>>>            Move sRow to sFileArray[iRow]
95298>>>>>            Increment iRow
95299>>>>>        End
95300>>>>>>
95300>>>>>        Send Seq_Close_Channel iCh
95301>>>>>        
95301>>>>>        Sleep 1 // Wait for Windows to close the file
95302>>>>>    
95302>>>>>        Get Seq_Open_Output_Channel sFileName to iCh
95303>>>>>        If (iCh < 1) Begin
95305>>>>>            Function_Return False
95306>>>>>        End
95306>>>>>>
95306>>>>>        Move (SizeOfArray(sFileArray)) to iItems
95307>>>>>        Decrement iItems
95308>>>>>    
95308>>>>>        For iCount from 0 to iItems
95314>>>>>>
95314>>>>>            Move sFileArray[iCount] to sValue
95315>>>>>            Writeln channel iCh sValue
95318>>>>>        Loop
95319>>>>>>
95319>>>>>        Send Seq_Close_Channel iCh
95320>>>>>    
95320>>>>>        Function_Return (Err = False)
95321>>>>>    End_Function
95322>>>>>    
95322>>>>>    // This might be needed by API-methods when a connection id is to be used and
95322>>>>>    // the connection ID hasn't been established with the driver's CLI interface.
95322>>>>>    // NOTE: Only applicable for DAW drivers, as Mertech drivers doesn't use connection ID's.
95322>>>>>    Function UtilCreateConnectionID String sConnectionID Returns Boolean
95324>>>>>        String sConnectionString sDriverID
95324>>>>>        Boolean bOK bSilent bDawDriver
95324>>>>>        Handle hoCLI
95324>>>>>        
95324>>>>>        Move False to bOK   
95325>>>>>        Get psDriverID to sDriverID
95326>>>>>        Get IsDAWSQLDriver sDriverID to bDawDriver
95327>>>>>        If (bDawDriver = False) Begin
95329>>>>>            Error DFERR_PROGRAM "The UtilCreateConnectionID function is only available for DAW drivers. (Not Mertech)."
95330>>>>>>
95330>>>>>            Function_Return False
95331>>>>>        End
95331>>>>>>
95331>>>>>        
95331>>>>>        Get psConnectionString to sConnectionString
95332>>>>>        Get pbSilentLogin      to bSilent
95333>>>>>        
95333>>>>>        Get phoCLIHandler to hoCLI 
95334>>>>>        If (hoCLI <> 0) Begin
95336>>>>>            Set psDriverID of hoCLI to sDriverID
95337>>>>>            Get CreateConnectionID of hoCLI sConnectionID sConnectionString bSilent to bOK
95338>>>>>        End
95338>>>>>>
95338>>>>>        
95338>>>>>        Function_Return (bOK = False)
95339>>>>>    End_Function
95340>>>>>
95340>>>>>    // This message creates an error log in the "Home" folder named "SQLErrorLog.txt",
95340>>>>>    // and opens it in "notepad.exe".
95340>>>>>    // Note: This is _not_ used by the cDbUpdateHandler & cDbUpdateVersion classes!
95340>>>>>    //       Instead the cDbUpdateLogFile's WriteErrorLog & ShowErrorLog are then used.
95340>>>>>    Procedure UtilShowErrorList
95342>>>>>        tSqlErrorArray aSqlErrorArray 
95342>>>>>        tSqlErrorArray aSqlErrorArray 
95342>>>>>        Integer iRows iCount iCh iErrorNum
95342>>>>>        String sPath sFileName sErrorTxt sStatement
95342>>>>>        
95342>>>>>        Get psHome of (phoWorkspace(ghoApplication)) to sPath
95343>>>>>        Get vFolderFormat sPath to sPath
95344>>>>>        Move "SQLErrorLog.txt"  to sFileName
95345>>>>>        Get Seq_Open_Output_Channel (sPath + sFileName) to iCh
95346>>>>>            Get paSqlErrorArray to aSqlErrorArray
95347>>>>>            Move (SizeOfArray(aSqlErrorArray.sSqlErrorArray)) to iRows
95348>>>>>            If (iRows > 0) Begin
95350>>>>>                Decrement iRows
95351>>>>>                for iCount from 0 to iRows
95357>>>>>>
95357>>>>>                    Move aSqlErrorArray.sSqlErrorArray[iCount]      to sErrorTxt
95358>>>>>                    Move aSqlErrorArray.sSqlStatementArray[iCount]  to sStatement
95359>>>>>                    Move aSqlErrorArray.iSqlErrorArray[iCount]      to iErrorNum
95360>>>>>                    Writeln channel iCh "Error No: " iErrorNum " Error Text: " sErrorTxt
95366>>>>>                    Writeln channel iCh "SQL Statement: " sStatement
95370>>>>>                Loop
95371>>>>>>
95371>>>>>            End
95371>>>>>>
95371>>>>>        Send Seq_Close_Channel iCh
95372>>>>>        
95372>>>>>        If (iRows > 0) Begin
95374>>>>>            Runprogram Background "Notepad.exe" (sPath + sFileName)
95375>>>>>        End
95375>>>>>>
95375>>>>>    End_Procedure
