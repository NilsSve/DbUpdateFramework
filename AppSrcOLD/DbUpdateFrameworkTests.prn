91104>>>>>        Get UtilDeleteCacheFile sTableName to iRetval
91105>>>>>            
91105>>>>>        Get piDbType to iDbType
91106>>>>>        Get _SqlProperTableName sTableName to sTableName
91107>>>>>        Get _SqlFindKeyWord CI_SQLDropTable iDbType to sDropTable
91108>>>>>        Move (sDropTable * String(sTableName)) to sSQLString
91109>>>>>        
91109>>>>>        Move False to Err               
91110>>>>>        Send SqlUtilExecuteQuery sSQLString sDriverID
91111>>>>>    
91111>>>>>        // We also need to remove the cache-file since the table has been changed
91111>>>>>        Get UtilDeleteCacheFile sTableName to bOK
91112>>>>>    
91112>>>>>        Function_Return (Err = False)
91113>>>>>    End_Function 
91114>>>>>    
91114>>>>>    // First deletes the data cache file and then drops the passed data table. 
91114>>>>>    Function SqlTableRemoveByTableName String sTableName Returns Boolean
91116>>>>>        String sSQLString sPath sDropTable sVal sSchema sDriverID 
91116>>>>>        Integer iRetval iDbType
91116>>>>>        Boolean bMertechDriver bOK
91116>>>>>        
91116>>>>>        Get psDriverID to sDriverID
91117>>>>>        Get IsMertechDriver sDriverID to bMertechDriver
91118>>>>>        Get psDataPathFirstPart to sPath               
91119>>>>>        Get UtilDeleteCacheFile sTableName to iRetval
91120>>>>>        
91120>>>>>        Get piDbType to iDbType
91121>>>>>        Get _SqlFindKeyWord CI_SQLDropTable iDbType to sDropTable 
91122>>>>>        Get psSchema to sSchema
91123>>>>>        If (sSchema = "") Begin
91125>>>>>            Get _SqlFindKeyWord CI_SQLDBO to sSchema 
91126>>>>>        End
91126>>>>>>
91126>>>>>        Move (Uppercase(sTableName)) to sVal
91127>>>>>        If (not(sVal contains (sSchema + "."))) Begin    
91129>>>>>            Move (Lowercase(sSchema) + "." + sTableName) to sTableName
91130>>>>>        End    
91130>>>>>>
91130>>>>>        Move (sDropTable * String(sTableName)) to sSQLString
91131>>>>>        
91131>>>>>        Move False to Err               
91132>>>>>        Send SqlUtilExecuteQuery sSQLString sDriverID
91133>>>>>    
91133>>>>>        // We also need to remove the cache-file since the table has been changed
91133>>>>>        Get UtilDeleteCacheFile sTableName to bOK
91134>>>>>    
91134>>>>>        Function_Return (Err = False)
91135>>>>>    End_Function 
