82545>>>>>>>//*****************************************************************************
82545>>>>>>>//*** MSSQLDRV.PKG                                                          ***
82545>>>>>>>//***                                                                       ***
82545>>>>>>>//*** Author: Ben Weijers                                                   ***
82545>>>>>>>//***         Data Access Nederland                                         ***
82545>>>>>>>//***         29 June 1998                                                  ***
82545>>>>>>>//***                                                                       ***
82545>>>>>>>//***                                                                       ***
82545>>>>>>>//*** Purpose:                                                              ***
82545>>>>>>>//***   Package that declares MS SQL driver constants and functions.        ***
82545>>>>>>>//****                                                                      ***
82545>>>>>>>//***   This package can be used by developers who want to add Data Access  ***
82545>>>>>>>//***   MS SQL Client specific code to a DataFlex application.              ***
82545>>>>>>>//***   Updated:  June 4th 2012 (Current CK build: 5.1.0.96)                ***
82545>>>>>>>//***             Changed EnumerateServers function to use the highest      ***
82545>>>>>>>//***             available SQL Server client driver.                       ***
82545>>>>>>>//***             Moved SQL Server client constants from cli.pkg to         ***
82545>>>>>>>//***             mssqldrv.pkg                                              ***
82545>>>>>>>//***   Updated:  November 6th 2013 (Current CK build: 6.0.0.19)            ***
82545>>>>>>>//***             Added constants for SQL Server specific native types      ***
82545>>>>>>>//***             ( var...(max) types, money types, datetime types)         ***
82545>>>>>>>//*****************************************************************************
82545>>>>>>>
82545>>>>>>>Use Cli.pkg
82545>>>>>>>Use SQL.pkg
82545>>>>>>>
82545>>>>>>>//*** Driver Indentification
82545>>>>>>>
82545>>>>>>>//*** Error number constants
82545>>>>>>>
82545>>>>>>>
82545>>>>>>>//*** Possible DF_DRIVER_SQLSERVER_CLIENT_VERSION values
82545>>>>>>>
82545>>>>>>>
82545>>>>>>>
82545>>>>>>>
82545>>>>>>>
82545>>>>>>>
82545>>>>>>>// SQL Server spcific types. 
82545>>>>>>>Define SQL_SS_TIMESTAMPOFFSET   for   (-155) //SQL server datetimeoffset type */
82545>>>>>>>Define SQL_SS_TIME2             for   (-154) //SQL server time type */
82545>>>>>>>Define SQL_SS_XML               for   (-152) //SQL server xml type */
82545>>>>>>>Define SQL_SS_VARIANT           for   (-150) //SQL server variant type */
82545>>>>>>>
82545>>>>>>>// SQL Server spcific types. 
82545>>>>>>>Define SQL_TYPE_TIMESTAMP2      for   (-200) //SQL server datetime2 type */
82545>>>>>>>Define SQL_VARCHARMAX           for   (-201) //SQL server varchar(max) type */
82545>>>>>>>Define SQL_WVARCHARMAX          for   (-202) //SQL server wvarchar(max) type */
82545>>>>>>>Define SQL_VARBINARYMAX         for   (-203) //SQL server varbinary(max) type */
82545>>>>>>>Define SQL_TYPE_MONEY           for   (-204) //SQL server money type */
82545>>>>>>>Define SQL_TYPE_SMALLMONEY      for   (-205) //SQL server smallmoney type */
82545>>>>>>>Define SQL_TYPE_SMALLDATETIME   for   (-206) //SQL server smalldatetype type */
82545>>>>>>>
82545>>>>>>>
82545>>>>>>>//*****************************************************************************
82545>>>>>>>//*** MSSQL_SetConstraint <FileNum> <ConstraintText>                        ***
82545>>>>>>>//***                                                                       ***
82545>>>>>>>//***   Setup a constraint for a file.                                      ***
82545>>>>>>>//*****************************************************************************
82545>>>>>>>
82545>>>>>>>
82545>>>>>>>
82545>>>>>>>Class cMSSQLHandler Is A cCLIHandler
82546>>>>>>>
82546>>>>>>>    Procedure Construct_Object
82548>>>>>>>        Forward Send Construct_Object
82550>>>>>>>
82550>>>>>>>        Set psDriverID To MSSQLDRV_ID
82551>>>>>>>    End_Procedure // Construct_Object
82552>>>>>>>
82552>>>>>>>
82552>>>>>>>
82552>>>>>>>    //***
82552>>>>>>>    //*** Function: ExtractList
82552>>>>>>>    //*** Purpose : Extract the list from the out connect string.
82552>>>>>>>    //***
82552>>>>>>>
82552>>>>>>>    Function ExtractList String sOutConnStr Integer hoStore Returns Integer
82554>>>>>>>        Local String  sItem
82554>>>>>>>        Local Integer iStart
82554>>>>>>>        Local Integer iEnd
82554>>>>>>>
82554>>>>>>>        If (hoStore = 0) ;            Move Current_object To hoStore
82557>>>>>>>
82557>>>>>>>        Send Delete_Data To hoStore
82558>>>>>>>        Move (Pos("{", sOutConnStr)) To iStart
82559>>>>>>>        While (iStart > 0)
82563>>>>>>>            Move (Right(sOutConnStr, Length(sOutConnStr) - iStart)) To sOutConnStr
82564>>>>>>>            If (Left(sOutConnStr, 1) = "}") ;                Move 0 To iStart
82567>>>>>>>            Else Begin
82568>>>>>>>                Move (Pos(",", sOutConnStr)) To iStart
82569>>>>>>>                Move (Pos("}", sOutConnStr)) To iEnd
82570>>>>>>>                If ((iStart = 0) Or (iEnd < iStart)) ;                    Move iEnd To iStart
82573>>>>>>>
82573>>>>>>>                If (iStart > 0) ;                    Set Value Of hoStore Item (Item_Count(Current_Object)) To (Left(sOutConnStr, iStart - 1))
82576>>>>>>>
82576>>>>>>>                If (iStart = iEnd) ;                    Move 0 To iStart
82579>>>>>>>            End
82579>>>>>>>>
82579>>>>>>>        Loop
82580>>>>>>>>
82580>>>>>>>
82580>>>>>>>        Function_Return (Item_Count(hoStore))
82581>>>>>>>    End_Procedure // ExtractList
82582>>>>>>>
82582>>>>>>>
82582>>>>>>>
82582>>>>>>>    //***
82582>>>>>>>    //*** Function: BrowseConnect
82582>>>>>>>    //*** Purpose : Call the driver's browse connect function
82582>>>>>>>    //***
82582>>>>>>>
82582>>>>>>>    Function BrowseConnect String sInConnStr Returns String
82584>>>>>>>        Local String  sDriver
82584>>>>>>>        Local String  sOutConnStr
82584>>>>>>>        Local Integer iArg
82584>>>>>>>        Local Integer iRetval
82584>>>>>>>
82584>>>>>>>        Get psDriverID To sDriver
82585>>>>>>>        If (sDriver <> "") Begin
82587>>>>>>>            Move (Repeat(" ", 8192)) To sOutConnStr
82588>>>>>>>            Call_Driver 0 sDRiver Function CLI_BROWSECONNECT Callback 0 Passing sInConnStr sOutConnStr iArg Result iRetval
82593>>>>>>>        End
82593>>>>>>>>
82593>>>>>>>
82593>>>>>>>        Function_Return sOutConnStr
82594>>>>>>>    End_Function// BrowseConnect
82595>>>>>>>
82595>>>>>>>
82595>>>>>>>    Function BrowseConnectLocal String sInConnStr Returns String
82597>>>>>>>        Local String  sDriver
82597>>>>>>>        Local String  sOutConnStr
82597>>>>>>>        Local Integer iArg
82597>>>>>>>        Local Integer iRetval
82597>>>>>>>        
82597>>>>>>>        Move 1 to iArg // Browses only local
82598>>>>>>>
82598>>>>>>>        Get psDriverID to sDriver
82599>>>>>>>        If (sDriver <> "") Begin
82601>>>>>>>            Move (Repeat(" ", 8192)) to sOutConnStr
82602>>>>>>>            Call_Driver 0 sDRiver Function CLI_BROWSECONNECT Callback 0 Passing sInConnStr sOutConnStr iArg Result iRetval
82607>>>>>>>        End
82607>>>>>>>>
82607>>>>>>>
82607>>>>>>>        Function_Return sOutConnStr
82608>>>>>>>    End_Function// BrowseConnect
82609>>>>>>>
82609>>>>>>>
82609>>>>>>>    Function DriverIndex String sDriver Returns Integer
82611>>>>>>>    
82611>>>>>>>        Local String  sCurrentDriver
82611>>>>>>>        Local Integer iNumberOfDrivers iDriver iCount
82611>>>>>>>    
82611>>>>>>>        Move 0 to iDriver
82612>>>>>>>    
82612>>>>>>>        Get_Attribute DF_NUMBER_DRIVERS to iNumberOfDrivers
82615>>>>>>>        For iCount from 1 to iNumberOfDrivers
82621>>>>>>>>
82621>>>>>>>    
82621>>>>>>>            Get_Attribute DF_DRIVER_NAME of iCount to sCurrentDriver
82624>>>>>>>            If ( Uppercase(sCurrentDriver) = Uppercase(sDriver) ) Begin
82626>>>>>>>                Move iCount to iDriver
82627>>>>>>>            End
82627>>>>>>>>
82627>>>>>>>        Loop
82628>>>>>>>>
82628>>>>>>>    
82628>>>>>>>        Function_Return iDriver
82629>>>>>>>    
82629>>>>>>>    End_Function 
82630>>>>>>>
82630>>>>>>>    Function EnumerateServersNetworkOrLocal Integer iNetworkLocal  Returns Integer
82632>>>>>>>        
82632>>>>>>>        Local String  sServerList
82632>>>>>>>        Local Integer iNumServers
82632>>>>>>>        Local Integer iDriver
82632>>>>>>>        Local Integer iClientVersion
82632>>>>>>>        Local String  sDriver
82632>>>>>>>        
82632>>>>>>>        Get DriverIndex MSSQLDRV_ID to iDriver
82633>>>>>>>
82633>>>>>>>        If (iDriver) Begin
82635>>>>>>>                
82635>>>>>>>            Get_Attribute DF_DRIVER_SQLSERVER_CLIENT_VERSION of iDriver to iClientVersion
82638>>>>>>>            
82638>>>>>>>            Case Begin
82638>>>>>>>    
82638>>>>>>>                Case (iClientVersion = SQLSERVER2016CLIENT)
82640>>>>>>>                    Move SQLSERVER2016DRVRSTR to sDriver
82641>>>>>>>                    Case Break
82642>>>>>>>    
82642>>>>>>>                Case (iClientVersion = SQLSERVER2014CLIENT)
82645>>>>>>>                    Move SQLSERVER2014DRVRSTR to sDriver
82646>>>>>>>                    Case Break
82647>>>>>>>            
82647>>>>>>>                Case (iClientVersion = SQLSERVER2012CLIENT)
82650>>>>>>>                    Move SQLSERVER2012DRVRSTR to sDriver
82651>>>>>>>                    Case Break
82652>>>>>>>    
82652>>>>>>>                Case (iClientVersion = SQLSERVER2008CLIENT)
82655>>>>>>>                    Move SQLSERVER2008DRVRSTR to sDriver
82656>>>>>>>                    Case Break
82657>>>>>>>    
82657>>>>>>>                Case (iClientVersion = SQLSERVER2005CLIENT)
82660>>>>>>>                    Move SQLSERVER2005DRVRSTR to sDriver
82661>>>>>>>                    Case Break
82662>>>>>>>            
82662>>>>>>>                Case (iClientVersion = SQLSERVER2000CLIENT)
82665>>>>>>>                    Move SQLSERVER2000DRVRSTR to sDriver
82666>>>>>>>                    Case Break
82667>>>>>>>            
82667>>>>>>>                Case Else
82667>>>>>>>                    Move SQLSERVER2000DRVRSTR to sDriver
82668>>>>>>>            
82668>>>>>>>            Case End
82668>>>>>>>    
82668>>>>>>>            Move ("DRIVER={" + sDriver + "};") to sDriver
82669>>>>>>>            If (iNetworkLocal = 0) Begin
82671>>>>>>>                Get BrowseConnect sDriver to sServerList
82672>>>>>>>            End
82672>>>>>>>>
82672>>>>>>>            Else Begin
82673>>>>>>>                Get BrowseConnectLocal sDriver to sServerList
82674>>>>>>>            End
82674>>>>>>>>
82674>>>>>>>            Get ExtractList sServerList Current_object to iNumServers
82675>>>>>>>        End
82675>>>>>>>>
82675>>>>>>>        
82675>>>>>>>        Function_Return iNumServers
82676>>>>>>>        
82676>>>>>>>    End_Function
82677>>>>>>>
82677>>>>>>>    //***
82677>>>>>>>    //*** Procedure: EnumerateServers
82677>>>>>>>    //*** Purpose  : Enumerate the available SQL Server database servers
82677>>>>>>>    //***            This function will return all SQL Server instances on the network. 
82677>>>>>>>    //***            This may take a long time. 
82677>>>>>>>    //***            To enumerate only local SQL Server instances use EnumerateServersLocal 
82677>>>>>>>    Function EnumerateServers Returns Integer
82679>>>>>>>
82679>>>>>>>        Local Integer iNumServers
82679>>>>>>>        Local Integer iNetworkLocal
82679>>>>>>>        
82679>>>>>>>        Move 0 to iNetworkLocal // 0 = enumerate network servers
82680>>>>>>>        
82680>>>>>>>        Get EnumerateServersNetworkOrLocal iNetworkLocal to iNumServers
82681>>>>>>>        
82681>>>>>>>        Function_Return iNumServers
82682>>>>>>>        
82682>>>>>>>    End_Function
82683>>>>>>>
82683>>>>>>>
82683>>>>>>>    //***
82683>>>>>>>    //*** Procedure: EnumerateServersLocal
82683>>>>>>>    //*** Purpose  : Enumerate the available SQL Server database servers
82683>>>>>>>    //***            This function will return only return SQL Server instance on the local machine
82683>>>>>>>    //***            To enumerate all SQL Server instances in a network use EnumerateServers
82683>>>>>>>    Function EnumerateServersLocal Returns Integer
82685>>>>>>>
82685>>>>>>>        Local Integer iNumServers
82685>>>>>>>        Local Integer iNetworkLocal
82685>>>>>>>        
82685>>>>>>>        Move 1 to iNetworkLocal // 1 = enumerate local servers
82686>>>>>>>        
82686>>>>>>>        Get EnumerateServersNetworkOrLocal iNetworkLocal to iNumServers
82687>>>>>>>        
82687>>>>>>>        Function_Return iNumServers
82688>>>>>>>        
82688>>>>>>>    End_Function
82689>>>>>>>
82689>>>>>>>    
82689>>>>>>>
82689>>>>>>>    //***
82689>>>>>>>    //*** Function: EnumerateDatabases
82689>>>>>>>    //*** Purpose : Enumerate database in a given server.
82689>>>>>>>    //***
82689>>>>>>>
82689>>>>>>>    Function EnumerateDatabases String sServer String sUser String sPassWord Returns Integer
82691>>>>>>>        Local Integer hoSQL
82691>>>>>>>        Local String  sConnect
82691>>>>>>>        Local String  sDatabase
82691>>>>>>>        Local Integer hdbc
82691>>>>>>>        Local Integer hstmt
82691>>>>>>>        Local Integer iFetchResult
82691>>>>>>>
82691>>>>>>>        If (Num_Arguments < 3) ;            Move "" To sPassWord
82694>>>>>>>        If (Num_Arguments < 2) ;            Move "" To sUser
82697>>>>>>>
82697>>>>>>>        If (sUser <> "") ;            Move ("SERVER=" + Trim(sServer) + ";UID=" + Trim(sUser) + ";PWD=" + Trim(sPassword) + ";") To sConnect
82700>>>>>>>        Else ;            Move ("SERVER=" + Trim(sServer) + ";Trusted_Connection=yes") To sConnect
82702>>>>>>>
82702>>>>>>>        Object oEnumDBSQLmanager Is A cSQLHandleManager
82704>>>>>>>            Move Current_Object To hoSQL
82705>>>>>>>        End_Object // oEnumDBSQLManager
82706>>>>>>>
82706>>>>>>>        If (hoSQL <> 0) Begin
82708>>>>>>>            Get SQLConnect Of hoSQL "MSSQLDRV" sConnect To hdbc
82709>>>>>>>            If (hdbc <> 0) Begin
82711>>>>>>>                Get SQLOpen Of hdbc To hstmt
82712>>>>>>>                If (hstmt <> 0) Begin
82714>>>>>>>                    //*** We could do a direct select on the sysdatabases table but we use
82714>>>>>>>                    //*** the stored procedure sp_database instead. SQL Server recommends this
82714>>>>>>>                    //*** approach in case meta data might change, the stored procedure will
82714>>>>>>>                    //*** stay the same.
82714>>>>>>>                    Send SQLSetProcedureName To hstmt "sp_databases"
82715>>>>>>>                    Send SQLCall To hstmt
82716>>>>>>>                    Repeat
82716>>>>>>>>
82716>>>>>>>                        Get SQLFetch Of hstmt To iFetchResult
82717>>>>>>>                        If (iFetchResult <> 0) Begin
82719>>>>>>>                            Get SQLColumnValue Of hstmt 1 To sDatabase
82720>>>>>>>                            Set Value Item (Item_Count(Current_Object)) To sDatabase
82721>>>>>>>                        End
82721>>>>>>>>
82721>>>>>>>                    Until (iFetchResult = 0)
82723>>>>>>>
82723>>>>>>>                    Send SQLClose To hstmt
82724>>>>>>>                End
82724>>>>>>>>
82724>>>>>>>                Send SQLDisconnect To hdbc
82725>>>>>>>            End
82725>>>>>>>>
82725>>>>>>>        End
82725>>>>>>>>
82725>>>>>>>        Send Destroy_Object To hoSQL
82726>>>>>>>
82726>>>>>>>        Function_return (Item_Count(Current_Object))
82727>>>>>>>    End_Function // EnumerateDatabases
82728>>>>>>>
82728>>>>>>>
82728>>>>>>>    Function SqlServerClientVersionName Integer iClientVersion  Returns String
82730>>>>>>>        
82730>>>>>>>        Local String  sSqlServerClientVersionName
82730>>>>>>>        
82730>>>>>>>            
82730>>>>>>>        Case Begin
82730>>>>>>>
82730>>>>>>>            Case (iClientVersion = SQLSERVER2016CLIENT)
82732>>>>>>>                Move SQLSERVER2016CLIENTNAME to sSqlServerClientVersionName
82733>>>>>>>                Case Break
82734>>>>>>>
82734>>>>>>>            Case (iClientVersion = SQLSERVER2014CLIENT)
82737>>>>>>>                Move SQLSERVER2014CLIENTNAME to sSqlServerClientVersionName
82738>>>>>>>                Case Break
82739>>>>>>>        
82739>>>>>>>            Case (iClientVersion = SQLSERVER2012CLIENT)
82742>>>>>>>                Move SQLSERVER2012CLIENTNAME to sSqlServerClientVersionName
82743>>>>>>>                Case Break
82744>>>>>>>
82744>>>>>>>            Case (iClientVersion = SQLSERVER2008CLIENT)
82747>>>>>>>                Move SQLSERVER2008CLIENTNAME to sSqlServerClientVersionName
82748>>>>>>>                Case Break
82749>>>>>>>
82749>>>>>>>            Case (iClientVersion = SQLSERVER2005CLIENT)
82752>>>>>>>                Move SQLSERVER2005CLIENTNAME to sSqlServerClientVersionName
82753>>>>>>>                Case Break
82754>>>>>>>        
82754>>>>>>>            Case (iClientVersion = SQLSERVER2000CLIENT)
82757>>>>>>>                Move SQLSERVER2000CLIENTNAME to sSqlServerClientVersionName
82758>>>>>>>                Case Break
82759>>>>>>>        
82759>>>>>>>            Case Else
82759>>>>>>>                Move SQLSERVERUNKNOWNCLIENTNAME to sSqlServerClientVersionName
82760>>>>>>>        
82760>>>>>>>        Case End
82760>>>>>>>    
82760>>>>>>>        
82760>>>>>>>        Function_Return sSqlServerClientVersionName
82761>>>>>>>        
82761>>>>>>>    End_Function
82762>>>>>>>
82762>>>>>>>
82762>>>>>>>End_Class // cMSSQLHandler
