94021>>>>>    // The bANSI parameter's default value = True, meaning a table in ANSI format will be created.
94021>>>>>    // i.e. DF_FILE_TABLE_CHARACTER_FORMAT {"OEM"|"ANSI"}
94021>>>>>    Function ApiTableCreate Handle hTable String sRoot String sDisplay String sTableName Boolean bUseConnectionID Boolean bANSI Boolean bRecnum Returns Boolean
94023>>>>>        Handle hFile
94023>>>>>        String sConnectionID sPhysicalFile sANSI_OEM sVal sSchema sOriginalDriverID sDriverID
94023>>>>>        Integer iColumn 
94023>>>>>        Boolean bOk bExists bMertechDriver
94023>>>>>        tSQLConnection SQLConnection
94023>>>>>        tSQLConnection SQLConnection
94023>>>>>
94023>>>>>        If (ghoProgressBar <> 0) Begin
94025>>>>>            Send DoAdvance of ghoProgressBar
94026>>>>>        End
94026>>>>>>
94026>>>>>        
94026>>>>>        // First check if the passed filenumber already exists; in case we do nothing
94026>>>>>        Get UtilTableNumberIsInUse hTable to bOk
94027>>>>>        If (bOk = True) Begin
94029>>>>>            Function_Return False
94030>>>>>        End
94030>>>>>>
94030>>>>>        
94030>>>>>        Get psDriverID to sDriverID
94031>>>>>        // If this is a SQL based driver we also check if the table exists
94031>>>>>        // in the SQL back end; in case we do nothing.
94031>>>>>        Get IsSQLDriver sDriverID to bOk
94032>>>>>        If (bOk = True) Begin
94034>>>>>            Get SqlUtilCheckIfTableHandleExists hTable sDriverID to bExists
94035>>>>>            If (bExists = True) Begin
94037>>>>>                Function_Return False
94038>>>>>            End                      
94038>>>>>>
94038>>>>>        
94038>>>>>            // Get all connection properties
94038>>>>>            Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection  
94039>>>>>            Move SQLConnection.sSchema to sSchema
94040>>>>>            If (sSchema = "") Begin
94042>>>>>                Get _SqlFindKeyWord CI_SQLDBO to sSchema  
94043>>>>>            End
94043>>>>>>
94043>>>>>        End
94043>>>>>>
94043>>>>>        
94043>>>>>        Move CS_ANSI_Txt to sANSI_OEM
94044>>>>>        If (num_arguments > 6) Begin
94046>>>>>            If (bANSI = False) Begin
94048>>>>>                Move CS_OEM_Txt to sANSI_OEM
94049>>>>>            End
94049>>>>>>
94049>>>>>        End  
94049>>>>>>
94049>>>>>        
94049>>>>>        // Mertech drivers don't use connection id's, so if the passed bUseConnectionID = True that
94049>>>>>        // is a programmer's error and we auto-correct for it here.
94049>>>>>        // This is also a bit messy. If a Mertech driver is used and we want to create a new table,
94049>>>>>        // we first need to create it as embedded (DataFlex) and then convert it to SQL (!)
94049>>>>>        // So we set the driver ID temporarily to "DataFlex" to get the table created as embedded and later
94049>>>>>        // set it back and use a Mertech function to convert it to SQL.
94049>>>>>        Get IsMertechDriver sDriverID to bMertechDriver
94050>>>>>        If (bMertechDriver = True) Begin
94052>>>>>            If (bUseConnectionID = True) Begin
94054>>>>>                Move False to bUseConnectionID
94055>>>>>            End
94055>>>>>>
94055>>>>>            Move sDriverID to sOriginalDriverID
94056>>>>>            Move DATAFLEX_ID to sDriverID
94057>>>>>        End
94057>>>>>>
94057>>>>>            
94057>>>>>        Move False to Err
94058>>>>>        If (sDriverID = DATAFLEX_ID) Begin
94060>>>>>            Move sRoot to sPhysicalFile 
94061>>>>>        End
94061>>>>>>
94061>>>>>        
94061>>>>>        If (sDriverID <> DATAFLEX_ID) Begin 
94063>>>>>            Move SQLConnection.sConnectionID to sConnectionID
94064>>>>>            
94064>>>>>            // If DAW driver and we should use a connection id we need to
94064>>>>>            // check if the connection ID exists; else we create it before attempting creating the table
94064>>>>>            If (bMertechDriver = False and bUseConnectionID = True) Begin
94066>>>>>                Get IsConnectionID sConnectionID sDriverID to bExists
94067>>>>>                If (bExists = False) Begin
94069>>>>>                    Get UtilCreateConnectionID sConnectionID to bOk
94070>>>>>                    If (bOk = False) Begin
94072>>>>>                        Error DFERR_PROGRAM ("The Connection ID:" * sConnectionID * "could not be created and therefor the table can't be created.")
94073>>>>>>
94073>>>>>                        Function_Return False
94074>>>>>                    End
94074>>>>>>
94074>>>>>                End
94074>>>>>>
94074>>>>>            End
94074>>>>>>
94074>>>>>            
94074>>>>>            Move (sRoot + ".int") to sPhysicalFile
94075>>>>>            Move (Uppercase(sDisplay)) to sVal
94076>>>>>            If (not(sVal contains (sSchema + "."))) Begin    
94078>>>>>                Move (Lowercase(sSchema) + "." + sTableName) to sDisplay
94079>>>>>            End                                       
94079>>>>>>
94079>>>>>        End                                          
94079>>>>>>
94079>>>>>        Move 0 to hFile   
94080>>>>>        Move False to Err 
94081>>>>>        
94081>>>>>        Structure_Start hFile sDriverID
94082>>>>>            If (sDriverID <> DATAFLEX_ID) Begin
94084>>>>>                If (bUseConnectionID = True) Begin
94086>>>>>                    Set_Attribute DF_FILE_LOGIN              of hFile to (CS_DFCONNID + "=" + sConnectionID)
94089>>>>>                End 
94089>>>>>>
94089>>>>>                Else Begin
94090>>>>>                    Set_Attribute DF_FILE_LOGIN              of hFile to SQLConnection.sConnectionString
94093>>>>>                End
94093>>>>>>
94093>>>>>                Set_Attribute DF_FILE_TABLE_NAME             of hFile to sRoot  
94096>>>>>                Set_Attribute DF_FILE_USE_DUMMY_ZERO_DATE    of hFile to True     
94099>>>>>                Set_Attribute DF_FILE_TABLE_CHARACTER_FORMAT of hFile to sANSI_OEM
94102>>>>>                Set_Attribute DF_FILE_RECNUM_TABLE           of hFile to bRecnum
94105>>>>>
94105>>>>>                If (sSchema <> "") Begin
94107>>>>>                    Set_Attribute DF_FILE_OWNER                of hFile to sSchema
94110>>>>>                End
94110>>>>>>
94110>>>>>    
94110>>>>>                If (sDriverID = DB2_DRV_ID) Begin                           
94112>>>>>                    If (SQLConnection.sLongTableSpace <> "") Begin
94114>>>>>                        Set_Attribute DF_FILE_LONG_TABLESPACE  of hFile to SQLConnection.sLongTableSpace
94117>>>>>                    End
94117>>>>>>
94117>>>>>                End   
94117>>>>>>
94117>>>>>                If (sDriverID = DB2_DRV_ID or sDriverID = ORAFLEX or sDriverID = MDSPgSQL) Begin
94119>>>>>                    If (SQLConnection.sBaseTableSpace <> "") Begin
94121>>>>>                        Set_Attribute DF_FILE_TABLE_TABLESPACE of hFile to SQLConnection.sBaseTableSpace
94124>>>>>                    End
94124>>>>>>
94124>>>>>                    If (SQLConnection.sIndexTableSpace <> "") Begin
94126>>>>>                        Set_Attribute DF_FILE_INDEX_TABLESPACE of hFile to SQLConnection.sIndexTableSpace
94129>>>>>                    End
94129>>>>>>
94129>>>>>                End
94129>>>>>>
94129>>>>>            End 
94129>>>>>>
94129>>>>>                       
94129>>>>>            Set_Attribute DF_FILE_PHYSICAL_NAME              of hFile to sPhysicalFile 
94132>>>>>            
94132>>>>>            // We need to create at least one column else the table creation will fail.
94132>>>>>            // We remove it before the end of this function.
94132>>>>>            Move 0 to iColumn
94133>>>>>            Create_Field hFile at iColumn                   
94134>>>>>            
94134>>>>>            Set_Attribute DF_FIELD_NAME of hFile iColumn to "temp"
94137>>>>>            Set_Attribute DF_FIELD_TYPE of hFile iColumn to DF_DATE
94140>>>>>        Structure_End hFile
94142>>>>>        
94142>>>>>        // If Mertech driver we convert the newly created embedded table (DataFlex) to SQL
94142>>>>>        If (bMertechDriver = True) Begin
94144>>>>>            Move sOriginalDriverID to sDriverID
94145>>>>>            If (not(sVal contains (sSchema + "."))) Begin    
94147>>>>>                Move (Lowercase(sSchema) + "." + sTableName) to sDisplay
94148>>>>>            End                                       
94148>>>>>>
94148>>>>>            // Note: This function also sets the Err flag.
94148>>>>>            Get _MertechApiTableConvertToSQL hTable sRoot SQLConnection.sDatabase sDriverID SQLConnection.sBaseTableSpace SQLConnection.sIndexTableSpace False to bOK
94149>>>>>        End
94149>>>>>>
94149>>>>>
94149>>>>>        Move (not(Err)) to bOK                                     
94150>>>>>        If (bOk = True) Begin
94152>>>>>            If (sDriverID <> DATAFLEX_ID) Begin
94154>>>>>                Move (sDriverID + ":" + sRoot) to sRoot
94155>>>>>            End
94155>>>>>>
94155>>>>>    
94155>>>>>            If (sDriverID <> DATAFLEX_ID and not(Uppercase(sRoot) contains sDriverID)) Begin
94157>>>>>                Move (sDriverID + ":" + sRoot) to sRoot
94158>>>>>            End
94158>>>>>>
94158>>>>>            Set_Attribute DF_FILE_ROOT_NAME     of hTable to sRoot
94161>>>>>            Set_Attribute DF_FILE_LOGICAL_NAME  of hTable to sTableName 
94164>>>>>            Set_Attribute DF_FILE_DISPLAY_NAME  of hTable to sDisplay
94167>>>>>        
94167>>>>>            // Lastly we remove the temporary column we created above, if all went well.
94167>>>>>            Get ApiColumnRemove hTable "temp" to bOk
94168>>>>>        End
94168>>>>>>
94168>>>>>        
94168>>>>>        Function_Return (bOK = True)
94169>>>>>    End_Function  
