85368>>>>>    // called after list is created and active. Load Data, seed list, select start column, etc.
85368>>>>>    Procedure LoadData
85370>>>>>        Handle hoInvokingObject hoDataSource hoInitialColumn
85370>>>>>        Integer iUpdateColumn iRows iInitialColumn iInitialOrder
85370>>>>>        Integer eUpdateMode
85370>>>>>        Boolean bAutoSeed bAutoColumn bCancel bSubFocus bAutoOrder 
85370>>>>>        
85370>>>>>        Get phoDataSource to hoDataSource
85371>>>>>        Get peUpdateMode to eUpdateMode
85372>>>>>        Get phoInvokingObject to hoInvokingObject
85373>>>>>        Get pbAutoSeed to bAutoSeed
85374>>>>>        Get piInitialColumn to iInitialColumn
85375>>>>>        Get piUpdateColumn to iUpdateColumn
85376>>>>>        Get RowCount of hoDataSource to iRows
85377>>>>>        
85377>>>>>        // We need an initial column. if you specified an initial column that will get used for the start column
85377>>>>>        // and the initial sort order. If you did not, which is typical, it will use the update column
85377>>>>>        If (iInitialColumn=-1) Begin
85379>>>>>            Move iUpdateColumn to iInitialColumn
85380>>>>>        End
85380>>>>>>
85380>>>>>        If (iInitialColumn>=0) Begin
85382>>>>>            Get ColumnObject iInitialColumn to hoInitialColumn
85383>>>>>            Set pbVisible of hoInitialColumn to True // initial column should be visible
85384>>>>>        End
85384>>>>>>
85384>>>>>        Send OnSeedData // find a good starting place for the row
85385>>>>>        Get pbFocusSubItems to bSubFocus
85386>>>>>        If bSubFocus Begin
85388>>>>>            // if column focus, which is normal, go to initialcolumn       
85388>>>>>            If hoInitialColumn Begin
85390>>>>>                Get MoveToColumnObject hoInitialColumn to bCancel
85391>>>>>            End
85391>>>>>>
85391>>>>>            Else Begin
85392>>>>>                Send MoveToFirstEnterableColumn
85393>>>>>            End
85393>>>>>>
85393>>>>>        End
85393>>>>>>
85393>>>>>
85393>>>>>    End_Procedure
