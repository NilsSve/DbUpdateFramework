84067>>>>>>>//=============================================================================
84067>>>>>>>/// @Name        ENABLE_SCRIPTING
84067>>>>>>>/// @Description Scripting is used for testing and preparation. This
84067>>>>>>>/// command allows structural changes to be compiled and tested without
84067>>>>>>>/// actually making any of the changes. Any table restructuring done
84067>>>>>>>/// between this command and DISABLE_SCRIPTING will not actually be
84067>>>>>>>/// committed but will instead create a mock INT file. The script and
84067>>>>>>>/// INT file can then be retrieved and examined for testing purposes.
84067>>>>>>>///
84067>>>>>>>/// @Assumptions
84067>>>>>>>/// @Status      Public
84067>>>>>>>/// @Drivers     All
84067>>>>>>>/// @VersionNote Last Revised: 2013-10-09 by Aaron Gulack
84067>>>>>>>/// @See                 DISABLE_SCRIPTING GET_SQL_SCRIPT_CHUNK GET_INT_CHUNK
84067>>>>>>>///
84067>>>>>>>/// @Syntax ENABLE_SCRIPTING
84067>>>>>>>///
84067>>>>>>>/// @Example
84067>>>>>>>/// ENABLE_SCRIPTING
84067>>>>>>>///     //Table restructuring would go here
84067>>>>>>>/// DISABLE_SCRIPTING
84067>>>>>>>///
84067>>>>>>>/// GET_SQL_SCRIPT_CHUNK OFFSET 0 to sChunk sLength
84067>>>>>>>/// Showln sChunk
84067>>>>>>>
84067>>>>>>>//=============================================================================
84067>>>>>>>/// @Name        DISABLE_SCRIPTING
84067>>>>>>>/// @Description This command ends any scripting started by ENABLE_SCRIPTING.
84067>>>>>>>/// The mock INT file and script can then be retrieved and examined.
84067>>>>>>>///
84067>>>>>>>/// @Assumptions
84067>>>>>>>/// @Status      Public
84067>>>>>>>/// @Drivers     All
84067>>>>>>>/// @VersionNote Last Revised: 2010-12-13 By Marcelo Nachbar
84067>>>>>>>/// @See                 ENABLE_SCRIPTING  GET_SQL_SCRIPT_CHUNK GET_INT_CHUNK
84067>>>>>>>///
84067>>>>>>>/// @Syntax DISABLE_SCRIPTING
84067>>>>>>>///
84067>>>>>>>/// @Example
84067>>>>>>>/// ENABLE_SCRIPTING
84067>>>>>>>///     //Table restructuring would go here
84067>>>>>>>/// DISABLE_SCRIPTING
84067>>>>>>>///
84067>>>>>>>/// GET_SQL_SCRIPT_CHUNK OFFSET 0 to sChunk sLength
84067>>>>>>>/// Showln sChunk
84067>>>>>>>
84067>>>>>>>Function MertechInc_GET_RESTRUCTURE_SCRIPT Global Integer iLong Integer iOffset Returns String
84069>>>>>>>    Local Integer iChuck_Size
84069>>>>>>>    Local String sChunk
84069>>>>>>>
84069>>>>>>>    //Get current Chuck size and pre size string
84069>>>>>>>    Call_Driver 0 MertechInc_DriverName Function CALLDRV_CHUNK_SIZE CALLBACK 0 PASSING iChuck_Size MertechInc_Blank 1 RESULT MertechInc_iRet
84074>>>>>>>    Get MertechInc_Pre_Size_String iChuck_Size to sChunk
84075>>>>>>>
84075>>>>>>>    //Get data
84075>>>>>>>    Call_Driver 0 MertechInc_DriverName Function CALLDRV_RESTRUCTURE_SCRIPT CALLBACK 0 PASSING sChunk iOffset iLong RESULT MertechInc_iRet
84080>>>>>>>
84080>>>>>>>    // Replace insert a CR before any LF character
84080>>>>>>>    Move (Replaces(Character(10), sChunk, Character(13)+Character(10))) to sChunk
84081>>>>>>>
84081>>>>>>>    Function_Return sChunk
84082>>>>>>>End_Function
84083>>>>>>>
84083>>>>>>>
84083>>>>>>>//=============================================================================
84083>>>>>>>/// @Name        GET_SQL_SCRIPT_CHUNK
84083>>>>>>>/// @Description This command returns a chunk of the script generated
84083>>>>>>>/// from the restructuring done inside of ENABLE_SCRIPTING and
84083>>>>>>>/// DISABLE_SCRIPTING. Since some scripts can be very large, the script
84083>>>>>>>/// can be looped through, grabbing chunks at a time.
84083>>>>>>>///
84083>>>>>>>/// @Assumptions
84083>>>>>>>/// @Status      Public
84083>>>>>>>/// @Drivers     All
84083>>>>>>>/// @VersionNote Last Revised: 2013-10-09 by Aaron Gulack
84083>>>>>>>/// @See                 ENABLE_SCRIPTING DISABLE_SCRIPTING GET_INT_CHUNK
84083>>>>>>>///
84083>>>>>>>/// @Syntax GET_SQL_SCRIPT_CHUNK OFFSET {offset} to {variable} [{length}]
84083>>>>>>>/// @Param offset                       Specifies the offset to start at for the chunk
84083>>>>>>>/// @Param variable                     Variable to hold the chunk
84083>>>>>>>/// @Param length                       Length of chunk returned (optional)
84083>>>>>>>///
84083>>>>>>>/// @Example
84083>>>>>>>/// ENABLE_SCRIPTING
84083>>>>>>>///     //Table restructuring would go here
84083>>>>>>>/// DISABLE_SCRIPTING
84083>>>>>>>///
84083>>>>>>>/// GET_SQL_SCRIPT_CHUNK OFFSET 0 to sChunk sLength
84083>>>>>>>/// Showln sChunk
84083>>>>>>>
84083>>>>>>>//=============================================================================
84083>>>>>>>/// @Name        GET_INT_CHUNK
84083>>>>>>>/// @Description This command returns a chunk of the INT file generated
84083>>>>>>>/// from the restructuring done inside of ENABLE_SCRIPTING and
84083>>>>>>>/// DISABLE_SCRIPTING. Since some INT files can be very large, the file
84083>>>>>>>/// can be looped through, grabbing chunks at a time.
84083>>>>>>>///
84083>>>>>>>/// @Assumptions
84083>>>>>>>/// @Status      Public
84083>>>>>>>/// @Drivers     All
84083>>>>>>>/// @VersionNote Last Revised: 2013-10-09 by Aaron Gulack
84083>>>>>>>/// @See                 ENABLE_SCRIPTING DISABLE_SCRIPTING GET_SQL_SCRIPT_CHUNK
84083>>>>>>>///
84083>>>>>>>/// @Syntax GET_INT_CHUNK OFFSET {offset} to {variable} [{length}]
84083>>>>>>>/// @Param offset                       Specifies the offset to start at for the chunk
84083>>>>>>>/// @Param variable                     Variable to hold the chunk
84083>>>>>>>/// @Param length                       Length of chunk returned (optional)
84083>>>>>>>///
84083>>>>>>>/// @Example
84083>>>>>>>/// ENABLE_SCRIPTING
84083>>>>>>>///     //Table restructuring would go here
84083>>>>>>>/// DISABLE_SCRIPTING
84083>>>>>>>///
84083>>>>>>>/// GET_INT_CHUNK OFFSET 0 to sChunk sLength
84083>>>>>>>/// Showln sChunk
84083>>>>>>>
84083>>>>>>>//=============================================================================
84083>>>>>>>/// @Name        REPORT_STMT
84083>>>>>>>/// @Description This command is an alternative to DataFlex's "Report"
84083>>>>>>>/// command. This allows embedded SQL to be used to fetch data instead of
84083>>>>>>>/// standard table queries.. All of the finds, for example, normally found
84083>>>>>>>/// in "Report" are replaced by SQL_FETCH_NEXT_ROW.
84083>>>>>>>///
84083>>>>>>>/// @Assumptions
84083>>>>>>>/// @Status      Public
84083>>>>>>>/// @Drivers     n/a
84083>>>>>>>/// @VersionNote Last Revised: 2013-10-09 by Aaron Gulack
84083>>>>>>>/// @See
84083>>>>>>>///
84083>>>>>>>/// @Syntax See DataFlex / Visual DataFlex documentation
84083>>>>>>>///
84083>>>>>>>/// @Example
84083>>>>>>>/// /Header
84083>>>>>>>/// __/__/____                                                        Page ___.
84083>>>>>>>///                 MERTECH DATA SYSTEMS, INC. - NOT FOR RESALE
84083>>>>>>>///
84083>>>>>>>/// ID   NAME
84083>>>>>>>///
84083>>>>>>>/// /Body
84083>>>>>>>/// ____ _________________________
84083>>>>>>>/// /Total
84083>>>>>>>/// Records printed = _______.
84083>>>>>>>/// /*
84083>>>>>>>///
84083>>>>>>>///
84083>>>>>>>/// OPEN SALESP
84083>>>>>>>/// direct_output "con:"
84083>>>>>>>/// // Write the complete SELECT statement to retrieve the expected records from your REPORT
84083>>>>>>>/// // Must include the expression to qualify the required records and specify the order by as well
84083>>>>>>>///
84083>>>>>>>/// sql_set_stmt of salesp to "select recnum, id, name from SALESP where recnum > 5 order by id"
84083>>>>>>>/// sql_prepare_stmt of salesp
84083>>>>>>>/// sql_bindcolumns_stmt of salesp to salesp.recnum salesp.id salesp.name
84083>>>>>>>/// sql_execute_stmt of salesp
84083>>>>>>>///
84083>>>>>>>/// Report_stmt SALESP By Index.1
84083>>>>>>>///
84083>>>>>>>/// Section Header
84083>>>>>>>///     Sysdate Header.1
84083>>>>>>>///     Move PageCount to Header.2
84083>>>>>>>///     output header
84083>>>>>>>///
84083>>>>>>>/// Section Body
84083>>>>>>>///     Print Salesp.id   to Body.1
84083>>>>>>>///     Print Salesp.name to Body.2
84083>>>>>>>///     output body
84083>>>>>>>/// Section Total
84083>>>>>>>///
84083>>>>>>>/// Return
84083>>>>>>>/// ReportEnd
84083>>>>>>>
84083>>>>>>>//=============================================================================
84083>>>>>>>/// @Name        GET_SERVER_CFG
84083>>>>>>>/// @Description This command, when passed a valid server name, returns
84083>>>>>>>/// the a value for the specified attribute. See the list below for an
84083>>>>>>>/// explanation of each attribute.
84083>>>>>>>///
84083>>>>>>>/// SERVER_REVISION    Returns the major version, to the left of the decimal, of the server
84083>>>>>>>/// SUPPORT_DESC       Returns 1 if Server supports descending index segments
84083>>>>>>>/// SUPPORT_CASE       Returns 1 if Server supports case insensitive index segments
84083>>>>>>>/// SERVER_VERSION     Returns the full version of the server
84083>>>>>>>/// SERVER_ENCODING    Returns the Server Encoding
84083>>>>>>>/// CONNECTION_ACTIVE  Returns 1 if the connection to the server is active
84083>>>>>>>/// CITEXT_SUPPORT     Returns 1 if Server supports citext, a PostgreSQL data type
84083>>>>>>>///
84083>>>>>>>/// @Assumptions
84083>>>>>>>/// @Status      Internal
84083>>>>>>>/// @Drivers     All
84083>>>>>>>/// @VersionNote Last Revised: 2013-10-02 by Aaron Gulack
84083>>>>>>>/// @See
84083>>>>>>>///
84083>>>>>>>/// @Syntax GET_SERVER_CFG {constant} of {server} to {variable}
84083>>>>>>>/// @Param constant                     SERVER_REVISION,SERVER_MIN_REVISION,SUPPORT_DESC,SUPPORT_CASE,SERVER_VERSION,SERVER_ENCODING,CONNECTION_ACTIVE
84083>>>>>>>/// @Param server                       Name of the server being checked
84083>>>>>>>/// @Param variable                     Variable to hold the returned value
84083>>>>>>>///
84083>>>>>>>/// @Example
84083>>>>>>>/// GET_SERVER_CFG SERVER_VERSION of "localhost" to sVersion
84083>>>>>>>
84083>>>>>>>Function MertechInc_GET_SERVER_CFG Global String sServer Integer iAttribute Returns String
84085>>>>>>>    Local String sReturnValue
84085>>>>>>>
84085>>>>>>>    Get MertechInc_Pre_Size_String 512 to sReturnValue
84086>>>>>>>
84086>>>>>>>    Call_Driver 0 MertechInc_DriverName Function CALLDRV_GET_SERVER_CFG CALLBACK 0 PASSING sServer sReturnValue iAttribute RESULT MertechInc_iRet
84091>>>>>>>
84091>>>>>>>    //If iAttribute = SERVER_VERSION or SERVER_ENCODING then return sReturnValue
84091>>>>>>>    //else we need to return MertechInc_iRet
84091>>>>>>>    If ((iAttribute = 4) or (iAttribute = 5)) Function_Return sReturnValue
84094>>>>>>>    Else                                      Function_Return MertechInc_iRet
84096>>>>>>>End_Function
