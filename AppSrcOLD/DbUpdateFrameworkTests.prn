84976>>>>>
84976>>>>>    Procedure Set Version String sVersion
84978>>>>>        Handle hoVersionInfo
84978>>>>>        Boolean bIncluded
84978>>>>>        Integer iMajor iMinor iRelease iBuild
84978>>>>>        Date dCompileDate
84978>>>>>
84978>>>>>        If (sVersion = "") Begin
84980>>>>>            // This automatically shows the program version of the program, if available.
84980>>>>>            // It will be displayed as the second item in the edit object.
84980>>>>>            If (ghoApplication <> 0) Begin
84982>>>>>                Get phoVersionInfo of ghoApplication to hoVersionInfo
84983>>>>>                If (hoVersionInfo <> 0) Begin
84985>>>>>                    Get pbIncluded of hoVersionInfo to bIncluded
84986>>>>>                    If (bIncluded) Begin
84988>>>>>                        Get piVersionMajor of hoVersionInfo to iMajor
84989>>>>>                        Get piVersionMinor of hoVersionInfo to iMinor
84990>>>>>                        Get piVersionRelease of hoVersionInfo to iRelease
84991>>>>>                        Get piVersionBuild of hoVersionInfo to iBuild
84992>>>>>                        Move (SFormat (C_$VERSION + ": %1.%2.%3.%4", iMajor, iMinor, iRelease, iBuild)) to sVersion
84993>>>>>                    End
84993>>>>>>
84993>>>>>                End
84993>>>>>>
84993>>>>>            End
84993>>>>>>
84993>>>>>        End
84993>>>>>>
84993>>>>>
84993>>>>>        // Display the compiled date as the next row in the edit object, after the program version.
84993>>>>>        Get GetCompileDate to dCompileDate
84994>>>>>        If (sVersion <> "") Begin
84996>>>>>            Send Add_Lineln (sVersion + (Character(13)) + C_$Compile_Date * String(dCompileDate))
84997>>>>>        End
84997>>>>>>
84997>>>>>    End_Procedure
84998>>>>>
84998>>>>>    Function GetCompileDate Returns Date
85000>>>>>        Date dCompileDate
85000>>>>>        String sAppFilename sData sCompileDate
85000>>>>>        Integer iChannel iPos iDateFormat
85000>>>>>
85000>>>>>        // Get full path to the current running executable
85000>>>>>        Get GetApplicationFileName of ghoApplication to sAppFilename
85001>>>>>
85001>>>>>        //Read the current file  up to where the data we're interesting in is (this was hand calced and so could vary)
85001>>>>>        Get Seq_Open_Input_Channel ("binary:" * sAppFilename) to iChannel
85002>>>>>        Read_Block channel iChannel sData (8 * 1024)    // First 8K is .exe header skip it
85004>>>>>        Read_Block channel iChannel sData 75            // The compile information we're interested in
85006>>>>>        Send Seq_Close_Channel iChannel
85007>>>>>
85007>>>>>        // The data is padded with Character(0)s. Strip them out
85007>>>>>        Move (CString(sData)) to sData
85008>>>>>
85008>>>>>        // The compile date is after the first ", ", so string parsing is required
85008>>>>>        Move (Pos(", ", sData)) to iPos
85009>>>>>        Move (Mid(sData, 10, (iPos + 2) ))  to sCompileDate // In US format
85010>>>>>        // If the current date format is non US, we need to temporary
85010>>>>>        // change the format and then move the string to the date variable.
85010>>>>>        Get_Attribute DF_DATE_FORMAT        to iDateFormat
85013>>>>>        Set_Attribute DF_DATE_FORMAT        to DF_DATE_USA
85016>>>>>        Move (Date(sCompileDate))           to dCompileDate
85017>>>>>        Set_Attribute DF_DATE_FORMAT        to iDateFormat // Reset date format
85020>>>>>
85020>>>>>        Function_Return dCompileDate
85021>>>>>    End_Function
85022>>>>>
