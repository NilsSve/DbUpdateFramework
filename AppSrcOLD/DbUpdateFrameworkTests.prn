83075>>>>>>>/// @Assumptions
83075>>>>>>>/// @Status      Internal
83075>>>>>>>/// @Drivers     n/a
83075>>>>>>>/// @VersionNote Last Revised: 2009-08-17 By Ian Smith
83075>>>>>>>Procedure MertechInc_Set_DecSep Global
83077>>>>>>>    Get_Attribute DF_DECIMAL_SEPARATOR to MertechInc_iDecSep
83080>>>>>>>    If MertechInc_iDecSep Ne 46 Set_Attribute DF_DECIMAL_SEPARATOR to 46 // (.) WILL BE DECIMAL SEPARATOR
83085>>>>>>>End_Procedure
83086>>>>>>>
83086>>>>>>>//=============================================================================
83086>>>>>>>/// @Name        MertechInc_Reset_DecSep
83086>>>>>>>/// @Description Sets the decimal separator to the saved value.
83086>>>>>>>///
83086>>>>>>>/// @Status      Internal
83086>>>>>>>/// @Drivers     n/a
83086>>>>>>>/// @VersionNote Last Revised: 2009-08-17 By Ian Smith
83086>>>>>>>///
83086>>>>>>>Procedure MertechInc_Reset_DecSep Global
83088>>>>>>>    If MertechInc_iDecSep Ne 46 Set_Attribute DF_DECIMAL_SEPARATOR to MertechInc_iDecSep
83093>>>>>>>End_Procedure
83094>>>>>>>
83094>>>>>>>//=============================================================================
83094>>>>>>>/// @Name        FETCH_FIELD
83094>>>>>>>/// @Description Selects or de-selects the fields to be fetched during the
83094>>>>>>>/// next FIND (query).
83094>>>>>>>///
83094>>>>>>>/// @Status      Internal
83094>>>>>>>/// @Drivers     All
83094>>>>>>>/// @VersionNote Last Revised: 2009-07-16 By Ian Smith
83094>>>>>>>///
83094>>>>>>>/// @Syntax FETCH_FIELD <FileNum> <FieldStart> THRU <FieldEnd> TO DF_FETCH_TRUE
83094>>>>>>>/// @Param  FileNum    is the File Number
83094>>>>>>>/// @Param  FieldStart is the Field Name or Number that will start the selection range
83094>>>>>>>/// @Param  FieldEnd   is the Field Name or Number that will finish the selection range
83094>>>>>>>///
83094>>>>>>>/// @Syntax FETCH_FIELD <FileNum> <Field1> TO DF_FETCH_TRUE
83094>>>>>>>/// @Param  FileNum  is the File Number
83094>>>>>>>/// @Param  Field1 Fields Name or Number to be selected
83094>>>>>>>///
83094>>>>>>>
83094>>>>>>>//=============================================================================
83094>>>>>>>/// @Name        SQL_TEXT_MESSAGE
83094>>>>>>>/// @Description Use this command to manually insert a string into a trace
83094>>>>>>>/// file. This can be useful for readability within the trace file to log
83094>>>>>>>/// what is actually happening at certain points.
83094>>>>>>>///
83094>>>>>>>/// @Assumptions The text string is less than 80 characters long.
83094>>>>>>>/// @Status      Public
83094>>>>>>>/// @Drivers     All
83094>>>>>>>/// @VersionNote Last Revised: 20013-08-19 by Aaron Gulack
83094>>>>>>>/// @See         ENABLE_TRACE_ON DISABLE_TRACE_ON
83094>>>>>>>///
83094>>>>>>>/// @Syntax SQL_TEXT_MESSAGE {variable}
83094>>>>>>>/// @Param  {variable}          The string to insert into the trace file.
83094>>>>>>>///
83094>>>>>>>/// @Example
83094>>>>>>>/// Login "localhost" "mds" "mertech" "ora_drv"
83094>>>>>>>///
83094>>>>>>>/// ENABLE_TRACE_ON to "c:\trace.txt" DEBUG_LEVEL
83094>>>>>>>/// open Customer
83094>>>>>>>/// SQL_TEXT_MESSAGE "The table has been opened"
83094>>>>>>>
83094>>>>>>>//=============================================================================
83094>>>>>>>/// @Name       SELECT_COLUMNS_FIND
83094>>>>>>>/// @Description This command is used to fetch only a certain number of fields
83094>>>>>>>/// while doing a "find". When specifying the field number to start from and
83094>>>>>>>/// field number to end on, the find will only fetch the given fields from the
83094>>>>>>>/// record. It is important to always use this command after first deselecting
83094>>>>>>>/// all columns i.e. setting RESET_FETCH_FIELDS to DF_FETCH_FALSE. Also, after
83094>>>>>>>/// using this command, all columns need to be reselected i.e. setting
83094>>>>>>>/// RESET_FETCH_FIELDS to DF_FETCH_TRUE. Note that fields used as a part the
83094>>>>>>>/// index segment associated with the find will always be fetched regardless.
83094>>>>>>>///
83094>>>>>>>/// @Assumptions
83094>>>>>>>/// @Status      Public
83094>>>>>>>/// @Drivers     All
83094>>>>>>>/// @VersionNote Last Revised: 20014-04-30 by Marcello Yo
83094>>>>>>>/// @See         RESET_FETCH_FIELDS DISABLE_SELECT_COLUMNS_ERRORS
83094>>>>>>>///
83094>>>>>>>/// @Syntax SELECT_COLUMNS_FIND {FileNumber} {fieldStart} THRU {fieldEnd}
83094>>>>>>>/// @Param  FileNumber          The number of the file
83094>>>>>>>/// @Param  fieldStart          The field number to start the fetch from
83094>>>>>>>/// @Param  FieldEnd            The field number to end the fetch at
83094>>>>>>>///
83094>>>>>>>/// @Example
83094>>>>>>>/// Open Customer
83094>>>>>>>/// RESET_FETCH_FIELDS  CUSTOMER DF_FETCH_FALSE
83094>>>>>>>/// SELECT_COLUMNS_FIND CUSTOMER CUSTOMER_NUMBER NAME
83094>>>>>>>/// DISABLE_SELECT_COLUMNS_ERRORS DISABLED
83094>>>>>>>///
83094>>>>>>>/// Clear Customer
83094>>>>>>>/// Repeat
83094>>>>>>>///    Find Gt Customer by Index.1
83094>>>>>>>///    If (Found) Showln Customer.Customer_Number '-' Customer.Name
83094>>>>>>>/// Until (Not(Found))
83094>>>>>>>///
83094>>>>>>>/// RESET_FETCH_FIELDS Customer DF_FETCH_TRUE
83094>>>>>>>
83094>>>>>>>
83094>>>>>>>//=============================================================================
83094>>>>>>>/// @Name        RESET_FETCH_FIELDS
83094>>>>>>>/// @Description This command is used to specify whether to retrieve all columns
83094>>>>>>>/// or no columns when performing a find. It is usually used with the command
83094>>>>>>>/// SELECT_COLUMNS_FIND to reset the column fetching. This command can either be
83094>>>>>>>/// set to DF_FETCH_TRUE, which will fetch all columns or set to DF_FETCH_FALSE,
83094>>>>>>>/// which will fetch no columns.
83094>>>>>>>/// @Assumptions
83094>>>>>>>/// @Status      Public
83094>>>>>>>/// @Drivers     All
83094>>>>>>>/// @VersionNote Last Revised: 2014-04-30 by Marcello Yo
83094>>>>>>>/// @See         SELECT_COLUMNS_FIND DISABLE_SELECT_COLUMNS_ERRORS
83094>>>>>>>///
83094>>>>>>>/// @Syntax RESET_FETCH_FIELDS {FileNumber} {DF_FETCH_TRUE/DF_FETCH_FALSE}
83094>>>>>>>/// @Param  FileNumber                  The number of the file
83094>>>>>>>/// @Param  DF_FETCH_TRUE               fetch all columns
83094>>>>>>>/// @Param  DF_FETCH_FALSE              fetch no columns
83094>>>>>>>///
83094>>>>>>>/// @Example
83094>>>>>>>/// Open Customer
83094>>>>>>>/// RESET_FETCH_FIELDS  CUSTOMER DF_FETCH_FALSE
83094>>>>>>>/// SELECT_COLUMNS_FIND CUSTOMER CUSTOMER_NUMBER NAME
83094>>>>>>>/// DISABLE_SELECT_COLUMNS_ERRORS DISABLED
83094>>>>>>>///
83094>>>>>>>/// Clear Customer
83094>>>>>>>/// Repeat
83094>>>>>>>///    Find Gt Customer by Index.1
83094>>>>>>>///    If (Found) Showln Customer.Customer_Number '-' Customer.Name
83094>>>>>>>/// Until (Not(Found))
83094>>>>>>>///
83094>>>>>>>/// RESET_FETCH_FIELDS Customer DF_FETCH_TRUE
83094>>>>>>>
83094>>>>>>>//=============================================================================
83094>>>>>>>/// @Name        SQL_FOR_ONEROW
83094>>>>>>>/// @Description This command will instruct the driver to fetch one row
83094>>>>>>>/// per query
83094>>>>>>>///
83094>>>>>>>/// @Assumptions
83094>>>>>>>/// @Status      Deprecated
83094>>>>>>>/// @Drivers     All
83094>>>>>>>/// @VersionNote Last Revised: 2013-08-19 by Aaron Gulack
83094>>>>>>>/// @See
83094>>>>>>>///
83094>>>>>>>/// @Syntax SQL_FOR_ONEROW {FileNumber}
83094>>>>>>>/// @Param  FileNumber          The number of the file
83094>>>>>>>/// @Example
83094>>>>>>>///     open Customer
83094>>>>>>>///     SQL_FOR_ONEROW Customer.File_Number
83094>>>>>>>///     Repeat
83094>>>>>>>///             find gt Customer by Recnum
83094>>>>>>>///         If (Found) Begin
83094>>>>>>>///             showln "Sales name is " Customer.FirstName
83094>>>>>>>///         end
83094>>>>>>>///     until (Customer.ID = 10)
83094>>>>>>>
83094>>>>>>>//=============================================================================
83094>>>>>>>/// @Name        SQL_REFRESH_CACHE
83094>>>>>>>/// @Description For optimization during record retrieval, a set number of
83094>>>>>>>/// records are stored in a local cache. This command forces a refresh, by
83094>>>>>>>/// making the next find retrieve the record from the database instead of
83094>>>>>>>/// the cache.
83094>>>>>>>///
83094>>>>>>>/// @Assumptions
83094>>>>>>>/// @Status      Public
83094>>>>>>>/// @Drivers     All
83094>>>>>>>/// @VersionNote Last Revised: 2013-08-19 by Aaron Gulack
83094>>>>>>>/// @See
83094>>>>>>>///
83094>>>>>>>/// @Syntax SQL_REFRESH_CACHE OF {FileNumber}
83094>>>>>>>/// @Param  FileNumber          The number of the file
83094>>>>>>>/// @Example
83094>>>>>>>/// Open Customer
83094>>>>>>>///
83094>>>>>>>/// Find gt Customer by Index.1
83094>>>>>>>/// While (Found) Begin
83094>>>>>>>///     showln "Customer name is " CUSTOMER.CUSTOMER
83094>>>>>>>/// Loop
83094>>>>>>>///
83094>>>>>>>/// SQL_REFRESH_CACHE of CUSTOMER
83094>>>>>>>
83094>>>>>>>//=============================================================================
83094>>>>>>>/// @Name        SQL_FOR_SET
83094>>>>>>>/// @Description Use this command during LT or GT finds to only fetch a set
83094>>>>>>>/// number of rows. An option is also available for this command to disable
83094>>>>>>>/// the local cash by passing NOCACHE at the end of the command call. Note
83094>>>>>>>/// that if the rowcount is set low, too many round-trips to the server may
83094>>>>>>>/// result, effecting performance significantly. Also, if the rowcount is set
83094>>>>>>>/// too high a large number of records can be pre-fetched and end up not being
83094>>>>>>>/// used by the application. Because of this, the default of 10 rows and a cache
83094>>>>>>>/// will be adequate for most situations.
83094>>>>>>>///
83094>>>>>>>/// @Assumptions
83094>>>>>>>/// @Status      Public
83094>>>>>>>/// @Drivers     All
83094>>>>>>>/// @VersionNote Last Revised: 2013-08-20 by Aaron Gulack
83094>>>>>>>/// @See
83094>>>>>>>///
83094>>>>>>>/// @Syntax SQL_FOR_SET {FileNumber} MAXROWS {variable} {CACHE/NOCACHE}
83094>>>>>>>/// @Param  FileNumber          The number of the file
83094>>>>>>>/// @Param  variable            The maximum number of rows to retrieve
83094>>>>>>>/// @Param  CACHE               fetched rows will be kept at the local cache
83094>>>>>>>/// @Param  NOCACHE             fetched rows will not be kept at the local cache
83094>>>>>>>/// @Example
83094>>>>>>>/// Open Customer
83094>>>>>>>///
83094>>>>>>>/// SQL_FOR_SET Customer MAXROWS 15 CACHE
83094>>>>>>>/// find gt Customer by Index.1
83094>>>>>>>
83094>>>>>>>//=============================================================================
83094>>>>>>>/// @Name        SQL_SET
83094>>>>>>>/// @Description Initializes and sets an initial statement for embedded
83094>>>>>>>/// sql execution.
83094>>>>>>>///
83094>>>>>>>/// @Assumptions Parameter may be more than 255 characters long so redirect to method.
83094>>>>>>>/// @Status      Deprecated
83094>>>>>>>/// @Drivers     All
83094>>>>>>>/// @VersionNote Last Revised: 2013-08-20 by Aaron Gulack
83094>>>>>>>/// @See         SQL_SET_STMT
83094>>>>>>>///
83094>>>>>>>/// @Syntax SQL_SET {FileNumber}
83094>>>>>>>/// @Param  FileNumber          The number of the file
83094>>>>>>>
83094>>>>>>>Procedure MertechInc_SQL_SET Global String sStatement
83096>>>>>>>    Call_Driver 0 MertechInc_DriverName Function 1 CALLBACK 0 PASSING MertechInc_Blank sStatement 0 RESULT MertechInc_iRet
83101>>>>>>>End_Procedure
83102>>>>>>>
83102>>>>>>>//=============================================================================
83102>>>>>>>/// @Name        SQL_APPEND
83102>>>>>>>/// @Description Appends a string value to the current embedded sql statement
83102>>>>>>>/// already set.
83102>>>>>>>///
83102>>>>>>>/// @Assumptions Parameter may be more than 255 characters long so redirect to method.
83102>>>>>>>/// @Status      Deprecated
83102>>>>>>>/// @Drivers     All
83102>>>>>>>/// @VersionNote Last Revised: 2013-08-20 by Aaron Gulack
83102>>>>>>>/// @See                 SQL_APPEND_STMT
83102>>>>>>>
83102>>>>>>>Procedure MertechInc_SQL_APPEND Global String sStatement
83104>>>>>>>    Call_Driver 0 MertechInc_DriverName Function 2 CALLBACK 0 PASSING MertechInc_Blank sStatement 0 RESULT MertechInc_iRet
83109>>>>>>>End_Procedure
83110>>>>>>>
83110>>>>>>>//=============================================================================
83110>>>>>>>/// @Name        SQL_EXECUTE
83110>>>>>>>/// @Description Executes the current embedded SQL statement set and commits
83110>>>>>>>/// finishing any pending transaction.
83110>>>>>>>///
83110>>>>>>>/// @Assumptions
83110>>>>>>>/// @Status      Deprecated
83110>>>>>>>/// @Drivers     All
83110>>>>>>>/// @VersionNote Last Revised: 2013-08-20 by Aaron Gulack
83110>>>>>>>/// @See                 SQL_EXECUTE_STMT
83110>>>>>>>
83110>>>>>>>//=============================================================================
83110>>>>>>>/// @Name        LOCK_TABLE
83110>>>>>>>/// @Description Locks a table. This is equivalent to locking a DAT file.
83110>>>>>>>///
83110>>>>>>>/// @Assumptions
83110>>>>>>>/// @Status      Deprecated
83110>>>>>>>/// @Drivers     DB2Flex, and ORAFlex 3.x
83110>>>>>>>/// @VersionNote Last Revised: 2013-08-20 by Aaron Gulack
83110>>>>>>>/// @See
83110>>>>>>>///
83110>>>>>>>/// @Syntax LOCK_TABLE {FileName} {FileName1} {FileName2} {FileName3}...
83110>>>>>>>/// @Param  FileName            The name of file to be locked. Can be more than one
83110>>>>>>>
83110>>>>>>>//=============================================================================
83110>>>>>>>/// @Name        SQL_CHECK_TABLE
83110>>>>>>>/// @Description Use this command to verify that a given table exists on the
83110>>>>>>>/// SQL backend. This command takes three arguments, a string containing the
83110>>>>>>>/// name of the database, a string containing the name of the user and finally
83110>>>>>>>/// a string containing the name of the table being checked. If the table exists,
83110>>>>>>>/// the program proceeds normally. If the table does not exist then the flag
83110>>>>>>>/// "finderr" is set to true. Note that in order to handle the error a check must
83110>>>>>>>/// be done on the "finderr" variable.
83110>>>>>>>///
83110>>>>>>>/// @Assumptions All three parameters are less than 256 characters long.
83110>>>>>>>/// @Status      Public
83110>>>>>>>/// @Drivers     All
83110>>>>>>>/// @VersionNote Last Revised: 2013-08-20 by Aaron Gulack
83110>>>>>>>/// @See
83110>>>>>>>///
83110>>>>>>>/// @Syntax SQL_CHECK_TABLE {database} {username} {table}
83110>>>>>>>/// @Param  database            Name of the database
83110>>>>>>>/// @Param  username            Name of the user
83110>>>>>>>/// @Param  table                       Name of the table being checked
83110>>>>>>>///
83110>>>>>>>/// @Example
83110>>>>>>>/// SQL_CHECK_TABLE "testDB" "user" "Customer"
83110>>>>>>>/// If (finderr) Begin
83110>>>>>>>///     Showln "This table does not exist"
83110>>>>>>>/// End
83110>>>>>>>
83110>>>>>>>//=============================================================================
83110>>>>>>>/// @Name        SET_SQL_CONSTRAINT
83110>>>>>>>/// @Description This command allows you to put an additional constraint on
83110>>>>>>>/// your finds, moving filtering to the SQL backend. Using this command can
83110>>>>>>>/// result in significantly improved performance, since the server network traffic
83110>>>>>>>/// reduced. Note that the SQL statement passed for this command is added onto
83110>>>>>>>/// the predefined Database SQL statement so treat it as such. Because of this,
83110>>>>>>>/// it will almost always begin with "AND" followed by the desired constraint.
83110>>>>>>>///
83110>>>>>>>/// @Assumptions Parameter may be more than 255 characters long so redirect to method.
83110>>>>>>>/// @Status      Public
83110>>>>>>>/// @Drivers     All
83110>>>>>>>/// @VersionNote Last Revised: 2013-08-20 by Aaron Gulack
83110>>>>>>>/// @See         SQL_CONSTRAINT GET_SQL_CONSTRAINT DF_FIELD_PROGRAMMATIC_DEFAULT
83110>>>>>>>///
83110>>>>>>>/// @Syntax SET_SQL_CONSTRAINT of {file} to {variable}
83110>>>>>>>/// @Param  file                        Name or Number of the file.
83110>>>>>>>/// @Param  variable            A SQL expression that constrains the data
83110>>>>>>>///
83110>>>>>>>/// @Example
83110>>>>>>>/// Open Customer
83110>>>>>>>///
83110>>>>>>>/// SET_SQL_CONSTRAINT of 1 to (SFormat('AND "%1"."%2" = ' + "'%3'", "Customer", "Status", "Active"))
83110>>>>>>>///
83110>>>>>>>/// For_All Customer by Index.1 do
83110>>>>>>>///     Showln Customer.FirstName
83110>>>>>>>/// End_For_All
83110>>>>>>>
83110>>>>>>>Procedure MertechInc_SET_SQL_CONSTRAINT Global Integer iFunction String sConstraint
83112>>>>>>>    Call_Driver MertechInc_FileNumber MertechInc_DriverName Function iFunction CALLBACK 0 PASSING sConstraint MertechInc_Blank 0 RESULT MertechInc_iRet
83117>>>>>>>End_Procedure
83118>>>>>>>
83118>>>>>>>Procedure MertechInc_SET_SQL_CONSTRAINT_PROGRAMMATIC Global Integer iFunction
83120>>>>>>>    Call_Driver MertechInc_FileNumber MertechInc_DriverName Function iFunction CALLBACK 0 PASSING MertechInc_Blank MertechInc_Blank 4 RESULT MertechInc_iRet
83125>>>>>>>End_Procedure
83126>>>>>>>
83126>>>>>>>//=============================================================================
83126>>>>>>>/// @Name        GET_SQL_CONSTRAINT
83126>>>>>>>/// @Description This command returns the current SQL constraint for the given
83126>>>>>>>/// table.  If there is no current constraint, then a blank string is returned.
83126>>>>>>>///
83126>>>>>>>/// @Assumptions Parameter may be more than 255 characters long so redirect to method.
83126>>>>>>>/// @Status      Public
83126>>>>>>>/// @Drivers     All
83126>>>>>>>/// @VersionNote Last Revised: 2013-08-20 by Aaron Gulack
83126>>>>>>>/// @See         SQL_CONSTRAINT SET_SQL_CONSTRAINT
83126>>>>>>>///
83126>>>>>>>/// @Syntax GET_SQL_CONSTRAINT of {File} to {variable}
83126>>>>>>>/// @Param  File                        Name or number of the file
83126>>>>>>>/// @Param  variable            The string containing the constraining SQL expression
83126>>>>>>>///
83126>>>>>>>/// @Example
83126>>>>>>>/// Open Customer
83126>>>>>>>///
83126>>>>>>>/// String sCon
83126>>>>>>>///
83126>>>>>>>/// SET_SQL_CONSTRAINT of Customer to (SFormat('AND "%1"."%2" = ' + "'%3'", "Customer", "Status", "Active"))
83126>>>>>>>/// GET_SQL_CONSTRAINT of Customer to sCon
83126>>>>>>>///
83126>>>>>>>/// For_All Customer by Index.1 do
83126>>>>>>>///     Showln Customer.FirstName
83126>>>>>>>///     Showln sCon
83126>>>>>>>/// End_For_All
83126>>>>>>>
83126>>>>>>>Function MertechInc_GET_SQL_CONSTRAINT Global Integer iFunction Returns String
83128>>>>>>>    Local String sConstraint
83128>>>>>>>    Get MertechInc_Pre_Size_String 0 to sConstraint
83129>>>>>>>
83129>>>>>>>    Call_Driver MertechInc_FileNumber MertechInc_DriverName Function iFunction CALLBACK 0 PASSING sConstraint MertechInc_Blank 3 RESULT MertechInc_iRet
83134>>>>>>>    Function_Return sConstraint
83135>>>>>>>End_Function
83136>>>>>>>
83136>>>>>>>//=============================================================================
83136>>>>>>>/// @Name        SQL_CONSTRAINT
83136>>>>>>>/// @Description This command is used to toggle on or off the current SQL
83136>>>>>>>/// constraint that is set for a table. To deactivate the current constraint,
83136>>>>>>>/// pass the constant DEACTIVATE to this command. to reactivate the constraint,
83136>>>>>>>/// pass ACTIVATE to this command.
83136>>>>>>>///
83136>>>>>>>/// @Status      Public
83136>>>>>>>/// @Drivers     All
83136>>>>>>>/// @VersionNote Last Revised: 2013-08-20 by Aaron Gulack
83136>>>>>>>/// @See         SET_SQL_CONSTRAINT GET_SQL_CONSTRAINT
83136>>>>>>>///
83136>>>>>>>/// @Syntax SQL_CONSTRAINT of {File} to {Activate|Deactivate}
83136>>>>>>>/// @Param  File                        Name or Number of the file
83136>>>>>>>/// @Param  Activate            Activates the constraint
83136>>>>>>>/// @Param  Deactivate          Deactivates the constraint
83136>>>>>>>///
83136>>>>>>>/// @Example
83136>>>>>>>/// Open Customer
83136>>>>>>>///
83136>>>>>>>/// SET_SQL_CONSTRAINT of Customer to (SFormat('AND "%1"."%2" = ' + "'%3'", "Customer", "FirstName", "Aaron"))
83136>>>>>>>/// SQL_CONSTRAINT of Customer to Deactivate
83136>>>>>>>///
83136>>>>>>>/// For_All Customer by Index.1 do
83136>>>>>>>///     Showln Customer.FirstName
83136>>>>>>>/// End_For_All
83136>>>>>>>
83136>>>>>>>//=============================================================================
83136>>>>>>>/// @Name        CREATE_TD_FILE
83136>>>>>>>/// @Description A .TD file is created when the attribute is set to True.
83136>>>>>>>///
83136>>>>>>>/// @Assumptions
83136>>>>>>>/// @Status      Deprecated
83136>>>>>>>/// @Drivers     All
83136>>>>>>>/// @VersionNote Last Revised: 2013-08-20 by Aaron Gulack
83136>>>>>>>/// @See
83136>>>>>>>///
83136>>>>>>>/// @Syntax CREATE_TD_FILE {variable}
83136>>>>>>>/// @Param  variable            True to create the .TD file, false doesn't create it.
83136>>>>>>>
83136>>>>>>>//=============================================================================
83136>>>>>>>/// @Name        OPEN_INT
83136>>>>>>>/// @Description This command is used to replace the OPEN command in DataFlex.
83136>>>>>>>/// It can be useful when accessing tables that are not in the current filelist.
83136>>>>>>>/// To access these tables, the INT and FD files must be in the directory. From
83136>>>>>>>/// there, all that is needed is to open the table using this command under an
83136>>>>>>>/// alias name. If the command is executed successfully then the table can be
83136>>>>>>>/// queried normally as if it were a standard table. Note that if the desired
83136>>>>>>>/// table is already in the filelist or doesn't have an INT file then this
83136>>>>>>>/// command will act as a normal open command.
83136>>>>>>>///
83136>>>>>>>/// @Assumptions
83136>>>>>>>/// @Status      Public
83136>>>>>>>/// @Drivers     All
83136>>>>>>>/// @VersionNote Last Revised: 2013-08-21 by Aaron Gulack
83136>>>>>>>/// @See
83136>>>>>>>///
83136>>>>>>>/// @Syntax OPEN_INT {variable} as {aliasName}
83136>>>>>>>/// @Param  variable            The name of the int file without the extension.
83136>>>>>>>/// @Param  aliasName           The alias name being used to query this table.
83136>>>>>>>/// @Example
83136>>>>>>>/// OPEN_INT "customer" as Customer
83136>>>>>>>///
83136>>>>>>>/// For_All Customer by Index.1 do
83136>>>>>>>///     Showln Customer.FirstName
83136>>>>>>>/// End_For_All
83136>>>>>>>
83136>>>>>>>//=============================================================================
83136>>>>>>>/// @Name        SET_OPEN_MODE
83136>>>>>>>/// @Description This command is used to enable an option known as "Lazy Open
83136>>>>>>>/// Mode". When turned on the table's metadata i.e. table, columns, index
83136>>>>>>>/// descriptions, is deferred until a field is accessed, even if a OPEN has
83136>>>>>>>/// already been done. This can significantly improve an application's initial
83136>>>>>>>/// performance, especially when a large number of files are opened when the
83136>>>>>>>/// program is launched. By default, tables are set to open normally, but by
83136>>>>>>>/// passing the constant LAZY_MODE to this command, it can be altered to use
83136>>>>>>>/// this mode. Note that when this mode is activated, it effects all tables
83136>>>>>>>/// that are opened. To deactivate this feature, pass the constant "DEFAULT"
83136>>>>>>>/// to this command at any time. This is the preferred method to activate or
83136>>>>>>>/// deactive this feature but it can also be set globally in the .INI file.
83136>>>>>>>///
83136>>>>>>>/// Default Value: DEFAULT (Off)
83136>>>>>>>///
83136>>>>>>>/// @Assumptions
83136>>>>>>>/// @Status      Public
83136>>>>>>>/// @Drivers     All
83136>>>>>>>/// @VersionNote Last Revised: 2013-08-21 by Aaron Gulack
83136>>>>>>>/// @See
83136>>>>>>>///
83136>>>>>>>/// @Syntax SET_OPEN_MODE to {DEFAULT/LAZY_MODE}
83136>>>>>>>/// @Param  DEFAULT                     Used to turn of the lazy mode feature.
83136>>>>>>>/// @Param  LAZY_MODE           Turns on the lazy mode feature
83136>>>>>>>///
83136>>>>>>>/// @Example
83136>>>>>>>/// SET_OPEN_MODE TO LAZY_MODE
83136>>>>>>>/// Open "customer.int" as Customer
83136>>>>>>>/// ...
83136>>>>>>>/// ...
83136>>>>>>>/// Find gt Customer by Index.1
83136>>>>>>>
83136>>>>>>>//=============================================================================
83136>>>>>>>/// @Name        SQL_SET_STMT
83136>>>>>>>/// @Description Use this command to set an SQL statement to be executed on the
83136>>>>>>>/// desired table. The string passed to this command must be a valid SQL
83136>>>>>>>/// expression and must be on a table that has already been opened. Note that
83136>>>>>>>/// when using this command, the SQL_PREPARE_STMT and SQL_EXECUTE_STMT must be
83136>>>>>>>/// used in addition to carry out the expression. The option to pass the file
83136>>>>>>>/// name as an extra parameter is used in cases where the data needs to be
83136>>>>>>>/// fetched directly into the record buffer of the specified file.
83136>>>>>>>///
83136>>>>>>>/// @Assumptions Parameter may be more than 255 characters long so redirect to method.
83136>>>>>>>/// @Status      Public
83136>>>>>>>/// @Drivers     All
83136>>>>>>>/// @VersionNote Last Revised: 2013-08-21 by Aaron Gulack
83136>>>>>>>/// @See                 SQL_APPEND_STMT SQL_PREPARE_STMT SQL_EXECUTE_STMT SQL_CANCEL_QUERY_STMT SQL_FETCH_NEXT_ROW SQL_BINDCOLUMNS_STMT
83136>>>>>>>///
83136>>>>>>>/// @Syntax SQL_SET_STMT [of {file}] to {variable}
83136>>>>>>>/// @Param file                         Name or number of the file (optional)
83136>>>>>>>/// @Param variable                     String containing the SQL statement
83136>>>>>>>///
83136>>>>>>>/// @Usage SQL_SET_STMT of Customer to "SELECT * FROM CUSTOMER WHERE STATUS = 'Active'"
83136>>>>>>>/// @Usage SQL_SET_STMT to "SELECT * FROM CUSTOMER WHERE STATUS = 'Active'"
83136>>>>>>>///
83136>>>>>>>/// @Example
83136>>>>>>>/// Open Customer
83136>>>>>>>///
83136>>>>>>>/// String sID sFirstName sLastName sDOB
83136>>>>>>>///
83136>>>>>>>/// SQL_SET_STMT to "SELECT * FROM CUSTOMER WHERE STATUS = 'Active'"
83136>>>>>>>/// SQL_PREPARE_STMT
83136>>>>>>>/// SQL_EXECUTE_STMT
83136>>>>>>>/// While (Found)
83136>>>>>>>/// SQL_FETCH_NEXT_ROW into sID sFirstName sLastName sDOB
83136>>>>>>>///     Showln sID
83136>>>>>>>///     Showln sFirstName
83136>>>>>>>///     Showln sLastName
83136>>>>>>>///     Showln sDOB
83136>>>>>>>/// Loop
83136>>>>>>>/// SQL_CANCEL_QUERY_STMT
83136>>>>>>>
83136>>>>>>>Procedure MertechInc_SQL_SET_STMT Global String sStatment
83138>>>>>>>    Call_Driver MertechInc_FileNumber MertechInc_DriverName Function 22 CALLBACK 0 PASSING MertechInc_Blank sStatment 0 RESULT MertechInc_iRet
83143>>>>>>>End_Procedure
83144>>>>>>>
83144>>>>>>>//=============================================================================
83144>>>>>>>/// @Name        SQL_APPEND_STMT
83144>>>>>>>/// @Description This command is used to append a command string to the
83144>>>>>>>/// command buffer initialized by SQL_SET_STMT. SQL_APPEND_STMT was added
83144>>>>>>>/// so that long SQL expressions could be broken into smaller strings and
83144>>>>>>>/// appended to a dynamic command buffer, which is then passed to the server.
83144>>>>>>>/// The SQL_APPEND_STMT will concatenate a string to the command buffer
83144>>>>>>>/// initialized by the SQL_SET_STMT command. SQL_APPEND_STMT can be called as
83144>>>>>>>/// many times as necessary to complete the SQL expression. Subsequently, the
83144>>>>>>>/// SQL_EXECUTE_STMT command executes the completed command.  The option to
83144>>>>>>>/// pass the file name as an extra parameter is used in cases where the data
83144>>>>>>>/// needs to be fetched directly into the record buffer of the specified file.
83144>>>>>>>///
83144>>>>>>>/// @Assumptions Parameter may be more than 255 characters long so redirect to method.
83144>>>>>>>/// @Status      Public
83144>>>>>>>/// @Drivers     All
83144>>>>>>>/// @VersionNote Last Revised: 2013-08-22 by Aaron Gulack
83144>>>>>>>/// @See                 SQL_SET_STMT SQL_PREPARE_STMT SQL_EXECUTE_STMT SQL_CANCEL_QUERY_STMT SQL_FETCH_NEXT_ROW SQL_BINDCOLUMNS_STMT
83144>>>>>>>///
83144>>>>>>>/// @Syntax SQL_APPEND_STMT [of {file}] to {variable}
83144>>>>>>>/// @Param file                         The name or number of the file (optional)
83144>>>>>>>/// @Param variable                     The string to be appended to the current SQL expression
83144>>>>>>>///
83144>>>>>>>/// @Usage SQL_APPEND_STMT to " CUSTOMER.PHONE_NUMBER, CUSTOMER.FAX_NUMBER"
83144>>>>>>>/// @Usage SQL_APPEND_STMT of Customer to " CUSTOMER.PHONE_NUMBER, CUSTOMER.FAX_NUMBER"
83144>>>>>>>///
83144>>>>>>>/// @Example
83144>>>>>>>/// Open Customer
83144>>>>>>>///
83144>>>>>>>/// String sID sFirstName sLastName sDOB
83144>>>>>>>///
83144>>>>>>>/// SQL_SET_STMT to "SELECT * FROM CUSTOMER WHERE STATUS = 'Active'"
83144>>>>>>>/// SQL_PREPARE_STMT
83144>>>>>>>/// SQL_EXECUTE_STMT
83144>>>>>>>/// While (Found)
83144>>>>>>>///     SQL_FETCH_NEXT_ROW into sID sFirstName sLastName sDOB
83144>>>>>>>///     Showln sID
83144>>>>>>>///     Showln sFirstName
83144>>>>>>>///     Showln sLastName
83144>>>>>>>///     Showln sDOB
83144>>>>>>>/// Loop
83144>>>>>>>/// SQL_CANCEL_QUERY_STMT
83144>>>>>>>
83144>>>>>>>Procedure MertechInc_SQL_APPEND_STMT Global String sStatement
83146>>>>>>>    Call_Driver MertechInc_FileNumber MertechInc_DriverName Function 22 CALLBACK 0 PASSING MertechInc_Blank sStatement 1 RESULT MertechInc_iRet
83151>>>>>>>End_Procedure
83152>>>>>>>
83152>>>>>>>//=============================================================================
83152>>>>>>>/// @Name        APPEND_UPDATE_COLUMN
83152>>>>>>>/// @Description Append a given string to the existing SQL statement
83152>>>>>>>/// already set.
83152>>>>>>>///
83152>>>>>>>/// @Assumptions Parameter may be more than 255 characters long so redirect to method
83152>>>>>>>/// @Status      Internal
83152>>>>>>>/// @Drivers     All
83152>>>>>>>/// @VersionNote Last Revised: 2013-08-23 by Aaron Gulack
83152>>>>>>>/// @See
83152>>>>>>>///
83152>>>>>>>/// @Syntax APPEND_UPDCOL_STMT {variable} for {fileName}.{fieldName} {fields...}
83152>>>>>>>/// @Param variable                             SQL expression to be appended
83152>>>>>>>/// @Param fileName                             Name of the file
83152>>>>>>>/// @Param fieldName                    Name of the field
83152>>>>>>>/// @Param fields...                    Any additional fields, use the file.field format
83152>>>>>>>
83152>>>>>>>Procedure MertechInc_APPEND_UPDATE_COLUMN Global String sStatement
83154>>>>>>>    Call_Driver MertechInc_FileNumber MertechInc_DriverName Function 22 CALLBACK 0 PASSING MertechInc_Blank sStatement 1 RESULT MertechInc_iRet
83159>>>>>>>End_Procedure
83160>>>>>>>
83160>>>>>>>//=============================================================================
83160>>>>>>>/// @Name        SQL_APPEND_UPDCOL_STMT
83160>>>>>>>/// @Description Used to optimize the update process of columns being loaded
83160>>>>>>>/// with the same value.
83160>>>>>>>///
83160>>>>>>>/// @Assumptions
83160>>>>>>>/// @Status      Deprecated
83160>>>>>>>/// @Drivers     All
83160>>>>>>>/// @VersionNote Last Revised: 2013-08-23 by Aaron Gulack
83160>>>>>>>/// @See
83160>>>>>>>///
83160>>>>>>>/// @Syntax SQL_APPEND_UPDCOL_STMT [of {file}] Value {variable} for {fileName}.{fieldName} {fields...}
83160>>>>>>>/// @Param file                         The name or number of the file (optional)
83160>>>>>>>/// @Param variable                     The value being uploaded
83160>>>>>>>/// @Param fileName                     The name of the file
83160>>>>>>>/// @Param fieldName            The name of the field
83160>>>>>>>/// @Param fields...            Any additional fields, use the file.field format
83160>>>>>>>///
83160>>>>>>>/// @Example
83160>>>>>>>/// Open Customer
83160>>>>>>>///
83160>>>>>>>/// SQL_SET_STMT    of Customer to "UPDATE CUSTOMER SET"
83160>>>>>>>/// SQL_APPEND_STMT of Customer to " ASC11='x', ASC12='y', ASC13='z'"
83160>>>>>>>///
83160>>>>>>>/// SQL_APPEND_UPDCOL_STMT of Customer value 0 ;
83160>>>>>>>///     for Customer.ID Customer.Purchases Customer.Credit ;
83160>>>>>>>///
83160>>>>>>>/// SQL_APPEND_STMT of Customer to " WHERE RECNUM=1"
83160>>>>>>>///
83160>>>>>>>/// SQL_PREPARE_STMT of Customer
83160>>>>>>>/// SQL_EXECUTE_STMT of Customer
83160>>>>>>>
83160>>>>>>>//=============================================================================
83160>>>>>>>/// @Name        SQL_SET_CURSOR_TYPE
83160>>>>>>>/// @Description Specify the SQL cursor type to be used during the next
83160>>>>>>>/// embedded SQL statement execution.
83160>>>>>>>///
83160>>>>>>>/// @Assumptions
83160>>>>>>>/// @Status      Internal
83160>>>>>>>/// @Drivers     SQLFlex
83160>>>>>>>/// @VersionNote Last Revised: 2013-08-23 by Aaron Gulack
83160>>>>>>>/// @See
83160>>>>>>>///
83160>>>>>>>/// @Syntax SQL_SET_CURSOR_TYPE to {TYPE_NONE/TYPE_CLIENT/TYPE_SERVER}
83160>>>>>>>/// @Param TYPE_NONE                    the default cursor type should be used
83160>>>>>>>/// @Param TYPE_CLIENT                  a client side cursor should be used
83160>>>>>>>/// @Param TYPE_SERVER                  a server side cursor should be used
83160>>>>>>>
83160>>>>>>>//=============================================================================
83160>>>>>>>/// @Name        CLEAR_INT_CACHE
83160>>>>>>>/// @Description Clears all memory-cached INT info. This is used in the
83160>>>>>>>/// test framework to force a "reload" of int info which the framework
83160>>>>>>>/// modifies for its tests. This is a different cache than the TD files
83160>>>>>>>/// which are a file based cache of the structure for use at file open.
83160>>>>>>>///
83160>>>>>>>/// @Assumptions
83160>>>>>>>/// @Status      Internal
83160>>>>>>>/// @Drivers     All
83160>>>>>>>/// @VersionNote Last Revised: 2013-08-23 by Aaron Gulack
83160>>>>>>>/// @See
83160>>>>>>>///
83160>>>>>>>/// @Syntax CLEAR_INT_CACHE
83160>>>>>>>
83160>>>>>>>//=============================================================================
83160>>>>>>>/// @Name        CREATE_INVERSE_KEY_FUNCTIONS
83160>>>>>>>/// @Description Create SQL Functions to handle Inverse Key columns.
83160>>>>>>>///
83160>>>>>>>/// @Assumptions
83160>>>>>>>/// @Status      Internal
83160>>>>>>>/// @Drivers     All (v10.1 and above)
83160>>>>>>>/// @VersionNote Last Revised: 2013-08-23 by Aaron Gulack
83160>>>>>>>/// @See
83160>>>>>>>///
83160>>>>>>>/// @Syntax CREATE_INVERSE_KEY_FUNCTIONS
83160>>>>>>>
83160>>>>>>>//=============================================================================
83160>>>>>>>/// @Name        SQL_PREPARE_STMT
83160>>>>>>>/// @Description Prepares a statement and opens a cursor to be executed by
83160>>>>>>>/// SQL_EXECUTE_STMT. This command tells the server to parse the SQL statement
83160>>>>>>>/// created by the respective SQL_SET_STMT and all subsequent SQL_APPEND_STMT
83160>>>>>>>/// statements and to allocate cursor handles to be used to fetch the data.
83160>>>>>>>/// A cursor can be thought of as a pointer to a record set. The CURSOR_TYPE
83160>>>>>>>/// argument is only supported by SQLFlex and by default SQLFLex is using a
83160>>>>>>>/// TYPE_SERVER cursor type to all embedded SQL. TYPE_CLIENT should be used only
83160>>>>>>>/// for the statements that are querying LOB columns i.e. TEXT, NVARCHAR(MAX),
83160>>>>>>>/// VARCHAR(MAX), IMAGE, VARBINARY(MAX), XML. If the cursor type is
83160>>>>>>>/// TYPE_SERVER and a LOB type column is selected, MS SQL Server will not be
83160>>>>>>>/// able to get into a transaction, either explicitly or implicitly through a
83160>>>>>>>/// REREAD, LOCK, SAVERECORD, etc.
83160>>>>>>>///
83160>>>>>>>/// @Assumptions
83160>>>>>>>/// @Status      Public
83160>>>>>>>/// @Drivers     All
83160>>>>>>>/// @VersionNote Last Revised: 2013-08-23 by Aaron Gulack
83160>>>>>>>/// @See                 SQL_SET_STMT SQL_APPEND_STMT SQL_EXECUTE_STMT SQL_CANCEL_QUERY_STMT SQL_FETCH_NEXT_ROW SQL_BINDCOLUMNS_STMT
83160>>>>>>>///
83160>>>>>>>/// @Syntax SQL_PREPARE_STMT [of {file}] CURSOR_TYPE {TYPE_NONE/TYPE_CLIENT/TYPE_SERVER}
83160>>>>>>>/// @Param file                         The name or number of the file (optional)
83160>>>>>>>/// @Param CURSOR_TYPE          Used if the cursor type is being set, do not include otherwise
83160>>>>>>>/// @Param TYPE_NONE            Default cursor will be used
83160>>>>>>>/// @Param TYPE_CLIENT          A client side cursor should be used
83160>>>>>>>/// @Param TYPE_SERVER          A server side cursor should be used (Default)
83160>>>>>>>///
83160>>>>>>>/// @Usage SQL_PREPARE_STMT
83160>>>>>>>/// @Usage SQL_PREPARE_STMT of Customer
83160>>>>>>>/// @Usage SQL_PREPARE_STMT CURSOR_TYPE TYPE_SERVER
83160>>>>>>>/// @Usage SQL_PREPARE_STMT of Customer CURSOR_TYPE TYPE_CLIENT
83160>>>>>>>///
83160>>>>>>>/// @Example
83160>>>>>>>/// Open Customer
83160>>>>>>>///
83160>>>>>>>/// String sID sFirstName
83160>>>>>>>///
83160>>>>>>>/// SQL_SET_STMT to "SELECT * FROM CUSTOMER WHERE STATUS = 'Active'"
83160>>>>>>>/// SQL_PREPARE_STMT
83160>>>>>>>/// SQL_EXECUTE_STMT
83160>>>>>>>/// SQL_FETCH_NEXT_ROW into sID sFirstName
83160>>>>>>>
83160>>>>>>>//=============================================================================
83160>>>>>>>/// @Name        SQL_BIND_COLUMN
83160>>>>>>>/// @Description Clears all cached INT info. This should be merged with
83160>>>>>>>/// SQL_BINDCOLUMNS_STMT, but has to remain as a separate command for
83160>>>>>>>/// compatibility.
83160>>>>>>>///
83160>>>>>>>/// @Assumptions
83160>>>>>>>/// @Status      Internal
83160>>>>>>>/// @Drivers     All
83160>>>>>>>/// @VersionNote Last Revised: 2013-08-26 by Aaron Gulack
83160>>>>>>>/// @See
83160>>>>>>>///
83160>>>>>>>/// @Syntax SQL_BIND_COLUMN FileNumber FieldNumber | DF_BIND_ALL_COLUMNS
83160>>>>>>>/// @Param FileNumber                   The number of the file
83160>>>>>>>/// @Param FieldNumber                  The number of the field
83160>>>>>>>
83160>>>>>>>//=============================================================================
83160>>>>>>>/// @Name        SQL_BINDCOLUMNS_STMT
83160>>>>>>>/// @Description This command is used to fetch the returned data of a
83160>>>>>>>/// specified SQL expression into the given field in the record buffer. By
83160>>>>>>>/// passing any number of fields to this command, the fetched record will then
83160>>>>>>>/// be put into the subsequent fields in the record buffer. The order of the
83160>>>>>>>/// fields must be the same as the order of the columns being retrieved from
83160>>>>>>>/// the SQL expression. SQL_FETCH_NEXT_ROW can then be called to take the data
83160>>>>>>>/// retrieved from the server and place it into the corresponding fields in the
83160>>>>>>>/// buffer. Instead of specifying each field, DF_BIND_ALL_COLUMNS can be passed,
83160>>>>>>>/// which will retrieve every column in the table.
83160>>>>>>>///
83160>>>>>>>/// @Assumptions
83160>>>>>>>/// @Status      Public
83160>>>>>>>/// @Drivers     All
83160>>>>>>>/// @VersionNote Last Revised: 2013-08-26 by Aaron Gulack
83160>>>>>>>/// @See                 SQL_SET_STMT SQL_APPEND_STMT SQL_PREPARE_STMT SQL_EXECUTE_STMT SQL_CANCEL_QUERY_STMT SQL_FETCH_NEXT_ROW
83160>>>>>>>///
83160>>>>>>>/// @Syntax SQL_BINDCOLUMNS_STMT of {file} to {field/DF_BIND_ALL_COLUMNS}
83160>>>>>>>///
83160>>>>>>>/// @Param file                 Name or number of the file
83160>>>>>>>/// @Param field                        Name or number of the field (can be multiple)
83160>>>>>>>/// @Param DF_BIND_ALL_COLUMNS  Used instead of the field to retrieve all columns in the file
83160>>>>>>>///
83160>>>>>>>/// @Example
83160>>>>>>>/// Open Customer
83160>>>>>>>///
83160>>>>>>>/// SQL_SET_STMT to "SELECT * FROM CUSTOMER WHERE STATUS = 'Active' "
83160>>>>>>>/// SQL_PREPARE_STMT
83160>>>>>>>/// SQL_BINDCOLUMNS_STMT of Customer to DF_BIND_ALL_COLUMNS
83160>>>>>>>/// SQL_EXECUTE_STMT of Customer
83160>>>>>>>/// While (Found)
83160>>>>>>>///     SQL_FETCH_NEXT_ROW of Customer
83160>>>>>>>///     Showln Customer.ID
83160>>>>>>>///     Showln Customer.FirstName
83160>>>>>>>///     Showln Customer.LastName
83160>>>>>>>///     Showln Customer.DOB
83160>>>>>>>/// Loop
83160>>>>>>>/// SQL_CANCEL_QUERY_STMT
83160>>>>>>>
83160>>>>>>>//=============================================================================
83160>>>>>>>/// @Name        SQL_EXECUTE_STMT
83160>>>>>>>/// @Description This command is used to execute the SQL expression created
83160>>>>>>>/// by the SQL_SET_STMT and any subsequent SQL_APPEND_STMT commands issued
83160>>>>>>>/// after a SQL_PREPARE_STMT. If the results will be sent to the record
83160>>>>>>>/// buffer directly, then the file must be specified. An optional parameter
83160>>>>>>>/// can also be passed, indicating the maximum number of rows to be sent to
83160>>>>>>>/// the local cache. This is done by adding the constant ROWCOUNT followed
83160>>>>>>>/// by the maximun number.
83160>>>>>>>///
83160>>>>>>>/// @Assumptions
83160>>>>>>>/// @Status      Public
83160>>>>>>>/// @Drivers     All
83160>>>>>>>/// @VersionNote Last Revised: 2013-08-26 by Aaron Gulack
83160>>>>>>>/// @See                 SQL_SET_STMT SQL_APPEND_STMT SQL_PREPARE_STMT SQL_CANCEL_QUERY_STMT SQL_FETCH_NEXT_ROW SQL_BINDCOLUMNS_STMT
83160>>>>>>>///
83160>>>>>>>/// @Syntax SQL_EXECUTE_STMT [of {file} ROWCOUNT {variable}]
83160>>>>>>>/// @Param file                         Name or number of the file (optional)
83160>>>>>>>/// @Param variable                     Maximum number of rows to send to the local cache (optional)
83160>>>>>>>///
83160>>>>>>>/// @Usage SQL_EXECUTE_STMT
83160>>>>>>>/// @Usage SQL_EXECUTE_STMT of Customer
83160>>>>>>>/// @Usage SQL_EXECUTE_STMT of Customer ROWCOUNT 10
83160>>>>>>>///
83160>>>>>>>/// @Example
83160>>>>>>>/// Open Customer
83160>>>>>>>///
83160>>>>>>>/// SQL_SET_STMT to "SELECT * FROM CUSTOMER WHERE STATUS = 'Active' "
83160>>>>>>>/// SQL_PREPARE_STMT
83160>>>>>>>/// SQL_BINDCOLUMNS_STMT of Customer to DF_BIND_ALL_COLUMNS
83160>>>>>>>/// SQL_EXECUTE_STMT of Customer
83160>>>>>>>/// While (Found)
83160>>>>>>>///     SQL_FETCH_NEXT_ROW of Customer
83160>>>>>>>///     Showln Customer.ID
83160>>>>>>>///     Showln Customer.FirstName
83160>>>>>>>///     Showln Customer.LastName
83160>>>>>>>///     Showln Customer.DOB
83160>>>>>>>/// Loop
83160>>>>>>>/// SQL_CANCEL_QUERY_STMT
83160>>>>>>>
83160>>>>>>>
83160>>>>>>>//This alias may be redundant. Is was only called from MertechInc_SQL_FUNCTION_EXECUTE
83160>>>>>>>//which has been recoded to directly call SQL_EXECUTE_STMT - I.S. 2009-09-19
83160>>>>>>>Procedure MertechInc_SQL_PROCEDURE_EXECUTE Global
83162>>>>>>>    SQL_EXECUTE_STMT
83177>>>>>>>End_Procedure
83178>>>>>>>
83178>>>>>>>//=============================================================================
83178>>>>>>>/// @Name        SQL_START_TRANSACTION_STMT
83178>>>>>>>/// @Description Transactions in SQL are used to maintain atomicity within
83178>>>>>>>/// an process. If one procedure in the transaction fails, then they all
83178>>>>>>>/// will fail. This command is used to start an SQL transaction. Inside of
83178>>>>>>>/// a transaction, there can be any number of SQL statements, none of which
83178>>>>>>>/// will be executed until SQL_COMMIT_STMT is called. Note that transactions
83178>>>>>>>/// are generally only needed when a table is being altered.
83178>>>>>>>///
83178>>>>>>>/// @Assumptions
83178>>>>>>>/// @Status      Public
83178>>>>>>>/// @Drivers     All
83178>>>>>>>/// @VersionNote Last Revised: 2013-08-26 by Aaron Gulack
83178>>>>>>>/// @See         SQL_COMMIT_STMT SQL_ROLLBACK_STMT
83178>>>>>>>///
83178>>>>>>>/// @Syntax SQL_START_TRANSACTION_STMT
83178>>>>>>>///
83178>>>>>>>/// @Example
83178>>>>>>>/// SQL_START_TRANSACTION_STMT
83178>>>>>>>/// SQL_SET_STMT to "UPDATE CUSTOMER SET STATUS = 'Inactive'"
83178>>>>>>>/// SQL_PREPARE_STMT
83178>>>>>>>/// SQL_EXECUTE_STMT
83178>>>>>>>/// SQL_COMMIT_STMT
83178>>>>>>>
83178>>>>>>>//=============================================================================
83178>>>>>>>/// @Name        SQL_COMMIT_STMT
83178>>>>>>>/// @Description Just as the SQL_EXECUTE_STMT is used to execute the SQL
83178>>>>>>>/// statement in the block, this command is used to commit the transaction
83178>>>>>>>/// started by SQL_START_TRANSACTION_STMT. When this command is called, any
83178>>>>>>>/// preceding statements or procedures that are apart of the transaction will
83178>>>>>>>/// be committed. If one or more of these statements fail, then none of them
83178>>>>>>>/// will be successful, thus maintaining atomicity.
83178>>>>>>>///
83178>>>>>>>/// @Assumptions
83178>>>>>>>/// @Status      Public
83178>>>>>>>/// @Drivers     All
83178>>>>>>>/// @VersionNote Last Revised: 2013-08-27 by Aaron Gulack
83178>>>>>>>/// @See                 SQL_START_TRANSACTION_STMT SQL_ROLLBACK_STMT
83178>>>>>>>///
83178>>>>>>>/// @Syntax SQL_COMMIT_STMT
83178>>>>>>>///
83178>>>>>>>/// @Example
83178>>>>>>>/// SQL_START_TRANSACTION_STMT
83178>>>>>>>/// SQL_SET_STMT to "UPDATE CUSTOMER SET STATUS = 'Inactive'"
83178>>>>>>>/// SQL_PREPARE_STMT
83178>>>>>>>/// SQL_EXECUTE_STMT
83178>>>>>>>/// SQL_COMMIT_STMT
83178>>>>>>>
83178>>>>>>>//=============================================================================
83178>>>>>>>/// @Name        SQL_ROLLBACK_STMT
83178>>>>>>>/// @Description Rolls back an SQL transaction, any data changes inside the
83178>>>>>>>/// transaction will not be committed by the server.
83178>>>>>>>///
83178>>>>>>>/// @Assumptions
83178>>>>>>>/// @Status      Public
83178>>>>>>>/// @Drivers     All
83178>>>>>>>/// @VersionNote Last Revised: 2013-08-27 by Aaron Gulack
83178>>>>>>>/// @See                 SQL_START_TRANSACTION_STMT SQL_COMMIT_STMT
83178>>>>>>>///
83178>>>>>>>/// @Syntax SQL_ROLLBACK_STMT
83178>>>>>>>///
83178>>>>>>>/// @Example
83178>>>>>>>/// SQL_START_TRANSACTION_STMT
83178>>>>>>>/// SQL_SET_STMT to "DELETE FROM CUSTOMER WHERE ID = 2145"
83178>>>>>>>/// SQL_PREPARE_STMT
83178>>>>>>>/// SQL_EXECUTE_STMT
83178>>>>>>>/// If (Err) Begin
83178>>>>>>>///             SQL_ERROR_MESSAGE errorString
83178>>>>>>>///     Showln errorString
83178>>>>>>>///     SQL_ROLLBACK_STMT
83178>>>>>>>/// End
83178>>>>>>>/// Else
83178>>>>>>>///     Showln "SQL Statement successful - committing"
83178>>>>>>>///     SQL_COMMIT_STMT
83178>>>>>>>
83178>>>>>>>//=============================================================================
83178>>>>>>>/// @Name        SET_TRANSACTIONS_ALLOWED
83178>>>>>>>/// @Description This command is used to toggle on or off the ability to
83178>>>>>>>/// complete transaction to the server. Passing false to this command will
83178>>>>>>>/// not allow transactions to be made, passing true will allow the transactions.
83178>>>>>>>///
83178>>>>>>>/// @Assumptions
83178>>>>>>>/// @Status      Internal
83178>>>>>>>/// @Drivers     All
83178>>>>>>>/// @VersionNote Last Revised: 2013-08-27 by Aaron Gulack
83178>>>>>>>/// @See
83178>>>>>>>///
83178>>>>>>>/// @Syntax SET_TRANSACTIONS_ALLOWED of {server} to {variable}
83178>>>>>>>/// @Param server                               The name of the server being used
83178>>>>>>>/// @Param variable                     Boolean to enable or disable transactions
83178>>>>>>>///
83178>>>>>>>/// @Example
83178>>>>>>>/// SET_TRANSACTIONS_ALLOWED of "localhost" to True
83178>>>>>>>
83178>>>>>>>//=============================================================================
83178>>>>>>>/// @Name        SQL_FETCH_NEXT_ROW
83178>>>>>>>/// @Description This command is used to fetch the next row returned by the
83178>>>>>>>/// associated SQL statement. The SQL statement is created from the
83178>>>>>>>/// SQL_SET_STMT and executed with the SQL_EXECUTE_STMT. This command can be
83178>>>>>>>/// used in two ways. If the results are to be attached to variables, then no
83178>>>>>>>/// file needs to be specified, just the variables for each column in the row.
83178>>>>>>>/// If the results are to be inserted into the record buffer directly, then the
83178>>>>>>>/// file must be specified. From there, a SQL_BINDCOLUMNS_STMT can be used to
83178>>>>>>>/// bind the fetched row to the specific fields in the file. Note that the
83178>>>>>>>/// columns are fecthed in the order that the SQL statement generates them, so
83178>>>>>>>/// the variables must follow the same order. The two constants, "found" and
83178>>>>>>>/// "finderr" are set depending on whether the next row was found.
83178>>>>>>>///
83178>>>>>>>/// @Assumptions
83178>>>>>>>/// @Status      Public
83178>>>>>>>/// @Drivers     All
83178>>>>>>>/// @VersionNote Last Revised: 2013-08-27 by Aaron Gulack
83178>>>>>>>/// @See                 SQL_SET_STMT SQL_APPEND_STMT SQL_PREPARE_STMT SQL_EXECUTE_STMT SQL_CANCEL_QUERY_STMT SQL_BINDCOLUMNS_STMT
83178>>>>>>>///
83178>>>>>>>/// @Syntax SQL_FETCH_NEXT_ROW [of {file}] into {variable}
83178>>>>>>>/// @Param  file                                The name or number of the file
83178>>>>>>>/// @Param  variable                    The variable that the next column in the fetched row will be put into (can be multiple)
83178>>>>>>>///
83178>>>>>>>/// @Usage SQL_FETCH_NEXT_ROW of Customer
83178>>>>>>>/// @Usage SQL_FETCH_NEXT_ROW into sRecnum sID
83178>>>>>>>///
83178>>>>>>>/// @Example
83178>>>>>>>/// String sID sRecnum
83178>>>>>>>///
83178>>>>>>>/// SQL_SET_STMT to "SELECT * FROM CUSTOMER ID"
83178>>>>>>>/// SQL_APPEND_STMT to " BY NAME DESC"
83178>>>>>>>/// SQL_PREPARE_STMT
83178>>>>>>>/// SQL_EXECUTE_STMT
83178>>>>>>>/// While (found)
83178>>>>>>>///     SQL_FETCH_NEXT_ROW into sRecnum sID
83178>>>>>>>///     If (found) Begin
83178>>>>>>>///             Showln sID
83178>>>>>>>///    End
83178>>>>>>>/// Loop
83178>>>>>>>/// SQL_CANCEL_QUERY_STMT
83178>>>>>>>///
83178>>>>>>>/// @Example
83178>>>>>>>/// Open Customer
83178>>>>>>>///
83178>>>>>>>/// SQL_SET_STMT of Customer to "SELECT * FROM CUSTOMER WHERE STATUS = 'Active'"
83178>>>>>>>/// SQL_PREPARE_STMT of Customer
83178>>>>>>>/// SQL_BINDCOLUMNS_STMT of Customer to DF_BIND_ALL_COLUMNS
83178>>>>>>>/// SQL_EXECUTE_STMT of Customer
83178>>>>>>>/// While (Found)
83178>>>>>>>///     SQL_FETCH_NEXT_ROW of Customer
83178>>>>>>>///     Showln Customer.ID
83178>>>>>>>///     Showln Customer.FirstName
83178>>>>>>>///             Showln Customer.LastName
83178>>>>>>>/// Loop
83178>>>>>>>/// SQL_CANCEL_QUERY_STMT
83178>>>>>>>
83178>>>>>>>
83178>>>>>>>//=============================================================================
83178>>>>>>>/// @Name        GET_RESULT_SET
83178>>>>>>>/// @Description Fetches the next row in the result set returned by a
83178>>>>>>>/// query or stored procedure.
83178>>>>>>>///
83178>>>>>>>/// @Assumptions
83178>>>>>>>/// @Status      Deprecated
83178>>>>>>>/// @Drivers     All
83178>>>>>>>/// @VersionNote Last Revised: 2013-08-27 by Aaron Gulack
83178>>>>>>>/// @See
83178>>>>>>>///
83178>>>>>>>/// @Syntax GET_RESULT_SET into {variable}
83178>>>>>>>/// @Param variable                     The variable receiving the result (can be multiple)
83178>>>>>>>
83178>>>>>>>//=============================================================================
83178>>>>>>>/// @Name        SQL_GET_DATA_CHUNK
83178>>>>>>>/// @Description This command is used to get a chunk of data from a column
83178>>>>>>>/// retrieved through an embedded SQL statement. By passing the column number
83178>>>>>>>/// and the offset number, the chunk will be put into the specified variable.
83178>>>>>>>/// To specify how big of a chunk to get, use the SQL_SET_CHUNK_SIZE command.
83178>>>>>>>/// Otherwise the maximum length will be retrieved. An optional variable can
83178>>>>>>>/// also be passed which will store the length of the chunk. Note that unlike
83178>>>>>>>/// LOB_READ, this command works for any column type, not just LOB columns.
83178>>>>>>>///
83178>>>>>>>/// @Assumptions
83178>>>>>>>/// @Status      Public
83178>>>>>>>/// @Drivers     SQLFlex
83178>>>>>>>/// @VersionNote Last Revised: 2013-10-04 by Aaron Gulack
83178>>>>>>>/// @See                 SQL_SET_CHUNK_SIZE SQL_GET_CHUNK_SIZE SQL_SET_MAX_DATA_SIZE SQL_GET_MAX_DATA_SIZE
83178>>>>>>>///
83178>>>>>>>/// @Syntax SQL_GET_DATA_CHUNK COLUMN {column} OFFSET {offset} to {variable} {length}
83178>>>>>>>/// @Param column                               Column number to get chunk from
83178>>>>>>>/// @Param offset                       Offset to start at for the chunk
83178>>>>>>>/// @Param variable                     Variable to hold the returned chunk
83178>>>>>>>/// @Param length                       Variable to hold the chunk length
83178>>>>>>>///
83178>>>>>>>/// @Example
83178>>>>>>>/// SQL_SET_STMT to "SELECT * FROM CUSTOMER WHERE STATUS = 'Active' "
83178>>>>>>>/// SQL_PREPARE_STMT
83178>>>>>>>/// SQL_EXECUTE_STMT
83178>>>>>>>/// SQL_FETCH_NEXT_ROW into sID sBio
83178>>>>>>>/// If (Found) Begin
83178>>>>>>>///     SQL_SET_CHUNK_SIZE to 150
83178>>>>>>>///     SQL_GET_DATA_CHUNK COLUMN 6 OFFSET 1 to sChunk iLength
83178>>>>>>>///     Showln sChunk
83178>>>>>>>///     Showln iLength
83178>>>>>>>/// End
83178>>>>>>>
83178>>>>>>>Function MertechInc_SQL_GET_DATA_CHUNK Global Integer iColumn Integer iOffset Returns String
83180>>>>>>>    Local Integer iChuck_Size
83180>>>>>>>    Local String sChunk
83180>>>>>>>
83180>>>>>>>    //Get current Chuck size and pre size string
83180>>>>>>>    Call_Driver 0 MertechInc_DriverName Function CALLDRV_CHUNK_SIZE CALLBACK 0 PASSING iChuck_Size MertechInc_Blank 1 RESULT MertechInc_iRet
83185>>>>>>>    Get MertechInc_Pre_Size_String iChuck_Size to sChunk
83186>>>>>>>
83186>>>>>>>    //Get data
83186>>>>>>>    Call_Driver 0 MertechInc_DriverName Function CALLDRV_GET_DATA_CHUNK CALLBACK 0 PASSING iColumn sChunk iOffset RESULT MertechInc_iRet
83191>>>>>>>
83191>>>>>>>    //sArg1 (iColumn) contains the number of bytes returned, so move it to
83191>>>>>>>    //MertechInc_Arg1 to pass the value back
83191>>>>>>>    Move iColumn to MertechInc_sArg1
83192>>>>>>>
83192>>>>>>>    Function_Return sChunk
83193>>>>>>>End_Function
83194>>>>>>>
83194>>>>>>>//=============================================================================
83194>>>>>>>/// @Name        SQL_SET_CHUNK_SIZE
83194>>>>>>>/// @Description This command sets the size of the chunk to retrieve when
83194>>>>>>>/// using SQL_GET_DATA_CHUNK. Whatever number is set here will be the
83194>>>>>>>/// length of the chunk that is retrieved, as long as it does not exceed
83194>>>>>>>/// the maximum chunk size.
83194>>>>>>>///
83194>>>>>>>/// @Assumptions
83194>>>>>>>/// @Status      Public
83194>>>>>>>/// @Drivers     SQLFlex
83194>>>>>>>/// @VersionNote Last Revised: 2013-10-04 by Aaron Gulack
83194>>>>>>>/// @See                 SQL_GET_DATA_CHUNK SQL_GET_CHUNK_SIZE SQL_SET_MAX_DATA_SIZE SQL_GET_MAX_DATA_SIZE
83194>>>>>>>///
83194>>>>>>>/// @Syntax SQL_SET_CHUNK_SIZE to {variable}
83194>>>>>>>/// @Param variable                     Length of chunk to retrive
83194>>>>>>>///
83194>>>>>>>/// @Example
83194>>>>>>>/// SQL_SET_STMT to "SELECT * FROM CUSTOMER WHERE STATUS = 'Active' "
83194>>>>>>>/// SQL_PREPARE_STMT
83194>>>>>>>/// SQL_EXECUTE_STMT
83194>>>>>>>/// SQL_FETCH_NEXT_ROW into sID sBio
83194>>>>>>>/// If (Found) Begin
83194>>>>>>>///     SQL_SET_CHUNK_SIZE to 150
83194>>>>>>>///     SQL_GET_DATA_CHUNK COLUMN 6 OFFSET 1 to sChunk iLength
83194>>>>>>>///     Showln sChunk
83194>>>>>>>///     Showln iLength
83194>>>>>>>/// End
83194>>>>>>>
83194>>>>>>>//=============================================================================
83194>>>>>>>/// @Name        SQL_GET_CHUNK_SIZE
83194>>>>>>>/// @Description This command gets the size of the chunk being retrieved
83194>>>>>>>/// from SQL_GET_DATA_CHUNK and puts it into the specified variable.
83194>>>>>>>///
83194>>>>>>>/// @Assumptions
83194>>>>>>>/// @Status      Public
83194>>>>>>>/// @Drivers     SQLFlex
83194>>>>>>>/// @VersionNote Last Revised: 2013-10-04 by Aaron Gulack
83194>>>>>>>/// @See                 SQL_SET_CHUNK_SIZE SQL_GET_DATA_CHUNK SQL_SET_MAX_DATA_SIZE SQL_GET_MAX_DATA_SIZE
83194>>>>>>>///
83194>>>>>>>/// @Syntax SQL_GET_CHUNK_SIZE to {variable}
83194>>>>>>>/// @Param variable             Variable to hold the chunk size
83194>>>>>>>///
83194>>>>>>>/// @Example
83194>>>>>>>/// SQL_GET_CHUNK_SIZE to iLength
83194>>>>>>>
83194>>>>>>>//=============================================================================
83194>>>>>>>/// @Name        SQL_SET_MAX_DATA_SIZE
83194>>>>>>>/// @Description This command sets the maximum size for data chunks
83194>>>>>>>/// retrieved through SQL_GET_DATA_CHUNK. If SQL_SET_CHUNK_SIZE is higher
83194>>>>>>>/// than the maximum size set with this command, then this will override
83194>>>>>>>/// it and the chunk will be no longer than the maximum size set here.
83194>>>>>>>///
83194>>>>>>>/// @Assumptions
83194>>>>>>>/// @Status      Public
83194>>>>>>>/// @Drivers     SQLFlex
83194>>>>>>>/// @VersionNote Last Revised: 2013-10-04 by Aaron Gulack
83194>>>>>>>/// @See                 SQL_SET_CHUNK_SIZE SQL_GET_CHUNK_SIZE SQL_GET_DATA_CHUNK SQL_GET_MAX_DATA_SIZE
83194>>>>>>>///
83194>>>>>>>/// @Syntax SQL_SET_MAX_DATA_SIZE to {variable}
83194>>>>>>>/// @Param variable                     Max length to allow for chunks
83194>>>>>>>///
83194>>>>>>>/// @Example
83194>>>>>>>/// SQL_SET_MAX_DATA_SIZE to 1000
83194>>>>>>>
83194>>>>>>>//=============================================================================
83194>>>>>>>/// @Name        SQL_GET_MAX_DATA_SIZE
83194>>>>>>>/// @Description This command returns the maximum chunk size allowed
83194>>>>>>>/// for SQL_GET_DATA_CHUNK.
83194>>>>>>>///
83194>>>>>>>/// @Assumptions
83194>>>>>>>/// @Status      Public
83194>>>>>>>/// @Drivers     SQLFlex
83194>>>>>>>/// @VersionNote Last Revised: 2013-10-04 by Aaron Gulack
83194>>>>>>>/// @See                 SQL_SET_CHUNK_SIZE SQL_GET_CHUNK_SIZE SQL_GET_DATA_CHUNK SQL_SET_MAX_DATA_SIZE
83194>>>>>>>///
83194>>>>>>>/// @Syntax SQL_GET_MAX_DATA_SIZE to {variable}
83194>>>>>>>/// @Param variable             Variable to hold the maximum chunk size
83194>>>>>>>///
83194>>>>>>>/// @Example
83194>>>>>>>/// SQL_GET_MAX_DATA_SIZE to iLength
83194>>>>>>>
83194>>>>>>>//=============================================================================
83194>>>>>>>/// @Name        SQL_GET_NUM_COLS
83194>>>>>>>/// @Description This command is used to get the number of columns retrieved
83194>>>>>>>/// from an SQL expression result set. Since the column number is based on
83194>>>>>>>/// the result set, this command cannot be used when the results are being
83194>>>>>>>/// bound to the record buffer.  If this command is used with the record
83194>>>>>>>/// buffer or if no columns are found, -1 is returned.
83194>>>>>>>///
83194>>>>>>>/// @Assumptions
83194>>>>>>>/// @Status      Public
83194>>>>>>>/// @Drivers     All
83194>>>>>>>/// @VersionNote Last Revised: 2013-08-28 by Aaron Gulack
83194>>>>>>>/// @See                 SQL_PREPARE_STMT SQL_EXECUTE_STMT SQL_SET_STMT
83194>>>>>>>///
83194>>>>>>>/// @Syntax SQL_GET_NUM_COLS to {variable}
83194>>>>>>>/// @Param variable                     Variable to hold the number of columns.
83194>>>>>>>///
83194>>>>>>>/// @Example
83194>>>>>>>/// SQL_SET_STMT to "SELECT * FROM CUSTOMER WHERE FIRSTNAME = 'Aaron'"
83194>>>>>>>/// SQL_PREPARE_STMT
83194>>>>>>>/// SQL_EXECUTE_STMT
83194>>>>>>>/// GET_RESULT_SET_NUM_COLS to iNumCols
83194>>>>>>>/// Showln iNumCols
83194>>>>>>>
83194>>>>>>>
83194>>>>>>>//=============================================================================
83194>>>>>>>/// @Name        GET_RESULT_SET_NUM_COLS
83194>>>>>>>/// @Description Returns the number of columns in the result set.
83194>>>>>>>///
83194>>>>>>>/// @Assumptions
83194>>>>>>>/// @Status      Deprecated
83194>>>>>>>/// @Drivers     All
83194>>>>>>>/// @VersionNote Last Revised: 2013-08-28 by Aaron Gulack
83194>>>>>>>/// @See                 SQL_GET_NUM_COLS
83194>>>>>>>///
83194>>>>>>>/// @Syntax GET_RESULT_SET_NUM_COLS to {variable}
83194>>>>>>>/// @Param variable                     Variable to hold the number of columns
83194>>>>>>>///
83194>>>>>>>/// @Example
83194>>>>>>>/// Integer iNumCols
83194>>>>>>>///
83194>>>>>>>/// SQL_SET_STMT to "SELECT * FROM CUSTOMER WHERE FIRSTNAME = 'Aaron'"
83194>>>>>>>/// SQL_PREPARE_STMT
83194>>>>>>>/// SQL_EXECUTE_STMT
83194>>>>>>>/// GET_RESULT_SET_NUM_COLS to iNumCols
83194>>>>>>>/// Showln iNumCols
83194>>>>>>>
83194>>>>>>>//=============================================================================
83194>>>>>>>/// @Name        SQL_GET_NUM_ROWS
83194>>>>>>>/// @Description This command is used to get the number of rows retrieved
83194>>>>>>>/// from a result set of an SQL expression. It cannot be used when binding
83194>>>>>>>/// the result set to the record buffer.
83194>>>>>>>///
83194>>>>>>>/// Note: The number of rows may not always be available, depending
83194>>>>>>>/// on server and cursor types.
83194>>>>>>>///
83194>>>>>>>/// @Assumptions
83194>>>>>>>/// @Status      Public
83194>>>>>>>/// @Drivers     All
83194>>>>>>>/// @VersionNote Last Revised: 2013-08-30 by Aaron Gulack
83194>>>>>>>/// @See                 SQL_PREPARE_STMT SQL_EXECUTE_STMT
83194>>>>>>>///
83194>>>>>>>/// @Syntax SQL_GET_NUM_ROWS to {variable}
83194>>>>>>>/// @Param variable                     Variable to hold the number of rows
83194>>>>>>>///
83194>>>>>>>/// @Example
83194>>>>>>>/// Integer iNumRows
83194>>>>>>>///
83194>>>>>>>/// SQL_SET_STMT to "SELECT * FROM CUSTOMER WHERE STATUS = 'Active'"
83194>>>>>>>/// SQL_PREPARE_STMT
83194>>>>>>>/// SQL_EXECUTE_STMT
83194>>>>>>>/// SQL_GET_NUM_ROWS to iNumRows
83194>>>>>>>/// Showln iNumRows
83194>>>>>>>
83194>>>>>>>
83194>>>>>>>//=============================================================================
83194>>>>>>>/// @Name        SQL_GET_COL_NAME
83194>>>>>>>/// @Description This command is used to retrieve the name of a specified
83194>>>>>>>/// column within an SQL result set. An optional second variable can be used
83194>>>>>>>/// to retrieve the size of the specified column. Note that this command
83194>>>>>>>/// cannot be used when the results are being directly binded to the record
83194>>>>>>>/// buffer, it can only be used for the results of an SQL statement.
83194>>>>>>>///
83194>>>>>>>/// @Assumptions
83194>>>>>>>/// @Status      Public
83194>>>>>>>/// @Drivers     All
83194>>>>>>>/// @VersionNote Last Revised: 2013-08-30 by Aaron Gulack
83194>>>>>>>/// @See                 SQL_GET_NUM_COLS
83194>>>>>>>///
83194>>>>>>>/// @Syntax SQL_GET_COL_NAME {columnNumber} to {variable} [{length}]
83194>>>>>>>/// @Param columnNumber                 The column number being used
83194>>>>>>>/// @Param variable                             String variable for the column name
83194>>>>>>>/// @Param length                       Variable to hold the column length (optional)
83194>>>>>>>///
83194>>>>>>>/// @Example
83194>>>>>>>/// Open Customer
83194>>>>>>>///
83194>>>>>>>/// String sColumnName
83194>>>>>>>/// Integer iLength
83194>>>>>>>///
83194>>>>>>>/// SQL_SET_STMT to "SELECT * FROM CUSTOMER WHERE STATUS = 'Active'"
83194>>>>>>>/// SQL_PREPARE_STMT
83194>>>>>>>/// SQL_EXECUTE_STMT
83194>>>>>>>/// SQL_GET_COL_NAME 1 to sColumnName iLength
83194>>>>>>>/// showln sColumnName
83194>>>>>>>/// showln iLength
83194>>>>>>>
83194>>>>>>>
83194>>>>>>>//=============================================================================
83194>>>>>>>/// @Name        GET_RESULT_SET_COL_NAME
83194>>>>>>>/// @Description Returns the column name being populated from the result set.
83194>>>>>>>///
83194>>>>>>>/// @Assumptions
83194>>>>>>>/// @Status      Deprecated
83194>>>>>>>/// @Drivers     All
83194>>>>>>>/// @VersionNote Last Revised: 2013-08-30 by Aaron Gulack
83194>>>>>>>/// @See                 SQL_GET_COL_NAME
83194>>>>>>>///
83194>>>>>>>/// @Syntax GET_RESULT_SET_COL_NAME {columnNumber} to {variable} [{length}]
83194>>>>>>>/// @Param columnNumber                 The column number being used
83194>>>>>>>/// @Param variable                             String variable for the column name
83194>>>>>>>/// @Param length                       Variable receiving the column length (optional)
83194>>>>>>>
83194>>>>>>>//=============================================================================
83194>>>>>>>/// @Name        SQL_GET_COL_ATTRIBUTE
83194>>>>>>>/// @Description This command is used to get specific column information from
83194>>>>>>>/// the columns in a result set of an SQL statement. By passing one of the
83194>>>>>>>/// supported attributes below, the command will return the desired information.
83194>>>>>>>/// Note that some attributes only work with specific drivers. See the list
83194>>>>>>>/// below for more information.
83194>>>>>>>///
83194>>>>>>>/// Supported attributes are:
83194>>>>>>>/// <dl>
83194>>>>>>>/// <dt>SIZE        </dt><dd>The maximum length of the column</dd>
83194>>>>>>>/// <dt>DATA_LENGTH </dt><dd>Length of data currently in the column</dd>
83194>>>>>>>/// <dt>DECIMALS    </dt><dd>If numeric, shows number of decimal places</dd>
83194>>>>>>>/// <dt>LABEL       </dt><dd>Returns the column name in ORAFlex and MySQLFlex</dd>
83194>>>>>>>/// <dt>COLUMN_NAME </dt><dd>Returns the name of the column</dd>
83194>>>>>>>/// <dt>TABLE_NAME  </dt><dd>Returns the name of the table (MySQLFlex only)</dd>
83194>>>>>>>/// <dt>SQLTYPE     </dt><dd>Returns the number representing the SQL data type</dd>
83194>>>>>>>/// <dt>NULLABLE    </dt><dd>Returns true if null is allowed, false otherwise (doesn't work in PostgreSQL)</dd>
83194>>>>>>>/// <dt>DFTYPE      </dt><dd>Dataflex type column is mapped to</dd>
83194>>>>>>>/// </dl>
83194>>>>>>>///
83194>>>>>>>/// @Assumptions
83194>>>>>>>/// @Status      Public
83194>>>>>>>/// @Drivers     All
83194>>>>>>>/// @VersionNote Last Revised: 2013-09-05 by Aaron Gulack
83194>>>>>>>/// @See
83194>>>>>>>///
83194>>>>>>>/// @Syntax SQL_GET_COL_ATTRIBUTE of {columnNumber} {attribute} to {variable}
83194>>>>>>>/// @Param columnNumber                 The number of the column that is being examined
83194>>>>>>>/// @Param attribute                    The attribute being checked (see list)
83194>>>>>>>/// @Param variable                             Variable to hold the attribute value
83194>>>>>>>///
83194>>>>>>>/// @Example
83194>>>>>>>/// String sFirstName sLastName sColumn1Name sColumn2Name
83194>>>>>>>///
83194>>>>>>>/// Open Customer
83194>>>>>>>///
83194>>>>>>>/// SQL_SET_STMT to "SELECT * FROM CUSTOMER WHERE STATUS = 'Active' "
83194>>>>>>>/// SQL_PREPARE_STMT
83194>>>>>>>/// SQL_EXECUTE_STMT
83194>>>>>>>/// SQL_FETCH_NEXT_ROW into sFirstName sLastName
83194>>>>>>>/// If (Found) Begin
83194>>>>>>>///     SQL_GET_COL_ATTRIBUTE of 1 COLUMN_NAME to sColumn1Name
83194>>>>>>>///     SQL_GET_COL_ATTRIBUTE of 2 COLUMN_NAME to sColumn2Name
83194>>>>>>>///     Showln (sColumn1Name + " = " + sFirstName)
83194>>>>>>>///     Showln (sColumn2Name + " = " + sLastName)
83194>>>>>>>/// End
83194>>>>>>>
83194>>>>>>>//=============================================================================
83194>>>>>>>/// @Name        DDO_GET_BIND_RSPARAMETERS
83194>>>>>>>/// @Description Recursively calls DO_GET_BIND_RSPARAMETERS.
83194>>>>>>>///
83194>>>>>>>/// @Assumptions
83194>>>>>>>/// @Status      Internal
83194>>>>>>>/// @Drivers     All
83194>>>>>>>/// @VersionNote Last Revised: 2013-08-30 by Aaron Gulack
83194>>>>>>>/// @See
83194>>>>>>>
83194>>>>>>>//=============================================================================
83194>>>>>>>/// @Name        DO_GET_BIND_RSPARAMETERS
83194>>>>>>>/// @Description Gets bound parameters values for result set call.
83194>>>>>>>///
83194>>>>>>>/// @Assumptions
83194>>>>>>>/// @Status      Internal
83194>>>>>>>/// @Drivers     All
83194>>>>>>>/// @VersionNote Last Revised: 2013-08-30 by Aaron Gulack
83194>>>>>>>/// @See
83194>>>>>>>
83194>>>>>>>Function MertechInc_DO_GET_BIND_RSPARAMETERS Global Integer bSQLFlex String sArg1 String sArg2 Integer iArg Returns String
83196>>>>>>>    Local String sReturnValue
83196>>>>>>>    Local Integer iSize
83196>>>>>>>
83196>>>>>>>    move 0 to iSize
83197>>>>>>>        SQL_GET_COL_ATTRIBUTE of iArg DATA_LENGTH to iSize
83214>>>>>>>>
83214>>>>>>>
83214>>>>>>>    Get MertechInc_Pre_Size_String (iSize+1) to sReturnValue
83215>>>>>>>    Move (|CI$10000 * iArg) To iArg // Shift column number 16 bits to the left
83216>>>>>>>    Call_Driver 0 MertechInc_DriverName Function 24 CALLBACK 0 PASSING sReturnValue MertechInc_Blank iArg RESULT MertechInc_iRet
83221>>>>>>>
83221>>>>>>>    Function_Return sReturnValue
83222>>>>>>>End_Function
83223>>>>>>>
83223>>>>>>>
83223>>>>>>>//=============================================================================
83223>>>>>>>/// @Name        SQL_NEXT_RESULT_SET
83223>>>>>>>/// @Description This command is used when working with SQL statements that
83223>>>>>>>/// return multiple result sets. In that scenario, calling this command will
83223>>>>>>>/// move to the next result set. That set can now be fetched or binded to
83223>>>>>>>/// columns on a table.
83223>>>>>>>///
83223>>>>>>>/// @See
83223>>>>>>>/// @Status      Public
83223>>>>>>>/// @Drivers     All
83223>>>>>>>/// @VersionNote Last Revised: 2013-09-02 by Aaron Gulack
83223>>>>>>>/// @See
83223>>>>>>>///
83223>>>>>>>/// @Syntax SQL_NEXT_RESULT_SET [of {file}]
83223>>>>>>>/// @Param file                 Name or number of the file (optional)
83223>>>>>>>///
83223>>>>>>>/// @Example
83223>>>>>>>/// SQL_SET_STMT to "SP_HELP CUSTOMER"
83223>>>>>>>/// SQL_PREPARE_STMT
83223>>>>>>>/// SQL_EXECUTE_STMT
83223>>>>>>>/// SQL_FETCH_NEXT_ROW into sTable sOwner sTableType dtCreated
83223>>>>>>>/// If (Found) Begin
83223>>>>>>>///     Showln sTable
83223>>>>>>>///     Showln sOwner
83223>>>>>>>///     Showln sTableType
83223>>>>>>>///     Showln dtCreated
83223>>>>>>>/// End
83223>>>>>>>/// SQL_NEXT_RESULT_SET
83223>>>>>>>/// SQL_FETCH_NEXT_ROW into sColumnName sColumnType sComputed sLength
83223>>>>>>>/// If (Found) Begin
83223>>>>>>>///     Showln sColumnName
83223>>>>>>>///     Showln sColumnType
83223>>>>>>>///     Showln sComputed
83223>>>>>>>///     Showln sLength
83223>>>>>>>/// End
83223>>>>>>>
83223>>>>>>>//=============================================================================
83223>>>>>>>/// @Name        DDO_PASS_ARGUMENTS
83223>>>>>>>/// @Description Calls DO_PASS_ARGUMENTS until the argument is "BINDING" and
83223>>>>>>>/// then stops.
83223>>>>>>>///
83223>>>>>>>/// @Assumptions
83223>>>>>>>/// @Status      Internal
83223>>>>>>>/// @Drivers     All
83223>>>>>>>/// @VersionNote Last Revised: 2013-09-05 by Aaron Gulack
83223>>>>>>>/// @See
83223>>>>>>>
83223>>>>>>>//=============================================================================
83223>>>>>>>/// @Name        DO_PASS_ARGUMENTS
83223>>>>>>>/// @Description Builds parameter statements for stored procedures and adds
83223>>>>>>>/// them to the current query.
83223>>>>>>>///
83223>>>>>>>/// @Assumptions
83223>>>>>>>/// @Status      internal
83223>>>>>>>/// @Drivers     All
83223>>>>>>>/// @VersionNote Last Revised: 2013-09-05 by Aaron Gulack
83223>>>>>>>/// @See
83223>>>>>>>
83223>>>>>>>//=============================================================================
83223>>>>>>>/// @Name        DDO_BIND_PARAMETERS
83223>>>>>>>/// @Description Recursively calls DO_BIND_PARAMETERS until the keyword
83223>>>>>>>/// "BINDING" is encountered.
83223>>>>>>>///
83223>>>>>>>/// @Assumptions
83223>>>>>>>/// @Status      Internal
83223>>>>>>>/// @Drivers     All
83223>>>>>>>/// @VersionNote Last Revised: 2013-09-05 by Aaron Gulack
83223>>>>>>>/// @See
83223>>>>>>>
83223>>>>>>>//=============================================================================
83223>>>>>>>/// @Name        DO_BIND_PARAMETERS
83223>>>>>>>/// @Description Binds parameters for a stored procedure call.
83223>>>>>>>///
83223>>>>>>>/// @Assumptions
83223>>>>>>>/// @Status      Internal
83223>>>>>>>/// @Drivers     All
83223>>>>>>>/// @VersionNote Last Revised: 2013-09-05 by Aaron Gulack
83223>>>>>>>/// @See
83223>>>>>>>
83223>>>>>>>Procedure MertechInc_DO_BIND_PARAMETERS Global String sValue String sName Integer iLength
83225>>>>>>>    Call_Driver 0 MertechInc_DriverName Function CALLDRV_BIND_PARAMETER CALLBACK 0 PASSING sValue sName iLength RESULT MertechInc_iRet
83230>>>>>>>End_Procedure
83231>>>>>>>
83231>>>>>>>//=============================================================================
83231>>>>>>>/// @Name        DO_BIND_PAR_RET
83231>>>>>>>/// @Description Binds parameters for a stored procedure call.
83231>>>>>>>///
83231>>>>>>>/// @Assumptions
83231>>>>>>>/// @Status      Internal
83231>>>>>>>/// @Drivers     OraFlex
83231>>>>>>>/// @VersionNote Last Revised: 2013-09-05 by Aaron Gulack
83231>>>>>>>/// @See
83231>>>>>>>
83231>>>>>>>//=============================================================================
83231>>>>>>>/// @Name        DDO_GET_BIND_PARAMETERS
83231>>>>>>>/// @Description Recursively calls DO_GET_BIND_PARAMETERS.
83231>>>>>>>///
83231>>>>>>>/// @Assumptions
83231>>>>>>>/// @Status      Internal
83231>>>>>>>/// @Drivers     All
83231>>>>>>>/// @VersionNote Last Revised: 2013-09-05 by Aaron Gulack
83231>>>>>>>/// @See
83231>>>>>>>
83231>>>>>>>//=============================================================================
83231>>>>>>>/// @Name        DO_GET_BIND_PARAMETERS
83231>>>>>>>/// @Description Gets bound parameter values for a stored procedure call.
83231>>>>>>>///
83231>>>>>>>/// @Assumptions
83231>>>>>>>/// @Status      Internal
83231>>>>>>>/// @Drivers     All
83231>>>>>>>/// @VersionNote Last Revised: 2013-09-05 by Aaron Gulack
83231>>>>>>>/// @See
83231>>>>>>>
83231>>>>>>>Function MertechInc_DO_GET_BIND_PARAMETERS Global Integer bSQLFlex String sArg1 String sArg2 Integer iArg Returns String
83233>>>>>>>    Local String sReturnValue
83233>>>>>>>    Local Integer iSize
83233>>>>>>>
83233>>>>>>>    if (MertechInc_DriverName = SQLFLEX) ;                move (iArg+1) to iArg
83236>>>>>>>//        SQL_GET_COL_ATTRIBUTE of iArg DATA_LENGTH to iSize
83236>>>>>>>
83236>>>>>>>    Get MertechInc_Pre_Size_String (iSize+1) to sReturnValue
83237>>>>>>>    Call_Driver 0 MertechInc_DriverName Function 24 CALLBACK 0 PASSING sReturnValue MertechInc_Blank iArg RESULT MertechInc_iRet
83242>>>>>>>
83242>>>>>>>    Function_Return sReturnValue
83243>>>>>>>End_Function
83244>>>>>>>
83244>>>>>>>//=============================================================================
83244>>>>>>>/// @Name        SQL_GET_OUTPUT_VALUE
83244>>>>>>>/// @Description This command is used to get the value of a specific
83244>>>>>>>/// parameter associated with a stored procedure.  Although this
83244>>>>>>>/// command will work with any parameter, it is mostly used with
83244>>>>>>>/// IN/OUT or OUT parameters as their value will more often be important
83244>>>>>>>/// once returned. When multiple values are returned, this command can be
83244>>>>>>>/// more efficient than other options. Note that the specified parameter
83244>>>>>>>/// must first be defined using the SQL_SET_PROCEDURE_PARAMETER command
83244>>>>>>>/// in order to work properly.
83244>>>>>>>///
83244>>>>>>>/// @Assumptions
83244>>>>>>>/// @Status      Deprecated
83244>>>>>>>/// @Drivers     All
83244>>>>>>>/// @VersionNote Last Revised: 2013-10-01 by Aaron Gulack
83244>>>>>>>/// @See                 SQL_GET_PROCEDURE_PARAMETER
83244>>>>>>>///
83244>>>>>>>/// @Syntax SQL_GET_OUTPUT_VALUE {parameter} to {variable}
83244>>>>>>>/// @Param parameter            Number of the parameter
83244>>>>>>>/// @Param variable                     Variable to hold the parameter's value
83244>>>>>>>///
83244>>>>>>>/// @Example
83244>>>>>>>/// SQL_SET_PROCEDURE_NAME "user.getCustomerStatus" NUMPAR 1
83244>>>>>>>/// SQL_SET_PROCEDURE_PARAMETER 1 to sCustomerID IN_OUT
83244>>>>>>>/// SQL_PROCEDURE_EXECUTE
83244>>>>>>>/// SQL_GET_OUTPUT_VALUE 1 to sStatus
83244>>>>>>>///
83244>>>>>>>/// Showln sStatus
83244>>>>>>>///
83244>>>>>>>/// @Example
83244>>>>>>>/// SQL_SET_PROCEDURE_NAME "user.getCustomerStatus" NUMPAR 2
83244>>>>>>>/// SQL_SET_PROCEDURE_PARAMETER 1 to sCustomerID IN
83244>>>>>>>/// SQL_SET_PROCEDURE_PARAMETER 2 to sStatus OUT
83244>>>>>>>/// SQL_PROCEDURE_EXECUTE
83244>>>>>>>/// SQL_GET_OUTPUT_VALUE 2 to sStatus
83244>>>>>>>///
83244>>>>>>>/// Showln sStatus
83244>>>>>>>// OLI:
83244>>>>>>>// This function is identical in operation to SQL_GET_PROCEDURE_PARAMETER, so just do a replace
83244>>>>>>>
83244>>>>>>>//=============================================================================
83244>>>>>>>/// @Name        SQL_FETCH_COLUMN
83244>>>>>>>/// @Description This command is used to retrieve a specified column from a
83244>>>>>>>/// result set of an SQL statement. Note that this command cannot be used to
83244>>>>>>>/// replace SQL_FETCH_NEXT_ROW but is used in addition to it when only one
83244>>>>>>>/// column is needed. For most cases, SQL_FETCH_NEXT_ROW can be used alone
83244>>>>>>>/// to retrieve the columns desired so this should only be used if there is
83244>>>>>>>/// a specific reason to do so.
83244>>>>>>>///
83244>>>>>>>/// @Assumptions
83244>>>>>>>/// @Status      Public
83244>>>>>>>/// @Drivers     All
83244>>>>>>>/// @VersionNote Last Revised: 2013-09-05 by Aaron Gulack
83244>>>>>>>/// @See                 SQL_FETCH_NEXT_ROW
83244>>>>>>>///
83244>>>>>>>/// @Syntax SQL_FETCH_COLUMN {columnNumber} into {variable}
83244>>>>>>>/// @Param columnNumber    Number of the column to fetch
83244>>>>>>>/// @Param variable        Variable to hold the fetched value
83244>>>>>>>///
83244>>>>>>>/// @Example
83244>>>>>>>/// SQL_SET_STMT to "SELECT * FROM CUSTOMER WHERE STATUS = 'Active' "
83244>>>>>>>/// SQL_PREPARE_STMT
83244>>>>>>>/// SQL_EXECUTE_STMT
83244>>>>>>>/// SQL_FETCH_NEXT_ROW
83244>>>>>>>/// SQL_GET_NUM_COLS to iCols
83244>>>>>>>/// For fieldIndex from 1 to iCols
83244>>>>>>>///     SQL_FETCH_COLUMN fieldIndex into sValue
83244>>>>>>>///     Showln sValue
83244>>>>>>>/// Loop
83244>>>>>>>
83244>>>>>>>Function MertechInc_SQL_FETCH_COLUMN Global String sArg1 String sArg2 Integer iArg Returns String
83246>>>>>>>    Local String sReturnValue
83246>>>>>>>    Local Integer iSize
83246>>>>>>>
83246>>>>>>>    Move 0 to iSize
83247>>>>>>>        SQL_GET_COL_ATTRIBUTE of iArg DATA_LENGTH to iSize
83264>>>>>>>>
83264>>>>>>>
83264>>>>>>>    Get MertechInc_Pre_Size_String (iSize+1) to sReturnValue
83265>>>>>>>    Move (|CI$10000 * iArg) to iArg // Shift column number 16 bits to the left
83266>>>>>>>    Call_Driver 0 MertechInc_DriverName Function 24 CALLBACK 0 PASSING sReturnValue MertechInc_Blank iArg RESULT MertechInc_iRet
83271>>>>>>>
83271>>>>>>>    Function_Return sReturnValue
83272>>>>>>>End_Function
83273>>>>>>>
83273>>>>>>>//=============================================================================
83273>>>>>>>/// @Name        SET_SCHEMA_NAME
83273>>>>>>>/// @Description This command is used to set the schema name to be used when
83273>>>>>>>/// opening tables. Note that this command will override the schema name that
83273>>>>>>>/// is set in the INT file.  The default schema for the current user is used
83273>>>>>>>/// when no name is set.
83273>>>>>>>///
83273>>>>>>>/// @Assumptions
83273>>>>>>>/// @Status      Public
83273>>>>>>>/// @Drivers     SQLFlex and ORAFlex
83273>>>>>>>/// @VersionNote Last Revised: 2013-09-24 by Aaron Gulack
83273>>>>>>>/// @See                 GET_SCHEMA_NAME
83273>>>>>>>///
83273>>>>>>>/// @Syntax SET_SCHEMA_NAME to {schema}
83273>>>>>>>/// @Param variable                     Name of the schema
83273>>>>>>>///
83273>>>>>>>/// @Example
83273>>>>>>>/// SET_SCHEMA_NAME to 'CustomerSchema'
83273>>>>>>>/// OPEN "CUSTOMER.INT" as CUSTOMER
83273>>>>>>>/// SET_SCHEMA_NAME to 'SalesSchema'
83273>>>>>>>/// OPEN "SALESP.INT" as SALESP
83273>>>>>>>
83273>>>>>>>//=============================================================================
83273>>>>>>>/// @Name        GET_SCHEMA_NAME
83273>>>>>>>/// @Description This command is used to get the name of the schema being
83273>>>>>>>/// used to open tables.
83273>>>>>>>///
83273>>>>>>>/// @Assumptions
83273>>>>>>>/// @Status      Public
83273>>>>>>>/// @Drivers     SQLFlex and ORAFlex
83273>>>>>>>/// @VersionNote Last Revised: 2013-09-24 by Aaron Gulack
83273>>>>>>>/// @See                 SET_SCHEMA_NAME
83273>>>>>>>///
83273>>>>>>>/// @Syntax GET_SCHEMA_NAME to {variable}
83273>>>>>>>/// @Param variable                     variable to hold the schema name
83273>>>>>>>///
83273>>>>>>>/// @Example
83273>>>>>>>/// GET_SCHEMA_NAME to sName
83273>>>>>>>/// Showln sName
83273>>>>>>>
83273>>>>>>>//=============================================================================
83273>>>>>>>/// @Name        CALL_ORACLE_STORED_PROCEDURE
83273>>>>>>>/// @Description This command is used to call a stored procedure on the SQL
83273>>>>>>>/// backend. To successfully call a procedure with this command, a string
83273>>>>>>>/// must be passed containing a valid procedure name. In addition, if the
83273>>>>>>>/// procedure takes any arguments, they must also be passed using the constant
83273>>>>>>>/// "passing" along with all of the needed arguments. If the procedure has a
83273>>>>>>>/// return value, then SQL_GET_FUNCTION_RETURN or SQL_FETCH_NEXT_ROW can be
83273>>>>>>>/// used to get the value(s). If an error is found then the indicator "Err"
83273>>>>>>>/// is set to true.
83273>>>>>>>///
83273>>>>>>>/// @Assumptions
83273>>>>>>>/// @Status      Deprecated
83273>>>>>>>/// @Drivers     ORAFLex
83273>>>>>>>/// @VersionNote Last Revised: 2013-09-25 by Aaron Gulack
83273>>>>>>>/// @See                 CALL_STORED_PROCEDURE
83273>>>>>>>///
83273>>>>>>>/// @Syntax CALL_ORACLE_STORED_PROCEDURE {procedure} Passing {variable}
83273>>>>>>>/// @Param procedure            Full name of the procedure
83273>>>>>>>/// @Param variable                     Argument being passed to procedure (can be multiple)
83273>>>>>>>///
83273>>>>>>>/// @Example
83273>>>>>>>/// CALL_ORACLE_STORED_PROCEDURE "sys.sp_addmessage" passing 50003 15 "Please enter a valid date"
83273>>>>>>>
83273>>>>>>>//=============================================================================
83273>>>>>>>/// @Name        SQL_SET_PROCEDURE_NAME
83273>>>>>>>/// @Description This command is used to set the procedure to be executed.
83273>>>>>>>/// This is used when the procedure is being split up into multiple lines
83273>>>>>>>/// as shown below. When using this command, SQL_PROCEDURE_EXECUTE must be
83273>>>>>>>/// called after all parameters have been set to successfully execute the
83273>>>>>>>/// procedure. The constant "NUMPAR" is used to indicate how many parameters
83273>>>>>>>/// will be passed.
83273>>>>>>>///
83273>>>>>>>/// @Assumptions The procedure is a valid procedure in the SQL database
83273>>>>>>>/// @Status      Public
83273>>>>>>>/// @Drivers     All
83273>>>>>>>/// @VersionNote Last Revised: 2013-09-25 by Aaron Gulack
83273>>>>>>>/// @See                 SQL_SET_PROCEDURE_PARAMETER SQL_PROCEDURE_EXECUTE
83273>>>>>>>///
83273>>>>>>>/// @Syntax SQL_SET_PROCEDURE_NAME {procedure} NUMPAR {variable}
83273>>>>>>>/// @Param procedure            Full name of the procedure
83273>>>>>>>/// @Param variable                     Number of parameters to be passed
83273>>>>>>>///
83273>>>>>>>/// @Example
83273>>>>>>>/// SQL_SET_PROCEDURE_NAME "sys.sp_addmessage" NUMPAR 3
83273>>>>>>>/// SQL_SET_PROCEDURE_PARAMETER 1 to 500004 IN
83273>>>>>>>/// SQL_SET_PROCEDURE_PARAMETER 2 to 15 IN
83273>>>>>>>/// SQL_SET_PROCEDURE_PARAMETER 3 to "Please enter a valid Date" IN
83273>>>>>>>/// SQL_PROCEDURE_EXECUTE
83273>>>>>>>
83273>>>>>>>
83273>>>>>>>Procedure MertechInc_SQL_SET_ORAPROCEDURE_NAME Global String strProcName Integer iNumpar
83275>>>>>>>    Local Integer iParam
83275>>>>>>>
83275>>>>>>>    Move 0 to MertechInc_iParamCount       //Redundant, but left in incase called
83276>>>>>>>    INDICATE ERR False              //directly and not via SQL_SET_PROCEDURE_NAME
83277>>>>>>>    Move ORAFlex to MertechInc_DriverName  //
83278>>>>>>>
83278>>>>>>>    SQL_SET_STMT to "BEGIN "
83286>>>>>>>    SQL_APPEND_STMT to strProcName
83294>>>>>>>    SQL_APPEND_STMT to "( "
83302>>>>>>>    For iParam from 1 to iNumpar
83308>>>>>>>>
83308>>>>>>>        DO_PASS_ARGUMENTS iParam
83340>>>>>>>    Loop
83341>>>>>>>>
83341>>>>>>>    SQL_APPEND_STMT to  " ); END;"
83349>>>>>>>    SQL_PREPARE_STMT
83361>>>>>>> End_Procedure
83362>>>>>>>
83362>>>>>>>Procedure MertechInc_SQL_SET_MYPROCEDURE_NAME Global String strProcName Integer iNumpar
83364>>>>>>>    Local Integer iParam
83364>>>>>>>
83364>>>>>>>    Move 0 to MertechInc_iParamCount           //Redundant, but left in incase called
83365>>>>>>>    INDICATE ERR False                  //directly and not via SQL_SET_PROCEDURE_NAME
83366>>>>>>>    Move MySQLFlex to MertechInc_DriverName    //
83367>>>>>>>
83367>>>>>>>    SQL_SET_STMT to "CALL "
83375>>>>>>>    SQL_APPEND_STMT to strProcName
83383>>>>>>>    SQL_APPEND_STMT to "("
83391>>>>>>>    For iParam from 1 to iNumpar
83397>>>>>>>>
83397>>>>>>>        DO_PASS_ARGUMENTS iParam
83429>>>>>>>    Loop
83430>>>>>>>>
83430>>>>>>>    SQL_APPEND_STMT to ")"
83438>>>>>>>    SQL_PREPARE_STMT
83450>>>>>>>End_Procedure
83451>>>>>>>
83451>>>>>>>Procedure MertechInc_SQL_SET_MSPROCEDURE_NAME Global String strProcName Integer iNumpar
83453>>>>>>>    local Integer iParam
83453>>>>>>>    local String  sParam
83453>>>>>>>
83453>>>>>>>    Move SQLFlex to MertechInc_DriverName
83454>>>>>>>
83454>>>>>>>    // This calling syntax is referred to as the "ODBC CALL escape sequence".  This syntax is
83454>>>>>>>    // advised over the execute command since CALL allows for the retrieval of the return codes
83454>>>>>>>    // from the call.
83454>>>>>>>    SQL_SET_STMT to "{? = CALL "
83462>>>>>>>    SQL_APPEND_STMT to strProcName
83470>>>>>>>
83470>>>>>>>    // Note that DO_PASS_ARGUMENTS can add the open paren for us, but only if the keyword "PASSING"
83470>>>>>>>    // is passed to it first time through.  This is a bit weird, so we ignore that and just add
83470>>>>>>>    // the open and close parens ourself to make things more clear.
83470>>>>>>>    If (iNumpar > 0) SQL_APPEND_STMT to " ("
83480>>>>>>>
83480>>>>>>>    For iParam from 1 to iNumpar
83486>>>>>>>>
83486>>>>>>>        DO_PASS_ARGUMENTS iParam
83518>>>>>>>    Loop
83519>>>>>>>>
83519>>>>>>>
83519>>>>>>>    If (iNumpar > 0) SQL_APPEND_STMT to ")"
83529>>>>>>>    SQL_APPEND_STMT to  " };"
83537>>>>>>>
83537>>>>>>>    SQL_PREPARE_STMT
83549>>>>>>>
83549>>>>>>>    // This bind parameter is for the "{? = " which is technically the first parameter even though
83549>>>>>>>    // it is the return value.  The driver will bind MertechInc_iWork to it.
83549>>>>>>>    DO_BIND_PARAMETERS MertechInc_iWork
83572>>>>>>>End_Procedure
83573>>>>>>>
83573>>>>>>>Procedure MertechInc_SQL_SET_PGPROCEDURE_NAME Global String strProcName Integer iNumpar
83575>>>>>>>    local Integer iParam
83575>>>>>>>    local String  sParam
83575>>>>>>>
83575>>>>>>>    Move PgFlex to MertechInc_DriverName
83576>>>>>>>
83576>>>>>>>    // For Postgres, you can call a function just by passing the function name and
83576>>>>>>>    // open/close parens
83576>>>>>>>    SQL_SET_STMT to strProcName
83584>>>>>>>
83584>>>>>>>    // Note that DO_PASS_ARGUMENTS can add the open paren for us, but only if the keyword "PASSING"
83584>>>>>>>    // is passed to it first time through.  This is a bit weird, so we ignore that and just add
83584>>>>>>>    // the open and close parens ourself to make things more clear.
83584>>>>>>>    SQL_APPEND_STMT to "( "
83592>>>>>>>
83592>>>>>>>    For iParam from 1 to iNumpar
83598>>>>>>>>
83598>>>>>>>        DO_PASS_ARGUMENTS iParam
83630>>>>>>>    Loop
83631>>>>>>>>
83631>>>>>>>
83631>>>>>>>    SQL_APPEND_STMT to ")"
83639>>>>>>>
83639>>>>>>>    SQL_PREPARE_STMT
83651>>>>>>>    // Indicate that a stored function will be executed - Query = 0, Procedure = 1, Function = 2
83651>>>>>>>    Call_Driver 0 MertechInc_DriverName Function CALLDRV_EMBEDDED_SQL_TYPE CALLBACK 0 PASSING MertechInc_Blank MertechInc_Blank 1 RESULT MertechInc_iRet
83656>>>>>>>End_Procedure
83657>>>>>>>
83657>>>>>>>//=============================================================================
83657>>>>>>>/// @Name        SQL_GET_STMT
83657>>>>>>>/// @Description This command returns the last embedded SQL statement that
83657>>>>>>>/// was executed into a string. Optional parameters can be passed to specify
83657>>>>>>>/// what character to start the string at and also the maximum number of
83657>>>>>>>/// characters to allow for the string.
83657>>>>>>>///
83657>>>>>>>/// @Assumptions
83657>>>>>>>/// @Status      Public
83657>>>>>>>/// @Drivers     All
83657>>>>>>>/// @VersionNote Last Revised: 2013-09-24 by Aaron Gulack
83657>>>>>>>/// @See                 SQL_GET_STATEMENT
83657>>>>>>>///
83657>>>>>>>/// @Syntax SQL_GET_STMT to {variable} [{max} {start}]
83657>>>>>>>/// @Param variable                     SQL statement to be executed
83657>>>>>>>/// @Param max                          Indicates the maximum number of characters to get (optional)
83657>>>>>>>/// @Param start                        Indicates what character to start at for the returned string (optional)
83657>>>>>>>///
83657>>>>>>>/// @Example
83657>>>>>>>/// SQL_SET_STMT to "SELECT * FROM CUSTOMER WHERE STATUS = 'Active' "
83657>>>>>>>/// SQL_PREPARE_STMT
83657>>>>>>>/// SQL_EXECUTE_STMT
83657>>>>>>>/// SQL_FETCH_NEXT_ROW into sFirstName sLastName
83657>>>>>>>/// If (Found) Begin
83657>>>>>>>///     Showln sFirstName
83657>>>>>>>///     Showln sLastName
83657>>>>>>>/// End
83657>>>>>>>///
83657>>>>>>>/// SQL_GET_STATEMENT to sValue
83657>>>>>>>/// Showln sValue
83657>>>>>>>
83657>>>>>>>
83657>>>>>>>Function MertechInc_SQL_GET_STATEMENT Global Integer iLength Integer iStart Returns String
83659>>>>>>>    Local String sStatement
83659>>>>>>>
83659>>>>>>>    DO_GETFILENUMBER_DRIVERNAME 0
83661>>>>>>>
83661>>>>>>>    If (MertechInc_FileNumber <> -1) Begin
83663>>>>>>>        Get MertechInc_Pre_Size_String 0 to sStatement
83664>>>>>>>        Call_Driver 0 MertechInc_DriverName Function CALLDRV_GET_SQL_STMT CALLBACK 0 PASSING sStatement iStart iLength RESULT MertechInc_iRet
83669>>>>>>>    End
83669>>>>>>>>
83669>>>>>>>    Function_Return sStatement
83670>>>>>>>End_Function
83671>>>>>>>
83671>>>>>>>//=============================================================================
83671>>>>>>>/// @Name        SQL_SET_FUNCTION_NAME
83671>>>>>>>/// @Description This command is used in the same way as SQL_SET_PROCEDURE_NAME
83671>>>>>>>/// and SQL_SET_STMT to set the name of the function to be executed. When
83671>>>>>>>/// calling SQL functions in this fashion, this command must be used along with
83671>>>>>>>/// SQL_FUNCTION_EXECUTE (to execute the function), SQL_SET_FUNCTION_PARAMETER
83671>>>>>>>/// (to set the needed parameters) and SQL_GET_FUNCTION_RETURN (to get any
83671>>>>>>>/// returned value). The number of parameters must be set using the constant,
83671>>>>>>>/// NUMPAR, followed by the number of parameters. Note that when setting the
83671>>>>>>>/// name of the function, the user can be specified or, if left blank, the
83671>>>>>>>/// current user will be inserted before the function name.
83671>>>>>>>///
83671>>>>>>>/// @Assumptions
83671>>>>>>>/// @Status      Public
83671>>>>>>>/// @Drivers     All
83671>>>>>>>/// @VersionNote Last Revised: 2013-10-01 by Aaron Gulack
83671>>>>>>>/// @See                 SQL_FUNCTION_EXECUTE SQL_SET_FUNCTION_PARAMETER SQL_GET_FUNCTION_RETURN
83671>>>>>>>///
83671>>>>>>>/// @Syntax SQL_SET_FUNCTION_NAME {function} NUMPAR {parameters}
83671>>>>>>>/// @Param function                     Full name of the function
83671>>>>>>>/// @Param parameters           Number of parameters to pass
83671>>>>>>>///
83671>>>>>>>/// @Example
83671>>>>>>>/// SQL_SET_FUNCTION_NAME "getCustomerStatus" NUMPAR 1
83671>>>>>>>/// SQL_SET_FUNCTION_PARAMETER 1 to 'Jones' IN
83671>>>>>>>/// SQL_FUNCTION_EXECUTE
83671>>>>>>>/// SQL_GET_FUNCTION_RETURN to dDOB
83671>>>>>>>/// Showln dDOB
83671>>>>>>>
83671>>>>>>>Procedure MertechInc_SQL_SET_ORAFUNCTION_NAME Global String strProcName Integer iNumpar
83673>>>>>>>    Local Integer iParam
83673>>>>>>>
83673>>>>>>>    SQL_SET_STMT to "BEGIN "
83681>>>>>>>    SQL_APPEND_STMT to ":PAR_RET := "
83689>>>>>>>    SQL_APPEND_STMT to strProcName
83697>>>>>>>    SQL_APPEND_STMT to "( "
83705>>>>>>>    For iParam from 1 to iNumpar
83711>>>>>>>>
83711>>>>>>>        DO_PASS_ARGUMENTS iParam
83743>>>>>>>    Loop
83744>>>>>>>>
83744>>>>>>>    SQL_APPEND_STMT to  " ); END;"
83752>>>>>>>    SQL_PREPARE_STMT
83764>>>>>>>
83764>>>>>>>    Move IS_OUT to MertechInc_iArg
83765>>>>>>>    Call_Driver 0 ORAFLEX Function CALLDRV_SET_PROC_ATTRIBUTE_TYPE CALLBACK 0 PASSING MertechInc_Blank MertechInc_Blank MertechInc_iArg RESULT MertechInc_iRet
83770>>>>>>>
83770>>>>>>>    Increment MertechInc_iParamCount
83771>>>>>>>    Move ":PAR_RET" to MertechInc_sArg2
83772>>>>>>>    Call_Driver 0 MertechInc_DriverName Function CALLDRV_BIND_PARAMETER CALLBACK 0 PASSING MertechInc_Blank MertechInc_sArg2 16384 RESULT MertechInc_iRet
83777>>>>>>>End_Procedure
83778>>>>>>>
83778>>>>>>>Procedure MertechInc_SQL_SET_MYFUNCTION_NAME Global String strProcName Integer iNumpar
83780>>>>>>>    Local Integer iParam
83780>>>>>>>
83780>>>>>>>    Move MySQLFlex to MertechInc_DriverName
83781>>>>>>>
83781>>>>>>>    SQL_SET_STMT to "SELECT "
83789>>>>>>>    SQL_APPEND_STMT to strProcName
83797>>>>>>>    SQL_APPEND_STMT to "("
83805>>>>>>>    For iParam from 1 to iNumpar
83811>>>>>>>>
83811>>>>>>>        DO_PASS_ARGUMENTS iParam
83843>>>>>>>    Loop
83844>>>>>>>>
83844>>>>>>>    SQL_APPEND_STMT to ")"
83852>>>>>>>    SQL_PREPARE_STMT
83864>>>>>>>End_Procedure
83865>>>>>>>
83865>>>>>>>Procedure MertechInc_SQL_SET_SQLFUNCTION_NAME Global String strProcName Integer iNumpar
83867>>>>>>>    Local Integer iParam
83867>>>>>>>
83867>>>>>>>    Move SQLFlex to MertechInc_DriverName
83868>>>>>>>
83868>>>>>>>    If (not(strProcName contains ".")) Begin
83870>>>>>>>        String schema
83870>>>>>>>        GET_SCHEMA_NAME to schema
83892>>>>>>>        Move (schema + "." + strProcName) to strProcName
83893>>>>>>>    End
83893>>>>>>>>
83893>>>>>>>
83893>>>>>>>    SQL_SET_STMT    to "SELECT "
83901>>>>>>>    SQL_APPEND_STMT to strProcName
83909>>>>>>>    SQL_APPEND_STMT to "("
83917>>>>>>>End_Procedure
83918>>>>>>>
83918>>>>>>>Procedure MertechInc_SQL_SET_PGFUNCTION_NAME Global String strProcName Integer iNumpar
83920>>>>>>>    Local Integer iParam
83920>>>>>>>
83920>>>>>>>    Move PgFlex to MertechInc_DriverName
83921>>>>>>>
83921>>>>>>>    SQL_SET_STMT    to "SELECT "
83929>>>>>>>    SQL_APPEND_STMT to strProcName
83937>>>>>>>    SQL_APPEND_STMT to "("
83945>>>>>>>End_Procedure
83946>>>>>>>
83946>>>>>>>//=============================================================================
83946>>>>>>>/// @Name        SQL_SET_PROCEDURE_PARAMETER
83946>>>>>>>/// @Description
83946>>>>>>>/// With this command you can pass one or more parameters to predefined
83946>>>>>>>/// stored procedures on a MySQL or Oracle server. The SQL_SET_PROCEDURE_PARAMETER
83946>>>>>>>/// command enables you to add a parameter to a stored procedure which you are
83946>>>>>>>/// planning to call. You can pass multiple parameters by calling the command
83946>>>>>>>/// for each parameter.
83946>>>>>>>///
83946>>>>>>>/// When passing parameters you'll have to inform the driver which variable
83946>>>>>>>/// you are passing, starting with 1 from left-to-right in the parameter list.
83946>>>>>>>///
83946>>>>>>>/// For each parameter you'll have to indicate if the variable is to be
83946>>>>>>>/// regarded as input, output or both.
83946>>>>>>>///
83946>>>>>>>///@Assumptions
83946>>>>>>>/// @Status      Public
83946>>>>>>>/// @Drivers     All
83946>>>>>>>/// @VersionNote Last Revised: 2013-09-27 by Aaron Gulack
83946>>>>>>>/// @See                 SQL_SET_PROCEDURE_NAME SQL_PROCEDURE_EXECUTE
83946>>>>>>>///
83946>>>>>>>/// @Syntax SQL_SET_PROCEDURE_PARAMETER {number} to {variable} {direction}
83946>>>>>>>/// @Param number                       Index number of the parameter being defined.
83946>>>>>>>/// @Param variable                     Variable holding the parameter to be passed.
83946>>>>>>>/// @Param direction            IN, OUT, IN_OUT, RSET, or leave blank
83946>>>>>>>///
83946>>>>>>>/// @Example
83946>>>>>>>/// SQL_SET_PROCEDURE_NAME "sys.sp_addmessage" NUMPAR 3
83946>>>>>>>/// SQL_SET_PROCEDURE_PARAMETER 1 to 500004 IN
83946>>>>>>>/// SQL_SET_PROCEDURE_PARAMETER 2 to 15 IN
83946>>>>>>>/// SQL_SET_PROCEDURE_PARAMETER 3 to "Please enter a valid Date" IN
83946>>>>>>>/// SQL_PROCEDURE_EXECUTE
83946>>>>>>>
83946>>>>>>>
83946>>>>>>>
83946>>>>>>>//=============================================================================
83946>>>>>>>/// @Name        SQL_GET_PROCEDURE_PARAMETER
83946>>>>>>>/// @Description This command is used to get the value of a specific
83946>>>>>>>/// parameter associated with a stored procedure.  Although this
83946>>>>>>>/// command will work with any parameter, it is mostly be used with
83946>>>>>>>/// IN/OUT or OUT parameters as their value will more often be important
83946>>>>>>>/// once returned. When multiple values are returned, this command can be
83946>>>>>>>/// more efficient than other options. Note that the specified parameter
83946>>>>>>>/// must first be defined using the SQL_SET_PROCEDURE_PARAMETER command
83946>>>>>>>/// in order to work properly.
83946>>>>>>>///
83946>>>>>>>/// @Assumptions
83946>>>>>>>/// @Status      Public
83946>>>>>>>/// @Drivers     All
83946>>>>>>>/// @VersionNote Last Revised: 2013-10-02 by Aaron Gulack
83946>>>>>>>/// @See                 SQL_SET_PROCEDURE_NAME SQL_SET_PROCEDURE_PARAMETER SQL_PROCEDURE_EXECUTE
83946>>>>>>>///
83946>>>>>>>/// @Syntax SQL_GET_PROCEDURE_PARAMETER {parameter} to {variable}
83946>>>>>>>/// @Param parameter            Number of paramater to return
83946>>>>>>>/// @Param variable                     Variable to hold the value of the parameter
83946>>>>>>>///
83946>>>>>>>/// @Example
83946>>>>>>>/// SQL_SET_PROCEDURE_NAME "user.getCustomerStatus" NUMPAR 1
83946>>>>>>>/// SQL_SET_PROCEDURE_PARAMETER 1 to sCustomerID IN_OUT
83946>>>>>>>/// SQL_PROCEDURE_EXECUTE
83946>>>>>>>/// SQL_GET_PROCEDURE_PARAMETER 1 to sStatus
83946>>>>>>>///
83946>>>>>>>/// Showln sStatus
83946>>>>>>>///
83946>>>>>>>/// @Example
83946>>>>>>>/// SQL_SET_PROCEDURE_NAME "user.getCustomerStatus" NUMPAR 2
83946>>>>>>>/// SQL_SET_PROCEDURE_PARAMETER 1 to sCustomerID IN
83946>>>>>>>/// SQL_SET_PROCEDURE_PARAMETER 2 to sStatus OUT
83946>>>>>>>/// SQL_PROCEDURE_EXECUTE
83946>>>>>>>/// SQL_GET_PROCEDURE_PARAMETER 2 to sStatus
83946>>>>>>>///
83946>>>>>>>/// Showln sStatus
83946>>>>>>>
83946>>>>>>>
83946>>>>>>>
83946>>>>>>>//=============================================================================
83946>>>>>>>/// @Name        SQL_GET_FUNCTION_RETURN
83946>>>>>>>/// @Description This variable is used to get the value returned from a SQL
83946>>>>>>>/// function call. After the function has been successfully called, this
83946>>>>>>>/// command takes the returned value and inserts it the given variable.
83946>>>>>>>///
83946>>>>>>>/// @Assumptions
83946>>>>>>>/// @Status      Public
83946>>>>>>>/// @Drivers     All
83946>>>>>>>/// @VersionNote Last Revised: 2013-10-01 by Aaron Gulack
83946>>>>>>>/// @See                 SQL_SET_FUNCTION_NAME SQL_SET_FUNCTION_PARAMETER SQL_FUNCTION_EXECUTE
83946>>>>>>>///
83946>>>>>>>/// @Syntax SQL_GET_FUNCTION_RETURN to {variable}
83946>>>>>>>/// @Param variable                     Variable to hold the returned value
83946>>>>>>>///
83946>>>>>>>/// @Example
83946>>>>>>>/// SQL_SET_FUNCTION_NAME "getCustomerStatus" NUMPAR 1
83946>>>>>>>/// SQL_SET_FUNCTION_PARAMETER 1 to 'Jones' IN
83946>>>>>>>/// SQL_FUNCTION_EXECUTE
83946>>>>>>>/// SQL_GET_FUNCTION_RETURN to dDOB
83946>>>>>>>/// Showln dDOB
83946>>>>>>>
83946>>>>>>>//=============================================================================
83946>>>>>>>/// @Name        SQL_FUNCTION_EXECUTE
83946>>>>>>>/// @Description This command is used to execute the function statement
83946>>>>>>>/// that was built by the SQL_SET_FUNCTION_NAME and subsequent
83946>>>>>>>/// SQL_SET_FUNCTION_PARAMETER commands. This works similarly to the
83946>>>>>>>/// SQL_EXECUTE_STMT command. Note that executing the function with this
83946>>>>>>>/// command will not get any returned values but will simply execute the
83946>>>>>>>/// function.
83946>>>>>>>///
83946>>>>>>>/// @Assumptions
83946>>>>>>>/// @Status      Public
83946>>>>>>>/// @Drivers     All
83946>>>>>>>/// @VersionNote Last Revised: 2013-10-01 by Aaron Gulack
83946>>>>>>>/// @See                 SQL_SET_FUNCTION_NAME SQL_SET_FUNCTION_PARAMETER SQL_GET_FUNCTION_RETURN
83946>>>>>>>///
83946>>>>>>>/// @Syntax SQL_FUNCTION_EXECUTE
83946>>>>>>>///
83946>>>>>>>/// @Example
83946>>>>>>>/// SQL_SET_FUNCTION_NAME "getCustomerStatus" NUMPAR 1
83946>>>>>>>/// SQL_SET_FUNCTION_PARAMETER 1 to 'Jones' IN
83946>>>>>>>/// SQL_FUNCTION_EXECUTE
83946>>>>>>>/// SQL_GET_FUNCTION_RETURN to dDOB
83946>>>>>>>/// Showln dDOB
83946>>>>>>>
83946>>>>>>>Procedure MertechInc_SQL_FUNCTION_EXECUTE Global String sDriverName
83948>>>>>>>    Local Integer iParam
83948>>>>>>>    Local String  sParam
83948>>>>>>>
83948>>>>>>>    If (sDriverName = SQLFLEX or sDriverName = PgFlex) Begin
83950>>>>>>>       SQL_APPEND_STMT to ')'
83958>>>>>>>       SQL_PREPARE_STMT
83970>>>>>>>    End
83970>>>>>>>>
83970>>>>>>>
83970>>>>>>>    SQL_EXECUTE_STMT
83985>>>>>>>    If (sDriverName <> ORAFLEX) Begin
83987>>>>>>>        SQL_FETCH_NEXT_ROW
84002>>>>>>>>
84002>>>>>>>    End
84002>>>>>>>>
84002>>>>>>>End_Procedure
84003>>>>>>>
84003>>>>>>>//=============================================================================
84003>>>>>>>/// @Name        REEXEC_ORACLE_STORED_PROCEDURE
84003>>>>>>>/// @Description This command is used to re-execute a stored procedure
84003>>>>>>>/// when using Oracle. Although it follows the same format as
84003>>>>>>>/// CALL_STORED_PROCEDURE, it can be useful because it does not need to
84003>>>>>>>/// prepare the procedure again before executing. This can cause speed
84003>>>>>>>/// improvements when calling a stored procedure multiple times.
84003>>>>>>>///
84003>>>>>>>/// @Assumptions A procedure has already been created through CALL_STORED_PROCEDURE
84003>>>>>>>/// @Status      Public
84003>>>>>>>/// @Drivers     ORAFLex
84003>>>>>>>/// @VersionNote Last Revised: 2013-10-04 by Aaron Gulack
84003>>>>>>>/// @See                 CALL_STORED_PROCEDURE
84003>>>>>>>///
84003>>>>>>>/// @Syntax CALL_ORACLE_STORED_PROCEDURE {procedure} Passing {variable}
84003>>>>>>>/// @Param procedure            Full name of the procedure
84003>>>>>>>/// @Param variable                     Parameter to pass (optional and can be multiple)
84003>>>>>>>///
84003>>>>>>>/// @Example
84003>>>>>>>/// CALL_STORED_PROCEDURE "user.getCustomerStatus" Passing sCustomerID sStatus
84003>>>>>>>/// Showln sStatus
84003>>>>>>>///
84003>>>>>>>/// Move (sCustomerID + 1) to sCustomerID
84003>>>>>>>///
84003>>>>>>>/// REEXEC_ORACLE_STORED_PROCEDURE "user.getCustomerStatus" passing sCustomerID sStatus
84003>>>>>>>/// Showln sStatus
84003>>>>>>>
84003>>>>>>>
84003>>>>>>>//=============================================================================
84003>>>>>>>/// @Name        CALL_STORED_FUNCTION
84003>>>>>>>/// @Description This command is used to execute a function stored in the
84003>>>>>>>/// SQL backend. This is an alternative to building a function with the
84003>>>>>>>/// SQL_SET_FUNCTION_NAME, SQL_SET_FUNCTION_PARAMETER and SQL_FUNCTION_EXECUTE
84003>>>>>>>/// commands. This command builds and executes the function by setting the full
84003>>>>>>>/// function name, the parameter(s) to pass and the variable to hold the
84003>>>>>>>/// returned value. Note that this command can only return a single value
84003>>>>>>>/// so SQL_SET_FUNCTION_PARAMETER and SQL_SET_FUNCTION_NAME must be used when
84003>>>>>>>/// dealing with multiple return values.
84003>>>>>>>///
84003>>>>>>>/// Assumptions
84003>>>>>>>/// @Status      Public
84003>>>>>>>/// @Drivers     ORAFLex MySQLFlex PgFlex
84003>>>>>>>/// @VersionNote Last Revised: 2013-10-01 by Aaron Gulack
84003>>>>>>>/// @See
84003>>>>>>>///
84003>>>>>>>/// @Syntax CALL_STORED_FUNCTION {function} Returns {variable} Passing {parameters}
84003>>>>>>>/// @Param function                     Full name of the function
84003>>>>>>>/// @Param variable                     Variable to hold the returned value
84003>>>>>>>/// @Param parameters           Parameter to pass to the function (can be multiple)
84003>>>>>>>///
84003>>>>>>>/// @Example
84003>>>>>>>/// Move 5 to sCustomerID
84003>>>>>>>/// CALL_STORED_FUNCTION "getCustomerStatus" Returns sStatus Passing sCustomerID
84003>>>>>>>/// Showln sStatus
84003>>>>>>>
84003>>>>>>>//=============================================================================
84003>>>>>>>/// @Name        OUTPUT_INT_FILE
84003>>>>>>>/// @Description This command is used to output the int file of an opened
84003>>>>>>>/// table. If the file to be output to does not exist, it will be created
84003>>>>>>>/// upon execution of this command. Note that the INT file can be output
84003>>>>>>>/// into multiple types of files i.e. .doc, .txt, .int.
84003>>>>>>>///
84003>>>>>>>/// @Assumptions
84003>>>>>>>/// @Status      Public
84003>>>>>>>/// @Drivers     All
84003>>>>>>>/// @VersionNote Last Revised: 2013-10-01 by Aaron Gulack
84003>>>>>>>/// @See
84003>>>>>>>///
84003>>>>>>>/// @Syntax OUTPUT_INT_FILE for {FileNumber} to {variable}
84003>>>>>>>/// @Param FileNumber           The file number
84003>>>>>>>/// @Param variable                     Path of the file being output to
84003>>>>>>>///
84003>>>>>>>///@Example
84003>>>>>>>/// OUTPUT_INT_FILE for Customer.File_Number to "C:\Temp\Customer.int"
84003>>>>>>>
84003>>>>>>>//=============================================================================
84003>>>>>>>/// @Name        SQL_ERROR_MESSAGE
84003>>>>>>>/// @Description This command is used to get an error message
84003>>>>>>>/// from a given SQL statement. If the given statement is executed with
84003>>>>>>>/// no errors, the variable specified with this command will be blank.
84003>>>>>>>/// Otherwise the message will be stored in the given variable. Note that
84003>>>>>>>/// unless specified, strings have a size limit of 80 characters, so using
84003>>>>>>>/// a variant can ensure the full message is retrieved.
84003>>>>>>>///
84003>>>>>>>/// @Assumptions
84003>>>>>>>/// @Status      Public
84003>>>>>>>/// @Drivers     All
84003>>>>>>>/// @VersionNote Last Revised: 2013-10-01 by Aaron Gulack
84003>>>>>>>/// @See         SQL_ERROR_MESSAGE2
84003>>>>>>>///
84003>>>>>>>/// @Syntax SQL_ERROR_MESSAGE {variable}
84003>>>>>>>/// @Param variable                     Variable to hold the error message
84003>>>>>>>///
84003>>>>>>>/// @Example
84003>>>>>>>/// SQL_ERROR_MESSAGE sError
84003>>>>>>>
84003>>>>>>>Function MertechInc_SQL_ERROR_MESSAGE Global Returns String
84005>>>>>>>    Local String sMessage
84005>>>>>>>
84005>>>>>>>    Get MertechInc_Pre_Size_String 0 to sMessage
84006>>>>>>>    Call_Driver 0 MertechInc_DriverName Function CALLDRV_SQL_ERROR_MESSAGE CALLBACK 0 PASSING MertechInc_Blank sMessage 0 RESULT MertechInc_iRet
84011>>>>>>>
84011>>>>>>>    Function_Return sMessage
84012>>>>>>>End_Function
84013>>>>>>>
84013>>>>>>>//=============================================================================
84013>>>>>>>/// @Name        SQL_ERROR_MESSAGE2
84013>>>>>>>/// @Description This command is used to get the last error message used
84013>>>>>>>/// for the specified server. This can be useful once a transaction has
84013>>>>>>>/// already been completed and any error messages need to be retrieved.
84013>>>>>>>///
84013>>>>>>>/// @Assumptions
84013>>>>>>>/// @Status      Public
84013>>>>>>>/// @Drivers     All
84013>>>>>>>/// @VersionNote Last Revised: 2013-10-01 by Aaron Gulack
84013>>>>>>>/// @See         SQL_ERROR_MESSAGE SQL_ERROR_MESSAGE2
84013>>>>>>>///
84013>>>>>>>/// @Syntax SQL_ERROR_MESSAGE2 of {server} to {variable}
84013>>>>>>>/// @Param server                       Name of the server
84013>>>>>>>/// @Param variable                     Variable to hold the error message
84013>>>>>>>///
84013>>>>>>>/// @Example
84013>>>>>>>/// SQL_ERROR_MESSAGE2 of "localhost" to sError
84013>>>>>>>
84013>>>>>>>Function MertechInc_SQL_ERROR_MESSAGE2 Global String sServer Returns String
84015>>>>>>>    Local String sMessage
84015>>>>>>>
84015>>>>>>>    Get MertechInc_Pre_Size_String 800 to sMessage
84016>>>>>>>    Call_Driver 0 MertechInc_DriverName Function CALLDRV_SQL_ERROR_MESSAGE2 CALLBACK 0 PASSING sServer sMessage 0 RESULT MertechInc_iRet
84021>>>>>>>
84021>>>>>>>    Function_Return sMessage
84022>>>>>>>End_Function
84023>>>>>>>
84023>>>>>>>//=============================================================================
84023>>>>>>>/// @Name        MERTECH_WARNING_MESSAGE
84023>>>>>>>/// @Description When restructuring a table, i.e. Structure_Start, a warning
84023>>>>>>>/// message will appear to confirm the restructure before it is executed.
84023>>>>>>>/// This command is used to disable or enable that warning message. All that
84023>>>>>>>/// is passed is either the constant "Enabled" or "Disabled". By default,
84023>>>>>>>/// this message is enabled.
84023>>>>>>>///
84023>>>>>>>/// @Assumptions
84023>>>>>>>/// @Status      Public
84023>>>>>>>/// @Drivers     All
84023>>>>>>>/// @VersionNote Last Revised: 2013-10-01 by Aaron Gulack
84023>>>>>>>///
84023>>>>>>>/// @Syntax MERTECH_WARNING_MESSAGE {Enabled|Disabled}
84023>>>>>>>/// @Param Enabled                      Enables the restructure warning
84023>>>>>>>/// @Param Disabled                     Disables the restructure warning
84023>>>>>>>///
84023>>>>>>>/// @Example
84023>>>>>>>/// Move Customer.File_Number to hFile
84023>>>>>>>/// MERTECH_WARNING_MESSAGE Disabled
84023>>>>>>>///
84023>>>>>>>/// Structure_Start hFile
84023>>>>>>>///     Set_Attribute DF_FILE_OEM_TRANSLATION of hFile to True
84023>>>>>>>/// Structure_End hFile
84023>>>>>>>
84023>>>>>>>//=============================================================================
84023>>>>>>>/// @Name        DISABLE_SELECT_COLUMNS_ERRORS
84023>>>>>>>/// @Description When using SELECT_COLUMNS_FIND to limit the number of columns
84023>>>>>>>/// to fetch, the framework might still ask for columns that you do not need.
84023>>>>>>>/// As a result you'll end up getting runtime errors you do not want to see.
84023>>>>>>>/// This command gives you the ability to stop reporting errors for querying
84023>>>>>>>/// for data from columns that are not part of the query.
84023>>>>>>>///
84023>>>>>>>/// DISABLED_SELECT_COLUMNS_ERRORS DISABLED will disable the errors, use
84023>>>>>>>/// ENABLED to turn the error messages back on.
84023>>>>>>>///
84023>>>>>>>/// By default triggering error messages on unknown columns is ENABLED
84023>>>>>>>///
84023>>>>>>>/// @Assumptions
84023>>>>>>>/// @Status      Public
84023>>>>>>>/// @Drivers     All
84023>>>>>>>/// @VersionNote Last Revised: 2014-04-28 by Wil van Antwerpen
84023>>>>>>>/// @See         SELECT_COLUMNS_FIND RESET_FETCH_FIELDS
84023>>>>>>>///
84023>>>>>>>/// @Example
84023>>>>>>>/// Open Customer
84023>>>>>>>/// RESET_FETCH_FIELDS  CUSTOMER DF_FETCH_FALSE
84023>>>>>>>/// SELECT_COLUMNS_FIND CUSTOMER CUSTOMER_NUMBER NAME
84023>>>>>>>/// DISABLE_SELECT_COLUMNS_ERRORS DISABLED
84023>>>>>>>///
84023>>>>>>>/// Clear Customer
84023>>>>>>>/// Repeat
84023>>>>>>>///    Find Gt Customer by Index.1
84023>>>>>>>///    If (Found) Showln Customer.Customer_Number '-' Customer.Name
84023>>>>>>>/// Until (Not(Found))
84023>>>>>>>///
84023>>>>>>>/// RESET_FETCH_FIELDS Customer DF_FETCH_TRUE
84023>>>>>>>///
84023>>>>>>>/// @Syntax DISABLE_SELECT_COLUMNS_ERRORS {ENABLED|DISABLED}
84023>>>>>>>
84023>>>>>>>//=============================================================================
84023>>>>>>>/// @Name        SQLFlex_REVISION
84023>>>>>>>/// @Description This command will put the current version (decimals included)
84023>>>>>>>/// of the MSSQL driver associated with the current workspace into the
84023>>>>>>>/// specified variable.
