82397>>>>>>>
82397>>>>>>>Class cDFBtrDrvHandler Is An Array
82398>>>>>>>
82398>>>>>>>    Procedure Construct_Object Integer iImage
82400>>>>>>>        Forward Send Construct_object iImage
82402>>>>>>>
82402>>>>>>>        Property String  psDriverID       Public "DFBTRDRV"
82403>>>>>>>    End_Procedure // Construct_Object
82404>>>>>>>
82404>>>>>>>
82404>>>>>>>
82404>>>>>>>    //***
82404>>>>>>>    //*** Function: CKRevsion
82404>>>>>>>    //*** Purpose : The revsion of a Dfbtrdrv Connectivity Kit
82404>>>>>>>    //***
82404>>>>>>>
82404>>>>>>>    Function CKRevision Returns String
82406>>>>>>>        Local String  sDriverID
82406>>>>>>>        Local String  sRevision
82406>>>>>>>        Local String  sVoid
82406>>>>>>>        Local Integer iRetval
82406>>>>>>>
82406>>>>>>>        // Ignore error 20491 DFBTRERR_INVALID_DRIVER_FUNCTION_CALL.
82406>>>>>>>        // This error would otherwise be raised when we have an older
82406>>>>>>>        // DFBTRDRV version that has no DFBTRFN_CKREVISION function
82406>>>>>>>        Send Ignore_error To Error_object_Id 20491
82407>>>>>>>        Get psDriverID To sDriverID
82408>>>>>>>        Move (Repeat(" ", 255)) To sRevision
82409>>>>>>>        Call_Driver 0 sDRiverID Function DFBTRFN_CKREVISION Callback 0 Passing sRevision sVoid 0 Result iRetval
82414>>>>>>>        Send Trap_Error To Error_object_Id 20491
82415>>>>>>>        If (Trim(sRevision) = "") Begin
82417>>>>>>>            // Unable to get the revision. return all zeroes.
82417>>>>>>>            Move "0.0.0.0" To sRevision
82418>>>>>>>        End
82418>>>>>>>>
82418>>>>>>>        Function_Return sRevision
82419>>>>>>>    End_Function // CKRevision
82420>>>>>>>
82420>>>>>>>    Function CkUsesUri Returns Integer
82422>>>>>>>        Local String  sDriverID
82422>>>>>>>        Local String  sVoid1
82422>>>>>>>        Local String  sVoid2
82422>>>>>>>        Local Integer iRetval
82422>>>>>>>
82422>>>>>>>        Get psDriverID To sDriverID
82423>>>>>>>
82423>>>>>>>        Move 0 To iRetval
82424>>>>>>>        // Ignore error 20491 DFBTRERR_INVALID_DRIVER_FUNCTION_CALL.
82424>>>>>>>        // This error would otherwise be raised when we have an older
82424>>>>>>>        // DFBTRDRV version that has no DFBTRFN_CKUSESURI function
82424>>>>>>>        Send Ignore_error To Error_object_Id 20491
82425>>>>>>>        Call_Driver 0 sDRiverID Function DFBTRFN_CKUSESURI Callback 0 Passing sVoid1 sVoid2 0 Result iRetval
82430>>>>>>>        Send Trap_Error To Error_object_Id 20491
82431>>>>>>>
82431>>>>>>>        Function_Return iRetval
82432>>>>>>>    End_Function // CKUsesUri
82433>>>>>>>
82433>>>>>>>
82433>>>>>>>
82433>>>>>>>    //***
82433>>>>>>>    //*** Function: ExtractPartFromRevsion
82433>>>>>>>    //*** Purpose : Extarct the Nth part of a a.b.c.d revsion string.
82433>>>>>>>    //***
82433>>>>>>>    //*** Returns : The part version number or -1 if there is no such part number.
82433>>>>>>>    //***
82433>>>>>>>
82433>>>>>>>    Function ExtractPartFromRevision Integer iPartNum String sRevision Returns Integer
82435>>>>>>>        Local Integer iPartRev
82435>>>>>>>        Local Integer iCurrentPart
82435>>>>>>>        Local Integer iSeparatorPos
82435>>>>>>>
82435>>>>>>>        If (iPartNum > 4) ;            Function_Return -1
82438>>>>>>>
82438>>>>>>>        Move 0 To iCurrentPart
82439>>>>>>>        Repeat
82439>>>>>>>>
82439>>>>>>>            Move (Pos(".", sRevision)) To iSeparatorPos
82440>>>>>>>            If (iSeparatorPos > 0) Begin
82442>>>>>>>                Move (Left(sRevision, iSeparatorPos - 1)) To iPartRev
82443>>>>>>>                Move (Right(sRevision, Length(sRevision) - iSeparatorPos)) To sRevision
82444>>>>>>>                Increment iCurrentPart
82445>>>>>>>            End
82445>>>>>>>>
82445>>>>>>>            Else If (sRevision <> "") Begin
82448>>>>>>>                Move sRevision To iPartRev
82449>>>>>>>                Move "" To sRevision
82450>>>>>>>                Increment iCurrentPart
82451>>>>>>>            End
82451>>>>>>>>
82451>>>>>>>            Else ;                Move -1 To iPartRev
82453>>>>>>>        Until (iCurrentPart >= iPartNum Or iPartRev = -1)
82455>>>>>>>
82455>>>>>>>        Function_Return iPartRev
82456>>>>>>>    End_Function // EcxtractPartFromRevision
82457>>>>>>>
82457>>>>>>>
82457>>>>>>>
82457>>>>>>>    //***
82457>>>>>>>    //*** Function: CKMajorRevision
82457>>>>>>>    //*** Purpose : Returns the major revision of the CK
82457>>>>>>>    //***
82457>>>>>>>
82457>>>>>>>    Function CKMajorRevision Returns Integer
82459>>>>>>>        Function_Return (ExtractPartFromRevision (Current_Object, 1, CKRevision(Current_Object)))
82460>>>>>>>    End_Function // CKMajorRevision
82461>>>>>>>
82461>>>>>>>
82461>>>>>>>
82461>>>>>>>    //***
