94488>>>>>    // To move an existing field to another position in a table.
94488>>>>>    Function ApiColumnMove Handle hTable Integer iOld Integer iNew Returns Boolean
94490>>>>>        String sColumn sDriverID
94490>>>>>        Integer iType iLength iPrecision
94490>>>>>        Boolean bOK
94490>>>>>        
94490>>>>>        Get_Attribute DF_FILE_DRIVER of hTable to sDriverID
94493>>>>>        If (sDriverID = DFBTRDRV_ID) Begin
94495>>>>>            Error DFERR_PROGRAM "Function 'ColumnMove' is not supported for the Pervasive database."
94496>>>>>>
94496>>>>>            Function_Return False
94497>>>>>        End                      
94497>>>>>>
94497>>>>>        
94497>>>>>        Close hTable
94498>>>>>        Get AutoConnectionIDLogin to bOK
94499>>>>>        Open hTable Mode DF_EXCLUSIVE
94501>>>>>        Get_Attribute DF_FIELD_NAME of hTable iOld to sColumn
94504>>>>>        Get_Attribute DF_FIELD_TYPE of hTable iOld to iType
94507>>>>>    
94507>>>>>        If (iType <> DF_DATE) Begin
94509>>>>>            Get_Attribute DF_FIELD_LENGTH of hTable iOld to iLength
94512>>>>>        End
94512>>>>>>
94512>>>>>    
94512>>>>>        If (iType = DF_BCD) Begin
94514>>>>>            Get_Attribute DF_FIELD_PRECISION of hTable iOld to iPrecision
94517>>>>>        End
94517>>>>>>
94517>>>>>        Move False to Err
94518>>>>>    
94518>>>>>        Structure_Start hTable  
94519>>>>>            Delete_Field hTable iOld
94520>>>>>            Create_Field hTable At iNew
94521>>>>>            Set_Attribute DF_FIELD_NAME of hTable iNew to sColumn
94524>>>>>            Set_Attribute DF_FIELD_TYPE of hTable iNew to iType
94527>>>>>    
94527>>>>>            If (iType <> DF_DATE) Begin
94529>>>>>                Set_Attribute DF_FIELD_LENGTH of hTable iNew to iLength
94532>>>>>            End
94532>>>>>>
94532>>>>>    
94532>>>>>            If (iType = DF_BCD) Begin
94534>>>>>                Set_Attribute DF_FIELD_PRECISION of hTable iNew to iPrecision
94537>>>>>            End
94537>>>>>>
94537>>>>>    
94537>>>>>            Set_Attribute DF_FIELD_OLD_NUMBER of hTable iNew to iOld
94540>>>>>        Structure_End hTable
94542>>>>>        
94542>>>>>        Function_Return (Err = False)
94543>>>>>    End_Function
