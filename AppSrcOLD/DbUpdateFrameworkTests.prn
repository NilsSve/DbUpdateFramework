86134>>>>>>>>>>>//
86134>>>>>>>>>>>// Gets the string from the right of the last sStopChar in sFrom
86134>>>>>>>>>>>// If sStopChar has no occurences in the string an empty string is
86134>>>>>>>>>>>// returned.
86134>>>>>>>>>>>Function StringFromRightOfChar Global String sFrom String sStopChar Returns String
86136>>>>>>>>>>>  String  sRetVal
86136>>>>>>>>>>>  String  sChar
86136>>>>>>>>>>>  Integer iLength
86136>>>>>>>>>>>  Integer iPos
86136>>>>>>>>>>>  Boolean bStopChar
86136>>>>>>>>>>>  Move "" To sRetval
86137>>>>>>>>>>>  Move (Length(sFrom)) To iLength
86138>>>>>>>>>>>  If ((iLength>0) And (Pos(sStopChar,sFrom) <> 0)) Begin
86140>>>>>>>>>>>    Move iLength   To iPos
86141>>>>>>>>>>>    Move (False)   To bStopChar
86142>>>>>>>>>>>    While Not bStopChar
86146>>>>>>>>>>>      Move (Mid(sFrom,1,iPos)) To sChar
86147>>>>>>>>>>>      Decrement iPos
86148>>>>>>>>>>>      If ((sChar=sStopChar) Or (iPos<1)) Begin
86150>>>>>>>>>>>        Move (True) To bStopChar
86151>>>>>>>>>>>      End
86151>>>>>>>>>>>>
86151>>>>>>>>>>>      Else Begin
86152>>>>>>>>>>>        Move (sChar+sRetVal) To sRetVal
86153>>>>>>>>>>>      End
86153>>>>>>>>>>>>
86153>>>>>>>>>>>    Loop
86154>>>>>>>>>>>>
86154>>>>>>>>>>>  End
86154>>>>>>>>>>>>
86154>>>>>>>>>>>  Function_Return sRetVal
86155>>>>>>>>>>>End_Function // StringFromRightOfChar
86156>>>>>>>>>>>
86156>>>>>>>>>>>
86156>>>>>>>>>>>// Pre:  sFileName contains the complete path of the file.
86156>>>>>>>>>>>// Post: returns the complete path of the file.
86156>>>>>>>>>>>// This function is inspired on function SEQ_ExtractPathFromFileName of Sture Andersen.
86156>>>>>>>>>>>Function ParseFolderName Global String sFileName Returns String
86158>>>>>>>>>>>  String sFile
86158>>>>>>>>>>>  String sFolderName
86158>>>>>>>>>>>  String sDirSep // this is "\" for windows, or "/" for unix
86158>>>>>>>>>>>  MOve "" To sFolderName
86159>>>>>>>>>>>  Move (sysconf(SYSCONF_DIR_SEPARATOR)) To sDirSep
86160>>>>>>>>>>>  If sDirSep In sFileName Begin
86162>>>>>>>>>>>    Move (StringFromRightOfChar(sFileName,sDirSep)) To sFile
86163>>>>>>>>>>>    Move (Replace(sFile,sFileName,"")) To sFolderName
86164>>>>>>>>>>>  End
86164>>>>>>>>>>>>
86164>>>>>>>>>>>  Else If ":" In sFileName Begin
86167>>>>>>>>>>>    Move (StringFromRightOfChar(sFileName,":")) To sFile
86168>>>>>>>>>>>    Move (Replace(sFile,sFileName,"")) To sFolderName
86169>>>>>>>>>>>  End
86169>>>>>>>>>>>>
86169>>>>>>>>>>>  Function_Return sFolderName
86170>>>>>>>>>>>End_Function // ParseFolderName
86171>>>>>>>>>>>
86171>>>>>>>>>>>
86171>>>>>>>>>>>// Pre:  sFileName contains the complete path of the file.
86171>>>>>>>>>>>// post: The returned filename has it's path removed, but will have a extension
86171>>>>>>>>>>>Function ParseFileName Global String sFileName Returns String
86173>>>>>>>>>>>  String sFolderName
86173>>>>>>>>>>>  String sDirSep // this is "\" for windows, or "/" for unix
86173>>>>>>>>>>>  Move (sysconf(SYSCONF_DIR_SEPARATOR)) To sDirSep
86174>>>>>>>>>>>  Get ParseFolderName sFileName To sFolderName
86175>>>>>>>>>>>  If (sFolderName <> "") Move (Replace(sFolderName,sFileName,"")) To sFileName
86178>>>>>>>>>>>  Move (Replace(sDirSep,sFileName,"")) To sFileName
86179>>>>>>>>>>>  Function_Return sFilename
86180>>>>>>>>>>>End_Function // ParseFileName
86181>>>>>>>>>>>
86181>>>>>>>>>>>
86181>>>>>>>>>>>// Pre:  sFileName may contain the complete path of the file.
86181>>>>>>>>>>>//       or contain multiple dots in the filename, so temp.gif.bak will
86181>>>>>>>>>>>//       return "bak" as the extension and not "gif"
86181>>>>>>>>>>>// Post: returns the extension only, this extension can be a valid unixlike extension
86181>>>>>>>>>>>//       such as "html" or "java"
86181>>>>>>>>>>>Function ParseFileExtension Global String sFileName Returns String
86183>>>>>>>>>>>  String  sFileExtension
86183>>>>>>>>>>>  Get StringFromRightOfChar sFileName "." To sFileExtension
86184>>>>>>>>>>>  Function_Return sFileExtension
86185>>>>>>>>>>>End_Function // ParseFileExtension
86186>>>>>>>>>>>
86186>>>>>>>>>>>
86186>>>>>>>>>>>Define CS_DDE_ERR_UNKNOWN_LINE2   For ".\n"
86186>>>>>>>>>>>
86186>>>>>>>>>>>
86186>>>>>>>>>>>Function DDE_Error_To_String Integer iErrorID Returns String
86189>>>>>>>>>>>  String sMessage
86189>>>>>>>>>>>  Case Begin
86189>>>>>>>>>>>    Case (iErrorID = vERROR_FILE_NOT_FOUND)
86191>>>>>>>>>>>      Move CS_DDE_ERR_FILE_NOT_FOUND To sMessage
86192>>>>>>>>>>>      Case Break
86193>>>>>>>>>>>    Case (iErrorID = vERROR_PATH_NOT_FOUND)
86196>>>>>>>>>>>      Move CS_DDE_ERR_PATH_NOT_FOUND To sMessage
86197>>>>>>>>>>>      Case Break
86198>>>>>>>>>>>    Case (iErrorID = vERROR_BAD_FORMAT)
86201>>>>>>>>>>>      Move CS_DDE_ERR_BAD_FORMAT To sMessage
86202>>>>>>>>>>>      Case Break
86203>>>>>>>>>>>    Case (iErrorID = vSE_ERR_ACCESSDENIED)
86206>>>>>>>>>>>      Move CS_DDE_ERR_ACCESSDENIED To sMessage
86207>>>>>>>>>>>      Case Break
86208>>>>>>>>>>>    Case (iErrorID = vSE_ERR_ASSOCINCOMPLETE)
86211>>>>>>>>>>>      Move CS_DDE_ERR_ASSOCINCOMPLETE To sMessage
86212>>>>>>>>>>>      Case Break
86213>>>>>>>>>>>    Case (iErrorID = vSE_ERR_DDEBUSY)
86216>>>>>>>>>>>      Move CS_DDE_ERR_DDEBUSY To sMessage
86217>>>>>>>>>>>      Case Break
86218>>>>>>>>>>>    Case (iErrorID = vSE_ERR_DDEFAIL)
86221>>>>>>>>>>>      Move CS_DDE_ERR_DDEFAIL To sMessage
86222>>>>>>>>>>>      Case Break
86223>>>>>>>>>>>    Case (iErrorID = vSE_ERR_DDETIMEOUT)
86226>>>>>>>>>>>      Move CS_DDE_ERR_DDETIMEOUT To sMessage
86227>>>>>>>>>>>      Case Break
86228>>>>>>>>>>>    Case (iErrorID = vSE_ERR_DLLNOTFOUND)
86231>>>>>>>>>>>      Move CS_DDE_ERR_DLLNOTFOUND To sMessage
86232>>>>>>>>>>>      Case Break
86233>>>>>>>>>>>    Case (iErrorID = vSE_ERR_NOASSOC)
86236>>>>>>>>>>>      Move CS_DDE_ERR_NOASSOC To sMessage
86237>>>>>>>>>>>      Case Break
86238>>>>>>>>>>>    Case ((iErrorID = vSE_ERR_OOM) Or (iErrorID = 0))
86241>>>>>>>>>>>      Move CS_DDE_ERR_OOM To sMessage
86242>>>>>>>>>>>      Case Break
86243>>>>>>>>>>>    Case (iErrorID = vSE_ERR_PNF)
86246>>>>>>>>>>>      Move CS_DDE_ERR_PNF To sMessage
86247>>>>>>>>>>>      Case Break
86248>>>>>>>>>>>    Case (iErrorID = vSE_ERR_SHARE)
86251>>>>>>>>>>>      Move CS_DDE_ERR_SHARE To sMessage
86252>>>>>>>>>>>      Case Break
86253>>>>>>>>>>>    Case Else
86253>>>>>>>>>>>      Move CS_DDE_ERR_UNKNOWN_LINE1 To sMessage
86254>>>>>>>>>>>      Move (sMessage*Trim(iErrorID)*CS_DDE_ERR_UNKNOWN_LINE2) To sMessage
86255>>>>>>>>>>>      Case Break
86256>>>>>>>>>>>  Case End
86256>>>>>>>>>>>  Function_Return sMessage
86257>>>>>>>>>>>End_Function // DDE_Error_To_String
86258>>>>>>>>>>>
86258>>>>>>>>>>>
86258>>>>>>>>>>>Procedure vDDE_Error_Handler Integer iErrorID
86261>>>>>>>>>>>  String sMessage
86261>>>>>>>>>>>  Get DDE_Error_To_String iErrorID To sMessage
86262>>>>>>>>>>>  Append sMessage CS_DDE_ERR_HANDL_PAKTC //  "Press a key to continue..."
86263>>>>>>>>>>>  Send Stop_Box sMessage CS_DDE_ERR_HANDL_CAPTION
86264>>>>>>>>>>>End_Procedure // vDDE_Error_Handler hInstance
86265>>>>>>>>>>>
86265>>>>>>>>>>>
86265>>>>>>>>>>>// Does the directory exist? - No = 0, Yes = 1
86265>>>>>>>>>>>// This also works with UNC path encoding and wildcards
86265>>>>>>>>>>>Function vFolderExists Global String sFolderName Returns Integer
86267>>>>>>>>>>>  String  sFolder sTmp
86267>>>>>>>>>>>  Integer bFolderExists iCh
86267>>>>>>>>>>>
86267>>>>>>>>>>>  // 2013-09-29 NGS Check for empty folder name and convert to ANSI
86267>>>>>>>>>>>  Move (ToANSI(Trim(sFolderName))) to sFolderName
86268>>>>>>>>>>>  If (sFolderName = "") Begin
86270>>>>>>>>>>>    Function_Return False
86271>>>>>>>>>>>  End
86271>>>>>>>>>>>>
86271>>>>>>>>>>>
86271>>>>>>>>>>>  Move dfTrue To bFolderExists
86272>>>>>>>>>>>  Move "dir:" To sFolder
86273>>>>>>>>>>>  Append sFolder sFolderName
86274>>>>>>>>>>>  Get Seq_New_Channel To iCh  // get free channel for input
86275>>>>>>>>>>>  Direct_Input Channel iCh sFolder
86277>>>>>>>>>>>    Repeat
86277>>>>>>>>>>>>
86277>>>>>>>>>>>      Readln Channel iCh sTmp
86279>>>>>>>>>>>      If (Trim(sTmp)="") Move dfFalse To bFolderExists
86282>>>>>>>>>>>      Else Begin
86283>>>>>>>>>>>        Move dfTrue To bFolderExists
86284>>>>>>>>>>>        Indicate seqeof True  // end loop
86285>>>>>>>>>>>        End
86285>>>>>>>>>>>>
86285>>>>>>>>>>>    Until (seqeof)
86287>>>>>>>>>>>  Close_Input Channel iCh
86289>>>>>>>>>>>  Send Seq_Release_Channel iCh
86290>>>>>>>>>>>  Function_Return bFolderExists
86291>>>>>>>>>>>End_Function  // vFolderExists
86292>>>>>>>>>>>
86292>>>>>>>>>>>
86292>>>>>>>>>>>// returns folder name if a folder was selected, otherwise returns ""
86292>>>>>>>>>>>Function vSHBrowseForFolder Global String sDialogTitle Returns String
86294>>>>>>>>>>>  String sFolder sBrowseInfo sTitle
86294>>>>>>>>>>>  Pointer lpItemIdList lpsFolder lpsBrowseInfo lpsTitle
86294>>>>>>>>>>>  Integer iFolderSelected iRetval
86294>>>>>>>>>>>
86294>>>>>>>>>>>  // fill string variable with null characters
86294>>>>>>>>>>>  ZeroType vtBrowseInfo To sBrowseInfo
86295>>>>>>>>>>>
86295>>>>>>>>>>>  If (sDialogTitle<>"") Begin
86297>>>>>>>>>>>    Move sDialogTitle To sTitle
86298>>>>>>>>>>>    // Torben Lund suggested converting the string with toansi. Doing it like that
86298>>>>>>>>>>>    // disables showing some commonly used ascii characters like ascii 137 (‰)
86298>>>>>>>>>>>    // These chars are correctly shown if no toansi is used.
86298>>>>>>>>>>>    // I can imagine that he wanted to path to be ANSI, but as long as it isa just
86298>>>>>>>>>>>    // selected it will always be valid.
86298>>>>>>>>>>>    GetAddress Of sTitle To lpsTitle
86299>>>>>>>>>>>    Put lpsTitle To sBrowseInfo At vtBrowseInfo.lpszTitle
86300>>>>>>>>>>>  End
86300>>>>>>>>>>>>
86300>>>>>>>>>>>
86300>>>>>>>>>>>  Put vBIF_RETURNONLYFSDIRS To sBrowseInfo At vtBrowseInfo.ulFlags
86301>>>>>>>>>>>
86301>>>>>>>>>>>  // Torben Lund added line below. Move handle of focus object to structure before
86301>>>>>>>>>>>  // calling function. Otherwise, the folderdialog will be started as a seperate task.
86301>>>>>>>>>>>  Put (window_handle(focus(desktop))) To sBrowseInfo At vtBrowseInfo.hWndOwner
86302>>>>>>>>>>>
86302>>>>>>>>>>>  GetAddress Of sBrowseInfo To lpsBrowseInfo
86303>>>>>>>>>>>
86303>>>>>>>>>>>  // null 128 chars into var (make space)
86303>>>>>>>>>>>  Move (Repeat(Character(0), vMAX_PATH)) To sFolder
86304>>>>>>>>>>>  GetAddress Of sFolder To lpsFolder
86305>>>>>>>>>>>
86305>>>>>>>>>>>  // select folder
86305>>>>>>>>>>>  Move (vWin32_SHBrowseForFolder(lpsBrowseInfo)) To lpItemIdList
86306>>>>>>>>>>>  // get selected folder name
86306>>>>>>>>>>>  Move (vWin32_SHGetPathFromIDList(lpItemIdList, lpsFolder)) To iFolderSelected
86307>>>>>>>>>>>
86307>>>>>>>>>>>  // release memory resources that are used by the ItemIdList
86307>>>>>>>>>>>  Move (vWin32_CoTaskMemFree(lpItemIdList)) To iRetval
86308>>>>>>>>>>>
86308>>>>>>>>>>>  If (iFolderSelected<>0) Function_Return (CString(sFolder))
86311>>>>>>>>>>>  Else Function_Return ""
86313>>>>>>>>>>>End_Function // vSHBrowseForFolder
86314>>>>>>>>>>>
86314>>>>>>>>>>>
86314>>>>>>>>>>>// returns 0 if the folder is created.
86314>>>>>>>>>>>//         1 if the API-call returned an error.
86314>>>>>>>>>>>Function vCreateDirectory Global String sNewFolder Returns Integer
86316>>>>>>>>>>>  String  sFolder sSA
86316>>>>>>>>>>>  Pointer lpsFolder lpsSecurity_Attributes lpDescriptor
86316>>>>>>>>>>>  Integer iRetval bFolderCreated bInheritHandle
86316>>>>>>>>>>>
86316>>>>>>>>>>>  Move (False) To bFolderCreated
86317>>>>>>>>>>>  // fill string variable with null characters
86317>>>>>>>>>>>  ZeroType vtSecurity_attributes To sSA
86318>>>>>>>>>>>
86318>>>>>>>>>>>  // null MAX_PATH chars into var (make space)
86318>>>>>>>>>>>  Move (Repeat(Character(0), vMAX_PATH)) To sFolder
86319>>>>>>>>>>>
86319>>>>>>>>>>>  If (sNewFolder <> "") Begin
86321>>>>>>>>>>>
86321>>>>>>>>>>>    Move dfTrue To  bInheritHandle
86322>>>>>>>>>>>    // Setting this to NULL is already done by the zerotype command
86322>>>>>>>>>>>    // Move NULL   To  lpDescriptor
86322>>>>>>>>>>>    Put (length(sSA))   To sSA At vtSecurity_attributes.nLength
86323>>>>>>>>>>>    //Put lpDescriptor To sSA at vtSecurity_attributes.lpDescriptor
86323>>>>>>>>>>>    Put bInheritHandle To sSA At vtSecurity_attributes.bInheritHandle
86324>>>>>>>>>>>
86324>>>>>>>>>>>    GetAddress Of sSA To lpsSecurity_Attributes
86325>>>>>>>>>>>
86325>>>>>>>>>>>    //
86325>>>>>>>>>>>    Move sNewFolder To sFolder
86326>>>>>>>>>>>    GetAddress Of sFolder To lpsFolder
86327>>>>>>>>>>>    Move (vWin32_CreateDirectory(lpsFolder, lpsSecurity_Attributes)) To bFolderCreated
86328>>>>>>>>>>>  End
86328>>>>>>>>>>>>
86328>>>>>>>>>>>
86328>>>>>>>>>>>  Ifnot bFolderCreated Move 1 To iRetVal
86331>>>>>>>>>>>  Function_Return iRetVal
86332>>>>>>>>>>>End_Function // vCreateDirectory
86333>>>>>>>>>>>
86333>>>>>>>>>>>
86333>>>>>>>>>>>// **WvA: 03-02-2002 Function created.
86333>>>>>>>>>>>// With this function one can remove a directory.
86333>>>>>>>>>>>// returns 0 if the folder is removed.
86333>>>>>>>>>>>//         1 if the API-call returned an error (Use GetLastError API to get the details)
86333>>>>>>>>>>>//         2 if the folder did not exist
86333>>>>>>>>>>>//         3 if the sFolder parameter passed is equal to ""
86333>>>>>>>>>>>Function vRemoveDirectory Global String sFolder Returns Integer
86335>>>>>>>>>>>  String  sPath
86335>>>>>>>>>>>  Pointer lpsPath
86335>>>>>>>>>>>  Integer iRetval bRemoved bExists
86335>>>>>>>>>>>
86335>>>>>>>>>>>  Move (False) To bRemoved
86336>>>>>>>>>>>  Move 0 To iRetVal
86337>>>>>>>>>>>  Move (Trim(sFolder)) To sFolder
86338>>>>>>>>>>>  If (sFolder="") Begin
86340>>>>>>>>>>>    Move 3 To iRetVal
86341>>>>>>>>>>>  End
86341>>>>>>>>>>>>
86341>>>>>>>>>>>  If (vFolderExists(sFolder)=False) Begin
86343>>>>>>>>>>>    Move 2 To iRetVal
86344>>>>>>>>>>>  End
86344>>>>>>>>>>>>
86344>>>>>>>>>>>  If (iRetVal=0) Begin
86346>>>>>>>>>>>    // null MAX_PATH chars into var (make space)
86346>>>>>>>>>>>    Move (Repeat(Character(0), vMAX_PATH)) To sPath
86347>>>>>>>>>>>    //
86347>>>>>>>>>>>    Move (Insert(sFolder,sPath,1)) To sPath
86348>>>>>>>>>>>    GetAddress Of sPath To lpsPath
86349>>>>>>>>>>>    Move (vWin32_RemoveDirectory(lpsPath)) To bRemoved
86350>>>>>>>>>>>  End
86350>>>>>>>>>>>>
86350>>>>>>>>>>>
86350>>>>>>>>>>>  If ((iRetVal=0) And (bRemoved=False)) Begin
86352>>>>>>>>>>>    Move 1 To iRetVal
86353>>>>>>>>>>>  End
86353>>>>>>>>>>>>
86353>>>>>>>>>>>  Function_Return iRetVal
86354>>>>>>>>>>>End_Function // vRemoveDirectory
86355>>>>>>>>>>>
86355>>>>>>>>>>>
86355>>>>>>>>>>>
86355>>>>>>>>>>>// This function informs the user that he entered a yet unknown folder and
86355>>>>>>>>>>>// asks if he/she wants to create the folder (Yes/No)
86355>>>>>>>>>>>// Choice: "Yes" - this creates the folder
86355>>>>>>>>>>>//                 if successful, the function returns false
86355>>>>>>>>>>>//                 else it will be true.
86355>>>>>>>>>>>// Choice: "No"  - returns TRUE, This allows the programmer to take action
86355>>>>>>>>>>>//                 For example: to stop a save
86355>>>>>>>>>>>// Precondition: A foldername must be entered. We do not check for empty paths
86355>>>>>>>>>>>// This function returns a non-zero value if the folder isn't created afterwards
86355>>>>>>>>>>>Function vVerifyNewFolder Global String sFolderName Returns Integer
86357>>>>>>>>>>>  Integer bIsNotValid
86357>>>>>>>>>>>  Integer iUsers_Choice
86357>>>>>>>>>>>  String  sMessage
86357>>>>>>>>>>>
86357>>>>>>>>>>>  If (vFolderExists(sFolderName) Eq 0) Begin
86359>>>>>>>>>>>    Move "The folder '" To sMessage
86360>>>>>>>>>>>    Append sMessage sFolderName
86361>>>>>>>>>>>    Append sMessage "' does not yet exist,\n"
86362>>>>>>>>>>>    Append sMessage "Do you want to create it now?"
86363>>>>>>>>>>>    Get YesNo_Box sMessage "Confirm" MB_DefButton1 To iUsers_Choice
86364>>>>>>>>>>>    Case Begin
86364>>>>>>>>>>>      Case (iUsers_Choice = MBR_Yes)
86366>>>>>>>>>>>        Move (vCreateDirectory(sFolderName)) To bIsNotValid
86367>>>>>>>>>>>        If bIsNotValid Begin
86369>>>>>>>>>>>          Move "An error occurred while trying to create folder '" To sMessage
86370>>>>>>>>>>>          Append sMessage sFolderName "'.\n\n"
86372>>>>>>>>>>>          Send Info_Box sMessage "Info"
86373>>>>>>>>>>>          End
86373>>>>>>>>>>>>
86373>>>>>>>>>>>        Case Break
86374>>>>>>>>>>>      Case (iUsers_Choice = MBR_No)
86377>>>>>>>>>>>        Move dfTrue To bIsNotValid // Cancel the save
86378>>>>>>>>>>>        Case Break
86379>>>>>>>>>>>    Case End
86379>>>>>>>>>>>  End
86379>>>>>>>>>>>>
86379>>>>>>>>>>>  Function_Return bIsNotValid
86380>>>>>>>>>>>End_Function // vVerifyNewFolder
86381>>>>>>>>>>>
86381>>>>>>>>>>>
86381>>>>>>>>>>>// This will perform an operation on a file (e.g. open) with the application
86381>>>>>>>>>>>// registered in the Windows Registry to open that type of file (via its extension)
86381>>>>>>>>>>>// sOperation would be "OPEN" (it could also be "PRINT" etc).
86381>>>>>>>>>>>Procedure vShellExecute global String sOperation String sDocument String sParameters String sPath
86383>>>>>>>>>>>  Handle  hInstance hWnd
86383>>>>>>>>>>>  Pointer lpsOperation
86383>>>>>>>>>>>  Pointer lpsDocument
86383>>>>>>>>>>>  Pointer lpsParameters
86383>>>>>>>>>>>  Pointer lpsPath
86383>>>>>>>>>>>  // remove any leading/trailing spaces in the string
86383>>>>>>>>>>>  Move (Trim(sDocument)) To sDocument
86384>>>>>>>>>>>  Move (Trim(sPath))     To sPath
86385>>>>>>>>>>>  // Make the strings readable for windows API, by converting them to null-terminated
86385>>>>>>>>>>>  Append sOperation   (Character(0))
86386>>>>>>>>>>>  Append sDocument    (Character(0))
86387>>>>>>>>>>>  Append sParameters  (Character(0))
86388>>>>>>>>>>>  Append sPath        (Character(0))
86389>>>>>>>>>>>  // Connect the corresponding pointers to the strings
86389>>>>>>>>>>>  GetAddress Of sOperation  To lpsOperation
86390>>>>>>>>>>>  GetAddress Of sDocument   To lpsDocument
86391>>>>>>>>>>>  GetAddress Of sParameters To lpsParameters
86392>>>>>>>>>>>  GetAddress Of sPath       To lpsPath
86393>>>>>>>>>>>
86393>>>>>>>>>>>  Get Window_Handle To hWnd
86394>>>>>>>>>>>  Move (vWin32_ShellExecute (hWnd, lpsOperation, lpsDocument, lpsParameters, lpsPath, 1)) To hInstance
86395>>>>>>>>>>>  If (hInstance <= 32) Begin
86397>>>>>>>>>>>    Send vDDE_Error_Handler hInstance
86398>>>>>>>>>>>  End
86398>>>>>>>>>>>>
86398>>>>>>>>>>>End_Procedure // vShellExecute
86399>>>>>>>>>>>
86399>>>>>>>>>>>
86399>>>>>>>>>>>Class cShellFileOperations Is a Array
86400>>>>>>>>>>>
86400>>>>>>>>>>>  Procedure Construct_Object
86402>>>>>>>>>>>    Forward Send Construct_Object
86404>>>>>>>>>>>    Property Integer piDeleteFlags        Public 0
86405>>>>>>>>>>>    Property Integer piCopyFlags          Public 0
86406>>>>>>>>>>>    Property Integer piMoveFlags          Public 0
86407>>>>>>>>>>>    Property Integer piRenameFlags        Public 0
86408>>>>>>>>>>>    
86408>>>>>>>>>>>    Set piDeleteFlags To (vFOF_SILENT Ior vFOF_NOCONFIRMATION)
86409>>>>>>>>>>>    Set piCopyFlags   To (vFOF_SILENT iOr vFOF_NOCONFIRMMKDIR Ior vFOF_NOCONFIRMATION)
86410>>>>>>>>>>>    Set piMoveFlags   To (vFOF_SILENT iOr vFOF_NOCONFIRMMKDIR iOr vFOF_NOCONFIRMATION)
86411>>>>>>>>>>>    Set piRenameFlags To (vFOF_SILENT Ior vFOF_NOCONFIRMATION)
86412>>>>>>>>>>>  End_Procedure // Construct_Object
86413>>>>>>>>>>>  
86413>>>>>>>>>>>  
86413>>>>>>>>>>>  // This function uses the shell API to perform a file operation on the
86413>>>>>>>>>>>  // files supplied.
86413>>>>>>>>>>>  //
86413>>>>>>>>>>>  Function FileOperation String sSource String sDestination Integer iOperation Integer iFlags Returns Integer
86415>>>>>>>>>>>    String   sShFileOp
86415>>>>>>>>>>>    Pointer  lpShFileOp
86415>>>>>>>>>>>    Pointer  lpsSource
86415>>>>>>>>>>>    Pointer  lpsDestination
86415>>>>>>>>>>>    Integer  iRetVal
86415>>>>>>>>>>>    Integer  bUserAbort
86415>>>>>>>>>>>             
86415>>>>>>>>>>>    ZeroType vtShFileOpStruct To sShFileOp
86416>>>>>>>>>>>    Move (ToAnsi(sSource)+Character(0)+Character(0))      To sSource
86417>>>>>>>>>>>    Move (ToAnsi(sDestination)+Character(0)+Character(0)) To sDestination
86418>>>>>>>>>>>    GetAddress Of sSource    To lpsSource
86419>>>>>>>>>>>    If iOperation Ne vFO_DELETE Begin
86421>>>>>>>>>>>      GetAddress Of sDestination      To lpsDestination
86422>>>>>>>>>>>      Put lpsDestination To sShFileOp At vtShFileOpStruct.pTo
86423>>>>>>>>>>>    End
86423>>>>>>>>>>>>
86423>>>>>>>>>>>  
86423>>>>>>>>>>>    Put iOperation     To sShFileOp At vtShFileOpStruct.wFunc
86424>>>>>>>>>>>    Put lpsSource      To sShFileOp At vtShFileOpStruct.pFrom
86425>>>>>>>>>>>    Put iFlags         To sShFileOp At vtShFileOpStruct.fFlags
86426>>>>>>>>>>>  
86426>>>>>>>>>>>    GetAddress Of sShFileOp To lpShFileOp
86427>>>>>>>>>>>  
86427>>>>>>>>>>>    Move (vWin32_SHFileOperation(lpShFileOp)) To iRetVal
86428>>>>>>>>>>>    GetBuff From sShFileOp At vtShFileOpStruct.fAnyOperationsAborted To bUserAbort
86429>>>>>>>>>>>    If (bUserAbort <> 0) Begin
86431>>>>>>>>>>>      Move 80 To iRetVal  // file Operation Aborted by USER
86432>>>>>>>>>>>    End
86432>>>>>>>>>>>>
86432>>>>>>>>>>>    Function_Return (iRetVal)
86433>>>>>>>>>>>  End_Function // FileOperation
86434>>>>>>>>>>>    
86434>>>>>>>>>>>  
