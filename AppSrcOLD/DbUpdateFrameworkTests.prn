92754>>>>>    Function SQLUtilTableIsViewType String sDriverID Handle hTable Returns Boolean
92756>>>>>        Boolean bViewTableType bOpen bMertechDriver bOK
92756>>>>>        Integer hoSQLHandler
92756>>>>>        Integer iTableCount iNumTables iPos iTableIndex
92756>>>>>        String sTableName sOwner sTableType sLogin sEnumTableName sEnumSchemaName sCurrent_Login
92756>>>>>        Handle hoCliHandler  
92756>>>>>        tSQLConnection SQLConnection
92756>>>>>        tSQLConnection SQLConnection
92756>>>>>        
92756>>>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpen
92759>>>>>        If (bOpen = False) Begin  
92761>>>>>            Get AutoConnectionIDLogin to bOK
92762>>>>>            Open hTable
92764>>>>>        End
92764>>>>>>
92764>>>>>        
92764>>>>>        Get pSQLConnection to SQLConnection   
92765>>>>>        Get phoCLIHandler to hoCliHandler
92766>>>>>        Set psDriverID of hoCliHandler to sDriverID
92767>>>>>        
92767>>>>>        Get_Attribute DF_FILE_ROOT_NAME of hTable to sTableName 
92770>>>>>        Get _TableNameOnly sTableName to sTableName             
92771>>>>>        Get_Attribute DF_FILE_OWNER     of hTable to sOwner
92774>>>>>        Get EnumerateTables of hoCliHandler SQLConnection.sConnectionString to iNumTables
92775>>>>>        
92775>>>>>        For iTableCount from 1 to iNumTables
92781>>>>>>
92781>>>>>            Get TableName  of hoCliHandler iTableCount to sEnumTableName
92782>>>>>            Get SchemaName of hoCliHandler iTableCount to sEnumSchemaName
92783>>>>>            If ((Uppercase(sEnumTableName)  = Uppercase(sTableName)) and (Uppercase(sEnumSchemaName) = Uppercase(sOwner))) Begin
92785>>>>>                Get TableType of hoCliHandler iTableCount to sTableType
92786>>>>>                Move iNumTables to iTableCount // We're done.
92787>>>>>            End
92787>>>>>>
92787>>>>>        Loop
92788>>>>>>
92788>>>>>        
92788>>>>>        Move (sTableType = "VIEW") to bViewTableType
92789>>>>>        If (bOpen = False) Begin
92791>>>>>            Close hTable
92792>>>>>        End
92792>>>>>>
92792>>>>>        
92792>>>>>        Function_Return bViewTableType
92793>>>>>    End_Function
