100242>>>                Object oPrintFilelist_btn is a Button
100244>>>                    Set Location to 59 14
100245>>>                    Set Label to "Print Filelist"
100246>>>                    Set psToolTip to "Writes the content of Filelist.cfg to a textfile and shows the textfile in Notepad."
100247>>>                    
100247>>>                    Property Integer piSortOrder 0 // Property gets set by the radio group object.
100249>>>                    
100249>>>                    // Custom array sort function.
100249>>>                    // iSortOrder = 0 -> Filelist number order
100249>>>                    // iSortOrder = 1 -> Logical name order
100249>>>                    // iSortOrder = 2 -> Root name order                                             
100249>>>                    // iSortOrder = 3 -> Display name order
100249>>>                    Function CompareSortFilelist tFilelistDUF FilelistDUF1 tFilelistDUF FilelistDUF2 Returns Integer
100252>>>                        Integer iSortOrder 
100252>>>                        
100252>>>                        Get piSortOrder to iSortOrder
100253>>>                        
100253>>>                        Case Begin
100253>>>                            Case (iSortOrder = 0)    
100255>>>                                If (FilelistDUF1.iFileNumber  > FilelistDUF2.iFileNumber) Begin
100257>>>                                    Function_Return (GT)
100258>>>                                End
100258>>>>
100258>>>                                If (FilelistDUF1.iFileNumber  < FilelistDUF2.iFileNumber) Begin
100260>>>                                    Function_Return (LT)
100261>>>                                End                    
100261>>>>
100261>>>                                Function_Return (EQ)
100262>>>                            Case (iSortOrder = 1)
100265>>>                                If (Uppercase(FilelistDUF1.sLogicalName) > Uppercase(FilelistDUF2.sLogicalName)) Begin
100267>>>                                    Function_Return (GT)
100268>>>                                End
100268>>>>
100268>>>                                If (Uppercase(FilelistDUF1.sLogicalName) < Uppercase(FilelistDUF2.sLogicalName)) Begin
100270>>>                                    Function_Return (LT)
100271>>>                                End                    
100271>>>>
100271>>>                                Function_Return (EQ)
100272>>>                            Case (iSortOrder = 2)
100275>>>                                If (Uppercase(FilelistDUF1.sRootName)    > Uppercase(FilelistDUF2.sRootName)) Begin
100277>>>                                    Function_Return (GT)
100278>>>                                End
100278>>>>
100278>>>                                If (Uppercase(FilelistDUF1.sRootName)    < Uppercase(FilelistDUF2.sRootName)) Begin
100280>>>                                    Function_Return (LT)
100281>>>                                End                           
100281>>>>
100281>>>                                Function_Return (EQ)
100282>>>                            Case (iSortOrder = 3)
100285>>>                                If (Uppercase(FilelistDUF1.sDisplayName) > Uppercase(FilelistDUF2.sDisplayName)) Begin
100287>>>                                    Function_Return (GT)
100288>>>                                End
100288>>>>
100288>>>                                If (Uppercase(FilelistDUF1.sDisplayName) < Uppercase(FilelistDUF2.sDisplayName)) Begin
100290>>>                                    Function_Return (LT)
100291>>>                                End                    
100291>>>>
100291>>>                                Function_Return (EQ)
100292>>>                        Case End
100292>>>                            
100292>>>                    End_Function
100293>>>                
100293>>>                    Procedure OnClick
100296>>>                        String sFileList sRootName sLogicalName sDisplayName sPath sOutputName sTable sExt
100296>>>                        Integer iCh iCount iSize
100296>>>                        Handle hTable
100296>>>                        tFilelistDUF[] FilelistDUFArray FilelistDUFSorted
100296>>>                        tFilelistDUF[] FilelistDUFArray FilelistDUFSorted
100298>>>
100298>>>                        Get Value of oFilelistPath_fm to sFileList
100299>>>                        Move (Trim(sFileList)) to sFileList
100300>>>                        If (sFileList = "") Begin
100302>>>                            Send Info_Box "You need to select a Filelist.cfg file first"
100303>>>                            Procedure_Return
100304>>>                        End
100304>>>>
100304>>>                        
100304>>>                        Get ParseFolderName sFileList to sPath           
100305>>>                        Get vFolderFormat sPath to sPath
100306>>>                        Get ParseFileName sFileList to sOutputName
100307>>>                        Get ParseFileExtension sFileList to sExt
100308>>>                        Move (Replace(sExt, sOutputName, "")) to sOutputName
100309>>>                        Move (sOutputName + "txt")           to sOutputName
100310>>>                        Get Seq_Open_Output_Channel (sPath + sOutputName) to iCh
100311>>>                        If (iCh < 0) Begin
100313>>>                            Procedure_Return
100314>>>                        End
100314>>>>
100314>>>                        
100314>>>                        Move 0 to hTable
100315>>>                        Writeln channel iCh sFileList
100318>>>                        Writeln channel iCh "[Table No:]            [LogicalName:]        [RootName:]                             [DisplayName:]" 
100321>>>                        Writeln channel iCh "==================================================================================================="
100324>>>                        Writeln channel iCh
100326>>>                        
100326>>>                        Move 0 to iCount
100327>>>                        Repeat
100327>>>>
100327>>>                            Get_Attribute DF_FILE_NEXT_USED of hTable to hTable
100330>>>                            If (hTable > 0) Begin                               
100332>>>                                Move hTable                                  to FilelistDUFArray[iCount].iFileNumber
100333>>>                                Get_Attribute DF_FILE_LOGICAL_NAME of hTable to FilelistDUFArray[iCount].sLogicalName  
100336>>>                                Get_Attribute DF_FILE_ROOT_NAME    of hTable to FilelistDUFArray[iCount].sRootName
100339>>>                                Get_Attribute DF_FILE_DISPLAY_NAME of hTable to FilelistDUFArray[iCount].sDisplayName
100342>>>                                Increment iCount
100343>>>                            End
100343>>>>
100343>>>                        Until (hTable = 0)
100345>>>                        
100345>>>                        Move (SortArray(FilelistDUFArray, Self, (RefFunc(CompareSortFilelist)))) to FilelistDUFSorted
100346>>>                        Move (SizeOfArray(FilelistDUFSorted)) to iSize
100347>>>                        Decrement iSize
100348>>>                        
100348>>>                        For iCount from 0 to iSize
100354>>>>
100354>>>                            Move FilelistDUFSorted[iCount].iFileNumber  to hTable        
100355>>>                            Move FilelistDUFSorted[iCount].sLogicalName to sLogicalName
100356>>>                            Move FilelistDUFSorted[iCount].sRootName    to sRootName
100357>>>                            Move FilelistDUFSorted[iCount].sDisplayName to sDisplayName
100358>>>                            
100358>>>                            Get PadLeft (String(hTable))        09 to sTable
100359>>>                            Get PadLeft (String(sLogicalName)) (27 - Length(sTable))       to sLogicalName
100360>>>                            Get PadLeft (String(sRootName))    (46 - Length(sLogicalName)) to sRootName
100361>>>                            Get PadLeft (String(sDisplayName)) (72 - Length(sRootName))    to sDisplayName
100362>>>                            
100362>>>                            Writeln channel iCh sTable (ToANSI(sRootName)) (ToANSI(sLogicalName)) (ToANSI(sDisplayName)) 
100368>>>                        Loop                                
100369>>>>
100369>>>
100369>>>                        Writeln channel iCh "==================================================================================================="
100372>>>                        Writeln channel iCh "Total Number of Tables in Filelist.cfg: " (iSize + 1)
100376>>>                        Close_Output
100377>>>            
100377>>>                        Send vShellExecute "open" sOutputName "" sPath
100378>>>                    End_Procedure
100379>>>                
100379>>>                    Function PadLeft String sString Integer iLength String sOptChar Returns String
100382>>>                        String sChar
100382>>>                        
100382>>>                        If (Num_Arguments >= 3) Begin
100384>>>                            Move sOptChar to sChar
100385>>>                        End
100385>>>>
100385>>>                        Else Begin
100386>>>                            Move " " to sChar
100387>>>                        End
100387>>>>
100387>>>                        
100387>>>                        While (Length(sString) < iLength)
100391>>>                            Move (sChar + sString) to sString
100392>>>                        Loop
100393>>>>
100393>>>                        
100393>>>                        Function_Return sString 
100394>>>                    End_Function    
100395>>>                    
100395>>>                End_Object                         
