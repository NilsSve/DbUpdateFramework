89136>>>>>>>>>>>Class cDbUpdateGenericDatabaseDriver is a cObject
89137>>>>>>>>>>>    Procedure Construct_Object
89139>>>>>>>>>>>        Forward Send Construct_Object
89141>>>>>>>>>>>        Property String psDriverID DATAFLEX_ID
89142>>>>>>>>>>>    End_Procedure 
89143>>>>>>>>>>>    
89143>>>>>>>>>>>    Function ServerKeyword Returns String
89145>>>>>>>>>>>        Function_Return CS_SQLIniDSNKeyword
89146>>>>>>>>>>>    End_Function
89147>>>>>>>>>>>    
89147>>>>>>>>>>>    Function ConstructConnectionString String sServer String sDatabase Boolean bTrusted String sUserID String sPassword Returns String
89149>>>>>>>>>>>        String sConnect
89149>>>>>>>>>>>        
89149>>>>>>>>>>>        Move (sConnect * ServerKeyword(Self) + "=" + sServer) to sConnect
89150>>>>>>>>>>>        If (sDatabase <> "") Begin
89152>>>>>>>>>>>            Move (sConnect * ";" + CS_SQLIniDatabaseKeyword + "=" + sDatabase) to sConnect
89153>>>>>>>>>>>        End
89153>>>>>>>>>>>>
89153>>>>>>>>>>>        If (bTrusted = True) Begin
89155>>>>>>>>>>>            Move (sConnect * ";" + CS_SQLIniTrustedKeyword + "=Yes") to sConnect
89156>>>>>>>>>>>        End
89156>>>>>>>>>>>>
89156>>>>>>>>>>>        Else Begin
89157>>>>>>>>>>>            Move (sConnect * ";" + CS_SQLIniUIDKeyword + "=" + sUserID * ";" + CS_SQLIniPWDKeyword + "=" + sPassword) to sConnect
89158>>>>>>>>>>>        End
89158>>>>>>>>>>>>
89158>>>>>>>>>>>        Function_Return sConnect
89159>>>>>>>>>>>    End_Function
89160>>>>>>>>>>>    
89160>>>>>>>>>>>    Function DbLogin String sConnectionString String sServer String sDatabase Boolean bTrusted String sUserID String sPassword Returns Boolean
89162>>>>>>>>>>>        Boolean bLoginSuccessful
89162>>>>>>>>>>>        String sDriverID 
89162>>>>>>>>>>>        
89162>>>>>>>>>>>        Get psDriverID to sDriverID
89163>>>>>>>>>>>        Move 0 to LastErr  // Do NOT use the Err flag, it will be set true by the login command although it is successful.
89164>>>>>>>>>>>        If (bTrusted = False) Begin
89166>>>>>>>>>>>            Login sServer sUserId sPassword sDriverID
89168>>>>>>>>>>>        End 
89168>>>>>>>>>>>>
89168>>>>>>>>>>>        Else Begin
89169>>>>>>>>>>>            Login sConnectionString "" "" sDriverID
89171>>>>>>>>>>>        End
89171>>>>>>>>>>>>
89171>>>>>>>>>>>        Move (LastErr = 0) to bLoginSuccessful
89172>>>>>>>>>>>        Function_Return bLoginSuccessful
89173>>>>>>>>>>>    End_Function
89174>>>>>>>>>>>End_Class
89175>>>>>>>>>>>
