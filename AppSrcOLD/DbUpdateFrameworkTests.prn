86527>>>>>>>>>>>Function vGetWindowsDirectory Returns String
86530>>>>>>>>>>>  String  sDirectory
86530>>>>>>>>>>>  Pointer lpDirectory
86530>>>>>>>>>>>  Integer iVoid
86530>>>>>>>>>>>
86530>>>>>>>>>>>  ZeroString vMAX_PATH To sDirectory
86531>>>>>>>>>>>  GetAddress Of sDirectory To lpDirectory
86532>>>>>>>>>>>
86532>>>>>>>>>>>  Move (vWin32_GetWindowsDirectory(lpDirectory, vMAX_PATH)) To iVoid
86533>>>>>>>>>>>  Function_Return (CString(sDirectory))  // **WvA: Changed to CString()
86534>>>>>>>>>>>End_Function // vGetWindowsDirectory
86535>>>>>>>>>>>
86535>>>>>>>>>>>
86535>>>>>>>>>>>
86535>>>>>>>>>>>
86535>>>>>>>>>>>// Courtesy of Marco Kuipers
86535>>>>>>>>>>>Function vMakeTempFile Returns String
86538>>>>>>>>>>>    Integer iRetval
86538>>>>>>>>>>>    String  sTempPath sTempFileName sPrefixString
86538>>>>>>>>>>>    Pointer lpTempPath lpTempFileName lpPrefixString
86538>>>>>>>>>>>
86538>>>>>>>>>>>    Move (Repeat (Character (0), 255)) To sTempPath
86539>>>>>>>>>>>    GetAddress Of sTempPath To lpTempPath
86540>>>>>>>>>>>    Move (vWin32_GetTempPath (255, lpTempPath)) To iRetVal
86541>>>>>>>>>>>
86541>>>>>>>>>>>    If (sTempPath = "") Begin
86543>>>>>>>>>>>       Get_Current_Directory To sTempPath
86544>>>>>>>>>>>    End
86544>>>>>>>>>>>>
86544>>>>>>>>>>>    Move (pad(sTempPath,vMax_Path-14)) To sTempPath // *WvA: 28-04-2005 Quote from msdn: The string cannot be longer than MAX_PATH-14 characters.
86545>>>>>>>>>>>    Move (Repeat (Character (0), 255)) To sTempFileName
86546>>>>>>>>>>>    GetAddress Of sTempFileName To lpTempFileName
86547>>>>>>>>>>>    Move ("tmp"+character(0)) To sPrefixString // **WvA: 28-04-2005 Added a null
86548>>>>>>>>>>>    GetAddress Of sPrefixString To lpPrefixString
86549>>>>>>>>>>>    GetAddress Of sTempPath To lpTempPath
86550>>>>>>>>>>>    Move (vWin32_GetTempFileName (lpTempPath, lpPrefixString, 0, lpTempFileName)) To iRetval
86551>>>>>>>>>>>    If (iRetval = 0) Begin  // **WvA: 28-04-2005 Changed condition, the api call returns 0 if an error occurs
86553>>>>>>>>>>>        Move "" To sTempFileName
86554>>>>>>>>>>>    End
86554>>>>>>>>>>>>
86554>>>>>>>>>>>
86554>>>>>>>>>>>    Function_Return (Cstring(sTempFileName)) // **WvA: 28-04-2005 Cstring added
86555>>>>>>>>>>>End_Function // vMakeTempFile
86556>>>>>>>>>>>
86556>>>>>>>>>>>
86556>>>>>>>>>>>// This function creates a uniquely named temporary file in folder sPath
86556>>>>>>>>>>>// The file created will have a prefix based on the first 3 characters in sPrefix
86556>>>>>>>>>>>// Note that you will have to cleanup the tempfile yourself as the function
86556>>>>>>>>>>>// does not take care of that.
86556>>>>>>>>>>>Function vCreateTempFileInPath String sPath String sPrefix Returns String
86559>>>>>>>>>>>    String sTempFileName
86559>>>>>>>>>>>    Integer iCnt iRetVal
86559>>>>>>>>>>>    Pointer lpTempFileName
86559>>>>>>>>>>>    Pointer lpPath
86559>>>>>>>>>>>    Pointer lpPrefix
86559>>>>>>>>>>>
86559>>>>>>>>>>>    Move (ToAnsi(sPath)+Character(0))   To sPath
86560>>>>>>>>>>>    Move (ToAnsi(sPrefix)+Character(0)) To sPrefix
86561>>>>>>>>>>>    Move (pad("", vMAX_PATH)) To sTempFileName
86562>>>>>>>>>>>    GetAddress Of sTempFileName To lpTempFileName
86563>>>>>>>>>>>    GetAddress Of sPath         To lpPath
86564>>>>>>>>>>>    GetAddress Of sPrefix       To lpPrefix
86565>>>>>>>>>>>
86565>>>>>>>>>>>    Move (vWin32_GetTempFileName(lpPath, lpPrefix, 0, lpTempFileName)) To iRetVal
86566>>>>>>>>>>>    Move (Trim(Cstring(sTempFileName))) To sTempFileName
86567>>>>>>>>>>>    Function_Return sTempFileName
86568>>>>>>>>>>>End_Function // vCreateTempFileInPath
86569>>>>>>>>>>>
86569>>>>>>>>>>>//
86569>>>>>>>>>>>// Get a specific shell folder for example to get the desktop folder
86569>>>>>>>>>>>// simply call this function and pass it vCSIDL_DESKTOP
86569>>>>>>>>>>>//
86569>>>>>>>>>>>Function vSHGetFolderPath Integer eFolder Returns String
86572>>>>>>>>>>>  String  sFolder
