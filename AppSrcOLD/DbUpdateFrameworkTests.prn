95027>>>>>    
95027>>>>>    Function UtilColumnTypePrecision String sDriverID Integer iDbType Integer iDataType Returns String
95029>>>>>        tColumnType RetvalType  
95029>>>>>        tColumnType RetvalType  
95029>>>>>        String sValue
95029>>>>>        
95029>>>>>        Get _UtilColumnType sDriverID iDbType iDataType "" True to RetvalType 
95030>>>>>        Function_Return RetvalType.sPrecision
95031>>>>>    End_Function  
95032>>>>>    
95032>>>>>    Function UtilColumnTypeFixed String sDriverID Integer iDbType Integer iDataType Returns Boolean
95034>>>>>        tColumnType RetvalType  
95034>>>>>        tColumnType RetvalType  
95034>>>>>        String sValue
95034>>>>>        
95034>>>>>        Get _UtilColumnType sDriverID iDbType iDataType "" True to RetvalType 
95035>>>>>        Function_Return RetvalType.bFixedSize
95036>>>>>    End_Function  
95037>>>>>    
95037>>>>>    Function UtilColumnTypePrecisionSize String sDriverID Integer iDbType Integer iDataType Returns Integer
95039>>>>>        tColumnType RetvalType  
95039>>>>>        tColumnType RetvalType  
95039>>>>>        String sValue
95039>>>>>        Integer iRetval iPos
95039>>>>>        
95039>>>>>        Get _UtilColumnType sDriverID iDbType iDataType "" True to RetvalType 
95040>>>>>        Move RetvalType.sPrecision to sValue
95041>>>>>        Move (Pos(".", sValue)) to iPos
95042>>>>>        If (iPos <> 0) Begin
95044>>>>>            Move (Left(sValue, (iPos -1))) to iRetval
95045>>>>>        End                                          
95045>>>>>>
95045>>>>>        Else Begin
95046>>>>>            Move sValue to iRetval
95047>>>>>        End
95047>>>>>>
95047>>>>>        Function_Return iRetval
95048>>>>>    End_Function
95049>>>>>    
95049>>>>>    Function UtilColumnTypePrecisionDec String sDriverID Integer iDbType Integer iDataType Returns Integer
95051>>>>>        tColumnType RetvalType  
95051>>>>>        tColumnType RetvalType  
95051>>>>>        String sValue
95051>>>>>        Integer iRetval iPos
95051>>>>>        
95051>>>>>        Get _UtilColumnType sDriverID iDbType iDataType "" True to RetvalType 
95052>>>>>        Move RetvalType.sPrecision to sValue
95053>>>>>        Move (Pos(".", sValue)) to iPos
95054>>>>>        If (iPos = 0) Begin
95056>>>>>            Function_Return 0
95057>>>>>        End
95057>>>>>>
95057>>>>>        Move (Mid(sValue, 99, (iPos + 1))) to iRetval
95058>>>>>
95058>>>>>        Function_Return iRetval
95059>>>>>    End_Function
95060>>>>>    
95060>>>>>    // The default value used for a datatype as specified in the driver int file.
95060>>>>>    Function UtilDataTypeDefaultValue String sDriverID Integer iDbType Integer iDataType Returns String
95062>>>>>        String sRetval sServer
95062>>>>>        tColumnType RetvalType 
95062>>>>>        tColumnType RetvalType 
95062>>>>>        Integer iDriver iDataFlexType
95062>>>>>        Handle hDatabase
95062>>>>>        
95062>>>>>        Get _UtilColumnType sDriverID iDbType iDataType "" True to RetvalType 
95063>>>>>        Move RetvalType.iDataFlexType to iDataFlexType
95064>>>>>        Get DriverIndex sDriverID to iDriver
95065>>>>>        Get psServer to sServer
95066>>>>>        Get SqlUtilDatabaseHandle sDriverID sServer to hDatabase 
95067>>>>>        If (hDatabase = 0) Begin
95069>>>>>            Function_Return ""
95070>>>>>        End                   
95070>>>>>>
95070>>>>>        
95070>>>>>        Case Begin
95070>>>>>            Case (iDataFlexType = DF_ASCII)
95072>>>>>                Get_Attribute DF_DATABASE_DEFAULT_DEFAULT_ASCII     of iDriver hDatabase to sRetval
95075>>>>>                Case Break
95076>>>>>            Case (iDataFlexType = DF_BCD)
95079>>>>>                Get_Attribute DF_DATABASE_DEFAULT_DEFAULT_NUMERIC   of iDriver hDatabase to sRetval
95082>>>>>                Case Break
95083>>>>>            Case (iDataFlexType = DF_BINARY)
95086>>>>>                Get_Attribute DF_DATABASE_DEFAULT_DEFAULT_BINARY    of iDriver hDatabase to sRetval
95089>>>>>                Case Break
95090>>>>>            Case (iDataFlexType = DF_DATE)
95093>>>>>                Get_Attribute DF_DATABASE_DEFAULT_DEFAULT_DATE      of iDriver hDatabase to sRetval
95096>>>>>                Case Break
95097>>>>>            Case (iDataFlexType = DF_DATETIME)
95100>>>>>                Get_Attribute DF_DATABASE_DEFAULT_DEFAULT_DATETIME  of iDriver hDatabase to sRetval
95103>>>>>                Case Break
95104>>>>>            Case (iDataFlexType = DF_TEXT)
95107>>>>>                Get_Attribute DF_DATABASE_DEFAULT_DEFAULT_TEXT      of iDriver hDatabase to sRetval
95110>>>>>                Case Break
95111>>>>>            Case Else
95111>>>>>                Move "" to sRetval            
95112>>>>>        Case End
95112>>>>>        
95112>>>>>        Function_Return sRetval
95113>>>>>    End_Function  
95114>>>>>    
95114>>>>>    Function SQLUtilDefaultNullValue String sDriverID Integer iDbType Integer iDataType Returns String
95116>>>>>        String sNotNull sRetval sDefaultValue
95116>>>>>        Boolean bOK
95116>>>>>        
95116>>>>>        Get IsSQLDriver sDriverID to bOK
95117>>>>>        If (bOK = False) Begin
95119>>>>>            Function_Return ""
95120>>>>>        End                   
95120>>>>>>
95120>>>>>        
95120>>>>>        Get UtilDataTypeDefaultValue sDriverID iDbType iDataType to sDefaultValue
95121>>>>>        Get _SqlFindKeyWord CI_SQLNotNull to sNotNull
95122>>>>>        
95122>>>>>        Case Begin
95122>>>>>            Case (iDbType = EN_dbTypeMSSQL)
95124>>>>>                Move ("DEFAULT" * String(sDefaultValue) * String(sNotNull)) to sRetval
95125>>>>>                Case Break
95126>>>>>            Case (iDbType = EN_dbTypeMySQL)
95129>>>>>                Move (String(sNotNull) * "DEFAULT" * String(sDefaultValue)) to sRetval
95130>>>>>                Case Break
95131>>>>>            Case (iDbType = EN_dbTypePostgre)
95134>>>>>                Move (String(sNotNull) * "DEFAULT" * String(sDefaultValue)) to sRetval
95135>>>>>                Case Break
95136>>>>>            Case (iDbType = EN_dbTypeDB2)
95139>>>>>                Move (String(sNotNull))                                     to sRetval
95140>>>>>                Case Break
95141>>>>>            
95141>>>>>            // Seems like Oracle can't handle setting a new column to 'NOT NULL' if the table exists with data(!)
95141>>>>>            // ToDo: We need to look deeper into how Oracle handles NULL
95141>>>>>            Case (iDbType = EN_dbTypeOracle)
95144>>>>>                Move  ""                                                    to sRetval
95145>>>>>                Case Break                                              
95146>>>>>
95146>>>>>            Case Else
95146>>>>>                Move  ""                                                    to sRetval
95147>>>>>        Case End        
95147>>>>>        
95147>>>>>        Function_Return sRetval
95148>>>>>    End_Function
95149>>>>>    
95149>>>>>    // Returns a struct array with the default column types for the SQL back-end and how they
95149>>>>>    // are mapped to the standard DataFlex data types. 
95149>>>>>    // The DataFlex data types are: "ASCII", "BINARY", "DATE", "DATETIME", "NUMERIC" and "TEXT".
95149>>>>>    Function UtilDefaultSqlTypeMappings String sDriverID Integer iDbType Returns tColumnType
95151>>>>>        tColumnType[] ColumnTypeArray
95151>>>>>        tColumnType[] ColumnTypeArray
95152>>>>>        String sDataType
95152>>>>>        Integer iDataType iDriverID iCount
95152>>>>>        
95152>>>>>        Move 0 to iCount
95153>>>>>        Get DriverIndex sDriverID to iDriverID
95154>>>>>
95154>>>>>        // DF_ASCII       
95154>>>>>        If (sDriverID = ODBC_DRV_ID) Begin
95156>>>>>            Get_Attribute DF_DRIVER_MAP_DFASCII_TO_ODBCTYPE of iDriverID to iDataType
95159>>>>>        End                                                             
95159>>>>>>
95159>>>>>        Else Begin
95160>>>>>            Get_Attribute DF_DRIVER_MAP_DFASCII_TO_SQLTYPE  of iDriverID to iDataType 
95163>>>>>        End
95163>>>>>>
95163>>>>>        Move DF_ASCII    to ColumnTypeArray[iCount].iDataFlexType
95164>>>>>        Move "ASCII"     to ColumnTypeArray[iCount].sDataFlexType  
95165>>>>>        Get UtilColumnTypeToString sDriverID iDbType iDataType to sDataType
95166>>>>>        Move sDataType   to ColumnTypeArray[iCount].sType
95167>>>>>        Move iDataType   to ColumnTypeArray[iCount].iType
95168>>>>>        Increment iCount
95169>>>>>        
95169>>>>>        // DF_BINARY 
95169>>>>>        If (sDriverID = ODBC_DRV_ID) Begin
95171>>>>>            Get_Attribute DF_DRIVER_MAP_DFBINARY_TO_ODBCTYPE of iDriverID to iDataType
95174>>>>>        End                                                                          
95174>>>>>>
95174>>>>>        Else Begin
95175>>>>>            Get_Attribute DF_DRIVER_MAP_DFBINARY_TO_SQLTYPE  of iDriverID to iDataType
95178>>>>>        End
95178>>>>>>
95178>>>>>        Move DF_BINARY   to ColumnTypeArray[iCount].iDataFlexType
95179>>>>>        Move "Binary"    to ColumnTypeArray[iCount].sDataFlexType  
95180>>>>>        Get UtilColumnTypeToString sDriverID iDbType iDataType to sDataType
95181>>>>>        Move sDataType   to ColumnTypeArray[iCount].sType
95182>>>>>        Move iDataType   to ColumnTypeArray[iCount].iType
95183>>>>>        Increment iCount
95184>>>>>        
95184>>>>>        // DF_DATE
95184>>>>>        If (sDriverID = ODBC_DRV_ID) Begin
95186>>>>>            Get_Attribute DF_DRIVER_MAP_DFDATE_TO_ODBCTYPE of iDriverID to iDataType
95189>>>>>        End                                                                          
95189>>>>>>
95189>>>>>        Else Begin
95190>>>>>            Get_Attribute DF_DRIVER_MAP_DFDATE_TO_SQLTYPE  of iDriverID to iDataType
95193>>>>>        End
95193>>>>>>
95193>>>>>        Move DF_DATE     to ColumnTypeArray[iCount].iDataFlexType
95194>>>>>        Move "Date"      to ColumnTypeArray[iCount].sDataFlexType  
95195>>>>>        Get UtilColumnTypeToString sDriverID iDbType iDataType to sDataType
95196>>>>>        Move sDataType   to ColumnTypeArray[iCount].sType
95197>>>>>        Move iDataType   to ColumnTypeArray[iCount].iType
95198>>>>>        Increment iCount
95199>>>>>        
95199>>>>>        // DF_DATETIME
95199>>>>>        If (sDriverID = ODBC_DRV_ID) Begin
95201>>>>>            Get_Attribute DF_DRIVER_MAP_DFDATETIME_TO_ODBCTYPE of iDriverID to iDataType
95204>>>>>        End                                                                          
95204>>>>>>
95204>>>>>        Else Begin
95205>>>>>            Get_Attribute DF_DRIVER_MAP_DFDATETIME_TO_SQLTYPE  of iDriverID to iDataType
95208>>>>>        End
95208>>>>>>
95208>>>>>        Move DF_DATETIME to ColumnTypeArray[iCount].iDataFlexType
95209>>>>>        Move "DateTime"  to ColumnTypeArray[iCount].sDataFlexType  
95210>>>>>        Get UtilColumnTypeToString sDriverID iDbType iDataType to sDataType
95211>>>>>        Move sDataType   to ColumnTypeArray[iCount].sType
95212>>>>>        Move iDataType   to ColumnTypeArray[iCount].iType
95213>>>>>        Increment iCount
95214>>>>>
95214>>>>>        // DF_NUMERIC
95214>>>>>        // *** Why is there no DF_DRIVER_MAP available for BCD/Numeric??? ***
95214>>>>>        // DF_BCD can in SQL be either of "SmallInt", "Int", or "Numeric", but
95214>>>>>        // we make them here all "Numeric"...
95214>>>>>//        If (sDriverID = ODBC_DRV_ID) Begin
95214>>>>>//            Get_Attribute DF_DRIVER_MAP_DFDATE_TO_ODBCTYPE of iDriverID to iDataType
95214>>>>>//        End                                                                          
95214>>>>>//        Else Begin
95214>>>>>//            Get_Attribute DF_DRIVER_MAP_DFDATE_TO_SQLTYPE  of iDriverID to iDataType
95214>>>>>//        End                        
95214>>>>>        Move DF_BCD      to ColumnTypeArray[iCount].iDataFlexType
95215>>>>>        Move "Numeric"   to ColumnTypeArray[iCount].sDataFlexType
95216>>>>>        Move "Numeric"   to ColumnTypeArray[iCount].sType
95217>>>>>        Move SQL_NUMERIC to ColumnTypeArray[iCount].iType
95218>>>>>
95218>>>>>        // DF_TEXT
95218>>>>>        If (sDriverID = ODBC_DRV_ID) Begin
95220>>>>>            Get_Attribute DF_DRIVER_MAP_DFTEXT_TO_ODBCTYPE of iDriverID to iDataType
95223>>>>>        End                                                                          
95223>>>>>>
95223>>>>>        Else Begin
95224>>>>>            Get_Attribute DF_DRIVER_MAP_DFTEXT_TO_SQLTYPE  of iDriverID to iDataType
95227>>>>>        End
95227>>>>>>
95227>>>>>        Move DF_TEXT     to ColumnTypeArray[iCount].iDataFlexType
95228>>>>>        Move "Text"      to ColumnTypeArray[iCount].sDataFlexType  
95229>>>>>        Get UtilColumnTypeToString sDriverID iDbType iDataType to sDataType
95230>>>>>        Move sDataType   to ColumnTypeArray[iCount].sType
95231>>>>>        Move iDataType   to ColumnTypeArray[iCount].iType
95232>>>>>        Increment iCount
95233>>>>>        
95233>>>>>        Function_Return ColumnTypeArray
95234>>>>>    End_Function
