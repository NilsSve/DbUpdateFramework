89864>>>>>>>>>    // Returns the full path of the Application (no trailing "\")
89864>>>>>>>>>    Function ApplicationPath Returns String
89866>>>>>>>>>        String sApplicationFileName sPath
89866>>>>>>>>>        Integer iNumChars iRetval
89866>>>>>>>>>
89866>>>>>>>>>        Move (Repeat(Character(0), 1024))    to sApplicationFileName
89867>>>>>>>>>        Move (GetModuleFileName(0, AddressOf(sApplicationFileName), 1024)) to iNumChars
89868>>>>>>>>>        Move (CString(sApplicationFileName)) to sApplicationFileName
89869>>>>>>>>>        Move (PathRemoveFileSpec(AddressOf(sApplicationFileName))) to iRetval
89870>>>>>>>>>        Move (CString(sApplicationFileName)) to sPath
89871>>>>>>>>>
89871>>>>>>>>>        Function_Return sPath
89872>>>>>>>>>    End_Function
