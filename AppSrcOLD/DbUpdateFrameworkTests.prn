92445>>>>>    Procedure SqlUtilExecuteQuery String sStmt String sDriverID Boolean bShowProgr 
92447>>>>>        String sConnectionString sMessage
92447>>>>>        Handle hoSqlHandler hoSQLConnect hoStmt hoError
92447>>>>>        Integer i iMsgs iFetchResult iResultCount iRowType iRows iErr iMessage
92447>>>>>        String[] sMsg aSQLQueryMessages aSQLFetchResults
92450>>>>>        DateTime dtQueryExecStart dtQueryExecEnd dtFetchStart dtFetchEnd
92450>>>>>        TimeSpan tsQuery tsFetch
92450>>>>>        tSqlErrorArray aSqlErrorArray
92450>>>>>        tSqlErrorArray aSqlErrorArray
92450>>>>>        Boolean bOK bMertechDriver bShowProgress
92450>>>>>        tSQLConnection SQLConnection
92450>>>>>        tSQLConnection SQLConnection
92450>>>>>        
92450>>>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
92451>>>>>        If (bOK = False) Begin
92453>>>>>            Procedure_Return
92454>>>>>        End
92454>>>>>>
92454>>>>>        
92454>>>>>        If (num_arguments > 2) Begin
92456>>>>>            Move bShowProgr to bShowProgress
92457>>>>>        End
92457>>>>>>
92457>>>>>
92457>>>>>        Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
92458>>>>>        
92458>>>>>        Get IsMertechDriver sDriverID to bMertechDriver
92459>>>>>        If (bMertechDriver = True) Begin
92461>>>>>            Get _MertechSQLConnect sDriverID SQLConnection.sServer SQLConnection.sUserID SQLConnection.sPassword to hoSQLConnect
92462>>>>>        End
92462>>>>>>
92462>>>>>        If (bMertechDriver = False) Begin
92464>>>>>            Get phoSQLManager to hoSqlHandler
92465>>>>>            Send SqlSetConnect of hoSqlHandler sDriverID SQLConnection.sConnectionString
92466>>>>>            Get SqlConnect     of hoSqlHandler "" "" to hoSQLConnect
92467>>>>>        End
92467>>>>>>
92467>>>>>
92467>>>>>        If (hoSQLConnect <> 0) Begin
92469>>>>>            Get SqlOpen of hoSQLConnect to hoStmt
92470>>>>>            If (hoStmt <> 0) Begin
92472>>>>>                // record starting date/time stamp
92472>>>>>                Move (CurrentDateTime()) to dtQueryExecStart
92473>>>>>                // turn on error handling if enabled 
92473>>>>>                If (pbHandleQueryErrors(Self)) Begin
92475>>>>>                    Set pbSqlError to False 
92476>>>>>                    Set paSqlErrorArray to aSqlErrorArray
92477>>>>>                    Move Error_Object_Id to hoError
92478>>>>>                    Move Self to Error_Object_Id
92479>>>>>                End               
92479>>>>>>
92479>>>>>                
92479>>>>>                // Before we execute the statement; save it so we can display the faulty statement in the error log.
92479>>>>>                Set psSQLStatementString to sStmt
92480>>>>>                Send SqlExecDirect of hoStmt sStmt
92481>>>>>                
92481>>>>>                If (pbHandleQueryErrors(Self)) Begin
92483>>>>>                    Move hoError to Error_Object_Id
92484>>>>>                End       
92484>>>>>>
92484>>>>>                
92484>>>>>                Move 0 to iMsgs
92485>>>>>                // ToDo: There seems to be some issues with this code and Mertech drivers that makes
92485>>>>>                // the debugger crash in some cases like an error in the ESQL statement; so we exclude it for now.
92485>>>>>                If (bMertechDriver = False) Begin   
92487>>>>>                    Move Err to iErr
92488>>>>>                    Get SqlStmtAttribute of hoStmt SQLSTMTATTRIB_NUMMESSAGES   to iMsgs
92489>>>>>                    Get SqlStmtAttribute of hoStmt SqlSTMTATTRIB_ROWCOUNT      to iRows
92490>>>>>                    Get SqlStmtAttribute of hoStmt SqlSTMTATTRIB_ROWCOUNT_TYPE to iRowType
92491>>>>>                    Send _SqlColumnInfo hoStmt
92492>>>>>                    Send Ignore_Error of Error_Object_Id 12289    
92493>>>>>                    Set Error_Report_Mode to DUF_ERROR_NO_REPORT
92494>>>>>                    Repeat     
92494>>>>>>
92494>>>>>                        Get SqlFetch of hoStmt to iFetchResult
92495>>>>>                        If (iFetchResult <> 0) Begin
92497>>>>>                            Get SQLColumnValue of hoStmt 1 to aSQLFetchResults[SizeOfArray(aSQLFetchResults)]
92498>>>>>                        End
92498>>>>>>
92498>>>>>                    Until (iFetchResult = 0)
92500>>>>>                    Send Trap_Error of Error_Object_Id 12289    
92501>>>>>                    Set Error_Report_Mode to DUF_ERROR_REPORT 
92502>>>>>                    Move iErr to Err
92503>>>>>                    Set paSQLFetchResults to aSQLFetchResults
92504>>>>>                End 
92504>>>>>>
92504>>>>>                
92504>>>>>                Set piRows    to iRows
92505>>>>>                Set piRowType to iRowType
92506>>>>>                Move (CurrentDateTime()) to dtQueryExecEnd
92507>>>>>                Move (CurrentDateTime()) to dtFetchStart
92508>>>>>
92508>>>>>                If (iMsgs <> 0) Begin
92510>>>>>                    If (ghoDbUpdateHandler > 0) Begin
92512>>>>>                        Get paSQLQueryMessages of ghoDbUpdateHandler to aSQLQueryMessages
92513>>>>>                    End
92513>>>>>>
92513>>>>>                    For i from 1 to iMsgs
92519>>>>>>
92519>>>>>                        Get SqlGetMessage of hoStmt i to sMessage
92520>>>>>                        Get RemoveComponentIdentifier of hoStmt sMessage to sMessage
92521>>>>>                        If (bShowProgress = True) Begin
92523>>>>>                            If (Active_State(ghoStatusPanel)) Begin
92525>>>>>                                Send Update_StatusPanel of ghoStatusPanel (Sformat("  SQLGetMessage iMessage %1 returned [%2]",iMessage,sMessage))
92526>>>>>                            End                                                   
92526>>>>>>
92526>>>>>                            Else Begin
92527>>>>>                                Showln (Sformat("  SQLGetMessage iMessage %1 returned [%2]",iMessage,sMessage))
92529>>>>>                            End                                           
92529>>>>>>
92529>>>>>                        End
92529>>>>>>
92529>>>>>                        Move sMessage to sMsg[SizeOfArray(sMsg)]
92530>>>>>                        Move sMessage to aSQLQueryMessages[SizeOfArray(aSQLQueryMessages)]
92531>>>>>                    Loop
92532>>>>>>
92532>>>>>                    If (ghoDbUpdateHandler > 0) Begin
92534>>>>>                        Set paSQLQueryMessages of ghoDbUpdateHandler to aSQLQueryMessages
92535>>>>>                    End
92535>>>>>>
92535>>>>>                    Set paQueryMessages to sMsg  
92536>>>>>                End
92536>>>>>>
92536>>>>>                Move (CurrentDateTime()) to dtFetchEnd
92537>>>>>            End
92537>>>>>>
92537>>>>>            Move (dtQueryExecEnd - dtQueryExecStart) to tsQuery
92538>>>>>            Move (dtFetchStart - dtFetchEnd) to tsFetch
92539>>>>>            Set ptsQueryExec to tsQuery
92540>>>>>            Set ptsFetchResults to tsFetch
92541>>>>>            Send SqlClose of hoStmt
92542>>>>>        End
92542>>>>>>
92542>>>>>
92542>>>>>        Send SqlDisconnect of hoSQLConnect
92543>>>>>    End_Procedure
