93960>>>>>    // Calls a driver function directly to copy data from one table to another (table structures needs to be the same).
93960>>>>>    // It will first drop all indicies, copy the data and then recreate indicies. 
93960>>>>>    // An error log file with the sRootname + ".err" will be created in the Data folder.
93960>>>>>    Function ApiTableCopyData Integer hFromTable String sPhysicalName String sRootName String sDriverID Returns Boolean
93962>>>>>        Boolean bOpened bOK
93962>>>>>        Integer hToTable iIndex iCount iRetval iVoid iOrgFreq
93962>>>>>        String sErrorFile sEmpty sPath
93962>>>>>        
93962>>>>>        Get AutoConnectionIDLogin to bOK
93963>>>>>        Get_Attribute DF_FILE_NEXT_EMPTY of 0 to hToTable
93966>>>>>        Move False to Err
93967>>>>>        Open sPhysicalName as hToTable
93969>>>>>        Get_Attribute DF_FILE_OPENED of hToTable to bOpened
93972>>>>>        If (bOpened = False) Begin
93974>>>>>            Function_Return False
93975>>>>>        End                      
93975>>>>>>
93975>>>>>        
93975>>>>>        Move "" to sEmpty 
93976>>>>>        Move False to Err   
93977>>>>>        Move True to bOK       
93978>>>>>        
93978>>>>>        Get_Attribute DF_RUNTIME_PROGRESS_FREQUENCY to iOrgFreq
93981>>>>>        Set_Attribute DF_RUNTIME_PROGRESS_FREQUENCY to 10
93984>>>>>        // Remove all indices to speed up copying of data:
93984>>>>>        Call_Driver hToTable sDriverID Function CLI_DROPINDICES Callback Self Passing sEmpty sEmpty iVoid Result iRetval
93989>>>>>        If (iRetval <> 0) Begin
93991>>>>>            Error DFERR_PROGRAM ("Failed dropping indices for table:" * sRootName)
93992>>>>>>
93992>>>>>            Function_Return False
93993>>>>>        End
93993>>>>>>
93993>>>>>        
93993>>>>>        Move (sRootName + ".err") to sErrorFile  
93994>>>>>        Move 0 to iIndex           
93995>>>>>        Move False to Err   
93996>>>>>        
93996>>>>>        // Copy data: 
93996>>>>>        // This doesn't work properly any more under DF 19!
93996>>>>>//        If (sDriverID = MSSQLDRV_ID) Begin
93996>>>>>//            Call_Driver hToTable sDriverID Function CLI_BCP Callback Self Passing iIndex sErrorFile hFromTable Result iRetval
93996>>>>>//        End
93996>>>>>//        Else Begin
93996>>>>>            Copy_Records hFromTable to hToTable using 0 Callback Self
93999>>>>>//        End
93999>>>>>                  
93999>>>>>        If (Err = False) Begin             
94001>>>>>            Get psHome of (phoWorkspace(ghoApplication)) to sPath  
94002>>>>>            Get vDeleteFile (sPath + sErrorFile) to iRetval
94003>>>>>        End                                                          
94003>>>>>>
94003>>>>>        
94003>>>>>        // Recreate indices:
94003>>>>>        Call_Driver hToTable sDriverID Function CLI_CREATEINDICES Callback Self Passing sEmpty sEmpty iVoid Result iRetval
94008>>>>>        // ToDo: For some reason the iRetval sometimes indicates that the process was _not_ successful, while
94008>>>>>        //       in fact it all worked just fine! Therefore we do _not_ trigger an error here. TO BE INVESTIGATED FURTHER!
94008>>>>>        //        If (iRetval <> 0) Begin
94008>>>>>        //            Error DFERR_PROGRAM ("Could not create indices for the newly converted SQL table:" * sRootName)
94008>>>>>        //        End                                                                                                
94008>>>>>        
94008>>>>>        Close hToTable
94009>>>>>        Set_Attribute DF_RUNTIME_PROGRESS_FREQUENCY to iOrgFreq
94012>>>>>        
94012>>>>>        If (bOK = True) Begin
94014>>>>>            Move (not(Err)) to bOK
94015>>>>>        End
94015>>>>>>
94015>>>>>        
94015>>>>>        If (ghoStatusPanel <> 0) Begin
94017>>>>>            Set Message_Text of ghoStatusPanel to ""
94018>>>>>            Set Action_Text  of ghoStatusPanel to ""
94019>>>>>        End
94019>>>>>>
94019>>>>>        
94019>>>>>        Function_Return (bOK = True)
94020>>>>>    End_Function 
