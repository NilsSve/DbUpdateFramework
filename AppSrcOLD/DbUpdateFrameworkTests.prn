96825>>>>>    // connection ID will be returned.
96825>>>>>//    Function ConnectionID String sDriverID Returns String
96825>>>>>//        String sID
96825>>>>>//        Integer iDriver iNumConn iCount
96825>>>>>//        Handle hoCLI
96825>>>>>//
96825>>>>>//        Get psConnectionID to sID
96825>>>>>//        Function_Return sID
96825>>>>>//    End_Function
