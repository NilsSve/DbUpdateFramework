83018>>>>>>>/// @Example
83018>>>>>>>/// open Customer
83018>>>>>>>/// Handle hFile
83018>>>>>>>/// Integer bLocked
83018>>>>>>>///
83018>>>>>>>/// Move Customer.File_Number to hFile
83018>>>>>>>///
83018>>>>>>>/// Get_Attribute DF_FILE_LOCK_RECORD_STATUS of hFile to bLocked
83018>>>>>>>Define DF_FILE_LOCK_RECORD_STATUS                   For 632
