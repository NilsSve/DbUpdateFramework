89766>>>>>>>>>>Function ParseKeyWord String sConnect String sKeyWord Returns String
89768>>>>>>>>>>    Integer iStart iEnd
89768>>>>>>>>>>    String sRetval
89768>>>>>>>>>>
89768>>>>>>>>>>    Move (Trim(sConnect)) to sConnect
89769>>>>>>>>>>    Move (Pos(Uppercase(sKeyWord), Uppercase(sConnect)))  to iStart
89770>>>>>>>>>>    If (iStart = 0) Begin
89772>>>>>>>>>>        Function_Return ""
89773>>>>>>>>>>    End
89773>>>>>>>>>>>
89773>>>>>>>>>>    Move (Left(sConnect, (iStart -1 + Length(sKeyWord)))) to sRetval
89774>>>>>>>>>>    Move (Replace(sRetval, sConnect, "")) to sRetval 
89775>>>>>>>>>>    If (sKeyWord = Uppercase(CS_SQLConnectionIDText)) Begin
89777>>>>>>>>>>        Move (Pos(",", sRetval))          to iEnd
89778>>>>>>>>>>    End
89778>>>>>>>>>>>
89778>>>>>>>>>>    Else Begin
89779>>>>>>>>>>        Move (Pos(";", sRetval))          to iEnd
89780>>>>>>>>>>    End                                          
89780>>>>>>>>>>>
89780>>>>>>>>>>    If (iEnd = 0 and (sRetval contains ",")) Begin
89782>>>>>>>>>>        Move (Pos(",", sRetval))          to iEnd 
89783>>>>>>>>>>        Decrement iEnd
89784>>>>>>>>>>    End
89784>>>>>>>>>>>
89784>>>>>>>>>>    If (iEnd <> 0) Begin
89786>>>>>>>>>>        Move (Left(sRetval, (iEnd -1)))   to sRetval
89787>>>>>>>>>>    End
89787>>>>>>>>>>>
89787>>>>>>>>>>    Move (Replace("=", sRetval, ""))      to sRetval
89788>>>>>>>>>>
89788>>>>>>>>>>    Function_Return (Trim(sRetval))
89789>>>>>>>>>>End_Function
