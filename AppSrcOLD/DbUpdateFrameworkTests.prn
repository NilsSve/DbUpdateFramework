94398>>>>>    // *** Field/Column Level Functions: ***
94398>>>>>    //
94398>>>>>    // Adds a column name to the passed table number.
94398>>>>>    // Note: Types must be the standard DF_ASCII, DF_DATE etcetera and _cannot_ be any of the SQL_xxx types.
94398>>>>>    Function ApiColumnAdd Handle hTable String sFieldName Integer iType Integer iLength Integer iPrecision Returns Boolean
94400>>>>>        Integer iColumn iCount iFile
94400>>>>>        Boolean bExists bOK  
94400>>>>>        String sDdSrcPath sTableName
94400>>>>>    
94400>>>>>        Get UtilColumnExists hTable sFieldName to bExists
94401>>>>>        If (bExists = True) Begin
94403>>>>>            Function_Return False
94404>>>>>        End  
94404>>>>>>
94404>>>>>        If (iPrecision > 0) Begin
94406>>>>>            Move (iLength + iPrecision) to iLength
94407>>>>>        End
94407>>>>>>
94407>>>>>        
94407>>>>>        Get AutoConnectionIDLogin to bOK
94408>>>>>        Move False to Err   
94409>>>>>        // Structure_start will change the value of hTable...
94409>>>>>        Move hTable to iFile
94410>>>>>        Open iFile Mode DF_EXCLUSIVE
94412>>>>>        
94412>>>>>        Structure_Start iFile
94413>>>>>            Move 0 to iColumn
94414>>>>>            Create_Field hTable At iColumn
94415>>>>>            Set_Attribute DF_FIELD_NAME      of iFile iColumn to sFieldName
94418>>>>>            Set_Attribute DF_FIELD_TYPE      of iFile iColumn to iType
94421>>>>>            Set_Attribute DF_FIELD_LENGTH    of iFile iColumn to iLength
94424>>>>>            Set_Attribute DF_FIELD_PRECISION of iFile iColumn to iPrecision
94427>>>>>        Structure_End iFile
94429>>>>>        
94429>>>>>        // If in development environment; create .fd file:
94429>>>>>        Open hTable
94431>>>>>        Get psDdSrcPath of (phoWorkspace(ghoApplication)) to sDDSrcPath
94432>>>>>        Get CountOfPaths of (phoWorkspace(ghoApplication)) sDDSrcPath to iCount
94433>>>>>        If (iCount > 1) Begin
94435>>>>>            Get PathAtIndex of (phoWorkspace(ghoApplication)) sDDSrcPath 1 to sDDSrcPath    
94436>>>>>        End 
94436>>>>>>
94436>>>>>        Get vFolderExists sDDSrcPath to bExists
94437>>>>>        If (bExists = True) Begin                                   
94439>>>>>            Get vFolderFormat sDDSrcPath to sDDSrcPath 
94440>>>>>            Get_Attribute DF_FILE_ROOT_NAME of hTable to sTableName
94443>>>>>            Get _TableNameOnly sTableName to sTableName 
94444>>>>>            Output_Aux_File DF_AUX_FILE_FD for hTable to (sDDSrcPath + sTableName + ".fd")
94446>>>>>        End
94446>>>>>>
94446>>>>>        Close hTable
94447>>>>>
94447>>>>>        Function_Return (Err = False)
94448>>>>>    End_Function  
