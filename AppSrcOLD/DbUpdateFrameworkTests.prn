86458>>>>>>>>>>>
86458>>>>>>>>>>>  // Courtesy Of Steve Walter
86458>>>>>>>>>>>  // Requires Windows 2000 and up according to msdn but it was
86458>>>>>>>>>>>  //  in fact available before that as an unpublished API call
86458>>>>>>>>>>>  //  a little google search shows that this was already available
86458>>>>>>>>>>>  //  in windows 95 and NT
86458>>>>>>>>>>>  //
86458>>>>>>>>>>>  // The format is controlled by the dialog interface.
86458>>>>>>>>>>>  // That is, the user must click the OK button To actually Begin the format
86458>>>>>>>>>>>  // the format cannot be started programmatically.
86458>>>>>>>>>>>  // An alternative to this functionality would be to use a controlpanel
86458>>>>>>>>>>>  //  http://www.vdf-guidance.com/ContribPage.asp?Page=PKGCLSDFCPLAPP&ContribRecId=93
86458>>>>>>>>>>>  //
86458>>>>>>>>>>>  // hWnd = The windows handle of the object from which the format Function
86458>>>>>>>>>>>  //        is called.
86458>>>>>>>>>>>  // To Get this,
86458>>>>>>>>>>>  //          use:  Get Window_Handle Of <object>
86458>>>>>>>>>>>  //          For instance, in this app, we're going to use the Report_Panel:
86458>>>>>>>>>>>  //                  Get Window_Handle Of (Report_Panel(Main(Self))) To hWind
86458>>>>>>>>>>>  //
86458>>>>>>>>>>>  // sDrive = The drive letter. At this moment only A and B are valid
86458>>>>>>>>>>>  //
86458>>>>>>>>>>>  // iOptions = Format options.
86458>>>>>>>>>>>  //  SHFMT_OPT_DEFAULT = Quick format
86458>>>>>>>>>>>  //  SHFMT_OPT_FULL    = Full Format
86458>>>>>>>>>>>  //  SHFMT_OPT_SYSONLY = System only
86458>>>>>>>>>>>  //  3                 = Full format with system. (unsupported)
86458>>>>>>>>>>>  //
86458>>>>>>>>>>>  // Return Values:
86458>>>>>>>>>>>  //  SHFMT_ERROR    = Error on format or no drive specified.
86458>>>>>>>>>>>  //  SHFMT_CANCEL   = Format cancelled by user.
86458>>>>>>>>>>>  //  SHFMT_NOFORMAT = Drive is not formatable.
86458>>>>>>>>>>>  //
86458>>>>>>>>>>>  //
86458>>>>>>>>>>>  // *** ATTENTION: This function has been disabled as it doesn't
86458>>>>>>>>>>>  //                seem to work, i must have made a silly mistake
86458>>>>>>>>>>>  //                somewhere.
86458>>>>>>>>>>>  //
86458>>>>>>>>>>>  Function sfoFormatDisk String sDrive Integer iOptions Returns DWORD
86460>>>>>>>>>>>    Handle   hWnd
86460>>>>>>>>>>>    Integer  iObj
86460>>>>>>>>>>>    DWORD    dwReturnVal
86460>>>>>>>>>>>    Integer iDrive
86460>>>>>>>>>>>
86460>>>>>>>>>>>    Function_Return (1) // STOP HERE
86461>>>>>>>>>>>    
86461>>>>>>>>>>>    Move (Trim(sDrive)) To sDrive
86462>>>>>>>>>>>    If ( sDrive <> '' ) Begin
86464>>>>>>>>>>>      If ( sDrive Contains ':' ) Move (Replace(':',sDrive,'')) To sDrive
86467>>>>>>>>>>>      If (Not( 'AB' Contains sDrive )) Function_Return (SHFMT_NOFORMAT)
86470>>>>>>>>>>>      If ( sDrive = 'A' ) Move 0 To iDrive
86473>>>>>>>>>>>      Else If ( sDrive = 'B' ) Move 1 To iDrive
86477>>>>>>>>>>>      // Window_Handle Of Desktop equals to 0
86477>>>>>>>>>>>      
86477>>>>>>>>>>>      Get focus Of desktop To iObj
86478>>>>>>>>>>>      If (iObj>desktop) ;          Get Container_Handle Of iObj To hWnd
86481>>>>>>>>>>>      While (hWnd=0 And iObj<>Desktop)
86485>>>>>>>>>>>          Get Parent Of iObj To iObj
86486>>>>>>>>>>>          Get Container_Handle Of iObj To hWnd
86487>>>>>>>>>>>      End
86488>>>>>>>>>>>>
86488>>>>>>>>>>>                      
86488>>>>>>>>>>>      //Showln "hWnd = " hWnd " iDrive " iDrive " iOptions " iOptions
86488>>>>>>>>>>>      Move (vWin32_ShFormatDrive(hWnd, iDrive, SHFMT_ID_DEFAULT, iOptions)) To dwReturnVal
86489>>>>>>>>>>>    End
86489>>>>>>>>>>>>
86489>>>>>>>>>>>    Else Begin
86490>>>>>>>>>>>      Move (SHFMT_ERROR) To dwReturnVal
86491>>>>>>>>>>>    End
86491>>>>>>>>>>>>
86491>>>>>>>>>>>    Function_Return dwReturnVal
86492>>>>>>>>>>>  End_Function // sfoFormatDisk
86493>>>>>>>>>>> 
86493>>>>>>>>>>>  //Example:
86493>>>>>>>>>>>  // Get sfoFormatDisk 'A' 0 To dReturnVal    // Formats drive A in QuickFormat
86493>>>>>>>>>>>  //                                          mode.
86493>>>>>>>>>>>  
86493>>>>>>>>>>>End_Class // cShellFileOperations
86494>>>>>>>>>>>
86494>>>>>>>>>>>
86494>>>>>>>>>>>Object oShellFileOperations Is a cShellFileOperations
86496>>>>>>>>>>>End_Object // oShellFileOperations
