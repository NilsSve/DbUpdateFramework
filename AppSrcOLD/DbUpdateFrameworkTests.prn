90859>>>>>>>                Get ParseKeyWord sConnectionString (CS_SQLIniTrustedKeyword + "=")  to sValue
90860>>>>>>>                Move (If(Uppercase(sValue) = "YES", True, False))                   to bTrusted
90861>>>>>>>                If (bTrusted = False) Begin
90863>>>>>>>                    Get ParseKeyWord sConnectionString (CS_SQLIniUIDKeyword + "=")  to sUserID
90864>>>>>>>                    Get ParseKeyWord sConnectionString (CS_SQLIniPWDKeyword + "=")  to sPassword
90865>>>>>>>                End
90865>>>>>>>>
90865>>>>>>>                Case Break
90866>>>>>>>                                     
90866>>>>>>>            Case (sDriverID = ORAFLEX)
90869>>>>>>>                Get ParseKeyWord sConnectionString (CS_SQLIniDSNKeyword + "=")      to sServer
90870>>>>>>>                Get ParseKeyWord sConnectionString (CS_SQLIniDatabaseKeyword + "=") to sDatabase
90871>>>>>>>                If (sDatabase <> "" and (not(sServer contains "/"))) Begin
90873>>>>>>>                    Move (sServer + "/" + sDatabase)                                to sServer
90874>>>>>>>                End
90874>>>>>>>>
90874>>>>>>>                Get ParseKeyWord sConnectionString (CS_SQLIniUIDKeyword + "=")      to sUserID
90875>>>>>>>                Get ParseKeyWord sConnectionString (CS_SQLIniPWDKeyword + "=")      to sPassword
90876>>>>>>>                Case Break
90877>>>>>>>            
90877>>>>>>>            Case (sDriverID = MDSPgSQL)
90880>>>>>>>                Get ParseKeyWord sConnectionString (CS_SQLIniDSNKeyword + "=")      to sServer
90881>>>>>>>                Get ParseKeyWord sConnectionString (CS_SQLIniDatabaseKeyword + "=") to sDatabase
90882>>>>>>>                Get ParseKeyWord sConnectionString (CS_SQLIniUIDKeyword + "=")      to sUserID
90883>>>>>>>                Get ParseKeyWord sConnectionString (CS_SQLIniPWDKeyword + "=")      to sPassword
