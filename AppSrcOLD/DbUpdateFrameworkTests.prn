85852>>>>>>>>>>>Class cCryptographer is a cObject
85853>>>>>>>>>>>    
85853>>>>>>>>>>>    // Procedure : Construct_Object
85853>>>>>>>>>>>    // Purpose   : Object constructor
85853>>>>>>>>>>>    Procedure Construct_Object
85855>>>>>>>>>>>        Forward Send Construct_Object
85857>>>>>>>>>>>
85857>>>>>>>>>>>        Property String     psProvider  MS_ENHANCED_PROV
85858>>>>>>>>>>>        Property Integer    piProvider  PROV_RSA_FULL
85859>>>>>>>>>>>        Property Integer    piCipher    CALG_RC4
85860>>>>>>>>>>>        Property Integer    piHash      CALG_MD5
85861>>>>>>>>>>>        
85861>>>>>>>>>>>        // Private properties
85861>>>>>>>>>>>        Property Handle     Private_phProv
85862>>>>>>>>>>>    End_Procedure
85863>>>>>>>>>>>    
85863>>>>>>>>>>>    
85863>>>>>>>>>>>    // Function : AcquireContext
85863>>>>>>>>>>>    // Purpose  : Acquire key container handle
85863>>>>>>>>>>>    Function AcquireContext Returns Handle
85865>>>>>>>>>>>        Integer iProvider
85865>>>>>>>>>>>        String sProvider
85865>>>>>>>>>>>        Handle hProv
85865>>>>>>>>>>>        Boolean bOk
85865>>>>>>>>>>>        Address addrProv
85865>>>>>>>>>>>        
85865>>>>>>>>>>>        Move 0 to hProv
85866>>>>>>>>>>>        Get piProvider to iProvider
85867>>>>>>>>>>>        Get psProvider to sProvider
85868>>>>>>>>>>>        
85868>>>>>>>>>>>        //  Determine address to be passed as provider
85868>>>>>>>>>>>        If (Trim(sProvider) <> "") Begin
85870>>>>>>>>>>>            Move (AddressOf(sProvider)) to addrProv
85871>>>>>>>>>>>        End
85871>>>>>>>>>>>>
85871>>>>>>>>>>>        Else Begin
85872>>>>>>>>>>>            Move 0 to addrProv
85873>>>>>>>>>>>        End
85873>>>>>>>>>>>>
85873>>>>>>>>>>>        
85873>>>>>>>>>>>        //  Acquire Crypto Context
85873>>>>>>>>>>>        Move (CryptAcquireContext(AddressOf(hProv),0,addrProv,iProvider,CRYPT_VERIFYCONTEXT)) to bOk
85874>>>>>>>>>>>        If (not(bOk) or hProv = 0) Begin
85876>>>>>>>>>>>            Move (CryptAcquireContext(AddressOf(hProv),0,addrProv,iProvider,CRYPT_NEWKEYSET ior CRYPT_VERIFYCONTEXT)) to bOk
85877>>>>>>>>>>>        End
85877>>>>>>>>>>>>
85877>>>>>>>>>>>        
85877>>>>>>>>>>>        If (not(bOk) or hProv = 0) Begin
85879>>>>>>>>>>>            // Fallback to original
85879>>>>>>>>>>>            Move (CryptAcquireContext(AddressOf(hProv),0,addrProv,iProvider,0)) to bOk
85880>>>>>>>>>>>            
85880>>>>>>>>>>>            If (not(bOk) or hProv = 0) Begin
85882>>>>>>>>>>>                Move (CryptAcquireContext(AddressOf(hProv),0,addrProv,iProvider,CRYPT_NEWKEYSET)) to bOk
85883>>>>>>>>>>>            End
85883>>>>>>>>>>>>
85883>>>>>>>>>>>        End
85883>>>>>>>>>>>>
85883>>>>>>>>>>>        Set Private_phProv to hProv
85884>>>>>>>>>>>        
85884>>>>>>>>>>>        Function_Return hProv
85885>>>>>>>>>>>    End_Function
85886>>>>>>>>>>>    
85886>>>>>>>>>>>    // Function : ReleaseContext
85886>>>>>>>>>>>    // Purpose  : Releases key container handle
85886>>>>>>>>>>>    Function ReleaseContext Handle hProv Returns Boolean
85888>>>>>>>>>>>        Function_Return (CryptReleaseContext(hProv,0))
85889>>>>>>>>>>>    End_Function
85890>>>>>>>>>>>    
85890>>>>>>>>>>>    // Function : CreateHash
85890>>>>>>>>>>>    // Purpose  : Creates hash object
85890>>>>>>>>>>>    Function CreateHash Handle hProv Returns Handle
85892>>>>>>>>>>>        Integer iAlgorithm
85892>>>>>>>>>>>        Handle hHash
85892>>>>>>>>>>>        Boolean bOk
85892>>>>>>>>>>>        
85892>>>>>>>>>>>        Move 0 to hHash
85893>>>>>>>>>>>        Get piHash to iAlgorithm
85894>>>>>>>>>>>        Move (CryptCreateHash(hProv,iAlgorithm,0,0,AddressOf(hHash))) to bOk
85895>>>>>>>>>>>        
85895>>>>>>>>>>>        Function_Return hHash
85896>>>>>>>>>>>    End_Function
85897>>>>>>>>>>>    
85897>>>>>>>>>>>    // Function : DestroyHash
85897>>>>>>>>>>>    // Purpose  : Destroys the hash object
85897>>>>>>>>>>>    Function DestroyHash Handle hHash Returns Boolean
85899>>>>>>>>>>>        Function_Return (CryptDestroyHash(hHash))
85900>>>>>>>>>>>    End_Function
85901>>>>>>>>>>>    
85901>>>>>>>>>>>    // Function : HashData
85901>>>>>>>>>>>    // Purpose  : Adds data to hash object
85901>>>>>>>>>>>    Function HashData Handle hHash String sData Returns Boolean
85903>>>>>>>>>>>        Function_Return (CryptHashData(hHash,AddressOf(sData),Length(sData),0))
85904>>>>>>>>>>>    End_Function
85905>>>>>>>>>>>    
85905>>>>>>>>>>>    // Function : DeriveKey
85905>>>>>>>>>>>    // Purpose  : Generates session key
85905>>>>>>>>>>>    Function DeriveKey Handle hProv Handle hHash Returns Handle
85907>>>>>>>>>>>        Integer iAlgorithm
85907>>>>>>>>>>>        Handle hKey
85907>>>>>>>>>>>        Boolean bOk
85907>>>>>>>>>>>        
85907>>>>>>>>>>>        Move 0 to hKey
85908>>>>>>>>>>>        Get piCipher to iAlgorithm
85909>>>>>>>>>>>        Move (CryptDeriveKey(hProv,iAlgorithm,hHash,CRYPT_EXPORTABLE,AddressOf(hKey))) to bOk
85910>>>>>>>>>>>        
85910>>>>>>>>>>>        Function_Return hKey
85911>>>>>>>>>>>    End_Function
85912>>>>>>>>>>>    
85912>>>>>>>>>>>    // Function : ImportPlainTextKey
85912>>>>>>>>>>>    // Purpose  : Imports a plain text key
85912>>>>>>>>>>>    Function ImportPlainTextKey Handle hProv UChar[] ucaKey Returns Handle
85914>>>>>>>>>>>        tPLAINTEXTKEYBLOB blobhead
85914>>>>>>>>>>>        tPLAINTEXTKEYBLOB blobhead
85914>>>>>>>>>>>        Boolean   bSuccess
85914>>>>>>>>>>>        Handle    hKey
85914>>>>>>>>>>>        Integer   iHeadSize iKeySize
85914>>>>>>>>>>>        UChar[]   ucaKeyblob
85915>>>>>>>>>>>        Void_Type void
85915>>>>>>>>>>>    
85915>>>>>>>>>>>        Move (SizeOfType(tPLAINTEXTKEYBLOB)) to iHeadSize
85916>>>>>>>>>>>        Move (SizeOfArray(ucaKey)) to iKeySize
85917>>>>>>>>>>>    
85917>>>>>>>>>>>        Move PLAINTEXTKEYBLOB to blobhead.hdr.bType
85918>>>>>>>>>>>        Move CUR_BLOB_VERSION   to blobhead.hdr.bVersion
85919>>>>>>>>>>>        Get piCipher            to blobhead.hdr.aiKeyAlg
85920>>>>>>>>>>>        Move iKeySize           to blobhead.dwKeySize
85921>>>>>>>>>>>    
85921>>>>>>>>>>>        Move (ResizeArray(ucaKeyblob, iHeadSize)) to ucaKeyblob
85922>>>>>>>>>>>        Move (CopyMemory(AddressOf(ucaKeyblob), AddressOf(blobhead), iHeadSize)) to void
85923>>>>>>>>>>>        Move (AppendArray(ucaKeyblob, ucaKey)) to ucaKeyblob
85924>>>>>>>>>>>    
85924>>>>>>>>>>>        Move 0 to hKey
85925>>>>>>>>>>>        Move (CryptImportKey(hProv, AddressOf(ucaKeyblob), SizeOfArray(ucaKeyblob), 0, 0, AddressOf(hKey))) to bSuccess
85926>>>>>>>>>>>        If (not(bSuccess)) Begin 
85928>>>>>>>>>>>            Move (ShowLastError()) to void
85929>>>>>>>>>>>        End
85929>>>>>>>>>>>>
85929>>>>>>>>>>>    
85929>>>>>>>>>>>        Function_Return hKey
85930>>>>>>>>>>>    End_Function
85931>>>>>>>>>>>
85931>>>>>>>>>>>    // Function : DestroyKey
85931>>>>>>>>>>>    // Purpose  : Destroys the key
85931>>>>>>>>>>>    Function DestroyKey Handle hKey Returns Boolean
85933>>>>>>>>>>>        Function_Return (CryptDestroyKey(hKey))
85934>>>>>>>>>>>    End_Function
85935>>>>>>>>>>>    
85935>>>>>>>>>>>    // Function : KeyParameter
85935>>>>>>>>>>>    // Purpose  : Retrieves key data
85935>>>>>>>>>>>    Function KeyParameter Handle hKey Integer iQuery Returns Integer
85937>>>>>>>>>>>        Integer iBuffer iLen
85937>>>>>>>>>>>        Boolean bOk
85937>>>>>>>>>>>        
85937>>>>>>>>>>>        Move (SizeOfType(Integer)) to iLen
85938>>>>>>>>>>>        Move (CryptGetKeyParam(hKey,iQuery,AddressOf(iBuffer),AddressOf(iLen),0)) to bOk
85939>>>>>>>>>>>        Function_Return iBuffer
85940>>>>>>>>>>>    End_Function
85941>>>>>>>>>>>    
85941>>>>>>>>>>>    // Function : HashValue
85941>>>>>>>>>>>    // Purpose  : Retrieves a hash value
85941>>>>>>>>>>>    Function HashValue Handle lhHash Returns String
85943>>>>>>>>>>>        Pointer lpSize
85943>>>>>>>>>>>        Pointer lpHash
85943>>>>>>>>>>>        String  lsSize
85943>>>>>>>>>>>        String  lsHash
85943>>>>>>>>>>>        Integer liResult
85943>>>>>>>>>>>
85943>>>>>>>>>>>        Move (Repeat(Character(0),4)) to lsSize
85944>>>>>>>>>>>        GetAddress of lsSize to lpSize
85945>>>>>>>>>>>
85945>>>>>>>>>>>        Move (CryptGetHashParam(lhHash,HP_HASHVAL,0,lpSize,0)) to liResult
85946>>>>>>>>>>>        If (liResult = 0) Function_Return ""
85949>>>>>>>>>>>
85949>>>>>>>>>>>        Move (Repeat(Character(0),BytesTodWord(lsSize,1))) to lsHash
85950>>>>>>>>>>>        GetAddress of lsHash to lpHash
85951>>>>>>>>>>>
85951>>>>>>>>>>>        Move (CryptGetHashParam(lhHash,HP_HASHVAL,lpHash,lpSize,0)) to liResult
85952>>>>>>>>>>>        If (liResult = 0) Function_Return ""
85955>>>>>>>>>>>
85955>>>>>>>>>>>        Function_Return lsHash
85956>>>>>>>>>>>    End_Function  // HashValue
85957>>>>>>>>>>>    
85957>>>>>>>>>>>            
85957>>>>>>>>>>>    // Function : Encrypt
85957>>>>>>>>>>>    // Purpose  : Encrypts data
85957>>>>>>>>>>>    Function Encrypt String sPassword String sData Returns String
85959>>>>>>>>>>>        Handle hProv hHash hKey
85959>>>>>>>>>>>        Integer iAlgorithm iDataLen iCipherLen iErr
85959>>>>>>>>>>>        Boolean bOk
85959>>>>>>>>>>>        
85959>>>>>>>>>>>        Get AcquireContext to hProv
85960>>>>>>>>>>>        If (hProv) Begin
85962>>>>>>>>>>>            Get CreateHash hProv to hHash
85963>>>>>>>>>>>            If (hHash) Begin
85965>>>>>>>>>>>                Get HashData hHash sPassword to bOk
85966>>>>>>>>>>>                If (bOk) Begin
85968>>>>>>>>>>>                    Get piCipher to iAlgorithm
85969>>>>>>>>>>>                    Get DeriveKey hProv hHash to hKey
85970>>>>>>>>>>>                End // If (bOk) Begin            
85970>>>>>>>>>>>>
85970>>>>>>>>>>>                Get DestroyHash hHash to bOk
85971>>>>>>>>>>>            End // If (hHash) Begin
85971>>>>>>>>>>>>
85971>>>>>>>>>>>            
85971>>>>>>>>>>>            If (hKey) Begin
85973>>>>>>>>>>>                //  First call to determine resulting data size
85973>>>>>>>>>>>                Move (Length(sData)) to iDataLen
85974>>>>>>>>>>>                Move (Length(sData)) to iCipherLen
85975>>>>>>>>>>>                Move (CryptEncrypt(hKey, 0, True, 0, 0, AddressOf(iCipherLen), iDataLen)) to bOk
85976>>>>>>>>>>>                
85976>>>>>>>>>>>                //  Reserve space in string
85976>>>>>>>>>>>                If (iDataLen < iCipherLen) Begin
85978>>>>>>>>>>>                    Move (sData + Repeat(" ", iCipherLen - iDataLen)) to sData
85979>>>>>>>>>>>                End
85979>>>>>>>>>>>>
85979>>>>>>>>>>>                
85979>>>>>>>>>>>                //  Call to really decrypt
85979>>>>>>>>>>>                Move (CryptEncrypt(hKey,0,True,0,AddressOf(sData),AddressOf(iDataLen),Length(sData))) to bOk
85980>>>>>>>>>>>                //If (not(bOk)) Begin
85980>>>>>>>>>>>                    //Move "" to sData
85980>>>>>>>>>>>                    //Move (GetLastError()) to iErr
85980>>>>>>>>>>>                //End
85980>>>>>>>>>>>                
85980>>>>>>>>>>>                Get DestroyKey hKey to bOk
85981>>>>>>>>>>>            End // If (hKey) Begin
85981>>>>>>>>>>>>
85981>>>>>>>>>>>            Get ReleaseContext hProv to bOk
85982>>>>>>>>>>>        End // If (hProv) Begin
85982>>>>>>>>>>>>
85982>>>>>>>>>>>        Function_Return sData
85983>>>>>>>>>>>    End_Function
85984>>>>>>>>>>>    
85984>>>>>>>>>>>    // Function : Decrypt
85984>>>>>>>>>>>    // Purpose  : Decrypts data
85984>>>>>>>>>>>    Function Decrypt String sPassword String sData Returns String
85986>>>>>>>>>>>        Handle hProv hHash hKey
85986>>>>>>>>>>>        Integer iAlgorithm iDataLen
85986>>>>>>>>>>>        Boolean bOk
85986>>>>>>>>>>>        
85986>>>>>>>>>>>        Get AcquireContext to hProv
85987>>>>>>>>>>>        If (hProv) Begin
85989>>>>>>>>>>>            Get CreateHash hProv to hHash
85990>>>>>>>>>>>            If (hHash) Begin
85992>>>>>>>>>>>                Get HashData hHash sPassword to bOk
85993>>>>>>>>>>>                If (bOk) Begin
85995>>>>>>>>>>>                    Get piCipher to iAlgorithm
85996>>>>>>>>>>>                    Get DeriveKey hProv hHash to hKey
85997>>>>>>>>>>>                End // If (bOk) Begin            
85997>>>>>>>>>>>>
85997>>>>>>>>>>>                Get DestroyHash hHash to bOk
85998>>>>>>>>>>>            End // If (hHash) Begin
85998>>>>>>>>>>>>
85998>>>>>>>>>>>            
85998>>>>>>>>>>>            If (hKey) Begin
86000>>>>>>>>>>>                Move (Length(sData)) to iDataLen
86001>>>>>>>>>>>                Move (CryptDecrypt(hKey,0,True,0,AddressOf(sData),AddressOf(iDataLen))) to bOk
86002>>>>>>>>>>>                //If (bOk = False) Move "" to sData
86002>>>>>>>>>>>                
86002>>>>>>>>>>>                //  Resulting dat can be shorter as the input string, in that case we shorten the result string
86002>>>>>>>>>>>                If (Length(sData) > iDataLen) Begin
86004>>>>>>>>>>>                    Move (Left(sData, iDataLen)) to sData
86005>>>>>>>>>>>                End
86005>>>>>>>>>>>>
86005>>>>>>>>>>>                
86005>>>>>>>>>>>                Get DestroyKey hKey to bOk
86006>>>>>>>>>>>            End // If (hKey) Begin
86006>>>>>>>>>>>>
86006>>>>>>>>>>>            Get ReleaseContext hProv to bOk
86007>>>>>>>>>>>        End // If (hProv) Begin
86007>>>>>>>>>>>>
86007>>>>>>>>>>>        Function_Return sData
86008>>>>>>>>>>>    End_Function
86009>>>>>>>>>>>    
86009>>>>>>>>>>>    //  Function : GenerateRandom
86009>>>>>>>>>>>    //  Purpose  : Generates random data.
86009>>>>>>>>>>>    Function GenerateRandom Integer iBytes Returns UChar[]
86011>>>>>>>>>>>        Handle hProv
86011>>>>>>>>>>>        UChar[] uaResult
86012>>>>>>>>>>>        Boolean bRes
86012>>>>>>>>>>>        
86012>>>>>>>>>>>        Get AcquireContext to hProv
86013>>>>>>>>>>>        
86013>>>>>>>>>>>        Move (ResizeArray(uaResult, iBytes)) to uaResult
86014>>>>>>>>>>>        Move (CryptGenRandom(hProv, iBytes, AddressOf(uaResult))) to bRes
86015>>>>>>>>>>>        
86015>>>>>>>>>>>        Get ReleaseContext hProv to bRes
86016>>>>>>>>>>>        
86016>>>>>>>>>>>        Function_Return uaResult
86017>>>>>>>>>>>    End_Function
86018>>>>>>>>>>>    
86018>>>>>>>>>>>    //  Function : GenerateRandomString
86018>>>>>>>>>>>    //  Purpose  : Generates random data and does a base64 encoding to properly present it as a string.
86018>>>>>>>>>>>    Function GenerateRandomString Integer iLenght Returns String
86020>>>>>>>>>>>        String sResult
86020>>>>>>>>>>>        UChar[] aData
86021>>>>>>>>>>>        Address pBase64
86021>>>>>>>>>>>        Integer iVoid
86021>>>>>>>>>>>
86021>>>>>>>>>>>        Get GenerateRandom iLenght to aData
86022>>>>>>>>>>>        
86022>>>>>>>>>>>        Move (Base64Encode(AddressOf(aData), iLenght)) to pBase64
86023>>>>>>>>>>>        Move pBase64 to sResult
86024>>>>>>>>>>>        Move (Free(pBase64)) to iVoid    
86025>>>>>>>>>>>        
86025>>>>>>>>>>>        Function_Return (Left(sResult, iLenght))
86026>>>>>>>>>>>    End_Function
86027>>>>>>>>>>>
86027>>>>>>>>>>>End_Class
