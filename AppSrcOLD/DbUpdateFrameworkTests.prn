83018>>>>>>>    String MertechInc_DriverName       //Replaces _DRIVERNAME#
83018>>>>>>>    String MertechInc_sArg1 255        //Replaces _ARG1#
83018>>>>>>>    String MertechInc_sArg2 255        //Replaces _ARG2#
83018>>>>>>>    String MertechInc_sWork 255        //General work string
83018>>>>>>>
83018>>>>>>>    String MertechInc_CurrentDriver    //Keep the current driver name
83018>>>>>>>    //Global string are created pre-filled with spaces. We need an empty string
83018>>>>>>>    Move "" to MertechInc_Blank
83019>>>>>>>    Move "" to MertechInc_CurrentDriver
