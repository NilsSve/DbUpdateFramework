81219>>>                 Procedure ShowDDOConstraints Handle hoDD
81222>>>                    Integer i j iMain iCurrentDDFile
81222>>>                    tConstraintDef[] Constraints
81222>>>                    tConstraintDef[] Constraints
81223>>>                    String sFilter 
81223>>>                    Handle hoDDOther
81223>>>                    
81223>>>                    Get Main_File of hoDD to iMain
81224>>>                    Get DDOConstraints of  hoDD to Constraints
81225>>>                    
81225>>>                    Send Insert "Current DDO Constraints"
81226>>>                    Send Insert CR_LF
81227>>>                    Send Insert ("  Number of Constraints = " + String(SizeOfArray(Constraints)))
81228>>>                    Send Insert CR_LF
81229>>>
81229>>>                    For i from 0 to (SizeOfArray(Constraints)-1)
81235>>>>
81235>>>                        If (iCurrentDDFile<>Constraints[i].iFile) Begin
81237>>>                            Send Insert CR_LF
81238>>>                            Move Constraints[i].iFile to iCurrentDDFile
81239>>>                            If (Constraints[i].iFile<>iMain) Begin
81241>>>                                Get Which_Data_Set of hoDD Constraints[i].iFile to hoDDOther
81242>>>                            End
81242>>>>
81242>>>                            Else Begin
81243>>>                                Move hoDD to hoDDOther
81244>>>                            End
81244>>>>
81244>>>                            Send Insert  ("Constraints from ")
81245>>>                            
81245>>>                            If (hoDDOther) Begin
81247>>>                                Send Insert  (Object_Label(hoDDOther))
81248>>>                            End
81248>>>>
81248>>>                            Else Begin
81249>>>                                // not sure this could ever happen
81249>>>                                Send Insert  ("unknown. No DDO for file "+String(Constraints[i].iFile))
81250>>>                            End
81250>>>>
81250>>>                            
81250>>>                            If (hoDD<>hoDDOther) Begin
81252>>>                                Send Insert " (inherited)"
81253>>>                            End
81253>>>>
81253>>>                            
81253>>>                            Send Insert CR_LF
81254>>>                        End
81254>>>>
81254>>>                        
81254>>>                        
81254>>>                        Send Insert ("  " +String(i+1) + " Type=")
81255>>>                        Case Begin
81255>>>                            Case (Constraints[i].eType=CONST_VALUE) Send Insert "CONST_VALUE"
81258>>>                            Case (Constraints[i].eType=CONST_CHILD) Send Insert "CONST_CHILD"
81262>>>                            Case (Constraints[i].eType=CONST_FIELD) Send Insert "CONST_FIELD"
81266>>>                            Case (Constraints[i].eType=CONST_EXP) Send Insert "CONST_EXP"
81270>>>                            Case (Constraints[i].eType=CONST_RELATES) Send Insert "CONST_RELATES"
81274>>>                        Case End
81274>>>                        
81274>>>                        If (Constraints[i].eType=CONST_VALUE or Constraints[i].eType=CONST_FIELD) Begin
81276>>>                            Send Insert " mode="
81277>>>                            Case Begin
81277>>>                                Case (Constraints[i].eMODE=CONST_LT) Send Insert "LT"
81280>>>                                Case (Constraints[i].eMODE=CONST_LE) Send Insert "LE"
81284>>>                                Case (Constraints[i].eMODE=CONST_EQ) Send Insert "EQ"
81288>>>                                Case (Constraints[i].eMODE=CONST_GE) Send Insert "GE"
81292>>>                                Case (Constraints[i].eMODE=CONST_GT) Send Insert "GT"
81296>>>                                Case (Constraints[i].eMODE=CONST_NE) Send Insert "NE"
81300>>>                                Case (Constraints[i].eMODE=CONST_Matches) Send Insert "matches"
81304>>>                                Case (Constraints[i].eMODE=CONST_Contains) Send Insert "contains"
81308>>>                                Case (Constraints[i].eMODE=CONST_MatchesJumpIn) Send Insert "matches_JumpIn"
81312>>>                            Case End
81312>>>                        End
81312>>>>
81312>>>                        If (Constraints[i].eType<>CONST_EXP) Begin
81314>>>                            Send Insert (" File.Field=" + String(Constraints[i].iFile))
81315>>>                            Send Insert ("."  + String(Constraints[i].iField))
81316>>>                            Send Insert (" (" + FormatFileFieldName(Self,Constraints[i].iFile,Constraints[i].iField)+")")
81317>>>                        End
81317>>>>
81317>>>                        If (Constraints[i].eType=CONST_CHILD or Constraints[i].eType=CONST_FIELD) Begin
81319>>>                            Send Insert (" Other File.Field="  + String(Constraints[i].iOtherFile))
81320>>>                            Send Insert ("."  + String(Constraints[i].iOtherField))
81321>>>                            Send Insert (" (" + FormatFileFieldName(Self,Constraints[i].iOtherFile,Constraints[i].iOtherField)+")")
81322>>>                        End
81322>>>>
81322>>>                        Else If (Constraints[i].eType=CONST_VALUE) Begin
81325>>>                            Send Insert  (" Value=" + String(Constraints[i].sValue))
81326>>>                        End
81326>>>>
81326>>>                        Send Insert CR_LF
81327>>>                    Loop
