83018>>>>>>>/// @Name        DF_FILE_TABLESPACE_NAME
83018>>>>>>>/// @Description A tablespace is a container of segments (objects that have an
83018>>>>>>>/// allotted amount of space), i.e. tables and indexes. This attribute is
83018>>>>>>>/// used to get or set the name of the tablespace being used for the data tables.
83018>>>>>>>/// To set or get the tablespace name for indexes, use the DF_FILE_INDEXTABLESPACE_NAME
83018>>>>>>>/// attribute. Setting the tablespace name can only be done during a Structure_Start
83018>>>>>>>/// (during table creation).  Getting the name, however can be done at
83018>>>>>>>/// anytime.  Note that when setting the tablespace name, it must be set to an
83018>>>>>>>/// already existing tablespace, this attribute does not create the tablespace itself.
83018>>>>>>>/// Even though MYSQL uses tablespaces, this this attribute is only supported
83018>>>>>>>/// in Oracle and PostgreSQL.
83018>>>>>>>///
83018>>>>>>>/// @Assumptions
83018>>>>>>>/// @Status      Public
83018>>>>>>>/// @Drivers     ORAFlex PGFlex
83018>>>>>>>/// @VersionNote Last Revised: 2013-07-25 by Aaron Gulack
83018>>>>>>>/// @See         DF_FILE_INDEXTABLESPACE_NAME
83018>>>>>>>/// @INTOPT
83018>>>>>>>///
83018>>>>>>>/// @Syntax Get_Attribute DF_FILE_TABLESPACE_NAME of {FileNumber} to {variable}
83018>>>>>>>/// @Syntax Set_Attribute DF_FILE_TABLESPACE_NAME of {FileNumber} to {variable}
83018>>>>>>>/// @Param  FileNumber            Number of the file
83018>>>>>>>/// @Param  variable              Name of the Tablespace.
83018>>>>>>>/// @Example
83018>>>>>>>/// Handle hFile
83018>>>>>>>/// move 0 to hFile
83018>>>>>>>/// Structure_Start hFile "ORA_DRV"
83018>>>>>>>///     Set_Attribute DF_FILE_TABLESPACE_NAME      of hFile To "USERS"
83018>>>>>>>///     Set_Attribute DF_FILE_INDEXTABLESPACE_NAME of hFile To "INDXS"
83018>>>>>>>///
83018>>>>>>>///             // More table creation here
83018>>>>>>>///
83018>>>>>>>/// Structure_End hFile DF_STRUCTEND_OPT_NONE "." 0
83018>>>>>>>Define DF_FILE_TABLESPACE_NAME                      For (DF_FILE_RECORD_REREAD+14)
83018>>>>>>>
83018>>>>>>>// TODO: This is probably deprecated. Investigate.
83018>>>>>>>Define DF_FETCH_FIELDNUMBER                         For (DF_FILE_RECORD_REREAD+15)
83018>>>>>>>
83018>>>>>>>//=============================================================================
83018>>>>>>>/// @Name        DF_FILE_INDEXTABLESPACE_NAME
83018>>>>>>>/// @Description This attribute is used to get or set the name of the tablespace
83018>>>>>>>/// being used for the index segment of a database. For a description of tablespaces,
83018>>>>>>>/// see the description above for DF_FILE_TABLESPACE_NAME. Similar to the Tablespace
83018>>>>>>>/// name attribute, setting the index tablespace name can only be done during creation
83018>>>>>>>/// and must use an already existing tablespace as the variable. This attribute is
83018>>>>>>>/// only available for Oracle and Postgre.
83018>>>>>>>///
83018>>>>>>>/// @Assumptions
83018>>>>>>>/// @Status      Public
83018>>>>>>>/// @Drivers     ORAFlex PGFlex
83018>>>>>>>/// @VersionNote Last Revised: 2013-07-25 by Aaron Gulack
83018>>>>>>>/// @See         DF_FILE_TABLESPACE_NAME
83018>>>>>>>/// @INTOPT
83018>>>>>>>///
83018>>>>>>>/// @Syntax Get_Attribute DF_FILE_INDEXTABLESPACE_NAME of {File Number} to {variable}
83018>>>>>>>/// @Syntax Set_Attribute DF_FILE_INDEXTABLESPACE_NAME of {File Number} to {variable}
