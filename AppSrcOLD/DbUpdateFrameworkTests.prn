84097>>>>>>>//=============================================================================
84097>>>>>>>/// @Name        SQL_OPEN_CURSOR_STMT
84097>>>>>>>/// @Description This command is used to create a new SQl Cursor. Once
84097>>>>>>>/// created, SQL_SET_CURRENT_CURSOR_STMT can be called to specify which
84097>>>>>>>/// cursor is to be used for a given SQL statement. Creating multiple
84097>>>>>>>/// cursors using this command allows multiple SQL statements to be
84097>>>>>>>/// opened at once. Optionally a different server can be specified for each
84097>>>>>>>/// cursor by passing the server name to this command as well. If no
84097>>>>>>>/// server is specified, the current server will be used. Note that it
84097>>>>>>>/// is important to close all cursors at the end using SQL_CLOSE_CURSOR_STMT.
84097>>>>>>>///
84097>>>>>>>/// @Assumptions
84097>>>>>>>/// @Status      Public
84097>>>>>>>/// @Drivers     All
84097>>>>>>>/// @VersionNote Last Revised: 2013-10-07 by Aaron Gulack
84097>>>>>>>/// @See                 SQL_CLOSE_CURSOR_STMT SQL_SET_CURRENT_CURSOR_STMT SQL_GET_CURRENT_CURSOR_STMT
84097>>>>>>>///
84097>>>>>>>/// @Syntax SQL_OPEN_CURSOR_STMT [of {server}] to {variable}
84097>>>>>>>/// @Param server                       Name of the server (optional)
84097>>>>>>>/// @Param variable                     Variable to hold the returned cursor handle
84097>>>>>>>///
84097>>>>>>>/// @Example
84097>>>>>>>///
84097>>>>>>>/// Integer iCursor1 iCursor2 iCustomer
84097>>>>>>>/// String  sName
84097>>>>>>>/// Number  nOrderTotal
84097>>>>>>>///
84097>>>>>>>/// SQL_OPEN_CURSOR_STMT to iCursor1
84097>>>>>>>/// SQL_SET_STMT         to "SELECT CUSTOMER_NUMBER,NAME FROM CUSTOMER "
84097>>>>>>>/// SQL_APPEND_STMT      to "ORDER BY NAME "
84097>>>>>>>/// SQL_PREPARE_STMT
84097>>>>>>>/// SQL_EXECUTE_STMT
84097>>>>>>>/// Repeat
84097>>>>>>>///     SQL_SET_CURRENT_CURSOR_STMT TO iCursor1
84097>>>>>>>///     SQL_FETCH_NEXT_ROW INTO iCustomer sName
84097>>>>>>>///     If (Found) Begin
84097>>>>>>>///        SQL_OPEN_CURSOR_STMT to iCursor2
84097>>>>>>>///        SQL_SET_STMT         to "SELECT SUM(ORDER_TOTAL) FROM ORDERHEA "
84097>>>>>>>///        SQL_APPEND_STMT      to ("WHERE CUSTOMER_NUMBER = " + Trim(iCustomer))
84097>>>>>>>///        SQL_PREPARE_STMT
84097>>>>>>>///        SQL_EXECUTE_STMT
84097>>>>>>>///        SQL_FETCH_NEXT_ROW INTO nOrderTotal
84097>>>>>>>///        If (Found and nOrderTotal > 0) Begin
84097>>>>>>>///            Showln "Customer : " iCustomer "-" sName " - Total: " nOrderTotal
84097>>>>>>>///        End
84097>>>>>>>///        SQL_CLOSE_CURSOR_STMT to Cursor2
84097>>>>>>>///
84097>>>>>>>///        Indicate Found True
84097>>>>>>>///     End
84097>>>>>>>/// Until (Not(Found))
84097>>>>>>>///
84097>>>>>>>/// SQL_CLOSE_CURSOR_STMT to Cursor1
84097>>>>>>>
84097>>>>>>>//=============================================================================
84097>>>>>>>/// @Name        SQL_CLOSE_CURSOR_STMT
84097>>>>>>>/// @Description This command closes the specified cursor that was created
84097>>>>>>>/// from SQL_OPEN_CURSOR_STMT. It is good practice to close all cursors
84097>>>>>>>/// once the statements associated with them are complete.
84097>>>>>>>///
84097>>>>>>>/// @Assumptions
84097>>>>>>>/// @Status      Public
84097>>>>>>>/// @Drivers     All
84097>>>>>>>/// @VersionNote Last Revised: 2013-10-07 by Aaron Gulack
84097>>>>>>>/// @See                 SQL_OPEN_CURSOR_STMT SQL_SET_CURRENT_CURSOR_STMT SQL_GET_CURRENT_CURSOR_STMT
84097>>>>>>>///
84097>>>>>>>/// @Syntax SQL_CLOSE_CURSOR_STMT [of {server}] to {variable}
84097>>>>>>>/// @Param server                       Name of the server (optional)
84097>>>>>>>/// @Param variable                     Cursor handle to close
84097>>>>>>>///
84097>>>>>>>/// @Example
84097>>>>>>>///
84097>>>>>>>/// SQL_OPEN_CURSOR_STMT to hCursor1
84097>>>>>>>///
84097>>>>>>>/// SQL_SET_STMT to "SELECT * FROM CUSTOMER WHERE STATUS = 'Active' "
84097>>>>>>>/// SQL_PREPARE_STMT
84097>>>>>>>/// SQL_EXECUTE_STMT
84097>>>>>>>///
84097>>>>>>>/// SQL_OPEN_CURSOR_STMT to hCursor2
84097>>>>>>>///
84097>>>>>>>/// SQL_SET_STMT to "SELECT * FROM CUSTOMER WHERE STATUS = 'Inactive' "
84097>>>>>>>/// SQL_PREPARE_STMT
84097>>>>>>>/// SQL_EXECUTE_STMT
84097>>>>>>>///
84097>>>>>>>/// Repeat
84097>>>>>>>///     SQL_SET_CURRENT_CURSOR_STMT to hCursor1
84097>>>>>>>///     SQL_FETCH_NEXT_ROW INTO  sID sFirstName sLastName
84097>>>>>>>///     If (Found) Begin
84097>>>>>>>///        Showln "Active : " sID "- " sFirstName sLastName
84097>>>>>>>///     End
84097>>>>>>>///
84097>>>>>>>///     SQL_SET_CURRENT_CURSOR_STMT to hCursor2
84097>>>>>>>///     SQL_FETCH_NEXT_ROW into sId sFirstName sLastName
84097>>>>>>>///     If (Found) Begin
84097>>>>>>>///         Showln "Inactive : " sID "- " sFirstName sLastName
84097>>>>>>>///     End
84097>>>>>>>/// Until (FindErr)
84097>>>>>>>///
84097>>>>>>>/// SQL_CLOSE_CURSOR_STMT to hCursor1
84097>>>>>>>/// SQL_CLOSE_CURSOR_STMT to hCursor2
84097>>>>>>>
84097>>>>>>>//=============================================================================
84097>>>>>>>/// @Name        SQL_SET_CURRENT_CURSOR_STMT
84097>>>>>>>/// @Description This command is used to open a cursor to be used for an
84097>>>>>>>/// SQl statement. The cursor must be created using the SQL_OPEN_CURSOR_STMT,
84097>>>>>>>/// but once it has been created, this command can easily switch between
84097>>>>>>>/// cursors as desired. Optionally a different server can be specified for each
84097>>>>>>>/// cursor by passing the server name to this command as well. If no
84097>>>>>>>/// server is specified, the current server will be used. Note that it
84097>>>>>>>/// is important to close all cursors at the end using SQL_CLOSE_CURSOR_STMT.
84097>>>>>>>///
84097>>>>>>>/// @Assumptions
84097>>>>>>>/// @Status      Public
84097>>>>>>>/// @Drivers     All
84097>>>>>>>/// @VersionNote Last Revised: 2013-10-07 by Aaron Gulack
84097>>>>>>>/// @See                 SQL_OPEN_CURSOR_STMT SQL_CLOSE_CURSOR_STMT SQL_GET_CURRENT_CURSOR_STMT
84097>>>>>>>///
84097>>>>>>>/// @Syntax SQL_SET_CURRENT_CURSOR_STMT [of {server}] to {variable}
84097>>>>>>>/// @Param server                       Name of the server (optional)
84097>>>>>>>/// @Param variable                     Cursor handle to use
84097>>>>>>>///
84097>>>>>>>/// @Example
84097>>>>>>>///
84097>>>>>>>/// SQL_OPEN_CURSOR_STMT to hCursor1
84097>>>>>>>///
84097>>>>>>>/// SQL_SET_STMT to "SELECT * FROM CUSTOMER WHERE STATUS = 'Active' "
84097>>>>>>>/// SQL_PREPARE_STMT
84097>>>>>>>/// SQL_EXECUTE_STMT
84097>>>>>>>///
84097>>>>>>>/// SQL_OPEN_CURSOR_STMT to hCursor2
84097>>>>>>>///
84097>>>>>>>/// SQL_SET_STMT to "SELECT * FROM CUSTOMER WHERE STATUS = 'Inactive' "
84097>>>>>>>/// SQL_PREPARE_STMT
84097>>>>>>>/// SQL_EXECUTE_STMT
84097>>>>>>>///
84097>>>>>>>/// Repeat
84097>>>>>>>///     SQL_SET_CURRENT_CURSOR_STMT to hCursor1
84097>>>>>>>///     SQL_FETCH_NEXT_ROW INTO  sID sFirstName sLastName
84097>>>>>>>///     If (Found) Begin
84097>>>>>>>///        Showln "Active : " sID "- " sFirstName sLastName
84097>>>>>>>///     End
84097>>>>>>>///
84097>>>>>>>///     SQL_SET_CURRENT_CURSOR_STMT to hCursor2
84097>>>>>>>///     SQL_FETCH_NEXT_ROW into sId sFirstName sLastName
84097>>>>>>>///     If (Found) Begin
84097>>>>>>>///         Showln "Inactive : " sID "- " sFirstName sLastName
84097>>>>>>>///     End
84097>>>>>>>/// Until (FindErr)
84097>>>>>>>///
84097>>>>>>>/// SQL_CLOSE_CURSOR_STMT to hCursor1
84097>>>>>>>/// SQL_CLOSE_CURSOR_STMT to hCursor2
84097>>>>>>>
84097>>>>>>>//=============================================================================
