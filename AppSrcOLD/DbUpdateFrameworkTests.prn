86766>>>>>>>>>>>>>
86766>>>>>>>>>>>>>
86766>>>>>>>>>>>>>    Function IsProcedure String sFunctionName Returns Boolean
86768>>>>>>>>>>>>>        String sRoutineType
86768>>>>>>>>>>>>>
86768>>>>>>>>>>>>>        SQL_SET_CURRENT_CURSOR_STMT to (piCursorNum(Self))
86782>>>>>>>>>>>>>>
86782>>>>>>>>>>>>>
86782>>>>>>>>>>>>>        Case Begin
86782>>>>>>>>>>>>>            Case (MertechInc_DriverName = SQLFLEX)
86784>>>>>>>>>>>>>                sql_set_stmt to (SFormat("select type from master.sys.sysobjects where name = '%1' union all select type from sys.sysobjects where name = '%1'", sFunctionName))
86792>>>>>>>>>>>>>                sql_prepare_stmt
86804>>>>>>>>>>>>>                sql_execute_stmt
86819>>>>>>>>>>>>>
86819>>>>>>>>>>>>>                sql_fetch_next_row into sRoutineType
86843>>>>>>>>>>>>>>
86843>>>>>>>>>>>>>                If (sRoutineType = "P") Move "PROCEDURE" to sRoutineType
86846>>>>>>>>>>>>>                Else Move "FUNCTION" to sRoutineType
86848>>>>>>>>>>>>>                Case Break
86849>>>>>>>>>>>>>            Case (MertechInc_DriverName = MySQLFlex)
86852>>>>>>>>>>>>>                sql_set_stmt to (SFormat("select routine_type from information_schema.routines where routine_name = '%1'", sFunctionName))
86860>>>>>>>>>>>>>                sql_prepare_stmt
86872>>>>>>>>>>>>>                sql_execute_stmt
86887>>>>>>>>>>>>>                sql_fetch_next_row into sRoutineType
86911>>>>>>>>>>>>>>
86911>>>>>>>>>>>>>
86911>>>>>>>>>>>>>                Case Break
86912>>>>>>>>>>>>>            Case (MertechInc_DriverName = ORAFLEX)
86915>>>>>>>>>>>>>                sql_set_stmt  to (SFormat("SELECT object_type from all_objects where object_name = '%1'", sFunctionName))
86923>>>>>>>>>>>>>                sql_prepare_stmt
86935>>>>>>>>>>>>>                sql_execute_stmt
86950>>>>>>>>>>>>>                sql_fetch_next_row into sRoutineType
86974>>>>>>>>>>>>>>
86974>>>>>>>>>>>>>
86974>>>>>>>>>>>>>                Case Break
86975>>>>>>>>>>>>>            Case (MertechInc_DriverName = PgFlex)
86978>>>>>>>>>>>>>                // Postgres doesn't differentiate between procedures and functions, so treat everything as procedures
86978>>>>>>>>>>>>>                // because that is better tested.
86978>>>>>>>>>>>>>                Move "PROCEDURE" to sRoutineType
86979>>>>>>>>>>>>>                Case Break
86980>>>>>>>>>>>>>        Case End
86980>>>>>>>>>>>>>
86980>>>>>>>>>>>>>        Function_Return (sRoutineType = "PROCEDURE")
86981>>>>>>>>>>>>>    End_Function
86982>>>>>>>>>>>>>
86982>>>>>>>>>>>>>    Function ProcParams String sFunctionName Returns Variant[]
86984>>>>>>>>>>>>>        Variant[] vFuncParams
86985>>>>>>>>>>>>>        Integer i iParamType
86985>>>>>>>>>>>>>
86985>>>>>>>>>>>>>        SQL_SET_CURRENT_CURSOR_STMT to (piCursorNum(Self))
86999>>>>>>>>>>>>>>
86999>>>>>>>>>>>>>
86999>>>>>>>>>>>>>        Case Begin
86999>>>>>>>>>>>>>            Case (MertechInc_DriverName = SQLFLEX)
87001>>>>>>>>>>>>>                sql_set_stmt to (SFormat("sys.sp_procedure_params_managed @procedure_name = '%1'", sFunctionName))
87009>>>>>>>>>>>>>                sql_prepare_stmt
87021>>>>>>>>>>>>>                sql_execute_stmt
87036>>>>>>>>>>>>>
87036>>>>>>>>>>>>>                Repeat
87036>>>>>>>>>>>>>>
87036>>>>>>>>>>>>>                    sql_fetch_next_row
87051>>>>>>>>>>>>>>
87051>>>>>>>>>>>>>                    If (Found) Begin
87053>>>>>>>>>>>>>                        sql_fetch_column 6 into iParamType
87058>>>>>>>>>>>>>
87058>>>>>>>>>>>>>                        If (iParamType = 1) Move "IN" to vFuncParams[i]
87061>>>>>>>>>>>>>                        If (iParamType = 2) Move "INOUT" to vFuncParams[i]
87064>>>>>>>>>>>>>                        If (iParamType = 3) Move "OUT" to vFuncParams[i]
87067>>>>>>>>>>>>>                        If (iParamType <> 4) Increment i
87070>>>>>>>>>>>>>                    End
87070>>>>>>>>>>>>>>
87070>>>>>>>>>>>>>                Until (not(Found))
87072>>>>>>>>>>>>>
87072>>>>>>>>>>>>>                Function_Return vFuncParams
87073>>>>>>>>>>>>>
87073>>>>>>>>>>>>>                Case Break
87074>>>>>>>>>>>>>            Case (MertechInc_DriverName = MySQLFlex)
87077>>>>>>>>>>>>>                sql_set_stmt to (SFormat("select parameter_mode from INFORMATION_SCHEMA.PARAMETERS where SPECIFIC_NAME = '%1' order by ordinal_position", sFunctionName))
87085>>>>>>>>>>>>>                sql_prepare_stmt
87097>>>>>>>>>>>>>                sql_execute_stmt
87112>>>>>>>>>>>>>
87112>>>>>>>>>>>>>                Case Break
87113>>>>>>>>>>>>>            Case (MertechInc_DriverName = ORAFLEX)
87116>>>>>>>>>>>>>                sql_set_stmt to    "SELECT all_arguments.in_out as parameter_mode "
87124>>>>>>>>>>>>>                sql_append_stmt to "FROM all_objects inner join all_arguments on all_objects.object_id = all_arguments.object_id "
87132>>>>>>>>>>>>>                sql_append_stmt to (SFormat("WHERE all_objects.object_name = '%1' order by all_arguments.position", sFunctionName))
87140>>>>>>>>>>>>>                sql_prepare_stmt
87152>>>>>>>>>>>>>                sql_execute_stmt
87167>>>>>>>>>>>>>
87167>>>>>>>>>>>>>                Case Break
87168>>>>>>>>>>>>>            Case (MertechInc_DriverName = PgFlex)
87171>>>>>>>>>>>>>                sql_set_stmt    to "select information_schema.parameters.parameter_mode "
87179>>>>>>>>>>>>>                sql_append_stmt to "from information_schema.routines inner join information_schema.parameters "
87187>>>>>>>>>>>>>                sql_append_stmt to "on information_schema.routines.specific_name=information_schema.parameters.specific_name "
87195>>>>>>>>>>>>>                sql_append_stmt to (SFormat("where information_schema.routines.routine_name = '%1' ", sFunctionName))
87203>>>>>>>>>>>>>                sql_append_stmt to "order by information_schema.parameters.ordinal_position"
87211>>>>>>>>>>>>>                sql_prepare_stmt
87223>>>>>>>>>>>>>                sql_execute_stmt
87238>>>>>>>>>>>>>
87238>>>>>>>>>>>>>                Case Break
87239>>>>>>>>>>>>>        Case End
87239>>>>>>>>>>>>>
87239>>>>>>>>>>>>>        Repeat
87239>>>>>>>>>>>>>>
87239>>>>>>>>>>>>>            sql_fetch_next_row into vFuncParams[i]
87263>>>>>>>>>>>>>>
87263>>>>>>>>>>>>>            Increment i
87264>>>>>>>>>>>>>        Until (not(Found))
87266>>>>>>>>>>>>>        
87266>>>>>>>>>>>>>        Function_Return vFuncParams
87267>>>>>>>>>>>>>    End_Function
87268>>>>>>>>>>>>>    
87268>>>>>>>>>>>>>    Procedure Set StoreHandleInfo Handle hConn
87270>>>>>>>>>>>>>        Set phCLIHandle to hConn
87271>>>>>>>>>>>>>    End_Procedure
87272>>>>>>>>>>>>>    
87272>>>>>>>>>>>>>    Procedure FreeHandle
87274>>>>>>>>>>>>>        SQL_SET_CURRENT_CURSOR_STMT to (piCursorNum(Self))
87288>>>>>>>>>>>>>>
87288>>>>>>>>>>>>>                                
87288>>>>>>>>>>>>>                                 Case Begin
87288>>>>>>>>>>>>>            Case (MertechInc_DriverName = SQLFLEX)
87290>>>>>>>>>>>>>                                END_CALL_PROCEDURE
87295>>>>>>>>>>>>>                Case Break
87296>>>>>>>>>>>>>            Case (MertechInc_DriverName = MySQLFlex)
87299>>>>>>>>>>>>>                Case Break
87300>>>>>>>>>>>>>            Case (MertechInc_DriverName = ORAFLEX)
87303>>>>>>>>>>>>>                Case Break
87304>>>>>>>>>>>>>            Case (MertechInc_DriverName = PgFlex)
87307>>>>>>>>>>>>>                Case Break
87308>>>>>>>>>>>>>        Case End
87308>>>>>>>>>>>>>        
87308>>>>>>>>>>>>>        
87308>>>>>>>>>>>>>        SQL_CLOSE_CURSOR_STMT to (piCursorNum(Self))
87322>>>>>>>>>>>>>>
87322>>>>>>>>>>>>>        Send Destroy_Object
87323>>>>>>>>>>>>>    End_Procedure // FreeHandle
87324>>>>>>>>>>>>>
87324>>>>>>>>>>>>>    Procedure SQLClose
87326>>>>>>>>>>>>>        Send FreeHandle
87327>>>>>>>>>>>>>    End_Procedure // SQLClose
87328>>>>>>>>>>>>>
87328>>>>>>>>>>>>>    Procedure HandleError Integer ihstmt Integer ihdbc String sDrvrId String sOriginMsg
87330>>>>>>>>>>>>>        Integer iErrHandle
87330>>>>>>>>>>>>>        Integer iErrNum
87330>>>>>>>>>>>>>        String  sLocationInfo
87330>>>>>>>>>>>>>
87330>>>>>>>>>>>>>        //*** Get the DataFlex statement identifier
87330>>>>>>>>>>>>>        Move Current_object to iErrHandle
87331>>>>>>>>>>>>>
87331>>>>>>>>>>>>>        //*** Determine error number
87331>>>>>>>>>>>>>        If (ihstmt = 0) ;            Move CLIERR_SQLINVALID_CLI_STMT_HANDLE to iErrNum
87334>>>>>>>>>>>>>        Else If (ihdbc = 0) ;            Move CLIERR_SQLINVALID_CLI_CONN_HANDLE to iErrNum
87338>>>>>>>>>>>>>        Else If (sDrvrId = "") ;            Move CLIERR_SQLINVALID_DRIVER_ID to iErrNum
87342>>>>>>>>>>>>>        Else ;            Move CLIERR_SQL_ERROR to iErrNum
87344>>>>>>>>>>>>>
87344>>>>>>>>>>>>>        //*** Create location information
87344>>>>>>>>>>>>>        Move "[" to sLocationInfo
87345>>>>>>>>>>>>>        If (sOriginMsg <> "") Begin
87347>>>>>>>>>>>>>            Move (Append(sLocationInfo, sOriginMsg)) to sLocationInfo
87348>>>>>>>>>>>>>            Move (Append(sLocationInfo, ", "))       to sLocationInfo
87349>>>>>>>>>>>>>        End
87349>>>>>>>>>>>>>>
87349>>>>>>>>>>>>>        Move (Append(sLocationInfo, "DataFlex hstmt = ")) to sLocationInfo
87350>>>>>>>>>>>>>        Move (Append(sLocationInfo, iErrHandle))          to sLocationInfo
87351>>>>>>>>>>>>>        Move (Append(sLocationInfo, "]"))                 to sLocationInfo
87352>>>>>>>>>>>>>
87352>>>>>>>>>>>>>        //*** Generate the error
87352>>>>>>>>>>>>>        Error iErrNum sLocationInfo
87353>>>>>>>>>>>>>>
87353>>>>>>>>>>>>>    End_Procedure
87354>>>>>>>>>>>>>    
87354>>>>>>>>>>>>>    Procedure StmtError Integer iErrNum String sErrText String sOriginMsg
87356>>>>>>>>>>>>>        Local Integer iErrHandle
87356>>>>>>>>>>>>>        Local String  sLocationInfo
87356>>>>>>>>>>>>>
87356>>>>>>>>>>>>>        //*** Get the DataFlex statement identifier
87356>>>>>>>>>>>>>        Move Current_object to iErrHandle
87357>>>>>>>>>>>>>
87357>>>>>>>>>>>>>
87357>>>>>>>>>>>>>        //*** Create location information
87357>>>>>>>>>>>>>        Move "[" to sLocationInfo
87358>>>>>>>>>>>>>        If (sOriginMsg <> "") Begin
87360>>>>>>>>>>>>>            Move (Append(sLocationInfo, sOriginMsg)) to sLocationInfo
87361>>>>>>>>>>>>>            Move (Append(sLocationInfo, ", "))       to sLocationInfo
87362>>>>>>>>>>>>>        End
87362>>>>>>>>>>>>>>
87362>>>>>>>>>>>>>        If (sErrtext <> "") Begin
87364>>>>>>>>>>>>>            Move (Append(sLocationInfo, sErrtext)) to sLocationInfo
87365>>>>>>>>>>>>>            Move (Append(sLocationInfo, ", "))     to sLocationInfo
87366>>>>>>>>>>>>>        End
87366>>>>>>>>>>>>>>
87366>>>>>>>>>>>>>        Move (Append(sLocationInfo, "DataFlex hstmt = ")) to sLocationInfo
87367>>>>>>>>>>>>>        Move (Append(sLocationInfo, iErrHandle))          to sLocationInfo
87368>>>>>>>>>>>>>        Move (Append(sLocationInfo, "]"))                 to sLocationInfo
87369>>>>>>>>>>>>>
87369>>>>>>>>>>>>>        //*** Generate the error
87369>>>>>>>>>>>>>        Error iErrNum sLocationInfo
87370>>>>>>>>>>>>>>
87370>>>>>>>>>>>>>    End_Procedure
87371>>>>>>>>>>>>>    
87371>>>>>>>>>>>>>    Procedure SQLIllegalAttribute String sErrText String sOriginMsg
87373>>>>>>>>>>>>>        Local Integer bReport
87373>>>>>>>>>>>>>
87373>>>>>>>>>>>>>        Get_Attribute DF_REPORT_UNSUPPORTED_ATTRIBUTES to bReport
87376>>>>>>>>>>>>>        If (bReport) ;            Send StmtError CLIERR_SQLINVALID_ATTRIBUTE sErrtext sOriginMsg
87379>>>>>>>>>>>>>    End_Procedure // SQLIllegalAttribute
87380>>>>>>>>>>>>>
87380>>>>>>>>>>>>>    Function SQLColumnValue Integer iCol Returns String
87382>>>>>>>>>>>>>        String sResult
87382>>>>>>>>>>>>>        Integer iCols
87382>>>>>>>>>>>>>        Integer iOrgDateFmt
87382>>>>>>>>>>>>>        Integer iOrgDateSep
87382>>>>>>>>>>>>>        String sType 
87382>>>>>>>>>>>>>
87382>>>>>>>>>>>>>        SQL_SET_CURRENT_CURSOR_STMT to (piCursorNum(Self))
87396>>>>>>>>>>>>>>
87396>>>>>>>>>>>>>        
87396>>>>>>>>>>>>>        SQL_GET_NUM_COLS to iCols
87406>>>>>>>>>>>>>>
87406>>>>>>>>>>>>>        If (iCol <= iCols) Begin
87408>>>>>>>>>>>>>            //DAC SQL Driver currently uses military format for the SQL getting of dates.
87408>>>>>>>>>>>>>            If (giSQLCompatibilityMode=SQL_DAC_HIGH_COMPATABILITY) Begin             
87410>>>>>>>>>>>>>                Get_Attribute DF_DATE_FORMAT to iOrgDateFmt
87413>>>>>>>>>>>>>                Get_Attribute DF_DATE_SEPARATOR to iOrgDateSep
87416>>>>>>>>>>>>>                Set_Attribute DF_DATE_FORMAT to DF_DATE_MILITARY
87419>>>>>>>>>>>>>                Set_Attribute DF_DATE_SEPARATOR to (Ascii('-'))
87422>>>>>>>>>>>>>            End 
87422>>>>>>>>>>>>>>
87422>>>>>>>>>>>>>            
87422>>>>>>>>>>>>>            //DAC SQL Driver cannot directly get TEXT fields into a result. 
87422>>>>>>>>>>>>>            If (giSQLCompatibilityMode=SQL_DAC_HIGH_COMPATABILITY) Begin             
87424>>>>>>>>>>>>>                SQL_GET_COL_ATTRIBUTE of iCol DFTYPE to sType
87441>>>>>>>>>>>>>>
87441>>>>>>>>>>>>>                If (sType=5) Move "" to sResult 
87444>>>>>>>>>>>>>                Else Begin 
87445>>>>>>>>>>>>>                    SQL_FETCH_COLUMN iCol into sResult
87450>>>>>>>>>>>>>                End
87450>>>>>>>>>>>>>>
87450>>>>>>>>>>>>>            End 
87450>>>>>>>>>>>>>>
87450>>>>>>>>>>>>>            Else Begin 
87451>>>>>>>>>>>>>               SQL_FETCH_COLUMN iCol into sResult 
87456>>>>>>>>>>>>>            End
87456>>>>>>>>>>>>>>
87456>>>>>>>>>>>>>            
87456>>>>>>>>>>>>>
87456>>>>>>>>>>>>>            If (giSQLCompatibilityMode=SQL_DAC_HIGH_COMPATABILITY) Begin             
87458>>>>>>>>>>>>>                Set_Attribute DF_DATE_FORMAT to iOrgDateFmt
87461>>>>>>>>>>>>>                Set_Attribute DF_DATE_SEPARATOR to iOrgDateSep
87464>>>>>>>>>>>>>            End 
87464>>>>>>>>>>>>>>
87464>>>>>>>>>>>>>
87464>>>>>>>>>>>>>            Function_Return sResult
87465>>>>>>>>>>>>>        End
87465>>>>>>>>>>>>>>
87465>>>>>>>>>>>>>        Else Send HandleError (phCLIHandle(Self)) (phCLIHandle(Parent(Self))) (psDriverID(Self)) "SQLColumnValue"
87467>>>>>>>>>>>>>    End_Function // SQLColumnValue
87468>>>>>>>>>>>>>
87468>>>>>>>>>>>>>    Function SQLNextColumn Returns String
87470>>>>>>>>>>>>>        Integer iCol
87470>>>>>>>>>>>>>        String  sResult
87470>>>>>>>>>>>>>
87470>>>>>>>>>>>>>        Get piLastColumn to iCol
87471>>>>>>>>>>>>>        Increment iCol
87472>>>>>>>>>>>>>        Get SQLColumnValue iCol to sResult
87473>>>>>>>>>>>>>        Set piLastColumn to iCol
87474>>>>>>>>>>>>>
87474>>>>>>>>>>>>>        Function_Return sResult
87475>>>>>>>>>>>>>    End_Function // SQLNextColumn
