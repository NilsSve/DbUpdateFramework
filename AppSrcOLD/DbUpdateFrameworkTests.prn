90404>>>>>>>    // *** Main Connection Message ***
90404>>>>>>>    // It will create a Connection ID for the passed driver. 
90404>>>>>>>    // It will also set the psDriverID & psConnectionID of this class.
90404>>>>>>>    Procedure CreateSQLConnection String sDriverID String sConnectionID String sServer String sDatabase Boolean bTrusted String sUserID String sPassword Boolean bSilent
90406>>>>>>>        Integer iResult
90406>>>>>>>        Handle hoCLI hoDriver
90406>>>>>>>        String sConnectionString sError  
90406>>>>>>>        Boolean bMertech bLoginSuccessful
90406>>>>>>>        
90406>>>>>>>        Get ConstructConnectionString sDriverID sServer sDatabase bTrusted sUserID sPassword to sConnectionString 
90407>>>>>>>        Get Create (RefClass(cDbUpdateDatabaseDriver)) to hoDriver
90408>>>>>>>        Set psDriverID of hoDriver to sDriverID
90409>>>>>>>        Get DbLogin of hoDriver sConnectionString sServer sDatabase bTrusted sUserID sPassword to bLoginSuccessful
90410>>>>>>>        If (bLoginSuccessful = False) Begin
90412>>>>>>>            Error DFERR_PROGRAM (CS_DUF_CannotLoginToServer * CS_DUF_ErrorText * String(sError) + "\nConnectionID = " * sConnectionID + "\nConnection String = " * sConnectionString)
90413>>>>>>>>
90413>>>>>>>        End
90413>>>>>>>>
90413>>>>>>>        Send Destroy of hoDriver 
90414>>>>>>>    
90414>>>>>>>    End_Procedure
90415>>>>>>>    
90415>>>>>>>    Function RedirectConnection String sOldConnection String sNewConnection Returns Integer
90417>>>>>>>        Integer iRetval
90417>>>>>>>        Handle hoCLI               
90417>>>>>>>        String sDriverID
90417>>>>>>>        
90417>>>>>>>        Get psDriverID to sDriverID
90418>>>>>>>        Get Create (Refclass(cCLIHandler)) to hoCLI
90419>>>>>>>        If (hoCLI <> 0) Begin
90421>>>>>>>            Set psDriverID of hoCLI to sDriverID
90422>>>>>>>            Get RedirectConnection of hoCLI sOldConnection sNewConnection to iRetval
90423>>>>>>>            Send Destroy of hoCLI
90424>>>>>>>        End
90424>>>>>>>>
90424>>>>>>>        
90424>>>>>>>        Function_Return iRetval
90425>>>>>>>    End_Function
90426>>>>>>>    
90426>>>>>>>    Procedure CreateConnParamsFromConnectionString String sDriverID String sConnectionString
90428>>>>>>>        Integer iResult
90428>>>>>>>        Handle hoCLI
90428>>>>>>>        String sServer sDatabase sUserID sPassword
90428>>>>>>>        tSQLConnection SQLConnection
90428>>>>>>>        tSQLConnection SQLConnection
90428>>>>>>>        
90428>>>>>>>        Set psDriverID to sDriverID
90429>>>>>>>        Get DeComposeConnectionString sDriverID sConnectionString to SQLConnection
90430>>>>>>>        Send CreateSQLConnection SQLConnection.sDriverID SQLConnection.sConnectionID SQLConnection.sServer;                                 SQLConnection.sDatabase SQLConnection.bTrusted SQLConnection.sUserID SQLConnection.sPassword SQLConnection.bTrusted
90431>>>>>>>    End_Procedure
90432>>>>>>>    
90432>>>>>>>    // This is needed when e.g. the connection id we have specified in the program code
90432>>>>>>>    // also exists in e.g. the MSSQLDRV.ini file (can either be local in the Data folder
90432>>>>>>>    // or the one in the DataFlex Bin folder.)
90432>>>>>>>    // We then need to delete the current one before creating a new one.
90432>>>>>>>    // This is because the parameters may differ between the program code and the
90432>>>>>>>    // MSSQLDRV.ini file in a deployed environment. Also DataFlex will generate an error
90432>>>>>>>    // when one tries to create a Connection ID that already exists.
90432>>>>>>>    Procedure RemoveExistingConnectionID String sDriverID String sConnectionID
90434>>>>>>>        Integer iResult iDriver iNumConn iConn
90434>>>>>>>        Handle hoCLI
90434>>>>>>>        String sID   
90434>>>>>>>        
90434>>>>>>>        If (sDriverID = "" or sConnectionID = "") Begin
90436>>>>>>>            Procedure_Return
90437>>>>>>>        End                 
90437>>>>>>>>
90437>>>>>>>        
90437>>>>>>>        Move 0 to iResult
90438>>>>>>>        Get Create U_cCLIHandler to hoCLI
90439>>>>>>>        If (hoCLI <> 0) Begin
90441>>>>>>>            Set psDriverID of hoCLI to sDriverID   
90442>>>>>>>            Get DriverIndex sDriverID to iDriver
90443>>>>>>>            Get_Attribute DF_DRIVER_NUMBER_CONNECTION_IDS of iDriver to iNumConn 
90446>>>>>>>            Decrement iNumConn
90447>>>>>>>            For iConn from 0 to iNumConn
90453>>>>>>>>
90453>>>>>>>                Get_Attribute DF_DRIVER_CONNECTION_ID of iDriver iConn to sID
90456>>>>>>>                If (Uppercase(sID) = Uppercase(sConnectionID)) Begin
90458>>>>>>>                    Get DeleteConnectionID of hoCLI sConnectionID -1 to iResult
90459>>>>>>>                End
90459>>>>>>>>
90459>>>>>>>            Loop
90460>>>>>>>>
90460>>>>>>>            Send Destroy of hoCLI
90461>>>>>>>        End
90461>>>>>>>>
90461>>>>>>>    
90461>>>>>>>    End_Procedure   
90462>>>>>>>    
90462>>>>>>>    Function ExistingConnectionSettings String sDriverID String sConnectionID Returns tSQLConnection
90464>>>>>>>        Integer iResult iDriver iNumConn iConn
90464>>>>>>>        Handle hoCLI
90464>>>>>>>        String sID sConnectionString sVal sDatabase
90464>>>>>>>        tSQLConnection SQLConnection
90464>>>>>>>        tSQLConnection SQLConnection
90464>>>>>>>        Boolean bTrusted
90464>>>>>>>        
90464>>>>>>>        Move 0 to iResult
90465>>>>>>>        Get Create U_cCLIHandler to hoCLI
90466>>>>>>>        If (hoCLI <> 0) Begin
90468>>>>>>>            Set psDriverID of hoCLI to sDriverID
90469>>>>>>>            Get DriverIndex sDriverID to iDriver
90470>>>>>>>            Get_Attribute DF_DRIVER_NUMBER_CONNECTION_IDS of iDriver to iNumConn 
90473>>>>>>>            Decrement iNumConn
90474>>>>>>>            For iConn from 0 to iNumConn
90480>>>>>>>>
90480>>>>>>>                Get_Attribute DF_DRIVER_CONNECTION_ID of iDriver iConn to sID
90483>>>>>>>                If (Uppercase(sID) = Uppercase(sConnectionID)) Begin                                             
90485>>>>>>>                    Move sDriverID                                                      to SQLConnection.sDriverID      // For completeness only...
90486>>>>>>>                    Get_Attribute DF_DRIVER_CONNECTION_ID of iDriver iConn              to SQLConnection.sConnectionID  // For completeness only...
90489>>>>>>>                    Get_Attribute DF_DRIVER_CONNECTION_ID_STRING of iDriver iConn       to sConnectionString
90492>>>>>>>                    Move sConnectionString                                              to SQLConnection.sConnectionString 
90493>>>>>>>                    Get_Attribute DF_DRIVER_CONNECTION_ID_OPTIONS of iDriver iConn      to SQLConnection.bSilentLogin
90496>>>>>>>                    Get ParseKeyWord sConnectionString (CS_SQLIniServerKeyword + "=")   to SQLConnection.sServer
90497>>>>>>>                    Get ParseKeyWord sConnectionString (CS_SQLIniDatabaseKeyword + "=") to SQLConnection.sDatabase
90498>>>>>>>                    Get ParseKeyWord sConnectionString (CS_SQLIniUIDKeyword + "=")      to SQLConnection.sUserID
90499>>>>>>>                    Get ParseKeyWord sConnectionString (CS_SQLIniPWDKeyword + "=")      to SQLConnection.sPassword
90500>>>>>>>                    
90500>>>>>>>                    Case Begin
90500>>>>>>>                        Case (sDriverID = MSSQLDRV_ID)
90502>>>>>>>                            Get ParseKeyWord sConnectionString (CS_SQLIniTrustedKeyword + "=") to sVal
90503>>>>>>>                            Move (If(Uppercase(sVal) = Uppercase(CS_SQLIniConnectionYes), True, False)) to bTrusted
90504>>>>>>>                            Move bTrusted                                               to SQLConnection.bTrusted
90505>>>>>>>                            Case Break
90506>>>>>>>                        Case (sDriverID = DB2_DRV_ID)
90509>>>>>>>                            Get ParseKeyWord sConnectionString (CS_SQLIniDSNKeyword + "=") to SQLConnection.sServer
90510>>>>>>>                            Case Break
90511>>>>>>>                        Case (sDriverID = ODBC_DRV_ID)
90514>>>>>>>                            Get ParseKeyWord sConnectionString (CS_SQLIniDSNKeyword + "=") to SQLConnection.sServer
90515>>>>>>>                            Case Break
90516>>>>>>>                        Case (sDriverID = SQLFLEX)
90519>>>>>>>                            Get ParseKeyWord sConnectionString (CS_SQLIniDSNKeyword + "=") to SQLConnection.sServer 
90520>>>>>>>                            Move (CS_SQLIniServerKeyword + "=" + SQLConnection.sServer)    to sConnectionString
90521>>>>>>>                            If (SQLConnection.bTrusted = True) Begin
90523>>>>>>>                                Move (sConnectionString + ";" + CS_SQLIniTrustedKeyword + "=" + CS_SQLIniConnectionYes) to sConnectionString
90524>>>>>>>                            End
90524>>>>>>>>
90524>>>>>>>                            Else Begin
90525>>>>>>>                                Get ParseKeyWord sConnectionString (CS_SQLIniUIDKeyword + "=")    to sVal
90526>>>>>>>                                Move (sConnectionString + ";" + CS_SQLIniUIDKeyword + "=" + sVal) to sConnectionString
90527>>>>>>>                                Get ParseKeyWord sConnectionString (CS_SQLIniPWDKeyword + "=")    to sVal
90528>>>>>>>                                Move (sConnectionString + ";" + CS_SQLIniPWDKeyword + "=" + sVal) to sConnectionString
90529>>>>>>>                            End
90529>>>>>>>>
90529>>>>>>>                            Move sConnectionString                                         to SQLConnection.sConnectionString
90530>>>>>>>                            Case Break
90531>>>>>>>                        Case (sDriverID = MDSMySQL)
90534>>>>>>>                            Get ParseKeyWord sConnectionString (CS_SQLIniDSNKeyword + "=") to SQLConnection.sServer 
90535>>>>>>>                            Move (CS_SQLIniServerKeyword + "=" + SQLConnection.sServer)    to sConnectionString
90536>>>>>>>                            If (SQLConnection.bTrusted = True) Begin
90538>>>>>>>                                Move (sConnectionString + ";" + CS_SQLIniTrustedKeyword + "=" + CS_SQLIniConnectionYes) to sConnectionString
90539>>>>>>>                            End
90539>>>>>>>>
90539>>>>>>>                            Else Begin
90540>>>>>>>                                Get ParseKeyWord sConnectionString (CS_SQLIniUIDKeyword + "=")    to sVal
90541>>>>>>>                                Move (sConnectionString + ";" + CS_SQLIniUIDKeyword + "=" + sVal) to sConnectionString
90542>>>>>>>                                Get ParseKeyWord sConnectionString (CS_SQLIniPWDKeyword + "=")    to sVal
90543>>>>>>>                                Move (sConnectionString + ";" + CS_SQLIniPWDKeyword + "=" + sVal) to sConnectionString
90544>>>>>>>                            End
90544>>>>>>>>
90544>>>>>>>                            Move sConnectionString                                         to SQLConnection.sConnectionString
90545>>>>>>>                            Case Break
90546>>>>>>>                        Case (sDriverID = MDSPgSQL)
90549>>>>>>>                            Get ParseKeyWord sConnectionString (CS_SQLIniDSNKeyword + "=") to SQLConnection.sServer 
90550>>>>>>>                            Move (CS_SQLIniServerKeyword + "=" + SQLConnection.sServer)    to sConnectionString
90551>>>>>>>                            If (SQLConnection.bTrusted = True) Begin
90553>>>>>>>                                Move (sConnectionString + ";" + CS_SQLIniTrustedKeyword + "=" + CS_SQLIniConnectionYes) to sConnectionString
90554>>>>>>>                            End
90554>>>>>>>>
90554>>>>>>>                            Else Begin
90555>>>>>>>                                Get ParseKeyWord sConnectionString (CS_SQLIniUIDKeyword + "=")    to sVal
90556>>>>>>>                                Move (sConnectionString + ";" + CS_SQLIniUIDKeyword + "=" + sVal) to sConnectionString
90557>>>>>>>                                Get ParseKeyWord sConnectionString (CS_SQLIniPWDKeyword + "=")    to sVal
90558>>>>>>>                                Move (sConnectionString + ";" + CS_SQLIniPWDKeyword + "=" + sVal) to sConnectionString
90559>>>>>>>                            End
90559>>>>>>>>
90559>>>>>>>                            Move sConnectionString                                                to SQLConnection.sConnectionString
90560>>>>>>>                            Case Break
90561>>>>>>>                        
90561>>>>>>>                        Case (sDriverID = ORAFLEX)
90564>>>>>>>                            Get ParseKeyWord sConnectionString (CS_SQLIniDSNKeyword + "=")      to SQLConnection.sServer 
90565>>>>>>>                            Move (CS_SQLIniServerKeyword + "=" + SQLConnection.sServer)         to sConnectionString
90566>>>>>>>                            Get ParseKeyWord sConnectionString (CS_SQLIniDatabaseKeyword + "=") to sDatabase
90567>>>>>>>                            If (sDatabase <> "" and (not(SQLConnection.sServer contains "/"))) Begin
90569>>>>>>>                                Move (SQLConnection.sServer + "/" + sDatabase)                  to SQLConnection.sServer
90570>>>>>>>                            End
90570>>>>>>>>
90570>>>>>>>                            If (SQLConnection.bTrusted = True) Begin
90572>>>>>>>                                Move (sConnectionString + ";" + CS_SQLIniTrustedKeyword + "=" + CS_SQLIniConnectionYes) to sConnectionString
90573>>>>>>>                            End
90573>>>>>>>>
90573>>>>>>>                            Else Begin
90574>>>>>>>                                Get ParseKeyWord sConnectionString (CS_SQLIniUIDKeyword + "=")    to sVal
90575>>>>>>>                                Move (sConnectionString + ";" + CS_SQLIniUIDKeyword + "=" + sVal) to sConnectionString
90576>>>>>>>                                Get ParseKeyWord sConnectionString (CS_SQLIniPWDKeyword + "=")    to sVal
90577>>>>>>>                                Move (sConnectionString + ";" + CS_SQLIniPWDKeyword + "=" + sVal) to sConnectionString
90578>>>>>>>                            End
90578>>>>>>>>
90578>>>>>>>                            Move sConnectionString                                         to SQLConnection.sConnectionString
90579>>>>>>>                            Case Break
90580>>>>>>>                        Case Else
90580>>>>>>>                            Error ("Wrong driver ID passed:" * sDriverID)
90581>>>>>>>>
90581>>>>>>>                            Case Break
90582>>>>>>>                    Case End                    
90582>>>>>>>                End
90582>>>>>>>>
90582>>>>>>>            Loop
90583>>>>>>>>
90583>>>>>>>            Send Destroy of hoCLI
90584>>>>>>>        End
90584>>>>>>>>
90584>>>>>>>        
90584>>>>>>>        Function_Return SQLConnection
90585>>>>>>>    End_Function
90586>>>>>>>    
90586>>>>>>>    Function DriverIndex String sDriverID Returns Integer
90588>>>>>>>        String  sCurrentDriver
90588>>>>>>>        Integer iNumberOfDrivers iDriver iCount iRetval
90588>>>>>>>        
90588>>>>>>>        Move 0 to iDriver
90589>>>>>>>        Get_Attribute DF_NUMBER_DRIVERS to iNumberOfDrivers
90592>>>>>>>        For iCount from 1 to iNumberOfDrivers
90598>>>>>>>>
90598>>>>>>>            Get_Attribute DF_DRIVER_NAME of iCount to sCurrentDriver
90601>>>>>>>            If ( Uppercase(sCurrentDriver) = Uppercase(sDriverID) ) Begin
90603>>>>>>>                Function_Return iCount
90604>>>>>>>            End
90604>>>>>>>>
90604>>>>>>>        Loop
90605>>>>>>>>
90605>>>>>>>        
90605>>>>>>>        // If driver not previously loaded; attempt to do so now.
90605>>>>>>>        If (iDriver = 0) Begin
90607>>>>>>>            Move 0 to LastErr
90608>>>>>>>            Load_Driver sDriverID   
90609>>>>>>>            // If driver could not be loaded.
90609>>>>>>>            If (LastErr = 4255) Begin
90611>>>>>>>                Move 0 to iCount
90612>>>>>>>            End
90612>>>>>>>>
90612>>>>>>>            Function_Return iCount
90613>>>>>>>        End
90613>>>>>>>>
90613>>>>>>>        Function_Return 0
90614>>>>>>>    End_Function
90615>>>>>>>        
90615>>>>>>>    // This will update connection settings of the cCLIHandler object with that passed struct values.
90615>>>>>>>    Procedure UpdateConnectionString tSQLConnection SQLConnection
90617>>>>>>>        String sRetval sDriverID sConnectionID sConnectionString sServer sDatabase sUserID sPassword
90617>>>>>>>        Boolean bTrusted bSilent  
90617>>>>>>>        Integer iConnOptions
90617>>>>>>>        
90617>>>>>>>        Move SQLConnection.sDriverID     to sDriverID
90618>>>>>>>        Move SQLConnection.sConnectionID to sConnectionID
90619>>>>>>>        Move SQLConnection.sServer       to sServer
90620>>>>>>>        Move SQLConnection.sDatabase     to sDatabase
90621>>>>>>>        Move SQLConnection.bTrusted      to bTrusted
90622>>>>>>>        Move SQLConnection.sUserID       to sUserID
90623>>>>>>>        Move SQLConnection.sPassword     to sPassword  
90624>>>>>>>        Move SQLConnection.bSilentLogin  to bSilent
90625>>>>>>>        
90625>>>>>>>        // Note that this message will first delete the current ConnectionID if it exists; which is needed by the cCLIHandler logic.
90625>>>>>>>        Send CreateSQLConnection sDriverID sConnectionID sServer sDatabase bTrusted sUserID sPassword bSilent
90626>>>>>>>        
90626>>>>>>>    End_Procedure
90627>>>>>>>
90627>>>>>>>    // Called when the object is constructed.
90627>>>>>>>    // It will check the psDriverID for a ConnectionID and save it
90627>>>>>>>    // as psConnectionID property. It is later used whenever a login to
90627>>>>>>>    // the database is needed.
90627>>>>>>>    Procedure AutoSetConnectionID
90629>>>>>>>        String sConnectionID sValue sDriverID sConnectionString
90629>>>>>>>        Integer iDriver iNumConn iConn iConnOptions iRetval
90629>>>>>>>        Handle hoCLI                 
90629>>>>>>>        Boolean bOK bSilent bMertechDriver
90629>>>>>>>        
90629>>>>>>>        Get pbSilentLogin      to bSilent
90630>>>>>>>        Get psConnectionID     to sConnectionID                            
90631>>>>>>>        Get psConnectionString to sConnectionString
90632>>>>>>>        // Get the driver Connection ID string & set the psConnectionString property.
90632>>>>>>>        Get psDriverID to sDriverID
90633>>>>>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
90634>>>>>>>        If (bOK = False) Begin
90636>>>>>>>            Procedure_Return              
90637>>>>>>>        End                 
90637>>>>>>>>
90637>>>>>>>        
90637>>>>>>>        // Mertech drivers can't use connection ID's.
90637>>>>>>>        Get IsMertechDriver sDriverID to bMertechDriver    
90638>>>>>>>        If (bMertechDriver = True) Begin         
90640>>>>>>>            // This ensures that the correct Server & Database attributes are set both for 
90640>>>>>>>            // embedded SQL calls and "normal" database commands like e.g. "Open".
90640>>>>>>>            Get _MertechSQLManagerHandle to hoCLI
90641>>>>>>>            Procedure_Return
90642>>>>>>>        End
90642>>>>>>>>
90642>>>>>>>        
90642>>>>>>>        Get DriverIndex sDriverID          to iDriver
90643>>>>>>>        // If driver not loaded; load it.
90643>>>>>>>        If (iDriver = 0) Begin
90645>>>>>>>            Load_Driver sDriverID
90646>>>>>>>            Get DriverIndex sDriverID      to iDriver
90647>>>>>>>        End                      
90647>>>>>>>>
90647>>>>>>>        // This shouldn't be possible; unless the driver.dll file is missing or something...
90647>>>>>>>        If (iDriver = 0) Begin
90649>>>>>>>            Error DFERR_PROGRAM ("The database driver could not be loaded! Connection to database failed." * sDriverID)
90650>>>>>>>>
90650>>>>>>>            Procedure_Return
90651>>>>>>>        End
90651>>>>>>>>
90651>>>>>>>
90651>>>>>>>        Get Create (RefClass(cCLIHandler)) to hoCLI
90652>>>>>>>        Set psDriverID of hoCLI            to sDriverID   
90653>>>>>>>        // Delete the connection first; in case it exists
90653>>>>>>>//        Get DeleteConnectionID of hoCLI sConnectionID -1 to iRetval
