97492>>>>>    End_Function  
97493>>>>>    
97493>>>>>    // When dropping columns on some SQL back-ends they doesn't reclaim the space taken up by the columns dropped. 
97493>>>>>    // For data types that are stored inline in the rows (int for example) it may even take up space on 
97493>>>>>    // the new rows added after the alter statement. to get around this you need to create a clustered 
97493>>>>>    // index on the table _or_ rebuild the clustered Index if it already has one. Rebuilding the index 
97493>>>>>    // can be done with a REBUILD command after modifying the table. But be warned this can be slow on very big tables.
97493>>>>>    //   ALTER TABLE MyTable
97493>>>>>    //       REBUILD
97493>>>>>    Function _SqlUtilRemoveTableColumnMSSQL String sTableName String sColumnName Returns Boolean
97495>>>>>        Boolean bOK  
97495>>>>>        
97495>>>>>        If (Trim(sTableName) = "" or Trim(sColumnName) = "") Begin
97497>>>>>            Function_Return False
97498>>>>>        End                             
97498>>>>>>
97498>>>>>        
97498>>>>>        SQLIncludeScriptFile ..\Scripts\DropConstraintAndColumnNameMSSQL.sql as DropConstraintAndColumnNameMSSQL.sql
97498>>>>>        Get _SqlUtilRemoveTableColumnByScript "DropConstraintAndColumnNameMSSQL.sql" sTableName sColumnName to bOK
97499>>>>>        
97499>>>>>        Function_Return (bOK = True)
97500>>>>>    End_Function
97501>>>>>
97501>>>>>
97501>>>>>    // *** Helper functions with compiled sql script code ***
97501>>>>>    //  
97501>>>>>    // When dropping columns SQL Sever does not reclaim the space taken up by the columns dropped. 
97501>>>>>    // For data types that are stored inline in the rows (int for example) it may even take up space on 
97501>>>>>    // the new rows added after the alter statement. To get around this you need to create a clustered 
97501>>>>>    // index on the table or rebuild the clustered Index if it already has one. Rebuilding the index 
97501>>>>>    // can be done with a REBUILD command after modifying the table. But be warned this can be slow on very big tables.
97501>>>>>    //   ALTER TABLE MyTable
97501>>>>>    //       REBUILD
97501>>>>>    Function _SqlUtilRemoveTableColumnByScript String sMemScriptFile String sTableName String sColumnName Returns Boolean
97503>>>>>        tSQLScriptArray SQLScriptArray                      
97503>>>>>        tSQLScriptArray SQLScriptArray                      
97503>>>>>        String sDriverID sVal
97503>>>>>        Boolean bOK  
97503>>>>>        Integer iSize iCount
97503>>>>>        
97503>>>>>        If (Trim(sTableName) = "" or Trim(sColumnName) = "") Begin
97505>>>>>            Function_Return False
97506>>>>>        End                             
97506>>>>>>
97506>>>>>        
97506>>>>>        Get psDriverID to sDriverID
97507>>>>>        Get SqlUtilReadResource sMemScriptFile to SQLScriptArray
97508>>>>>        If (SQLScriptArray.bError = True) Begin
97510>>>>>            Function_Return False
97511>>>>>        End                     
97511>>>>>>
97511>>>>>        
