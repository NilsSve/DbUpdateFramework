93375>>>>>    Function SqlProcedureArrayMertech String sStmt String sArgument Returns String[]
93377>>>>>        String[] sReturnArray
93378>>>>>        String sValue sUserID sPassword 
93378>>>>>        Handle hoSQLHandler hoSQLConnect hStmt 
93378>>>>>        Integer iFetchResult iRetval
93378>>>>>        tSQLConnection SQLConnection
93378>>>>>        tSQLConnection SQLConnection
93378>>>>>        
93378>>>>>        Get _MertechSQLManagerHandle to hoSQLHandler
93379>>>>>        If (hoSQLHandler <> 0) Begin 
93381>>>>>            Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
93382>>>>>            Get SQLConnect of hoSQLHandler SQLConnection.sDriverID SQLConnection.sServer SQLConnection.sUserID SQLConnection.sPassword to hoSQLConnect
93383>>>>>            If (hoSQLConnect <> 0) Begin   
93385>>>>>                Get SQLOpen of hoSQLConnect to hStmt
93386>>>>>                If (hStmt <> 0) Begin
93388>>>>>                    Send SQLSetProcedureName of hStmt sStmt
93389>>>>>                    If (sArgument <> "") Begin
93391>>>>>                        Send SqlSetArgument  of hStmt 1 sArgument
93392>>>>>                    End
93392>>>>>>
93392>>>>>                    Send SQLCall of hStmt
93393>>>>>
93393>>>>>                    Get SqlReturnValue       of hStmt to iRetval
93394>>>>>                    If (iRetval = 0) Begin
93396>>>>>                        Repeat
93396>>>>>>
93396>>>>>                            Get SQLFetch of hStmt to iFetchResult
93397>>>>>                            If (iFetchResult <> 0) Begin
93399>>>>>                                Get SQLColumnValue of hStmt 1 to sValue
93400>>>>>                                Move (Trim(sValue)) to sReturnArray[SizeOfArray(sReturnArray)
93401>>>>>                            End
93401>>>>>>
93401>>>>>                        Until (iFetchResult = 0)
93403>>>>>                        Send SQLClose of hStmt
93404>>>>>                    End
93404>>>>>>
93404>>>>>                End
93404>>>>>>
93404>>>>>                Send SQLDisconnect of hoSQLConnect    
93405>>>>>            End
93405>>>>>>
93405>>>>>        End
93405>>>>>>
93405>>>>>
93405>>>>>        Function_Return sReturnArray
