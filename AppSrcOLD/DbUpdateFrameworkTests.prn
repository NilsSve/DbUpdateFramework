93300>>>>>        tSQLConnection SQLConnection
93300>>>>>        tSQLConnection SQLConnection
93300>>>>>        
93300>>>>>        Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
93301>>>>>        If (SQLConnection.sConnectionString = "") Begin
93303>>>>>            Function_Return sReturnArray
93304>>>>>        End 
93304>>>>>>
93304>>>>>        
93304>>>>>        Move SQLConnection.sSchema      to sDefSchema
93305>>>>>        Move (Uppercase(sDefSchema))    to sDefSchema
93306>>>>>        Get _SqlFindKeyWord CI_SQLTable to sTableKeyWord
93307>>>>>        Get _SqlFindKeyWord CI_SQLSys   to sSysKeyWord
93308>>>>>
93308>>>>>        Get phoCLIHandler to hoSQLHandler             
93309>>>>>        Set psDriverID    of hoSQLHandler to SQLConnection.sDriverID
93310>>>>>        Send Delete_Data  of hoSQLHandler
93311>>>>>
93311>>>>>        Send Ignore_Error of Error_Object_Id CLIERR_LOGIN_UNSUCCESSFUL
93312>>>>>        Get EnumerateTables of hoSQLHandler SQLConnection.sConnectionString to iSize 
93313>>>>>        Move False to Err
93314>>>>>        Decrement iSize
93315>>>>>
93315>>>>>        For iCount from 0 to iSize
93321>>>>>>
93321>>>>>            Get TableName    of hoSQLHandler iCount to sTable
93322>>>>>            Get TableType    of hoSQLHandler iCount to sTableType 
93323>>>>>            Get SchemaName   of hoSQLHandler iCount to sSchema
93324>>>>>            Get TableComment of hoSQLHandler iCount to sComment
93325>>>>>            Move (Trim(sTable)) to sTable
93326>>>>>            If (SQLConnection.sDriverID = DB2_DRV_ID) Begin
93328>>>>>                Move (sTable <> "" and Uppercase(sTableType) = sTableKeyWord and Uppercase(sSchema) = sDefSchema) to bOK
93329>>>>>            End
93329>>>>>>
93329>>>>>            Else Begin
93330>>>>>                Move (sTable <> "" and Uppercase(sTableType) = sTableKeyWord and Uppercase(sSchema) <> sSysKeyWord and Uppercase(sSchema) <> "SYSTOOLS") to bOK
93331>>>>>            End
93331>>>>>>
93331>>>>>            If (bOK = True) Begin
93333>>>>>                Move sTable to sReturnArray[iItem]
93334>>>>>                Increment iItem
93335>>>>>            End
93335>>>>>>
93335>>>>>        Loop
93336>>>>>>
93336>>>>>
93336>>>>>        Send Trap_Error of Error_Object_Id CLIERR_LOGIN_UNSUCCESSFUL
93337>>>>>
93337>>>>>        Function_Return sReturnArray
93338>>>>>    End_Function
93339>>>>>
93339>>>>>    Function _SqlProcedureArrayDAW String sStmt String sArgument Returns String[]
93341>>>>>        String[] sReturnArray  
93342>>>>>        String sValue                         
93342>>>>>        Handle hoSQLHandler hoSQLConnect hStmt    
93342>>>>>        Integer iRetval iCols iFetchResult
93342>>>>>        tSQLConnection SQLConnection
93342>>>>>        tSQLConnection SQLConnection
93342>>>>>        
93342>>>>>        Get phoSQLManager to hoSQLHandler
93343>>>>>        Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
93344>>>>>        Get SqlConnect of hoSQLHandler SQLConnection.sDriverID SQLConnection.sConnectionString to hoSQLConnect
93345>>>>>
93345>>>>>        If (hoSQLConnect <> 0) Begin
93347>>>>>            Get SqlOpen of hoSQLConnect to hStmt
93348>>>>>            If (hStmt <> 0) Begin
93350>>>>>                Send SqlSetProcedurename of hStmt sStmt 
93351>>>>>                If (sArgument <> "") Begin
93353>>>>>                    Send SqlSetArgument  of hStmt 1 sArgument
93354>>>>>                End
93354>>>>>>
93354>>>>>                            
93354>>>>>                Send SqlCall             of hStmt      
93355>>>>>                Get SqlReturnValue       of hStmt to iRetval
93356>>>>>                If (iRetval = 0) Begin
93358>>>>>                    Repeat    
93358>>>>>>
93358>>>>>                        Get SqlStmtAttribute of hStmt SqlSTMTATTRIB_COLUMNCOUNT to iCols
93359>>>>>                        If (iCols > 0) Begin 
93361>>>>>                            Repeat
93361>>>>>>
93361>>>>>                                Get SqlFetch of hStmt to iFetchResult
93362>>>>>                                If (iFetchResult <> 0) Begin
93364>>>>>                                    Get SqlColumnValue of hStmt 1 to sValue    
93365>>>>>                                    Move (Trim(sValue)) to sReturnArray[SizeOfArray(sReturnArray)]
93366>>>>>                                End
93366>>>>>>
93366>>>>>                            Until (iFetchResult = 0)
93368>>>>>                        End
93368>>>>>>
93368>>>>>                        Get SqlNextResultSet of hStmt to iRetval
93369>>>>>                    Until (iRetval = 0) 
93371>>>>>                    Send SqlClose of hStmt
93372>>>>>                End
93372>>>>>>
93372>>>>>            End                       
93372>>>>>>
93372>>>>>            Send SqlDisconnect of hoSQLConnect
93373>>>>>        End                                                                         
93373>>>>>>
93373>>>>>        Function_Return sReturnArray
93374>>>>>    End_Function
