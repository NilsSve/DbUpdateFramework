93217>>>>>    Function _SqlProperTableName String sTableName Returns String
93219>>>>>        String sVal sSchema sDriverID sValue
93219>>>>>        Handle hTable  
93219>>>>>        Integer iDbType
93219>>>>>        
93219>>>>>        If (Trim(sTableName) = "") Begin
93221>>>>>            Function_Return ""
93222>>>>>        End
93222>>>>>>
93222>>>>>
93222>>>>>        Get psDriverID to sDriverID
93223>>>>>        Get piDbType   to iDbType
93224>>>>>        If (iDbType = EN_dbTypeOracle) Begin
93226>>>>>            Get psUserID to sSchema
93227>>>>>            // Not sure about this uppercasing but it seems like Oracle wants that?
93227>>>>>            Move (Uppercase(sSchema)) to sSchema
93228>>>>>            Move ('"' + sSchema + '"."' + sTableName + '"') to sTableName
93229>>>>>            Function_Return sTableName
93230>>>>>        End 
93230>>>>>>
93230>>>>>        If (iDbType = EN_DbTypeMySQL) Begin
93232>>>>>            Get psDatabase to sVal
93233>>>>>            Move (sVal + "." + sTableName) to sTableName
93234>>>>>            Function_Return sTableName
93235>>>>>        End 
93235>>>>>>
93235>>>>>        If (iDbType = EN_DbTypePostgre) Begin
93237>>>>>            Move ('"' + sTableName + '"') to sTableName
93238>>>>>            Function_Return sTableName
93239>>>>>        End
93239>>>>>>
93239>>>>>        
93239>>>>>        Get psSchema to sSchema   
93240>>>>>        If (sSchema = "") Begin
93242>>>>>            Get _SqlFindKeyWord CI_SQLDBO to sSchema
93243>>>>>        End
93243>>>>>>
93243>>>>>
93243>>>>>        Move (Uppercase(sTableName)) to sVal
93244>>>>>        If (not(sVal contains (sSchema + "."))) Begin  
93246>>>>>            If (iDbType = EN_dbTypeDB2) Begin
93248>>>>>                Move (Lowercase(sSchema) + "." + sTableName) to sTableName
93249>>>>>            End 
93249>>>>>>
93249>>>>>            Else Begin
93250>>>>>                Move (sSchema + "." + sTableName) to sTableName
93251>>>>>            End
93251>>>>>>
93251>>>>>        End    
93251>>>>>>
93251>>>>>
93251>>>>>        Function_Return sTableName
93252>>>>>    End_Function
93253>>>>>    
93253>>>>>    // SQL column names can be case-sensitive. This function is used to check that
93253>>>>>    // the passed sFieldName has the correct spelling.                            
93253>>>>>    // Used with Embedded SQL statement calls.
93253>>>>>    // If the spelling or fieldname doesn't exist, the return value is "" (blank).
93253>>>>>    Function _SqlFindColumnName String sTableName String sColumnName Returns String
93255>>>>>        String sRetval sValue sConnectionString sDriverID 
93255>>>>>        String[] sColumnNamesArray
93256>>>>>        Integer iCount iColumns
93256>>>>>
93256>>>>>        Move "" to sRetval
93257>>>>>        Get psDriverID to sDriverID
93258>>>>>        Get SqlUtilEnumerateColumns sDriverID sTableName to sColumnNamesArray
93259>>>>>        Move (SizeOfArray(sColumnNamesArray)) to iColumns
93260>>>>>        Decrement iColumns
93261>>>>>        
93261>>>>>        For iCount from 0 to iColumns
93267>>>>>>
93267>>>>>            Move sColumnNamesArray[iCount] to sValue
93268>>>>>            If (Uppercase(sColumnName) = Uppercase(sValue)) Begin
93270>>>>>                Move sValue to sRetval
93271>>>>>                Move iColumns to iCount // We're done.
93272>>>>>            End
93272>>>>>>
93272>>>>>        Loop                           
93273>>>>>>
93273>>>>>        
93273>>>>>        Function_Return sRetval
93274>>>>>    End_Function
