84478>>>>>    // 2013-08-14 NGS
84478>>>>>    // Unformatted numeric values shown doesn't look good. These looks much better.
84478>>>>>    Procedure Show_Systemresources
84480>>>>>        tWinMemoryStatusEx MemoryStatusInfo
84480>>>>>        tWinMemoryStatusEx MemoryStatusInfo
84480>>>>>        Integer iRetval
84480>>>>>        Number nValue
84480>>>>>        String sValue
84480>>>>>
84480>>>>>        Move (SizeOfType (tWinMemoryStatusEx)) to MemoryStatusInfo.dwLength
84481>>>>>        Move (GlobalMemoryStatusEx (AddressOf (MemoryStatusInfo))) to iRetval
84482>>>>>        If (iRetval = 0) Begin
84484>>>>>            Move (ShowLastError ()) to iRetval
84485>>>>>            Procedure_Return
84486>>>>>        End
84486>>>>>>
84486>>>>>
84486>>>>>        Send AppendTextLn ""
84487>>>>>        Move MemoryStatusInfo.ullTotalPhys to nValue
84488>>>>>
84488>>>>>        // Show memory in Gigabytes:
84488>>>>>        Move (nValue/1024/1024/1024) to nValue
84489>>>>>        Move (Round(nValue)) to nValue
84490>>>>>        Get FormatNumber nValue 2 to sValue
84491>>>>>        Send AppendTextLn (SFormat (C_$AvailableMemory, (sValue * "GB")))
84492>>>>>        Send AppendTextLn (SFormat (C_$MemoryUtilization, String(MemoryStatusInfo.dwMemoryLoad) * "%"))
84493>>>>>
84493>>>>>//        Send AppendTextLn (SFormat (C_$AvailablePhysicalMemory, Real (MemoryStatusInfo.ullAvailPhys) / Real (MemoryStatusInfo.ullTotalPhys) * 100.0))
84493>>>>>        Move (Real(MemoryStatusInfo.ullAvailPhys) / Real(MemoryStatusInfo.ullTotalPhys) * 100.0) to nValue
84494>>>>>        Move (Round(nValue)) to nValue
84495>>>>>        Get FormatNumber nValue 0 to sValue
84496>>>>>        Send AppendTextLn (SFormat (C_$AvailablePhysicalMemory, (sValue * "%")))
84497>>>>>
84497>>>>>//        Send AppendTextLn (SFormat (C_$AvailablePagefileSpace, Real (MemoryStatusInfo.ullAvailPageFile) / Real (MemoryStatusInfo.ullTotalPageFile) * 100.0))
84497>>>>>        Move (Real(MemoryStatusInfo.ullAvailPageFile) / Real(MemoryStatusInfo.ullTotalPageFile) * 100.0) to nValue
84498>>>>>        Move (Round(nValue)) to nValue
84499>>>>>        Get FormatNumber nValue 0 to sValue
84500>>>>>        Send AppendTextLn (SFormat (C_$AvailablePagefileSpace, (sValue * "%")))
84501>>>>>
84501>>>>>//        Send AppendTextLn (SFormat (C_$AvailableVirtualMemory, Real (MemoryStatusInfo.ullAvailVirtual) / Real (MemoryStatusInfo.ullTotalVirtual) * 100.0))
84501>>>>>        Move (Real(MemoryStatusInfo.ullAvailVirtual) / Real(MemoryStatusInfo.ullTotalVirtual) * 100.0) to nValue
84502>>>>>        Move (Round(nValue)) to nValue
84503>>>>>        Get FormatNumber nValue 0 to sValue
84504>>>>>        Send AppendTextLn (SFormat (C_$AvailableVirtualMemory, (sValue * "%")))
84505>>>>>
84505>>>>>        // Add an empty row after the memory information:
84505>>>>>        Send AppendTextLn ""
84506>>>>>    End_Procedure
