83018>>>>>>>/// allow null values. When set to true, the column accepts null values. Setting
83018>>>>>>>/// this attribute to false will keep it from accepting null values. Although,
83018>>>>>>>/// getting the value of this attribute can be done at anytime, setting it must
83018>>>>>>>/// be done in a Structure_Start or during table creation.
83018>>>>>>>///
83018>>>>>>>/// @Assumptions
83018>>>>>>>/// @Status      Public
83018>>>>>>>/// @Drivers     All
83018>>>>>>>/// @VersionNote Last Revised: 2013-08-09 by Aaron Gulack
83018>>>>>>>/// @See
83018>>>>>>>/// @INTOPT
83018>>>>>>>///
83018>>>>>>>/// @Syntax Get_Attribute DF_FIELD_NULL of {FileNumber} {FieldNumber} to {variable}
83018>>>>>>>/// @Syntax Set_Attribute DF_FIELD_NULL of {FileNumber} {FieldNumber} to {variable}
83018>>>>>>>/// @Param  FileNumber          Number of the file
83018>>>>>>>/// @Param  FieldNumber                 Number of the Field
83018>>>>>>>/// @Param  variable                    Boolean variable
83018>>>>>>>/// @Example
83018>>>>>>>/// Open Customer
83018>>>>>>>/// Handle hFile
83018>>>>>>>/// Integer iColumn
83018>>>>>>>/// Boolean bAllowNull
83018>>>>>>>///
83018>>>>>>>/// Move Customer.File_Number to hFile
83018>>>>>>>/// Move 3 to iColumn
83018>>>>>>>///
83018>>>>>>>/// Structure_Start hFile "ORA_DRV"
83018>>>>>>>///    Set_Attribute DF_FIELD_NULL of hFile iColumn to True
83018>>>>>>>/// Structure_End hFile
83018>>>>>>>///
83018>>>>>>>/// Get_Attribute DF_FIELD_NULL of hFile iColumn to bAllowNull
83018>>>>>>>Define DF_FIELD_NULL                                For (DF_FIELD_NATIVE_LENGTH+10)
83018>>>>>>>
83018>>>>>>>
83018>>>>>>>//=============================================================================
83018>>>>>>>/// @Name        DF_FIELD_NATIVE_TYPE
83018>>>>>>>/// @Description Use this attribute to get or set the Native type for a specific
83018>>>>>>>/// field in a table.  The native type refers to the data type of the field on the
83018>>>>>>>/// SQL backend. Setting this attribute can only be done during table creation or
83018>>>>>>>/// inside of a Structure_Start. When setting this attribute, it is good practice
83018>>>>>>>/// to use the constants mentioned below instead of the integers. For a list of
83018>>>>>>>/// these constants, refer to the sections: "Oracle Data Types", "MySQL Data Types",
83018>>>>>>>/// "PostgreSQL Data Types", and "SQL Server Data Types" included in this document.
83018>>>>>>>/// Note that when getting the value for this attribute, an integer will be returned
83018>>>>>>>/// so these lists of constants can again prove useful.
83018>>>>>>>///
83018>>>>>>>/// @Assumptions
83018>>>>>>>/// @Status      Public
83018>>>>>>>/// @Drivers     All
83018>>>>>>>/// @VersionNote Last Revised: 2013-08-09 by Aaron Gulack
83018>>>>>>>/// @See
83018>>>>>>>/// @INTOPT      FIELD_TYPE
83018>>>>>>>///
83018>>>>>>>/// @Syntax Set_Attribute DF_FIELD_NATIVE_TYPE of {FileNumber} {FieldNumber} to {variable}
83018>>>>>>>/// @Syntax Get_Attribute DF_FIELD_NATIVE_TYPE of {FileNumber} {FieldNumber} to {variable}
83018>>>>>>>/// @Param  FileNumber          Number of the file
83018>>>>>>>/// @Param  FieldNumber         Number of the field
83018>>>>>>>/// @Param  variable                    variable for the native data type
83018>>>>>>>/// @Example
83018>>>>>>>/// open Customer
83018>>>>>>>///
83018>>>>>>>/// Integer iColumn iType
83018>>>>>>>/// Handle hFile
83018>>>>>>>///
83018>>>>>>>/// Move Customer.File_Number to hFile
83018>>>>>>>/// Structure_Start hFile
83018>>>>>>>///     Set_Attribute DF_FIELD_NATIVE_TYPE of hFile iColumn to "eSQLServer_DATE"
83018>>>>>>>///     Get_Attribute DF_FIELD_NATIVE_TYPE of hFile iColumn to iType
83018>>>>>>>///     Structure_End hFile
83018>>>>>>>Define DF_FIELD_NATIVE_TYPE                         For (DF_FIELD_NATIVE_LENGTH+12)
83018>>>>>>>
83018>>>>>>>// Currently Unsupported Attribute (readOnly used by DataFlex 18.0 Studio)
83018>>>>>>>Define DF_FIELD_NATIVE_TYPE_NAME                    For 711
83018>>>>>>>
83018>>>>>>>// Currently Unsupported Attribute
83018>>>>>>>Define DF_FIELD_NATIVE_OFFSET                       For (DF_FIELD_NATIVE_LENGTH+14)
83018>>>>>>>
83018>>>>>>>//=============================================================================
83018>>>>>>>/// @Name        DF_FIELD_AUTO_INCREMENT
83018>>>>>>>/// @Description Auto incrementing is a technique used in Dataflex usually for
83018>>>>>>>/// fields that are set as the unique identifier. Instead of generating a value
83018>>>>>>>/// or manually inserting data into the column, when a field auto increments,
83018>>>>>>>/// the value of the field increases by one (usually) with each record.  This
83018>>>>>>>/// field is used to get or set whether the field uses this technique or not.
83018>>>>>>>/// The attribute, however, can only be set inside of a Structure_Start or during
83018>>>>>>>/// table creation. Getting the attribute's value can be done at anytime. The
83018>>>>>>>/// value is stored as a boolean, either true or false.
83018>>>>>>>///
83018>>>>>>>/// @Assumptions
83018>>>>>>>/// @Status      Public
83018>>>>>>>/// @Drivers     All
83018>>>>>>>/// @VersionNote Last Revised: 2013-08-12 by Aaron Gulack
83018>>>>>>>/// @See
83018>>>>>>>/// @INTOPT      FIELD_AUTOINCREMENT_TYPE
83018>>>>>>>///
83018>>>>>>>/// @Syntax Set_Attribute DF_FIELD_AUTO_INCREMENT of {FileNumber} {FieldNumber} to {variable}
83018>>>>>>>/// @Syntax Get_Attribute DF_FIELD_AUTO_INCREMENT of {FileNumber} {FieldNumber} to {variable}
83018>>>>>>>/// @Param  FileNumber          Number of the file
83018>>>>>>>/// @Param  FieldNumber         Number of the field
83018>>>>>>>/// @Param  variable                    Boolean variable indicating if the field auto increments.
83018>>>>>>>/// @Example
83018>>>>>>>/// open Customer
83018>>>>>>>///
83018>>>>>>>/// Integer iColumn
83018>>>>>>>/// Boolean bIncrement
83018>>>>>>>/// Handle hFile
83018>>>>>>>///
83018>>>>>>>/// Move Customer.File_Number to hFile
83018>>>>>>>///
83018>>>>>>>/// Structure_Start hFile
83018>>>>>>>///     Set_Attribute DF_FIELD_AUTO_INCREMENT of hFile iColumn to True
83018>>>>>>>///     Get_Attribute DF_FIELD_AUTO_INCREMENT of hFile iColumn to bIncrement
83018>>>>>>>///     Structure_End hFile
83018>>>>>>>Define DF_FIELD_AUTO_INCREMENT                      For (DF_FIELD_NATIVE_LENGTH+16)
83018>>>>>>>
83018>>>>>>>//Currently Unsupported Attribute
83018>>>>>>>Define DF_FIELD_GENERATE_ALWAYS                     For (DF_FIELD_NATIVE_LENGTH+18)
83018>>>>>>>
83018>>>>>>>// Currently Unsupported Attribute
83018>>>>>>>Define DF_FIELD_SEND_LONG_DATA                      For 702
83018>>>>>>>
83018>>>>>>>//=============================================================================
