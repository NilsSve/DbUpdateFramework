91951>>>>>    // Enumerate SQL Servers. 
91951>>>>>    // Pass a driver id. Returns a string array.                     
91951>>>>>    // The iDataSourceType (iDatSrcType) parameter is optional and is for the ODBC driver only.
91951>>>>>    // Note: Returns servers for MSSQLDRV; else data-sources on the machine.
91951>>>>>    Function SqlUtilEnumerateServers String sDriverID Integer iDatSrcType Returns String[]
91953>>>>>        String[] sReturnArray
91954>>>>>        Handle hoSQLHandler
91954>>>>>        String sServer
91954>>>>>        Integer iCount iNumItems iDataSourceType
91954>>>>>        Boolean bOK
91954>>>>>        
91954>>>>>        If (num_arguments > 1) Begin
91956>>>>>            Move iDatSrcType to iDataSourceType
91957>>>>>        End                                    
91957>>>>>>
91957>>>>>        
91957>>>>>        Case Begin
91957>>>>>            Case (sDriverID = MSSQLDRV_ID) 
91959>>>>>                Get phoMSSQLHandler to hoSQLHandler
91960>>>>>                    Get EnumerateServersLocal of hoSQLHandler to iNumItems
91961>>>>>                    If (iNumItems = 0) Begin
91963>>>>>                        Get EnumerateServers of hoSQLHandler to iNumItems
91964>>>>>                    End            
91964>>>>>>
91964>>>>>                For iCount from 0 to (iNumItems - 1)
91970>>>>>>
91970>>>>>                    Get String_Value of hoSQLHandler item iCount to sServer
91971>>>>>                    Move (Trim(sServer)) to sReturnArray[iCount]
91972>>>>>                Loop
91973>>>>>>
91973>>>>>                Case Break 
91974>>>>>    
91974>>>>>            Case (sDriverID = DB2_DRV_ID) 
91977>>>>>                Get phoDB2SQLHandler to hoSQLHandler
91978>>>>>                Send SeedDataSources of hoSQLHandler          
91979>>>>>                Move 0 to iCount
91980>>>>>                Repeat
91980>>>>>>
91980>>>>>                    Get DataSources of hoSQLHandler to sServer
91981>>>>>                    If (sServer <> "") Begin   
91983>>>>>                        Move (Replace(",", sServer, "")) to sServer
91984>>>>>                        Move sServer to sReturnArray[iCount]
91985>>>>>                    End
91985>>>>>>
91985>>>>>                    Increment iCount    
91986>>>>>                Until (sServer = "")
91988>>>>>                Case Break
91989>>>>>    
91989>>>>>            Case (sDriverID = ODBC_DRV_ID) 
91992>>>>>                Get phoODBCSQLHandler to hoSQLHandler
91993>>>>>                Set DataSourceType of hoSQLHandler to iDataSourceType       
91994>>>>>                Move 0 to iCount
91995>>>>>                Repeat
91995>>>>>>
91995>>>>>                    Get DataSources of hoSQLHandler to sServer
91996>>>>>                    If (sServer <> "") Begin   
91998>>>>>                        Move (Replace(",", sServer, ", ")) to sServer
91999>>>>>                        Move sServer to sReturnArray[iCount]
92000>>>>>                    End
92000>>>>>>
92000>>>>>                    Increment iCount    
92001>>>>>                Until (sServer = "")
92003>>>>>                Case Break    
92004>>>>>            
92004>>>>>            Case (sDriverID = SQLFLEX)  
92007>>>>>                Get _MertechEnumerateSQLFlexServers to sReturnArray
92008>>>>>                Case Break
92009>>>>>            
92009>>>>>            Case (sDriverID = ORAFLEX)          
92012>>>>>                Get _MertechEnumerateORAFLEXServers to sReturnArray
92013>>>>>                Case Break
92014>>>>>            
92014>>>>>            // There appearantly is no way to enumerate servers for this backend.
92014>>>>>            Case (sDriverID = MDSPgSQL)
92017>>>>>                Move "localhost" to sReturnArray[0]
92018>>>>>                Case Break
92019>>>>>            
92019>>>>>            // There appearantly is no way to enumerate servers for this backend.
92019>>>>>            Case (sDriverID = MDSMySQL)
92022>>>>>                Move "localhost" to sReturnArray[0]
92023>>>>>                Case Break
92024>>>>>            
92024>>>>>            Case Else
92024>>>>>                Error DFERR_PROGRAM "Unsupported DriverID passed to SqlUtilEnumerateServers function"
92025>>>>>>
92025>>>>>        Case End
92025>>>>>
92025>>>>>        Function_Return sReturnArray
92026>>>>>    End_Function
92027>>>>>    
92027>>>>>    // Returns all databases as a string array for the passed driver id.
92027>>>>>    Function SqlUtilEnumerateDatabases String sDriverID Returns String[]
92029>>>>>        String[] sReturnArray                                                    
92030>>>>>        String sUserID sPassword 
92030>>>>>        Boolean bOK
92030>>>>>        
92030>>>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
