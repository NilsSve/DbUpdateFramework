85250>>>>>    // finds the target seed value in the updatecolumn. If we autoseed and there is a
85250>>>>>    // seed value (psSeedValue), attempt to find GE that value, else move to first row
85250>>>>>    // Suitable for augmentation
85250>>>>>    Procedure OnSeedData
85252>>>>>        Integer iUpdateColumn iSortColumn
85252>>>>>        Boolean bSeed bAuto
85252>>>>>        String sValue
85252>>>>>        Handle hoCol
85252>>>>>
85252>>>>>        Get piUpdateColumn to iUpdateColumn
85253>>>>>        Get psSeedValue to sValue
85254>>>>>        Get pbAutoSeed to bSeed
85255>>>>>        Get piSortColumn to iSortColumn
85256>>>>>        Get pbAutoOrdering to bAuto
85257>>>>>        // if not yet sorted and this is auto ordering we will
85257>>>>>        // sort the data for the search column. We do this to make the
85257>>>>>        // column search GE logic work properly. 
85257>>>>>        If (bSeed and bAuto and iUpdateColumn<>-1 and iSortColumn<>iUpdateColumn) Begin
85259>>>>>            Get ColumnObject iUpdateColumn to hoCol
85260>>>>>            Send SortGridByColumn hoCol False
85261>>>>>        End
85261>>>>>>
85261>>>>>
85261>>>>>        If (bSeed and sValue<>"" and iUpdateColumn<>-1) Begin
85263>>>>>            Send RequestFindColumnValue iUpdateColumn sValue True 0  
85264>>>>>        End
85264>>>>>>
85264>>>>>        Else Begin
85265>>>>>            Send MovetoFirstRow
85266>>>>>        End
85266>>>>>>
85266>>>>>
85266>>>>>    End_Function
