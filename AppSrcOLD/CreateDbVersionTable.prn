91112>>>>>>>>>use VDFBase.pkg
91112>>>>>>>>>
91112>>>>>>>>>Class cFormatter is an cObject
91113>>>>>>>>>
91113>>>>>>>>>    Procedure Construct_object
91115>>>>>>>>>        Integer iCh
91115>>>>>>>>>        forward send construct_object
91117>>>>>>>>>        Property String  psCurrencySymbol
91118>>>>>>>>>        Set psCurrencySymbol to (Default_Currency_Symbol())
91119>>>>>>>>>
91119>>>>>>>>>        Property string  psLeft
91120>>>>>>>>>        Property string  psright
91121>>>>>>>>>        Property integer pbThousandsSep
91122>>>>>>>>>        Property integer piPoints
91123>>>>>>>>>
91123>>>>>>>>>        Property string  psCurPosLeft
91124>>>>>>>>>        Property string  psCurPosright
91125>>>>>>>>>        Property integer pbCurPosThousandsSep
91126>>>>>>>>>        Property integer piCurPosPoints
91127>>>>>>>>>
91127>>>>>>>>>        Property string  psCurNegLeft
91128>>>>>>>>>        Property string  psCurNegright
91129>>>>>>>>>        Property integer pbCurNegThousandsSep
91130>>>>>>>>>        Property integer piCurNegPoints
91131>>>>>>>>>
91131>>>>>>>>>        Property string  psNumPosLeft
91132>>>>>>>>>        Property string  psNumPosright
91133>>>>>>>>>        Property integer pbNumPosThousandsSep
91134>>>>>>>>>        Property integer piNumPosPoints
91135>>>>>>>>>
91135>>>>>>>>>        Property string  psNumNegLeft
91136>>>>>>>>>        Property string  psNumNegright
91137>>>>>>>>>        Property integer pbNumNegThousandsSep
91138>>>>>>>>>        Property integer piNumNegPoints
91139>>>>>>>>>
91139>>>>>>>>>        Send SetFormat "$,#.##;($,#.##)" true  // currency
91140>>>>>>>>>        Send SetFormat  ",#.*"           false // numeric
91141>>>>>>>>>
91141>>>>>>>>>    end_procedure
91142>>>>>>>>>
91142>>>>>>>>>    // internal
91142>>>>>>>>>    // parse passed format string and set temporary properties with result
91142>>>>>>>>>    //
91142>>>>>>>>>    Procedure ParseFormat string sFmt
91144>>>>>>>>>
91144>>>>>>>>>        string sLeft sRight sDigit
91144>>>>>>>>>        integer bSep iPos i iDigits
91144>>>>>>>>>
91144>>>>>>>>>        // replace any literals. A "/" followed by anything.
91144>>>>>>>>>        // some literals are special. $ . , / #
91144>>>>>>>>>        Move (Replaces("/$",sFmt,Character(1)))    to sFmt
91145>>>>>>>>>        Move (Replaces("/.",sFmt,Character(2)))    to sFmt
91146>>>>>>>>>        Move (Replaces("/,",sFmt,Character(3)))    to sFmt
91147>>>>>>>>>        Move (Replaces("/"+"/",sFmt,Character(4))) to sFmt
91148>>>>>>>>>        Move (Replaces("/#",sFmt,Character(5)))    to sFmt
91149>>>>>>>>>        Move (Character(9)) to sDigit
91150>>>>>>>>>        Move (Replaces("#",sFmt,sDigit))           to sFmt
91151>>>>>>>>>        Move (Replaces("/",sFmt,""))               to sFmt // replace all others
91152>>>>>>>>>
91152>>>>>>>>>        Move (Pos(",",sFmt))                 to bSep // if we have any , we use thousand seps
91153>>>>>>>>>        If bSep Move (Replaces(",",sFmt,"")) to sFmt // remove all ,
91156>>>>>>>>>
91156>>>>>>>>>        Move (Replaces("$",sFmt,psCurrencySymbol(self))) to sFmt // replace any $ with currency symbol
91157>>>>>>>>>
91157>>>>>>>>>        Move (Pos(".",sFmt)) to iPos                 // position of decimal
91158>>>>>>>>>
91158>>>>>>>>>        // Move all the special literals back into place before parsing
91158>>>>>>>>>        Move (Replaces(Character(1),sFmt,"$")) to sFmt
91159>>>>>>>>>        Move (Replaces(Character(2),sFmt,".")) to sFmt
91160>>>>>>>>>        Move (Replaces(Character(3),sFmt,",")) to sFmt
91161>>>>>>>>>        Move (Replaces(Character(4),sFmt,"/")) to sFmt
91162>>>>>>>>>        Move (Replaces(Character(5),sFmt,"#")) to sFmt
91163>>>>>>>>>
91163>>>>>>>>>        If (iPos>0) Begin                      // if we have a decimanl point
91165>>>>>>>>>            Move 1 to i                        // look for first non # to right and count the #s
91166>>>>>>>>>            If (mid(sFmt,1,iPos+i)="*") Begin  // the "*" is special. It means as many as you want
91168>>>>>>>>>               Move -2 to iDigits
91169>>>>>>>>>               increment i
91170>>>>>>>>>            end
91170>>>>>>>>>>
91170>>>>>>>>>            While (mid(sFmt,1,iPos+i)=sDigit)
91174>>>>>>>>>                 Increment i
91175>>>>>>>>>            end
91176>>>>>>>>>>
91176>>>>>>>>>            Move (Mid(sFmt,255,iPos+i)) to sRight // everything to the right of the last # is format stuff
91177>>>>>>>>>            If (iDigits=0) Move (i-1) to iDigits
91180>>>>>>>>>            //
91180>>>>>>>>>            Move 1 to i                           // find the first non-# to the left of the point
91181>>>>>>>>>            While (mid(sFmt,1,iPos-i)=sDigit)     // everything to the left is format stuff
91185>>>>>>>>>                 increment i
91186>>>>>>>>>            end
91187>>>>>>>>>>
91187>>>>>>>>>            Move (left(sFmt,iPos-i)) to sLeft
91188>>>>>>>>>        end
91188>>>>>>>>>>
91188>>>>>>>>>        else begin                             // we have no decinal
91189>>>>>>>>>            Move 0 to iDigits                  // so points is none
91190>>>>>>>>>            Move (Pos(sDigit,sFmt)) to iPos    // find first #.
91191>>>>>>>>>            If (iPos=0) Begin                  // if none, entire string is left format stuff..wierd!
91193>>>>>>>>>                Move sFmt to sLeft
91194>>>>>>>>>                Move ""   to sRight
91195>>>>>>>>>            end
91195>>>>>>>>>>
91195>>>>>>>>>            else begin
91196>>>>>>>>>                Move (left(sFmt,iPos-1)) to sLeft // all char to left of first # is left format stuff
91197>>>>>>>>>                Move 1 to i
91198>>>>>>>>>                While (mid(sFmt,1,iPos+i)=sDigit) // find last #, all char to right is right format
91202>>>>>>>>>                    Increment i
91203>>>>>>>>>                end
91204>>>>>>>>>>
91204>>>>>>>>>                Move (Mid(sFmt,255,i+iPos)) to sRight
91205>>>>>>>>>            end
91205>>>>>>>>>>
91205>>>>>>>>>        end
91205>>>>>>>>>>
91205>>>>>>>>>        // set temporary format properties and exit
91205>>>>>>>>>        Set pbThousandsSep to bSep
91206>>>>>>>>>        set psLeft         to sLeft
91207>>>>>>>>>        set psRight        to sRight
91208>>>>>>>>>        Set piPoints       to iDigits
91209>>>>>>>>>     End_procedure
91210>>>>>>>>>
91210>>>>>>>>>    // Public: Sets a format string. Pass full format for Positve and negative in sFmt. Pass
91210>>>>>>>>>    //         bCurrency true is this is a currency format, false if a numeric format
91210>>>>>>>>>    //
91210>>>>>>>>>    //  e.g. Send SetFormat "$,#.##;($,#.##)" True
91210>>>>>>>>>    //
91210>>>>>>>>>    Procedure SetFormat string sFmt integer bCurrency
91212>>>>>>>>>        string sPos sNeg
91212>>>>>>>>>        integer iPos
91212>>>>>>>>>
91212>>>>>>>>>        Move (Pos(";",sFmt)) to iPos
91213>>>>>>>>>        If iPos begin
91215>>>>>>>>>            Move (left(sFmt,iPos-1))    to sPos
91216>>>>>>>>>            Move (mid(sFmt,255,iPos+1)) to sNeg
91217>>>>>>>>>        end
91217>>>>>>>>>>
91217>>>>>>>>>        else Begin
91218>>>>>>>>>            Move sFmt         to sPos
91219>>>>>>>>>            Move ("-" + sFmt) to sNeg
91220>>>>>>>>>        end
91220>>>>>>>>>>
91220>>>>>>>>>        Send ParseFormat sPos
91221>>>>>>>>>        If bCurrency begin
91223>>>>>>>>>            Set pbCurPosThousandsSep to (pbThousandsSep(self))
91224>>>>>>>>>            set psCurPosLeft         to (psLeft(self))
91225>>>>>>>>>            set psCurPosRight        to (psRight(self))
91226>>>>>>>>>            Set piCurPosPoints       to (piPoints(self))
91227>>>>>>>>>        End
91227>>>>>>>>>>
91227>>>>>>>>>        else Begin
91228>>>>>>>>>            Set pbNumPosThousandsSep to (pbThousandsSep(self))
91229>>>>>>>>>            set psNumPosLeft         to (psLeft(self))
91230>>>>>>>>>            set psNumPosRight        to (psRight(self))
91231>>>>>>>>>            Set piNumPosPoints       to (piPoints(self))
91232>>>>>>>>>        end
91232>>>>>>>>>>
91232>>>>>>>>>
91232>>>>>>>>>        Send ParseFormat sNeg
91233>>>>>>>>>        If bCurrency begin
91235>>>>>>>>>            Set pbCurNegThousandsSep to (pbThousandsSep(self))
91236>>>>>>>>>            set psCurNegLeft         to (psLeft(self))
91237>>>>>>>>>            set psCurNegRight        to (psRight(self))
91238>>>>>>>>>            Set piCurNegPoints       to (piPoints(self))
91239>>>>>>>>>        End
91239>>>>>>>>>>
91239>>>>>>>>>        else Begin
91240>>>>>>>>>            Set pbNumNegThousandsSep to (pbThousandsSep(self))
91241>>>>>>>>>            set psNumNegLeft         to (psLeft(self))
91242>>>>>>>>>            set psNumNegRight        to (psRight(self))
91243>>>>>>>>>            Set piNumNegPoints       to (piPoints(self))
91244>>>>>>>>>        end
91244>>>>>>>>>>
91244>>>>>>>>>    End_procedure
91245>>>>>>>>>
91245>>>>>>>>>    // low level formatting. Pass parameters
91245>>>>>>>>>    Function Format_Num number nNumber integer iPoints integer bSep ;                       string sPrefix string sSuffix returns string
91247>>>>>>>>>        string  sLeft sRight sNumber sSep sDec
91247>>>>>>>>>        integer bIsNegative iDec iLen iCh
91247>>>>>>>>>
91247>>>>>>>>>        Get_Attribute DF_DECIMAL_SEPARATOR to iCh
91250>>>>>>>>>        Move (Character(iCh)) to sDec
91251>>>>>>>>>
91251>>>>>>>>>        Move (abs(nNumber)) to sNumber
91252>>>>>>>>>        Move (Pos(sDec,sNumber)) to iDec
91253>>>>>>>>>        Move (If(iDec=0, sNumber, left(sNumber,iDec-1))) to sLeft
91254>>>>>>>>>        Move (If(iDec=0, "", mid(sNumber,255,iDec+1)))   to sRight
91255>>>>>>>>>        // format for decimal separator
91255>>>>>>>>>        If (iPoints>=0) ; // if -2, leave it alone, it should not be -1            Move (left(sRight+repeat("0",iPoints),iPoints)) to sRight
91258>>>>>>>>>
91258>>>>>>>>>        // format for thousand sep.
91258>>>>>>>>>        If bSep Begin
91260>>>>>>>>>            Get_Attribute DF_THOUSANDS_SEPARATOR to iCh
91263>>>>>>>>>            Move (Character(iCh)) to sSep
91264>>>>>>>>>            Move (Length(sLeft)) to iLen
91265>>>>>>>>>            While (iLen>3)
91269>>>>>>>>>                Move (insert(sSep,sLeft,iLen-2)) to sLeft
91270>>>>>>>>>                Move (iLen-3) to iLen
91271>>>>>>>>>            End
91272>>>>>>>>>>
91272>>>>>>>>>        End
91272>>>>>>>>>>
91272>>>>>>>>>        // if decimal points or -2 (allow anything) and there are points to show
91272>>>>>>>>>        If (iPoints>0 OR (iPoints=-2 AND sRight<>"")) ;            Move (sLeft + sDec + sright) to sLeft
91275>>>>>>>>>        Function_return (sPrefix + sLeft+ sSuffix)
91276>>>>>>>>>    End_Function
91277>>>>>>>>>
91277>>>>>>>>>    // Public: Format for currency
91277>>>>>>>>>    //
91277>>>>>>>>>    Function FormatCur number nNumber integer iPoints returns string
91279>>>>>>>>>        string  sLeft sRight
91279>>>>>>>>>        integer bSep
91279>>>>>>>>>        If (nNumber<0) Begin
91281>>>>>>>>>            get pbCurNegThousandsSep to bSep
91282>>>>>>>>>            get psCurNegLeft         to sLeft
91283>>>>>>>>>            get psCurNegRight        to sRight
91284>>>>>>>>>            If (iPoints=-1) get piCurNegPoints       to iPoints
91287>>>>>>>>>        end
91287>>>>>>>>>>
91287>>>>>>>>>        Else Begin
91288>>>>>>>>>            get pbCurPosThousandsSep to bSep
91289>>>>>>>>>            get psCurPosLeft         to sLeft
91290>>>>>>>>>            get psCurPosRight        to sRight
91291>>>>>>>>>            If (iPoints=-1) get piCurPosPoints       to iPoints
91294>>>>>>>>>        end
91294>>>>>>>>>>
91294>>>>>>>>>        Function_return (Format_Num(self, nNumber,iPoints,bSep,sLeft,sRight))
91295>>>>>>>>>    End_function
91296>>>>>>>>>
91296>>>>>>>>>    // Public: Format for numeric
91296>>>>>>>>>    //
91296>>>>>>>>>    Function FormatNum number nNumber integer iPoints returns string
91298>>>>>>>>>        string  sLeft sRight
91298>>>>>>>>>        integer bSep
91298>>>>>>>>>        If (nNumber<0) Begin
91300>>>>>>>>>            get pbNumNegThousandsSep to bSep
91301>>>>>>>>>            get psNumNegLeft         to sLeft
91302>>>>>>>>>            get psNumNegRight        to sRight
91303>>>>>>>>>            If (iPoints=-1) get piNumNegPoints       to iPoints
91306>>>>>>>>>        end
91306>>>>>>>>>>
91306>>>>>>>>>        Else Begin
91307>>>>>>>>>            get pbNumPosThousandsSep to bSep
91308>>>>>>>>>            get psNumPosLeft         to sLeft
91309>>>>>>>>>            get psNumPosRight        to sRight
91310>>>>>>>>>            If (iPoints=-1) get piNumPosPoints       to iPoints
91313>>>>>>>>>        end
91313>>>>>>>>>>
91313>>>>>>>>>        Function_return (Format_Num(self, nNumber,iPoints,bSep,sLeft,sRight))
91314>>>>>>>>>    End_function
91315>>>>>>>>>
91315>>>>>>>>>
91315>>>>>>>>>    // Public: Format passing format string
91315>>>>>>>>>    //
91315>>>>>>>>>    Function FormatVal number nNumber string sFmt returns string
91317>>>>>>>>>        integer iPos bIsNeg
91317>>>>>>>>>        string  sLeft sRight
91317>>>>>>>>>        integer iPoints bSep
91317>>>>>>>>>        Move (nNumber<0) to bIsNeg
91318>>>>>>>>>        Move (Pos(";",sFmt)) to iPos
91319>>>>>>>>>        Case Begin
91319>>>>>>>>>            Case (iPos and Not(bIsNeg))      Move (left(sFmt,iPos-1))    to sFmt
91322>>>>>>>>>            Case (iPos and bIsNeg)           Move (mid(sFmt,255,iPos+1)) to sFmt
91326>>>>>>>>>            Case (not(iPos) and not(bIsNeg)) Move sFmt                   to sFmt
91330>>>>>>>>>            Case else                        Move ("-" + sFmt)           to sFmt
91332>>>>>>>>>        case end
91332>>>>>>>>>        Send ParseFormat sFmt
91333>>>>>>>>>        get pbThousandsSep to bSep
91334>>>>>>>>>        get psLeft         to sLeft
91335>>>>>>>>>        get psRight        to sRight
91336>>>>>>>>>        get piPoints       to iPoints
91337>>>>>>>>>        Function_return (Format_Num(self, nNumber,iPoints,bSep,sLeft,sRight))
91338>>>>>>>>>    end_function
91339>>>>>>>>>
91339>>>>>>>>>End_Class
