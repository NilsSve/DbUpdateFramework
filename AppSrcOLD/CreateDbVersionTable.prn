83176>>>>>    
83176>>>>>    // ************************************        
83176>>>>>    Function SetupSQLConnection Boolean bReadSettings Returns tSQLConnection
83178>>>>>        tSQLConnection SQLConnection 
83178>>>>>        tSQLConnection SQLConnection 
83178>>>>>        
83178>>>>>        // If this object was created by the cDbUpdateHandler class we will
83178>>>>>        // deferr reading SQL connection values until later.
83178>>>>>        If (bReadSettings = True) Begin
83180>>>>>            // This is the new SQL login logic for DF 19 and up; "Managed Connections"
83180>>>>>            If (ghoConnection > 0) Begin
83182>>>>>                Get ReadcConnections to SQLConnection
83183>>>>>            End
83183>>>>>>
83183>>>>>            
83183>>>>>            // In addition to the above; there might be other values set even if a cConnection
83183>>>>>            // object is used.
83183>>>>>            Get ReadSQLConnectionsIniSettings to SQLConnection
83184>>>>>        End     
83184>>>>>>
83184>>>>>        
83184>>>>>        Function_Return SQLConnection
83185>>>>>    End_Function
83186>>>>>    
83186>>>>>    // This is for the new cConnection class used by DF 19 and up (only).
83186>>>>>    Function ReadcConnections Returns tSQLConnection
83188>>>>>        tConnection Connection                 
83188>>>>>        tConnection Connection                 
83188>>>>>        tSQLConnection SQLConnection SQLConnectionEmpty
83188>>>>>        tSQLConnection SQLConnection SQLConnectionEmpty
83188>>>>>        Integer iCount iSize iRetval iDbType
83188>>>>>        Boolean bOK bEnabled bConnected bVal
83188>>>>>        String sConnectionID sSchema
83188>>>>>        
83188>>>>>            // - If the DF 19 cConnection class has been used in the cApplication object
83188>>>>>            // - and there are multiple connection id's defined for the same driver. This is
83188>>>>>            //   because otherwise we can't possibly know which connection id to use... So
83188>>>>>            //   we then generate an error and abort the program...
83188>>>>>            Get IsSinglecConnection (&sConnectionID) to bOK                                     
83189>>>>>            If (bOK = False) Begin
83191>>>>>                Error DFERR_PROGRAM ("Programming error. The psConnectionID must be set in the cDbUpdateVersion object when a cConnect object is used in the cApplication object, and there are multiple connections defined. Program will now exit!")
83192>>>>>>
83192>>>>>                Abort
83193>>>>>>
83193>>>>>            End  
83193>>>>>>
83193>>>>>            
83193>>>>>            Move 0 to iRetval
83194>>>>>            // DAW DF19 connection info: 
83194>>>>>            // We first check that the connection is OK:  
83194>>>>>            Get ConnectionIdIndex of ghoConnection sConnectionID to iRetval
83195>>>>>            // It might happen that no connection has been setup although the object exists, in case we do nothing.
83195>>>>>            If (iRetval = -1) Begin
83197>>>>>                Function_Return SQLConnectionEmpty
83198>>>>>            End                                 
83198>>>>>>
83198>>>>>
83198>>>>>            If (sConnectionID <> "") Begin
83200>>>>>                Get ConnectionIdInfo of ghoConnection sConnectionID to Connection  
83201>>>>>            End
83201>>>>>>
83201>>>>>            If (Connection.sId = "") Begin
83203>>>>>                Move True to SQLConnectionEmpty.bError
83204>>>>>                Function_Return SQLConnectionEmpty
83205>>>>>            End
83205>>>>>>
83205>>>>>            
83205>>>>>            Move Connection.sId to sConnectionID  
83206>>>>>            Get IsConnectionIdLoggedIn of ghoConnection sConnectionID to bConnected
83207>>>>>    
83207>>>>>            If (bConnected = False) Begin
83209>>>>>                Get LoginConnectionId of ghoConnection to iRetval    
83210>>>>>                If (iRetval <> 0) Begin 
83212>>>>>                    Send UserError CS_DUF_CannotLoginToServer
83213>>>>>                    Send Exit_Application    
83214>>>>>                End
83214>>>>>>
83214>>>>>            End
83214>>>>>>
83214>>>>>            
83214>>>>>            // DUF connection info struct property:
83214>>>>>            Get Private.pSQLConnection                       to SQLConnection   
83215>>>>>            Move True                                        to SQLConnection.bEnabled
83216>>>>>            Move Connection.bTrustedConnection               to SQLConnection.bTrusted
83217>>>>>    
83217>>>>>            // Not used in DUF:
83217>>>>>            // Move Connection.iDriverIndex                    to SQLConnection.iDriverIndex
83217>>>>>    
83217>>>>>            Move (If(Connection.iOptions = 0, False, True))  to SQLConnection.bSilentLogin
83218>>>>>            Move Connection.sConnectionString                to SQLConnection.sConnectionString
83219>>>>>            Move Connection.sDriver                          to SQLConnection.sDriverID
83220>>>>>            Move Connection.sId                              to SQLConnection.sConnectionID
83221>>>>>            Move Connection.sUID                             to SQLConnection.sUserID
83222>>>>>            Move Connection.sPWD                             to SQLConnection.sPassword
83223>>>>>    
83223>>>>>            // Not used in DUF:
83223>>>>>            // Move Connection.sSection to SQLConnection.xxx
83223>>>>>            
83223>>>>>            // The rest of the properties of the SQLConnection struct should have been
83223>>>>>            // setup in the cDbUpdateHandler object, and we should be able to reach them through delegation:
83223>>>>>            If (Connection.sDriver <> ODBC_DRV_ID) Begin
83225>>>>>                Get ParseKeyWord Connection.sString CS_SQLIniServerKeyword to SQLConnection.sServer
83226>>>>>            End
83226>>>>>>
83226>>>>>            If (Connection.sDriver = ODBC_DRV_ID) Begin
83228>>>>>                Get ParseKeyWord Connection.sString CS_SQLIniDSNKeyword    to SQLConnection.sServer
83229>>>>>            End
83229>>>>>>
83229>>>>>            Get ParseKeyWord Connection.sString CS_SQLIniDatabaseKeyword   to SQLConnection.sDatabase  
83230>>>>>            
83230>>>>>            // The DbType is a bit special. If the piDbType has _not_ been setup in object code we try to derave
83230>>>>>            // the value from the driver id:
83230>>>>>            Get SqlUtilDbTypeFromDriver of (phoSQLConnectionIniFile(Self)) Connection.sDriver to SQLConnection.iDbType
83231>>>>>            // ...but in case it has been explicitly set in the object we use that value.
83231>>>>>            Get piDbType                                     to iDbType
83232>>>>>            If (iDbType <> SQLConnection.iDbType) Begin
83234>>>>>                Move iDbType to SQLConnection.iDbType
83235>>>>>            End
83235>>>>>>
83235>>>>>            Get psBaseTableSpace                             to SQLConnection.sBaseTableSpace
83236>>>>>            Get psLongTableSpace                             to SQLConnection.sLongTableSpace
83237>>>>>            Get psIndexTableSpace                            to SQLConnection.sIndexTableSpace
83238>>>>>            Get psSchema                                     to SQLConnection.sSchema
83239>>>>>            
83239>>>>>            // We finally set the struct property to the newly fetched values.
83239>>>>>            Set pSQLConnection to SQLConnection
83240>>>>>        
83240>>>>>        Function_Return SQLConnection
83241>>>>>    End_Function
83242>>>>>    
83242>>>>>    // Returns True if the psConnectionID has been set in the cDbUpateHandler object,
83242>>>>>    // or the DAW cConnect array of registered connection only contains one active/enabled
83242>>>>>    // connection id for a particular driver.
83242>>>>>    // So either the psConnectionID or the psDriverID can have been set in the cDbUpdateHandler
83242>>>>>    // object. We can then match a connection id from the DAW cConnect class array.
83242>>>>>    // Returns False if there are multiple connections that are enabled or the psConnectionID has
83242>>>>>    // been set in the cDbUpdateHandler object but it cannot be found amongst the registered 
83242>>>>>    // connections of the DAW cConnect class.
83242>>>>>    Function IsSinglecConnection String ByRef sConnectionID Returns Boolean
83244>>>>>        tConnection[] ConnIdArray
83244>>>>>        tConnection[] ConnIdArray
83245>>>>>        Integer iCount iSize iConnectionIDCounter
83245>>>>>        Boolean bOK bEnabled bFound
83245>>>>>        String sConnectionID2 sDriverID sDriverConn
83245>>>>>        
83245>>>>>        Move False to bFound
83246>>>>>        If (ghoConnection > 0) Begin           
83248>>>>>            
83248>>>>>            // The property of the cDbUpdateHandler container object
83248>>>>>            Get psDriverID to sDriverID
83249>>>>>            
83249>>>>>            Move 0 to iConnectionIDCounter 
83250>>>>>            // This is the the DAW cConnect array with all registered connection id's.
83250>>>>>                Get ConnectionIDs of ghoConnection to ConnIdArray
83251>>>>>            Move (SizeOfArray(ConnIdArray)) to iSize
83252>>>>>            Decrement iSize
83253>>>>>            For iCount from 0 to iSize
83259>>>>>>
83259>>>>>                Move ConnIdArray[iCount].sDriver to sDriverConn
83260>>>>>                Move ConnIdArray[iCount].sId to sConnectionID2
83261>>>>>                Move (ConnIdArray[iCount].bDisabled = False) to bEnabled    
83262>>>>>                // If no psConnectionID specified in the cDbUpdateHandler, we check if there is a driver
83262>>>>>                // connection in the DAW cConnect object _and_ that there is only one!
83262>>>>>                If (sConnectionID = "") Begin
83264>>>>>                    Move (sDriverID = sDriverConn and bEnabled = True) to bFound 
83265>>>>>                End 
83265>>>>>>
83265>>>>>                Else Begin
83266>>>>>                    If (Uppercase(sConnectionID) = Uppercase(sConnectionID2)) Begin
83268>>>>>                        Move iSize to iCount // Then we've found what we were looking for and we're out of here... 
83269>>>>>                    End
83269>>>>>>
83269>>>>>                End
83269>>>>>>
83269>>>>>                    
83269>>>>>                If (bFound = True) Begin
83271>>>>>                    Increment iConnectionIDCounter
83272>>>>>                End
83272>>>>>>
83272>>>>>            Loop
83273>>>>>>
83273>>>>>            Move (iConnectionIDCounter <= 1 and sDriverConn <> "" and sConnectionID2 <> "") to bFound 
83274>>>>>            If (bFound = True) Begin
83276>>>>>                Move sConnectionID2 to sConnectionID
83277>>>>>            End
83277>>>>>>
83277>>>>>        End 
83277>>>>>>
83277>>>>>        
83277>>>>>        // Special case; a cConnection object has been setup in the cApplication,
83277>>>>>        // but no DFConn.ini record has been created.
83277>>>>>        If (iSize = -1) Begin
83279>>>>>            Move True to bFound
83280>>>>>        End
83280>>>>>>
83280>>>>>            
83280>>>>>        Function_Return bFound
83281>>>>>    End_Function
83282>>>>>    
83282>>>>>    // Send on object creation to read the default connection string settings, and
83282>>>>>    // create a connection to the server.
83282>>>>>    Function ReadSQLConnectionsIniSettings Returns tSQLConnection
83284>>>>>        String sPath sFileName sSection sConnectionString sPassword 
83284>>>>>        Boolean bExists
83284>>>>>        tSQLConnection[] SQLConnectionArray
83284>>>>>        tSQLConnection[] SQLConnectionArray
83285>>>>>        tSQLConnection SQLConnection SQLConnectionEmpty
83285>>>>>        tSQLConnection SQLConnection SQLConnectionEmpty
83285>>>>>        Handle hoIniFile
83285>>>>>        Integer iSize iCount
83285>>>>>        
83285>>>>>        Get psIniFilePath to sPath
83286>>>>>        Get phoSQLConnectionIniFile to hoIniFile
83287>>>>>        If (sPath = "") Begin
83289>>>>>            Get ApplicationPath of hoIniFile to sPath 
83290>>>>>            Set psIniFilePath   of hoIniFile to sPath 
83291>>>>>        End         
83291>>>>>>
83291>>>>>        Get vFolderFormat sPath to sPath
83292>>>>>        Get psIniFileName to sFileName    
83293>>>>>        Get vFilePathExists (sPath + sFileName) to bExists
83294>>>>>//        If (bExists = False) Begin   
83294>>>>>//            Move True to SQLConnection.bError
83294>>>>>//            Function_Return SQLConnectionEmpty 
83294>>>>>//        End                                                         
83294>>>>>        
83294>>>>>        Get SQLIniFileReadConnections of hoIniFile to SQLConnectionArray
83295>>>>>        Move (SizeOfArray(SQLConnectionArray)) to iSize
83296>>>>>        If (iSize = 0) Begin
83298>>>>>            // This may have been set by the "ReadcConnections" function,
83298>>>>>            // if a cConnection object has been setup for DataFlex 19 or later
83298>>>>>            // in the cApplication object.
83298>>>>>            Get pSQLConnection to SQLConnection
83299>>>>>            If (SQLConnection.sConnectionID = "") Begin
83301>>>>>                Function_Return SQLConnectionEmpty
83302>>>>>            End
83302>>>>>>
83302>>>>>            Move SQLConnection to SQLConnectionArray[0]
83303>>>>>        End
83303>>>>>>
83303>>>>>        
83303>>>>>        // The first connection should be the one that is active, but just in case...
83303>>>>>        Decrement iSize
83304>>>>>        For iCount from 0 to iSize
83310>>>>>>
83310>>>>>            Move SQLConnectionArray[iCount] to SQLConnection
83311>>>>>            If (SQLConnection.bEnabled = True) Begin
83313>>>>>                Move iSize to iCount // We've found the enabled item, so we're out of here.
83314>>>>>            End
83314>>>>>>
83314>>>>>        Loop
83315>>>>>>
83315>>>>>
83315>>>>>        Send CreateSQLConnection SQLConnection.sDriverID SQLConnection.sConnectionID ;             SQLConnection.sServer SQLConnection.sDatabase SQLConnection.bTrusted ;             SQLConnection.sUserID SQLConnection.sPassword SQLConnection.bSilentLogin   
83316>>>>>             
83316>>>>>        Set pSQLConnection to SQLConnection 
83317>>>>>        Send AutoSetConnectionID
83318>>>>>        
83318>>>>>        Function_Return SQLConnection
