82844>>>>>>>        Move (Repeat(Character(0), 1024))    to sApplicationFileName
82845>>>>>>>        Move (GetModuleFileName(0, AddressOf(sApplicationFileName), 1024)) to iNumChars
82846>>>>>>>        Move (CString(sApplicationFileName)) to sApplicationFileName
82847>>>>>>>        Move (PathRemoveFileSpec(AddressOf(sApplicationFileName))) to iRetval
82848>>>>>>>        Move (CString(sApplicationFileName)) to sPath
82849>>>>>>>
82849>>>>>>>        Function_Return sPath
82850>>>>>>>    End_Function
