87442>>>                Set_Attribute DF_FIELD_LENGTH of hTable iNew to iLength
87445>>>            End
87445>>>>
87445>>>    
87445>>>            If (iType = DF_BCD) Begin
87447>>>                Set_Attribute DF_FIELD_PRECISION of hTable iNew to iPrecision
87450>>>            End
87450>>>>
87450>>>    
87450>>>            Set_Attribute DF_FIELD_OLD_NUMBER of hTable iNew to iOld
87453>>>        Structure_End hTable
87455>>>        
87455>>>        Function_Return (Err = False)
87456>>>    End_Function
