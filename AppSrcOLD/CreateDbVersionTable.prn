87401>>>    // To move an existing field to another position in a table.
87401>>>    Function ApiColumnMove Handle hTable Integer iOld Integer iNew Returns Boolean
87403>>>        String sColumn sDriverID
87403>>>        Integer iType iLength iPrecision
87403>>>        Boolean bOK
87403>>>        
