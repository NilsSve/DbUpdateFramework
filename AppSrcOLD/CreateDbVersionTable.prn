87952>>>    Function UtilColumnTypePrecisionSize String sDriverID Integer iDbType Integer iDataType Returns Integer
87954>>>        tColumnType RetvalType  
87954>>>        tColumnType RetvalType  
87954>>>        String sValue
87954>>>        Integer iRetval iPos
87954>>>        
87954>>>        Get _UtilColumnType sDriverID iDbType iDataType "" True to RetvalType 
87955>>>        Move RetvalType.sPrecision to sValue
87956>>>        Move (Pos(".", sValue)) to iPos
87957>>>        If (iPos <> 0) Begin
87959>>>            Move (Left(sValue, (iPos -1))) to iRetval
87960>>>        End                                          
87960>>>>
87960>>>        Else Begin
87961>>>            Move sValue to iRetval
87962>>>        End
87962>>>>
87962>>>        Function_Return iRetval
87963>>>    End_Function
87964>>>    
87964>>>    Function UtilColumnTypePrecisionDec String sDriverID Integer iDbType Integer iDataType Returns Integer
87966>>>        tColumnType RetvalType  
87966>>>        tColumnType RetvalType  
87966>>>        String sValue
87966>>>        Integer iRetval iPos
87966>>>        
87966>>>        Get _UtilColumnType sDriverID iDbType iDataType "" True to RetvalType 
87967>>>        Move RetvalType.sPrecision to sValue
87968>>>        Move (Pos(".", sValue)) to iPos
87969>>>        If (iPos = 0) Begin
87971>>>            Function_Return 0
87972>>>        End
87972>>>>
87972>>>        Move (Mid(sValue, 99, (iPos + 1))) to iRetval
87973>>>
87973>>>        Function_Return iRetval
87974>>>    End_Function
87975>>>    
87975>>>    // The default value used for a datatype as specified in the driver int file.
87975>>>    Function UtilDataTypeDefaultValue String sDriverID Integer iDbType Integer iDataType Returns String
87977>>>        String sRetval sServer
87977>>>        tColumnType RetvalType 
87977>>>        tColumnType RetvalType 
87977>>>        Integer iDriver iDataFlexType
87977>>>        Handle hDatabase
87977>>>        
87977>>>        Get _UtilColumnType sDriverID iDbType iDataType "" True to RetvalType 
87978>>>        Move RetvalType.iDataFlexType to iDataFlexType
87979>>>        Get DriverIndex sDriverID to iDriver
87980>>>        Get psServer to sServer
87981>>>        Get SqlUtilDatabaseHandle sDriverID sServer to hDatabase 
87982>>>        If (hDatabase = 0) Begin
87984>>>            Function_Return ""
87985>>>        End                   
87985>>>>
87985>>>        
87985>>>        Case Begin
87985>>>            Case (iDataFlexType = DF_ASCII)
87987>>>                Get_Attribute DF_DATABASE_DEFAULT_DEFAULT_ASCII     of iDriver hDatabase to sRetval
87990>>>                Case Break
87991>>>            Case (iDataFlexType = DF_BCD)
87994>>>                Get_Attribute DF_DATABASE_DEFAULT_DEFAULT_NUMERIC   of iDriver hDatabase to sRetval
87997>>>                Case Break
87998>>>            Case (iDataFlexType = DF_BINARY)
88001>>>                Get_Attribute DF_DATABASE_DEFAULT_DEFAULT_BINARY    of iDriver hDatabase to sRetval
88004>>>                Case Break
88005>>>            Case (iDataFlexType = DF_DATE)
88008>>>                Get_Attribute DF_DATABASE_DEFAULT_DEFAULT_DATE      of iDriver hDatabase to sRetval
88011>>>                Case Break
88012>>>            Case (iDataFlexType = DF_DATETIME)
88015>>>                Get_Attribute DF_DATABASE_DEFAULT_DEFAULT_DATETIME  of iDriver hDatabase to sRetval
88018>>>                Case Break
88019>>>            Case (iDataFlexType = DF_TEXT)
88022>>>                Get_Attribute DF_DATABASE_DEFAULT_DEFAULT_TEXT      of iDriver hDatabase to sRetval
88025>>>                Case Break
88026>>>            Case Else
88026>>>                Move "" to sRetval            
88027>>>        Case End
88027>>>        
88027>>>        Function_Return sRetval
88028>>>    End_Function  
88029>>>    
88029>>>    Function SQLUtilDefaultNullValue String sDriverID Integer iDbType Integer iDataType Returns String
88031>>>        String sNotNull sRetval sDefaultValue
88031>>>        Boolean bOK
88031>>>        
88031>>>        Get IsSQLDriver sDriverID to bOK
88032>>>        If (bOK = False) Begin
88034>>>            Function_Return ""
88035>>>        End                   
88035>>>>
88035>>>        
88035>>>        Get UtilDataTypeDefaultValue sDriverID iDbType iDataType to sDefaultValue
88036>>>        Get _SqlFindKeyWord CI_SQLNotNull to sNotNull
88037>>>        
88037>>>        Case Begin
88037>>>            Case (iDbType = EN_dbTypeMSSQL)
88039>>>                Move ("DEFAULT" * String(sDefaultValue) * String(sNotNull)) to sRetval
88040>>>                Case Break
88041>>>            Case (iDbType = EN_dbTypeMySQL)
88044>>>                Move (String(sNotNull) * "DEFAULT" * String(sDefaultValue)) to sRetval
88045>>>                Case Break
88046>>>            Case (iDbType = EN_dbTypePostgre)
88049>>>                Move (String(sNotNull) * "DEFAULT" * String(sDefaultValue)) to sRetval
88050>>>                Case Break
88051>>>            Case (iDbType = EN_dbTypeDB2)
88054>>>                Move (String(sNotNull))                                     to sRetval
88055>>>                Case Break
88056>>>            
88056>>>            // Seems like Oracle can't handle setting a new column to 'NOT NULL' if the table exists with data(!)
88056>>>            // ToDo: We need to look deeper into how Oracle handles NULL
88056>>>            Case (iDbType = EN_dbTypeOracle)
88059>>>                Move  ""                                                    to sRetval
88060>>>                Case Break                                              
88061>>>
88061>>>            Case Else
88061>>>                Move  ""                                                    to sRetval
88062>>>        Case End        
88062>>>        
88062>>>        Function_Return sRetval
88063>>>    End_Function
88064>>>    
88064>>>    // Returns a struct array with the default column types for the SQL back-end and how they
88064>>>    // are mapped to the standard DataFlex data types. 
88064>>>    // The DataFlex data types are: "ASCII", "BINARY", "DATE", "DATETIME", "NUMERIC" and "TEXT".
88064>>>    Function UtilDefaultSqlTypeMappings String sDriverID Integer iDbType Returns tColumnType
88066>>>        tColumnType[] ColumnTypeArray
88066>>>        tColumnType[] ColumnTypeArray
88067>>>        String sDataType
88067>>>        Integer iDataType iDriverID iCount
88067>>>        
88067>>>        Move 0 to iCount
88068>>>        Get DriverIndex sDriverID to iDriverID
88069>>>
88069>>>        // DF_ASCII       
88069>>>        If (sDriverID = ODBC_DRV_ID) Begin
88071>>>            Get_Attribute DF_DRIVER_MAP_DFASCII_TO_ODBCTYPE of iDriverID to iDataType
88074>>>        End                                                             
88074>>>>
88074>>>        Else Begin
88075>>>            Get_Attribute DF_DRIVER_MAP_DFASCII_TO_SQLTYPE  of iDriverID to iDataType 
88078>>>        End
88078>>>>
88078>>>        Move DF_ASCII    to ColumnTypeArray[iCount].iDataFlexType
88079>>>        Move "ASCII"     to ColumnTypeArray[iCount].sDataFlexType  
88080>>>        Get UtilColumnTypeToString sDriverID iDbType iDataType to sDataType
88081>>>        Move sDataType   to ColumnTypeArray[iCount].sType
88082>>>        Move iDataType   to ColumnTypeArray[iCount].iType
88083>>>        Increment iCount
88084>>>        
88084>>>        // DF_BINARY 
88084>>>        If (sDriverID = ODBC_DRV_ID) Begin
88086>>>            Get_Attribute DF_DRIVER_MAP_DFBINARY_TO_ODBCTYPE of iDriverID to iDataType
88089>>>        End                                                                          
88089>>>>
88089>>>        Else Begin
88090>>>            Get_Attribute DF_DRIVER_MAP_DFBINARY_TO_SQLTYPE  of iDriverID to iDataType
88093>>>        End
88093>>>>
88093>>>        Move DF_BINARY   to ColumnTypeArray[iCount].iDataFlexType
88094>>>        Move "Binary"    to ColumnTypeArray[iCount].sDataFlexType  
88095>>>        Get UtilColumnTypeToString sDriverID iDbType iDataType to sDataType
88096>>>        Move sDataType   to ColumnTypeArray[iCount].sType
88097>>>        Move iDataType   to ColumnTypeArray[iCount].iType
88098>>>        Increment iCount
88099>>>        
88099>>>        // DF_DATE
88099>>>        If (sDriverID = ODBC_DRV_ID) Begin
88101>>>            Get_Attribute DF_DRIVER_MAP_DFDATE_TO_ODBCTYPE of iDriverID to iDataType
88104>>>        End                                                                          
88104>>>>
88104>>>        Else Begin
88105>>>            Get_Attribute DF_DRIVER_MAP_DFDATE_TO_SQLTYPE  of iDriverID to iDataType
88108>>>        End
88108>>>>
88108>>>        Move DF_DATE     to ColumnTypeArray[iCount].iDataFlexType
88109>>>        Move "Date"      to ColumnTypeArray[iCount].sDataFlexType  
88110>>>        Get UtilColumnTypeToString sDriverID iDbType iDataType to sDataType
88111>>>        Move sDataType   to ColumnTypeArray[iCount].sType
88112>>>        Move iDataType   to ColumnTypeArray[iCount].iType
88113>>>        Increment iCount
88114>>>        
88114>>>        // DF_DATETIME
88114>>>        If (sDriverID = ODBC_DRV_ID) Begin
88116>>>            Get_Attribute DF_DRIVER_MAP_DFDATETIME_TO_ODBCTYPE of iDriverID to iDataType
88119>>>        End                                                                          
88119>>>>
88119>>>        Else Begin
88120>>>            Get_Attribute DF_DRIVER_MAP_DFDATETIME_TO_SQLTYPE  of iDriverID to iDataType
88123>>>        End
88123>>>>
88123>>>        Move DF_DATETIME to ColumnTypeArray[iCount].iDataFlexType
88124>>>        Move "DateTime"  to ColumnTypeArray[iCount].sDataFlexType  
88125>>>        Get UtilColumnTypeToString sDriverID iDbType iDataType to sDataType
88126>>>        Move sDataType   to ColumnTypeArray[iCount].sType
88127>>>        Move iDataType   to ColumnTypeArray[iCount].iType
88128>>>        Increment iCount
88129>>>
88129>>>        // DF_NUMERIC
88129>>>        // *** Why is there no DF_DRIVER_MAP available for BCD/Numeric??? ***
88129>>>        // DF_BCD can in SQL be either of "SmallInt", "Int", or "Numeric", but
88129>>>        // we make them here all "Numeric"...
88129>>>//        If (sDriverID = ODBC_DRV_ID) Begin
88129>>>//            Get_Attribute DF_DRIVER_MAP_DFDATE_TO_ODBCTYPE of iDriverID to iDataType
88129>>>//        End                                                                          
88129>>>//        Else Begin
88129>>>//            Get_Attribute DF_DRIVER_MAP_DFDATE_TO_SQLTYPE  of iDriverID to iDataType
88129>>>//        End                        
88129>>>        Move DF_BCD      to ColumnTypeArray[iCount].iDataFlexType
88130>>>        Move "Numeric"   to ColumnTypeArray[iCount].sDataFlexType
88131>>>        Move "Numeric"   to ColumnTypeArray[iCount].sType
88132>>>        Move SQL_NUMERIC to ColumnTypeArray[iCount].iType
88133>>>
88133>>>        // DF_TEXT
88133>>>        If (sDriverID = ODBC_DRV_ID) Begin
88135>>>            Get_Attribute DF_DRIVER_MAP_DFTEXT_TO_ODBCTYPE of iDriverID to iDataType
88138>>>        End                                                                          
88138>>>>
88138>>>        Else Begin
88139>>>            Get_Attribute DF_DRIVER_MAP_DFTEXT_TO_SQLTYPE  of iDriverID to iDataType
88142>>>        End
88142>>>>
88142>>>        Move DF_TEXT     to ColumnTypeArray[iCount].iDataFlexType
88143>>>        Move "Text"      to ColumnTypeArray[iCount].sDataFlexType  
88144>>>        Get UtilColumnTypeToString sDriverID iDbType iDataType to sDataType
88145>>>        Move sDataType   to ColumnTypeArray[iCount].sType
88146>>>        Move iDataType   to ColumnTypeArray[iCount].iType
88147>>>        Increment iCount
88148>>>        
88148>>>        Function_Return ColumnTypeArray
88149>>>    End_Function
