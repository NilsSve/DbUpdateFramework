86121>>>    // Checks that the passed sDriverID is defined.
86121>>>    // Also checks if the driver has been loaded; else it gets loaded.
86121>>>    Function _SqlCheckCurrentDriver String sDriverID Returns Boolean
86123>>>        Boolean bOK                         
86123>>>        Integer iDriver
86123>>>        
86123>>>        If (sDriverID = DATAFLEX_ID) Begin
86125>>>            Function_Return False
86126>>>        End                      
86126>>>>
86126>>>
86126>>>        Get IsDAWSQLDriver sDriverID to bOK
86127>>>
86127>>>        If (bOK = False) Begin
86129>>>            Get IsMertechDriver sDriverID to bOK
86130>>>        End   
86130>>>>
86130>>>        
86130>>>        If (bOK = False) Begin        
86132>>>            Error DFERR_PROGRAM "Driver needs to be one of MSSQLDRV, DB2_DRV, ODBC_DRV, SQLFLEX, ORAFLEX, MDSPgSQL or MDSMySQL"
86133>>>>
86133>>>            Function_Return False
86134>>>        End 
86134>>>>
86134>>>        
86134>>>        Get DriverIndex sDriverID to iDriver
86135>>>        If (iDriver = 0) Begin
86137>>>            Load_Driver sDriverID
86138>>>        End
86138>>>>
86138>>>        
86138>>>        Function_Return True
86139>>>    End_Function
