88304>>>    
88304>>>    // Returns True if the passed hTable (filelist slot number) is an Alias table.
88304>>>    // An Alias file/table is a filelist number that share the same Physical filename
88304>>>    // but which Logical name is different.
88304>>>    // Note: If the table cannot be opened; the table is not considered to be an Alias.
88304>>>    Function UtilTableIsAlias Handle hTable Returns Boolean
88306>>>        String sPhysicalName sPhysicalNameCompare     
88306>>>        Boolean bOpened bOK
88306>>>        
88306>>>        Open hTable
88308>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpened
88311>>>        If (bOpened = False) Begin
88313>>>            Function_Return False
88314>>>        End                      
88314>>>>
88314>>>        
88314>>>        Get_Attribute DF_FILE_PHYSICAL_NAME of hTable to sPhysicalName 
88317>>>        Get _TableNameOnly sPhysicalName to sPhysicalName
88318>>>        Close hTable
88319>>>        
88319>>>        Move 0 to hTable
88320>>>        Repeat
88320>>>>
88320>>>            Get_Attribute DF_FILE_NEXT_USED of hTable to hTable
88323>>>            If (hTable > 0) Begin         
88325>>>                Open hTable
88327>>>                Get_Attribute DF_FILE_OPENED of hTable to bOpened
88330>>>                If (bOpened = True) Begin
88332>>>                    Get_Attribute DF_FILE_PHYSICAL_NAME of hTable to sPhysicalNameCompare 
88335>>>                    Close hTable
88336>>>                    Get _TableNameOnly sPhysicalNameCompare to sPhysicalNameCompare
88337>>>                    If (Uppercase(sPhysicalName) = Uppercase(sPhysicalNameCompare)) Begin
88339>>>                        Function_Return True
88340>>>                    End
88340>>>>
88340>>>                End
88340>>>>
88340>>>            End
88340>>>>
88340>>>        Until (hTable = 0)
88342>>>        
88342>>>        Function_Return False
88343>>>    End_Function
88344>>>    
88344>>>    // To Open a table with any driver.
88344>>>    // Note: If the driver is <> DATAFLEX_ID  - login credentials are used; it is then assumed 
88344>>>    //       that the proper login properties has been setup properly with the cSQLConnections object.
88344>>>    //
88344>>>    // If the open command fails the Err flag will be reset to false, at the end of the function!
88344>>>    // The found flag is still used to indicate if the open was successful or not. The function
88344>>>    // returns a True if successful (table could be opened).
88344>>>    //
88344>>>    // Using the "Open As" syntax with drivers means that we don't need to rely on .int file settings.
88344>>>    // This is good because with DFConnectionID's those credentials doesn't need to be available in
88344>>>    // the .int file (and probably aren't). As long as the login properties of this object have been
88344>>>    // set properly we can open the table.
88344>>>    //
88344>>>    // DAW Driver Syntax:
88344>>>    //  <CKId>:<Schema>#<Table>@<ConnectString>|<Filename>.int
88344>>>    //  Now the @<ConnectString> can be followed by a pipe character '|' followed by the name of the INT file.
88344>>>    //  Doing so, the driver will apply the information from the .INT file to the passed direct Open String.
88344>>>    //  Note that when an INT file has been passed, it will skip the keyword DRIVER_NAME, SERVER_NAME,
88344>>>    //  DATABASE_NAME and SCHEMA_NAME from the INT file because those are supposed to be supplied in the String already. 
88344>>>    //  Open mode; iMode = DF_SHARE or DF_EXCLUSIVE.
88344>>>    //
88344>>>    // DAW Driver Sample:
88344>>>    //   Open "MSSQLDRV:dbo#MyFile@SERVER=(local)\SQLEXPRESS;Trusted_Connection=yes;DATABASE=OrderEntry|options|intfile=MyFile.int"
88344>>>    //
88344>>>    // Mertech Driver Samples:
88344>>>    //   SQLFlex:   Open "sql_drv:\\<serverName>\<database>*<owner>*<tableName>=<numberFieds>" as table 
88344>>>    //   MySQLFlex: Open "mdsmysql:\\<serverName>\<database>*<tableName>=<numberFieds>" as table 
88344>>>    //   PgFlex:    Open "mdspgsql:\\<serverName>\<database>*<schema>*<tableName>=<numberFieds>" as table 
88344>>>    //   ORAFlex:   Open "ora_drv:\\<serverName>\<owner>*<tableName>=<numberFieds>" as table 
88344>>>    Function UtilTableOpen Integer hTable String sTableName Integer iMode Returns Boolean
88346>>>        String sDriverID sConnection sSchema sExt sTableNameShort sTableNameOrg
88346>>>        Boolean bOpen bMertechDriver
88346>>>        Integer iRetval              
88346>>>        tSQLConnection SQLConnection
88346>>>        tSQLConnection SQLConnection
88346>>>
88346>>>        Move sTableName to sTableNameOrg
88347>>>        If (hTable > 0 and Trim(sTableName) = "") Begin
88349>>>            Send Ignore_Error of Error_Object_Id 20529
88350>>>            Send Ignore_Error of Error_Object_Id DFERR_CANT_OPEN_DATA_FILE
88351>>>            Send Ignore_Error of Error_Object_Id CLIERR_CONNECTIONIDNOTFOUND
88352>>>            Open hTable
88354>>>            Send Trap_Error of Error_Object_Id 20529
88355>>>            Send Trap_Error of Error_Object_Id DFERR_CANT_OPEN_DATA_FILE
88356>>>            Send Trap_Error of Error_Object_Id CLIERR_CONNECTIONIDNOTFOUND
88357>>>            Function_Return (Found = True)
88358>>>        End
88358>>>>
88358>>>        
88358>>>        Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
88359>>>        Move SQLConnection.sDriverID to sDriverID
88360>>>        Get IsMertechDriver sDriverID to bMertechDriver
88361>>>        Move SQLConnection.sConnectionString to sConnection
88362>>>        Move SQLConnection.sSchema to sSchema
88363>>>        If (sSchema = "") Begin 
88365>>>            Get _SqlFindKeyWord CI_SQLDBO to sSchema 
88366>>>        End
88366>>>>
88366>>>
88366>>>        // We need to remove the ".int" part of the table name because
88366>>>        // the table name after the "#" in the connection syntax below wants the
88366>>>        // "bare" table name without any extension.
88366>>>        If (sDriverID <> DATAFLEX_ID) Begin
88368>>>            If (Lowercase(sTableName) contains ".int") Begin
88370>>>                Get ParseFileExtension sTableName to sExt
88371>>>                Move (Replace(("." + sExt), sTableName, "")) to sTableNameShort
88372>>>            End                                                                
88372>>>>
88372>>>            Else Begin
88373>>>                Move sTableName to sTableNameShort  
88374>>>                Move (Append(sTableName, ".int")) to sTableName
88375>>>            End   
88375>>>>
88375>>>            If (bMertechDriver = False) Begin
88377>>>                Move (sDriverID + ":" + sSchema + "#" + sTableNameShort + "@" + sConnection + "|options|intfile=" + sTableName) to sConnection
88378>>>                Move sConnection to sTableName
88379>>>            End
88379>>>>
88379>>>        End
88379>>>>
88379>>>
88379>>>        Send Ignore_Error of Error_Object_Id CLIERR_LOGIN_UNSUCCESSFUL
88380>>>        Send Ignore_Error of Error_Info_Object DFERR_FILE_ACCESS_VIOLATION 
88381>>>        If (hTable = 0) Begin
88383>>>            Get NextFreeFilelistSlot to hTable
88384>>>        End
88384>>>>
88384>>>
88384>>>        Case Begin
88384>>>            Case (sDriverID = MSSQLDRV_ID)
88386>>>                // If not df_exclusive mode, we use the "Open As" syntax.
88386>>>                If (iMode <> DF_EXCLUSIVE) Begin
88388>>>                    Open sTableName as hTable
88390>>>                End
88390>>>>
88390>>>                Else Begin
88391>>>                    Open hTable mode DF_Exclusive
88393>>>                End
88393>>>>
88393>>>                Case Break
88394>>>
88394>>>            Case (sDriverID = DB2_DRV_ID)
88397>>>                // If not df_exclusive mode, we use the "Open As" syntax.
88397>>>                If (iMode <> DF_EXCLUSIVE) Begin
88399>>>                    Open sTableName as hTable
88401>>>                End
88401>>>>
88401>>>                Else Begin
88402>>>                    Open hTable mode DF_Exclusive
88404>>>                End
88404>>>>
88404>>>                Case Break
88405>>>
88405>>>            Case (sDriverID = ODBC_DRV_ID)
88408>>>                // If not df_exclusive mode, we use the "Open As" syntax.
88408>>>                If (iMode <> DF_EXCLUSIVE) Begin
88410>>>                    Open sTableName as hTable
88412>>>                End
88412>>>>
88412>>>                Else Begin
88413>>>                    Open hTable mode DF_Exclusive
88415>>>                End
88415>>>>
88415>>>                Case Break 
88416>>>                
88416>>>            Case (sDriverID = SQLFLEX)                                                                               
88419>>>                // ToDo: What is the <owner>? Same as Schema?
88419>>>                // SQLFlex:   Open "sql_drv:\\<serverName>\<database>*<owner>*<tableName>=<numberFieds>" as table 
88419>>>                Move (SQLFLEX + ":\\" + SQLConnection.sServer + "\" + SQLConnection.sDatabase + SQLConnection.sSchema + "*" + sTableNameOrg) to sTableName
88420>>>                // If not df_exclusive mode, we use the "Open As" syntax.
88420>>>                If (iMode <> DF_EXCLUSIVE) Begin
88422>>>                    Open sTableName as hTable
88424>>>                End
88424>>>>
88424>>>                Else Begin
88425>>>                    Open hTable mode DF_Exclusive
88427>>>                End
88427>>>>
88427>>>                Case Break
88428>>>
88428>>>            Case (sDriverID = MDSMySQL)
88431>>>                // MySQLFlex: Open "mdsmysql:\\<serverName>\<database>*<tableName>=<numberFieds>" as table 
88431>>>                Move (MDSMySQL + ":\\" + SQLConnection.sServer + "\" + SQLConnection.sDatabase + "*" + sTableNameOrg) to sTableName
88432>>>                // If not df_exclusive mode, we use the "Open As" syntax.
88432>>>                If (iMode <> DF_EXCLUSIVE) Begin
88434>>>                    Open sTableName as hTable
88436>>>                End
88436>>>>
88436>>>                Else Begin
88437>>>                    Open hTable mode DF_Exclusive
88439>>>                End
88439>>>>
88439>>>                Case Break
88440>>>
88440>>>            Case (sDriverID = MDSPgSQL)
88443>>>                // PgFlex: Open "mdspgsql:\\<serverName>\<database>*<schema>*<tableName>=<numberFieds>" as table 
88443>>>                Move (MDSPgSQL + ":\\" + SQLConnection.sServer + "\" + SQLConnection.sDatabase + "*" + SQLConnection.sSchema + "*" + sTableNameOrg) to sTableName
88444>>>                // If not df_exclusive mode, we use the "Open As" syntax.
88444>>>                If (iMode <> DF_EXCLUSIVE) Begin
88446>>>                    Open sTableName as hTable
88448>>>                End
88448>>>>
88448>>>                Else Begin
88449>>>                    Open hTable mode DF_Exclusive
88451>>>                End
88451>>>>
88451>>>                Case Break
88452>>>
88452>>>            Case (sDriverID = ORAFLEX)
88455>>>                // ToDo: What is the <owner>? Same as Schema?
88455>>>                // ORAFlex: Open "ora_drv:\\<serverName>\<owner>*<tableName>=<numberFieds>" as table 
88455>>>                Move (ORAFLEX + ":\\" + SQLConnection.sServer + "\" + SQLConnection.sSchema + "*" + sTableName) to sTableName
88456>>>                // If not df_exclusive mode, we use the "Open As" syntax.
88456>>>                If (iMode <> DF_EXCLUSIVE) Begin
88458>>>                    Open sTableName as hTable
88460>>>                End
88460>>>>
88460>>>                Else Begin
88461>>>                    Open hTable mode DF_Exclusive
88463>>>                End
88463>>>>
88463>>>                Case Break
88464>>>
88464>>>            Case (sDriverID = DATAFLEX_ID)
88467>>>                If (sTableName <> "" and iMode <> DF_EXCLUSIVE) Begin
88469>>>                    Open sTableName as hTable
88471>>>                End
88471>>>>
88471>>>                Else If (iMode = DF_EXCLUSIVE) Begin
88474>>>                    Open hTable mode DF_Exclusive
88476>>>                End
88476>>>>
88476>>>                Else Begin
88477>>>                    Open hTable
88479>>>                End
88479>>>>
88479>>>                Case Break
88480>>>                
88480>>>            // ToDo: Logic needs to be expanded for Mertech drivers!
88480>>>
88480>>>            Case Else
88480>>>                Error DFERR_PROGRAM ("Invalid driver:" * sDriverID)
88481>>>>
88481>>>        Case End
88481>>>
88481>>>        Send Trap_Error of Error_Object_Id CLIERR_LOGIN_UNSUCCESSFUL 
88482>>>        Send Trap_Error of Error_Info_Object DFERR_FILE_ACCESS_VIOLATION
88483>>>        If (LastErr = CLIERR_LOGIN_UNSUCCESSFUL) Begin
88485>>>            Move False to Found
88486>>>        End
88486>>>>
88486>>>        // If open failed, the Err is set to true,
88486>>>        // but we don't want that because it could end our loop.
88486>>>        Move False to Err
88487>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpen
88490>>>
88490>>>        Function_Return bOpen
88491>>>    End_Function
88492>>>    
88492>>>    // Pass a table handle
88492>>>    // Returns True if the table exists in filelist.cfg.
88492>>>    Function UtilTableNumberIsInUse Handle hCheckTable Returns Boolean
88494>>>        Handle hTable
88494>>>        Boolean bFound
88494>>>        
88494>>>        Move False to bFound
88495>>>        Move 0 to hTable              
88496>>>        Repeat
88496>>>>
88496>>>            Get_Attribute DF_FILE_NEXT_USED of hTable to hTable
88499>>>            If (hTable > 0) Begin
88501>>>                If (hTable = hCheckTable) Begin
88503>>>                    Move True to bFound
88504>>>                End
88504>>>>
88504>>>            End
88504>>>>
88504>>>            If (bFound = True) Break
88507>>>        Until (hTable = 0)
88509>>>    
88509>>>        Function_Return (bFound = True)
88510>>>    End_Function
88511>>>    
88511>>>    Function UtilEnumerateOverlapFields Integer hTable Integer iField Returns String[]
88513>>>        String  sRetval sColumnName
88513>>>        String[] sOverlapFieldsArray
88514>>>        Integer iType iColumn iColumns 
88514>>>        Boolean bOpen bOverlap
88514>>>        
88514>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpen
88517>>>        If (bOpen = False) Begin
88519>>>            Open hTable
88521>>>        End
88521>>>>
88521>>>        
88521>>>        Move "" to sRetval
88522>>>        
88522>>>        Get_Attribute DF_FILE_NUMBER_FIELDS of hTable to iColumns
88525>>>        
88525>>>        for iColumn from 0 to iColumns
88531>>>>
88531>>>            Get_Attribute DF_FIELD_TYPE of hTable iColumn to iType
88534>>>            If (iField <> iColumn and iType <> DF_OVERLAP) Begin
88536>>>                Get_Attribute DF_FIELD_OVERLAP of hTable iField iColumn to bOverlap
88539>>>                If (bOverlap) Begin
88541>>>                    If (sRetval <> "") Begin
88543>>>                        Append sRetval ","
88544>>>                    End
88544>>>>
88544>>>                    Append sRetval iColumn
88545>>>                End
88545>>>>
88545>>>            End
88545>>>>
88545>>>        Loop
88546>>>>
88546>>>        
88546>>>        If (bOpen = False) Begin
88548>>>            Close hTable
88549>>>        End    
88549>>>>
88549>>>        
88549>>>        Move (StrSplitToArray(sRetval, ",")) to sOverlapFieldsArray
88550>>>        
88550>>>        Function_Return sOverlapFieldsArray
88551>>>    End_Function
88552>>>    
88552>>>    // Returns a struct array with all data types for the passed driver & dbtype.
88552>>>    Function UtilEnumerateColumnTypes String sDriverID Integer iDbType Returns tColumnType[]
88554>>>        tColumnType[] ColumnType               
88554>>>        tColumnType[] ColumnType               
88555>>>            
88555>>>        Case Begin
88555>>>            Case (iDbType = EN_dbTypeDataFlex)  
88557>>>                Get _UtilEnumerateDataFlexTypes to ColumnType
88558>>>                Case Break
88559>>>                
88559>>>            Case (iDbType = EN_DbTypeDB2)
88562>>>                Get _UtilEnumerateDB2Types to ColumnType
88563>>>                Case Break
88564>>>                
88564>>>            Case (iDbType = EN_DbTypeMSSQL)
88567>>>                Get _UtilEnumerateMSSQLTypes sDriverID to ColumnType
88568>>>                Case Break
88569>>>            
88569>>>            Case (sDriverID = MDSMySQL)            
88572>>>                Get _UtilEnumerateMySQLTypes to ColumnType
88573>>>                Case Break
88574>>>            
88574>>>            Case (sDriverID = ORAFLEX)
88577>>>                Get _UtilEnumerateOracleTypes to ColumnType
88578>>>                Case Break
88579>>>
88579>>>            Case (sDriverID = MDSPgSQL)   
88582>>>                Get _UtilEnumeratePostgreSQLTypes to ColumnType
88583>>>                Case Break
88584>>>        Case End
88584>>>        
88584>>>        Function_Return ColumnType
88585>>>    End_Function
