85228>>>    // Returns a string array with all table names the passed table handle has relation ships with.
85228>>>    // The format of the array is "TableName.FieldName"
85228>>>    Function SqlUtilEnumerateRelations String sTableName String sDriverID Returns tSQLRelation[]
85230>>>        String[] sFileNameArray sFieldNameArray
85232>>>        tSQLRelation[] sRelationsArray
85232>>>        tSQLRelation[] sRelationsArray
85233>>>        String sServer sConnectionString sSelect sSchema sFileName sFieldName sVal
85233>>>        Boolean bOK  
85233>>>        Integer iCount iSize iLength iPos 
85233>>>        Integer iFileNumber iFieldNumber
85233>>>        
85233>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
85234>>>        If (bOK = False) Begin
85236>>>            Error DFERR_PROGRAM ("Unsupported driver. A list of table columns could not be retrieved for:" * sDriverID + ".")
85237>>>>
85237>>>            Function_Return sRelationsArray
85238>>>        End   
85238>>>>
85238>>>       
85238>>>        Get psConnectionString to sConnectionString  
85239>>>        Get psSchema to sSchema
85240>>>        
85240>>>        Case Begin
85240>>>            Case (sDriverID = MSSQLDRV_ID)    
85242>>>                Move ("SELECT object_name(parent_object_id), object_name(referenced_object_id), name from sys.foreign_keys WHERE parent_object_id = object_id( '" + sTableName + "')") to sSelect
85243>>>                Get SqlEnumerateEsqlDAW sSelect 2 to sFileNameArray
85244>>>                Get SqlEnumerateEsqlDAW sSelect 3 to sFieldNameArray
85245>>>                Case Break
85246>>>
85246>>>            Case (sDriverID = DB2_DRV_ID) 
85249>>>                Error "Not implemented yet! The select statement has not been finalized."
85250>>>>
85250>>>//                Move () to sSelect
85250>>>//                Get SqlEnumerateEsqlDAW sSelect 2 to sReturnArray
85250>>>//                Get SqlEnumerateEsqlDAW sSelect 3 to sFieldNameArray
85250>>>                Case Break
85251>>>
85251>>>            Case (sDriverID = SQLFLEX)
85254>>>                Error "Not implemented yet! The select statement has not been finalized."
85255>>>>
85255>>>//                Move () to sSelect
85255>>>//                Get SqlEnumerateEsqlMertech sSelect 2 to sReturnArray
85255>>>//                Get SqlEnumerateEsqlDAW sSelect 3 to sFieldNameArray
85255>>>                Case Break
85256>>>            
85256>>>            Case (sDriverID = MDSMySQL) 
85259>>>                Error "Not implemented yet! The select statement has not been finalized."
85260>>>>
85260>>>//                Move () to sSelect
85260>>>//                Get SqlEnumerateEsqlMertech sSelect 2 to sReturnArray
85260>>>//                Get SqlEnumerateEsqlDAW sSelect 3 to sFieldNameArray
85260>>>                Case Break
85261>>>            
85261>>>            Case (sDriverID = MDSPgSQL) 
85264>>>                Error "Not implemented yet! The select statement has not been finalized."
85265>>>>
85265>>>//                Move () to sSelect
85265>>>//                Get SqlEnumerateEsqlMertech sSelect 2 to sReturnArray
85265>>>//                Get SqlEnumerateEsqlDAW sSelect 3 to sFieldNameArray
85265>>>                Case Break            
85266>>>            
85266>>>            Case (sDriverID = ORAFLEX) 
85269>>>                Error "Not implemented yet! The select statement has not been finalized."
85270>>>>
85270>>>//                Move () to sSelect
85270>>>//                Get SqlEnumerateEsqlMertech sSelect to sReturnArray
85270>>>//                Get SqlEnumerateEsqlDAW sSelect 3 to sFieldNameArray
85270>>>                Case Break
85271>>>                            
85271>>>            Case Else     
85271>>>                Error DFERR_PROGRAM "Unsupported driver passed to the SqlUtilEnumerateRelations function."
85272>>>>
85272>>>                Case Break
85273>>>        Case End   
85273>>>        
85273>>>        Move (Length(sTableName)) to iLength
85274>>>        Move (iLength + 4)        to iLength // The related to field key has the format "FK_TableName + FieldName"
85275>>>        Move (SizeOfArray(sFileNameArray)) to iSize
85276>>>        Decrement iSize
85277>>>        For iCount from 0 to iSize
85283>>>>
85283>>>            If (Trim(sFileNameArray[iCount]) <> "") Begin
85285>>>                Move sFileNameArray[iCount]         to sFileName 
85286>>>                Move sFieldNameArray[iCount]        to sFieldName
85287>>>                Move (Mid(sFieldName, 99, iLength)) to sFieldName
85288>>>                Move sFileName  to sRelationsArray[iCount].sFileName
85289>>>                Move sFieldName to sRelationsArray[iCount].sFieldName
85290>>>            End
85290>>>>
85290>>>        Loop
85291>>>>
85291>>>        
85291>>>        Function_Return sRelationsArray
85292>>>    End_Function  
85293>>>    
85293>>>    Function SqlUtilEnumerateLoggedInUsers String sDriverID String sDatabase Returns tSQLLoggedInUser[]
85295>>>        tSQLLoggedInUser[] SQLLoggedInUser
85295>>>        tSQLLoggedInUser[] SQLLoggedInUser
85296>>>        String[] sUsers sPrograms
85298>>>        String sSelect 
85298>>>        Integer iSize iCount
85298>>>        
85298>>>        Case Begin
85298>>>            Case (sDriverID = MSSQLDRV_ID)
85300>>>                Move ("SELECT RTRIM(SP.nt_username) AS Inlog, RTRIM(SP.program_name) as Programma from master.dbo.sysprocesses SP INNER JOIN master.dbo.sysdatabases SD ON SP.dbid = SD.dbid WHERE (SP.nt_username <> '') and (SP.nt_username <> 'SYSTEM') and (SD.name = '" ;                + sDatabase + "') ORDER by Inlog") to sSelect
85301>>>                Get SqlEnumerateEsqlDAW sSelect 1 to sUsers
85302>>>                Get SqlEnumerateEsqlDAW sSelect 2 to sPrograms
85303>>>                Case Break
85304>>>            Case (sDriverID = SQLFLEX)
85307>>>                Move ("SELECT RTRIM(SP.nt_username) AS Inlog, RTRIM(SP.program_name) as Programma from master.dbo.sysprocesses SP INNER JOIN master.dbo.sysdatabases SD ON SP.dbid = SD.dbid WHERE (SP.nt_username <> '') and (SP.nt_username <> 'SYSTEM') and (SD.name = '" ;                + sDatabase + "') ORDER by Inlog") to sSelect
85308>>>                Get SqlEnumerateEsqlMertech sSelect 1 to sUsers
85309>>>                Get SqlEnumerateEsqlMertech sSelect 2 to sPrograms
85310>>>                Case Break                 
85311>>>            Case Else
85311>>>                Error DFERR_PROGRAM ("Not implemented yet for this driver (" + sDriverID + ")")
85312>>>>
85312>>>        Case End
85312>>>        
85312>>>        Move (SizeOfArray(sUsers)) to iSize
85313>>>        Decrement iSize
85314>>>        For iCount from 0 to iSize
85320>>>>
85320>>>            Move sUsers[iCount]    to SQLLoggedInUser[iCount].sUser
85321>>>            Move sPrograms[iCount] to SQLLoggedInUser[iCount].sProgram
85322>>>        Loop
85323>>>>
85323>>>        
85323>>>        Function_Return SQLLoggedInUser
85324>>>    End_Function 
85325>>>    
85325>>>    // Returns an array with all ".int" files for the passed sDataPath, _except_ for the driver .int files;
85325>>>    // "MSSQLDRV.int", "DB2_DRV.int" & "ODBC_DRV.int".
85325>>>    Function SqlUtilEnumerateIntFiles String sDataPath Returns String[]
85327>>>        String[] sFilesData
85328>>>        Boolean bExists
85328>>>        Integer iCh
85328>>>        String sFileName sExt
85328>>>        
85328>>>        Get vFolderExists sDataPath to bExists
85329>>>        If (bExists = True) Begin
85331>>>            Move (ToANSI(Trim(sDataPath))) to sDataPath
85332>>>            Move ("dir:" + sDataPath)      to sDataPath
85333>>>            Get Seq_New_Channel to iCh  // get free channel for input
85334>>>            Direct_Input channel iCh sDataPath
85336>>>                Repeat
85336>>>>
85336>>>                    Readln channel iCh sFileName
85338>>>                    Get ParseFileExtension sFileName to sExt
85339>>>                    If (Uppercase(sExt) = "INT") Begin
85341>>>                        If (not(Uppercase(sFileName) contains "MSSQLDRV" and Uppercase(sFileName) contains "DB2_DRV" and Uppercase(sFileName) contains "ODBC_DRV")) Begin
85343>>>                            Move sFileName to sFilesData[SizeOfArray(sFilesData)]
85344>>>                        End
85344>>>>
85344>>>                    End
85344>>>>
85344>>>                Until (SeqEof = True)
85346>>>            Close_Input channel iCh
85348>>>        End
85348>>>>
85348>>>        Function_Return sFilesData
85349>>>    End_Function                                  
85350>>>    
85350>>>    // Returns a handle to the SQL server associated with the passed driver ID.
85350>>>    // Pass e.g. the psServer property to determine the current connection server.
85350>>>    // Returns a handle to the database connection, or a zero (0) if it fails.
85350>>>    // This handle can be used to obtain attributes about the server, such as default
85350>>>    // column types.
85350>>>    Function SqlUtilDatabaseHandle String sDriverID String sServer Returns Handle
85352>>>        Handle hDatabase
85352>>>        Integer iDriver iServers iCount
85352>>>        String sValue
85352>>>        
85352>>>        If (sServer = "") Begin
85354>>>            Function_Return 0
85355>>>        End 
85355>>>>
85355>>>        
85355>>>        Get DriverIndex sDriverID to iDriver
85356>>>        If (iDriver = 0) Begin
85358>>>            Function_Return 0
85359>>>        End                  
85359>>>>
85359>>>        
85359>>>        Get_Attribute DF_DRIVER_NUMBER_SERVERS of iDriver to iServers
85362>>>        For iCount from 1 to iServers
85368>>>>
85368>>>            Get_Attribute DF_DRIVER_SERVER_NAME of iDriver iCount to sValue
85371>>>            If (Uppercase(sValue) contains Uppercase(sServer)) Begin
85373>>>                Get_Attribute DF_DATABASE_ID of iDriver iCount to hDatabase
85376>>>            End
85376>>>>
85376>>>        Loop
85377>>>>
85377>>>                
85377>>>        Function_Return hDatabase
85378>>>    End_Function
85379>>>
85379>>>    Procedure SqlUtilExecuteQuery String sStmt String sDriverID Boolean bShowProgr 
85381>>>        String sConnectionString sMessage
85381>>>        Handle hoSqlHandler hoSQLConnect hoStmt hoError
85381>>>        Integer i iMsgs iFetchResult iResultCount iRowType iRows iErr iMessage
85381>>>        String[] sMsg aSQLQueryMessages aSQLFetchResults
85384>>>        DateTime dtQueryExecStart dtQueryExecEnd dtFetchStart dtFetchEnd
85384>>>        TimeSpan tsQuery tsFetch
85384>>>        tSqlErrorArray aSqlErrorArray
85384>>>        tSqlErrorArray aSqlErrorArray
85384>>>        Boolean bOK bMertechDriver bShowProgress
85384>>>        tSQLConnection SQLConnection
85384>>>        tSQLConnection SQLConnection
85384>>>        
85384>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
85385>>>        If (bOK = False) Begin
85387>>>            Procedure_Return
85388>>>        End
85388>>>>
85388>>>        
85388>>>        If (num_arguments > 2) Begin
85390>>>            Move bShowProgr to bShowProgress
85391>>>        End
85391>>>>
85391>>>
85391>>>        Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
85392>>>        
85392>>>        Get IsMertechDriver sDriverID to bMertechDriver
85393>>>        If (bMertechDriver = True) Begin
85395>>>            Get _MertechSQLConnect sDriverID SQLConnection.sServer SQLConnection.sUserID SQLConnection.sPassword to hoSQLConnect
85396>>>        End
85396>>>>
85396>>>        If (bMertechDriver = False) Begin
85398>>>            Get phoSQLManager to hoSqlHandler
85399>>>            Send SqlSetConnect of hoSqlHandler sDriverID SQLConnection.sConnectionString
85400>>>            Get SqlConnect     of hoSqlHandler "" "" to hoSQLConnect
85401>>>        End
85401>>>>
85401>>>
85401>>>        If (hoSQLConnect <> 0) Begin
85403>>>            Get SqlOpen of hoSQLConnect to hoStmt
85404>>>            If (hoStmt <> 0) Begin
85406>>>                // record starting date/time stamp
85406>>>                Move (CurrentDateTime()) to dtQueryExecStart
85407>>>                // turn on error handling if enabled 
85407>>>                If (pbHandleQueryErrors(Self)) Begin
85409>>>                    Set pbSqlError to False 
85410>>>                    Set paSqlErrorArray to aSqlErrorArray
85411>>>                    Move Error_Object_Id to hoError
85412>>>                    Move Self to Error_Object_Id
85413>>>                End               
85413>>>>
85413>>>                
85413>>>                // Before we execute the statement; save it so we can display the faulty statement in the error log.
85413>>>                Set psSQLStatementString to sStmt
85414>>>                Send SqlExecDirect of hoStmt sStmt
85415>>>                
85415>>>                If (pbHandleQueryErrors(Self)) Begin
85417>>>                    Move hoError to Error_Object_Id
85418>>>                End       
85418>>>>
85418>>>                
85418>>>                Move 0 to iMsgs
85419>>>                // ToDo: There seems to be some issues with this code and Mertech drivers that makes
85419>>>                // the debugger crash in some cases like an error in the ESQL statement; so we exclude it for now.
85419>>>                If (bMertechDriver = False) Begin   
85421>>>                    Move Err to iErr
85422>>>                    Get SqlStmtAttribute of hoStmt SQLSTMTATTRIB_NUMMESSAGES   to iMsgs
85423>>>                    Get SqlStmtAttribute of hoStmt SqlSTMTATTRIB_ROWCOUNT      to iRows
85424>>>                    Get SqlStmtAttribute of hoStmt SqlSTMTATTRIB_ROWCOUNT_TYPE to iRowType
85425>>>                    Send _SqlColumnInfo hoStmt
85426>>>                    Send Ignore_Error of Error_Object_Id 12289    
85427>>>                    Set Error_Report_Mode to DUF_ERROR_NO_REPORT
85428>>>                    Repeat     
85428>>>>
85428>>>                        Get SqlFetch of hoStmt to iFetchResult
85429>>>                        If (iFetchResult <> 0) Begin
85431>>>                            Get SQLColumnValue of hoStmt 1 to aSQLFetchResults[SizeOfArray(aSQLFetchResults)]
85432>>>                        End
85432>>>>
85432>>>                    Until (iFetchResult = 0)
85434>>>                    Send Trap_Error of Error_Object_Id 12289    
85435>>>                    Set Error_Report_Mode to DUF_ERROR_REPORT 
85436>>>                    Move iErr to Err
85437>>>                    Set paSQLFetchResults to aSQLFetchResults
85438>>>                End 
85438>>>>
85438>>>                
85438>>>                Set piRows    to iRows
85439>>>                Set piRowType to iRowType
85440>>>                Move (CurrentDateTime()) to dtQueryExecEnd
85441>>>                Move (CurrentDateTime()) to dtFetchStart
85442>>>
85442>>>                If (iMsgs <> 0) Begin
85444>>>                    If (ghoDbUpdateHandler > 0) Begin
85446>>>                        Get paSQLQueryMessages of ghoDbUpdateHandler to aSQLQueryMessages
85447>>>                    End
85447>>>>
85447>>>                    For i from 1 to iMsgs
85453>>>>
85453>>>                        Get SqlGetMessage of hoStmt i to sMessage
85454>>>                        Get RemoveComponentIdentifier of hoStmt sMessage to sMessage
85455>>>                        If (bShowProgress = True) Begin
85457>>>                            If (Active_State(ghoStatusPanel)) Begin
85459>>>                                Send Update_StatusPanel of ghoStatusPanel (Sformat("  SQLGetMessage iMessage %1 returned [%2]",iMessage,sMessage))
85460>>>                            End                                                   
85460>>>>
85460>>>                            Else Begin
85461>>>                                Showln (Sformat("  SQLGetMessage iMessage %1 returned [%2]",iMessage,sMessage))
85463>>>                            End                                           
85463>>>>
85463>>>                        End
85463>>>>
85463>>>                        Move sMessage to sMsg[SizeOfArray(sMsg)]
85464>>>                        Move sMessage to aSQLQueryMessages[SizeOfArray(aSQLQueryMessages)]
85465>>>                    Loop
85466>>>>
85466>>>                    If (ghoDbUpdateHandler > 0) Begin
85468>>>                        Set paSQLQueryMessages of ghoDbUpdateHandler to aSQLQueryMessages
85469>>>                    End
85469>>>>
85469>>>                    Set paQueryMessages to sMsg  
85470>>>                End
85470>>>>
85470>>>                Move (CurrentDateTime()) to dtFetchEnd
85471>>>            End
85471>>>>
85471>>>            Move (dtQueryExecEnd - dtQueryExecStart) to tsQuery
85472>>>            Move (dtFetchStart - dtFetchEnd) to tsFetch
85473>>>            Set ptsQueryExec to tsQuery
85474>>>            Set ptsFetchResults to tsFetch
85475>>>            Send SqlClose of hoStmt
85476>>>        End
85476>>>>
85476>>>
85476>>>        Send SqlDisconnect of hoSQLConnect
85477>>>    End_Procedure
85478>>>
85478>>>    // *** Main message for executing an SQL script that has been compiled into the program as a resource ***
85478>>>    // Use the SQLIncludeScriptFile command to include an SQL script into the program.
85478>>>    // Returns False if no error occured.
85478>>>    Function SqlUtilExecuteResource String sMemFileName String sDriverID Boolean bCreateScriptFile Boolean bShowProgr Returns Boolean
85480>>>        Boolean bOK bShowProgress                               
85480>>>        tSQLScriptArray SQLScriptArray                      
85480>>>        tSQLScriptArray SQLScriptArray                      
85480>>>        Integer iOut iRows iCount
85480>>>        DateTime dtTotalQueryStart dtTotalQueryEnd
85480>>>        TimeSpan tsTotalTime  
85480>>>        String sMessage
85480>>>        
85480>>>        Move (CurrentDateTime()) to dtTotalQueryStart
85481>>>        Get SqlUtilReadResource sMemFileName to SQLScriptArray
85482>>>        If (SQLScriptArray.bError = True) Begin
85484>>>            Function_Return False
85485>>>        End
85485>>>>
85485>>>
85485>>>        If (num_arguments > 3) Begin
85487>>>            Move bShowProgr to bShowProgress
85488>>>        End
85488>>>>
85488>>>
85488>>>        Set Error_Report_Mode to DUF_ERROR_NO_REPORT
85489>>>        Get SqlUtilExecuteEmbeddedScript SQLScriptArray sDriverID bCreateScriptFile sMemFileName bShowProgress to bOK
85490>>>        Set Error_Report_Mode to DUF_ERROR_REPORT 
85491>>>        
85491>>>        If (SQLScriptArray.bArgumentSizeChanged = True) Begin
85493>>>            Set_Argument_Size SQLScriptArray.iOrgArgumentSize
85494>>>>
85494>>>        End
85494>>>>
85494>>>
85494>>>        Move (CurrentDateTime()) to dtTotalQueryEnd
85495>>>        Move (dtTotalQueryEnd - dtTotalQueryStart) to tsTotalTime
85496>>>        Set ptsTotalQueryTime to tsTotalTime
85497>>>        
85497>>>        Function_Return bOK
85498>>>    End_Procedure
