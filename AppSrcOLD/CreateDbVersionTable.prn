84003>>>        Get _SqlProperTableName sTableName to sTableName
84004>>>        Get _SqlFindKeyWord CI_SQLCreateTable iDbType to sCreateTable
84005>>>        Move (sCreateTable * String(sTableName) * "(Dummy Decimal(2,0))") to sSQLString
84006>>>        
84006>>>        Move False to Err               
84007>>>        Send SqlUtilExecuteQuery sSQLString sDriverID
84008>>>    
84008>>>        Function_Return (Err = False)
84009>>>    End_Function       
