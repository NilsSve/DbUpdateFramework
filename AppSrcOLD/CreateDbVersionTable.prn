87002>>>                End 
87002>>>>
87002>>>                Else Begin
87003>>>                    Set_Attribute DF_FILE_LOGIN              of hFile to SQLConnection.sConnectionString
87006>>>                End
87006>>>>
87006>>>                Set_Attribute DF_FILE_TABLE_NAME             of hFile to sRoot  
87009>>>                Set_Attribute DF_FILE_USE_DUMMY_ZERO_DATE    of hFile to True     
87012>>>                Set_Attribute DF_FILE_TABLE_CHARACTER_FORMAT of hFile to sANSI_OEM
87015>>>                Set_Attribute DF_FILE_RECNUM_TABLE           of hFile to bRecnum
87018>>>
87018>>>                If (sSchema <> "") Begin
