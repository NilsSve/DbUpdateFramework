87257>>>    Function ApiTableRename Integer hTable String sRootName String sDisplayName String sLogicalName Returns Boolean
87259>>>        String sPhysicalName sDataPath sDriverID
87259>>>        Boolean bOK bExists
87259>>>        Integer iRetval
87259>>>        
87259>>>        Move False to Err
87260>>>        Get psDataPathFirstPart to sDataPath
87261>>>        Get_Attribute DF_FILE_PHYSICAL_NAME of hTable to sPhysicalName
87264>>>        
87264>>>        Get_Attribute DF_FILE_DRIVER of hTable to sDriverID
87267>>>        Close hTable  
87268>>>        If (sDriverID = DATAFLEX_ID) Begin                    
87270>>>            Get vFilePathExists (sDataPath + sRootName + ".dat") to bExists
87271>>>            If (bExists = True) Begin
87273>>>                If (Uppercase(sPhysicalName) = Uppercase(sRootName)) Begin
87275>>>                    Function_Return False
87276>>>                End
87276>>>>
87276>>>
87276>>>                // ToDo: How do we handle this when the library has been imported into 
87276>>>                // the cDbUpdateVersion Class?
87276>>>                // Get YesNo_Box ("The table:\n" + (sDataPath + sPhysicalName) + "\nis to be renamed to:\n" + (sDataPath + sRootName) + "\nBut the destination already exists. Overwrite?") to iRetval
87276>>>                If (iRetval <> MBR_Yes) Begin
87278>>>                    Function_Return False
87279>>>                End                      
87279>>>>
87279>>>            End                                           
87279>>>>
87279>>>            Copy_db (sDataPath + sPhysicalName) to (sDataPath + sRootName) 
87282>>>        End
87282>>>>
87282>>>        
87282>>>        If (sDriverID <> DATAFLEX_ID) Begin
87284>>>            Move (sDriverID + ":" + sRootName) to sRootName
87285>>>        End
87285>>>>
87285>>>
87285>>>        Set_Attribute DF_FILE_ROOT_NAME     of hTable to sRootName
87288>>>        Set_Attribute DF_FILE_DISPLAY_NAME  of hTable to sDisplayName
87291>>>        Set_Attribute DF_FILE_LOGICAL_NAME  of hTable to sLogicalName
87294>>>        
87294>>>        // We need a short break here before attempting to delete the physical file or Windows
87294>>>        // might report "File in use..." and the deletion will fail.
87294>>>        Sleep 2
87295>>>        If (sDriverID = DATAFLEX_ID) Begin                    
87297>>>            Get vDeleteFile (sDataPath + sPhysicalName + ".*") to bOK
87298>>>        End
87298>>>>
87298>>>        
87298>>>        Function_Return (Err = False)
87299>>>    End_Function
