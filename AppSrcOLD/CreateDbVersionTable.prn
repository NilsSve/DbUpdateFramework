82966>>>>>            End
82966>>>>>>
82966>>>>>        End  
82966>>>>>>
82966>>>>>        
82966>>>>>        Move Error_Object_Id to hoErrorObj
82967>>>>>        Move Self to Error_Object_Id        
82968>>>>>        
82968>>>>>        Get phoSQLConnectionIniFile to hoIniFile
82969>>>>>        Get ConstructConnectionString SQLConnection.sDriverID SQLConnection.sServer SQLConnection.sDatabase SQLConnection.bTrusted SQLConnection.sUserID SQLConnection.sPassword to sConnectionString
82970>>>>>        Get DriverIndex SQLConnection.sDriverID to iDriverID
82971>>>>>        If (iDriverID = 0) Begin
82973>>>>>            Move hoErrorObj to Error_Object_Id
82974>>>>>            Function_Return False
82975>>>>>        End
82975>>>>>>
82975>>>>>        
82975>>>>>        // There's a bug in Mertech drivers creating "an Exception error" in the debugger (probably will crash an application too.)
82975>>>>>        If (bIsMertech = False) Begin
82977>>>>>            Set_Attribute DF_DRIVER_SILENT_LOGIN of iDriverID to SQLConnection.bSilentLogin
82980>>>>>        End
82980>>>>>>
82980>>>>>        
82980>>>>>        Get Create (RefClass(cDbUpdateDatabaseDriver)) to hoDriver
82981>>>>>        Set psDriverID of hoDriver to SQLConnection.sDriverID
82982>>>>>        Get DbLogin    of hoDriver sConnectionString SQLConnection.sServer SQLConnection.sDatabase SQLConnection.bTrusted SQLConnection.sUserID SQLConnection.sPassword to bOK
82983>>>>>        Send Destroy   of hoDriver
82984>>>>>        Move hoErrorObj to Error_Object_Id
82985>>>>>        
82985>>>>>        Function_Return bOK
82986>>>>>    End_Function
82987>>>>>    
