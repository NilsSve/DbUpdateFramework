86539>>>        
86539>>>        Structure_Start hToTable sDriverID
86540>>>            If (bUseConnectionID = True) Begin  
86542>>>                Set_Attribute DF_FILE_LOGIN     of hToTable to (CS_DFCONNID + "=" + sConnectionID)
86545>>>            End
86545>>>>
86545>>>            Else Begin
