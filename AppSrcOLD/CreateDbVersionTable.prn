85583>>>    // This function allows you to put an Sql script in a CM Image. It makes it easier to
85583>>>    // copy and paste between a DataFlex program and an Sql Editor.
85583>>>    Function SqlUtilLoadImageFile String sFileName Returns String
85585>>>        Integer iChannel iPos
85585>>>        String sTextValue sLine sPath
85585>>>        Boolean bSeqEof
85585>>>        
85585>>>        Move "" to sTextValue        
85586>>>        Get ParseFolderName sFileName to sPath
85587>>>        If (Trim(sPath) = "") Begin
85589>>>            Get psDataPathFirstPart to sPath
85590>>>            Move (sPath + sFileName) to sFileName
85591>>>        End
85591>>>>
85591>>>        
85591>>>        Get Seq_New_Channel to iChannel
85592>>>        If (iChannel = DF_SEQ_CHANNEL_NOT_AVAILABLE) Begin
85594>>>            Error DFERR_PROGRAM "No channel available..."
85595>>>>
85595>>>        End
85595>>>>
85595>>>        Else Begin        
85596>>>            Direct_Input channel iChannel sFileName
85598>>>            Move (SeqEof) to bSeqEof
85599>>>            If (bSeqEof = True) Begin
85601>>>                Send Seq_Release_Channel iChannel 
85602>>>                Set psSQLStatementString to ""  
85603>>>                Error DFERR_PROGRAM ("The Sql script file:\n" + sFileName + "\nCould not be found.")
85604>>>>
85604>>>                Function_Return "" 
85605>>>            End
85605>>>>
85605>>>    
85605>>>            While (not(bSeqEof))
85609>>>                Readln channel iChannel sLine 
85611>>>                Move (Pos("/", sLine)) to iPos
85612>>>                Move (SeqEol) to bSeqEof
85613>>>                If (not(bSeqEof) and iPos <> 1) Begin
85615>>>                    Move (sTextValue + sLine + Character(13)) to sTextValue
85616>>>                End
85616>>>>
85616>>>            Loop
85617>>>>
85617>>>            Send Seq_Release_Channel iChannel
85618>>>        End
85618>>>>
85618>>>        
85618>>>        Set psSQLStatementString to sTextValue
85619>>>        Function_Return sTextValue
85620>>>    End_Function  
