87068>>>    
87068>>>            If (sDriverID <> DATAFLEX_ID and not(Uppercase(sRoot) contains sDriverID)) Begin
87070>>>                Move (sDriverID + ":" + sRoot) to sRoot
87071>>>            End
87071>>>>
87071>>>            Set_Attribute DF_FILE_ROOT_NAME     of hTable to sRoot
87074>>>            Set_Attribute DF_FILE_LOGICAL_NAME  of hTable to sTableName 
87077>>>            Set_Attribute DF_FILE_DISPLAY_NAME  of hTable to sDisplay
87080>>>        
87080>>>            // Lastly we remove the temporary column we created above, if all went well.
87080>>>            Get ApiColumnRemove hTable "temp" to bOk
