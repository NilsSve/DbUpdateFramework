85054>>>    // Returns a string array with all tables for the current database.
85054>>>    Function SqlUtilEnumerateTables String sDriverID Returns String[]
85056>>>        String[] sReturnArray sArray
85058>>>        String sServer sDatabase sConnectionString sSelect sSchema     
85058>>>        Integer iSize iCount
85058>>>        Boolean bOK
85058>>>
85058>>>        If (sDriverID = DATAFLEX_ID) Begin
85060>>>            Function_Return sArray        
85061>>>        End                       
85061>>>>
85061>>>        
85061>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
85062>>>        If (bOK = False) Begin
85064>>>            Function_Return sReturnArray
85065>>>        End    
85065>>>>
85065>>>        
85065>>>        Get psConnectionString to sConnectionString
85066>>>        Get psDatabase to sDatabase                               
85067>>>        Get psSchema   to sSchema                                                                              
85068>>>                                                                                                              
85068>>>        Case Begin
85068>>>            Case (sDriverID = MSSQLDRV_ID)
85070>>>                Get _SqlTableArrayDAW to sReturnArray
85071>>>                Case Break                                                            
85072>>>            
85072>>>            Case (sDriverID = DB2_DRV_ID)
85075>>>                Get _SqlTableArrayDAW to sReturnArray
85076>>>                Case Break
85077>>>            
85077>>>            Case (sDriverID = ODBC_DRV_ID)
85080>>>                Get _SqlTableArrayDAW to sReturnArray
85081>>>                Case Break
85082>>>            
85082>>>            Case (sDriverID = SQLFLEX)
85085>>>                Move ("SELECT TABLE_NAME FROM" * sDatabase + ".INFORMATION_SCHEMA.TABLES WHERE TABLE_TYPE != 'VIEW'") to sSelect
85086>>>                Get SqlEnumerateEsqlMertech sSelect to sReturnArray
85087>>>                Case Break
85088>>>            
85088>>>            Case (sDriverID = MDSMySQL)                                   
85091>>>                Move ("SELECT TABLE_NAME from INFORMATION_SCHEMA.TABLES where TABLE_SCHEMA = '" + sDatabase + "' and TABLE_TYPE = 'BASE TABLE' order by TABLE_NAME") to sSelect
85092>>>                Get SqlEnumerateEsqlMertech sSelect to sReturnArray
85093>>>                Case Break
85094>>>            
85094>>>            Case (sDriverID = MDSPgSQL)                                          
85097>>>                Move "select tablename, schemaname from pg_catalog.pg_tables order by tablename"  to sSelect
85098>>>                Get SqlEnumerateEsqlMertech sSelect "" to sReturnArray
85099>>>                Case Break            
85100>>>            
85100>>>            Case (sDriverID = ORAFLEX)                                          
85103>>>                Move "SELECT table_name from user_tables" to sSelect  
85104>>>                Get SqlEnumerateEsqlMertech sSelect to sArray
85105>>>                Move (SizeOfArray(sArray)) to iSize
85106>>>                Decrement iSize
85107>>>                For iCount from 0 to iSize
85113>>>>
85113>>>                    If (not(sArray[iCount] contains "$")) Begin
85115>>>                        Move sArray[iCount] to sReturnArray[SizeOfArray(sReturnArray)]
85116>>>                    End
85116>>>>
85116>>>                Loop
85117>>>>
85117>>>                Case Break            
85118>>>
85118>>>            Case Else     
85118>>>                Error DFERR_PROGRAM "Unsupported driver passed to SqlUtilEnumerateTables function."
85119>>>>
85119>>>                Case Break
85120>>>        Case End
85120>>>        
85120>>>        Function_Return sReturnArray
85121>>>    End_Function
