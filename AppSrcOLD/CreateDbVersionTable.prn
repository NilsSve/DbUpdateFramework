92333>>>                Send Add_LineLn sParam7
92334>>>            End
92334>>>>
92334>>>
92334>>>            If (iArgs = 8 and sParam8  <> "") Begin
92336>>>                Send Add_Line sParam8
92337>>>            End
92337>>>>
92337>>>            Else If (iArgs > 8 and sParam8  <> "") Begin
92340>>>                Send Add_LineLn sParam8
92341>>>            End
92341>>>>
92341>>>
92341>>>            If (iArgs = 9 and sParam9  <> "") Begin
92343>>>                Send Add_Line sParam9
92344>>>            End
92344>>>>
92344>>>            Else If (iArgs > 9 and sParam9  <> "") Begin
92347>>>                Send Add_LineLn sParam9
92348>>>            End
92348>>>>
92348>>>
92348>>>            If (iArgs = 10 and sParam10 <> "") Begin
92350>>>                Send Add_Line sParam10
92351>>>            End
92351>>>>
92351>>>
92351>>>            Move Self to hoObj
92352>>>        End_Object
92353>>>
92353>>>        Send Popup   of hoObj // Popup the about object
92354>>>        Send Destroy of hoObj // When done, it will be destroyed
92355>>>End_Procedure
