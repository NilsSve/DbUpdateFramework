87228>>>        If (hTable <> 0) Begin
87230>>>            Set_Attribute DF_FILE_ROOT_NAME     of hTable to ""
87233>>>            Set_Attribute DF_FILE_DISPLAY_NAME  of hTable to ""
87236>>>            Set_Attribute DF_FILE_LOGICAL_NAME  of hTable to ""  
87239>>>        End
87239>>>>
87239>>>        
87239>>>        Function_Return (hTable <> 0)
87240>>>    End_Function
