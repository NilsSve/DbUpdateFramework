90937>    Object oCreateTable_btn is a Button
90939>        Set Size to 14 54
90940>        Set Location to 155 309
90941>        Set Label to "Create Table"
90942>        Set FontWeight to fw_Bold
90943>        Property String psToolTip1 "This will create a table & column for the Embedded database, to be used with the DataFlex Update Framework."
90945>        Property String psToolTip2 "There is also a 'SQLCreateDbVersionTable' function that can be used to create/move the Table at customer site to SQL."
90947>        Set psToolTip to (psToolTip1(Self) + psToolTip2(Self))
90948>        
90948>        Procedure OnClick
90951>            String sTableName sColumnName sInfoTxt1 sInfoTxt2 sDataType sFileList sDataPath
90951>            Integer iLength iDecimals iDataType iRetval iMin iMax 
90951>            Boolean bOK 
90951>            Handle hTable
90951>            
90951>            Get Value of oFileList_fm  to sFileList
90952>            Get Value of oTableName_fm to sTableName
90953>            Move (Trim(sTableName))    to sTableName
90954>            If (sTableName = "") Begin
90956>                Send Info_Box "You first need to enter a table name."
90957>                Procedure_Return
90958>            End
90958>            
90958>            Get psDataPath of (phoWorkspace(ghoApplication)) to sDataPath
90959>            Get vFolderFormat sDataPath to sDataPath
90960>            Set psDriverID                      of ghoDbUpdateFunctionLibrary to DATAFLEX_ID  
90961>            Get UtilTableNameToHandle of ghoDbUpdateFunctionLibrary sTableName to iRetval
90962>            If (iRetval <> 0) Begin
90964>                Send Info_Box ("Sorry, a table named: '" + sTableName + "' already exists in" * sFileList + "!")
90965>                Procedure_Return
90966>            End
90966>            
90966>            Get Value of oColumnName_fm      to sColumnName
90967>            Move (Trim(sColumnName))         to sColumnName
90968>            If (sColumnName = "") Begin
90970>                Send Info_Box "You need to enter a column name."
90971>                Procedure_Return
90972>            End
90972>            
90972>            Get Value        of oDataType_cf to sDataType    
90973>            Get SelectedType of oDataType_cf to iDataType   
90974>            Get Value        of oLength_sf   to iLength 
90975>            If (iLength < 1) Begin
90977>                Send Info_Box "You need to enter a proper length for the column"
90978>                Procedure_Return
90979>            End
90979>            Get Value of oDecimals_sf to iDecimals
90980>            
90980>            Get Value of oTableNo_sf  to hTable
90981>            Get Maximum_Position of oTableNo_sf to iMax
90982>            Get Minimum_Position of oTableNo_sf to iMin
90983>            If (hTable < iMin or hTable > iMax) Begin
90985>                Send Info_Box "The selected Filelist number must be in the range: 1-4095"
90986>                Procedure_Return
90987>            End
90987>            Get UtilTableNumberIsInUse of ghoDbUpdateFunctionLibrary hTable to bOK
90988>            If (bOK = True) Begin
90990>                Send Info_Box "The selected Filelist number exists and cannot be used to create a new table!"
90991>                Procedure_Return
90992>            End     
90992> 
90992>            // Reserved filelist numbers 48-50, 250-300
90992>            Move (hTable <> 48 and hTable <> 49 and hTable <> 50 and (hTable < 250 or hTable > 300)) to bOK
90993>            If (bOK = False) Begin
90995>                Send Info_Box "The selected Filelist number is in the range of reserved filelist numbers; 48-50 and 250-300"
90996>                Procedure_Return
90997>            End
90997>            
90997>            Get psToolTip1 to sInfoTxt1
90998>            Get psToolTip2 to sInfoTxt2
90999>            Get YesNo_Box (sInfoTxt1 + "\n\n" + sInfoTxt2 + "\n\nContinue?") to iRetval
91000>            If (iRetval <> MBR_Yes) Begin
91002>                Procedure_Return
91003>            End
91003>            
91003>            Send Cursor_Wait of Cursor_Control 
91004>            
91004>            Get ApiTableCreate of ghoDbUpdateFunctionLibrary hTable sTableName sTableName sTableName False False True to bOk
91005>            If (bOk = False) Begin
91007>                Send Info_Box "Sorry, it didn't work to create the table."
91008>                Procedure_Return
91009>            End        
91009>            
91009>            Get ApiTableChangeAttribute of ghoDbUpdateFunctionLibrary hTable DF_FILE_IS_SYSTEM_FILE True to bOK
91010>            Get ApiColumnAdd            of ghoDbUpdateFunctionLibrary hTable sColumnName iDataType iLength iDecimals to bOk 
91011>            If (bOK = True) Begin
91013>                Move ("Column '" + sColumnName + "'" * sDataType * String(iLength) + ", was successfully added to '" + sTableName + "'" * "(at filelist slot:" * String(hTable) + ")") to sInfoTxt1
91014>            End                                                      
91014>            Else Begin
91015>                Move ("The column could NOT be added. Either column" * sColumnName * "already exists or the Table name is incorrect?") to sInfoTxt1
91016>            End
91016>            Send Cursor_Ready of Cursor_Control 
91017>            Send Info_Box sInfoTxt1
91018>        End_Procedure
91019>    
91019>    End_Object
