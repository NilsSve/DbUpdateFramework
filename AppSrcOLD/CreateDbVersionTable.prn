90826>        Procedure Combo_Fill_List                                  
90829>            tColumnType[] ColumnTypeArray      
90829>            tColumnType[] ColumnTypeArray      
90830>            Integer iSize iCount iStart
90830>            
90830>            Send Delete_Data
90831>            Get UtilEnumerateColumnTypes of ghoDbUpdateFunctionLibrary DATAFLEX_ID EN_DbTypeDataFlex to ColumnTypeArray
90832>            Move (SizeOfArray(ColumnTypeArray)) to iSize                        
90833>            Decrement iSize
90834>            For iCount from 0 to iSize
90840>                Send Combo_Add_Item ColumnTypeArray[iCount].sType
90841>            Loop  
90842>            Set Value to "NUMERIC"
90843>            Set Enabled_State of oLength_sf to False
90844>            Set Enabled_State of oDecimals_sf to False
90845>            Set Value of oLength_sf   to 4
90846>            Set Value of oDecimals_sf to 2
90847>        End_Procedure
90848>        
90848>        Procedure OnChange
90851>            String sDataType sPrecision
90851>            Integer iDataType iSize iDec
90851>            Boolean bFixed
90851>            
90851>            Get SelectedType to iDataType
90852>            Get UtilColumnTypePrecisionSize of ghoDbUpdateFunctionLibrary DATAFLEX_ID EN_DbTypeDataFlex iDataType to iSize
90853>            Get UtilColumnTypePrecisionDec  of ghoDbUpdateFunctionLibrary DATAFLEX_ID EN_DbTypeDataFlex iDataType to iDec   
90854>            Get UtilColumnTypeFixed         of ghoDbUpdateFunctionLibrary DATAFLEX_ID EN_DbTypeDataFlex iDataType to bFixed
90855>            Set Enabled_State of oLength_sf   to (bFixed = False)
90856>            Set Enabled_State of oDecimals_sf to (bFixed = False)
90857>            Set Value of oLength_sf to iSize
90858>            If (iDec = 0) Begin
90860>                Set Value of oDecimals_sf to ""
90861>            End                                                
90861>            Else Begin
90862>                Set Value of oDecimals_sf to iDec
90863>            End      
90863>            If (bFixed = False) Begin
90865>                Set Enabled_State of oDecimals_sf to (iDec <> 0)
90866>            End
90866>        End_Procedure     
