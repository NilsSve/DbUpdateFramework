82114>>>>>>>>>Class cDbUpdateGenericDatabaseDriver is a cObject
82115>>>>>>>>>    Procedure Construct_Object
82117>>>>>>>>>        Forward Send Construct_Object
82119>>>>>>>>>        Property String psDriverID DATAFLEX_ID
82120>>>>>>>>>    End_Procedure 
82121>>>>>>>>>    
82121>>>>>>>>>    Function ServerKeyword Returns String
82123>>>>>>>>>        Function_Return CS_SQLIniDSNKeyword
82124>>>>>>>>>    End_Function
82125>>>>>>>>>    
82125>>>>>>>>>    Function ConstructConnectionString String sServer String sDatabase Boolean bTrusted String sUserID String sPassword Returns String
82127>>>>>>>>>        String sConnect
82127>>>>>>>>>        
82127>>>>>>>>>        Move (sConnect * ServerKeyword(Self) + "=" + sServer) to sConnect
82128>>>>>>>>>        If (sDatabase <> "") Begin
82130>>>>>>>>>            Move (sConnect * ";" + CS_SQLIniDatabaseKeyword + "=" + sDatabase) to sConnect
82131>>>>>>>>>        End
82131>>>>>>>>>>
82131>>>>>>>>>        If (bTrusted = True) Begin
82133>>>>>>>>>            Move (sConnect * ";" + CS_SQLIniTrustedKeyword + "=Yes") to sConnect
82134>>>>>>>>>        End
82134>>>>>>>>>>
82134>>>>>>>>>        Else Begin
82135>>>>>>>>>            Move (sConnect * ";" + CS_SQLIniUIDKeyword + "=" + sUserID * ";" + CS_SQLIniPWDKeyword + "=" + sPassword) to sConnect
82136>>>>>>>>>        End
82136>>>>>>>>>>
82136>>>>>>>>>        Function_Return sConnect
82137>>>>>>>>>    End_Function
82138>>>>>>>>>    
82138>>>>>>>>>    Function DbLogin String sConnectionString String sServer String sDatabase Boolean bTrusted String sUserID String sPassword Returns Boolean
82140>>>>>>>>>        Boolean bLoginSuccessful
82140>>>>>>>>>        String sDriverID 
82140>>>>>>>>>        
82140>>>>>>>>>        Get psDriverID to sDriverID
82141>>>>>>>>>        Move 0 to LastErr  // Do NOT use the Err flag, it will be set true by the login command although it is successful.
82142>>>>>>>>>        If (bTrusted = False) Begin
82144>>>>>>>>>            Login sServer sUserId sPassword sDriverID
82146>>>>>>>>>        End 
82146>>>>>>>>>>
82146>>>>>>>>>        Else Begin
82147>>>>>>>>>            Login sConnectionString "" "" sDriverID
82149>>>>>>>>>        End
82149>>>>>>>>>>
82149>>>>>>>>>        Move (LastErr = 0) to bLoginSuccessful
82150>>>>>>>>>        Function_Return bLoginSuccessful
82151>>>>>>>>>    End_Function
82152>>>>>>>>>End_Class
