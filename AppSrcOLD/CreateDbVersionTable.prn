87139>>>    Function ApiTableMoveToFileSlot Integer iFromFileSlot Integer iToFileSlot String sDriverID Returns Boolean
87141>>>        Boolean bTmp bErr bOK 
87141>>>        String sTableName sDisplayName sFileName sDBOKeyWord sVal
87141>>>        
87141>>>        // We preserve the value of the Err flag, by saving its current state and resetting it before end of function.
87141>>>        Move Err to bTmp
87142>>>        Move False to Err
87143>>>        
87143>>>        Get AutoConnectionIDLogin to bOK
87144>>>        // First get the info for the current filelist slot:
87144>>>        Open iFromFileSlot                      
87146>>>        Get_Attribute DF_FILE_OPENED of iFromFileSlot to bOK
87149>>>        If (bOK = True) Begin
87151>>>            Get_Attribute DF_FILE_ROOT_NAME    of iFromFileSlot to sFileName
87154>>>            Get_Attribute DF_FILE_LOGICAL_NAME of iFromFileSlot to sTableName
87157>>>            Get_Attribute DF_FILE_DISPLAY_NAME of iFromFileSlot to sDisplayName
87160>>>            
87160>>>            //...then move it.
87160>>>            Set_Attribute DF_FILE_ROOT_NAME    of iToFileSlot to sFileName
87163>>>            Set_Attribute DF_FILE_LOGICAL_NAME of iToFileSlot to sTableName
87166>>>            Set_Attribute DF_FILE_DISPLAY_NAME of iToFileSlot to sDisplayName
87169>>>            
87169>>>            //...and finally remove the old filelist values.
87169>>>            Set_Attribute DF_FILE_ROOT_NAME    of iFromFileSlot to ""
87172>>>            Set_Attribute DF_FILE_LOGICAL_NAME of iFromFileSlot to ""
87175>>>            Set_Attribute DF_FILE_DISPLAY_NAME of iFromFileSlot to ""
87178>>>        End
87178>>>>
87178>>>        Close iFromFileSlot
87179>>>        
87179>>>        Move Err to bErr                     
87180>>>        Move bTmp to Err
87181>>>        Function_Return (bErr = False)
87182>>>    End_Function
