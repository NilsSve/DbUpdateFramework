91449>>>>>>>>>>>
91449>>>>>>>>>>>    // Use this if you want your help context to be ID based
91449>>>>>>>>>>>    //
91449>>>>>>>>>>>    procedure View_Context_ID_Help integer Obj
91451>>>>>>>>>>>       Integer Context_ID
91451>>>>>>>>>>>       String Context
91451>>>>>>>>>>>       If Obj gt 0 ;          Get Help_Context of Obj HELP_CONTEXT_ID to Context_ID
91454>>>>>>>>>>>       Get System_Help_Context_id Context_Id to Context
91455>>>>>>>>>>>       Send Exec_Context_Help Context
91456>>>>>>>>>>>    end_procedure
91457>>>>>>>>>>>
91457>>>>>>>>>>>    // Use this is you want the object requesting help to support either
91457>>>>>>>>>>>    // keyword or context ID help (it will use whatever it finds first).
91457>>>>>>>>>>>    //
91457>>>>>>>>>>>    procedure View_Context_Help integer Obj
91459>>>>>>>>>>>       String Context
91459>>>>>>>>>>>       If Obj gt 0 ;          Get Help_Context of obj HELP_CONTEXT_ID_OR_KEY to Context
91462>>>>>>>>>>>       if (left(context,1)) in '0123456789' ;          Get System_Help_Context_id Context to Context
91465>>>>>>>>>>>       Send Exec_Context_Help Context
91466>>>>>>>>>>>    end_procedure
