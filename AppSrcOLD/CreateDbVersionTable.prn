84175>>>    // Same as SqlColumnChange but instead of passing a filelist number; pass the table name as a string. 
84175>>>    // The fourth & fifth arguments are optional, depending on the iDataType
84175>>>    // passed. For e.g. a DF_ASCII the iLen must be passed.                     // Optional: // Optional:  
84175>>>    Function SqlColumnChangeByTableName String sTableName String sColumnName Integer iDataType Integer iLen Integer iDec Returns Boolean
84177>>>        Integer iColumn iDbType iLength iDecimals
84177>>>        String sDriverID sStmt sAlterTable sAlterColumn sVal sDataType sRetval sLengthAndDecimals sNotNull
84177>>>        Boolean bExists bOK bFixed
84177>>>        Handle hTable
84177>>>        
84177>>>        Get psDriverID to sDriverID
84178>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
84179>>>        If (bOK = False) Begin
84181>>>            Function_Return False
84182>>>        End
84182>>>>
84182>>>        
84182>>>        Get UtilTableNameToHandle sTableName to hTable 
84183>>>        If (hTable = 0) Begin
84185>>>            Get NextFreeFilelistSlot to hTable
84186>>>        End
84186>>>>
84186>>>        Get SQLUtilColumnExists sTableName sColumnName to bExists
84187>>>        If (bExists = True) Begin
84189>>>            Function_Return False
84190>>>        End
84190>>>>
84190>>>
84190>>>        If (num_arguments > 3) Begin
84192>>>            Move iLen to iLength
84193>>>        End                     
84193>>>>
84193>>>        If (num_arguments > 4) Begin
84195>>>            Move iDec to iDecimals
84196>>>        End                
84196>>>>
84196>>>        
84196>>>        Get piDbType to iDbType
84197>>>        Get UtilColumnTypeToString sDriverID iDbType iDataType to sDataType
84198>>>        
84198>>>        Move False to Err   
84199>>>        Get _SqlProperTableName sTableName    to sTableName
84200>>>        Get _SqlFindKeyWord CI_SQLAlterTable  to sAlterTable
84201>>>        Get _SqlFindKeyWord CI_SQLAlterColumn to sAlterColumn
84202>>>        Get SQLUtilDefaultNullValue sDriverID iDbType iDataType to sNotNull
84203>>>
84203>>>        Get UtilColumnTypeFixed sDriverID iDbType iDataType to bFixed
84204>>>        If (bFixed = False) Begin
84206>>>            Get _SqlFormatLengthAndDecimalAsString iLength iDecimals to sLengthAndDecimals
84207>>>        End
84207>>>>
84207>>>        
84207>>>        Move (sAlterTable * sTableName * sAlterColumn * sColumnName * sDataType + sLengthAndDecimals * sNotNull) to sStmt
84208>>>        Send SqlUtilExecuteQuery sStmt sDriverID
84209>>>    
84209>>>        // We also need to remove the cache-file since the table has been changed
84209>>>        Get UtilDeleteCacheFile sTableName to bOK
84210>>>    
84210>>>        Function_Return (Err = False)    
84211>>>    End_Function    
84212>>>    
84212>>>    Function SqlColumnDefaultValue Handle hTable Integer iColumn String sValue Returns Boolean
84214>>>        Boolean bOK bErr bIsSQLDriver
84214>>>        String sDriverID
84214>>>        
84214>>>        Get psDriverID to sDriverID
84215>>>        Get IsSQLDriver sDriverID to bIsSQLDriver
84216>>>        If (bIsSQLDriver = False) Begin
84218>>>            Function_Return False
84219>>>        End
84219>>>>
84219>>>
84219>>>        Move Err to bErr
84220>>>        Move False to bErr                                      
84221>>>        
84221>>>        // There seems to be a problem with the ODBC_DRV driver that sometimes
84221>>>        // inserts randomly character(10) and spaces, so we correct from that here:
84221>>>        Move (Replaces(Character(10), Trim(sValue), "")) to sValue                   
84222>>>        
84222>>>        Set_Attribute DF_FIELD_DEFAULT_VALUE of hTable iColumn to sValue
84225>>>        Move (not(Err)) to bOK
84226>>>        Move bErr to Err
84227>>>        
84227>>>        Function_Return bOK
84228>>>    End_Function
84229>>>    
84229>>>    Function SqlColumnNullable Handle hTable Integer iColumn Boolean bNullable Returns Boolean
84231>>>        Boolean bOK bErr bCurrentState bOpen bIsSQLDriver
84231>>>        String sDriverID
84231>>>        
84231>>>        Get psDriverID to sDriverID
84232>>>        Get IsSQLDriver sDriverID to bIsSQLDriver
84233>>>        If (bIsSQLDriver = False) Begin
84235>>>            Function_Return False
84236>>>        End
84236>>>>
84236>>>        
84236>>>        Move Err to bErr
84237>>>        Move False to bErr
84238>>>        Get_Attribute DF_FIELD_NULL_ALLOWED of hTable iColumn to bCurrentState
84241>>>        If (bNullable = bCurrentState) Begin
84243>>>            Function_Return True
84244>>>        End                     
84244>>>>
84244>>>        
84244>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpen
84247>>>        If (bOpen = False) Begin                       
84249>>>            Get AutoConnectionIDLogin to bOK
84250>>>            Send Ignore_Error of Error_Object_Id DFERR_CANT_OPEN_DATA_FILE
84251>>>            Send Ignore_Error of Error_Object_Id DFERR_CANT_OPEN_INTERMEDIATE_FILE
84252>>>            Send Ignore_Error of Error_Object_Id CLIERR_GENERAL_ERROR
84253>>>            Open hTable
84255>>>            Send Trap_Error of Error_Object_Id DFERR_CANT_OPEN_DATA_FILE
84256>>>            Send Trap_Error of Error_Object_Id DFERR_CANT_OPEN_INTERMEDIATE_FILE
84257>>>            Send Trap_Error of Error_Object_Id CLIERR_GENERAL_ERROR
84258>>>            Get_Attribute DF_FILE_OPENED of hTable to bOpen
84261>>>        End
84261>>>>
84261>>>        If (bOpen = True) Begin
84263>>>            Structure_Start hTable sDriverID
84264>>>                Set_Attribute DF_FIELD_NULL_ALLOWED of hTable iColumn to bNullable
84267>>>            Structure_End hTable
84269>>>        End
84269>>>>
84269>>>
84269>>>        Move (not(Err)) to bOK
84270>>>        Move bErr to Err
84271>>>        
84271>>>        Function_Return bOK
84272>>>    End_Function
84273>>>    
84273>>>    // Drop column by its table handle 
84273>>>    Function SqlColumnRemove Handle hTable String sColumnName Returns Boolean
84275>>>        Integer iColumn idbType
84275>>>        String sDriverID sStmt sAlterTable sDropColumn sVal sTableName 
84275>>>        Boolean bExists bOK
84275>>>        
84275>>>        Get psDriverID to sDriverID
84276>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
84277>>>        If (bOK = False) Begin
84279>>>            Function_Return False
84280>>>        End
84280>>>>
84280>>>        
84280>>>        Get UtilTableHandleToString hTable to sTableName
84281>>>        If (sTableName = "") Begin
84283>>>            Function_Return False
84284>>>        End  
84284>>>>
84284>>>        
84284>>>        Get SqlColumnRemoveByTableName sTableName sColumnName to bOK
84285>>>            
84285>>>        Function_Return (bOK = True)    
84286>>>    End_Function    
84287>>>    
84287>>>    // Drop column by its table name as a string.
84287>>>    Function SqlColumnRemoveByTableName String sTableName String sColumnName Returns Boolean
84289>>>        Integer iColumn iDbType iDriver
84289>>>        String sDriverID sStmt sAlterTable sDropColumn sVal 
84289>>>        Boolean bExists bOK bRetval bDriverIgnoreErrorState
84289>>>        Handle hTable 
84289>>>        
84289>>>        Get psDriverID to sDriverID
84290>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
84291>>>        If (bOK = False) Begin
84293>>>            Function_Return False
84294>>>        End
84294>>>>
84294>>>
84294>>>        Get DriverIndex sDriverID to iDriver
84295>>>        Get_Attribute DF_DRIVER_IGNORE_WARNINGS of iDriver to bDriverIgnoreErrorState
84298>>>        Set_Attribute DF_DRIVER_IGNORE_WARNINGS of iDriver to True
84301>>>        
84301>>>        Get UtilTableNameToHandle sTableName to hTable
84302>>>        If (hTable <> 0) Begin
84304>>>            Get SQLUtilColumnExists sTableName sColumnName to bExists
84305>>>            If (bExists = False) Begin
84307>>>                Set_Attribute DF_DRIVER_IGNORE_WARNINGS of iDriver to bDriverIgnoreErrorState
84310>>>                Function_Return False
84311>>>            End
84311>>>>
84311>>>        End
84311>>>>
84311>>>
84311>>>        Get piDbType to iDbType
84312>>>        If (iDbType = EN_DbTypeMSSQL) Begin
84314>>>            Get _SqlUtilRemoveTableColumnMSSQL sTableName sColumnName to bOK
84315>>>            Get UtilDeleteCacheFile sTableName to bOK
84316>>>            Set_Attribute DF_DRIVER_IGNORE_WARNINGS of iDriver to bDriverIgnoreErrorState
84319>>>            Function_Return bOK
84320>>>        End
84320>>>>
84320>>>        
84320>>>        Move False to Err   
84321>>>        Get _SqlProperTableName sTableName    to sTableName
84322>>>        Get _SqlFindKeyWord CI_SQLAlterTable  to sAlterTable
84323>>>        Get _SqlFindKeyWord CI_SQLDropColumn  to sDropColumn   
84324>>>        
84324>>>        Move (sAlterTable * sTableName * sDropColumn * sColumnName) to sStmt
84325>>>        Send SqlUtilExecuteQuery sStmt sDriverID
84326>>>        Move (not(Err)) to bRetval
84327>>>    
84327>>>        // We also need to remove the cache-file since the table has been changed
84327>>>        Get UtilDeleteCacheFile sTableName to bOK
84328>>>        Set_Attribute DF_DRIVER_IGNORE_WARNINGS of iDriver to bDriverIgnoreErrorState
84331>>>    
84331>>>        Function_Return bRetval
84332>>>    End_Function    
84333>>>    
84333>>>    // Rename a field/column by table handle (filelist number)
84333>>>    Function SqlColumnRename Integer hTable String sColumnName String sNewColumnName Returns Boolean
84335>>>        Integer iColumn idbType
84335>>>        String sDriverID sTableName sStmt sAlterTable sRenameColumn sVal sColumnKeyWord
84335>>>        Boolean bExists bOK
84335>>>        
84335>>>        Get psDriverID to sDriverID
84336>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
84337>>>        If (bOK = False) Begin
84339>>>            Function_Return False
84340>>>        End
84340>>>>
84340>>>        
84340>>>        Get UtilTableHandleToString hTable to sTableName   
84341>>>        Get SqlColumnRenameByTableName sTableName sColumnName sNewColumnName to bOK
84342>>>
84342>>>        Function_Return (Err = False)    
84343>>>    End_Function    
84344>>>    
84344>>>    // Rename a field/column by table name.
84344>>>    Function SqlColumnRenameByTableName String sTableName String sColumnName String sNewColumnName Returns Boolean
84346>>>        Integer iColumn iDbType iDataType
84346>>>        String sDriverID sStmt sAlterTable sRenameColumn sVal sColumnKeyWord sOrgTableName sDatabase sDataType
84346>>>        Boolean bExists bOK bRetval                                        
84346>>>        Handle hTable
84346>>>        
84346>>>        Move sTableName to sOrgTableName
84347>>>        Get psDriverID to sDriverID
84348>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
84349>>>        If (bOK = False) Begin
84351>>>            Function_Return False
84352>>>        End
84352>>>>
84352>>>        
84352>>>        Get _SqlFindColumnName sTableName sColumnName to sVal
84353>>>        If (sVal = "") Begin
84355>>>            Function_Return False
84356>>>        End                          
84356>>>>
84356>>>        
84356>>>        Get piDbType to iDbType
84357>>>        Get _SqlFindKeyWord CI_SQLColumn       to sColumnKeyWord
84358>>>        Get _SqlProperTableName sTableName     to sTableName
84359>>>        Get _SqlFindKeyWord CI_SQLAlterTable   to sAlterTable
84360>>>        Get _SqlFindKeyWord CI_SQLRenameColumn to sRenameColumn
84361>>>        
84361>>>        Case Begin
84361>>>            Case (iDbType = EN_dbTypeMSSQL) 
84363>>>                Move (sRenameColumn * "'" + sTableName + "." + sColumnName + "'," * "'" + sNewColumnName + "'," * "'" + sColumnKeyWord + "'") to sStmt
84364>>>                Case Break
84365>>>            // Alter table "SYS"."Customer" rename column "Comments" to "NewColumnName"    
84365>>>            Case (iDbType = EN_dbTypeOracle) 
84368>>>                Move (sAlterTable * '"' + sTableName + '"' * sRenameColumn * '"' + sColumnName + '"' * "TO" * '"' + sNewColumnName + '"') to sStmt
84369>>>                Case Break  
84370>>>            // ALTER TABLE Schema.TableName RENAME COLUMN "deptnumb" TO "deptnum"
84370>>>            Case (iDbType = EN_dbTypeDB2)
84373>>>                Move (sAlterTable *  sTableName * sRenameColumn * '"' + sColumnName + '"' * "TO" * '"' + sNewColumnName + '"') to sStmt
84374>>>                Case Break
84375>>>            // ALTER TABLE "Customer" RENAME COLUMN "Comments" TO "NewColumnName"
84375>>>            Case (iDbType = EN_dbTypePostgre) 
84378>>>                Move sOrgTableName to sTableName
84379>>>                Move (sAlterTable * '"' + sTableName + '"' * sRenameColumn * '"' + sColumnName + '"' * "TO" * '"' + sNewColumnName + '"') to sStmt
84380>>>                Case Break  
84381>>>            Case (iDbType = EN_dbTypeMySQL)
84384>>>                // ALTER TABLE orderentry.customer CHANGE Comments NewColumnName text // Note: The last token is the column type!
84384>>>                Move sOrgTableName to sTableName
84385>>>                Get psDatabase to sDatabase 
84386>>>                Get UtilTableNameToHandle sTableName to hTable
84387>>>                If (hTable = 0) Begin
84389>>>                    Get UtilTableOpen hTable sTableName DF_SHARE to bOK
84390>>>                    If (bOK = False) Begin
84392>>>                        Function_Return False 
84393>>>                    End
84393>>>>
84393>>>                    Get NextFreeFilelistSlot to hTable
84394>>>                End
84394>>>>
84394>>>                Else Begin
84395>>>                    Open hTable
84397>>>                End          
84397>>>>
84397>>>                Get SQLColumnType sDriverID hTable sTableName sColumnName to iDataType
84398>>>                Get UtilColumnTypeToString sDriverID iDbType iDataType    to sDataType
84399>>>                Move (sAlterTable * sDatabase + "." + sTableName * sRenameColumn * sColumnName * sNewColumnName * sDataType) to sStmt
84400>>>                Case Break  
84401>>>            Case Else 
84401>>>                Move (sAlterTable * "'" + sTableName + "'" * sRenameColumn * "'" + sTableName + "." + sColumnName + "'" * "TO" * "'" + sNewColumnName + "'") to sStmt
84402>>>        Case End
84402>>>        
84402>>>        Move False to Err   
84403>>>        Send SqlUtilExecuteQuery sStmt sDriverID
84404>>>        Move (Err = False) to bRetval
84405>>>        // We also need to remove the cache-file since the table has been changed
84405>>>        Get UtilDeleteCacheFile sTableName to bOK
84406>>>    
84406>>>        Function_Return bRetval
84407>>>    End_Function    
84408>>>
84408>>>    Function SqlColumnType String sDriverID Handle hTable String sTableName String sColumnName Returns Integer
84410>>>        Handle hoSQLHandler hSQLConnect hStmt
84410>>>        Boolean bMertechDriver                                     
84410>>>        Integer iNumCols iCount iSQLType iDataType
84410>>>        String sValue 
84410>>>        
84410>>>        Get IsMertechDriver sDriverID to bMertechDriver
84411>>>        If (bMertechDriver = False) Begin
84413>>>            Get phoSQLManager to hoSQLHandler
84414>>>        End                                  
84414>>>>
84414>>>        Else Begin
84415>>>            Get _MertechSQLManagerHandle to hoSQLHandler
84416>>>        End                                    
84416>>>>
84416>>>        
84416>>>        Get SQLFileConnect of hoSQLHandler hTable to hSQLConnect
84417>>>        If (hSQLConnect <> 0) Begin
84419>>>            Get SQLOpen of hSQLConnect to hStmt
84420>>>            If (hStmt <> 0) Begin
84422>>>                Send SQLExecDirect of hStmt ("select * from" * sTableName)
84423>>>        
84423>>>                Get SQLStmtAttribute of hStmt SQLSTMTATTRIB_COLUMNCOUNT to iNumCols
84424>>>                For iCount from 1 to iNumCols
84430>>>>
84430>>>                    Get SQLColAttribute of hStmt iCount SQLCOLATTRIB_LABEL to sValue
84431>>>                    If (Lowercase(sValue) = Lowercase(sColumnName)) Begin
84433>>>                        Get SQLColAttribute of hStmt iCount SQLCOLATTRIB_SQLTYPE to iDataType
84434>>>                        Move iNumCols to iCount // We're out of here
84435>>>                    End
84435>>>>
84435>>>                Loop                                                
84436>>>>
84436>>>                
84436>>>                Send SQLClose of hStmt
84437>>>            End
84437>>>>
84437>>>            Send SQLDisconnect of hSQLConnect    
84438>>>        End
84438>>>>
84438>>>        
84438>>>        Function_Return iDataType
84439>>>    End_Function
84440>>>        
84440>>>    
84440>>>    // *** SQL Utility Messages ***
84440>>>    // They are not geared at making database changes.
84440>>>    //
84440>>>
84440>>>    // Will create an SQL table with the passed sTableName & sColumnName as Numeric 4.2 to keep
84440>>>    // the DbUpdateVersion database revision in.  
84440>>>    // Also pass the file number of the current (embedded?) table number used in development.
84440>>>    // It will first create the SQL Table & column, then create the .int file and change Filelist.cfg
84440>>>    Function SQLCreateDbVersionTable Handle hTable String sColumnName String sDriverID Returns Boolean
84442>>>        Boolean bOK bOpened
84442>>>        String sTableName sDataType sAlterTable sAddColumn sLengthAndDecimals sStmt sDropColumn
84442>>>        
84442>>>        Get_Attribute DF_FILE_ROOT_NAME of hTable to sTableName
84445>>>        Get _TableNameOnly sTableName to sTableName   
84446>>>        If (sTableName = "") Begin
84448>>>            Function_Return False
84449>>>        End 
84449>>>>
84449>>>        
84449>>>        // This just creates the table and a "dummy" column.
84449>>>        Get SqlTableCreate hTable sDriverID to bOK
84450>>>        If (bOK = False) Begin
84452>>>            Function_Return False 
84453>>>        End                      
84453>>>>
84453>>>        
84453>>>        Close hTable
84454>>>        Move False to Err
84455>>>        
84455>>>        Get _SqlFindKeyWord CI_SQLAlterTable to sAlterTable
84456>>>        Get _SqlFindKeyWord CI_SQLAdd        to sAddColumn
84457>>>        Move "Decimal" to sDataType
84458>>>        Get _SqlFormatLengthAndDecimalAsString 4 2 to sLengthAndDecimals
84459>>>        
84459>>>        // Adds the "sColumnName" passed to the function
84459>>>        Move (sAlterTable * sTableName * sAddColumn * sColumnName * sDataType + sLengthAndDecimals) to sStmt 
84460>>>        Send SqlUtilExecuteQuery sStmt sDriverID
84461>>>        
84461>>>        // Now we can delete the dummy column:
84461>>>        Get SqlColumnRemoveByTableName sTableName "Dummy" to bOK
84462>>>        
84462>>>        // Finally, we attach to the newly created table.
84462>>>        If (Err = False) Begin    
84464>>>            Get ApiTableAttachToSQL hTable True to bOK
84465>>>        End
84465>>>>
84465>>>        Open hTable                                                  
84467>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpened
84470>>>        
84470>>>        Function_Return (Err = False and bOK = True and bOpened = True)
84471>>>    End_Function
84472>>>    
84472>>>    // Checks if a column/field name exists in a SQL table definition
84472>>>    // Returns True if it does
84472>>>    // Sample:
84472>>>    //   Get SQLUtilColumnExists "MySQLTable" "MyColumnName" to bExists
84472>>>    Function SQLUtilColumnExists String sTableName String sFieldName Returns Boolean
84474>>>        Integer iNumColumns iColumn
84474>>>        String sColumn sDriverID
84474>>>        String[] sColumnsArray
84475>>>        Boolean bExists bOK
84475>>>    
84475>>>        Move False to bExists  
84476>>>        Get AutoConnectionIDLogin to bOK
84477>>>        Get psDriverID to sDriverID
84478>>>        
84478>>>        Get SqlUtilEnumerateColumns sDriverID sTableName to sColumnsArray
84479>>>        Move (SizeOfArray(sColumnsArray)) to iNumColumns
84480>>>        Decrement iNumColumns
84481>>>        For iColumn from 0 to iNumColumns
84487>>>>
84487>>>            Move sColumnsArray[iColumn] to sColumn
84488>>>            If (Uppercase(sFieldName) = Uppercase(sColumn)) Begin
84490>>>                Move True to bExists
84491>>>                Move iNumColumns to iColumn // We're out of here
84492>>>            End
84492>>>>
84492>>>        Loop
84493>>>>
84493>>>    
84493>>>        Function_Return bExists
84494>>>    End_Function
84495>>>    
84495>>>    Function SQLUtilConvertColumnTypesToSQL2008 Handle hTable Returns Boolean
84497>>>        Integer iNumColumns iColumn iDFType iNativeType
84497>>>        Boolean bOpened bOK
84497>>>        String sColumnName sNativeTypeName
84497>>>        
84497>>>        Get AutoConnectionIDLogin to bOK
84498>>>        Open hTable Mode DF_EXCLUSIVE
84500>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpened
84503>>>        If (bOpened = False) Begin
84505>>>            Error DFERR_PROGRAM ("Function SQLUtilConvertColumnTypesToSQL2008; Could not open table" * String(hTable))
84506>>>>
84506>>>            Function_Return False 
84507>>>        End
84507>>>>
84507>>>        
84507>>>        Move False to Err                               
84508>>>        
84508>>>        Structure_Start hTable
84509>>>            Get_Attribute DF_FILE_NUMBER_FIELDS of hTable to iNumColumns
84512>>>        
84512>>>            For iColumn from 1 to iNumColumns
84518>>>>
84518>>>                Get_Attribute DF_FIELD_TYPE             of hTable iColumn to iDfType
84521>>>                Get_Attribute DF_FIELD_NAME             of hTable iColumn to sColumnName
84524>>>                Get_Attribute DF_FIELD_NATIVE_TYPE      of hTable iColumn to iNativeType
84527>>>                Get_Attribute DF_FIELD_NATIVE_TYPE_Name of hTable iColumn to sNativeTypeName
84530>>>                
84530>>>                Case Begin
84530>>>                    Case (iDFType = DF_DATE) 
84532>>>                        If (iNativeType = SQL_TYPE_TIMESTAMP) Begin
84534>>>                            // Convert datetime to date
84534>>>                            Set_Attribute DF_FIELD_NATIVE_TYPE of hTable iColumn to SQL_TYPE_DATE
84537>>>                        End
84537>>>>
84537>>>                        Case Break
84538>>>                    Case (iDFType = DF_DATETIME) 
84541>>>                        If (iNativeType = SQL_TYPE_TIMESTAMP) Begin
84543>>>                            // Convert datetime to datetime2
84543>>>                            Set_Attribute DF_FIELD_NATIVE_TYPE of hTable iColumn to SQL_TYPE_TIMESTAMP2
84546>>>                        End
84546>>>>
84546>>>                        Case Break
84547>>>                    Case (iDFType = DF_ASCII) 
84550>>>                        If (iNativeType = SQL_CHAR) Begin
84552>>>                            // Convert char to varchar
84552>>>                            Set_Attribute DF_FIELD_NATIVE_TYPE of hTable iColumn to SQL_VARCHAR
84555>>>                        End
84555>>>>
84555>>>                        Case Break
84556>>>                    Case (iDFType = DF_TEXT) 
84559>>>                        If (iNativeType = SQL_LONGVARCHAR) Begin 
84561>>>                            // Convert text to varchar(max)
84561>>>                            Set_Attribute DF_FIELD_NATIVE_TYPE of hTable iColumn to SQL_VARCHAR
84564>>>                        End
84564>>>>
84564>>>                        Case Break
84565>>>                    Case (iDFType = DF_BINARY) 
84568>>>                        If (iNativeType = SQL_LONGVARBINARY) Begin
84570>>>                            // Convert image to varbinary(max)
84570>>>                            Set_Attribute DF_FIELD_NATIVE_TYPE of hTable iColumn to SQL_VARBINARY
84573>>>                        End
84573>>>>
84573>>>                        Case Break
84574>>>                Case End
84574>>>            Loop
84575>>>>
84575>>>        Structure_End hTable
84577>>>    
84577>>>        Function_Return (Err = False)    
84578>>>    End_Function  
