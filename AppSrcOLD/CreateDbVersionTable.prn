85122>>>    // Returns a string array with all table columns/fields for the passed table handle and driver id.
85122>>>    Function SqlUtilEnumerateColumns String sDriverID String sTableName Returns String[]
85124>>>        String[] sReturnArray                                          
85125>>>        String sServer sConnectionString sSelect sSchema
85125>>>        Boolean bOK
85125>>>        
85125>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
85126>>>        If (bOK = False) Begin
85128>>>            Error DFERR_PROGRAM ("Unsupported driver. A list of table columns could not be retrieved for:" * sDriverID + ".")
85129>>>>
85129>>>            Function_Return sReturnArray
85130>>>        End   
85130>>>>
85130>>>       
85130>>>        Get psConnectionString to sConnectionString  
85131>>>        Get psSchema to sSchema
85132>>>        
85132>>>        Case Begin
85132>>>            Case (sDriverID = MSSQLDRV_ID)    
85134>>>                Move ("select name from sys.columns where [object_id] = object_id('dbo." + sTableName + "')") to sSelect
85135>>>                Get SqlEnumerateEsqlDAW sSelect 1 to sReturnArray
85136>>>                Case Break
85137>>>
85137>>>            Case (sDriverID = DB2_DRV_ID) 
85140>>>                Move ("SELECT colname from syscat.columns WHERE tabschema = '" + sSchema + "'" * "AND tabname = '" + sTableName + "'") to sSelect  
85141>>>                Get SqlEnumerateEsqlDAW sSelect 1 to sReturnArray
85142>>>                Case Break
85143>>>
85143>>>            Case (sDriverID = SQLFLEX)
85146>>>                Move ("select name from sys.columns where [object_id] = object_id('dbo." + sTableName + "')") to sSelect
85147>>>                Get SqlEnumerateEsqlMertech sSelect 1 to sReturnArray
85148>>>                Case Break
85149>>>            
85149>>>            Case (sDriverID = MDSMySQL) 
85152>>>                Move ("SHOW COLUMNS FROM" * sTableName) to sSelect
85153>>>                Get SqlEnumerateEsqlMertech sSelect 1 to sReturnArray
85154>>>                Case Break
85155>>>            
85155>>>            Case (sDriverID = MDSPgSQL) 
85158>>>                Move ("select column_name, data_type, character_maximum_length from INFORMATION_SCHEMA.COLUMNS where table_name = '" +sTableName + "'") to sSelect
85159>>>                Get SqlEnumerateEsqlMertech sSelect 1 to sReturnArray
85160>>>                Case Break            
85161>>>            
85161>>>            Case (sDriverID = ORAFLEX) 
85164>>>                Move ("SELECT column_name from user_tab_cols WHERE table_name = '" + sTableName + "'") to sSelect
85165>>>                Get SqlEnumerateEsqlMertech sSelect 1 to sReturnArray
85166>>>                Case Break
85167>>>                            
85167>>>            Case Else     
85167>>>                Error DFERR_PROGRAM "Unsupported driver passed to SqlUtilEnumerateColumns function."
85168>>>>
85168>>>                Case Break
85169>>>        Case End
85169>>>        
85169>>>        Function_Return sReturnArray
85170>>>    End_Function  
