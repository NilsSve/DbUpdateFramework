87223>>>        
87223>>>        If (sDriverID <> DATAFLEX_ID) Begin
87225>>>            Get SqlTableRemoveByTableName sDriverID sTableName to bOk   
87226>>>            Get psDataPathFirstPart to sDataPath
87227>>>            Get vDeleteFile (sDataPath + sTableName + ".int") to bOk
87228>>>        End
87228>>>>
