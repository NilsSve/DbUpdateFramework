81874>>>>>        Property String[] paSQLFetchResults
81875>>>>>
81875>>>>>        // Error handling
81875>>>>>        Property Boolean pbSqlError False 
81876>>>>>        Property tSqlErrorArray paSqlErrorArray
81877>>>>>        Property Boolean pbProcessingError False
81878>>>>>
81878>>>>>        // Statistics on query
81878>>>>>        Property TimeSpan ptsTotalQueryTime
81879>>>>>        Property TimeSpan ptsQueryExec
81880>>>>>        Property TimeSpan ptsFetchResults
81881>>>>>        Property Integer piColumns 0
81882>>>>>        Property Integer piRows 0
81883>>>>>        Property Integer piRowType 0
81884>>>>>        Property String[] paQueryMessages  
81885>>>>>        Property String psSQLStatementString 
81886>>>>>        
81886>>>>>        // How many SQL statements to send of to be executed when a really big
81886>>>>>        // SQL file has been compiled into the program. It is way faster to divide
81886>>>>>        // the statements in smaller chunks than to execute them all at the same time.
81886>>>>>        Property Integer piChunkMax 500  
81887>>>>>        
81887>>>>>        // Driver default value settings:
81887>>>>>        // Note: When the object is created the corresponding values
81887>>>>>        // from the driver .int files are read.
81887>>>>>        // Sample: Get_Attribute DF_DRIVER_DEFAULT_DEFAULT_NUMERIC of {driverNumber} to {StringVariable}
81887>>>>>        Property String psDriverDefaultValueASCII    ""
81888>>>>>        Property String psDriverDefaultValueBinary   ""
81889>>>>>        Property String psDriverDefaultValueDate     ""
81890>>>>>        Property String psDriverDefaultValueDateTime ""
81891>>>>>        Property String psDriverDefaultValueNumeric  ""
81892>>>>>        Property String psDriverDefaultValueText     ""
81893>>>>>        
81893>>>>>        // Driver "nullability" settings:
81893>>>>>        // Note: When the object is created the corresponding values
81893>>>>>        // from the driver .int files are read.
81893>>>>>        // Get_Attribute DF_DRIVER_DEFAULT_NULLABLE_ASCII of {driverNumber} to {BooleanVariable}
81893>>>>>        Property Boolean pbDriverDefaultNullableASCII    False
81894>>>>>        Property Boolean pbDriverDefaultNullableBinary   False
81895>>>>>        Property Boolean pbDriverDefaultNullableDate     False
81896>>>>>        Property Boolean pbDriverDefaultNullableDateTime False
81897>>>>>        Property Boolean pbDriverDefaultNullableNumeric  False
81898>>>>>        Property Boolean pbDriverDefaultNullableText     False
81899>>>>>    
