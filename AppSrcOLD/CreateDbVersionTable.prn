87682>>>    // Checks if a field name exists in a table definition
87682>>>    // Returns True if it does
87682>>>    // Sample:
87682>>>    //   Get UtilColumnExists MyTable.File_Number "MyColumnName" to iExists
87682>>>    Function UtilColumnExists Handle hTable String sFieldName Returns Boolean
87684>>>        Integer iNumColumns iColumn
87684>>>        String sColumn
87684>>>        Boolean bExists bOK
87684>>>    
87684>>>        Get AutoConnectionIDLogin to bOK
87685>>>        Send Ignore_Error of Error_Object_Id DFERR_CANT_OPEN_DATA_FILE
87686>>>        Open hTable                       
87688>>>        Send Trap_Error   of Error_Object_Id DFERR_CANT_OPEN_DATA_FILE
87689>>>        If (Found = False) Begin
87691>>>            Function_Return False
87692>>>        End                      
87692>>>>
87692>>>        
87692>>>        Move False to bExists  
87693>>>        Get_Attribute DF_FILE_NUMBER_FIELDS of hTable to iNumColumns
87696>>>        for iColumn from 1 to iNumColumns
87702>>>>
87702>>>            Get_Attribute DF_FIELD_NAME of hTable iColumn to sColumn
87705>>>            If (Uppercase(sFieldName) = Uppercase(sColumn)) Begin
87707>>>                Move iNumColumns to iColumn
87708>>>                Move True to bExists
87709>>>            End
87709>>>>
87709>>>        Loop
87710>>>>
87710>>>        Close hTable
87711>>>    
87711>>>        Function_Return bExists
87712>>>    End_Function
87713>>>    
87713>>>    // Checks if the current psConnectionID is logged in; if not
87713>>>    // attempts to make a login. 
87713>>>    // Because
87713>>>    // Returns True if already logged in or the new login was successful.
87713>>>    Function AutoConnectionIDLogin Returns Boolean
87715>>>        String sConnectionID sConnectionString sDriverID
87715>>>        Boolean bExists bOK bDAWDriver
87715>>>        Handle hoCLI hoDriver                                    
87715>>>        Integer iRetval
87715>>>        tSQLConnection SQLConnection
87715>>>        tSQLConnection SQLConnection
87715>>>        
87715>>>        Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
87716>>>        Move SQLConnection.sDriverID                  to sDriverID      
87717>>>        Move SQLConnection.sConnectionString          to sConnectionString
87718>>>        Get IsDAWSQLDriver sDriverID to bOK
87719>>>        If (bOK = False) Begin                         
87721>>>            Get _MertechSQLManagerHandle to hoCLI
87722>>>            Get Create (RefClass(cDbUpdateDatabaseDriver)) to hoDriver
87723>>>            Set psDriverID of hoDriver to SQLConnection.sDriverID
87724>>>            Get DbLogin    of hoDriver sConnectionString SQLConnection.sServer SQLConnection.sDatabase SQLConnection.bTrusted SQLConnection.sUserID SQLConnection.sPassword to bOK
87725>>>            Send Destroy   of hoDriver
87726>>>            Function_Return False
87727>>>        End                      
87727>>>>
87727>>>        
87727>>>        Move SQLConnection.sConnectionID to sConnectionID
87728>>>        
87728>>>        Get IsConnectionID sConnectionID sDriverID to bExists
87729>>>        If (bExists = False) Begin
87731>>>            // We always start by deleting the current connection - if any - because the
87731>>>            // login details my have changed.
87731>>>            Get phoCLIHandler to hoCLI   
87732>>>            Set psDriverID    of hoCLI to sDriverID
87733>>>            Get DeleteConnectionID of hoCLI sConnectionID -1 to iRetval
87734>>>            Get UtilCreateConnectionID sConnectionID to bOk
87735>>>            If (bOk = False) Begin
87737>>>                Error DFERR_PROGRAM ("The Connection ID:" * sConnectionID * "could not be created and therefor the table can't be changed.")
87738>>>>
87738>>>                Function_Return False
87739>>>            End
87739>>>>
87739>>>            Move bOK to bExists
87740>>>        End
87740>>>>
87740>>>        
87740>>>        Function_Return (bExists = True)
87741>>>    End_Function
87742>>>    
87742>>>    // *** Utility Messages ***
87742>>>    // 
87742>>>    //
87742>>>    // To add a value to the CodeMast & CodeType tables. Pass; a) bCodeType if it is CodeType that should be updated. 
87742>>>    // Else it is CodeMast. b) sTypeValue; either to be added If bCodeType = True, or it will be used to find the correct 
87742>>>    // CodeType record. c) sValue1 and d) sValue2 is the CodeType Description & Comment, or CodeMast Type and Code values.
87742>>>    Function UtilCodeMasterAddValue Boolean bCodeType String sTypeValue String sValue2 String sValue3 Returns Boolean
87744>>>        Boolean bError bFound
87744>>>        
87744>>>        Move False to Err
87745>>>        Open CodeMast
87747>>>        Open CodeType
87749>>>        
87749>>>        If (bCodeType = True) Begin
87751>>>            Clear CodeType
87752>>>            Move sTypeValue to CODETYPE.Type 
87753>>>            Find eq CODETYPE.Type
87754>>>>
87754>>>            Move (Found = True) to bFound
87755>>>            If (bFound = True) Begin
87757>>>                Reread CodeType
87761>>>            End
87761>>>>
87761>>>            If (bFound = False) Begin
87763>>>                Clear CodeType
87764>>>            End       
87764>>>>
87764>>>                Move sTypeValue to CODETYPE.Type 
87765>>>                Move sValue2    to CODETYPE.Description
87766>>>                Move sValue3    to CODETYPE.Comment
87767>>>                SaveRecord CODETYPE
87768>>>            If (bFound = True) Begin
87770>>>                Unlock
87771>>>>
87771>>>            End
87771>>>>
87771>>>        End
87771>>>>
87771>>>        
87771>>>        If (bCodeType = False) Begin
87773>>>            Clear CODEMAST
87774>>>            Move sTypeValue to CODEMAST.Type
87775>>>            Move sValue2    to CODEMAST.Code  
87776>>>            Find eq CODEMAST.Code
87777>>>>
87777>>>            Move (Found = True) to bFound
87778>>>            If (bFound = True) Begin
87780>>>                Reread CODEMAST
87784>>>            End
87784>>>>
87784>>>            If (bFound = False) Begin
87786>>>                Clear CODEMAST
87787>>>            End   
87787>>>>
87787>>>                Move sTypeValue to CODEMAST.Type
87788>>>                Move sValue2    to CODEMAST.Code  
87789>>>                Move sValue3    to CODEMAST.Description
87790>>>                SaveRecord CODEMAST
87791>>>            If (bFound = True) Begin
87793>>>            Unlock
87794>>>>
87794>>>            End
87794>>>>
87794>>>        End
87794>>>>
87794>>>        
87794>>>        Close CodeMast
87795>>>        Close CodeType
87796>>>        
87796>>>        Function_Return (Err = False)
87797>>>    End_Function
87798>>>
87798>>>    // Changes values in CodeType & CodeMast - From type value To type value. It first changes the type value in 
87798>>>    // CodeType and then spins through all CodeMast records to change all related records.
87798>>>    Function UtilCodeMasterChangeValue String sFromValue String sToValue Returns Boolean
87800>>>        Boolean bFound
87800>>>        
87800>>>        Move False to Err
87801>>>        Open CodeMast
87803>>>        Open CodeType
87805>>>        
87805>>>        Clear CodeType
87806>>>        Move sFromValue to CODETYPE.Type
87807>>>        Find eq CODETYPE.Type
87808>>>>
87808>>>        If (Found = True) Begin
87810>>>            Reread CODETYPE
87814>>>                Move sToValue to CODETYPE.Type
87815>>>                SaveRecord CODETYPE
87816>>>            Unlock                 
87817>>>>
87817>>>        End
87817>>>>
87817>>>            
87817>>>        Clear CODEMAST
87818>>>        Find gt CODEMAST by Recnum
87819>>>>
87819>>>        While (Found = True)
87823>>>            Move (Trim(Uppercase(CODEMAST.Type) = Trim(Uppercase(sFromValue)))) to bFound
87824>>>            If (bFound = True) Begin
87826>>>                Reread CODEMAST
87830>>>                    Move sToValue to CODEMAST.Type
87831>>>                    SaveRecord CODEMAST
87832>>>                Unlock
87833>>>>
87833>>>            End
87833>>>>
87833>>>            Find gt CODEMAST by Recnum
87834>>>>
87834>>>        Loop
87835>>>>
87835>>>        
87835>>>        Close CodeMast
87836>>>        Close CodeType
87837>>>        
87837>>>        Function_Return (Err = False)
87838>>>    End_Function
87839>>>    
87839>>>    // Removes a value from CodeMast. Pass the sTypeValue and the sValue2 to remove.
87839>>>    Function UtilCodeMasterRemoveValue String sTypeValue String sValue2 Returns Boolean
87841>>>        Boolean bError bFound
87841>>>        
87841>>>        Move False to Err
87842>>>        Open CodeMast
87844>>>        
87844>>>        Clear CODEMAST
87845>>>        Move sTypeValue to CODEMAST.Type
87846>>>        Move sValue2    to CODEMAST.Code  
87847>>>        Find eq CODEMAST.Code
87848>>>>
87848>>>        Move (Found = True) to bFound
87849>>>        If (bFound = True) Begin
87851>>>            Delete CODEMAST
87852>>>        End
87852>>>>
87852>>>        
87852>>>        Close CodeMast
87853>>>        
87853>>>        Function_Return (Err = False)
87854>>>    End_Function
87855>>>
87855>>>    // Note:
87855>>>    // The DF_FILE_TABLE_NAME attribute holds the name of the table at the back end. Depending on the back end, table 
87855>>>    // names may be case sensitive, contain spaces or other special characters. This attribute is used to determine a table's 
87855>>>    // back end name when using Embedded SQL. Since Embedded SQL works on the back end directly, the back end's name must be used. 
87855>>>    // In most cases the back end name will be the same as the table name used in DataFlex.
87855>>>    // To do the opposite; To get the file handle from a table name string use the UtilTableNameToHandle function.
87855>>>    Function UtilTableHandleToString Handle hTable Returns String
87857>>>        String sTableName
87857>>>        Boolean bOpen bExists bRecnum bOK
87857>>>        
87857>>>        Get UtilTableNumberIsInUse hTable to bExists
87858>>>        If (bExists = False) Begin
87860>>>            Move True to Err
87861>>>            Function_Return ""
87862>>>        End
87862>>>>
87862>>>
87862>>>        Set Error_Report_Mode to DUF_ERROR_NO_REPORT
87863>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpen
87866>>>        If (bOpen = False) Begin                       
87868>>>            Get AutoConnectionIDLogin to bOK
87869>>>            Send Ignore_Error of Error_Object_Id DFERR_CANT_OPEN_DATA_FILE
87870>>>            Send Ignore_Error of Error_Object_Id DFERR_CANT_OPEN_INTERMEDIATE_FILE
87871>>>            Send Ignore_Error of Error_Object_Id CLIERR_GENERAL_ERROR
87872>>>            Open hTable
87874>>>            Send Trap_Error of Error_Object_Id DFERR_CANT_OPEN_DATA_FILE
87875>>>            Send Trap_Error of Error_Object_Id DFERR_CANT_OPEN_INTERMEDIATE_FILE
87876>>>            Send Trap_Error of Error_Object_Id CLIERR_GENERAL_ERROR
87877>>>            Get_Attribute DF_FILE_OPENED of hTable to bOpen
87880>>>        End
87880>>>>
87880>>>        If (bOpen = True) Begin
87882>>>            Send Ignore_Error of Error_Object_Id DFERR_UNSUPPORTED_ATTRIBUTE 
87883>>>            Get_Attribute DF_FILE_TABLE_NAME of hTable to sTableName 
87886>>>            // If blank it is an embedded table:
87886>>>            If (sTableName = "") Begin
87888>>>                Get_Attribute DF_FILE_LOGICAL_NAME of hTable to sTableName 
87891>>>                Move 0 to LastErr
87892>>>                Move False to Err
87893>>>            End
87893>>>>
87893>>>            Send Trap_Error of Error_Object_Id DFERR_UNSUPPORTED_ATTRIBUTE
87894>>>        End
87894>>>>
87894>>>        Set Error_Report_Mode to DUF_ERROR_REPORT
87895>>>            
87895>>>        Function_Return sTableName
87896>>>    End_Function
87897>>>    
87897>>>    // Returns the filenumber for the passed Table name from Filelist.cfg.
87897>>>    // Returns 0 if unsuccessful.
87897>>>    // To do the opposite; To get the string value from a table handle string use the UtilTableHandleToString function.
87897>>>    Function UtilTableNameToHandle String sTableName Returns Integer
87899>>>        String sValue sPrefixTableName sDriverID
87899>>>        Handle hTable hRetval
87899>>>        
87899>>>        Get psDriverID to sDriverID 
87900>>>        If (sDriverID <> DATAFLEX_ID and not(sTableName contains ":")) Begin
87902>>>            Move (sDriverID + ":" + sTableName) to sPrefixTableName
87903>>>        End
87903>>>>
87903>>>        Move 0 to hTable 
87904>>>        Move 0 to hRetval
87905>>>        Repeat 
87905>>>>
87905>>>            Get_Attribute DF_FILE_NEXT_USED of hTable to hTable
87908>>>            If (hTable <> 0) Begin
87910>>>                Get_Attribute DF_FILE_ROOT_NAME of hTable to sValue
87913>>>                If (Uppercase(sValue) = Uppercase(sTableName) or Uppercase(sValue) = Uppercase(sPrefixTableName)) Begin
87915>>>                    Move hTable to hRetval
87916>>>                    Move 0 to hTable
87917>>>                End
87917>>>>
87917>>>            End
87917>>>>
87917>>>        Until (hTable = 0)
87919>>>        
87919>>>        Function_Return hRetval
87920>>>    End_Function
87921>>>        
87921>>>    // Check if the file exists in the Data folder,
87921>>>    // else creates it from memory as it has been compiled into the program as a resource:
87921>>>    Function UtilCheckCreateIfFileExists String sFileName String sResourceName Boolean bDataFile Returns Boolean
87923>>>        String sPath sDataPath
87923>>>        Boolean bExists
87923>>>    
87923>>>        Get psDataPathFirstPart to sPath
87924>>>        Move (sPath + sFileName) to sFileName
87925>>>        Get vFilePathExists sFileName to bExists
87926>>>    
87926>>>        If (bExists = False) Begin
87928>>>            // Read from memory & create file on disk.
87928>>>            Send SqlUtilCreateFileFromMemory sResourceName sFileName
87929>>>            Get vFilePathExists sFileName to bExists
87930>>>        End     
87930>>>>
87930>>>        Function_Return bExists
87931>>>    End_Function
