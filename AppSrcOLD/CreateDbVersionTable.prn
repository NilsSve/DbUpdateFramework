87504>>>        Get AutoConnectionIDLogin to bOK
87505>>>        Move -1 to iSegment1
87506>>>        Move -1 to iSegment2
87507>>>        Move -1 to iSegment3
87508>>>        Move -1 to iSegment4
87509>>>        Move -1 to iSegment5
87510>>>        Move -1 to iSegment6
87511>>>        Move -1 to iSegment7
87512>>>        Move -1 to iSegment8
87513>>>        Move -1 to iSegment9
87514>>>        Move -1 to iSegment10
87515>>>        
87515>>>        If (num_arguments > 3) Begin
87517>>>            Move iSgmnt1 to iSegment1
87518>>>        End
87518>>>>
87518>>>        If (num_arguments > 4) Begin
87520>>>            Move iSgmnt2 to iSegment2
87521>>>        End
87521>>>>
87521>>>        If (num_arguments > 5) Begin
87523>>>            Move iSgmnt3 to iSegment3
87524>>>        End
87524>>>>
87524>>>        If (num_arguments > 6) Begin
87526>>>            Move iSgmnt4 to iSegment4
87527>>>        End
87527>>>>
87527>>>        If (num_arguments > 7) Begin
87529>>>            Move iSgmnt5 to iSegment5
87530>>>        End
87530>>>>
87530>>>        If (num_arguments > 8) Begin
87532>>>            Move iSgmnt6 to iSegment6
87533>>>        End
87533>>>>
87533>>>        If (num_arguments > 9) Begin
87535>>>            Move iSgmnt7 to iSegment7
87536>>>        End
87536>>>>
87536>>>        If (num_arguments > 10) Begin
87538>>>            Move iSgmnt8 to iSegment8
87539>>>        End
87539>>>>
87539>>>        If (num_arguments > 11) Begin
87541>>>            Move iSgmnt9 to iSegment9
87542>>>        End
87542>>>>
87542>>>        If (num_arguments > 12) Begin
87544>>>            Move iSgmnt10 to iSegment10
87545>>>        End
87545>>>>
87545>>>        
87545>>>        Move False to Err
87546>>>        Move hTable to iTableNo
87547>>>        Open hTable Mode DF_EXCLUSIVE
87549>>>        Get_Attribute DF_FILE_DRIVER of hTable to sDriverID
87552>>>        
87552>>>        // We start by deleting the index
87552>>>        Structure_Start hTable sDriverID 
87553>>>            Set Error_Report_Mode to DUF_ERROR_NO_REPORT
87554>>>            Send Ignore_Error of Error_Object_Id DFERR_BAD_PARAMETER
87555>>>            Delete_Index iTableNo iIndex
87556>>>            Set Error_Report_Mode to DUF_ERROR_REPORT
87557>>>            Send Trap_Error of Error_Object_Id DFERR_BAD_PARAMETER
87558>>>        Structure_End hTable DF_STRUCTEND_OPT_NONE
87560>>>        
87560>>>        Move False to Err
87561>>>        Move iTableNo to hTable
87562>>>        Open hTable Mode DF_EXCLUSIVE
87564>>>    
87564>>>        Send Ignore_Error of Error_Object_Id CLIERR_GENERAL_ERROR
87565>>>        Structure_Start hTable sDriverID
87566>>>            Create_Index hTable At iIndex
87567>>>            Set_Attribute DF_INDEX_NUMBER_SEGMENTS of hTable iIndex to iSegments
87570>>>    
87570>>>            If (iSgmnt1 <> -1) Begin
87572>>>                Set_Attribute DF_INDEX_SEGMENT_FIELD of hTable iIndex 1 to iSegment1
87575>>>            End
87575>>>>
87575>>>            If (iSegment2 <> -1) Begin
87577>>>                Set_Attribute DF_INDEX_SEGMENT_FIELD of hTable iIndex 2 to iSegment2
87580>>>            End
87580>>>>
87580>>>            If (iSegment3 <> -1) Begin
87582>>>                Set_Attribute DF_INDEX_SEGMENT_FIELD of hTable iIndex 3 to iSegment3
87585>>>            End
87585>>>>
87585>>>            If (iSegment4 <> -1) Begin
87587>>>                Set_Attribute DF_INDEX_SEGMENT_FIELD of hTable iIndex 4 to iSegment4
87590>>>            End
87590>>>>
87590>>>            If (iSegment5 <> -1) Begin
87592>>>                Set_Attribute DF_INDEX_SEGMENT_FIELD of hTable iIndex 5 to iSegment5
87595>>>            End
87595>>>>
87595>>>            If (iSegment6 <> -1) Begin
87597>>>                Set_Attribute DF_INDEX_SEGMENT_FIELD of hTable iIndex 6 to iSegment6
87600>>>            End
87600>>>>
87600>>>            If (iSegment7 <> -1) Begin
87602>>>                Set_Attribute DF_INDEX_SEGMENT_FIELD of hTable iIndex 7 to iSegment7
87605>>>            End
87605>>>>
87605>>>            If (iSegment8 <> -1) Begin
87607>>>                Set_Attribute DF_INDEX_SEGMENT_FIELD of hTable iIndex 8 to iSegment8
87610>>>            End
87610>>>>
87610>>>            If (iSegment9 <> -1) Begin
87612>>>                Set_Attribute DF_INDEX_SEGMENT_FIELD of hTable iIndex 9 to iSegment9
87615>>>            End
87615>>>>
87615>>>            If (iSegment10 <> -1) Begin
87617>>>                Set_Attribute DF_INDEX_SEGMENT_FIELD of hTable iIndex 10 to iSegment10
87620>>>            End
87620>>>>
87620>>>        Structure_End hTable DF_STRUCTEND_OPT_NONE
87622>>>    
87622>>>        Send Trap_Error of Error_Object_Id CLIERR_GENERAL_ERROR
87623>>>        
87623>>>        Function_Return (Err = False)
87624>>>    End_Function
