84087>>>    // *** Sql Column Messages ***
84087>>>    //
84087>>>    // Sample: Get SqlColumnAdd MyTable.File_Number "NewColumnName" True "InitValue" DF_ASCII 35  
84087>>>    Function SqlColumnAdd Integer hTable String sColumnName Integer iDataType Integer iLen Integer iDec Boolean bInitVal String sColVal Returns Boolean
84089>>>        Integer iColumn iDbType iLength iDecimals
84089>>>        String sStmt sAlterTable sAddColumn sModifyColumn sVal sDataType sLengthAndDecimals sColumnValue
84089>>>        String sTableName sDriverID sUpdate sSet sNoCountOn
84089>>>        Boolean bExists bOK bInitializeValue 
84089>>>        
84089>>>        Get psDriverID to sDriverID
84090>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
84091>>>        If (bOK = False) Begin   
84093>>>            Function_Return False
84094>>>        End              
84094>>>>
84094>>>        
84094>>>        Get UtilTableHandleToString hTable to sTableName
84095>>>        If (sTableName = "") Begin
84097>>>            Function_Return False    
84098>>>        End  
84098>>>>
84098>>>        
84098>>>        If (num_arguments > 4) Begin
84100>>>            Move iDec     to iDecimals
84101>>>            Move bInitVal to bInitializeValue                                      
84102>>>            Move sColVal  to sColumnValue
84103>>>        End                       
84103>>>>
84103>>>        
84103>>>        Get SqlColumnAddByTableName sTableName sColumnName iDataType iLen iDecimals bInitializeValue sColumnValue to bOK
84104>>>        
84104>>>        Function_Return (bOK = True)    
84105>>>    End_Function  
84106>>>    
84106>>>    // Sample: Get SqlColumnAddByTableName "MyTable" "NewColumnName" DF_ASCII 35 0 True "InitValue" 
84106>>>    Function SqlColumnAddByTableName String sTableName String sColumnName Integer iDataType Integer iLen Integer iDec Boolean bInitVal String sColVal Returns Boolean
84108>>>        Integer iColumn iDbType iLength iDecimals iDriver
84108>>>        String sStmt sAlterTable sAddColumn sModifyColumn sVal sDataType sLengthAndDecimals sColumnValue
84108>>>        String sDriverID sUpdate sSet sNoCountOn sNotNull
84108>>>        Boolean bExists bOK bInitializeValue bRetval bFixed bDriverIgnoreErrorState
84108>>>        Handle hTable 
84108>>>        
84108>>>        Get psDriverID to sDriverID
84109>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
84110>>>        If (bOK = False) Begin   
84112>>>            Function_Return False
84113>>>        End              
84113>>>>
84113>>>        
84113>>>        Get UtilTableNameToHandle sTableName to hTable
84114>>>        If (hTable = 0) Begin
84116>>>            Get NextFreeFilelistSlot to hTable
84117>>>        End
84117>>>>
84117>>>        
84117>>>        Get piDbType to iDbType
84118>>>        // If a field/column already exists; we just ignore the request to not add unneccesary errors to the log.
84118>>>        Get _SqlFindColumnName sTableName sColumnName to sVal
84119>>>        If (Uppercase(sVal) = Uppercase(sColumnName)) Begin
84121>>>            Function_Return False
84122>>>        End
84122>>>>
84122>>>
84122>>>        Get DriverIndex sDriverID to iDriver
84123>>>        Get_Attribute DF_DRIVER_IGNORE_WARNINGS of iDriver to bDriverIgnoreErrorState
84126>>>        Set_Attribute DF_DRIVER_IGNORE_WARNINGS of iDriver to True
84129>>>
84129>>>        Get UtilColumnTypeToString sDriverID iDbType iDataType to sDataType
84130>>>        Move iLen to iLength
84131>>>        Move iDec to iDecimals                           
84132>>>        If (num_arguments > 6) Begin
84134>>>            Move bInitVal to bInitializeValue
84135>>>            Move sColVal  to sColumnValue
84136>>>        End
84136>>>>
84136>>>        
84136>>>        Get _SqlProperTableName sTableName   to sTableName
84137>>>        Get _SqlFindKeyWord CI_SQLAlterTable to sAlterTable
84138>>>        Get _SqlFindKeyWord CI_SQLAdd        to sAddColumn
84139>>>        Get SQLUtilDefaultNullValue sDriverID iDbType iDataType to sNotNull
84140>>>        
84140>>>        Get UtilColumnTypeFixed sDriverID iDbType iDataType to bFixed
84141>>>        If (bFixed = False) Begin
84143>>>            Get _SqlFormatLengthAndDecimalAsString iLength iDecimals to sLengthAndDecimals
84144>>>        End
84144>>>>
84144>>>        Move (sAlterTable * sTableName * sAddColumn * sColumnName * sDataType + sLengthAndDecimals * sNotNull) to sStmt 
84145>>>        
84145>>>        Move False to Err              
84146>>>        Send SqlUtilExecuteQuery sStmt sDriverID 
84147>>>        
84147>>>        If (bInitializeValue = True and Err = False) Begin
84149>>>            Get _SqlFindKeyWord CI_SQLUpdate       to sUpdate
84150>>>            Get _SqlFindKeyWord CI_SQLSet          to sSet
84151>>>            Get _SqlFindKeyWord CI_SQLSetNoCountOn to sNoCountOn
84152>>>            Move (sNoCountOn * sUpdate * sTableName * sSet * sColumnName + "='" + sColumnValue + "'") to sStmt
84153>>>            Send SqlUtilExecuteQuery sStmt sDriverID
84154>>>        End
84154>>>>
84154>>>
84154>>>        If (Err = False) Begin
84156>>>            Get SqlUtilAdjustAuxFiles hTable sTableName sColumnName to bOK
84157>>>        End
84157>>>>
84157>>>        
84157>>>        Move (not(Err)) to bRetval 
84158>>>        
84158>>>        // We also need to remove the cache-file since the table has been changed
84158>>>        Get UtilDeleteCacheFile sTableName to bOK
84159>>>        Set_Attribute DF_DRIVER_IGNORE_WARNINGS of iDriver to bDriverIgnoreErrorState
84162>>>    
84162>>>        Function_Return bRetval
84163>>>    End_Function  
84164>>>    
84164>>>    // The fourth & fifth arguments are optional, depending on the iDataType
84164>>>    // passed. For e.g. a DF_ASCII the iLen must be passed.                     // Optional: // Optional:  
84164>>>    Function SqlColumnChange Handle hTable String sColumnName Integer iDataType Integer iLen Integer iDec Returns Boolean
84166>>>        Integer iColumn iDbType iLength iDecimals
84166>>>        String sDriverID sStmt sAlterTable sAlterColumn sVal sDataType sRetval sLengthAndDecimals sTableName sNotNull
84166>>>        Boolean bExists bOK bFixed
