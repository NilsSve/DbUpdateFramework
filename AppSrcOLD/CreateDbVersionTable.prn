84579>>>    // Does three things with auxilirary files;
84579>>>    // 1) Deletes the cache file in the first Data folder of the psDataPath property as the table at the SQL end has been changed.
84579>>>    // 2) Adds the sColumnName to the TableName.tag file in the first Data folder of the psDataPath property
84579>>>    // 3) Creates a new TableName.fd file if the DdSrc folder is available (if this is a development environment)
84579>>>    Function SqlUtilAdjustAuxFiles Handle hTable String sTableName String sColumnName Returns Boolean
84581>>>        String sDataPath sDDSrcPath sVal sDriverID
84581>>>        Boolean bOK bExists bMertechDriver
84581>>>        Integer iCount iItems iCh iPos
84581>>>        
84581>>>        // If table name equals e.g. "dbo.MyTable" we need to remove the prefix.
84581>>>        If (sTableName contains ".") Begin
84583>>>            Move (Pos(".", sTableName)) to iPos
84584>>>            Move (Mid(sTableName, 999, (iPos +1))) to sTableName    
84585>>>        End                                                     
84585>>>>
84585>>>        
84585>>>        Get psDriverID to sDriverID
84586>>>        Get psDataPathFirstPart to sDataPath 
84587>>>        Get vFolderExists sDataPath to bOK
84588>>>        If (bOK = False) Begin
84590>>>            Error DFERR_PROGRAM "Function SqlUtilAdjustAuxFiles; psDataPath not found!"
84591>>>>
84591>>>            Function_Return False    
84592>>>        End                      
84592>>>>
84592>>>        
84592>>>        Get IsMertechDriver sDriverID to bMertechDriver
84593>>>        // First delete the cache file:
84593>>>        Get UtilDeleteCacheFile sTableName to bOK
84594>>>            
84594>>>        Get Seq_New_Channel to iCh  
84595>>>        If (iCh = DF_SEQ_CHANNEL_NOT_AVAILABLE) Begin
84597>>>            Function_Return False
84598>>>        End                      
84598>>>>
84598>>>        
84598>>>        Get vFilePathExists (sDataPath + sTableName + ".tag") to bExists
84599>>>        If (bExists = False) Begin
84601>>>            Function_Return False
84602>>>        End                      
84602>>>>
84602>>>        
84602>>>        // Add the new column name to the .tag file: 
84602>>>        Append_Output channel iCh (sDataPath + sTableName + ".tag")
84604>>>            Writeln channel iCh sColumnName
84607>>>        Close_Output
84608>>>        
84608>>>        // If in development environment; output new .fd file:
84608>>>        Get psDdSrcPath of (phoWorkspace(ghoApplication)) to sDDSrcPath
84609>>>        Get CountOfPaths of (phoWorkspace(ghoApplication)) sDDSrcPath to iCount
84610>>>        If (iCount > 1) Begin
84612>>>            Get PathAtIndex of (phoWorkspace(ghoApplication)) sDDSrcPath 1 to sDDSrcPath    
84613>>>        End 
84613>>>>
84613>>>        Get vFolderExists sDDSrcPath to bExists
84614>>>        If (bExists = True) Begin                                   
84616>>>            Get vFolderFormat sDDSrcPath to sDDSrcPath  
84617>>>            Move False to Err 
84618>>>            Get AutoConnectionIDLogin to bOK
84619>>>            If (hTable <> 0) Begin
84621>>>                Open hTable
84623>>>            End 
84623>>>>
84623>>>            Else Begin
84624>>>                Get UtilTableOpen hTable sTableName DF_SHARE to bOK
84625>>>            End
84625>>>>
84625>>>                
84625>>>            Get_Attribute DF_FILE_OPENED of hTable to bOK
84628>>>            If (bOK = True) Begin
84630>>>                Output_Aux_File DF_AUX_FILE_FD for hTable to (sDDSrcPath + sTableName + ".fd")
84632>>>            End
84632>>>>
84632>>>            If (Err = True) Begin
84634>>>                Move False to bOK
84635>>>            End
84635>>>>
84635>>>        End
84635>>>>
84635>>>        
84635>>>        Function_Return (bOK = True)
84636>>>    End_Function  
84637>>>    
84637>>>    // The table must already exist in the filelist for this function to work.
84637>>>    // It creates a rudimentary .int file in the first Data folder of the psDataPath property.
84637>>>    Function SqlUtilCreateIntFile Handle hTable String sDriverID String sConnectionID Boolean bAnsi Boolean bSysFile Returns Boolean
84639>>>        Boolean bOK bExists bUseConnectionID bMertech
84639>>>        String sDataPath sRootName sPhysicalFileName sConnectionString sDatabaseName sSchemaName sANSI_OEM
84639>>>        String[] sIndexArray
84640>>>        Integer iCount iCh iSize
84640>>>        
84640>>>        Move (Trim(sConnectionID) <> "") to bUseConnectionID
84641>>>        Get psConnectionString to sConnectionString
84642>>>
84642>>>        Move CS_ANSI_Txt to sANSI_OEM
84643>>>        If (bANSI = False) Begin
84645>>>            Move CS_OEM_Txt to sANSI_OEM
84646>>>        End
84646>>>>
84646>>>        
84646>>>        Get psDataPathFirstPart to sDataPath
84647>>>        Get vFolderExists sDataPath to bOK
84648>>>        If (bOK = False) Begin
84650>>>            Error DFERR_PROGRAM "Function SqlUtilCreateIntFile; psDataPath not found!"
84651>>>>
84651>>>            Function_Return False    
84652>>>        End                      
84652>>>>
84652>>>        Get vFolderFormat sDataPath to sDataPath 
84653>>>
84653>>>        Get_Attribute DF_FILE_ROOT_NAME of hTable to sRootName
84656>>>        Get _TableNameOnly sRootName to sDatabaseName
84657>>>        Move sDatabaseName to sPhysicalFileName
84658>>>        Move (sPhysicalFileName + ".int") to sPhysicalFileName
84659>>>
84659>>>        Get IsMertechDriver sDriverID to bMertech
84660>>>        If (bMertech = True) Begin       
84662>>>            // This should not be called here. Instead it is called by the SqlUtilUpdateIntFile!
84662>>>            // Else it will create an error in the error log (although it won't do anything...)
84662>>>            // Get _MertechSqlUtilCreateIntFile hTable sDataPath sPhysicalFileName to bOK
84662>>>            Function_Return (bOK = True)
84663>>>        End
84663>>>>
84663>>>        
84663>>>        Get psSchema hTable to sSchemaName
84664>>>        If (sSchemaName = "") Begin   
84666>>>            Get _SqlFindKeyWord CI_SQLDBO to sSchemaName
84667>>>        End
84667>>>>
84667>>>
84667>>>        // If the .int file already exists; we rename it to "FileName" + ".bak"
84667>>>        Get vFilePathExists (sDataPath + sPhysicalFileName) to bExists
84668>>>        If (bExists = True) Begin            
84670>>>            Get vRenameFile (sDataPath + sPhysicalFileName) (sDataPath + sPhysicalFileName + ".bak") to bOK 
84671>>>        End
84671>>>>
84671>>>        
84671>>>        Get UtilDeleteCacheFile sRootName to bOK
84672>>>        Get SqlUtilEnumerateIndexes sRootName sDriverID to sIndexArray
84673>>>        
84673>>>        Get Seq_Open_Output_Channel (sDataPath + sPhysicalFileName) to iCh
84674>>>            Writeln channel iCh CS_DRIVER_NAME     " " sDriverID 
84679>>>            If (bUseConnectionID = True) Begin
84681>>>                Writeln channel iCh CS_SERVER_NAME " " CS_DFCONNID "=" sConnectionID
84688>>>            End 
84688>>>>
84688>>>            Else Begin
84689>>>                Writeln channel iCh CS_SERVER_NAME " " CS_SERVER "=" sConnectionString
84696>>>            End                                                      
84696>>>>
84696>>>            Writeln channel iCh CS_DATABASE_NAME          " " sDatabaseName
84701>>>            Writeln channel iCh CS_SCHEMA_NAME            " " (Lowercase(sSchemaName))
84706>>>            // There seems to be a new order how these are set from DF19.
84706>>>            If (bSysFile = True) Begin
84708>>>                Writeln channel iCh CS_RECNUM_TABLE       " " "NO"
84713>>>            End 
84713>>>>
84713>>>            Writeln channel iCh CS_TABLE_CHARACTER_FORMAT " " sANSI_OEM
84718>>>            Writeln channel iCh CS_USE_DUMMY_ZERO_DATE    " " "YES" // ToDo: We maybe need to paramerize this setting?  
84723>>>            If (bSysFile = True) Begin
84725>>>                Writeln channel iCh CS_SYSTEM_FILE        " " "YES" 
84730>>>            End  
84730>>>>
84730>>>            
84730>>>            If (bSysFile = False) Begin
84732>>>                Move (SizeOfArray(sIndexArray)) to iSize  
84733>>>                Move (SortArray(sIndexArray)) to sIndexArray
84734>>>                If (iSize > 0) Begin
84736>>>                    Writeln channel iCh (CS_PRIMARY_INDEX * String("0"))
84739>>>                    Writeln channel iCh // Just an empty line
84741>>>                End
84741>>>>
84741>>>                Decrement iSize                              
84742>>>                For iCount from 0 to iSize
84748>>>>
84748>>>                    Writeln channel iCh (CS_INDEX_NUMBER * String(iCount))
84751>>>                    Writeln channel iCh (CS_INDEX_NAME   * String(sIndexArray[iCount]))
84754>>>                    Writeln channel iCh
84756>>>                Loop
84757>>>>
84757>>>            End
84757>>>>
84757>>>        Send Seq_Close_Channel iCh 
84758>>>        
84758>>>        // Wait a sec for Windows to finish writing the file:
84758>>>        Sleep 1
84759>>>        
84759>>>        Function_Return (bOK = True)
84760>>>    End_Function
84761>>>    
84761>>>    // Message for changing .int files to use connection ID's
84761>>>    //
84761>>>    // Changes all ".int" files for the passed sDataPath to use a sConnectionID,
84761>>>    // OR changes an existing connection id to a new id.
84761>>>    // Pass the full path to the data folder and the name of the connection id (string value). 
84761>>>    // Pass a True for the bShowResult parameter to show work in progress (showln's).
84761>>>    Procedure SqlUtilChangeIntFilesToConnectionIDs String sDataPath String sConnectionID Boolean bShowResult
84763>>>        String sFileName sDriverID sDriverFile sConnectionString
84763>>>        String[] sFilesData
84764>>>        Boolean bExists bOK                               
84764>>>        Integer iSize iCount
84764>>>        
84764>>>        Get SqlUtilEnumerateIntFiles sDataPath to sFilesData
84765>>>        Move (SizeOfArray(sFilesData))    to iSize
84766>>>        If (iSize = 0) Begin
84768>>>            Send Info_Box "No .int files found! Nothing was changed."
84769>>>            Procedure_Return
84770>>>        End                                                          
84770>>>>
84770>>>        
84770>>>        Move (Trim(sConnectionID)) to sConnectionID
84771>>>        Get vFolderFormat sDataPath to sDataPath
84772>>>        Decrement iSize
84773>>>        For iCount from 0 to iSize
84779>>>>
84779>>>            Move sFilesData[iCount] to sFileName                                   
84780>>>            // This makes sure that we also can change an existing connection id to something new:
84780>>>            Get UtilChangeSourceCodeLine (sDataPath + sFileName) CS_SERVER_NAME (CS_SERVER_NAME * CS_DFCONNID + "=" + sConnectionID) bShowResult to bOK 
84781>>>        Loop                      
84782>>>>
84782>>>        
84782>>>        Get psDriverID to sDriverID
84783>>>        
84783>>>         // Finally also change the driver file e.g. MSSQLDRV.int file in the Data folder in case it has a "DFconnectionID xxxxID,SERVER..."
84783>>>        Move "" to sFileName
84784>>>        If (sDriverID = MSSQLDRV_ID) Begin
84786>>>            Move "MSSQLDrv.int" to sFileName
84787>>>        End                 
84787>>>>
84787>>>        If (sDriverID = DB2_DRV_ID) Begin
84789>>>            Move "DB2_Drv.int" to sFileName
84790>>>        End                                
84790>>>>
84790>>>        If (sDriverID = ODBC_DRV_ID) Begin
84792>>>            Move "ODBC_Drv.int" to sFileName
84793>>>        End                                 
84793>>>>
84793>>>        If (sFileName <> "") Begin     
84795>>>            Move "" to sDriverFile
84796>>>            Get_File_Path sFileName to sDriverFile
84797>>>            If (sDriverFile <> "") Begin                        
84799>>>                Get psConnectionString to sConnectionString
84800>>>                Get UtilChangeSourceCodeLine sDriverFile CS_SQLConnectionIDText (CS_SQLConnectionIDText * String(sConnectionID) + "," * String(sConnectionString) * String(",0")) bShowResult to bOK
84801>>>            End
84801>>>>
84801>>>        End
84801>>>>
84801>>>    End_Procedure
