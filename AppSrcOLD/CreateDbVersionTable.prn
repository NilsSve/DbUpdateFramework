86231>>>    Function _SqlTableArrayDAW Returns String[]
86233>>>        String[] sReturnArray   
86234>>>        String sTable sTableType sSchema sDefSchema sComment sTableKeyWord sSysKeyWord
86234>>>        Handle hoSQLHandler
86234>>>        Integer iCount iSize iItem
86234>>>        Boolean bOK   
86234>>>        tSQLConnection SQLConnection
86234>>>        tSQLConnection SQLConnection
86234>>>        
86234>>>        Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
86235>>>        If (SQLConnection.sConnectionString = "") Begin
86237>>>            Function_Return sReturnArray
86238>>>        End 
86238>>>>
86238>>>        
86238>>>        Move SQLConnection.sSchema      to sDefSchema
86239>>>        Move (Uppercase(sDefSchema))    to sDefSchema
86240>>>        Get _SqlFindKeyWord CI_SQLTable to sTableKeyWord
86241>>>        Get _SqlFindKeyWord CI_SQLSys   to sSysKeyWord
86242>>>
86242>>>        Get phoCLIHandler to hoSQLHandler             
86243>>>        Set psDriverID    of hoSQLHandler to SQLConnection.sDriverID
86244>>>        Send Delete_Data  of hoSQLHandler
86245>>>
86245>>>        Send Ignore_Error of Error_Object_Id CLIERR_LOGIN_UNSUCCESSFUL
86246>>>        Get EnumerateTables of hoSQLHandler SQLConnection.sConnectionString to iSize 
86247>>>        Move False to Err
86248>>>        Decrement iSize
86249>>>
86249>>>        For iCount from 0 to iSize
86255>>>>
86255>>>            Get TableName    of hoSQLHandler iCount to sTable
86256>>>            Get TableType    of hoSQLHandler iCount to sTableType 
86257>>>            Get SchemaName   of hoSQLHandler iCount to sSchema
86258>>>            Get TableComment of hoSQLHandler iCount to sComment
86259>>>            Move (Trim(sTable)) to sTable
86260>>>            If (SQLConnection.sDriverID = DB2_DRV_ID) Begin
86262>>>                Move (sTable <> "" and Uppercase(sTableType) = sTableKeyWord and Uppercase(sSchema) = sDefSchema) to bOK
86263>>>            End
86263>>>>
86263>>>            Else Begin
86264>>>                Move (sTable <> "" and Uppercase(sTableType) = sTableKeyWord and Uppercase(sSchema) <> sSysKeyWord and Uppercase(sSchema) <> "SYSTOOLS") to bOK
86265>>>            End
86265>>>>
86265>>>            If (bOK = True) Begin
86267>>>                Move sTable to sReturnArray[iItem]
86268>>>                Increment iItem
86269>>>            End
86269>>>>
86269>>>        Loop
86270>>>>
86270>>>
86270>>>        Send Trap_Error of Error_Object_Id CLIERR_LOGIN_UNSUCCESSFUL
86271>>>
86271>>>        Function_Return sReturnArray
86272>>>    End_Function
