85507>>>    // Removes all driver identifications (e.g. "MSSQLDRV;MyTable" or "MyTable.MSSQLDRV"
85507>>>    // from the passed filelist.
85507>>>    // Returns the number of tables affected.
85507>>>    Function SqlUtilFilelistRemoveDriverInfo String sFilelist Returns Integer
85509>>>        String sCurrentFileList sRootName sDisplayName sLogicalName sVal
85509>>>        Integer iRetval
85509>>>        Handle hTable
85509>>>        
85509>>>        // We first save the current filelist as the passed filelist name
85509>>>        // may come from another workspace, to restore it when we're ready.
85509>>>        Get_Attribute DF_FILELIST_NAME to sCurrentFileList
85512>>>        Set_Attribute DF_FILELIST_NAME to sFilelist
85515>>>        Move 0 to hTable
85516>>>        Move 0 to iRetval
85517>>>        
85517>>>        Repeat
85517>>>>
85517>>>            Get_Attribute DF_FILE_NEXT_USED of hTable to hTable
85520>>>            If (hTable <> 0) Begin
85522>>>                Get_Attribute DF_FILE_ROOT_NAME    of hTable to sRootName
85525>>>                Get_Attribute DF_FILE_DISPLAY_NAME of hTable to sDisplayName
85528>>>                Get_Attribute DF_FILE_LOGICAL_NAME of hTable to sLogicalName
85531>>>                Move (Uppercase(sRootName)) to sVal
85532>>>                If (sVal contains MSSQLDRV_ID or sVal contains DB2_DRV_ID or sVal contains ODBC_DRV_ID) Begin
85534>>>                    // Prefixes:
85534>>>                    Move (Replace((MSSQLDRV_ID + ":"), sRootName, "")) to sRootName
85535>>>                    Move (Replace((DB2_DRV_ID  + ":"), sRootName, "")) to sRootName
85536>>>                    Move (Replace((ODBC_DRV_ID + ":"), sRootName, "")) to sRootName
85537>>>                    // Suffixes:
85537>>>                    Move (Replace(("." + MSSQLDRV_ID), sRootName, "")) to sRootName
85538>>>                    Move (Replace(("." + DB2_DRV_ID),  sRootName, "")) to sRootName
85539>>>                    Move (Replace(("." + ODBC_DRV_ID), sRootName, "")) to sRootName
85540>>>                    
85540>>>                    // Change Filelist entry:
85540>>>                    Set_Attribute DF_FILE_ROOT_NAME of hTable          to sRootName
85543>>>
85543>>>                    Move (Lowercase(sDisplayName)) to sVal
85544>>>                    If (sVal contains "dbo.") Begin
85546>>>                        Move (Replace("dbo.", sDisplayName, ""))       to sDisplayName
85547>>>                        
85547>>>                        // Change Filelist entry:
85547>>>                        Set_Attribute DF_FILE_DISPLAY_NAME of hTable   to sDisplayName
85550>>>                    End
85550>>>>
85550>>>                    Increment iRetval
85551>>>                End
85551>>>>
85551>>>            End
85551>>>>
85551>>>        Until (hTable = 0)
85553>>>        
85553>>>        Set_Attribute DF_FILELIST_NAME to sCurrentFileList
85556>>>        
85556>>>        Function_Return iRetval
85557>>>    End_Function
85558>>>    
85558>>>    // To open all Sql based tables in Filelist.cfg
85558>>>    Procedure SqlUtilOpenAllTables
85560>>>        Handle hTable
85560>>>        String sRoot sDriverID
85560>>>        Boolean bOK
85560>>>        
85560>>>        Move 0 to hTable
85561>>>        Move "" to sDriverID
85562>>>        Get AutoConnectionIDLogin to bOK
85563>>>        
85563>>>        Repeat
85563>>>>
85563>>>            Get_Attribute DF_FILE_NEXT_USED of hTable to hTable
85566>>>            If (hTable > 0) Begin     
85568>>>                Get_Attribute DF_FILE_DRIVER of hTable to sDriverID
85571>>>                If (sDriverID = MSSQLDRV_ID or sDriverID = DB2_DRV_ID or sDriverID = ODBC_DRV_ID) Begin
85573>>>                    Get_Attribute DF_FILE_ROOT_NAME of hTable to sRoot
85576>>>                    If (Uppercase(sRoot) contains ".INT" or Uppercase(sRoot) contains MSSQLDRV_ID or Uppercase(sRoot) contains DB2_DRV_ID or Uppercase(sRoot) contains ODBC_DRV_ID) Begin
85578>>>                        Open hTable
85580>>>                    End
85580>>>>
85580>>>                End
85580>>>>
85580>>>            End
85580>>>>
85580>>>    
85580>>>        Until (hTable = 0)
85582>>>    End_Procedure             
