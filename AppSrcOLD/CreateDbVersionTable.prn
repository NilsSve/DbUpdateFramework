79715>>>//
79715>>>// Gets the string from the right of the last sStopChar in sFrom
79715>>>// If sStopChar has no occurences in the string an empty string is
79715>>>// returned.
79715>>>Function StringFromRightOfChar Global String sFrom String sStopChar Returns String
79717>>>  String  sRetVal
79717>>>  String  sChar
79717>>>  Integer iLength
79717>>>  Integer iPos
79717>>>  Boolean bStopChar
79717>>>  Move "" To sRetval
79718>>>  Move (Length(sFrom)) To iLength
79719>>>  If ((iLength>0) And (Pos(sStopChar,sFrom) <> 0)) Begin
79721>>>    Move iLength   To iPos
79722>>>    Move (False)   To bStopChar
79723>>>    While Not bStopChar
79727>>>      Move (Mid(sFrom,1,iPos)) To sChar
79728>>>      Decrement iPos
79729>>>      If ((sChar=sStopChar) Or (iPos<1)) Begin
79731>>>        Move (True) To bStopChar
79732>>>      End
79732>>>>
79732>>>      Else Begin
79733>>>        Move (sChar+sRetVal) To sRetVal
79734>>>      End
79734>>>>
79734>>>    Loop
79735>>>>
79735>>>  End
79735>>>>
79735>>>  Function_Return sRetVal
79736>>>End_Function // StringFromRightOfChar
79737>>>
79737>>>
79737>>>// Pre:  sFileName contains the complete path of the file.
79737>>>// Post: returns the complete path of the file.
79737>>>// This function is inspired on function SEQ_ExtractPathFromFileName of Sture Andersen.
79737>>>Function ParseFolderName Global String sFileName Returns String
79739>>>  String sFile
79739>>>  String sFolderName
79739>>>  String sDirSep // this is "\" for windows, or "/" for unix
79739>>>  MOve "" To sFolderName
79740>>>  Move (sysconf(SYSCONF_DIR_SEPARATOR)) To sDirSep
79741>>>  If sDirSep In sFileName Begin
79743>>>    Move (StringFromRightOfChar(sFileName,sDirSep)) To sFile
79744>>>    Move (Replace(sFile,sFileName,"")) To sFolderName
79745>>>  End
79745>>>>
79745>>>  Else If ":" In sFileName Begin
79748>>>    Move (StringFromRightOfChar(sFileName,":")) To sFile
79749>>>    Move (Replace(sFile,sFileName,"")) To sFolderName
79750>>>  End
79750>>>>
79750>>>  Function_Return sFolderName
79751>>>End_Function // ParseFolderName
79752>>>
79752>>>
79752>>>// Pre:  sFileName contains the complete path of the file.
79752>>>// post: The returned filename has it's path removed, but will have a extension
79752>>>Function ParseFileName Global String sFileName Returns String
79754>>>  String sFolderName
79754>>>  String sDirSep // this is "\" for windows, or "/" for unix
79754>>>  Move (sysconf(SYSCONF_DIR_SEPARATOR)) To sDirSep
79755>>>  Get ParseFolderName sFileName To sFolderName
79756>>>  If (sFolderName <> "") Move (Replace(sFolderName,sFileName,"")) To sFileName
79759>>>  Move (Replace(sDirSep,sFileName,"")) To sFileName
79760>>>  Function_Return sFilename
79761>>>End_Function // ParseFileName
79762>>>
79762>>>
79762>>>// Pre:  sFileName may contain the complete path of the file.
79762>>>//       or contain multiple dots in the filename, so temp.gif.bak will
79762>>>//       return "bak" as the extension and not "gif"
79762>>>// Post: returns the extension only, this extension can be a valid unixlike extension
79762>>>//       such as "html" or "java"
79762>>>Function ParseFileExtension Global String sFileName Returns String
79764>>>  String  sFileExtension
79764>>>  Get StringFromRightOfChar sFileName "." To sFileExtension
79765>>>  Function_Return sFileExtension
79766>>>End_Function // ParseFileExtension
