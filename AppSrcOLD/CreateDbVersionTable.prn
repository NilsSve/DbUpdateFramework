82376>>>>>>>    // Sort function that first sorts on bEnabled & then on the connection string.
82376>>>>>>>    Function SortActiveFirst tSQLConnection SQLConnectionRow1 tSQLConnection SQLConnectionRow2 Returns Integer
82378>>>>>>>        Integer iCheckboxCol
82378>>>>>>>        If (SQLConnectionRow1.bEnabled > SQLConnectionRow2.bEnabled) Begin
82380>>>>>>>            Function_Return (LT)
82381>>>>>>>        End
82381>>>>>>>>
82381>>>>>>>        If (SQLConnectionRow1.bEnabled < SQLConnectionRow2.bEnabled) Begin
82383>>>>>>>            Function_Return (GT) 
82384>>>>>>>        End
82384>>>>>>>>
82384>>>>>>>
82384>>>>>>>        If (SQLConnectionRow1.sConnectionID < SQLConnectionRow2.sConnectionID) Begin
82386>>>>>>>            Function_Return (LT)
82387>>>>>>>        End
82387>>>>>>>>
82387>>>>>>>        If (SQLConnectionRow1.sConnectionID > SQLConnectionRow2.sConnectionID) Begin
82389>>>>>>>            Function_Return (GT) 
82390>>>>>>>        End
82390>>>>>>>>
82390>>>>>>>
82390>>>>>>>        If (SQLConnectionRow1.iDbType < SQLConnectionRow2.iDbType) Begin
82392>>>>>>>            Function_Return (LT)
82393>>>>>>>        End
82393>>>>>>>>
82393>>>>>>>        If (SQLConnectionRow1.iDbType > SQLConnectionRow2.iDbType) Begin
82395>>>>>>>            Function_Return (GT) 
82396>>>>>>>        End
82396>>>>>>>>
82396>>>>>>>
82396>>>>>>>        If (SQLConnectionRow1.sServer < SQLConnectionRow2.sServer) Begin
82398>>>>>>>            Function_Return (LT)
82399>>>>>>>        End
82399>>>>>>>>
82399>>>>>>>        If (SQLConnectionRow1.sServer > SQLConnectionRow2.sServer) Begin
82401>>>>>>>            Function_Return (GT) 
82402>>>>>>>        End
82402>>>>>>>>
82402>>>>>>>
82402>>>>>>>        If (SQLConnectionRow1.sDatabase < SQLConnectionRow2.sDatabase) Begin
82404>>>>>>>            Function_Return (LT)
82405>>>>>>>        End
82405>>>>>>>>
82405>>>>>>>        If (SQLConnectionRow1.sDatabase > SQLConnectionRow2.sDatabase) Begin
82407>>>>>>>            Function_Return (GT) 
82408>>>>>>>        End
82408>>>>>>>>
82408>>>>>>>
82408>>>>>>>        If (SQLConnectionRow1.sDriverID < SQLConnectionRow2.sDriverID) Begin
82410>>>>>>>            Function_Return (LT)
82411>>>>>>>        End
82411>>>>>>>>
82411>>>>>>>        If (SQLConnectionRow1.sDriverID > SQLConnectionRow2.sDriverID) Begin
82413>>>>>>>            Function_Return (GT) 
82414>>>>>>>        End
82414>>>>>>>>
82414>>>>>>>
82414>>>>>>>        If (SQLConnectionRow1.sConnectionString < SQLConnectionRow2.sConnectionString) Begin
82416>>>>>>>            Function_Return (LT)
82417>>>>>>>        End
82417>>>>>>>>
82417>>>>>>>        If (SQLConnectionRow1.sConnectionString > SQLConnectionRow2.sConnectionString) Begin
82419>>>>>>>            Function_Return (GT) 
82420>>>>>>>        End
82420>>>>>>>>
82420>>>>>>>
82420>>>>>>>        Function_Return (EQ)
82421>>>>>>>    End_Function
