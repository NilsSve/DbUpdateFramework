87097>>>    // ToDo: Needs to be revised
87097>>>    Procedure ApiTableCreateFromDEF String sPath String sFileName String sTableName String sDisplayName Integer iFilelistSlot
87099>>>        Handle hTable 
87099>>>        String sDEFName sDataPath sDriverID
87099>>>        Boolean bExists
87099>>>        
87099>>>        // Do nothing if MSSQL Driver.
87099>>>//        Get IsMSSQLDriver to bExists
87099>>>//        If (bExists = True) Begin
87099>>>//            Procedure_Return
87099>>>//        End
87099>>>        
87099>>>        Get psDataPathFirstPart to sDataPath
87100>>>        Get vFilePathExists (sDataPath + sFileName + ".dat") to bExists
87101>>>        If (bExists = True) Begin      
87103>>>            // We also needs to check if it is an Alias file, in case the sFileName.dat exists, but it may
87103>>>            // still be missing from the filelist and needs to be added.
87103>>>            Get UtilTableNumberIsInUse iFilelistSlot to bExists
87104>>>            If (bExists = True) Begin
87106>>>                Procedure_Return
87107>>>            End 
87107>>>>
87107>>>            // Do _not_ use the DEF file if an alias, it will overwrite the base table data.
87107>>>            Else Begin
87108>>>                Set_Attribute DF_FILE_ROOT_NAME    of iFilelistSlot to sFileName
87111>>>                Set_Attribute DF_FILE_LOGICAL_NAME of iFilelistSlot to sTableName
87114>>>                Set_Attribute DF_FILE_DISPLAY_NAME of iFilelistSlot to sDisplayName
87117>>>                Procedure_Return
87118>>>            End
87118>>>>
87118>>>        End
87118>>>>
87118>>>    
87118>>>        Move (sPath + sFileName + ".def") to sDEFName
87119>>>        Move 0 to hTable
87120>>>        Move False to Err
87121>>>    
87121>>>        Structure_Start hTable DATAFLEX_ID
87122>>>            Load_Def sDEFName Onto hTable
87123>>>            Set_Attribute DF_FILE_PHYSICAL_NAME of hTable to sFileName
87126>>>        Structure_End hTable DF_STRUCTEND_OPT_NONE
87128>>>    
87128>>>        Move iFilelistSlot to hTable
87129>>>        Set_Attribute DF_FILE_ROOT_NAME    of hTable to sFileName
87132>>>        Set_Attribute DF_FILE_LOGICAL_NAME of hTable to sTableName
87135>>>        Set_Attribute DF_FILE_DISPLAY_NAME of hTable to sDisplayName
87138>>>    
87138>>>    End_Procedure      
