89885>>>            
89885>>>    // *** Error Handler ***
89885>>>    //
89885>>>    // Note: If the cDbUpdateHandler & cDbUpdateVersion classes are used this error handler is _not_
89885>>>    //       used. Instead the Error_Report in the cDbUpdateHandler i used.
89885>>>    Procedure Error_Report Integer iErrorNumber Integer iErrorLine String sErrorText
89887>>>        String sText
89887>>>        Integer iSize iErrorMode
89887>>>        tSqlErrorArray aSqlErrorArray
89887>>>        tSqlErrorArray aSqlErrorArray
89887>>>        
89887>>>        If (pbProcessingError(Self)) Begin
89889>>>            Procedure_Return
89890>>>        End 
89890>>>>
89890>>>        
89890>>>        Get Error_Report_Mode to iErrorMode
89891>>>        If (iErrorMode = DUF_ERROR_NO_REPORT) Begin
89893>>>            Procedure_Return
89894>>>        End
89894>>>>
89894>>>
89894>>>        Set pbProcessingError to True
89895>>>        Set pbSqlError to True
89896>>>        Get paSqlErrorArray      to aSqlErrorArray
89897>>>        Move (SizeOfArray(aSqlErrorArray.sSqlErrorArray)) to iSize
89898>>>        Move sErrorText          to aSqlErrorArray.sSqlErrorArray[iSize]
89899>>>        Get psSQLStatementString to aSqlErrorArray.sSqlStatementArray[iSize]
89900>>>        Move iErrorNumber        to aSqlErrorArray.iSqlErrorArray[iSize]
89901>>>        Set paSqlErrorArray      to aSqlErrorArray
89902>>>        Set pbProcessingError to False
89903>>>    End_Procedure
89904>>>
89904>>>    // *** Miscellanous Helper Functions ***
89904>>>    //
89904>>>    // Helper function. Takes a DF_FILE_XXXX_NAME value as parameter and 
89904>>>    // returns the table name only; stripped of any path or filename extension.
89904>>>    Function _TableNameOnly String sName Returns String
89906>>>        String sPath sExt
89906>>>        
89906>>>        Get ParseFolderName sName to sPath
89907>>>        If (sPath <> "") Begin
89909>>>            Move (Replace(sPath, sName, "")) to sName
89910>>>        End                                                  
89910>>>>
89910>>>        Get ParseFileExtension sName to sExt
89911>>>        If (sExt <> "") Begin
89913>>>            Move (Replace(("." + sExt), sName, "")) to sName
89914>>>        End
89914>>>>
89914>>>        
89914>>>        Function_Return sName
89915>>>    End_Function
89916>>>
89916>>>    // Returns the first datapath found in the psDataPath property.
89916>>>    // The returned path always ends with a "\"
89916>>>    Function psDataPathFirstPart Returns String
89918>>>        String sDataPath
89918>>>        Integer iCount
89918>>>        
89918>>>        Get psDataPath of (phoWorkspace(ghoApplication)) to sDataPath
89919>>>        Get CountOfPaths of (phoWorkspace(ghoApplication)) sDataPath to iCount
89920>>>        If (iCount > 1) Begin
89922>>>            Get PathAtIndex of (phoWorkspace(ghoApplication)) sDataPath 1 to sDataPath    
89923>>>        End             
89923>>>>
89923>>>        If (sDataPath <> "") Begin
89925>>>            Get vFolderFormat sDataPath to sDataPath
89926>>>        End
89926>>>>
89926>>>        
89926>>>        Function_Return sDataPath
89927>>>    End_Function
