83564>>>>>    Function DriverIndex String sDriverID Returns Integer
83566>>>>>        String  sCurrentDriver
83566>>>>>        Integer iNumberOfDrivers iDriver iCount iRetval
83566>>>>>        
83566>>>>>        Move 0 to iDriver
83567>>>>>        Get_Attribute DF_NUMBER_DRIVERS to iNumberOfDrivers
83570>>>>>        For iCount from 1 to iNumberOfDrivers
83576>>>>>>
83576>>>>>            Get_Attribute DF_DRIVER_NAME of iCount to sCurrentDriver
83579>>>>>            If ( Uppercase(sCurrentDriver) = Uppercase(sDriverID) ) Begin
83581>>>>>                Function_Return iCount
83582>>>>>            End
83582>>>>>>
83582>>>>>        Loop
83583>>>>>>
83583>>>>>        
83583>>>>>        // If driver not previously loaded; attempt to do so now.
83583>>>>>        If (iDriver = 0) Begin
83585>>>>>            Move 0 to LastErr
83586>>>>>            Load_Driver sDriverID   
83587>>>>>            // If driver could not be loaded.
83587>>>>>            If (LastErr = 4255) Begin
83589>>>>>                Move 0 to iCount
83590>>>>>            End
83590>>>>>>
83590>>>>>            Function_Return iCount
83591>>>>>        End
83591>>>>>>
83591>>>>>        Function_Return 0
83592>>>>>    End_Function
83593>>>>>        
83593>>>>>    // This will update connection settings of the cCLIHandler object with that passed struct values.
83593>>>>>    Procedure UpdateConnectionString tSQLConnection SQLConnection
83595>>>>>        String sRetval sDriverID sConnectionID sConnectionString sServer sDatabase sUserID sPassword
83595>>>>>        Boolean bTrusted bSilent  
83595>>>>>        Integer iConnOptions
83595>>>>>        
83595>>>>>        Move SQLConnection.sDriverID     to sDriverID
83596>>>>>        Move SQLConnection.sConnectionID to sConnectionID
83597>>>>>        Move SQLConnection.sServer       to sServer
83598>>>>>        Move SQLConnection.sDatabase     to sDatabase
83599>>>>>        Move SQLConnection.bTrusted      to bTrusted
83600>>>>>        Move SQLConnection.sUserID       to sUserID
83601>>>>>        Move SQLConnection.sPassword     to sPassword  
83602>>>>>        Move SQLConnection.bSilentLogin  to bSilent
83603>>>>>        
83603>>>>>        // Note that this message will first delete the current ConnectionID if it exists; which is needed by the cCLIHandler logic.
83603>>>>>        Send CreateSQLConnection sDriverID sConnectionID sServer sDatabase bTrusted sUserID sPassword bSilent
83604>>>>>        
83604>>>>>    End_Procedure
83605>>>>>
83605>>>>>    // Called when the object is constructed.
83605>>>>>    // It will check the psDriverID for a ConnectionID and save it
83605>>>>>    // as psConnectionID property. It is later used whenever a login to
83605>>>>>    // the database is needed.
83605>>>>>    Procedure AutoSetConnectionID
83607>>>>>        String sConnectionID sValue sDriverID sConnectionString
83607>>>>>        Integer iDriver iNumConn iConn iConnOptions iRetval
83607>>>>>        Handle hoCLI                 
83607>>>>>        Boolean bOK bSilent bMertechDriver
83607>>>>>        
83607>>>>>        Get pbSilentLogin      to bSilent
83608>>>>>        Get psConnectionID     to sConnectionID                            
83609>>>>>        Get psConnectionString to sConnectionString
83610>>>>>        // Get the driver Connection ID string & set the psConnectionString property.
83610>>>>>        Get psDriverID to sDriverID
83611>>>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
83612>>>>>        If (bOK = False) Begin
83614>>>>>            Procedure_Return              
83615>>>>>        End                 
83615>>>>>>
83615>>>>>        
83615>>>>>        // Mertech drivers can't use connection ID's.
83615>>>>>        Get IsMertechDriver sDriverID to bMertechDriver    
83616>>>>>        If (bMertechDriver = True) Begin         
83618>>>>>            // This ensures that the correct Server & Database attributes are set both for 
83618>>>>>            // embedded SQL calls and "normal" database commands like e.g. "Open".
83618>>>>>            Get _MertechSQLManagerHandle to hoCLI
83619>>>>>            Procedure_Return
83620>>>>>        End
83620>>>>>>
83620>>>>>        
83620>>>>>        Get DriverIndex sDriverID          to iDriver
83621>>>>>        // If driver not loaded; load it.
83621>>>>>        If (iDriver = 0) Begin
83623>>>>>            Load_Driver sDriverID
83624>>>>>            Get DriverIndex sDriverID      to iDriver
83625>>>>>        End                      
83625>>>>>>
83625>>>>>        // This shouldn't be possible; unless the driver.dll file is missing or something...
83625>>>>>        If (iDriver = 0) Begin
83627>>>>>            Error DFERR_PROGRAM ("The database driver could not be loaded! Connection to database failed." * sDriverID)
83628>>>>>>
83628>>>>>            Procedure_Return
83629>>>>>        End
83629>>>>>>
83629>>>>>
83629>>>>>        Get Create (RefClass(cCLIHandler)) to hoCLI
83630>>>>>        Set psDriverID of hoCLI            to sDriverID   
83631>>>>>        // Delete the connection first; in case it exists
83631>>>>>//        Get DeleteConnectionID of hoCLI sConnectionID -1 to iRetval
83631>>>>>        Get CreateConnectionID of hoCLI sConnectionID sConnectionString bSilent to iRetval
83632>>>>>
83632>>>>>        Send Destroy of hoCLI 
83633>>>>>    End_Procedure
83634>>>>>
83634>>>>>    // Returns the handle of the Mertech SQL handler.
83634>>>>>    // It also ensures that the correct Server & Database attributes are set both for 
83634>>>>>    // embedded SQL calls and "normal" database commands like e.g. "Open".  
83634>>>>>    // Note: This does _not_ return a proper CLI handler handle as it is not in this class.
83634>>>>>    //       So the return value is of no use! But we don't need the handle for this class.
83634>>>>>    Function _MertechSQLManagerHandle Returns Handle
83636>>>>>        Handle hoSQLHandler
83636>>>>>        String sDriverID sServer sDatabase
83636>>>>>        
83636>>>>>        Move 0 to hoSQLHandler
