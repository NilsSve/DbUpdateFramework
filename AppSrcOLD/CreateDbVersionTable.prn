92274>>>
92274>>>// *************************************************************************
92274>>>//  Public message. It is expected that you will send this message (most
92274>>>//  likely from Activate_About. This creates an about object, activates it
92274>>>//  and destroys it when done. It is not exepected that you will augment this.
92274>>>// *************************************************************************
92274>>>// Sample usage:
92274>>>//   The first two params will automatically be filled from the application settings if not provided.
92274>>>//   Send DoAbout "" "" ("Copyright: 2013" * psCompany(ghoApplication)) "Created by: Your Name" "YourAppBitmap.bmp" "Internet: http://www.YourWebAddress.com" "E-mail: mailto:support@YourEmailAddress.com" "Some other description of choice" "9th param" "and last param"
92274>>>
92274>>>Procedure DoAbout String sTitle String sVersion String sCopyRight String sAuthor String sBitmap ;                  String sParam6 String sParam7 String sParam8 String sParam9 String sParam10
92277>>>        Integer hoObj hoMain iArgs
92277>>>        String sValue
92277>>>
92277>>>        // Create object
92277>>>        Object About is an AboutDialog
92279>>>            // Uncomment these two lines if you would like to have a resizable About object.
92279>>>//            Set Border_Style to Border_Thick
92279>>>//            Set peAnchors to anAll
92279>>>
92279>>>            // Add checking for the number of arguments passed to avoid runtime errors
92279>>>            // if one of them is not passed. This makes the interface
92279>>>            // more flexible.
92279>>>            Move num_arguments to iArgs
92280>>>
92280>>>            // If no title is passed use the label of the main panel (if a main panel exists).
92280>>>            If (iArgs > 0 and sTitle = "") Begin
92282>>>                Get Main_Window of Desktop to hoMain
92283>>>                If hoMain Get Label of hoMain to sValue
92286>>>            End
92286>>>>
92286>>>            Else If (iArgs > 0 and sTitle <> "") Begin
92289>>>                Move sTitle to sValue
92290>>>            End
92290>>>>
92290>>>            Else If (iArgs = 0) Begin
92293>>>                Get Main_Window of Desktop to hoMain
92294>>>                If hoMain Get Label of hoMain to sValue
92297>>>            End
92297>>>>
92297>>>
92297>>>            If (sValue <> "") Send Add_LineLn sValue
92300>>>            Move "" to sValue
92301>>>
92301>>>            // If the passed sVersion value is blank, the info will be retrieved from the cApplication object.
92301>>>            // For this to work the Project Properties Version must have been set in the Studio.
92301>>>            If (iArgs < 2) Begin
92303>>>                Move "" to sValue
92304>>>            End
92304>>>>
92304>>>            Else Begin
92305>>>                Move sVersion to sValue
92306>>>            End
92306>>>>
92306>>>            Set Version to sValue
92307>>>
92307>>>            If (iArgs > 2 and sCopyRight <> "") Send Add_LineLn sCopyRight
92310>>>
92310>>>            // If only the five "standard" params were passed we don't add an extra linefeed;
92310>>>            // else we do.
92310>>>            If (iArgs > 3 and iArgs < 6 and sAuthor <> "") Begin
92312>>>                Send Add_Line sAuthor
92313>>>            End
92313>>>>
92313>>>            Else If (iArgs > 5 and sAuthor <> "") Begin
92316>>>                Send Add_LineLn sAuthor
92317>>>            End
92317>>>>
92317>>>
92317>>>            // Square bitmaps of 80x80 works best
92317>>>            If (iArgs > 4 and sBitmap <> "") Begin
92319>>>               Set Logo to sBitMap
92320>>>            End
92320>>>>
92320>>>
92320>>>            // Here starts handling of the five optional params:
92320>>>            If (iArgs = 6 and sParam6  <> "") Begin
92322>>>                Send Add_Line sParam6
92323>>>            End
92323>>>>
92323>>>            Else If (iArgs > 6 and sParam6  <> "") Begin
92326>>>                Send Add_LineLn sParam6
92327>>>            End
92327>>>>
92327>>>
92327>>>            If (iArgs = 7 and sParam7  <> "") Begin
92329>>>                Send Add_Line sParam7
92330>>>            End
92330>>>>
