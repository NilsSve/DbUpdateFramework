86829>>>    // Calls a driver function directly to copy data from one table to another (table structures needs to be the same).
86829>>>    // It will first drop all indicies, copy the data and then recreate indicies. 
86829>>>    // An error log file with the sRootname + ".err" will be created in the Data folder.
86829>>>    Function ApiTableCopyData Integer hFromTable String sPhysicalName String sRootName String sDriverID Returns Boolean
86831>>>        Boolean bOpened bOK
86831>>>        Integer hToTable iIndex iCount iRetval iVoid iOrgFreq
86831>>>        String sErrorFile sEmpty sPath
86831>>>        
86831>>>        Get_Attribute DF_FILE_NEXT_EMPTY of 0 to hToTable
86834>>>        Get AutoConnectionIDLogin to bOK
86835>>>        If (sDriverID = DATAFLEX_ID) Begin
86837>>>            Send IncreaseSortBufferSize  
86838>>>//            Send SetAllIndexesToBatch hToTable
86838>>>        End                          
86838>>>>
86838>>>
86838>>>        Move False to Err
86839>>>        Open sPhysicalName as hToTable
86841>>>        Get_Attribute DF_FILE_OPENED of hToTable to bOpened
86844>>>        If (bOpened = False) Begin
86846>>>            Function_Return False
86847>>>        End                      
86847>>>>
86847>>>        
86847>>>        Move "" to sEmpty 
86848>>>        Move False to Err   
86849>>>        Move True to bOK       
86850>>>        
86850>>>        Get_Attribute DF_RUNTIME_PROGRESS_FREQUENCY to iOrgFreq
86853>>>        Set_Attribute DF_RUNTIME_PROGRESS_FREQUENCY to 10        
86856>>>        If (sDriverID <> DATAFLEX_ID) Begin
86858>>>            // Remove all indices to speed up copying of data:
86858>>>            Call_Driver hToTable sDriverID Function CLI_DROPINDICES Callback Self Passing sEmpty sEmpty iVoid Result iRetval
86863>>>            If (iRetval <> 0) Begin
86865>>>                Error DFERR_PROGRAM ("Failed dropping indices for table:" * sRootName)
86866>>>>
86866>>>                Function_Return False
86867>>>            End
86867>>>>
86867>>>        End
86867>>>>
86867>>>        
86867>>>        Move (sRootName + ".err") to sErrorFile  
86868>>>        Move 0 to iIndex           
86869>>>        Move False to Err   
86870>>>        
86870>>>        Copy_Records hFromTable to hToTable using 0 Callback Self
86873>>>                  
86873>>>        If (Err = False) Begin             
86875>>>            Get psHome of (phoWorkspace(ghoApplication)) to sPath  
86876>>>            Get vDeleteFile (sPath + sErrorFile) to iRetval
86877>>>        End                                                          
86877>>>>
86877>>>        
86877>>>        If (sDriverID <> DATAFLEX_ID) Begin
86879>>>            // Recreate indices:
86879>>>            Call_Driver hToTable sDriverID Function CLI_CREATEINDICES Callback Self Passing sEmpty sEmpty iVoid Result iRetval
86884>>>        End
86884>>>>
86884>>>        
86884>>>        Close hToTable
86885>>>        Set_Attribute DF_RUNTIME_PROGRESS_FREQUENCY to iOrgFreq
86888>>>        
86888>>>        If (bOK = True) Begin
86890>>>            Move (not(Err)) to bOK
86891>>>        End
86891>>>>
86891>>>        
86891>>>        If (ghoStatusPanel <> 0) Begin
86893>>>            Set Message_Text of ghoStatusPanel to ""
86894>>>            Set Action_Text  of ghoStatusPanel to ""
86895>>>        End
86895>>>>
86895>>>        
86895>>>        Function_Return (bOK = True)
86896>>>    End_Function 
86897>>>
86897>>>    Procedure IncreaseSortBufferSize
86899>>>        String sNull
86899>>>        Integer iSortBufferSize
86899>>>        Boolean bBufferSet
86899>>>    
86899>>>        Move "" to sNull
86900>>>        Move (1024 * 128) to iSortBufferSize
86901>>>        Call_Driver 0 DATAFLEX_ID Function FLEX_SET_MAX_SORT_BUFFER Callback Self Passing sNull sNull iSortBufferSize Result bBufferSet
86906>>>    
86906>>>    End_Procedure     
