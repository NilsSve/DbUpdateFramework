89613>>>    
89613>>>    // Internal usage. Use the UtilColumnTypeXXX functions instead.
89613>>>    Function _UtilColumnType String sDriverID Integer iDbType Integer iType String sType Boolean bIntegerInputType Returns tColumnType
89615>>>        Integer iValue iSize iCount iStart
89615>>>        tColumnType[] ColumnTypeArray   
89615>>>        tColumnType[] ColumnTypeArray   
89616>>>        tColumnType RetvalType 
89616>>>        tColumnType RetvalType 
89616>>>        String sValue
89616>>>        
89616>>>        Move "Undefined" to RetvalType.sType 
89617>>>        Move -1999       to RetvalType.iType
89618>>>        
89618>>>        Move 0 to iStart
89619>>>        Move (Uppercase(sType)) to sType            
89620>>>        
89620>>>        If (iType <= -1500) Begin
89622>>>            Move EN_dbTypeDataFlex to iDbType
89623>>>            Move DATAFLEX_ID       to sDriverID
89624>>>        End
89624>>>>
89624>>>
89624>>>        Get UtilEnumerateColumnTypes sDriverID iDbType to ColumnTypeArray
89625>>>        
89625>>>        Move (SizeOfArray(ColumnTypeArray)) to iSize 
89626>>>        Decrement iSize
89627>>>        
89627>>>        for iCount from iStart to iSize
89633>>>>
89633>>>            Move ColumnTypeArray[iCount].iType to iValue
89634>>>            Move ColumnTypeArray[iCount].sType to sValue 
89635>>>            If (bIntegerInputType = True) Begin
89637>>>                If (iValue = iType) Begin
89639>>>                    Move ColumnTypeArray[iCount].sType          to RetvalType.sType  
89640>>>                    Move iType                                  to RetvalType.iType
89641>>>                    Move ColumnTypeArray[iCount].sDataFlexType  to RetvalType.sDataFlexType
89642>>>                    Move ColumnTypeArray[iCount].iDataFlexType  to RetvalType.iDataFlexType
89643>>>                    Move ColumnTypeArray[iCount].sPrecision     to RetvalType.sPrecision
89644>>>                    Move ColumnTypeArray[iCount].bFixedSize     to RetvalType.bFixedSize
89645>>>                    Move iSize to iCount // We're done!
89646>>>                End
89646>>>>
89646>>>            End
89646>>>>
89646>>>            Else Begin
89647>>>                Move (Uppercase(sValue)) to sValue
89648>>>                If (sValue = sType) Begin
89650>>>                    Move sType                                  to RetvalType.sType
89651>>>                    Move ColumnTypeArray[iCount].iType          to RetvalType.iType 
89652>>>                    Move ColumnTypeArray[iCount].sDataFlexType  to RetvalType.sDataFlexType
89653>>>                    Move ColumnTypeArray[iCount].iDataFlexType  to RetvalType.iDataFlexType
89654>>>                    Move ColumnTypeArray[iCount].sPrecision     to RetvalType.sPrecision
89655>>>                    Move ColumnTypeArray[iCount].bFixedSize     to RetvalType.bFixedSize
89656>>>                    Move iSize to iCount // We're done!
89657>>>                End
89657>>>>
89657>>>            End
89657>>>>
89657>>>        Loop
89658>>>>
89658>>>        
89658>>>        Function_Return RetvalType
89659>>>    End_Function
89660>>>    
89660>>>    // *** Miscellaneous other functions ***
89660>>>    // Some of which can be used by both "Sqlxxx" and "Apixxx" functions.
89660>>>    //
89660>>>    
89660>>>    // Callback functionality used when e.g. calling driver functions directly.
89660>>>    Function Callback String sCallback_Text Integer iCallback_Type Returns Integer
89662>>>        Integer iRetval iPos iPerc
89662>>>        String sVal1 sVal2 
89662>>>        Number nReady nTotal 
89662>>>        
89662>>>        Send DoAdvance of ghoProgressBar           
89663>>>        
89663>>>        If (sCallback_Text contains "Copy records") Begin
89665>>>            Move CS_SQLCopyingData to sCallback_Text
89666>>>        End                                        
89666>>>>
89666>>>        If (sCallback_Text contains "Dropping index" or sCallback_Text contains "Temporary delete of all indices of table") Begin
89668>>>            Move (Replace("Dropping index", sCallback_Text, CS_SQLDeletingIndex)) to sCallback_Text 
89669>>>            Move (Replace("Temporary delete of all indices of table", sCallback_Text, CS_SQLDeletingIndex)) to sCallback_Text
89670>>>        End
89670>>>>
89670>>>        If (sCallback_Text contains "Creating index") Begin
89672>>>            Move (Replace("Creating index", sCallback_Text, CS_SQLCreatingIndex)) to sCallback_Text
89673>>>        End                                               
89673>>>>
89673>>>        
89673>>>        Case Begin
89673>>>            Case (iCallback_Type = DF_Message_Text) 
89675>>>                Set Message_Text of ghoStatusPanel to sCallback_Text  
89676>>>                Set Action_Text  of ghoStatusPanel to ""
89677>>>                Case Break
89678>>>            Case (iCallback_Type = DF_Message_Heading_1) 
89681>>>                Set Message_Text of ghoStatusPanel to sCallback_Text 
89682>>>                Set Action_Text  of ghoStatusPanel to ""
89683>>>                Case Break
89684>>>            Case (iCallback_Type = DF_Message_Heading_2) 
89687>>>                Set Message_Text of ghoStatusPanel to sCallback_Text 
89688>>>                Set Action_Text  of ghoStatusPanel to ""
89689>>>                Case Break
89690>>>            Case (iCallback_Type = DF_Message_Heading_3) 
89693>>>                Set Message_Text of ghoStatusPanel to sCallback_Text 
89694>>>                Set Action_Text  of ghoStatusPanel to ""
89695>>>                Case Break
89696>>>            Case (iCallback_Type = DF_Message_Heading_4) 
89699>>>                Set Message_Text of ghoStatusPanel to sCallback_Text 
89700>>>                Set Action_Text  of ghoStatusPanel to ""
89701>>>                Case Break
89702>>>            Case (iCallback_Type = DF_Message_Heading_5) 
89705>>>                Set Message_Text of ghoStatusPanel to sCallback_Text 
89706>>>                Set Action_Text  of ghoStatusPanel to ""
89707>>>                Case Break
89708>>>            Case (iCallback_Type = DF_Message_Warning) 
89711>>>                Send None
89712>>>                Case Break
89713>>>            Case (iCallback_Type = DF_Message_Progress_Title) 
89716>>>                Set Message_Text of ghoStatusPanel to sCallback_Text 
89717>>>                Set Action_Text  of ghoStatusPanel to ""
89718>>>                Case Break
89719>>>            Case (iCallback_Type = DF_Message_Progress_Value) 
89722>>>                //*** Interpret numbers
89722>>>                Move (Left(sCallback_Text, (Pos(",", sCallback_Text) - 1)))                       to nReady
89723>>>                Move (Right(sCallback_Text, (Length(sCallback_Text) - Pos(",", sCallback_Text)))) to nTotal
89724>>>                Move ((nReady / nTotal) * 100)                                                    to iPerc
89725>>>                Set Action_Text of ghoStatusPanel to (String(iPerc) * String("% (Total:") * String(nTotal) + ")")
89726>>>                Case Break
89727>>>            Case Else
89727>>>                Set Message_Text to ""
89728>>>                Set Action_Text  to ""    
89729>>>        Case End
89729>>>
89729>>>        Send ProcessEvents of ghoStatusPanel
89730>>>        Function_Return False
89731>>>    End_Function
