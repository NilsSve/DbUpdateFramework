90397>>>        // This should get it from the parent object (when using the cDbUpdateHandler class)
90397>>>        Set Error_Report_Mode to DUF_ERROR_NO_REPORT
90398>>>        Delegate Get piDbType to iRetval
90400>>>        Set Error_Report_Mode to DUF_ERROR_REPORT
90401>>>        Send Trap_Error of Error_Object_Id DFERR_BAD_MESSAGE
90402>>>
90402>>>        // ...and in case it didn't use property of this class. Then the library is
90402>>>        // probably used as "utilites" from a special made program and
90402>>>        // the ghoSQLConnectionHandler must have been setup
90402>>>        If (Err = True) Begin
90404>>>            Get piDbType of ghoSQLConnectionHandler to iRetval
90405>>>        End            
90405>>>>
90405>>>
90405>>>        Move False to Err
90406>>>        Function_Return iRetval
90407>>>    End_Function  
90408>>>    
90408>>>    // When dropping columns on some SQL back-ends they doesn't reclaim the space taken up by the columns dropped. 
90408>>>    // For data types that are stored inline in the rows (int for example) it may even take up space on 
90408>>>    // the new rows added after the alter statement. to get around this you need to create a clustered 
90408>>>    // index on the table _or_ rebuild the clustered Index if it already has one. Rebuilding the index 
90408>>>    // can be done with a REBUILD command after modifying the table. But be warned this can be slow on very big tables.
90408>>>    //   ALTER TABLE MyTable
90408>>>    //       REBUILD
90408>>>    Function _SqlUtilRemoveTableColumnMSSQL String sTableName String sColumnName Returns Boolean
90410>>>        Boolean bOK  
90410>>>        
90410>>>        If (Trim(sTableName) = "" or Trim(sColumnName) = "") Begin
90412>>>            Function_Return False
90413>>>        End                             
90413>>>>
90413>>>        
90413>>>        SQLIncludeScriptFile ..\Scripts\DropConstraintAndColumnNameMSSQL.sql as DropConstraintAndColumnNameMSSQL.sql
90413>>>        Get _SqlUtilRemoveTableColumnByScript "DropConstraintAndColumnNameMSSQL.sql" sTableName sColumnName to bOK
90414>>>        
90414>>>        Function_Return (bOK = True)
90415>>>    End_Function
90416>>>
90416>>>
90416>>>    // *** Helper functions with compiled sql script code ***
90416>>>    //  
90416>>>    // When dropping columns SQL Sever does not reclaim the space taken up by the columns dropped. 
90416>>>    // For data types that are stored inline in the rows (int for example) it may even take up space on 
90416>>>    // the new rows added after the alter statement. To get around this you need to create a clustered 
90416>>>    // index on the table or rebuild the clustered Index if it already has one. Rebuilding the index 
90416>>>    // can be done with a REBUILD command after modifying the table. But be warned this can be slow on very big tables.
90416>>>    //   ALTER TABLE MyTable
90416>>>    //       REBUILD
90416>>>    Function _SqlUtilRemoveTableColumnByScript String sMemScriptFile String sTableName String sColumnName Returns Boolean
90418>>>        tSQLScriptArray SQLScriptArray                      
90418>>>        tSQLScriptArray SQLScriptArray                      
90418>>>        String sDriverID sVal
90418>>>        Boolean bOK  
90418>>>        Integer iSize iCount
90418>>>        
90418>>>        If (Trim(sTableName) = "" or Trim(sColumnName) = "") Begin
90420>>>            Function_Return False
90421>>>        End                             
90421>>>>
90421>>>        
90421>>>        Get psDriverID to sDriverID
90422>>>        Get SqlUtilReadResource sMemScriptFile to SQLScriptArray
90423>>>        If (SQLScriptArray.bError = True) Begin
90425>>>            Function_Return False
90426>>>        End                     
90426>>>>
90426>>>        
90426>>>        Move (SizeOfArray(SQLScriptArray.sSQLScriptArray)) to iSize
90427>>>        Decrement iSize
90428>>>        
90428>>>        for iCount from 0 to iSize   
90434>>>>
90434>>>            If (SQLScriptArray.sSQLScriptArray[iCount] contains "TABLE_NAME_XXX") Begin
90436>>>                Move (Replaces("TABLE_NAME_XXX",  SQLScriptArray.sSQLScriptArray[iCount], String(sTableName))) to SQLScriptArray.sSQLScriptArray[iCount]
90437>>>            End
90437>>>>
90437>>>            If (SQLScriptArray.sSQLScriptArray[iCount] contains "COLUMN_NAME_XXX") Begin
90439>>>                Move (Replaces("COLUMN_NAME_XXX", SQLScriptArray.sSQLScriptArray[iCount], String(sColumnName))) to SQLScriptArray.sSQLScriptArray[iCount]
90440>>>            End
90440>>>>
90440>>>        Loop
90441>>>>
90441>>>        
90441>>>        Get SqlUtilExecuteEmbeddedScript SQLScriptArray sDriverID False "" to bOK
90442>>>        
90442>>>        Function_Return (bOK = True)
90443>>>    End_Function
