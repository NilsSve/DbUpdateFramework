91510>>>>>>>>>>>
91510>>>>>>>>>>>    // Request context help. If context is a number assume that it is
91510>>>>>>>>>>>    // context id help, else assume it is keyword help.
91510>>>>>>>>>>>    //
91510>>>>>>>>>>>    Procedure Exec_Context_Help string Context
91512>>>>>>>>>>>       if (left(context,1)) in '0123456789' ;    // if first character is a          Send Exec_System_Context_Help Context  // numeric we assume ID help
91515>>>>>>>>>>>       else ;                                    // otherwise we assume key-          Send Exec_System_Help Context          // word help.
91517>>>>>>>>>>>    End_Procedure // Exec_Context_Help
91518>>>>>>>>>>>
91518>>>>>>>>>>>    // NOTE: the following two messages are the only messages that directly make calls
91518>>>>>>>>>>>    //       to the windows API. This is important. These two messages could be changed
91518>>>>>>>>>>>    //       to call other help systems (e.g. HTML help) and the rest of the high level
91518>>>>>>>>>>>    //       program remains the same. These are the only two messages that are
91518>>>>>>>>>>>    //       expected to be windows help centric.
91518>>>>>>>>>>>
91518>>>>>>>>>>>    // Get Context Id help for passed ID. Use help file as defined
91518>>>>>>>>>>>    // in Help_filename. If id is 0 use general help id (which must be
91518>>>>>>>>>>>    // defined.
91518>>>>>>>>>>>    //
91518>>>>>>>>>>>    Procedure Exec_System_Context_Help integer Context_id
91520>>>>>>>>>>>        If Context_Id eq 0 ; // if zero, see if we have a contents page            Move (Help_Id_General(self)) to Context_id
91523>>>>>>>>>>>        If Context_Id eq 0 ; // if still zero, jump to the topics popup dialog            Send Exec_System_Help HELP_ON_TOPIC_STRING
91526>>>>>>>>>>>        Else ;            Send gDoWinHelp WH_INTCONTEXT (Help_Filename(self)) Context_Id
91528>>>>>>>>>>>    end_procedure
91529>>>>>>>>>>>
91529>>>>>>>>>>>    // Get keyword help for passed keyword. Use help file as defined
91529>>>>>>>>>>>    // in help_filename.
91529>>>>>>>>>>>    //
91529>>>>>>>>>>>    procedure Exec_System_Help string Keyword
91531>>>>>>>>>>>        If Keyword eq HELP_FOR_HELP_STRING ;            Send gDoWinHelp WH_HELPONHELP
91534>>>>>>>>>>>        else if (Keyword eq HELP_ON_TOPIC_STRING OR KeyWord="");            Send gDoWinHelp WH_FINDER (Help_Filename(self))
91538>>>>>>>>>>>        else ;            Send gDoWinHelp WH_STRINGCONTEXT (Help_Filename(self)) KeyWord
91540>>>>>>>>>>>    end_procedure
91541>>>>>>>>>>>
91541>>>>>>>>>>>end_class
