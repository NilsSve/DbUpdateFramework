91026>        Get ExtractFileName sFilename   to sFilelistName 
91027>        Move (Uppercase(sFilelistName)) to sFilelistName
91028>        If (bLast = True and sFilelistName = "FILELIST.CFG") Begin
91030>            Set Value of oFileList_fm to sFilename
91031>        End
91031>    End_Procedure
