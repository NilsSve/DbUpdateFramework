88150>>>    Function UtilDeleteCacheFile String sTableName Returns Boolean
88152>>>        String sDataPath sDriverID
88152>>>        Boolean bMertechDriver bOK  
88152>>>        Integer iPos
88152>>>        
88152>>>        If (sTableName contains ".") Begin
88154>>>            Move (Pos(".", sTableName)) to iPos
88155>>>            Move (Mid(sTableName, 999, (iPos +1))) to sTableName    
88156>>>        End                                                     
88156>>>>
88156>>>        
88156>>>        Get psDriverID to sDriverID
88157>>>        Get psDataPathFirstPart to sDataPath 
88158>>>        Get IsMertechDriver sDriverID to bMertechDriver
88159>>>        // First delete the cache file:
88159>>>        If (bMertechDriver = False) Begin
88161>>>            Get vDeleteFile (sDataPath + sTableName + ".cch") to bOK
88162>>>        End 
88162>>>>
88162>>>        Else Begin
88163>>>            Get _MertechDeleteTDFile sTableName to bOK
88164>>>        End                
88164>>>>
88164>>>        
88164>>>        Function_Return bOK
88165>>>    End_Function
88166>>>
88166>>>    // Changes source code files.
88166>>>    // Pass a file name with full path and a value to search for, together with the value
88166>>>    // to change to. Can e.g. be used for changing all .int files from using a fixed server name,
88166>>>    // to use a Connection ID. 
88166>>>    // Sample: Get UtilChangeSourceCodeLine "C:\DataFlex 18.2 Examples\Order Entry\Data\Order.int" "SERVER_NAME SERVER=(local)\SQLEXPRESS1" "SERVER_NAME DFCONNID=ChinookDb"
88166>>>    // Pass "True" for the bShowResult if you want to see the result while it works. Showln will then be used for output
88166>>>    // Returns True if no errors occured. 
88166>>>    Function UtilChangeSourceCodeLine String sFileName String sChangeFrom String sChangeTo Boolean bShowResult Returns Boolean
88168>>>        Integer iCh iRow iItems iCount
88168>>>        String sValue sRow
88168>>>        String[] sFileArray
88169>>>        Boolean bExists
88169>>>    
88169>>>        Move False to Err
88170>>>        Move 0 to iRow
88171>>>    
88171>>>        Get vFilePathExists sFileName to bExists
88172>>>        If (bExists = False) Begin
88174>>>            If (bShowResult = True) Begin
88176>>>                Showln "File does not exist: " sFileName
88179>>>            End
88179>>>>
88179>>>            Function_Return False
88180>>>        End
88180>>>>
88180>>>    
88180>>>        Get Seq_Open_Input_Channel sFileName to iCh
88181>>>        If (iCh < 1) Begin
88183>>>            Function_Return False
88184>>>        End
88184>>>>
88184>>>        
88184>>>        If (bShowResult = True) Begin  
88186>>>            Showln ""
88188>>>            Showln "sFileName = " sFileName
88191>>>            Showln "sChangeFrom = " sChangeFrom " sChangeTo = " sChangeTo
88196>>>        End
88196>>>>
88196>>>        
88196>>>        While (not(SeqEof))
88200>>>            Readln channel iCh sRow
88202>>>            If (Uppercase(sRow) contains Uppercase(sChangeFrom)) Begin 
88204>>>                If (bShowResult = True) Begin
88206>>>                    Showln "Changed from: " sRow " to: " sChangeTo
88211>>>                End
88211>>>>
88211>>>                // Change the whole line to the new connection id:
88211>>>                Move sChangeTo to sRow
88212>>>                // Move (Replaces(sChangeFrom, sRow, sChangeTo)) to sValue
88212>>>            End
88212>>>>
88212>>>            Move sRow to sFileArray[iRow]
88213>>>            Increment iRow
88214>>>        End
88215>>>>
88215>>>        Send Seq_Close_Channel iCh
88216>>>        
88216>>>        Sleep 1 // Wait for Windows to close the file
88217>>>    
88217>>>        Get Seq_Open_Output_Channel sFileName to iCh
88218>>>        If (iCh < 1) Begin
88220>>>            Function_Return False
88221>>>        End
88221>>>>
88221>>>        Move (SizeOfArray(sFileArray)) to iItems
88222>>>        Decrement iItems
88223>>>    
88223>>>        For iCount from 0 to iItems
88229>>>>
88229>>>            Move sFileArray[iCount] to sValue
88230>>>            Writeln channel iCh sValue
88233>>>        Loop
88234>>>>
88234>>>        Send Seq_Close_Channel iCh
88235>>>    
88235>>>        Function_Return (Err = False)
88236>>>    End_Function
88237>>>    
88237>>>    // This might be needed by API-methods when a connection id is to be used and
88237>>>    // the connection ID hasn't been established with the driver's CLI interface.
88237>>>    // NOTE: Only applicable for DAW drivers, as Mertech drivers doesn't use connection ID's.
88237>>>    Function UtilCreateConnectionID String sConnectionID Returns Boolean
88239>>>        String sConnectionString sDriverID
88239>>>        Boolean bOK bSilent bDawDriver
88239>>>        Handle hoCLI
88239>>>        
88239>>>        Move False to bOK   
88240>>>        Get psDriverID to sDriverID
88241>>>        Get IsDAWSQLDriver sDriverID to bDawDriver
88242>>>        If (bDawDriver = False) Begin
88244>>>            Error DFERR_PROGRAM "The UtilCreateConnectionID function is only available for DAW drivers. (Not Mertech)."
88245>>>>
88245>>>            Function_Return False
88246>>>        End
88246>>>>
88246>>>        
88246>>>        Get psConnectionString to sConnectionString
88247>>>        Get pbSilentLogin      to bSilent
88248>>>        
88248>>>        Get phoCLIHandler to hoCLI 
88249>>>        If (hoCLI <> 0) Begin
88251>>>            Set psDriverID of hoCLI to sDriverID
88252>>>            Get CreateConnectionID of hoCLI sConnectionID sConnectionString bSilent to bOK
88253>>>        End
88253>>>>
88253>>>        
88253>>>        Function_Return (bOK = False)
88254>>>    End_Function
88255>>>
88255>>>    // This message creates an error log in the "Home" folder named "SQLErrorLog.txt",
88255>>>    // and opens it in "notepad.exe".
88255>>>    // Note: This is _not_ used by the cDbUpdateHandler & cDbUpdateVersion classes!
88255>>>    //       Instead the cDbUpdateLogFile's WriteErrorLog & ShowErrorLog are then used.
88255>>>    Procedure UtilShowErrorList
88257>>>        tSqlErrorArray aSqlErrorArray 
88257>>>        tSqlErrorArray aSqlErrorArray 
88257>>>        Integer iRows iCount iCh iErrorNum
88257>>>        String sPath sFileName sErrorTxt sStatement
88257>>>        
88257>>>        Get psHome of (phoWorkspace(ghoApplication)) to sPath
88258>>>        Get vFolderFormat sPath to sPath
88259>>>        Move "SQLErrorLog.txt"  to sFileName
88260>>>        Get Seq_Open_Output_Channel (sPath + sFileName) to iCh
88261>>>            Get paSqlErrorArray to aSqlErrorArray
88262>>>            Move (SizeOfArray(aSqlErrorArray.sSqlErrorArray)) to iRows
88263>>>            If (iRows > 0) Begin
88265>>>                Decrement iRows
88266>>>                for iCount from 0 to iRows
88272>>>>
88272>>>                    Move aSqlErrorArray.sSqlErrorArray[iCount]      to sErrorTxt
88273>>>                    Move aSqlErrorArray.sSqlStatementArray[iCount]  to sStatement
88274>>>                    Move aSqlErrorArray.iSqlErrorArray[iCount]      to iErrorNum
88275>>>                    Writeln channel iCh "Error No: " iErrorNum " Error Text: " sErrorTxt
88281>>>                    Writeln channel iCh "SQL Statement: " sStatement
88285>>>                Loop
88286>>>>
88286>>>            End
88286>>>>
88286>>>        Send Seq_Close_Channel iCh
88287>>>        
88287>>>        If (iRows > 0) Begin
88289>>>            Runprogram Background "Notepad.exe" (sPath + sFileName)
88290>>>        End
88290>>>>
88290>>>    End_Procedure
