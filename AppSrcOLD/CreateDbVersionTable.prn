90373>>>    Function psDriverID Returns String
90375>>>        String sDriverID
90375>>>        
90375>>>        Send Ignore_Error of Error_Object_Id DFERR_BAD_MESSAGE
90376>>>        // This should get it from the parent object (when using the cDbUpdateHandler class)
90376>>>        Delegate Get psDriverID to sDriverID
90378>>>        Send Trap_Error of Error_Object_Id DFERR_BAD_MESSAGE
90379>>>        Move False to Err
90380>>>
90380>>>        // ...and in case it didn't use property of this class. Then the library is
90380>>>        // probably used as "utilites" from a special made program and
90380>>>        // the ghoSQLConnectionHandler must have been setup
90380>>>        If (sDriverID = "") Begin
90382>>>            Get psDriverID of ghoSQLConnectionHandler to sDriverID
90383>>>        End            
90383>>>>
90383>>>        Function_Return sDriverID
90384>>>    End_Function  
