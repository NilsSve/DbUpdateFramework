87311>>>    // *** Field/Column Level Functions: ***
87311>>>    //
87311>>>    // Adds a column name to the passed table number.
87311>>>    // Note: Types must be the standard DF_ASCII, DF_DATE etcetera and _cannot_ be any of the SQL_xxx types.
87311>>>    Function ApiColumnAdd Handle hTable String sFieldName Integer iType Integer iLength Integer iPrecision Returns Boolean
87313>>>        Integer iColumn iCount iFile
87313>>>        Boolean bExists bOK  
87313>>>        String sDdSrcPath sTableName
87313>>>    
87313>>>        Get UtilColumnExists hTable sFieldName to bExists
87314>>>        If (bExists = True) Begin
87316>>>            Function_Return False
87317>>>        End  
87317>>>>
87317>>>        If (iPrecision > 0) Begin
87319>>>            Move (iLength + iPrecision) to iLength
87320>>>        End
87320>>>>
87320>>>        
87320>>>        Get AutoConnectionIDLogin to bOK
87321>>>        Move False to Err   
87322>>>        // Structure_start will change the value of hTable...
87322>>>        Move hTable to iFile
87323>>>        Open iFile Mode DF_EXCLUSIVE
87325>>>        
87325>>>        Structure_Start iFile
87326>>>            Move 0 to iColumn
87327>>>            Create_Field hTable At iColumn
87328>>>            Set_Attribute DF_FIELD_NAME      of iFile iColumn to sFieldName
87331>>>            Set_Attribute DF_FIELD_TYPE      of iFile iColumn to iType
87334>>>            Set_Attribute DF_FIELD_LENGTH    of iFile iColumn to iLength
87337>>>            Set_Attribute DF_FIELD_PRECISION of iFile iColumn to iPrecision
87340>>>        Structure_End iFile
87342>>>        
87342>>>        // If in development environment; create .fd file:
87342>>>        Open hTable
87344>>>        Get psDdSrcPath of (phoWorkspace(ghoApplication)) to sDDSrcPath
87345>>>        Get CountOfPaths of (phoWorkspace(ghoApplication)) sDDSrcPath to iCount
87346>>>        If (iCount > 1) Begin
87348>>>            Get PathAtIndex of (phoWorkspace(ghoApplication)) sDDSrcPath 1 to sDDSrcPath    
87349>>>        End 
87349>>>>
87349>>>        Get vFolderExists sDDSrcPath to bExists
87350>>>        If (bExists = True) Begin                                   
87352>>>            Get vFolderFormat sDDSrcPath to sDDSrcPath 
87353>>>            Get_Attribute DF_FILE_ROOT_NAME of hTable to sTableName
87356>>>            Get _TableNameOnly sTableName to sTableName 
87357>>>            Output_Aux_File DF_AUX_FILE_FD for hTable to (sDDSrcPath + sTableName + ".fd")
87359>>>        End
87359>>>>
87359>>>        Close hTable
87360>>>
87360>>>        Function_Return (Err = False)
87361>>>    End_Function  
