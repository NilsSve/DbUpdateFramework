82744>>>>>>>>Function ParseKeyWord String sConnect String sKeyWord Returns String
82746>>>>>>>>    Integer iStart iEnd
82746>>>>>>>>    String sRetval
82746>>>>>>>>
82746>>>>>>>>    Move (Trim(sConnect)) to sConnect
82747>>>>>>>>    Move (Pos(Uppercase(sKeyWord), Uppercase(sConnect)))  to iStart
82748>>>>>>>>    If (iStart = 0) Begin
82750>>>>>>>>        Function_Return ""
82751>>>>>>>>    End
82751>>>>>>>>>
82751>>>>>>>>    Move (Left(sConnect, (iStart -1 + Length(sKeyWord)))) to sRetval
82752>>>>>>>>    Move (Replace(sRetval, sConnect, "")) to sRetval 
82753>>>>>>>>    If (sKeyWord = Uppercase(CS_SQLConnectionIDText)) Begin
82755>>>>>>>>        Move (Pos(",", sRetval))          to iEnd
82756>>>>>>>>    End
82756>>>>>>>>>
82756>>>>>>>>    Else Begin
82757>>>>>>>>        Move (Pos(";", sRetval))          to iEnd
82758>>>>>>>>    End                                          
82758>>>>>>>>>
82758>>>>>>>>    If (iEnd = 0 and (sRetval contains ",")) Begin
82760>>>>>>>>        Move (Pos(",", sRetval))          to iEnd 
82761>>>>>>>>        Decrement iEnd
82762>>>>>>>>    End
82762>>>>>>>>>
82762>>>>>>>>    If (iEnd <> 0) Begin
82764>>>>>>>>        Move (Left(sRetval, (iEnd -1)))   to sRetval
82765>>>>>>>>    End
82765>>>>>>>>>
82765>>>>>>>>    Move (Replace("=", sRetval, ""))      to sRetval
82766>>>>>>>>
82766>>>>>>>>    Function_Return (Trim(sRetval))
82767>>>>>>>>End_Function
