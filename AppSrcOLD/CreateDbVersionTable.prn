84802>>>    // Checks if the database exists in SQL. Returns = True if it does.
84802>>>    Function SqlUtilCheckIfDatabaseExists String sDatabase Returns Boolean
84804>>>        String[] sDatabaseArray
84805>>>        String sVal sServer sDriverID
84805>>>        Integer iCount iSize iPos
84805>>>        Boolean bExists            
84805>>>        tSQLConnection SQLConnection
84805>>>        tSQLConnection SQLConnection
84805>>>        
84805>>>        Move False to bExists                              
84806>>>        Get psDriverID to sDriverID
84807>>>        // DB2 doesn't need to have a "Database" name, so we always return True.
84807>>>        If (sDriverID = DB2_DRV_ID) Begin
84809>>>            Function_Return bExists
84810>>>        End                     
84810>>>>
84810>>>        
84810>>>        Get SqlUtilEnumerateDatabases sDriverID to sDatabaseArray
84811>>>        If (SizeOfArray(sDatabaseArray) = 0) Begin
84813>>>            Function_Return False
84814>>>        End
84814>>>>
84814>>>        
84814>>>        Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
84815>>>        Get ParseKeyWord SQLConnection.sConnectionString (CS_SQLIniDSNKeyword + "=") to sServer
84816>>>        If (sServer contains "/") Begin
84818>>>            Move (Pos("/", sServer)) to iPos
84819>>>            Move (Mid(sServer, 999, (iPos +1)))                        to sDatabase
84820>>>        End
84820>>>>
84820>>>        
84820>>>        Move (SizeOfArray(sDatabaseArray)) to iSize
84821>>>        Decrement iSize
84822>>>        For iCount from 0 to iSize
84828>>>>
84828>>>            Move sDatabaseArray[iCount] to sVal
84829>>>            If (Uppercase(sVal) = Uppercase(sDatabase)) Begin
84831>>>                Move True to bExists
84832>>>            End
84832>>>>
84832>>>        Loop
84833>>>>
84833>>>        
84833>>>        Function_Return bExists
84834>>>    End_Function
