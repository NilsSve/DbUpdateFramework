84885>>>    // Enumerate SQL Servers. 
84885>>>    // Pass a driver id. Returns a string array.                     
84885>>>    // The iDataSourceType (iDatSrcType) parameter is optional and is for the ODBC driver only.
84885>>>    // Note: Returns servers for MSSQLDRV; else data-sources on the machine.
84885>>>    Function SqlUtilEnumerateServers String sDriverID Integer iDatSrcType Returns String[]
84887>>>        String[] sReturnArray
84888>>>        Handle hoSQLHandler
84888>>>        String sServer
84888>>>        Integer iCount iNumItems iDataSourceType
84888>>>        Boolean bOK
84888>>>        
84888>>>        If (num_arguments > 1) Begin
84890>>>            Move iDatSrcType to iDataSourceType
84891>>>        End                                    
84891>>>>
84891>>>        
84891>>>        Case Begin
84891>>>            Case (sDriverID = MSSQLDRV_ID) 
84893>>>                Get phoMSSQLHandler to hoSQLHandler
84894>>>                    Get EnumerateServersLocal of hoSQLHandler to iNumItems
84895>>>                    If (iNumItems = 0) Begin
84897>>>                        Get EnumerateServers of hoSQLHandler to iNumItems
84898>>>                    End            
84898>>>>
84898>>>                For iCount from 0 to (iNumItems - 1)
84904>>>>
84904>>>                    Get String_Value of hoSQLHandler item iCount to sServer
84905>>>                    Move (Trim(sServer)) to sReturnArray[iCount]
84906>>>                Loop
84907>>>>
84907>>>                Case Break 
84908>>>    
84908>>>            Case (sDriverID = DB2_DRV_ID) 
84911>>>                Get phoDB2SQLHandler to hoSQLHandler
84912>>>                Send SeedDataSources of hoSQLHandler          
84913>>>                Move 0 to iCount
84914>>>                Repeat
84914>>>>
84914>>>                    Get DataSources of hoSQLHandler to sServer
84915>>>                    If (sServer <> "") Begin   
84917>>>                        Move (Replace(",", sServer, "")) to sServer
84918>>>                        Move sServer to sReturnArray[iCount]
84919>>>                    End
84919>>>>
84919>>>                    Increment iCount    
84920>>>                Until (sServer = "")
84922>>>                Case Break
84923>>>    
84923>>>            Case (sDriverID = ODBC_DRV_ID) 
84926>>>                Get phoODBCSQLHandler to hoSQLHandler
84927>>>                Set DataSourceType of hoSQLHandler to iDataSourceType       
84928>>>                Move 0 to iCount
84929>>>                Repeat
84929>>>>
84929>>>                    Get DataSources of hoSQLHandler to sServer
84930>>>                    If (sServer <> "") Begin   
84932>>>                        Move (Replace(",", sServer, ", ")) to sServer
84933>>>                        Move sServer to sReturnArray[iCount]
84934>>>                    End
84934>>>>
84934>>>                    Increment iCount    
84935>>>                Until (sServer = "")
84937>>>                Case Break    
84938>>>            
84938>>>            Case (sDriverID = SQLFLEX)  
84941>>>                Get _MertechEnumerateSQLFlexServers to sReturnArray
84942>>>                Case Break
84943>>>            
84943>>>            Case (sDriverID = ORAFLEX)          
84946>>>                Get _MertechEnumerateORAFLEXServers to sReturnArray
84947>>>                Case Break
84948>>>            
84948>>>            // There appearantly is no way to enumerate servers for this backend.
84948>>>            Case (sDriverID = MDSPgSQL)
84951>>>                Move "localhost" to sReturnArray[0]
84952>>>                Case Break
84953>>>            
84953>>>            // There appearantly is no way to enumerate servers for this backend.
84953>>>            Case (sDriverID = MDSMySQL)
84956>>>                Move "localhost" to sReturnArray[0]
84957>>>                Case Break
84958>>>            
84958>>>            Case Else
84958>>>                Error DFERR_PROGRAM "Unsupported DriverID passed to SqlUtilEnumerateServers function"
84959>>>>
84959>>>        Case End
84959>>>
84959>>>        Function_Return sReturnArray
84960>>>    End_Function
84961>>>    
84961>>>    // Returns all databases as a string array for the passed driver id.
84961>>>    Function SqlUtilEnumerateDatabases String sDriverID Returns String[]
84963>>>        String[] sReturnArray                                                    
84964>>>        String sUserID sPassword 
84964>>>        Boolean bOK
84964>>>        
84964>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
84965>>>        If (bOK = False) Begin
84967>>>            Function_Return sReturnArray
84968>>>        End    
84968>>>>
84968>>>        
84968>>>        Case Begin
84968>>>            Case (sDriverID = MSSQLDRV_ID)
84970>>>                Get _SqlDatabasesArrayMSSQL to sReturnArray
84971>>>                Case Break                                                            
84972>>>            Case (sDriverID = DB2_DRV_ID)
84975>>>                Get _SqlDatabasesArrayDB2 to sReturnArray
84976>>>                Case Break
84977>>>
84977>>>            // Enumeration of ODBC databases should be irrelevant as the database
84977>>>            // should have been specified when the ODBC source was setup with the ODBC manager.
84977>>>            Case (sDriverID = ODBC_DRV_ID)
84980>>>                Case Break
84981>>>
84981>>>            Case (sDriverID = SQLFLEX)
84984>>>                Get SqlProcedureArrayMertech "sp_databases" "" to sReturnArray
84985>>>                Case Break
84986>>>
84986>>>            Case (sDriverID = MDSPgSQL)
84989>>>                Get SqlEnumerateEsqlMertech "SELECT datname FROM pg_database" to sReturnArray
84990>>>                Case Break
84991>>>                 
84991>>>            Case (sDriverID = MDSMySQL)
84994>>>                Get SqlEnumerateEsqlMertech "show databases" to sReturnArray
84995>>>                Case Break 
84996>>>            
84996>>>            Case (sDriverID = ORAFLEX)  
84999>>>                Get SqlEnumerateEsqlMertech "SELECT NAME FROM v$database" to sReturnArray
85000>>>                Case Break
85001>>>
85001>>>            Case Else
85001>>>                Error DFERR_PROGRAM "Unsupported DriverID passed to SqlUtilEnumerateDatabases function"
85002>>>>
85002>>>        Case End  
85002>>>        
85002>>>        Function_Return sReturnArray
85003>>>    End_Function
