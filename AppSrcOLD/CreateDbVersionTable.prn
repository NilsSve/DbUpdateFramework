81856>>>>>>>Struct tSQLConnection
81856>>>>>>>    Boolean bEnabled                // 1. There can only be one active/enabled connection at a time.
81856>>>>>>>    String sConnectionID            // 2. The name of the connection ID.      
81856>>>>>>>    Integer iDbType                 // 3. Database type; "MS-SQL Server", "DB2", "Oracle", "MySQL", "PostgreSQL"
81856>>>>>>>    String sDriverID                // 4. Name of the driver. E.g. "MSSQLDRV", "DB2_DRV" or "ODBC_DRV".
81856>>>>>>>    String sServer                  // 5. SQL Server/DSN/ODBC source name. (In DF19 this is the "sString" member of the tConnection struct.)
81856>>>>>>>    String sDatabase                // 6. SQL Database
81856>>>>>>>    String sConnectionString        // 7. Full connection string as is needed by e.g. the login command.
81856>>>>>>>    Boolean bTrusted                // 8. Trusted connection (then is UID & PWD not used)                
81856>>>>>>>    String sUserID                  // 9. User ID
81856>>>>>>>    String sPassword                // 10. Password
81856>>>>>>>    String sSchema                  // 11. DB2 (and perhaps ODBC specific)
81856>>>>>>>    String sBaseTableSpace          // 12. DB2 specific
81856>>>>>>>    String sLongTableSpace          // 13. DB2 specific
81856>>>>>>>    String sIndexTableSpace         // 14. DB2 specific 
81856>>>>>>>    Boolean bSilentLogin            // 15. True=Silent login. (i.e. don't show Database login dialog if database login to fails). Same as driver "Options" parameter.
81856>>>>>>>    Boolean bError                  // 16. Set to true on error.
81856>>>>>>>//    Boolean bDisabled               // 17. For compatability with DF19 Managed Connections only. Not used by DUF (Database Update Framework).
81856>>>>>>>//    Integer iDriverIndex            // 18. For compatability with DF19 Managed Connections only. Not used by DUF (Database Update Framework).
81856>>>>>>>End_Struct            
81856>>>>>
81856>>>>>Class cDbUpdateFunctionLibrary_Mixin is a Mixin 
81857>>>>>    Procedure CreateDbUpdateLibraryProperties
81859>>>>>        Handle hoSQLManagerMT
81859>>>>>        
81859>>>>>        // Error Reporting Related
81859>>>>>        // If DUF_ERROR_NO_REPORT errors are supressed (only ERR gets set)
81859>>>>>        Property Integer Error_Report_Mode DUF_ERROR_REPORT
81860>>>>>
81860>>>>>        Property String Private.psUseDatabase ""
81861>>>>>
81861>>>>>        Property Boolean pbToANSI   True
81862>>>>>        Property Boolean pbRecnum   True
81863>>>>>        Property Boolean pbCopyData True                    
81864>>>>>        
81864>>>>>        Property Handle phoCLIHandler      (Create(Self,RefClass(cCLIHandler)))
81865>>>>>        Property Handle phoSQLManager      (Create(Self,RefClass(cSQLHandleManager))) 
81866>>>>>        
81866>>>>>        Property Handle phoSQLManagerMT
81867>>>>>        
81867>>>>>        Property Handle phoMSSQLHandler    (Create(Self,RefClass(cMSSQLHandler)))
81868>>>>>        Property Handle phoDB2SQLHandler   (Create(Self,RefClass(cDB2Handler)))
81869>>>>>        Property Handle phoODBCSQLHandler  (Create(Self,RefClass(cODBCHandler)))
81870>>>>>        Property Handle phoSQLConnectionHandler 0  
81871>>>>>        Property tSQLKeyWords[] paSQLKeywordArray
81872>>>>>        
81872>>>>>        Property Boolean pbHandleQueryErrors True 
81873>>>>>        
