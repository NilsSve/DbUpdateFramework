80287>>>Function vWin32_APIFileSize Global string sFileName returns integer
80289>>>     dWord dwFileSizeHigh dwFileSizeLow
80289>>>     integer iFileSize iVoid
80289>>>     handle hFindFile
80289>>>     pointer lpsFilePath lpsWin32FindData
80289>>>     string sWin32FindData
80289>>>
80289>>>     GetAddress of sFileName to lpsFilePath
80290>>>
80290>>>     ZeroType vWin32_Find_Data to sWin32FindData
80291>>>     GetAddress of sWin32FindData to lpsWin32FindData
80292>>>
80292>>>     move (vWin32_FindFirstFile (lpsFilePath, lpsWin32FindData)) to hFindFile
80293>>>     if (hFindFile<>vINVALID_HANDLE_VALUE) begin
80295>>>         GetBuff From sWin32FindData At vWin32_Find_Data.nFileSizeHigh To dwFileSizeHigh
80296>>>         GetBuff From sWin32FindData At vWin32_Find_Data.nFileSizeLow To dwFileSizeLow
80297>>>     end
80297>>>>
80297>>>     move (vWin32_FindClose (hFindFile)) to iVoid
80298>>>
80298>>>     moveInt ((dwFileSizeHigh * vMaxDword) + dwFileSizeLow) to iFileSize
80299>>>>
80299>>>
80299>>>     function_return iFileSize
80300>>>End_Function  // vWin32_APIFileSize
