83645>>>>>
83645>>>>>        If (bOK = False) Begin
83647>>>>>            Get IsMertechDriver sDriverID to bOK
83648>>>>>        End                                     
83648>>>>>>
83648>>>>>
83648>>>>>        If (bOK = False) Begin        
83650>>>>>            Get IsMertechDriver sDriverID to bMertechDriver
83651>>>>>            If (bMertechDriver = True) Begin
83653>>>>>                Error DFERR_PROGRAM "Driver needs to be one of MSSQLDRV_ID, DB2_DRV_ID, ODBC_DRV_ID, SQLFLEX, ORAFLEX, MDSPgSQL or MDSMYSQL"
83654>>>>>>
83654>>>>>            End
83654>>>>>>
83654>>>>>            Else Begin
83655>>>>>                Error DFERR_PROGRAM "Driver needs to be one of MSSQLDRV_ID, DB2_DRV_ID or ODBC_DRV_ID"
83656>>>>>>
83656>>>>>            End
83656>>>>>>
83656>>>>>            Function_Return False
83657>>>>>        End
83657>>>>>>
83657>>>>>        
83657>>>>>        Function_Return True
83658>>>>>    End_Function
83659>>>>>            
83659>>>>>    Function IsDAWSQLDriver String sDriverID Returns Boolean
83661>>>>>        Boolean bOK
83661>>>>>        Move (sDriverID = MSSQLDRV_ID or sDriverID = DB2_DRV_ID or sDriverID = ODBC_DRV_ID) to bOK
83662>>>>>        Function_Return bOK
83663>>>>>    End_Function
83664>>>>>
83664>>>>>    Function IsMertechDriver String sDriverID Returns Boolean
83666>>>>>        Boolean bOK   
