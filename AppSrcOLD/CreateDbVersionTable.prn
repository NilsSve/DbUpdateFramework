86273>>>    Function _SqlProcedureArrayDAW String sStmt String sArgument Returns String[]
86275>>>        String[] sReturnArray  
86276>>>        String sValue                         
86276>>>        Handle hoSQLHandler hoSQLConnect hStmt    
86276>>>        Integer iRetval iCols iFetchResult
86276>>>        tSQLConnection SQLConnection
86276>>>        tSQLConnection SQLConnection
86276>>>        
86276>>>        Get phoSQLManager to hoSQLHandler
86277>>>        Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
86278>>>        Get SqlConnect of hoSQLHandler SQLConnection.sDriverID SQLConnection.sConnectionString to hoSQLConnect
86279>>>
86279>>>        If (hoSQLConnect <> 0) Begin
86281>>>            Get SqlOpen of hoSQLConnect to hStmt
86282>>>            If (hStmt <> 0) Begin
86284>>>                Send SqlSetProcedurename of hStmt sStmt 
86285>>>                If (sArgument <> "") Begin
86287>>>                    Send SqlSetArgument  of hStmt 1 sArgument
86288>>>                End
86288>>>>
86288>>>                            
86288>>>                Send SqlCall             of hStmt      
86289>>>                Get SqlReturnValue       of hStmt to iRetval
86290>>>                If (iRetval = 0) Begin
86292>>>                    Repeat    
86292>>>>
86292>>>                        Get SqlStmtAttribute of hStmt SqlSTMTATTRIB_COLUMNCOUNT to iCols
86293>>>                        If (iCols > 0) Begin 
86295>>>                            Repeat
86295>>>>
86295>>>                                Get SqlFetch of hStmt to iFetchResult
86296>>>                                If (iFetchResult <> 0) Begin
86298>>>                                    Get SqlColumnValue of hStmt 1 to sValue    
86299>>>                                    Move (Trim(sValue)) to sReturnArray[SizeOfArray(sReturnArray)]
86300>>>                                End
86300>>>>
86300>>>                            Until (iFetchResult = 0)
86302>>>                        End
86302>>>>
86302>>>                        Get SqlNextResultSet of hStmt to iRetval
86303>>>                    Until (iRetval = 0) 
86305>>>                    Send SqlClose of hStmt
86306>>>                End
86306>>>>
86306>>>            End                       
86306>>>>
86306>>>            Send SqlDisconnect of hoSQLConnect
86307>>>        End                                                                         
86307>>>>
86307>>>        Function_Return sReturnArray
86308>>>    End_Function
