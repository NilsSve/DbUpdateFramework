86151>>>    Function _SqlProperTableName String sTableName Returns String
86153>>>        String sVal sSchema sDriverID sValue
86153>>>        Handle hTable  
86153>>>        Integer iDbType
86153>>>        
86153>>>        If (Trim(sTableName) = "") Begin
86155>>>            Function_Return ""
86156>>>        End
86156>>>>
86156>>>
86156>>>        Get psDriverID to sDriverID
86157>>>        Get piDbType   to iDbType
86158>>>        If (iDbType = EN_dbTypeOracle) Begin
86160>>>            Get psUserID to sSchema
86161>>>            // Not sure about this uppercasing but it seems like Oracle wants that?
86161>>>            Move (Uppercase(sSchema)) to sSchema
86162>>>            Move ('"' + sSchema + '"."' + sTableName + '"') to sTableName
86163>>>            Function_Return sTableName
86164>>>        End 
86164>>>>
86164>>>        If (iDbType = EN_DbTypeMySQL) Begin
86166>>>            Get psDatabase to sVal
86167>>>            Move (sVal + "." + sTableName) to sTableName
86168>>>            Function_Return sTableName
86169>>>        End 
86169>>>>
86169>>>        If (iDbType = EN_DbTypePostgre) Begin
86171>>>            Move ('"' + sTableName + '"') to sTableName
86172>>>            Function_Return sTableName
86173>>>        End
86173>>>>
86173>>>        
86173>>>        Get psSchema to sSchema   
86174>>>        If (sSchema = "") Begin
86176>>>            Get _SqlFindKeyWord CI_SQLDBO to sSchema
86177>>>        End
86177>>>>
86177>>>
86177>>>        Move (Uppercase(sTableName)) to sVal
86178>>>        If (not(sVal contains (sSchema + "."))) Begin  
86180>>>            If (iDbType = EN_dbTypeDB2) Begin
86182>>>                Move (Lowercase(sSchema) + "." + sTableName) to sTableName
86183>>>            End 
86183>>>>
86183>>>            Else Begin
86184>>>                Move (sSchema + "." + sTableName) to sTableName
86185>>>            End
86185>>>>
86185>>>        End    
86185>>>>
86185>>>
86185>>>        Function_Return sTableName
86186>>>    End_Function
86187>>>    
86187>>>    // SQL column names can be case-sensitive. This function is used to check that
86187>>>    // the passed sFieldName has the correct spelling.                            
86187>>>    // Used with Embedded SQL statement calls.
86187>>>    // If the spelling or fieldname doesn't exist, the return value is "" (blank).
86187>>>    Function _SqlFindColumnName String sTableName String sColumnName Returns String
86189>>>        String sRetval sValue sConnectionString sDriverID 
86189>>>        String[] sColumnNamesArray
86190>>>        Integer iCount iColumns
86190>>>
86190>>>        Move "" to sRetval
86191>>>        Get psDriverID to sDriverID
86192>>>        Get SqlUtilEnumerateColumns sDriverID sTableName to sColumnNamesArray
86193>>>        Move (SizeOfArray(sColumnNamesArray)) to iColumns
86194>>>        Decrement iColumns
86195>>>        
86195>>>        For iCount from 0 to iColumns
86201>>>>
86201>>>            Move sColumnNamesArray[iCount] to sValue
86202>>>            If (Uppercase(sColumnName) = Uppercase(sValue)) Begin
86204>>>                Move sValue to sRetval
86205>>>                Move iColumns to iCount // We're done.
86206>>>            End
86206>>>>
86206>>>        Loop                           
86207>>>>
86207>>>        
86207>>>        Function_Return sRetval
86208>>>    End_Function
