83442>>>>>        tSQLConnection SQLConnection
83442>>>>>        tSQLConnection SQLConnection
83442>>>>>        Boolean bTrusted
83442>>>>>        
83442>>>>>        Move 0 to iResult
83443>>>>>        Get Create U_cCLIHandler to hoCLI
83444>>>>>        If (hoCLI <> 0) Begin
83446>>>>>            Set psDriverID of hoCLI to sDriverID
83447>>>>>            Get DriverIndex sDriverID to iDriver
83448>>>>>            Get_Attribute DF_DRIVER_NUMBER_CONNECTION_IDS of iDriver to iNumConn 
83451>>>>>            Decrement iNumConn
83452>>>>>            For iConn from 0 to iNumConn
83458>>>>>>
83458>>>>>                Get_Attribute DF_DRIVER_CONNECTION_ID of iDriver iConn to sID
83461>>>>>                If (Uppercase(sID) = Uppercase(sConnectionID)) Begin                                             
83463>>>>>                    Move sDriverID                                                      to SQLConnection.sDriverID      // For completeness only...
83464>>>>>                    Get_Attribute DF_DRIVER_CONNECTION_ID of iDriver iConn              to SQLConnection.sConnectionID  // For completeness only...
83467>>>>>                    Get_Attribute DF_DRIVER_CONNECTION_ID_STRING of iDriver iConn       to sConnectionString
83470>>>>>                    Move sConnectionString                                              to SQLConnection.sConnectionString 
83471>>>>>                    Get_Attribute DF_DRIVER_CONNECTION_ID_OPTIONS of iDriver iConn      to SQLConnection.bSilentLogin
83474>>>>>                    Get ParseKeyWord sConnectionString (CS_SQLIniServerKeyword + "=")   to SQLConnection.sServer
83475>>>>>                    Get ParseKeyWord sConnectionString (CS_SQLIniDatabaseKeyword + "=") to SQLConnection.sDatabase
83476>>>>>                    Get ParseKeyWord sConnectionString (CS_SQLIniUIDKeyword + "=")      to SQLConnection.sUserID
83477>>>>>                    Get ParseKeyWord sConnectionString (CS_SQLIniPWDKeyword + "=")      to SQLConnection.sPassword
83478>>>>>                    
83478>>>>>                    Case Begin
83478>>>>>                        Case (sDriverID = MSSQLDRV_ID)
83480>>>>>                            Get ParseKeyWord sConnectionString (CS_SQLIniTrustedKeyword + "=") to sVal
83481>>>>>                            Move (If(Uppercase(sVal) = Uppercase(CS_SQLIniConnectionYes), True, False)) to bTrusted
83482>>>>>                            Move bTrusted                                               to SQLConnection.bTrusted
83483>>>>>                            Case Break
83484>>>>>                        Case (sDriverID = DB2_DRV_ID)
83487>>>>>                            Get ParseKeyWord sConnectionString (CS_SQLIniDSNKeyword + "=") to SQLConnection.sServer
83488>>>>>                            Case Break
83489>>>>>                        Case (sDriverID = ODBC_DRV_ID)
83492>>>>>                            Get ParseKeyWord sConnectionString (CS_SQLIniDSNKeyword + "=") to SQLConnection.sServer
83493>>>>>                            Case Break
83494>>>>>                        Case (sDriverID = SQLFLEX)
83497>>>>>                            Get ParseKeyWord sConnectionString (CS_SQLIniDSNKeyword + "=") to SQLConnection.sServer 
83498>>>>>                            Move (CS_SQLIniServerKeyword + "=" + SQLConnection.sServer)    to sConnectionString
83499>>>>>                            If (SQLConnection.bTrusted = True) Begin
83501>>>>>                                Move (sConnectionString + ";" + CS_SQLIniTrustedKeyword + "=" + CS_SQLIniConnectionYes) to sConnectionString
83502>>>>>                            End
83502>>>>>>
83502>>>>>                            Else Begin
83503>>>>>                                Get ParseKeyWord sConnectionString (CS_SQLIniUIDKeyword + "=")    to sVal
83504>>>>>                                Move (sConnectionString + ";" + CS_SQLIniUIDKeyword + "=" + sVal) to sConnectionString
83505>>>>>                                Get ParseKeyWord sConnectionString (CS_SQLIniPWDKeyword + "=")    to sVal
83506>>>>>                                Move (sConnectionString + ";" + CS_SQLIniPWDKeyword + "=" + sVal) to sConnectionString
83507>>>>>                            End
83507>>>>>>
83507>>>>>                            Move sConnectionString                                         to SQLConnection.sConnectionString
83508>>>>>                            Case Break
83509>>>>>                        Case (sDriverID = MDSMySQL)
83512>>>>>                            Get ParseKeyWord sConnectionString (CS_SQLIniDSNKeyword + "=") to SQLConnection.sServer 
83513>>>>>                            Move (CS_SQLIniServerKeyword + "=" + SQLConnection.sServer)    to sConnectionString
83514>>>>>                            If (SQLConnection.bTrusted = True) Begin
83516>>>>>                                Move (sConnectionString + ";" + CS_SQLIniTrustedKeyword + "=" + CS_SQLIniConnectionYes) to sConnectionString
83517>>>>>                            End
83517>>>>>>
83517>>>>>                            Else Begin
83518>>>>>                                Get ParseKeyWord sConnectionString (CS_SQLIniUIDKeyword + "=")    to sVal
83519>>>>>                                Move (sConnectionString + ";" + CS_SQLIniUIDKeyword + "=" + sVal) to sConnectionString
83520>>>>>                                Get ParseKeyWord sConnectionString (CS_SQLIniPWDKeyword + "=")    to sVal
83521>>>>>                                Move (sConnectionString + ";" + CS_SQLIniPWDKeyword + "=" + sVal) to sConnectionString
83522>>>>>                            End
83522>>>>>>
83522>>>>>                            Move sConnectionString                                         to SQLConnection.sConnectionString
83523>>>>>                            Case Break
83524>>>>>                        Case (sDriverID = MDSPgSQL)
83527>>>>>                            Get ParseKeyWord sConnectionString (CS_SQLIniDSNKeyword + "=") to SQLConnection.sServer 
83528>>>>>                            Move (CS_SQLIniServerKeyword + "=" + SQLConnection.sServer)    to sConnectionString
83529>>>>>                            If (SQLConnection.bTrusted = True) Begin
83531>>>>>                                Move (sConnectionString + ";" + CS_SQLIniTrustedKeyword + "=" + CS_SQLIniConnectionYes) to sConnectionString
83532>>>>>                            End
83532>>>>>>
