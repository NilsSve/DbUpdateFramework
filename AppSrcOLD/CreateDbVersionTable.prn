92197>>>>>    Procedure Set Version String sVersion
92199>>>>>        Handle hoVersionInfo
92199>>>>>        Boolean bIncluded
92199>>>>>        Integer iMajor iMinor iRelease iBuild
92199>>>>>        Date dCompileDate
92199>>>>>
92199>>>>>        If (sVersion = "") Begin
92201>>>>>            // This automatically shows the program version of the program, if available.
92201>>>>>            // It will be displayed as the second item in the edit object.
92201>>>>>            If (ghoApplication <> 0) Begin
92203>>>>>                Get phoVersionInfo of ghoApplication to hoVersionInfo
92204>>>>>                If (hoVersionInfo <> 0) Begin
92206>>>>>                    Get pbIncluded of hoVersionInfo to bIncluded
92207>>>>>                    If (bIncluded) Begin
92209>>>>>                        Get piVersionMajor of hoVersionInfo to iMajor
92210>>>>>                        Get piVersionMinor of hoVersionInfo to iMinor
92211>>>>>                        Get piVersionRelease of hoVersionInfo to iRelease
92212>>>>>                        Get piVersionBuild of hoVersionInfo to iBuild
92213>>>>>                        Move (SFormat (C_$VERSION + ": %1.%2.%3.%4", iMajor, iMinor, iRelease, iBuild)) to sVersion
92214>>>>>                    End
92214>>>>>>
92214>>>>>                End
92214>>>>>>
92214>>>>>            End
92214>>>>>>
92214>>>>>        End
92214>>>>>>
92214>>>>>
92214>>>>>        // Display the compiled date as the next row in the edit object, after the program version.
92214>>>>>        Get GetCompileDate to dCompileDate
92215>>>>>        If (sVersion <> "") Begin
92217>>>>>            Send Add_Lineln (sVersion + (Character(13)) + C_$Compile_Date * String(dCompileDate))
92218>>>>>        End
92218>>>>>>
92218>>>>>    End_Procedure
92219>>>>>
92219>>>>>    Function GetCompileDate Returns Date
92221>>>>>        Date dCompileDate
92221>>>>>        String sAppFilename sData sCompileDate
92221>>>>>        Integer iChannel iPos iDateFormat
92221>>>>>
92221>>>>>        // Get full path to the current running executable
92221>>>>>        Get GetApplicationFileName of ghoApplication to sAppFilename
92222>>>>>
92222>>>>>        //Read the current file  up to where the data we're interesting in is (this was hand calced and so could vary)
92222>>>>>        Get Seq_Open_Input_Channel ("binary:" * sAppFilename) to iChannel
92223>>>>>        Read_Block channel iChannel sData (8 * 1024)    // First 8K is .exe header skip it
92225>>>>>        Read_Block channel iChannel sData 75            // The compile information we're interested in
92227>>>>>        Send Seq_Close_Channel iChannel
92228>>>>>
92228>>>>>        // The data is padded with Character(0)s. Strip them out
92228>>>>>        Move (CString(sData)) to sData
92229>>>>>
92229>>>>>        // The compile date is after the first ", ", so string parsing is required
92229>>>>>        Move (Pos(", ", sData)) to iPos
92230>>>>>        Move (Mid(sData, 10, (iPos + 2) ))  to sCompileDate // In US format
92231>>>>>        // If the current date format is non US, we need to temporary
92231>>>>>        // change the format and then move the string to the date variable.
92231>>>>>        Get_Attribute DF_DATE_FORMAT        to iDateFormat
92234>>>>>        Set_Attribute DF_DATE_FORMAT        to DF_DATE_USA
92237>>>>>        Move (Date(sCompileDate))           to dCompileDate
92238>>>>>        Set_Attribute DF_DATE_FORMAT        to iDateFormat // Reset date format
92241>>>>>
92241>>>>>        Function_Return dCompileDate
92242>>>>>    End_Function
