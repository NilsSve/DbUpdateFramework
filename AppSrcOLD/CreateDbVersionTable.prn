86549>>>            End
86549>>>>
86549>>>            Set_Attribute DF_FILE_OWNER         of hToTable to (Lowercase(sSchema))
86552>>>            // For unknown reason the above sometimes triggers an error and it doesn't help to try to trap the error; so we cheat...
86552>>>            Move False to Err
