87211>>>    // Removes the passed table name completely from disk, filelist (& Sql Server if an Sql-driver)
87211>>>    Function ApiTableRemove Handle hTable Returns Boolean
87213>>>        String sTableName sDriverID  
87213>>>        Boolean bOk     
87213>>>        String sDataPath
87213>>>        
87213>>>        Get AutoConnectionIDLogin to bOK
87214>>>        Move False to Err 
87215>>>        Get psDriverID to sDriverID
87216>>>        Get UtilTableHandleToString hTable sDriverID to sTableName
87217>>>        If (sTableName = "") Begin
87219>>>            Function_Return False
87220>>>        End                      
87220>>>>
87220>>>        
87220>>>        Send Ignore_Error of Error_Object_Id DFERR_CANT_DELETE_FILE
87221>>>        Delete_db sTableName 
