90580>>>    Function AddProgramToStudioToolsMenu String sStudioVersion Returns Integer
90583>>>        Boolean bOk bExists bOpen
90583>>>        String sKey sValue sProgramPath sProgram sProduct sStudioPath
90583>>>        Handle hoReg hoArray
90583>>>        Integer i iItems iCreated iRetval
90583>>>
90583>>>        Move False to bOk
90584>>>        Move (CS_StudioPath + (Trim(sStudioVersion)))  to sStudioPath
90585>>>        If (sStudioVersion > "17.1") Begin
90587>>>            Move (Replace("Visual ", sStudioPath, "")) to sStudioPath
90588>>>        End
90588>>>>
90588>>>
90588>>>        Get psProgramPath of (phoWorkspace(ghoApplication)) to sProgramPath
90589>>>        Get PathAtIndex of (phoWorkspace(ghoApplication)) sProgramPath 1 to sProgramPath
90590>>>        Get vFolderFormat sProgramPath to sProgramPath
90591>>>        Get psProduct     of (phoWorkspace(ghoApplication)) to sProduct
90592>>>        Get Module_Name to sProgram
90593>>>        Get Create U_cRegistry to hoReg
90594>>>        Set phRootKey of hoReg to HKEY_CURRENT_USER
90595>>>
90595>>>        // First check if the DataFlex version is installed
90595>>>        Get KeyExists of hoReg sStudioPath to bExists
90596>>>        If (bExists = False) Begin
90598>>>            Send Destroy of hoReg
90599>>>            Function_Return cx_RegKeyVDFKeyDoesNotExist
90600>>>        End
90600>>>>
90600>>>
90600>>>        // Then check if any tools have been installed in the Tools Menu.
90600>>>        // If no tools created yet, create the Tools registry key.
90600>>>        Move (sStudioPath + CS_StudioTools) to sStudioPath
90601>>>        Get KeyExists of hoReg sStudioPath to bExists
90602>>>        If (bExists = False) Begin
90604>>>            Set pfAccessRights of hoReg to KEY_ALL_ACCESS
90605>>>            Get CreateKey of hoReg sStudioPath to iCreated
90606>>>            If (iCreated <> 0) Begin
90608>>>                Move cx_RegkeyFailed to iRetval
90609>>>            End
90609>>>>
90609>>>            Else Begin
90610>>>                Move True to bExists
90611>>>            End
90611>>>>
90611>>>        End
90611>>>>
90611>>>
90611>>>        If (bExists = True) Begin
90613>>>            Get OpenKey of hoReg sStudioPath to bOk
90614>>>            If (bOk = True) Begin
90616>>>                Get Create U_Array to hoArray
90617>>>                Get GetSubkeys of hoReg hoArray to iItems
90618>>>                Decrement iItems
90619>>>                Move False to bExists
90620>>>                Set pfAccessRights of hoReg to KEY_READ
90621>>>                // Check if the key already exists:
90621>>>                For i from 0 to iItems
90627>>>>
90627>>>                    Get Value of hoArray item i to sKey
90628>>>                    Move (sStudioPath + "\" + sKey) to sKey
90629>>>                    Get OpenKey of hoReg sKey to bOpen
90630>>>                    If (bOpen = True) Begin
90632>>>                        Get ReadString of hoReg CS_Name to sValue
90633>>>                        If (sValue = sProduct) Move True to bExists
90636>>>                    End
90636>>>>
90636>>>                Loop
90637>>>>
90637>>>                Send Destroy of hoArray
90638>>>                If (bExists = False) Begin
90640>>>                    Set pfAccessRights of hoReg to KEY_ALL_ACCESS
90641>>>                    // We need to create the next key number:
90641>>>                    // The studio expect tools menu items to be numbered 1,2,3...n
90641>>>                    Increment iItems
90642>>>                    Increment iItems
90643>>>                    Get CreateKey of hoReg (sStudioPath + "\" + String(iItems)) to iCreated
90644>>>                    If (iCreated = 0) Begin
90646>>>                        Send WriteString of hoReg CS_Name sProduct
90647>>>                        // From DataFlex 16 and up the params for the Studio's Tools menu changed slightly:
90647>>>                        If (sStudioVersion >= "16.0") Begin
90649>>>                            Send WriteString of hoReg CS_Command (sProgramPath + sProgram)
90650>>>                            Send WriteString of hoReg CS_CommandLine (psTag(Self))
90651>>>                        End
90651>>>>
90651>>>                        Else Begin
90652>>>                            Send WriteString of hoReg CS_CommandLine ('"' + sProgramPath + sProgram + ".exe" + '"' * psTag(Self))
90653>>>                            Move CX_InstalledOkVdfUnder16 to iRetval
90654>>>                        End
90654>>>>
90654>>>                        Send WriteDword  of hoReg CS_Separator 1
90655>>>                        Move cx_RegKeyCreated to iRetval
90656>>>                    End
90656>>>>
90656>>>                    Else Begin
90657>>>                        Move cx_RegkeyFailed to iRetval
90658>>>                    End
90658>>>>
90658>>>                End
90658>>>>
90658>>>                Else Begin
90659>>>                    Move cx_RegKeyAlreadyExist to iRetval
90660>>>                End
90660>>>>
90660>>>                Send CloseKey of hoReg
90661>>>            End
90661>>>>
90661>>>        End
90661>>>>
90661>>>
90661>>>        Send Destroy of hoReg
90662>>>        Function_Return iRetval
90663>>>    End_Function
