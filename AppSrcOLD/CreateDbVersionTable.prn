82197>>>>>>>>>Class cDbUpdateORAFLEXDriver is a cDbUpdateGenericDatabaseDriver
82198>>>>>>>>>    Function DbLogin String sConnectionString String sServer String sDatabase Boolean bTrusted String sUserID String sPassword Returns Boolean
82200>>>>>>>>>        Boolean bLoginSuccessful
82200>>>>>>>>>        String sDriverID sErrorMsg
82200>>>>>>>>>        String sVal
82200>>>>>>>>>        Integer iPos
82200>>>>>>>>>
82200>>>>>>>>>        Get psDriverID to sDriverID
82201>>>>>>>>>        Move (Pos("/", sServer)) to iPos
82202>>>>>>>>>        If (iPos = 0) Begin
82204>>>>>>>>>            If (sDatabase <> "") Begin
82206>>>>>>>>>                Move (sServer + "/" + sDatabase) to sServer        
82207>>>>>>>>>            End
82207>>>>>>>>>>
82207>>>>>>>>>        End
82207>>>>>>>>>>
82207>>>>>>>>>        // For the Mertech driver, using the Err indicator is the sanctioned way
82207>>>>>>>>>        Move False to Err
82208>>>>>>>>>        // For Oracle I don't believe "Trusted" doesn't exist.
82208>>>>>>>>>        Login sServer sUserId sPassword sDriverID
82210>>>>>>>>>        
82210>>>>>>>>>        Move (not(Err)) to bLoginSuccessful
82211>>>>>>>>>        Function_Return bLoginSuccessful
82212>>>>>>>>>    End_Function
82213>>>>>>>>>End_Class
