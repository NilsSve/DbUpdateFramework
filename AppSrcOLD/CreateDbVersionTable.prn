82994>>>>>        tSQLConnection SQLConnection                                       
82994>>>>>        tSQLConnection SQLConnection                                       
82994>>>>>        Integer iIndex
82994>>>>>        
82994>>>>>        Get Private.pSQLConnection to SQLConnection
82995>>>>>        If (SQLConnection.sConnectionID = "") Begin
82997>>>>>            Move sValue to SQLConnection.sConnectionID
82998>>>>>        End
82998>>>>>>
82998>>>>>        
82998>>>>>        // Else we might want to change the current connection ID
82998>>>>>        Else If (SQLConnection.sConnectionID <> "" and SQLConnection.sConnectionID <> sValue) Begin   
83001>>>>>            Move False to Err
83002>>>>>            Logout SQLConnection.sDriverID  
83003>>>>>            // This will also make a login to the new server.
83003>>>>>            Get SQLIniFileConnectionID of (phoSQLConnectionIniFile(Self)) sValue to SQLConnection
83004>>>>>        End
83004>>>>>>
83004>>>>>        Set pSQLConnection to SQLConnection
83005>>>>>    End_Procedure
