90706>    Object oFileList_fm is a Form
90708>        Set Size to 13 246
90709>        Set Location to 89 27
90710>        Set Label to "Filelist.cfg:     (You can drop a Filelist.cfg here)"
90711>        Set Label_Col_Offset to 0
90712>        Set Label_Justification_Mode to JMode_Top
90713>        Set peAnchors to anTopLeftRight
90714>        Set Enabled_State to False
90715>        Set Label_Row_Offset to 1
90716>        Set FontWeight to fw_Bold
90717>       
90717>        Procedure Prompt
90720>            String sValue sPath sFilelistName sFileMask 
90720>            Get Value to sValue       
90721>            
90721>            Move (Trim(sValue)) to sValue
90722>            If (sValue <> "") Begin
90724>                Get ParseFolderName sValue to sPath
90725>            End
90725>
90725>            Move "Filelist.cfg files (*.cfg)|*.cfg" to sFileMask
90726>            Get vSelect_File sFileMask "Please select a Filelist.cfg file" sPath to sFilelistName
90727>            If (sFilelistName <> "") Begin
90729>                Set Value to sFilelistName
90730>            End
90730>        End_Procedure
90731>        
90731>        Procedure OnChange
90734>            String sFilelistName sPath sOpenPath sDataPath sDdSrcPath sDataFolder                                    
90734>            Handle hTable  
90734>            Boolean bOK
90734>            
90734>            Get psOpenPath of ghoApplication to sOpenPath 
90735>            Get psDataPath of (phoWorkspace(ghoApplication)) to sDataPath
90736>            If (sOpenPath contains sDataPath) Begin
90738>                Move (Replace((sDataPath + "\;"), sOpenPath, "")) to sOpenPath
90739>            End                                                      
90739>            
90739>            Get Value to sFilelistName  
90740>            // This might be true if there was no .ws file on startup.
90740>            If (sFilelistName = "") Begin
90742>                Send Prompt  
90743>                Procedure_Return
90744>            End                 
90744>            Get ParseFolderName sFilelistName to sPath 
90745>            If (Right(sPath, 1) ="\") Begin
90747>                Move (Left(sPath, Length(sPath) -1)) to sPath
90748>            End 
90748>            If (sPath = "") Begin
90750>                Procedure_Return
90751>            End
90751>            Set_Directory sPath
90752>
90752>            Set_Attribute DF_OPEN_PATH to (sPath + ";" + sOpenPath)
90755>            Set_Attribute DF_FILELIST_NAME to sFilelistName   
90758>            // Change output folder so files are written to the correct Data folder.
90758>            // For some reason the psDataPath isn't used by default by the Structure_End command.
90758>            
90758>            Set psDataPath of (phoWorkspace(ghoApplication))  to sPath  
90759>            Set psFileList of (phoWorkspace(ghoApplication))  to sFilelistName 
90760>            
90760>            // We also need to output the .fd file if in development environment.
90760>            Get psDdSrcPath of (phoWorkspace(ghoApplication)) to sDdSrcPath
90761>            If (sDdSrcPath = "") Begin        
90763>                Get ExtractFileName of (phoWorkspace(ghoApplication)) sPath to sDataFolder
90764>                Move (Replace(sDataFolder, sPath, "DdSrc")) to sDdSrcPath
90765>                Set psDdSrcPath of (phoWorkspace(ghoApplication)) to sDdSrcPath
90766>            End
90766>            Move 0 to hTable
90767>            Get_Attribute DF_FILE_NEXT_EMPTY of hTable to hTable
90770>            Set Value of oTableNo_sf to hTable
90771>        End_Procedure  
90772>        
