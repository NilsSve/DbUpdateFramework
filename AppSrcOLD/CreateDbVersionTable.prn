81900>>>>>    End_Procedure  
81901>>>>>    
81901>>>>>    // Custom array find function. It compares both the iSQLWord & iSQLDbType params.
81901>>>>>    Function CompareFindSQLKeyWords tSQLKeyWords SQLKeywords1 tSQLKeyWords SQLKeywords2 Returns Integer
81903>>>>>        If (SQLKeywords1.iSQLWord = SQLKeywords2.iSQLWord and SQLKeywords1.iSQLDbType = SQLKeywords2.iSQLDbType) Begin
81905>>>>>            Function_Return (EQ)
81906>>>>>        End
81906>>>>>>
81906>>>>>        Function_Return (NE)
81907>>>>>    End_Function
81908>>>>>    
81908>>>>>    // Custom array sort function. It compares both the iSQLWord & iSQLDbType params.
81908>>>>>    Function CompareSortSQLKeyWords tSQLKeyWords SQLKeywords1 tSQLKeyWords SQLKeywords2 Returns Integer
81910>>>>>        If (SQLKeywords1.iSQLWord   < SQLKeywords2.iSQLWord) Begin
81912>>>>>            Function_Return (LT)
81913>>>>>        End
81913>>>>>>
81913>>>>>        If (SQLKeywords1.iSQLWord   > SQLKeywords2.iSQLWord) Begin
81915>>>>>            Function_Return (GT)
81916>>>>>        End
81916>>>>>>
81916>>>>>        If (SQLKeywords1.iSQLDbType < SQLKeywords2.iSQLDbType) Begin
81918>>>>>            Function_Return (LT)
81919>>>>>        End
81919>>>>>>
81919>>>>>        If (SQLKeywords1.iSQLDbType > SQLKeywords2.iSQLDbType) Begin
81921>>>>>            Function_Return (GT)
81922>>>>>        End
81922>>>>>>
81922>>>>>
81922>>>>>        Function_Return (EQ)    
81923>>>>>    End_Function
81924>>>>>    
81924>>>>>    Procedure Add_Element Integer iSQLKeywordConstant Integer iEN_dbType String sSQLKeyword
81926>>>>>        tSQLKeyWords[] SQLKeywordArray 
81926>>>>>        tSQLKeyWords[] SQLKeywordArray 
81927>>>>>        Integer iSize
81927>>>>>        
81927>>>>>        Get paSQLKeywordArray to SQLKeywordArray 
81928>>>>>        Move (SizeOfArray(SQLKeywordArray)) to iSize
81929>>>>>        Move iSQLKeywordConstant to SQLKeywordArray[iSize].iSQLWord
81930>>>>>        Move iEN_dbType          to SQLKeywordArray[iSize].iSQLDbType
81931>>>>>        Move sSQLKeyword         to SQLKeywordArray[iSize].sSQLPhrase
81932>>>>>        
81932>>>>>        Set paSQLKeywordArray to SQLKeywordArray
81933>>>>>    End_Procedure  
81934>>>>>    
81934>>>>>    // Creates a struct array with all SQL keywords
81934>>>>>    // for all EN_xxx SQL back-ends. Various back-ends can
81934>>>>>    // have slightly different wording.
81934>>>>>    // If a new EN_dbTypexxx type is added; additions
81934>>>>>    // needs to be done for every keyword group below.
81934>>>>>    Procedure SetupSQLKeywordArray
81936>>>>>        tSQLKeyWords[] SQLKeywordArray SQLKeywordArraySorted
81936>>>>>        tSQLKeyWords[] SQLKeywordArray SQLKeywordArraySorted
81938>>>>>        
81938>>>>>        // This should only be called once; but in case it is
81938>>>>>        // we delete the array first.                        
81938>>>>>        Set paSQLKeywordArray to SQLKeywordArray 
81939>>>>>       
81939>>>>>        // ToDo: *** These SQL Key-words needs to be checked for other backends than MS-SQL! ***
81939>>>>>        //
81939>>>>>        Send Add_Element CI_SQLAlterTable EN_dbTypeMSSQL    "ALTER TABLE"
81940>>>>>        Send Add_Element CI_SQLAlterTable EN_dbTypeMySQL    "ALTER TABLE"
81941>>>>>        Send Add_Element CI_SQLAlterTable EN_dbTypeOracle   "ALTER TABLE"
81942>>>>>        Send Add_Element CI_SQLAlterTable EN_dbTypeDB2      "ALTER TABLE"
81943>>>>>        Send Add_Element CI_SQLAlterTable EN_dbTypePostgre  "ALTER TABLE"
81944>>>>>    
