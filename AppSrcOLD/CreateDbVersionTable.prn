82428>>>>>>>    // The normal connection string looks something like this;
82428>>>>>>>    // "SERVER=.\SQLEXPRESS; DATABASE=OrderEntry; TRUSTED_CONNECTION=Yes; ,0"
82428>>>>>>>    // ...but the full connection string looks like this;
82428>>>>>>>    // "DFConnectionId OrderEntry, SERVER=.\SQLEXPRESS; DATABASE=OrderEntry; TRUSTED_CONNECTION=Yes; ,0"
82428>>>>>>>//    Function SQLIniFileAddConnection String sFullConnectionString Returns Boolean
82428>>>>>>>//        String sSection
82428>>>>>>>//        Integer iCount
82428>>>>>>>//        
82428>>>>>>>//        Move False to Err
82428>>>>>>>//        Get psIniSectionName to sSection
82428>>>>>>>//        Get SQLIniFileNumberOfConnections to iCount
82428>>>>>>>//        Increment iCount
82428>>>>>>>//        Set IniFileValue sSection (CS_SQLIniSectionName + String(iCount)) to sFullConnectionString
82428>>>>>>>//        
82428>>>>>>>//        Function_Return (Err = False)
82428>>>>>>>//    End_Function
82428>>>>>>>    
82428>>>>>>>    Function SQLIniFileDeleteAllConnections Returns Boolean
82430>>>>>>>        Integer iCount 
82430>>>>>>>        Boolean bExists 
82430>>>>>>>        String sSection
82430>>>>>>>        
82430>>>>>>>        Move False to Err
82431>>>>>>>        Move 1 to iCount
82432>>>>>>>        Get psIniSectionName to sSection
82433>>>>>>>        Get SectionExists (CS_SQLIniSectionName + String(iCount)) to bExists
82434>>>>>>>        While (bExists = True)
82438>>>>>>>            Send DeleteSection (CS_SQLIniSectionName + String(iCount))
82439>>>>>>>            Increment iCount
82440>>>>>>>            Get SectionExists (CS_SQLIniSectionName + String(iCount)) to bExists
82441>>>>>>>        Loop
82442>>>>>>>>
82442>>>>>>>        Function_Return (Err = False)
82443>>>>>>>    End_Function
82444>>>>>>>    
82444>>>>>>>    Function SQLIniFileDeleteConnection Integer iItem Returns Boolean
82446>>>>>>>        Integer iCount 
82446>>>>>>>        String sSection 
82446>>>>>>>        Boolean bExists
82446>>>>>>>        
82446>>>>>>>        Move False to Err
82447>>>>>>>        Move 1 to iCount
82448>>>>>>>        Get psIniSectionName to sSection
82449>>>>>>>        Get KeyExists sSection CS_SQLIniConnectionIdKeyword to bExists
82450>>>>>>>        While (bExists = True)
82454>>>>>>>            If (iCount = iItem) Begin   
82456>>>>>>>                Send DeleteSection sSection
82457>>>>>>>//                Set IniFileValue sSection (CS_SQLIniSectionName + String(iCount)) to ""
82457>>>>>>>                Move 9999 to iCount // Just some ridiculously high number to get out of the loop as we're done.
82458>>>>>>>            End
82458>>>>>>>>
82458>>>>>>>            Increment iCount
82459>>>>>>>            Get KeyExists sSection (CS_SQLIniSectionName + String(iCount)) to bExists
82460>>>>>>>        Loop
82461>>>>>>>>
82461>>>>>>>        
82461>>>>>>>        Function_Return (Err = False)
82462>>>>>>>    End_Function
82463>>>>>>>    
82463>>>>>>>    // Returns all connection details for the passed Connection ID as a tSQLConnection
82463>>>>>>>    // If it fails the returned struct member SQLConnection.bError = True. 
82463>>>>>>>    Function SQLIniFileConnectionID String sConnectionID Returns tSQLConnection
82465>>>>>>>        tSQLConnection[] SQLConnectionsArray
82465>>>>>>>        tSQLConnection[] SQLConnectionsArray
82466>>>>>>>        tSQLConnection   SQLConnection
82466>>>>>>>        tSQLConnection   SQLConnection
82466>>>>>>>        Integer iIndex
82466>>>>>>>        
82466>>>>>>>        Get SQLIniFileConnectionIDIndex sConnectionID to iIndex
82467>>>>>>>        If (iIndex = -1) Begin
82469>>>>>>>            Move True to SQLConnection.bError
82470>>>>>>>            Function_Return SQLConnection
82471>>>>>>>        End
82471>>>>>>>>
82471>>>>>>>
82471>>>>>>>        Get SQLIniFileReadConnections to SQLConnectionsArray
82472>>>>>>>        Move SQLConnectionsArray[iIndex -1] to SQLConnection
82473>>>>>>>        
82473>>>>>>>        Function_Return SQLConnection    
82474>>>>>>>    End_Function
82475>>>>>>>            
82475>>>>>>>    // Returns -1 if the passed connection ID was not found, else the item number.
82475>>>>>>>    Function SQLIniFileConnectionIDIndex String sConnectionID Returns Integer
82477>>>>>>>        tSQLConnection[] SQLConnectionsArray
82477>>>>>>>        tSQLConnection[] SQLConnectionsArray
82478>>>>>>>        Integer iRetval iCount iSize
82478>>>>>>>        String sValue
82478>>>>>>>        Boolean bExists
82478>>>>>>>        
82478>>>>>>>        Move -1 to iRetval
82479>>>>>>>
82479>>>>>>>        Get SQLIniFileReadConnections to SQLConnectionsArray
82480>>>>>>>        Move (SizeOfArray(SQLConnectionsArray)) to iSize
82481>>>>>>>        Decrement iSize
82482>>>>>>>        For iCount from 0 to iSize
82488>>>>>>>>
82488>>>>>>>            Move SQLConnectionsArray[iCount].sConnectionID to sValue 
82489>>>>>>>            Move (Uppercase(sValue) = Uppercase(sConnectionID)) to bExists
82490>>>>>>>            If (bExists) Begin
82492>>>>>>>                Move (iCount + 1) to iRetval // The [ConnectionX] keys are one-based (starts at 1) but the loop starts at zero.
82493>>>>>>>                Move iSize to iCount         // We're done!
82494>>>>>>>            End
82494>>>>>>>>
82494>>>>>>>        Loop
82495>>>>>>>>
82495>>>>>>>                
82495>>>>>>>        Function_Return iRetval
82496>>>>>>>    End_Function       
82497>>>>>>>    
82497>>>>>>>    // Checks if the passed sConnectionID exists more than once in the passed struct array.
82497>>>>>>>    // Used to check that ConnectionID's are unique.
82497>>>>>>>    Function IsConnectionIDDuplicate String sConnectionID Returns Boolean
82499>>>>>>>        Integer iCount iSize iItems
82499>>>>>>>        String sValue
82499>>>>>>>        Boolean bExists                                   
82499>>>>>>>        tSQLConnection[] SQLConnectionsArray 
82499>>>>>>>        tSQLConnection[] SQLConnectionsArray 
82500>>>>>>>        
82500>>>>>>>        Move 0 to iItems                     
82501>>>>>>>        Get SQLIniFileReadConnections to SQLConnectionsArray
82502>>>>>>>        Move (SizeOfArray(SQLConnectionsArray)) to iSize
82503>>>>>>>        Decrement iSize
82504>>>>>>>        For iCount from 0 to iSize
82510>>>>>>>>
82510>>>>>>>            Move SQLConnectionsArray[iCount].sConnectionID to sValue 
82511>>>>>>>            Move (sValue = sConnectionID) to bExists
82512>>>>>>>            If (bExists) Begin
82514>>>>>>>                Increment iItems
82515>>>>>>>            End
82515>>>>>>>>
82515>>>>>>>        Loop
82516>>>>>>>>
82516>>>>>>>                
82516>>>>>>>        Function_Return (iItems > 1)
82517>>>>>>>    End_Function       
82518>>>>>>>    
82518>>>>>>>    // To update the SQLConnections.ini file with a new default Connection ID.
82518>>>>>>>    Function SQLIniFileSetDefaultConnection String sConnectionID Returns Boolean
82520>>>>>>>        Boolean bRetval bOK
82520>>>>>>>        Integer iItem iSize iCount
82520>>>>>>>        tSQLConnection[] SQLConnectionsArray
82520>>>>>>>        tSQLConnection[] SQLConnectionsArray
82521>>>>>>>        tSQLConnection SQLConnection
82521>>>>>>>        tSQLConnection SQLConnection
82521>>>>>>>        String sConnectionString
82521>>>>>>>        
82521>>>>>>>        Move False to Err     
82522>>>>>>>        Get psConnectionString to sConnectionString             
82523>>>>>>>        
82523>>>>>>>        Get SQLIniFileReadConnections to SQLConnectionsArray
82524>>>>>>>        Move (SizeOfArray(SQLConnectionsArray)) to iSize
82525>>>>>>>        Decrement iSize
82526>>>>>>>        // Set all current connection to inactive.
82526>>>>>>>        For iCount from 0 to iSize
82532>>>>>>>>
82532>>>>>>>            Move False to SQLConnectionsArray[iCount].bEnabled
82533>>>>>>>        Loop                                              
82534>>>>>>>>
82534>>>>>>>        
82534>>>>>>>        Get SQLIniFileConnectionID sConnectionID to SQLConnection
82535>>>>>>>        Move True              to SQLConnection.bEnabled
82536>>>>>>>        Move sConnectionString to SQLConnection.sConnectionString
82537>>>>>>>        Move (InsertInArray(SQLConnectionsArray, 0, SQLConnection)) to SQLConnectionsArray
82538>>>>>>>        Get SQLIniFileWriteConnections SQLConnectionsArray to bOK
82539>>>>>>>        
82539>>>>>>>        Function_Return (bOK = True)
82540>>>>>>>    End_Function
82541>>>>>>>    
82541>>>>>>>    // Used for updating an existing connection with new data.
82541>>>>>>>    // Returns True if successful.
82541>>>>>>>    Function SQLIniFileUpdateConnection tSQLConnection SQLConnection Returns Boolean
82543>>>>>>>        Boolean bRetval bOK
82543>>>>>>>        Integer iItem iSize iCount
82543>>>>>>>        tSQLConnection[] SQLConnectionsArray
82543>>>>>>>        tSQLConnection[] SQLConnectionsArray
82544>>>>>>>        
82544>>>>>>>        Move False to Err           
82545>>>>>>>        Move -1 to iItem  
82546>>>>>>>        Get SQLIniFileReadConnections to SQLConnectionsArray
82547>>>>>>>        Move (SizeOfArray(SQLConnectionsArray)) to iSize
82548>>>>>>>        Decrement iSize
82549>>>>>>>        // Set all current connection to inactive.
82549>>>>>>>        For iCount from 0 to iSize
82555>>>>>>>>
82555>>>>>>>            Move False to SQLConnectionsArray[iCount].bEnabled 
82556>>>>>>>            If (SQLConnectionsArray[iCount].sConnectionID = SQLConnection.sConnectionID) Begin
82558>>>>>>>                Move iCount to iItem
82559>>>>>>>            End
82559>>>>>>>>
82559>>>>>>>        Loop                                              
82560>>>>>>>>
82560>>>>>>>        
82560>>>>>>>        If (iItem <> -1) Begin
82562>>>>>>>            Move True to SQLConnection.bEnabled
82563>>>>>>>            Move SQLConnection to SQLConnectionsArray[iItem]
82564>>>>>>>            Get SQLIniFileWriteConnections SQLConnectionsArray to bOK
82565>>>>>>>        End
82565>>>>>>>>
82565>>>>>>>        
82565>>>>>>>        Function_Return (bOK = True)
82566>>>>>>>    End_Function
82567>>>>>>>    
82567>>>>>>>    Function SQLIniFileReadConnections Returns tSQLConnection[]
82569>>>>>>>        tSQLConnection[] SQLConnectionsArray
82569>>>>>>>        tSQLConnection[] SQLConnectionsArray
82570>>>>>>>        String sSection sValue
82570>>>>>>>        Integer iCount
82570>>>>>>>        Boolean bExists bEnabled
82570>>>>>>>        
82570>>>>>>>        Get psIniSectionName to sSection
82571>>>>>>>        Get SectionExists sSection to bExists
82572>>>>>>>        If (bExists = False) Begin   
82574>>>>>>>            Function_Return SQLConnectionsArray
82575>>>>>>>        End                                  
82575>>>>>>>>
82575>>>>>>>        Get SectionExists CS_SQLIniConnectionSection to bExists
82576>>>>>>>        If (bExists = True) Begin
82578>>>>>>>            Error DFERR_PROGRAM "Sorry, the format for the SQLConnections.ini file has been changed and this file has the old format that is no longer valid and thus cannot be read. You need to re-enter your connection(s)."
82579>>>>>>>>
82579>>>>>>>        End
82579>>>>>>>>
82579>>>>>>>                
82579>>>>>>>        Move 1 to iCount // The section name "[ConnectionXX]" starts with "1"
82580>>>>>>>        Get SectionExists (CS_SQLIniSectionName + String(iCount)) to bExists 
82581>>>>>>>        
82581>>>>>>>        While (bExists = True)
82585>>>>>>>            // We always put the enabled/active connection at the top
82585>>>>>>>            Move (iCount = 1) to bEnabled
82586>>>>>>>            Move bEnabled to SQLConnectionsArray[iCount].bEnabled
82587>>>>>>>            
82587>>>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniConnectionIdKeyword ""        to SQLConnectionsArray[iCount].sConnectionID
82588>>>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniDriverKeyword       ""        to SQLConnectionsArray[iCount].sDriverID
82589>>>>>>>
82589>>>>>>>            // The iDbType might be missing from the ini-file. This is e.g. the case when a DAW Managed Connection "DFConnId.ini" file is read.
82589>>>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniDbTypeKeyword       "99"      to sValue
82590>>>>>>>            If (sValue = "99") Begin
82592>>>>>>>                Get SqlUtilDbTypeFromDriver SQLConnectionsArray[iCount].sDriverID to sValue
82593>>>>>>>            End
82593>>>>>>>>
82593>>>>>>>            Move sValue                                                                                     to SQLConnectionsArray[iCount].iDbType
82594>>>>>>>
82594>>>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniConnectionKeyWord   ""        to SQLConnectionsArray[iCount].sConnectionString
82595>>>>>>>            Get ParseKeyWord SQLConnectionsArray[iCount].sConnectionString (CS_SQLIniServerKeyword + "=")   to SQLConnectionsArray[iCount].sServer
82596>>>>>>>            If (SQLConnectionsArray[iCount].sServer = "") Begin
82598>>>>>>>                Get ParseKeyWord SQLConnectionsArray[iCount].sConnectionString (CS_SQLIniDSNKeyword +"=")   to SQLConnectionsArray[iCount].sServer
82599>>>>>>>            End
82599>>>>>>>>
82599>>>>>>>            Get ParseKeyWord SQLConnectionsArray[iCount].sConnectionString (CS_SQLIniDatabaseKeyword + "=") to SQLConnectionsArray[iCount].sDatabase
82600>>>>>>>
82600>>>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniTrustedKeyword      ""        to sValue
82601>>>>>>>            Move (If(Uppercase(sValue) = "YES", True, False))                                               to SQLConnectionsArray[iCount].bTrusted
82602>>>>>>>
82602>>>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniUIDKeyword          ""        to SQLConnectionsArray[iCount].sUserID
82603>>>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniDFPWDKeyword        ""        to sValue
82604>>>>>>>            If (pbDFConnId(Self) = False and sValue <> "") Begin
82606>>>>>>>                Get DecryptPassword sValue to sValue    
82607>>>>>>>            End
82607>>>>>>>>
82607>>>>>>>            Move sValue                                                                                     to SQLConnectionsArray[iCount].sPassword
82608>>>>>>>            
82608>>>>>>>            // Here we reconstruct the connection string to be complete with all params;
82608>>>>>>>            Get ConstructConnectionString SQLConnectionsArray[iCount].sDriverID SQLConnectionsArray[iCount].sServer SQLConnectionsArray[iCount].sDatabase ;                                          SQLConnectionsArray[iCount].bTrusted SQLConnectionsArray[iCount].sUserID SQLConnectionsArray[iCount].sPassword ;                                          to SQLConnectionsArray[iCount].sConnectionString    
82609>>>>>>>            
82609>>>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniSchemaKeyword          ""     to SQLConnectionsArray[iCount].sSchema
82610>>>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniBaseTableSpaceKeyword  ""     to SQLConnectionsArray[iCount].sBaseTableSpace
82611>>>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniLongTableSpaceKeyword  ""     to SQLConnectionsArray[iCount].sLongTableSpace
82612>>>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniIndexTableSpaceKeyword ""     to SQLConnectionsArray[iCount].sIndexTableSpace
82613>>>>>>>            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniSilentLoginKeyword     ""     to SQLConnectionsArray[iCount].bSilentLogin  
82614>>>>>>>//            Get IniFileValue (CS_SQLIniSectionName + String(iCount)) CS_SQLIniDisabledKeyword        ""     to SQLConnectionsArray[iCount].bDisabled
82614>>>>>>>
82614>>>>>>>            Increment iCount
82615>>>>>>>            Get SectionExists (CS_SQLIniSectionName + String(iCount)) to bExists
82616>>>>>>>        Loop
82617>>>>>>>>
82617>>>>>>>        
82617>>>>>>>        // Lastly, we remove the very first array item as it is empty (we started at 1 because that is the first [Connection#])
82617>>>>>>>        If (SizeOfArray(SQLConnectionsArray) > 0) Begin
82619>>>>>>>            Move (RemoveFromArray(SQLConnectionsArray, 0)) to SQLConnectionsArray
82620>>>>>>>        End
82620>>>>>>>>
82620>>>>>>>        
82620>>>>>>>        Function_Return SQLConnectionsArray
82621>>>>>>>    End_Function 
82622>>>>>>>        
82622>>>>>>>    Function SQLIniFileWriteConnections tSQLConnection[] SQLConnectionsArray Returns Boolean
82624>>>>>>>        Integer iCount iSize iItem
82624>>>>>>>        Boolean bIsOneActive bEnabled bExists bOK
82624>>>>>>>        String sConnectionString sSection sValue
82624>>>>>>>        
82624>>>>>>>        // First we need to _remove_ all current connections in the ini-file, we
82624>>>>>>>        // do that by setting their values to "".
82624>>>>>>>        Move 0 to iCount  
82625>>>>>>>        Get SQLIniFileDeleteAllConnections to bOK
82626>>>>>>>        If (bOK = False) Begin
82628>>>>>>>            Function_Return False
82629>>>>>>>        End                 
82629>>>>>>>>
82629>>>>>>>        
82629>>>>>>>        Move False to Err
82630>>>>>>>        Get psIniSectionName to sSection                                                          
82631>>>>>>>        // Sorting will make sure we have the active connection record as the first connection item in the ini-file.
82631>>>>>>>        Move (SortArray(SQLConnectionsArray, Self, (RefFunc(SortActiveFirst)))) to SQLConnectionsArray
82632>>>>>>>        Move (SizeOfArray(SQLConnectionsArray)) to iSize
82633>>>>>>>        Decrement iSize       
82634>>>>>>>        
82634>>>>>>>        For iCount from 0 to iSize
82640>>>>>>>>
82640>>>>>>>            // DF 19 compatible settings:
82640>>>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniConnectionIdKeyword   to SQLConnectionsArray[iCount].sConnectionID
82641>>>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniDriverKeyword         to SQLConnectionsArray[iCount].sDriverID
82642>>>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniUIDKeyword            to SQLConnectionsArray[iCount].sUserID
82643>>>>>>>            
82643>>>>>>>            Move SQLConnectionsArray[iCount].sPassword to sValue
82644>>>>>>>            If (pbDFConnId(Self) = False and sValue <> "") Begin
82646>>>>>>>                Get EncryptPassword sValue to sValue    
82647>>>>>>>            End
82647>>>>>>>>
82647>>>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniDFPWDKeyword          to sValue
82648>>>>>>>
82648>>>>>>>            If (SQLConnectionsArray[iCount].bTrusted = True) Begin
82650>>>>>>>                Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniTrustedKeyword    to CS_SQLIniConnectionYes
82651>>>>>>>            End                                                                
82651>>>>>>>>
82651>>>>>>>            
82651>>>>>>>            Get ConstructShortConnectionString SQLConnectionsArray[iCount].sDriverID SQLConnectionsArray[iCount].sServer SQLConnectionsArray[iCount].sDatabase ;                                            to SQLConnectionsArray[iCount].sConnectionString
82652>>>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniConnectionKeyWord     to SQLConnectionsArray[iCount].sConnectionString
82653>>>>>>>            
82653>>>>>>>            // The Database Update Framework extended settings:
82653>>>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniDbTypeKeyword          to SQLConnectionsArray[iCount].iDbType
82654>>>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniSchemaKeyword          to SQLConnectionsArray[iCount].sSchema
82655>>>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniBaseTableSpaceKeyword  to SQLConnectionsArray[iCount].sBaseTableSpace
82656>>>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniLongTableSpaceKeyword  to SQLConnectionsArray[iCount].sLongTableSpace
82657>>>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniIndexTableSpaceKeyword to SQLConnectionsArray[iCount].sIndexTableSpace
82658>>>>>>>            Set IniFileValue (CS_SQLIniSectionName + String(iCount + 1)) CS_SQLIniSilentLoginKeyword     to SQLConnectionsArray[iCount].bSilentLogin
82659>>>>>>>        Loop                 
82660>>>>>>>>
82660>>>>>>>        
82660>>>>>>>        Function_Return (bOK and Err = False)
82661>>>>>>>    End_Function
82662>>>>>>>
82662>>>>>>>    // *** DbType conversion routines - Converts between string/integer and driver ID values ***
82662>>>>>>>    //
82662>>>>>>>    // SQL utility function that returns a database type (string) constant
82662>>>>>>>    // corresponding to the passed iDbType.
82662>>>>>>>    Function SqlUtilDbTypeToString Integer iDbType Returns String
82664>>>>>>>        String sRetval
82664>>>>>>>        If (iDbType = EN_dbTypeMSSQL)       Move CS_dbTypeMSSQL     to sRetval
82667>>>>>>>        If (iDbType = EN_dbTypeMySQL)       Move CS_dbTypeMySQL     to sRetval
82670>>>>>>>        If (iDbType = EN_dbTypeOracle)      Move CS_dbTypeOracle    to sRetval
82673>>>>>>>        If (iDbType = EN_dbTypeDB2)         Move CS_dbTypeDB2       to sRetval
82676>>>>>>>        If (iDbType = EN_dbTypePostgre)     Move CS_dbTypePostgre   to sRetval
82679>>>>>>>        Function_Return sRetval
82680>>>>>>>    End_Function
