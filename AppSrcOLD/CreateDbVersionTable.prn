85621>>>    Function SqlUtilUpdateIntFile Integer hTable Returns Boolean           
85623>>>        String sOrgFormat sNewFormat sRootName sDatabaseName sPhysicalFileName sDriverID sDataPath         
85623>>>        Boolean bOpened bOK bMertech
85623>>>        
85623>>>        Move CS_OEM_Txt  to sOrgFormat
85624>>>        Move CS_ANSI_Txt to sNewFormat
85625>>>        Get AutoConnectionIDLogin to bOK
85626>>>        Send Ignore_Error of Error_Object_Id DFERR_MISSING_VALUE
85627>>>        Open hTable //Mode DF_EXCLUSIVE
85629>>>        Send Trap_Error of Error_Object_Id DFERR_MISSING_VALUE
85630>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpened
85633>>>        
85633>>>        // ToDo: What to do if we cannot open the table?!
85633>>>        If (bOpened = False) Begin
85635>>>            Function_Return False
85636>>>        End
85636>>>>
85636>>>        
85636>>>        Get psDriverID to sDriverID
85637>>>        Get IsMertechDriver sDriverID to bMertech
85638>>>        If (bMertech = True) Begin       
85640>>>            Get psDataPathFirstPart to sDataPath
85641>>>            Get vFolderExists sDataPath to bOK
85642>>>            If (bOK = False) Begin
85644>>>                Error DFERR_PROGRAM "Function SqlUtilUpdateIntFile; psDataPath not found!"
85645>>>>
85645>>>                Function_Return False    
85646>>>            End                      
85646>>>>
85646>>>            Get vFolderFormat sDataPath to sDataPath 
85647>>>            Get_Attribute DF_FILE_ROOT_NAME of hTable to sRootName
85650>>>            Get _TableNameOnly sRootName to sDatabaseName
85651>>>            Move sDatabaseName to sPhysicalFileName
85652>>>            Move (sPhysicalFileName + ".int") to sPhysicalFileName
85653>>>            Get _MertechSqlUtilCreateIntFile hTable sDataPath sPhysicalFileName to bOK
85654>>>            Function_Return (bOK = True)
85655>>>        End
85655>>>>
85655>>>        
85655>>>        Move False to Err
85656>>>        Get_Attribute DF_FILE_TABLE_CHARACTER_FORMAT of hTable to sOrgFormat
85659>>>        Move (Uppercase(sOrgFormat)) to sOrgFormat       
85660>>>        // Lets swap the OEM/ANSI format, just to make a change in Structure_Start below (and back),
85660>>>        // to "touch" the table so the driver feels there has been a change and updates the .int file.
85660>>>        Move (If(sOrgFormat = CS_OEM_Txt, CS_ANSI_Txt, CS_OEM_Txt)) to sNewFormat
85661>>>        
85661>>>        Structure_Start hTable
85662>>>            Set_Attribute DF_FILE_TABLE_CHARACTER_FORMAT of hTable to sNewFormat
85665>>>            Set_Attribute DF_FILE_TABLE_CHARACTER_FORMAT of hTable to sOrgFormat
85668>>>        Structure_End hTable (DF_STRUCTEND_OPT_IN_PLACE ior DF_STRUCTEND_OPT_FORCE)
85670>>>        
85670>>>        Function_Return (Err = False)
85671>>>    End_Function 
85672>>>    
85672>>>    // Checks if the passed Table;
85672>>>    // 1) Already has a Filelist entry that points to SQL and
85672>>>    // 2) It has an .int file. 
85672>>>    // If both is True it should already be connected to SQL
85672>>>    Function SQLUtilTableIsAttached String sDriverID Handle hTable Returns Boolean
85674>>>        Boolean bExists bRootName
85674>>>        String sRootName sDataPath
85674>>>        Integer iCount
85674>>>        
85674>>>        Get_Attribute DF_FILE_ROOT_NAME of hTable to sRootName
85677>>>        Move (sRootName contains sDriverID) to bRootName
85678>>>        
85678>>>        Get psDataPathFirstPart to sDataPath
85679>>>        Get vFolderExists sDataPath to bExists
85680>>>        If (bExists = False) Begin
85682>>>            // If the path doesn't exist it cannot have an .int file and we're done, although it shouldn't happen.
85682>>>            Function_Return False
85683>>>        End                      
85683>>>>
85683>>>        
85683>>>        Get vFolderFormat sDataPath to sDataPath         
85684>>>        Get _TableNameOnly sRootName to sRootName
85685>>>        Get vFilePathExists (sDataPath + sRootName + ".int") to bExists
85686>>>
85686>>>        Function_Return (bRootName = True and bExists = True)
85687>>>    End_Function       
85688>>>    
85688>>>    Function SQLUtilTableIsViewType String sDriverID Handle hTable Returns Boolean
85690>>>        Boolean bViewTableType bOpen bMertechDriver bOK
85690>>>        Integer hoSQLHandler
85690>>>        Integer iTableCount iNumTables iPos iTableIndex
85690>>>        String sTableName sOwner sTableType sLogin sEnumTableName sEnumSchemaName sCurrent_Login
85690>>>        Handle hoCliHandler  
85690>>>        tSQLConnection SQLConnection
85690>>>        tSQLConnection SQLConnection
85690>>>        
85690>>>        Get_Attribute DF_FILE_OPENED of hTable to bOpen
85693>>>        If (bOpen = False) Begin  
85695>>>            Get AutoConnectionIDLogin to bOK
85696>>>            Open hTable
85698>>>        End
85698>>>>
85698>>>        
85698>>>        Get pSQLConnection to SQLConnection   
85699>>>        Get phoCLIHandler to hoCliHandler
85700>>>        Set psDriverID of hoCliHandler to sDriverID
85701>>>        
85701>>>        Get_Attribute DF_FILE_ROOT_NAME of hTable to sTableName 
85704>>>        Get _TableNameOnly sTableName to sTableName             
85705>>>        Get_Attribute DF_FILE_OWNER     of hTable to sOwner
85708>>>        Get EnumerateTables of hoCliHandler SQLConnection.sConnectionString to iNumTables
85709>>>        
85709>>>        For iTableCount from 1 to iNumTables
85715>>>>
85715>>>            Get TableName  of hoCliHandler iTableCount to sEnumTableName
85716>>>            Get SchemaName of hoCliHandler iTableCount to sEnumSchemaName
85717>>>            If ((Uppercase(sEnumTableName)  = Uppercase(sTableName)) and (Uppercase(sEnumSchemaName) = Uppercase(sOwner))) Begin
85719>>>                Get TableType of hoCliHandler iTableCount to sTableType
85720>>>                Move iNumTables to iTableCount // We're done.
85721>>>            End
85721>>>>
85721>>>        Loop
85722>>>>
85722>>>        
85722>>>        Move (sTableType = "VIEW") to bViewTableType
85723>>>        If (bOpen = False) Begin
85725>>>            Close hTable
85726>>>        End
85726>>>>
85726>>>        
85726>>>        Function_Return bViewTableType
85727>>>    End_Function
85728>>>    
85728>>>    // *** DbType conversion routines - Converts between string/integer and driver ID values ***
85728>>>    //
85728>>>    // SQL utility function that returns a database type (string) constant
85728>>>    // corresponding to the passed iDbType.
85728>>>    Function SqlUtilDbTypeToString Integer iDbType Returns String
85730>>>        String sRetval
85730>>>        Get SqlUtilDbTypeToString of (phoSQLConnectionIniFile(ghoSQLConnectionHandler)) iDbType to sRetval
85731>>>        Function_Return sRetval
85732>>>    End_Function    
85733>>>    
85733>>>    // SQL utility function that returns a database type constant (integer)
85733>>>    // corresponding to the passed sDbType string constant.
85733>>>    Function SqlUtilDbTypeToInteger String sDbType Returns Integer
85735>>>        Integer iRetval            
85735>>>        Get SqlUtilDbTypeToInteger of (phoSQLConnectionIniFile(ghoSQLConnectionHandler)) sDbType to iRetval
85736>>>        Function_Return iRetval
85737>>>    End_Function    
85738>>>    
85738>>>    // Pass an integer DbType and function returns the database type integer as a string value.
85738>>>    // Used e.g. when reading a connection ini-file to display the database type in
85738>>>    // the SQL Connection program's grid.
85738>>>    Function SqlUtilDbTypeIntegerToStringConstant Integer iDbType Returns String
85740>>>        String sRetval   
85740>>>        Get SqlUtilDbTypeIntegerToStringConstant of (phoSQLConnectionIniFile(ghoSQLConnectionHandler)) iDbType to sRetval
85741>>>        Function_Return sRetval
85742>>>    End_Function    
85743>>>
85743>>>    // Pass a driver name as a string and the function will return
85743>>>    // a dbType as an integer. Obviously for the ODBC_DRV this doesn't
85743>>>    // quite work and always returns "MS SQL Server"
85743>>>    Function SqlUtilDbTypeFromDriver String sDriverID Returns Integer     
85745>>>        Integer iRetval
85745>>>        Get SqlUtilDbTypeFromDriver of (phoSQLConnectionIniFile(ghoSQLConnectionHandler)) sDriverID to iRetval
85746>>>        Function_Return iRetval
85747>>>    End_Function    
85748>>>    
85748>>>    // *** Helper Functions ***
85748>>>    // They all start with an underscore: "_" in the function name.
85748>>>    //
85748>>>    // Reads a SQL script file that has been compiled into the .exe program as a resource.
85748>>>    // Pass: The memory resource reference and a boolean True if you want to create the file on disk (in the Home folder).
85748>>>    // Returns: A tSQLScriptArray Struct with the Sql script as an uChar Array will be returned along with the a bError boolean.
85748>>>    Function SqlUtilReadResource String sMemFileName Returns tSQLScriptArray
85750>>>        Integer iChannel iArgumentSize iOut iChunk iPointer iCount iSize
85750>>>        Number nByteCount
85750>>>        String sCharacter sSQLScript 
85750>>>        Boolean bSeqEof
85750>>>        tSQLScriptArray SqlScriptArray
85750>>>        tSQLScriptArray SqlScriptArray
85750>>>        UChar[] uCharData
85751>>>        
85751>>>        Move False to Err
85752>>>        Get Seq_New_Channel to iChannel
85753>>>        If (iChannel = DF_SEQ_CHANNEL_NOT_AVAILABLE) Begin
85755>>>            Error DFERR_PROGRAM 'No channel available...'
85756>>>>
85756>>>            Move True to SqlScriptArray.bError
85757>>>            Function_Return SqlScriptArray
85758>>>        End                    
85758>>>>
85758>>>        
85758>>>        // First decide the size of the script
85758>>>        Direct_Input channel iChannel ("Resource: " + sMemFileName)
85760>>>        Read_Block channel iChannel uCharData -1 // -1 means that all data should be read.
85762>>>        Close_Input channel iChannel
85764>>>
85764>>>        Move (SizeOfArray(uCharData)) to nByteCount 
85765>>>        If (nByteCount  < 1) Begin
85767>>>            Send Seq_Release_Channel iChannel  
85768>>>            Move True to SqlScriptArray.bError
85769>>>            Function_Return SqlScriptArray
85770>>>        End
85770>>>>
85770>>>        
85770>>>        // If necessary change the string argument_size
85770>>>        Get_Argument_Size to iArgumentSize
85771>>>        If (nByteCount >= iArgumentSize) Begin
85773>>>            Move (nByteCount + 2048) to nByteCount
85774>>>            Set_Argument_Size nByteCount // Set new argument size just a bit higher than "needed" for overhead margin.
85775>>>>
85775>>>            Move True          to SqlScriptArray.bArgumentSizeChanged
85776>>>            Move iArgumentSize to SqlScriptArray.iOrgArgumentSize
85777>>>        End                         
85777>>>>
85777>>>        Else Begin
85778>>>            Move False to SqlScriptArray.bArgumentSizeChanged
85779>>>        End
85779>>>>
85779>>>        
85779>>>        // Read the script file from memory line-by-line
85779>>>        Direct_Input channel iChannel ("Resource: " + sMemFileName) 
85781>>>            Move 0 to iCount
85782>>>            Repeat
85782>>>>
85782>>>                Readln channel iChannel sSQLScript
85784>>>                Move sSQLScript to SqlScriptArray.sSQLScriptArray[iCount]
85785>>>                Increment iCount
85786>>>            Until (SeqEof = True)
85788>>>        Close_Input channel iChannel
85790>>>        Send Seq_Release_Channel iChannel 
85791>>>        
85791>>>        // Finally "sanitize" the script by removing all comments.
85791>>>        Get _SqlUtilSanitizeScript SqlScriptArray to SqlScriptArray  
85792>>>
85792>>>        Function_Return SqlScriptArray
85793>>>    End_Function 
85794>>>    
85794>>>    Function SqlUtilExecuteEmbeddedScript tSQLScriptArray SQLScriptArray String sDriverID Boolean bCreateScriptFile String sMemFileName Boolean bShowProgr Returns Boolean
85796>>>        String sSQLVal sStmt sCR sDebugFileName sTmp sGOKeyWord sNoCountKeyWord sMessage sExportFile
85796>>>        Handle hoSql hoSQLConnect hoStmt hoError
85796>>>        Integer i iMsgs iFetchResult iResultCount iRows iRowType iCount iChunkCounter iChunkMax iPos iOut iNextSet iMessage
85796>>>        String[] sMsg aSQLQueryMessages
85798>>>        DateTime dtQueryExecStart dtQueryExecEnd
85798>>>        TimeSpan tsQuery
85798>>>        tSqlErrorArray aSqlErrorArray  
85798>>>        tSqlErrorArray aSqlErrorArray  
85798>>>        tSQLConnection SQLConnection
85798>>>        tSQLConnection SQLConnection
85798>>>        Boolean bOK bMertechDriver bShowProgress
85798>>>        
85798>>>        If (num_arguments > 4) Begin
85800>>>            Move bShowProgr to bShowProgress
85801>>>        End
85801>>>>
85801>>>        Get IsMertechDriver sDriverID to bMertechDriver
85802>>>        If (bMertechDriver = False) Begin
85804>>>            Get phoSQLManager to hoSql
85805>>>        End 
85805>>>>
85805>>>        Else Begin
85806>>>            Get _MertechSQLManagerHandle to hoSql
85807>>>        End
85807>>>>
85807>>>            
85807>>>        Get _SqlFindKeyWord CI_SQLGO to sGOKeyWord
85808>>>        // There seems to be a problem to pass strings when their value gets really big, aka
85808>>>        // above the argument_size level. It isn't clear when these problems starts but sooner
85808>>>        // or later SqlExecDirect stops working correctly with no error messages!
85808>>>        // To guard from this we set a max number of lines (iChunkMax) that can be processed
85808>>>        // at a time. Testing with the Create Chinook Database script; 500 seems like a number that works fine. 
85808>>>        // A bonus of this is that it turns out that it is actually faster to run in chunks!
85808>>>        Get piChunkMax to iChunkMax    
85809>>>        Move 0 to iChunkCounter                                 
85810>>>        Move "" to sStmt   
85811>>>
85811>>>        Get _SqlFindKeyWord CI_SQLSetNoCountOn to sNoCountKeyWord
85812>>>        Move (Character(13) + Character(10)) to sCR
85813>>>
85813>>>        Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
85814>>>        
85814>>>        If (bMertechDriver = True) Begin
85816>>>            Get _MertechSQLConnect sDriverID SQLConnection.sServer SQLConnection.sUserID SQLConnection.sPassword to hoSQLConnect
85817>>>        End
85817>>>>
85817>>>        If (bMertechDriver = False) Begin
85819>>>            Get phoSQLManager  to hoSQL
85820>>>            Send SqlSetConnect of hoSQL sDriverID SQLConnection.sConnectionString
85821>>>            Get SqlConnect     of hoSQL "" "" to hoSQLConnect
85822>>>        End
85822>>>>
85822>>>
85822>>>        If (hoSQLConnect <> 0) Begin 
85824>>>            Move False to Err
85825>>>            Get SqlOpen of hoSQLConnect to hoStmt
85826>>>            If (hoStmt <> 0) Begin
85828>>>
85828>>>                // If the embedded resource should be written as a script file to disk:
85828>>>                If (bCreateScriptFile = True) Begin
85830>>>                    Get psHome of (phoWorkspace(ghoApplication)) to sExportFile
85831>>>                    Get vFolderFormat sExportFile to sExportFile
85832>>>                    Move (sExportFile + sMemFileName) to sExportFile
85833>>>                    Get Seq_New_Channel to iOut 
85834>>>                    If (iOut <> DF_SEQ_CHANNEL_NOT_AVAILABLE) Begin
85836>>>                        Direct_Output channel iOut sExportFile  
85838>>>                    End
85838>>>>
85838>>>                End
85838>>>>
85838>>>        
85838>>>                // Record starting date/time stamp
85838>>>                Move (CurrentDateTime()) to dtQueryExecStart
85839>>>                // Turn on error handling if enabled
85839>>>                If (pbHandleQueryErrors(Self)) Begin
85841>>>                    Set pbSqlError to False  
85842>>>                    Set paSqlErrorArray to aSqlErrorArray
85843>>>                    Move Error_Object_Id to hoError
85844>>>                    Move Self to Error_Object_Id
85845>>>                End                                                    
85845>>>>
85845>>>                
85845>>>                Move (SizeOfArray(SQLScriptArray.sSQLScriptArray)) to iRows  
85846>>>                Decrement iRows
85847>>>                Move (sNoCountKeyWord + sCR) to sStmt
85848>>>
85848>>>                For iCount from 0 to iRows   
85854>>>>
85854>>>                    Move (SQLScriptArray.sSQLScriptArray[iCount]) to sSQLVal
85855>>>                    
85855>>>                    If (Uppercase(sSQLVal) <> sGOKeyWord) Begin
85857>>>                        If (sSQLVal <> "") Begin
85859>>>                            Move (sSQLVal + sCR) to sSQLVal
85860>>>                        End
85860>>>>
85860>>>                        Move (Append(sStmt, (sSQLVal))) to sStmt
85861>>>                    End
85861>>>>
85861>>>                    
85861>>>                    // - Each time we encounter a "GO" statement we execute it,
85861>>>                    // or if at the very end of the script.
85861>>>                    If (Uppercase(sSQLVal) = sGOKeyWord or iChunkCounter >= iChunkMax or iCount = iRows) Begin 
85863>>>                        
85863>>>                        // - It turns out it can be at least 10 times faster to execute SQL statements in chunks,
85863>>>                        // instead of all in one go. 
85863>>>                        Send SqlExecDirect of hoStmt sStmt 
85864>>>                        
85864>>>                        If (bCreateScriptFile = True) Begin
85866>>>                            Write channel iOut sStmt
85868>>>                        End
85868>>>>
85868>>>                        Move "" to sStmt   
85869>>>                        Move 0 to iChunkCounter
85870>>>                    End
85870>>>>
85870>>>                    Increment iChunkCounter
85871>>>                Loop
85872>>>>
85872>>>                       
85872>>>                Repeat
85872>>>>
85872>>>                    If (pbHandleQueryErrors(Self)) Begin
85874>>>                        Move hoError to Error_Object_Id
85875>>>                    End
85875>>>>
85875>>>                    Move (CurrentDateTime()) to dtQueryExecEnd  
85876>>>                    
85876>>>                    Send _SqlColumnInfo hoStmt
85877>>>                    Get SqlStmtAttribute of hoStmt SqlSTMTATTRIB_ROWCOUNT to iRows
85878>>>                    Get SqlStmtAttribute of hoStmt SqlSTMTATTRIB_ROWCOUNT_TYPE to iRowType
85879>>>                    Get SqlStmtAttribute of hoStmt SqlSTMTATTRIB_NUMMESSAGES to iMsgs
85880>>>                    Set piRows    to iRows
85881>>>                    Set piRowType to iRowType
85882>>>                   
85882>>>                    If (iMsgs <> 0) Begin
85884>>>                        If (ghoDbUpdateHandler > 0) Begin
85886>>>                            Get paSQLQueryMessages of ghoDbUpdateHandler to aSQLQueryMessages
85887>>>                        End
85887>>>>
85887>>>                        For i from 1 to iMsgs
85893>>>>
85893>>>                            Get SqlGetMessage of hoStmt i to sMessage     
85894>>>                            Get RemoveComponentIdentifier of hoStmt sMessage to sMessage   
85895>>>                            If (bShowProgress = True) Begin
85897>>>                                If (Active_State(ghoStatusPanel)) Begin
85899>>>                                    Send Update_StatusPanel of ghoStatusPanel (Sformat("  SQLGetMessage iMessage %1 returned [%2]", iMessage, sMessage))
85900>>>                                End                                                   
85900>>>>
85900>>>                                Else Begin
85901>>>                                    Showln (Sformat("  SQLGetMessage iMessage %1 returned [%2]", iMessage, sMessage))
85903>>>                                End
85903>>>>
85903>>>                            End
85903>>>>
85903>>>                            Move sMessage to sMsg[SizeOfArray(sMsg)]
85904>>>                            Move sMessage to aSQLQueryMessages[SizeOfArray(aSQLQueryMessages)]
85905>>>                        Loop   
85906>>>>
85906>>>                    
85906>>>                    
85906>>>                        If (ghoDbUpdateHandler > 0) Begin
85908>>>                            Set paSQLQueryMessages of ghoDbUpdateHandler to aSQLQueryMessages
85909>>>                        End
85909>>>>
85909>>>                        Set paQueryMessages to sMsg
85910>>>                    End
85910>>>>
85910>>>
85910>>>                    Get SQLNextResultSet of hoStmt to iNextSet
85911>>>                Until (iNextSet = 0)
85913>>>                
85913>>>                Move (CurrentDateTime()) to dtQueryExecEnd
85914>>>            End 
85914>>>>
85914>>>            
85914>>>            Move (dtQueryExecEnd - dtQueryExecStart) to tsQuery
85915>>>            Set ptsQueryExec to tsQuery  
85916>>>            Send SqlClose of hoStmt
85917>>>
85917>>>            If (bCreateScriptFile = True) Begin
85919>>>                Close_Output channel iOut
85921>>>                Send Seq_Release_Channel iOut
85922>>>            End
85922>>>>
85922>>>        End
85922>>>>
85922>>>        Send SqlDisconnect of hoSQLConnect
85923>>>
85923>>>        Function_Return (hoSQLConnect <> 0 and Err = False)
85924>>>    End_Function
85925>>>        
85925>>>    // Returns the index for the passed sTableName
85925>>>    // Returns >= 0 if successful. It is e.g. needed to get the SchemaName for a table.
85925>>>    Function _SqlUtilEnumerateTableIndex String sTableName String sDriverID Returns Integer
85927>>>        Integer iIndex iSize iCount
85927>>>        String[] sTablesArray
85928>>>        String sVal sConnectionString
85928>>>        
85928>>>        Move -1 to iIndex            
85929>>>        Get psConnectionString to sConnectionString
85930>>>        Get SqlUtilEnumerateTables sDriverID to sTablesArray
85931>>>        Move (SizeOfArray(sTablesArray)) to iSize
85932>>>        Decrement iSize
85933>>>        For iCount from 0 to iSize
85939>>>>
85939>>>            Move sTablesArray[iCount] to sVal
85940>>>            If (Uppercase(sVal) = Uppercase(sTableName)) Begin
85942>>>                Move iCount to iIndex // We found it!
85943>>>                Move iSize to iCount  // End the loop    
85944>>>            End
85944>>>>
85944>>>        Loop                  
85945>>>>
85945>>>        
85945>>>        Function_Return iIndex
85946>>>    End_Function
85947>>>
85947>>>    // Helper function that builds a string like;
85947>>>    // "SELECT name from [Master].[sys].[databases] where name"
85947>>>    Function _SqlSelectFromWhereName Returns String
85949>>>        String sRetval sSelect sName sFrom sMaster sSys sDatabases sWhere sDBO
85949>>>        
85949>>>        Get _SqlFindKeyWord CI_SQLSelect       to sSelect
85950>>>        Get _SqlFindKeyWord CI_SQLName         to sName                             
85951>>>        Get _SqlFindKeyWord CI_SQLDBO          to sDBO
85952>>>        Get _SqlFindKeyWord CI_SQLFrom         to sFrom
85953>>>        Get _SqlFindKeyWord CI_SQLMaster       to sMaster
85954>>>        Get _SqlFindKeyWord CI_SQLSys          to sSys
85955>>>        Get _SqlFindKeyWord CI_SQLDatabases    to sDatabases
85956>>>        Get _SqlFindKeyWord CI_SQLWhere        to sWhere
85957>>>        Move (sSelect * sName * sFrom * "[" + sMaster + "].[" + sDBO + "].[" + sSys + sDatabases + "]" * sWhere * sName) to sRetval
85958>>>        Function_Return sRetval
85959>>>    End_Function  
85960>>>    
85960>>>    // To enumerate SQL database resources with ESQL and return the result as a string array,
85960>>>    // for DAW drivers.
85960>>>    // Returns: A string array.
85960>>>    Function SqlEnumerateEsqlDAW String sStmt Integer iColumn Returns String[]
85962>>>        String[] sReturnArray
85963>>>        String sValue sPrevious
85963>>>        Handle hoSQLHandler hoSQLConnect hstmt
85963>>>        Integer iFetchResult iRows
85963>>>        tSQLConnection SQLConnection
85963>>>        tSQLConnection SQLConnection
85963>>>        
85963>>>        Get phoSQLManager to hoSQLHandler
85964>>>                
85964>>>        If (hoSQLHandler <> 0) Begin 
85966>>>            Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
85967>>>            Get SQLConnect of hoSQLHandler SQLConnection.sDriverID SQLConnection.sConnectionString to hoSQLConnect
85968>>>            
85968>>>            If (hoSQLConnect <> 0) Begin   
85970>>>                Get SQLOpen of hoSQLConnect to hstmt
85971>>>                If (hstmt <> 0) Begin                                   
85973>>>                    Send SqlExecDirect of hstmt sStmt                                             
85974>>>                    Get SqlStmtAttribute of hstmt SqlSTMTATTRIB_ROWCOUNT to iRows 
85975>>>                    Repeat
85975>>>>
85975>>>                        Get SQLFetch of hstmt to iFetchResult
85976>>>                        If (iFetchResult <> 0) Begin
85978>>>                            Get SQLColumnValue of hstmt iColumn to sValue
85979>>>                            If (sValue <> sPrevious) Begin
85981>>>                                Move (Trim(sValue)) to sReturnArray[SizeOfArray(sReturnArray)
85982>>>                            End
85982>>>>
85982>>>                            Move sValue to sPrevious
85983>>>                        End
85983>>>>
85983>>>                    Until (iFetchResult = 0)
85985>>>                    Send SQLClose of hstmt
85986>>>                End
85986>>>>
85986>>>                Send SQLDisconnect of hoSQLConnect    
85987>>>            End
85987>>>>
85987>>>        End
85987>>>>
85987>>>    
85987>>>        Function_Return sReturnArray
85988>>>    End_Function   
85989>>>
85989>>>    // To enumerate SQL database resources with ESQL and return the result as a string array,
85989>>>    // for Mertech drivers.
85989>>>    // Returns: A string array.
85989>>>    Function SqlEnumerateEsqlMertech String sStmt Returns String[]
85991>>>        String[] sReturnArray
85992>>>        String sValue sUserID sPassword 
85992>>>        Handle hoSQLHandler hoSQLConnect hStmt
85992>>>        Integer iFetchResult iRows
85992>>>        tSQLConnection SQLConnection
85992>>>        tSQLConnection SQLConnection
85992>>>        
85992>>>        Get _MertechSQLManagerHandle to hoSQLHandler
85993>>>
85993>>>        If (hoSQLHandler <> 0) Begin 
85995>>>            Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection
85996>>>            Get SQLConnect of hoSQLHandler SQLConnection.sDriverID SQLConnection.sServer SQLConnection.sUserID SQLConnection.sPassword to hoSQLConnect
85997>>>            
85997>>>            If (hoSQLConnect <> 0) Begin   
85999>>>                Get SQLOpen of hoSQLConnect to hStmt
86000>>>                If (hStmt <> 0) Begin                                   
86002>>>                    Send SqlExecDirect of hStmt sStmt                                             
86003>>>                    Get SqlStmtAttribute of hStmt SqlSTMTATTRIB_ROWCOUNT to iRows
86004>>>                    Repeat
86004>>>>
86004>>>                        Get SQLFetch of hStmt to iFetchResult
86005>>>                        If (iFetchResult <> 0) Begin
86007>>>                            Get SQLColumnValue of hStmt 1 to sValue
86008>>>                            Move (Trim(sValue)) to sReturnArray[SizeOfArray(sReturnArray)
86009>>>                        End
86009>>>>
86009>>>                    Until (iFetchResult = 0)
86011>>>                    Send SQLClose of hStmt
86012>>>                End
86012>>>>
86012>>>                Send SQLDisconnect of hoSQLConnect    
86013>>>            End
86013>>>>
86013>>>        End
86013>>>>
86013>>>    
86013>>>        Function_Return sReturnArray
86014>>>    End_Function 
86015>>>    
86015>>>    // Backs up an SQL database to a folder of choice. If no path is passed the SQL default backup folder
86015>>>    // will be used.
86015>>>    Function SqlUtilBackupDatabaseToDisk String sDatabase String sBackupName String sPath Boolean bShowProg Returns Boolean
86017>>>        Boolean bOK bExists bShowProgress      
86017>>>        String sStatement sDriverID 
86017>>>        tSQLScriptArray SQLScriptArray SQLScriptArrayPercentReady
86017>>>        tSQLScriptArray SQLScriptArray SQLScriptArrayPercentReady
86017>>>        Integer iDbType
86017>>>        
86017>>>        If (sDatabase = "") Begin
86019>>>            Error DFERR_PROGRAM "The database name was not passed as a parameter to the 'SqlUtilBackupDatabaseToDisk' function"
86020>>>>
86020>>>            Function_Return False
86021>>>        End
86021>>>>
86021>>>        If (sBackupName = "") Begin
86023>>>            Error DFERR_PROGRAM "The database backup name was not passed as a parameter to the 'SqlUtilBackupDatabaseToDisk' function"
86024>>>>
86024>>>            Function_Return False
86025>>>        End
86025>>>>
86025>>>            
86025>>>        // Create backup-folder if it doesn't exist
86025>>>        Get vFolderExists sPath to bExists
86026>>>        If (bExists = False) Begin
86028>>>            Get vCreateDirectory sPath to bOK
86029>>>            If (bOK = False) Begin
86031>>>                Error DFERR_PROGRAM ("Could not create database backup folder:" * sPath)
86032>>>>
86032>>>                Function_Return False
86033>>>            End
86033>>>>
86033>>>        End                     
86033>>>>
86033>>>        // Make sure the path ends with a back-slash
86033>>>        If (sPath <> "") Begin
86035>>>            Get vFolderFormat sPath to sPath
86036>>>        End
86036>>>>
86036>>>        
86036>>>        Get psDriverID to sDriverID  
86037>>>        Get piDbType   to iDbType        
86038>>>        If (num_arguments > 3) Begin
86040>>>            Move bShowProg to bShowProgress
86041>>>        End
86041>>>>
86041>>>        
86041>>>        Case Begin
86041>>>            Case (iDbType = EN_DbTypeMSSQL)
86043>>>                SQLIncludeScriptFile ..\Scripts\BackupMSSQLDatabase.sql as BackupMSSQLDatabase.sql
86043>>>                SQLIncludeScriptFile ..\Scripts\GetPercentageBackupCompletionMSSQL.sql as GetPercentageBackupCompletionMSSQL.sql
86043>>>                Get SqlUtilReadResource of ghoDbUpdateFunctionLibrary "BackupMSSQLDatabase.sql" sDriverID False to SQLScriptArray
86044>>>                Get SqlUtilReadResource of ghoDbUpdateFunctionLibrary "GetPercentageBackupCompletionMSSQL.sql" sDriverID False to SQLScriptArrayPercentReady
86045>>>                
86045>>>                Move SQLScriptArray.sSQLScriptArray[0] to sStatement
86046>>>                Move (Replaces("DATABASE_NAME_XXX", sStatement, sDatabase))   to sStatement
86047>>>                Move (Replaces("BACKUP_PATH_XXX",   sStatement, sPath))       to sStatement
86048>>>                Move (Replaces("BACKUP_NAME_XXX",   sStatement, sBackupName)) to sStatement
86049>>>                Move sStatement to SQLScriptArray.sSQLScriptArray[0]    
86050>>>                Get SqlUtilExecuteEmbeddedScript of ghoDbUpdateFunctionLibrary SQLScriptArray sDriverID False "" bShowProgress to bOK
86051>>>                Case Break
86052>>>            Case Else
86052>>>                Send Info_Box ("The SqlUtilBackupDatabaseToDisk function is currently not implemented for the driver:" * sDriverID + ". It would be great if you could spend a couple of minutes and add a little ESQL code snippet to make it work for that driver! Thanks for helping out.")
86053>>>        Case End
86053>>>        
86053>>>        Function_Return bOK    
86054>>>    End_Function
86055>>>
86055>>>    // Reads a resource that has been embedded by the compiler and writes it to disk.
86055>>>    // Pass the memory resource file reference and the filename to be created,
86055>>>    // including full path.
86055>>>    Procedure SqlUtilCreateFileFromMemory String sMemFileName String sFileName
86057>>>        String sText
86057>>>        Integer iCh iSize iArgSize  
86057>>>        
86057>>>        Move ("Resource:" + sMemFileName) to sMemFileName
86058>>>        Get Seq_Open_Input_Channel sMemFileName to iCh
86059>>>            Get_Channel_Size iCh to iSize
86060>>>            Get_Argument_Size to iArgSize
86061>>>            If (iSize > iArgSize) Begin
86063>>>                Set_Argument_Size iSize
86064>>>>
86064>>>            End
86064>>>>
86064>>>            Read_Block channel iCh sText iSize
86066>>>        Send Seq_Close_Channel iCh
86067>>>    
86067>>>        Get Seq_Open_Output_Channel sFileName to iCh
86068>>>            Write channel iCh sText
86070>>>        Send Seq_Close_Channel iCh
86071>>>    
86071>>>        If (iSize <> iArgSize) Begin
86073>>>            Set_Argument_Size iArgSize
86074>>>>
86074>>>        End
86074>>>>
86074>>>    
86074>>>        // Wait for file to be written to disk.
86074>>>        Sleep 2
86075>>>    End_Procedure 
86076>>>    
86076>>>    // L„s f”rst .int fil och spara alla FIELD_INDEX + FIELD_NUMBER + FIELD_RELATED_FILE + FIELD_RELATED_FIELD i en struct array,
86076>>>    // INDEX_NUMBER + INDEX_NAME (string)
86076>>>    // samt spara undan .int "header rader" s† de kan skrivas ut senare.
86076>>>    // Check if index exists:    
86076>>>    //IF EXISTS (
86076>>>    //   SELECT 'X'
86076>>>    //   from sysindexes
86076>>>    //   WHERE id = (SELECT OBJECT_ID('accounts'))
86076>>>    //     and name = 'idx_acct_no'
86076>>>    //)          
86076>>>    //
86076>>>    // Helper function to create a SQL statement like;
86076>>>    // "SELECT * FROM SYS.INDEXES WHERE NAME = MyIndexName AND OBJECT_ID = OBJECT_ID([MySchmaName].[MyTableName])"
86076>>>    // Used for checking if an index exists.
86076>>>    Function _SqlQueryIfIndexExists String sSchemaName String sTableName String sIndexName Returns String
86078>>>        String sRetval sSelect sFrom sSysIndexes sWhere sObjectID sAnd sName
86078>>>        
86078>>>        Get _SqlFindKeyWord CI_SQLSelect to sSelect
86079>>>        Get _SqlFindKeyWord CI_SQLFrom to sFrom
86080>>>        Get _SqlFindKeyWord CI_SQLSysIndexes to sSysIndexes
86081>>>        Get _SqlFindKeyWord CI_SQLWhere to sWhere
86082>>>        Get _SqlFindKeyWord CI_SQLObjectID to sObjectID
86083>>>        Get _SqlFindKeyWord CI_SQLAND to sAnd
86084>>>        Get _SqlFindKeyWord CI_SQLName to sName
86085>>>        
86085>>>        Move (sSelect * String("*") * sFrom * sSysIndexes * sWhere * sName * "=" * sIndexName * sAnd * sObjectID * "=([" + sSchemaName + "].[" + sTableName + "])") to sRetval
86086>>>        
86086>>>        Function_Return sRetval
86087>>>    End_Function  
86088>>>    
86088>>>    // Formats a columns iLenght & iDecimal parameters as SQL expects them in a string. 
86088>>>    // E.g. (4,2), where 4 is the iLength and 2 the iDecimals param.
86088>>>    Function _SqlFormatLengthAndDecimalAsString Integer iLength Integer iDecimals Returns String
86090>>>        String sRetval
86090>>>        If (iLength <> 0) Begin
86092>>>            Move ("(" + String(iLength)) to sRetval
86093>>>            If (iDecimals <> 0) Begin
86095>>>                Move (sRetval + "," + String(iDecimals)) to sRetval
86096>>>            End
86096>>>>
86096>>>            Move (sRetval + ")") to sRetval
86097>>>        End
86097>>>>
86097>>>        Function_Return sRetval
86098>>>    End_Function
86099>>>    
86099>>>    Procedure _SqlColumnInfo Handle hoStmt
86101>>>        Integer i iCols iItem
86101>>>        tSqlColumnNew[] aQueryColumns
86101>>>        tSqlColumnNew[] aQueryColumns
86102>>>
86102>>>        Get SqlStmtAttribute of hoStmt SqlSTMTATTRIB_COLUMNCOUNT to iCols
86103>>>        For i from 1 to iCols
86109>>>>
86109>>>            Move (SizeOfArray(aQueryColumns)) to iItem
86110>>>            Get SqlColAttribute of hoStmt i SqlCOLATTRIB_BASECOLUMNNAME to aQueryColumns[iItem].sBaseColumnName
86111>>>            Get SqlColAttribute of hoStmt i SqlCOLATTRIB_BASETABLENAME  to aQueryColumns[iItem].sBaseTableName
86112>>>            Get SqlColAttribute of hoStmt i SqlCOLATTRIB_LABEL          to aQueryColumns[iItem].sLabel
86113>>>            Get SqlColAttribute of hoStmt i SqlCOLATTRIB_SQLTYPE        to aQueryColumns[iItem].iSqlType
86114>>>            Get SqlColAttribute of hoStmt i SqlCOLATTRIB_DFTYPE         to aQueryColumns[iItem].iDFType
86115>>>            Get SqlColAttribute of hoStmt i SqlCOLATTRIB_SIZE           to aQueryColumns[iItem].iSize
86116>>>            Get SqlColAttribute of hoStmt i SqlCOLATTRIB_PRECISION      to aQueryColumns[iItem].iPrecision
86117>>>        Loop
86118>>>>
86118>>>        Set piColumns to iCols
86119>>>        Set paQueryColumns to aQueryColumns
86120>>>    End_Procedure
