86372>>>
86372>>>    // We might have a split Sql script where the info about which database to use is
86372>>>    // put on top of the Sql script, we then need to save it to be able to retrieve it later and
86372>>>    // insert it for scriplets to come after the first one.
86372>>>    Function _SqlFormatStatement String sStmt Returns String
86374>>>        String sUseDatabase sTmp sUseKeyWord sCreateViewKeyWord sDBOKeyWord sNoCountKeyWord sDriverID
86374>>>        Integer iStart iEnd iDbType
86374>>>        Boolean bOK
86374>>>        
86374>>>        Get piDbType to iDbType 
86375>>>        Get psDriverID to sDriverID
86376>>>        Get _SqlFindKeyWord CI_SQLUse          to sUseKeyWord  
86377>>>        Get _SqlFindKeyWord CI_SQLSetNoCountOn to sNoCountKeyWord
86378>>>        Get _SqlFindKeyWord CI_SQLCreateView   to sCreateViewKeyWord            
86379>>>        Get _SqlFindKeyWord CI_SQLDBO          to sDBOKeyWord 
86380>>>        Move (Replaces(" ", sStmt, "")) to sTmp
86381>>>        If (Uppercase(sTmp) contains (sUseKeyWord +"[")) Begin
86383>>>            Move (Pos("[", (Uppercase(sTmp)))) to iStart
86384>>>            Move (Pos("]", sTmp)) to iEnd
86385>>>            Move (Mid(sTmp, (iEnd -iStart +1), iStart)) to sUseDatabase
86386>>>            Move (sUseKeyWord * sUseDatabase + " ") to sUseDatabase
86387>>>            Set Private.psUseDatabase to sUseDatabase
86388>>>        End
86388>>>>
86388>>>        Else Begin   
86389>>>            Move (Uppercase(sStmt)) to sTmp
86390>>>
86390>>>            // A "Create View" statement _must_ be the very first words in a Sql statement.
86390>>>            If (not(sTmp contains sCreateViewKeyWord)) Begin
86392>>>                Get Private.psUseDatabase to sUseDatabase
86393>>>                Move (Insert(sUseDatabase, sStmt, 1)) to sStmt
86394>>>            End 
86394>>>>
86394>>>            
86394>>>            // This is a bit special to place here but was done so because it was easier that way.
86394>>>            // We will get an error when trying to create a view if it already exists.
86394>>>            // So to avoid such errors; we first remove it & then recreate it.
86394>>>            Else If (sTmp contains sCreateViewKeyWord) Begin 
86397>>>                // Make sure we only have one space between statements/words.  
86397>>>                Move (Replaces("  ", sTmp, " ")) to sTmp
86398>>>                Move (Replace(sCreateViewKeyWord, sTmp, "")) to sTmp
86399>>>                Move (Trim(sTmp)) to sTmp
86400>>>                Move (Pos(" ", sTmp)) to iEnd
86401>>>                Move (Left(sTmp, iEnd)) to sTmp
86402>>>                If ((not(sTmp contains ("[" + sDBOKeyWord + "]."))) and (not(sTmp contains (sDBOKeyWord + ".")))) Begin
86404>>>                    Move (sDBOKeyWord + "." + Trim(sTmp)) to sTmp
86405>>>                End  
86405>>>>
86405>>>                Move (Trim(sTmp)) to sTmp
86406>>>                // Remove data view as it already exists!
86406>>>                Get SqlViewRemove sDriverID sTmp to bOK
86407>>>            End
86407>>>>
86407>>>        End
86407>>>>
86407>>>
86407>>>        Function_Return sStmt    
86408>>>    End_Function
86409>>>    
86409>>>    // Returns the proper Sql language key word(s) for the passed SQL key-word constant
86409>>>    Function _SqlFindKeyWord Integer iSQLKeywordConstant Returns String
86411>>>        String sRetval         
86411>>>        Integer iDbType iSize iItem iIndex
86411>>>        tSQLKeyWords[] SQLKeywordArray 
86411>>>        tSQLKeyWords[] SQLKeywordArray 
86412>>>        tSQLKeyWords   SQLKeyWords
86412>>>        tSQLKeyWords   SQLKeyWords
86412>>>        
86412>>>        // Sql back-end type. E.g. MS-SQL, MySQL, Oracle, DB2...
86412>>>        Get piDbType to iDbType
86413>>>        Move iDbType             to SQLKeyWords.iSQLDbType
86414>>>        Move iSQLKeywordConstant to SQLKeyWords.iSQLWord
86415>>>         
86415>>>        Get paSQLKeywordArray to SQLKeywordArray
86416>>>        Move (SearchArray(SQLKeyWords, SQLKeywordArray, Self, RefFunc(CompareFindSQLKeyWords))) to iIndex
86417>>>        Move SQLKeywordArray[iIndex].sSQLPhrase to sRetval
86418>>>
86418>>>        Function_Return sRetval
86419>>>    End_Function
86420>>>    
86420>>>    // Function will "clean/sanitize" the script by removing all comments and blank lines.
86420>>>    Function _SqlUtilSanitizeScript tSQLScriptArray SqlScriptArray Returns tSQLScriptArray[] 
86422>>>        String[] sSQLScriptArray
86423>>>        String sText sLine sTmp sCommentStart sCommentEnd sDashComment
86423>>>        Integer iCh iSize iArgSize iPos iCount
86423>>>        Boolean bCommentStart bCommentEnd bDashComment
86423>>>        
86423>>>        Move False to bCommentStart
86424>>>        Move False to bCommentEnd 
86425>>>        Move False to bDashComment                                    
86426>>>        Move "/*"  to sCommentStart   // These are the standard comment start & stop tokens...
86427>>>        Move "*/"  to sCommentEnd
86428>>>        Move "--"  to sDashComment    // ...but a comment can also start with two dashes "--".
86429>>>
86429>>>        Move (SizeOfArray(SqlScriptArray.sSQLScriptArray)) to iSize
86430>>>        Decrement iSize
86431>>>        Move "" to sText  
86432>>>        
86432>>>        For iCount from 0 to iSize
86438>>>>
86438>>>            Move SqlScriptArray.sSQLScriptArray[iCount] to sLine
86439>>>            Move (Trim(sLine)) to sTmp
86440>>>            If (sTmp <> "") Begin
86442>>>                Move (Left(sTmp, 2) = sDashComment) to bDashComment
86443>>>                If (bCommentStart = False) Begin
86445>>>                    Move (Left(sTmp, 2) = sCommentStart) to bCommentStart
86446>>>                    If (bCommentStart = False) Begin
86448>>>                    End
86448>>>>
86448>>>                End
86448>>>>
86448>>>                Move (sTmp contains sCommentEnd) to bCommentEnd
86449>>>                If (bCommentEnd = True) Begin
86451>>>                    Move False to bCommentStart
86452>>>                End
86452>>>>
86452>>>                If (bDashComment = False and bCommentStart = False and bCommentEnd = False) Begin
86454>>>                    Move sLine to sSQLScriptArray[SizeOfArray(sSQLScriptArray)] 
86455>>>                End
86455>>>>
86455>>>            End
86455>>>>
86455>>>        Loop 
86456>>>>
86456>>>        
86456>>>        // Update the retval struct array:    
86456>>>        Move sSQLScriptArray to SqlScriptArray.sSQLScriptArray
86457>>>        Function_Return SqlScriptArray
86458>>>    End_Function
86459>>>
86459>>>    // *** Database API Functions: ***
86459>>>    // Instead of using Sql Scripts (ESQL), we can opt to use the DataFlex Database API's to 
86459>>>    // make changes/updates to the database.
86459>>>    //
86459>>>    //
86459>>>    // This might not do what you think - Here's what it does:
86459>>>    // It checks that the passed hTable TableName in filelist.cfg is exactly the same as at the SQL back-end.
86459>>>    // If that is True; it creates an .int file for it and changes Filelist.cfg to point
86459>>>    // to the SQL table.
86459>>>    // Typical usage for this function is when an entry exists in the Filelist for a table and the table
86459>>>    // already exists in SQL. 
86459>>>    // This is a bit fiddly as the DF_FILE_PHYSICAL_NAME attribute can only be set inside a 
86459>>>    // Structure_Start ... Structure_End operation when creating a NEW table. Thus it cannot be set when 
86459>>>    // restructuring an existing table.
86459>>>    Function ApiTableAttachToSQL Handle hTable Boolean bUseConnID Returns Boolean
86461>>>        Boolean bExists bOpened bOK bSystemFile bMertechDriver bUseConnectionID
86461>>>        String sDriverID sTableName sConnectionID sConnectionString sDisplayName sRootName sLogicalName sPhysicalName sSchema
86461>>>        Handle hToTable 
86461>>>        Integer iPos
86461>>>        
86461>>>        Move True to bUseConnectionID
86462>>>        If (num_arguments > 1) Begin
86464>>>            Move bUseConnID to bUseConnectionID
86465>>>        End                                    
86465>>>>
86465>>>        
86465>>>        Get psDriverID to sDriverID
86466>>>        // If the table doesn't exist on the SQL back-end we do nothing.
86466>>>        Get SqlUtilCheckIfTableHandleExists hTable sDriverID to bExists
86467>>>        If (bExists = False) Begin
86469>>>            Function_Return False
86470>>>        End
86470>>>>
86470>>>        
86470>>>        Get _SqlCheckCurrentDriver sDriverID to bOK
86471>>>        If (bOK = False) Begin
86473>>>            Function_Return False
86474>>>        End
86474>>>>
86474>>>        
86474>>>        // Then we need to check that the function hasn't been called before; which in case
86474>>>        // we do nothing
86474>>>        Get SQLUtilTableIsAttached sDriverID hTable to bExists
86475>>>        If (bExists = True) Begin
86477>>>            Function_Return False
86478>>>        End
86478>>>>
86478>>>        
86478>>>        Get psConnectionID     to sConnectionID
86479>>>        Get psConnectionString to sConnectionString 
86480>>>        If (sConnectionID = "" or sConnectionString = "") Begin
86482>>>            Error DFERR_PROGRAM ("An SQL connection has NOT been setup correctly. Could not attach table:" * String(hTable) * "to SQL")
86483>>>>
86483>>>            Function_Return False
86484>>>        End                      
86484>>>>
86484>>>
86484>>>        Get psSchema to sSchema
86485>>>        If (sSchema = "") Begin
86487>>>            Get _SqlFindKeyWord CI_SQLDBO to sSchema  
86488>>>        End
86488>>>>
86488>>>
86488>>>        Get IsMertechDriver sDriverID to bMertechDriver
86489>>>        
86489>>>        // Mertech drivers don't use connection id's, so if the passed bUseConnectionID = True that
86489>>>        // was a programmer's error and we adjust for it here.
86489>>>        If (bMertechDriver = True) Begin
86491>>>            Move False to bUseConnectionID
86492>>>        End
86492>>>>
86492>>>            
86492>>>        // If we should use a connection id we need to check it exists; 
86492>>>        // else we create it before attempting creating the table
86492>>>        If (bUseConnectionID = True) Begin  
86494>>>            Get AutoConnectionIDLogin to bOK
86495>>>            If (bOk = False) Begin
86497>>>                Error DFERR_PROGRAM ("The Connection ID:" * sConnectionID * "could not be created and therefor the table can't be created.")
86498>>>>
86498>>>                Function_Return False
86499>>>            End
86499>>>>
86499>>>        End
86499>>>>
86499>>>            
86499>>>        Get_Attribute DF_FILE_ROOT_NAME of hTable to sRootName
86502>>>        Get _TableNameOnly sRootName to sRootName             
86503>>>        If (sRootName = "") Begin
86505>>>            Function_Return False
86506>>>        End
86506>>>>
86506>>>        Move (sRootName + ".int")                    to sPhysicalName       
86507>>>        Get_Attribute DF_FILE_LOGICAL_NAME of hTable to sLogicalName
