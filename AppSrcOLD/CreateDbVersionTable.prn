84046>>>        Get UtilDeleteCacheFile sTableName to bOK
84047>>>    
84047>>>        Function_Return (Err = False)
84048>>>    End_Function 
84049>>>    
84049>>>    // First deletes the data cache file and then drops the passed data table. 
84049>>>    Function SqlTableRemoveByTableName String sTableName Returns Boolean
84051>>>        String sSQLString sPath sDropTable sVal sSchema sDriverID 
84051>>>        Integer iRetval iDbType
84051>>>        Boolean bMertechDriver bOK
84051>>>        
84051>>>        Get psDriverID to sDriverID
84052>>>        Get IsMertechDriver sDriverID to bMertechDriver
84053>>>        Get psDataPathFirstPart to sPath               
84054>>>        Get UtilDeleteCacheFile sTableName to iRetval
84055>>>        
84055>>>        Get piDbType to iDbType
84056>>>        Get _SqlFindKeyWord CI_SQLDropTable iDbType to sDropTable 
84057>>>        Get psSchema to sSchema
84058>>>        If (sSchema = "") Begin
84060>>>            Get _SqlFindKeyWord CI_SQLDBO to sSchema 
84061>>>        End
84061>>>>
84061>>>        Move (Uppercase(sTableName)) to sVal
84062>>>        If (not(sVal contains (sSchema + "."))) Begin    
84064>>>            Move (Lowercase(sSchema) + "." + sTableName) to sTableName
84065>>>        End    
84065>>>>
84065>>>        Move (sDropTable * String(sTableName)) to sSQLString
84066>>>        
84066>>>        Move False to Err               
84067>>>        Send SqlUtilExecuteQuery sSQLString sDriverID
84068>>>    
84068>>>        // We also need to remove the cache-file since the table has been changed
84068>>>        Get UtilDeleteCacheFile sTableName to bOK
84069>>>    
84069>>>        Function_Return (Err = False)
84070>>>    End_Function 
84071>>>
84071>>>    // *** Sql View Messages ***
84071>>>
84071>>>    // First deletes the data cache file and then drops the passed Sql data view. 
84071>>>    Function SqlViewRemove String sDataView Returns Boolean
84073>>>        String sDriverID sSQLString sPath sDropViewKeyWord 
84073>>>        Integer iRetval                                
84073>>>        Boolean bMertechDriver bOK
84073>>>        
84073>>>        Get psDriverID to sDriverID
84074>>>        Get IsMertechDriver sDriverID to bMertechDriver
84075>>>        Get UtilDeleteCacheFile sDataView to iRetval
84076>>>        
84076>>>        Get _SqlFindKeyWord CI_SQLDropView to sDropViewKeyWord
84077>>>        Move (sDropViewKeyWord * String(sDataView)) to sSQLString
84078>>>        Set psSQLStatementString to sSQLString 
84079>>>        
84079>>>        // As we don't check if the view exist or not, it might happen
84079>>>        // that it doesn't and that would through an error, so guard for that eventuality (just ignore it).
84079>>>        Move False to Err 
84080>>>        Set Error_Report_Mode to DUF_ERROR_NO_REPORT
84081>>>        Send SqlUtilExecuteQuery sSQLString sDriverID
84082>>>        Set Error_Report_Mode to DUF_ERROR_REPORT
84083>>>        Move 0 to LastErr
84084>>>        
84084>>>        // We also need to remove the cache-file since the table has been changed
84084>>>        Get UtilDeleteCacheFile sDataView to bOK
84085>>>    
84085>>>        Function_Return (Err = False)
84086>>>    End_Function
