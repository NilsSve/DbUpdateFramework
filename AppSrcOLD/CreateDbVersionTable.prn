91690>>>>>
91690>>>>>    Procedure Show_Date_Format
91692>>>>>        Integer iDateFormat
91692>>>>>        String sDateFormat
91692>>>>>
91692>>>>>        Get_Attribute DF_DATE_FORMAT to iDateFormat
91695>>>>>        Case Begin
91695>>>>>            Case (iDateFormat = DF_DATE_USA)
91697>>>>>                Move C_$USA To sDateFormat
91698>>>>>                Case Break
91699>>>>>            Case (iDateFormat = DF_DATE_EUROPEAN)
91702>>>>>                Move C_$European To sDateFormat
91703>>>>>                Case Break
91704>>>>>            Case (iDateFormat = DF_DATE_MILITARY)
91707>>>>>                Move C_$Military To sDateFormat
91708>>>>>                Case Break
91709>>>>>            Case Else
91709>>>>>                Move C_$UnknownDateType To sDateFormat
91710>>>>>                Case Break
91711>>>>>        Case End
91711>>>>>
91711>>>>>        Send AppendTextLn (SFormat (C_$DateFormat, sDateformat))
91712>>>>>    End_Procedure
91713>>>>>
91713>>>>>    // 2013-08-14 NGS
91713>>>>>    // Unformatted numeric values shown doesn't look good. These looks much better.
91713>>>>>    Procedure Show_Systemresources
91715>>>>>        tWinMemoryStatusEx MemoryStatusInfo
91715>>>>>        tWinMemoryStatusEx MemoryStatusInfo
91715>>>>>        Integer iRetval
91715>>>>>        Number nValue
91715>>>>>        String sValue
91715>>>>>
91715>>>>>        Move (SizeOfType (tWinMemoryStatusEx)) to MemoryStatusInfo.dwLength
91716>>>>>        Move (GlobalMemoryStatusEx (AddressOf (MemoryStatusInfo))) to iRetval
91717>>>>>        If (iRetval = 0) Begin
91719>>>>>            Move (ShowLastError ()) to iRetval
91720>>>>>            Procedure_Return
91721>>>>>        End
91721>>>>>>
91721>>>>>
91721>>>>>        Send AppendTextLn ""
91722>>>>>        Move MemoryStatusInfo.ullTotalPhys to nValue
91723>>>>>
91723>>>>>        // Show memory in Gigabytes:
91723>>>>>        Move (nValue/1024/1024/1024) to nValue
91724>>>>>        Move (Round(nValue)) to nValue
91725>>>>>        Get FormatNumber nValue 2 to sValue
91726>>>>>        Send AppendTextLn (SFormat (C_$AvailableMemory, (sValue * "GB")))
91727>>>>>        Send AppendTextLn (SFormat (C_$MemoryUtilization, String(MemoryStatusInfo.dwMemoryLoad) * "%"))
91728>>>>>
91728>>>>>//        Send AppendTextLn (SFormat (C_$AvailablePhysicalMemory, Real (MemoryStatusInfo.ullAvailPhys) / Real (MemoryStatusInfo.ullTotalPhys) * 100.0))
91728>>>>>        Move (Real(MemoryStatusInfo.ullAvailPhys) / Real(MemoryStatusInfo.ullTotalPhys) * 100.0) to nValue
91729>>>>>        Move (Round(nValue)) to nValue
91730>>>>>        Get FormatNumber nValue 0 to sValue
91731>>>>>        Send AppendTextLn (SFormat (C_$AvailablePhysicalMemory, (sValue * "%")))
91732>>>>>
91732>>>>>//        Send AppendTextLn (SFormat (C_$AvailablePagefileSpace, Real (MemoryStatusInfo.ullAvailPageFile) / Real (MemoryStatusInfo.ullTotalPageFile) * 100.0))
91732>>>>>        Move (Real(MemoryStatusInfo.ullAvailPageFile) / Real(MemoryStatusInfo.ullTotalPageFile) * 100.0) to nValue
91733>>>>>        Move (Round(nValue)) to nValue
91734>>>>>        Get FormatNumber nValue 0 to sValue
91735>>>>>        Send AppendTextLn (SFormat (C_$AvailablePagefileSpace, (sValue * "%")))
91736>>>>>
91736>>>>>//        Send AppendTextLn (SFormat (C_$AvailableVirtualMemory, Real (MemoryStatusInfo.ullAvailVirtual) / Real (MemoryStatusInfo.ullTotalVirtual) * 100.0))
91736>>>>>        Move (Real(MemoryStatusInfo.ullAvailVirtual) / Real(MemoryStatusInfo.ullTotalVirtual) * 100.0) to nValue
91737>>>>>        Move (Round(nValue)) to nValue
91738>>>>>        Get FormatNumber nValue 0 to sValue
91739>>>>>        Send AppendTextLn (SFormat (C_$AvailableVirtualMemory, (sValue * "%")))
91740>>>>>
91740>>>>>        // Add an empty row after the memory information:
91740>>>>>        Send AppendTextLn ""
91741>>>>>    End_Procedure
91742>>>>>
91742>>>>>    Procedure Show_Registration
91744>>>>>        String sRegName
91744>>>>>        Integer iSN iUsersMax iUserCount
91744>>>>>
91744>>>>>        Registration sRegName iSN
91745>>>>>>
91745>>>>>        Get_Licensed_Max_Users to iUsersMax
91746>>>>>        Get_Current_User_Count to iUserCount
91747>>>>>
91747>>>>>        Send AppendTextLn (SFormat (C_$Serial, iSN))
91748>>>>>        Send AppendTextLn (SFormat (C_$RegName, sRegName))
91749>>>>>        Send AppendTextLn (SFormat (C_$Current_User_Count, iUserCount))
91750>>>>>        Send AppendTextLn (SFormat (C_$Max_Licensed_User_Count, iUsersMax))
91751>>>>>    End_Procedure
91752>>>>>
91752>>>>>    //****************************************************************************
91752>>>>>    // If workspaces are used, we will send the message EnumerateWorkspaceData
91752>>>>>    // To the workspace object passing the an object and message To send back
91752>>>>>    // To this object. It is expected that the workspace object will send this
91752>>>>>    // message for every line Of information it wants displayed (passing the
91752>>>>>    // information To be displayed
91752>>>>>    //****************************************************************************
91752>>>>>    Register_Procedure EnumerateWorkspaceData Integer hObjId Integer hmMessId
91752>>>>>
91752>>>>>    Procedure Show_ServicePack
91754>>>>>        String sKey sVersion sDataFlex
91754>>>>>        Handle hoRegistry
91754>>>>>        Boolean bExists bOpened
91754>>>>>
91754>>>>>        Move "DataFlex"        to sDataFlex
91755>>>>>
91755>>>>>        Get Create U_cRegistry to hoRegistry
91756>>>>>        Set phRootKey of hoRegistry to HKEY_LOCAL_MACHINE
91757>>>>>        Set pfAccessRights of hoRegistry to KEY_READ
91758>>>>>        Get KeyExists of hoRegistry "SOFTWARE\Wow6432Node" to bExists
91759>>>>>
91759>>>>>        If (bExists) Begin
91761>>>>>            Move ("SOFTWARE\Wow6432Node\Data Access Worldwide\" + sDataFlex + "\" + SysConf (SYSCONF_DATAFLEX_REV)) to sKey
91762>>>>>        End
91762>>>>>>
91762>>>>>        Else Begin
91763>>>>>            Move ("SOFTWARE\Data Access Worldwide\"             + sDataFlex + "\" + SysConf (SYSCONF_DATAFLEX_REV)) to sKey
91764>>>>>        End
91764>>>>>>
91764>>>>>        Get KeyExists of hoRegistry sKey to bExists
91765>>>>>        If (bExists) Begin
91767>>>>>            Get OpenKey of hoRegistry sKey to bOpened
91768>>>>>            If (bOpened) Begin
91770>>>>>                Get ValueExists of hoRegistry "CurrentVersionDescription" to bExists
91771>>>>>                If (bExists) Begin
91773>>>>>                    Get ReadString of hoRegistry "CurrentVersionDescription" to sVersion
91774>>>>>                End
91774>>>>>>
91774>>>>>                Send CloseKey of hoRegistry
91775>>>>>            End
91775>>>>>>
91775>>>>>        End
91775>>>>>>
91775>>>>>        Send Destroy of hoRegistry
91776>>>>>
91776>>>>>        If (sVersion <> "") Begin
91778>>>>>           Send AppendTextLn sVersion
91779>>>>>           Send AppendTextLn ""
91780>>>>>        End
91780>>>>>>
91780>>>>>    End_Procedure
91781>>>>>
91781>>>>>    Procedure Show_WorkspaceInformation
91783>>>>>        Integer hoWorkspace
91783>>>>>
91783>>>>>        If (ghoApplication <> 0) Begin
91785>>>>>            Get phoWorkspace of ghoApplication to hoWorkspace
91786>>>>>            If (hoWorkspace <> 0) Begin
91788>>>>>                Send EnumerateWorkspaceData of hoWorkspace Self msg_AppendTextLn
91789>>>>>            End
91789>>>>>>
91789>>>>>        End
91789>>>>>>
91789>>>>>    End_Procedure
91790>>>>>
91790>>>>>    //****************************************************************************
91790>>>>>    // If connection ids are used, we will send the message EnumerateConnections
91790>>>>>    // to the connection manager object passing the an object and message to send 
91790>>>>>    // back to this object. It is expected that the connection manager object will 
91790>>>>>    // send this message for every line Of information it wants displayed (passing 
91790>>>>>    // the information To be displayed
91790>>>>>    //****************************************************************************
91790>>>>>    Register_Procedure EnumerateConnections Integer hObjId Integer hmMessId
91790>>>>>
91790>>>>>    Procedure Show_ConnectionIdInformation
91792>>>>>        If (ghoConnection > 0) Begin
91794>>>>>            Send EnumerateConnections of ghoConnection Self (RefProc(AppendTextLn))
91795>>>>>            Send AppendTextLn ""
91796>>>>>        End
91796>>>>>>
91796>>>>>    End_Procedure
91797>>>>>
91797>>>>>    Function VersionStr Integer iVer Integer iRev Integer iBld Returns String
91799>>>>>        Function_Return (String (iVer) - "." - String (iRev) - "." - String (iBld))
91800>>>>>    End_Function
91801>>>>>
91801>>>>>    Procedure Show_Versions
91803>>>>>        Integer iVersion iRevision iBuild
91803>>>>>
91803>>>>>        Version_information iVersion iRevision iBuild
91805>>>>>
91805>>>>>        Send AppendTextLn (SFormat (C_$RuntimeVersion, VersionStr(self,iVersion,iRevision,iBuild) ))
91806>>>>>        Send AppendTextLn (SFormat (C_$PackageVersion, VersionStr(self,PKG_VERSION, PKG_REVISION, PKG_BUILD) ))
91807>>>>>        Send AppendTextLn (SFormat (C_$FMACVersion, VersionStr(self,FMAC_VERSION, FMAC_REVISION, FMAC_BUILD) ))
91808>>>>>    End_Procedure                                           
91809>>>>>    
91809>>>>>    Function IsDAWSQLDriver String sDriverID Returns Boolean
91811>>>>>        Boolean bOK
91811>>>>>        Move (sDriverID = MSSQLDRV_ID or sDriverID = DB2_DRV_ID or sDriverID = ODBC_DRV_ID) to bOK
91812>>>>>        Function_Return bOK
91813>>>>>    End_Function
91814>>>>>
91814>>>>>    Function IsMertechDriver String sDriverID Returns Boolean
91816>>>>>        Boolean bOK   
91816>>>>>        Function_Return bOK
91817>>>>>    End_Function
91818>>>>>
91818>>>>>    //***
91818>>>>>    //*** BW
91818>>>>>    //*** Procedure: Show_Drivers
91818>>>>>    //*** Purpose  : Show loaded database drivers
91818>>>>>    //***
91818>>>>>
91818>>>>>    Procedure Show_Drivers
91820>>>>>        String sDriverID sVersion sClient sMertechSQLFlexVersion sValue
91820>>>>>        Integer iNumberOfDrivers iDriver iClient iUsersMax iSerialNo iNumServers iCount
91820>>>>>        Handle hoCLIHandler hoBtrvHandler
91820>>>>>        Boolean bStudioLicense bIsDAWDriver bIsMertechDriver
91820>>>>>
91820>>>>>        Move False to bStudioLicense
91821>>>>>
91821>>>>>        Get Create U_cCLIHandler      to hoCLIHandler
91822>>>>>        Get Create U_cDFBtrDrvHandler to hoBtrvHandler 
91823>>>>>
91823>>>>>        // For testing purposes:        
91823>>>>>//        Send Ignore_Error of Error_Object_Id DFERR_CANT_LOAD_DLL
91823>>>>>//        Load_Driver MSSQLDRV_ID
91823>>>>>//        Load_Driver ODBC_DRV_ID
91823>>>>>//        Load_Driver DB2_DRV_ID
91823>>>>>//        Send Trap_Error of Error_Object_Id DFERR_CANT_LOAD_DLL
91823>>>>>//
91823>>>>>//        #IFDEF DUF_Use_Mertech_Drivers  
91823>>>>>//            Send Ignore_Error of Error_Object_Id DFERR_CANT_LOAD_DLL
91823>>>>>//            Load_Driver SQLFLEX 
91823>>>>>//            Load_Driver MDSPgSQL
91823>>>>>//            Load_Driver MDSMySQL
91823>>>>>//            Load_Driver ORAFLEX
91823>>>>>//            Send Trap_Error of Error_Object_Id DFERR_CANT_LOAD_DLL
91823>>>>>//        #ENDIF
91823>>>>>        Move False to Err
91824>>>>>        
91824>>>>>        // Loop through all loaded drivers.
91824>>>>>        Get_Attribute DF_NUMBER_DRIVERS to iNumberOfDrivers
91827>>>>>        If (iNumberOfDrivers > 1) Begin
91829>>>>>            Send AppendTextLn ""
91830>>>>>        End
91830>>>>>>
91830>>>>>        For iDriver from 1 to iNumberOfDrivers           
91836>>>>>>
91836>>>>>            // For some weird reason it can happen that - when using Mertech drivers - that the driver index
91836>>>>>            // was increased in the CLI array, but it has no value. In that case a "Bad parameter..." error
91836>>>>>            // would be thrown, so we safeguard from that here.
91836>>>>>            Send Ignore_Error of Error_Object_Id DFERR_BAD_PARAMETER
91837>>>>>            Get_Attribute DF_DRIVER_NAME of iDriver to sDriverID
91840>>>>>            Send Trap_Error of Error_Object_Id DFERR_BAD_PARAMETER
91841>>>>>            Get IsDAWSQLDriver sDriverID to bIsDAWDriver
91842>>>>>            Get IsMertechDriver sDriverID to bIsMertechDriver
91843>>>>>
91843>>>>>            If (sDriverID = DFBTRDRV_ID or bIsDAWDriver = True or bIsMertechDriver = True) Begin
91845>>>>>
91845>>>>>                // Pervasive/Btrieve database
91845>>>>>                If (sDriverID = DFBTRDRV_ID) Begin
91847>>>>>                    Get CKRevision of hoBtrvHandler to sVersion
91848>>>>>                    Get PSQLLocalEngineVersionInfo of hoBtrvHandler 0 to sClient
91849>>>>>                    If (sClient <> "0.0.0") Begin
91851>>>>>                        Send AppendTextLn (SFormat (C_$Pervasive_Local_Engine_Version, sClient))
91852>>>>>                    End
91852>>>>>>
91852>>>>>                    Get PSQLServerEngineVersionInfo of hoBtrvHandler 0 to sClient
91853>>>>>                    If (sClient <> "0.0.0") Begin
91855>>>>>                        Send AppendTextLn (SFormat (C_$Pervasive_Server_Engine_Version, sClient))
91856>>>>>                    End
91856>>>>>>
91856>>>>>                End
91856>>>>>>
91856>>>>>
91856>>>>>                Else Begin
91857>>>>>                    Set psDriverID of hoCLIHandler to sDriverID 
91858>>>>>                    Move 0 to iNumServers
91859>>>>>                    If (sDriverID <> DATAFLEX_ID) Begin
91861>>>>>                        Get_Attribute DF_DRIVER_NUMBER_SERVERS of iDriver to iNumServers
91864>>>>>                    End
91864>>>>>>
91864>>>>>                    
91864>>>>>                    If (bIsDAWDriver = True) Begin
91866>>>>>                        If (sDriverID = MSSQLDRV_ID) Begin
91868>>>>>                            // This info is only available for the MS SQL driver:
91868>>>>>                            Get_Attribute DF_DRIVER_SQLSERVER_CLIENT_VERSION of iDriver to iClient
91871>>>>>                            If (iClient = 13) Move C_$SQLSERVER2016DRVRSTR              to sClient
91874>>>>>                            If (iClient = 12) Move C_$SQLSERVER2014DRVRSTR              to sClient
91877>>>>>                            If (iClient = 11) Move C_$SQL_Server_Native_Client_11_0     to sClient
91880>>>>>                            If (iClient = 10) Move C_$SQL_Server_Native_Client_10_0     to sClient
91883>>>>>                            If (iClient = 9)  Move C_$SQL_Native_Client                 to sClient
91886>>>>>                            If (iClient = 8)  Move C_$SQL_Server_SQL_Server_2000_client to sClient
91889>>>>>                            If (sClient <> "") Begin
91891>>>>>                                Move ("    " + sClient) to sClient
91892>>>>>                            End
91892>>>>>>
91892>>>>>                        End
91892>>>>>>
91892>>>>>                    
91892>>>>>                        Get CKRevision of hoCLIHandler to sVersion 
91893>>>>>                    End
91893>>>>>>
91893>>>>>                    
91893>>>>>                    If (bIsMertechDriver = True) Begin
91895>>>>>                    End
91895>>>>>>
91895>>>>>                    
91895>>>>>                    // If the serialnumber is = 0, it means that the
91895>>>>>                    // Studio licens is in use and there is no
91895>>>>>                    // number of max users defined because the driver is
91895>>>>>                    // relying on the info from the VDF license.
91895>>>>>                    If (bStudioLicense = False) Begin
91897>>>>>                        Get SerialNumber of hoCLIHandler to iSerialNo
91898>>>>>                        Move (iSerialNo = 0) to bStudioLicense
91899>>>>>                    End
91899>>>>>>
91899>>>>>                End
91899>>>>>>
91899>>>>>                Send AppendTextLn (SFormat (C_$DatabaseDriver, (sDriverID * "-" * (C_$Version + ": " + sVersion))))
91900>>>>>                If (iNumServers <> 0) Begin
91902>>>>>                    For iCount from 1 to iNumServers
91908>>>>>>
91908>>>>>                        Get_Attribute DF_DRIVER_SERVER_NAME of iDriver iCount to sValue 
91911>>>>>                        Send AppendTextLn ("    " + "Server/DSN:" * sValue)
91912>>>>>                    Loop
91913>>>>>>
91913>>>>>                End
91913>>>>>>
91913>>>>>                If (sClient <> "" and sDriverID = MSSQLDRV_ID) Begin
91915>>>>>                    Send AppendTextLn sClient
91916>>>>>                End  
91916>>>>>>
91916>>>>>            End
91916>>>>>>
91916>>>>>        Loop
91917>>>>>>
91917>>>>>
91917>>>>>        Send AppendTextLn ""
91918>>>>>        If (bStudioLicense = False) Begin
91920>>>>>            Get MaxUsers of hoCLIHandler to iUsersMax 
91921>>>>>            Send AppendTextLn (SFormat (C_$Max_DbDriver_Licensed_User_Count, iUsersMax))
91922>>>>>        End
91922>>>>>>
91922>>>>>        Else Begin
91923>>>>>            Send AppendTextLn C_$VDF_Studio_License_Text
91924>>>>>        End
91924>>>>>>
91924>>>>>        Send Destroy of hoCLIHandler
91925>>>>>        Send Destroy of hoBtrvHandler
91926>>>>>    End_Procedure
91927>>>>>
91927>>>>>    Procedure Show_HelpFile
91929>>>>>        String sHelpFile
91929>>>>>        Integer eHelpType
91929>>>>>
91929>>>>>        If (ghoApplication <> 0) Begin
91931>>>>>            Get peHelpType Of ghoApplication To eHelpType
91932>>>>>            If (eHelpType = htHtmlHelp and ghoHtmlHelp) Begin
91934>>>>>                Get GetHelpFile Of ghoHtmlHelp To sHelpFile
91935>>>>>            End
91935>>>>>>
91935>>>>>            Else If (eHelpType = htWinHelp and Help_object_id) Begin
91938>>>>>                Get Help_filename Of Help_object_id To sHelpFile
91939>>>>>            End
91939>>>>>>
91939>>>>>            Else Begin
91940>>>>>                Move C_$ThereIsNoHelpfileDefined To sHelpFile
91941>>>>>            End
91941>>>>>>
91941>>>>>
91941>>>>>            Send AppendTextLn (SFormat (C_$HelpFile, sHelpFile))
91942>>>>>        End
91942>>>>>>
91942>>>>>    End_Procedure
91943>>>>>
91943>>>>>    Procedure Show_EnterAsTab
91945>>>>>        Boolean bEnterKeyAsTabKey
91945>>>>>        String sText
91945>>>>>
91945>>>>>        If (ghoApplication <> 0) Begin
91947>>>>>            Get pbEnterKeyAsTabKey Of ghoApplication To bEnterKeyAsTabKey
91948>>>>>            If (bEnterKeyAsTabKey) Begin
91950>>>>>                Move "True" To sText
91951>>>>>            End
91951>>>>>>
91951>>>>>            Else Begin
91952>>>>>                Move "False" To sText
91953>>>>>            End
91953>>>>>>
91953>>>>>            Send AppendTextLn (SFormat (C_$EnterKeyNavForward, sText))
91954>>>>>        End
91954>>>>>>
91954>>>>>    End_Procedure
91955>>>>>
91955>>>>>    //****************************************************************************
91955>>>>>    // $Module type: PROCEDURE
91955>>>>>    // $Module name: Add_Focus
91955>>>>>    // $Author     : VOO
91955>>>>>    // Created     : 24-09-96 @ 19:43
91955>>>>>    //
91955>>>>>    // Description
91955>>>>>    //    During activation we will remove the old information and add the newly
91955>>>>>    //    found systeminformation
91955>>>>>    //
91955>>>>>    // $Rev History
91955>>>>>    //    24-09-96  Module header created
91955>>>>>    //****************************************************************************
91955>>>>>    Procedure Add_Focus Integer hoRoot
91957>>>>>        Forward Send Add_Focus hoRoot
91959>>>>>
91959>>>>>        Send Delete_Data
91960>>>>>
91960>>>>>        Set Changed_State To False
91961>>>>>        Set Read_Only_State To True
91962>>>>>
91962>>>>>        Send Show_Registration
91963>>>>>        Send Show_Drivers
91964>>>>>        Send AppendTextLn ""
91965>>>>>
91965>>>>>        Send Show_ServicePack
91966>>>>>        If (ghoApplication <> 0) Begin
91968>>>>>            Send Show_WorkSpaceInformation
91969>>>>>            Send Show_HelpFile
91970>>>>>            Send AppendTextLn ""
91971>>>>>        End
91971>>>>>>
91971>>>>>        Else Begin
91972>>>>>            Send AppendTextLn ""
91973>>>>>        End
91973>>>>>>
91973>>>>>
91973>>>>>        If (ghoConnection <> 0) Begin
91975>>>>>            Send Show_ConnectionIdInformation
91976>>>>>        End
91976>>>>>>
91976>>>>>        
91976>>>>>        Send Show_Current_User
91977>>>>>        Send Show_Windows_Directory
91978>>>>>        Send Show_Current_Directory
91979>>>>>
91979>>>>>        // This is already shown in the workspace details,
91979>>>>>        // unless no workspace object is present:
91979>>>>>        If (ghoApplication = 0) Begin
91981>>>>>            Send Show_Filelist_Name
91982>>>>>        End
91982>>>>>>
91982>>>>>
91982>>>>>        If (ghoApplication <> 0) Begin
91984>>>>>            Send AppendTextLn ""
91985>>>>>            Send Show_EnterAsTab
91986>>>>>        End
91986>>>>>>
91986>>>>>
91986>>>>>        Send Show_Versions
91987>>>>>        Send Show_Screen_Size
91988>>>>>        Send Show_Page_Size
91989>>>>>        Send Show_Number_Format
91990>>>>>        Send Show_Date_Format
91991>>>>>        Send Show_Lock_Delay
91992>>>>>        Send Show_Lock_Timeout
91993>>>>>        Send Show_Date
91994>>>>>        Send Show_Systemresources
91995>>>>>        Send Beginning_of_Data
91996>>>>>
91996>>>>>        Set Icon to 'default.ico'
91997>>>>>    End_Procedure
91998>>>>>End_Class
