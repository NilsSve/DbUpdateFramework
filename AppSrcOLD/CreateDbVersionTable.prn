86907>>>    Procedure SetAllIndexesToBatch Handle hTable
86909>>>        Integer iLastIndex iIndex iNumSegments iIndexType
86909>>>        String sTable
86909>>>    
86909>>>        If (hTable > 0) Begin
86911>>>            Close hTable
86912>>>            Open hTable Mode DF_EXCLUSIVE
86914>>>            Get_Attribute DF_FILE_LAST_INDEX_NUMBER of hTable to iLastIndex
86917>>>            for iIndex from 1 to iLastIndex
86923>>>>
86923>>>                Get_Attribute DF_INDEX_NUMBER_SEGMENTS of hTable iIndex to iNumSegments
86926>>>                If (iNumSegments > 0) Begin
86928>>>                    Set_Attribute DF_INDEX_TYPE of hTable iIndex to DF_INDEX_TYPE_BATCH
86931>>>                End
86931>>>>
86931>>>            Loop
86932>>>>
86932>>>            Close hTable
86933>>>        End
86933>>>>
86933>>>    End_Procedure 
86934>>>    
86934>>>
86934>>>    // The bANSI parameter's default value = True, meaning a table in ANSI format will be created.
86934>>>    // i.e. DF_FILE_TABLE_CHARACTER_FORMAT {"OEM"|"ANSI"}
86934>>>    Function ApiTableCreate Handle hTable String sRoot String sDisplay String sTableName Boolean bUseConnectionID Boolean bANSI Boolean bRecnum Returns Boolean
86936>>>        Handle hFile
86936>>>        String sConnectionID sPhysicalFile sANSI_OEM sVal sSchema sOriginalDriverID sDriverID
86936>>>        Integer iColumn 
86936>>>        Boolean bOk bExists bMertechDriver
86936>>>        tSQLConnection SQLConnection
86936>>>        tSQLConnection SQLConnection
86936>>>
86936>>>        If (ghoProgressBar <> 0) Begin
86938>>>            Send DoAdvance of ghoProgressBar
86939>>>        End
86939>>>>
86939>>>        
86939>>>        // First check if the passed filenumber already exists; in case we do nothing
86939>>>        Get UtilTableNumberIsInUse hTable to bOk
86940>>>        If (bOk = True) Begin
86942>>>            Function_Return False
86943>>>        End
86943>>>>
86943>>>        
86943>>>        Get psDriverID to sDriverID
86944>>>        // If this is a SQL based driver we also check if the table exists
86944>>>        // in the SQL back end; in case we do nothing.
86944>>>        Get IsSQLDriver sDriverID to bOk
86945>>>        If (bOk = True) Begin
86947>>>            Get SqlUtilCheckIfTableHandleExists hTable sDriverID to bExists
86948>>>            If (bExists = True) Begin
86950>>>                Function_Return False
86951>>>            End                      
86951>>>>
86951>>>        
86951>>>            // Get all connection properties
86951>>>            Get pSQLConnection of ghoSQLConnectionHandler to SQLConnection  
86952>>>            Move SQLConnection.sSchema to sSchema
86953>>>            If (sSchema = "") Begin
86955>>>                Get _SqlFindKeyWord CI_SQLDBO to sSchema  
86956>>>            End
86956>>>>
86956>>>        End
86956>>>>
86956>>>        
86956>>>        Move CS_ANSI_Txt to sANSI_OEM
86957>>>        If (num_arguments > 6) Begin
86959>>>            If (bANSI = False) Begin
86961>>>                Move CS_OEM_Txt to sANSI_OEM
86962>>>            End
86962>>>>
86962>>>        End  
86962>>>>
86962>>>        
86962>>>        // Mertech drivers don't use connection id's, so if the passed bUseConnectionID = True that
86962>>>        // is a programmer's error and we auto-correct for it here.
86962>>>        // This is also a bit messy. If a Mertech driver is used and we want to create a new table,
86962>>>        // we first need to create it as embedded (DataFlex) and then convert it to SQL (!)
86962>>>        // So we set the driver ID temporarily to "DataFlex" to get the table created as embedded and later
86962>>>        // set it back and use a Mertech function to convert it to SQL.
86962>>>        Get IsMertechDriver sDriverID to bMertechDriver
86963>>>        If (bMertechDriver = True) Begin
86965>>>            If (bUseConnectionID = True) Begin
86967>>>                Move False to bUseConnectionID
86968>>>            End
86968>>>>
86968>>>            Move sDriverID to sOriginalDriverID
86969>>>            Move DATAFLEX_ID to sDriverID
86970>>>        End
86970>>>>
86970>>>            
86970>>>        Move False to Err
86971>>>        If (sDriverID = DATAFLEX_ID) Begin
86973>>>            Move sRoot to sPhysicalFile 
86974>>>        End
86974>>>>
86974>>>        
86974>>>        If (sDriverID <> DATAFLEX_ID) Begin 
86976>>>            Move SQLConnection.sConnectionID to sConnectionID
86977>>>            
86977>>>            // If DAW driver and we should use a connection id we need to
86977>>>            // check if the connection ID exists; else we create it before attempting creating the table
86977>>>            If (bMertechDriver = False and bUseConnectionID = True) Begin
86979>>>                Get IsConnectionID sConnectionID sDriverID to bExists
86980>>>                If (bExists = False) Begin
86982>>>                    Get UtilCreateConnectionID sConnectionID to bOk
86983>>>                    If (bOk = False) Begin
86985>>>                        Error DFERR_PROGRAM ("The Connection ID:" * sConnectionID * "could not be created and therefor the table can't be created.")
86986>>>>
86986>>>                        Function_Return False
86987>>>                    End
86987>>>>
86987>>>                End
86987>>>>
86987>>>            End
86987>>>>
86987>>>            
86987>>>            Move (sRoot + ".int") to sPhysicalFile
86988>>>            Move (Uppercase(sDisplay)) to sVal
86989>>>            If (not(sVal contains (sSchema + "."))) Begin    
86991>>>                Move (Lowercase(sSchema) + "." + sTableName) to sDisplay
86992>>>            End                                       
