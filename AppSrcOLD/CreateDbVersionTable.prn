89747>>>        
89747>>>    // Returns the integer number for the passed Driver ID that is 
89747>>>    // needed by some database API calls.
89747>>>    Function DriverIndex String sDriverID Returns Integer
89749>>>        String  sCurrentDriver
89749>>>        Integer iNumberOfDrivers iDriver iCount
89749>>>    
89749>>>        Move 0 to iDriver
89750>>>    
89750>>>        Get_Attribute DF_NUMBER_DRIVERS to iNumberOfDrivers
89753>>>        for iCount from 1 to iNumberOfDrivers
89759>>>>
89759>>>    
89759>>>            Get_Attribute DF_DRIVER_NAME of iCount to sCurrentDriver
89762>>>            If ( Uppercase(sCurrentDriver) = Uppercase(sDriverID) ) Begin
89764>>>                Move iCount to iDriver
89765>>>            End
89765>>>>
89765>>>        Loop
89766>>>>
89766>>>        
89766>>>        // In case it was not found, it wasn't loaded so we do that now.
89766>>>        If (iDriver = 0) Begin
89768>>>            Move False to Err
89769>>>            Load_Driver sDriverID
89770>>>            If (Err = False) Begin
89772>>>                Move 1 to iDriver
89773>>>            End
89773>>>>
89773>>>        End
89773>>>>
89773>>>    
89773>>>        Function_Return iDriver
89774>>>    End_Function 
89775>>>    
89775>>>    // Scans to see if all tables can be opened exclusivly. I.e. that nobody else is running the application.
89775>>>    // Returns: False if nobody else is running
89775>>>    //          True if at least one table is open by another process (e.g. another user is running the application) 
89775>>>    // N.B! Only works for Embedded DataFlex Tables! It will _not_ work for Sql tables because; these
89775>>>    //      tables are not locked as DataFlex tables are.
89775>>>    Function IsDatabaseInUse Returns Boolean
89777>>>        Handle  hTable
89777>>>        Integer iTemp
89777>>>        String  sRootName sOrgOpenPath sOrgFileList
89777>>>        Boolean bOpen bErr bAlias bOK bIsSQLTable
89777>>>
89777>>>        Get AutoConnectionIDLogin to bOK
89778>>>        Move 0 to hTable
89779>>>        Get_Attribute DF_FILE_NEXT_USED of hTable to hTable
89782>>>        Move False to bErr
89783>>>        Send Ignore_Error of Error_Object_Id DFERR_FILE_ACCESS_VIOLATION
89784>>>
89784>>>        Repeat
89784>>>>
89784>>>            Get_Attribute DF_FILE_ROOT_NAME of hTable to sRootName
89787>>>            
89787>>>            // This test is only applicable for DataFlex embedded tables; so skip test if driver based table.
89787>>>            Get UtilTableIsSQLByRootName sRootName to bIsSQLTable
89788>>>            Move False to bOpen
89789>>>            
89789>>>            // Don't bother about FlexErrs (Table 50)
89789>>>            If (bIsSQLTable = False and hTable <> 0 and hTable <> 50) Begin
89791>>>                Set Error_Report_Mode to DUF_ERROR_NO_REPORT
89792>>>                Open hTable 
89794>>>                Get_Attribute DF_FILE_OPENED of hTable to bOpen
89797>>>                Set Error_Report_Mode to DUF_ERROR_REPORT
89798>>>                If (bOpen = True) Begin                        
89800>>>                    // We cannot open an Alias file exclusive as it will generate an error (4177 - "File in use")
89800>>>                    Get UtilTableIsAlias hTable to bAlias
89801>>>                    If (bAlias = False) Begin
89803>>>                        Open hTable mode DF_EXCLUSIVE   
89805>>>                        Get_Attribute DF_FILE_OPENED of hTable to bOpen
89808>>>                        If (bOpen = False) Begin
89810>>>                            Move True to bErr
89811>>>                        End
89811>>>>
89811>>>                    End
89811>>>>
89811>>>                End
89811>>>>
89811>>>            End
89811>>>>
89811>>>            Get_Attribute DF_FILE_NEXT_USED of hTable to hTable
89814>>>            If (bOpen = False) Break
89817>>>        Until (not(hTable))
89819>>>
89819>>>        Send Trap_Error of Error_Object_Id DFERR_FILE_ACCESS_VIOLATION
89820>>>        Move False to Err
89821>>>        
89821>>>        Function_Return bErr
89822>>>    End_Function  
89823>>>    
89823>>>    // Checks if the passed connection id exists in the CLI interface.
89823>>>    // This might be needed by API-methods when a connection id is to be used and
89823>>>    // the connection id hasn't been established with the driver's CLI interface.
89823>>>    // NOTE: Only applicable for DAW drivers.
89823>>>    Function IsConnectionID String sConnectionID String sDriverID Returns Boolean
89825>>>        String sID 
89825>>>        Integer iDriver iNumConn iCount
89825>>>        Handle hoCLI                                            
89825>>>        Boolean bOK
89825>>>        
89825>>>        Get IsDAWSQLDriver sDriverID to bOK
89826>>>        If (bOK = False) Begin
89828>>>            Error DFERR_PROGRAM "Connection ID's can only be used with DAW drivers (not Mertech)."
89829>>>>
89829>>>            Function_Return False
89830>>>        End
89830>>>>
89830>>>        
89830>>>        Move False to bOK
89831>>>        Get phoCLIHandler to hoCLI 
89832>>>        If (hoCLI <> 0) Begin
89834>>>            Set psDriverID of hoCLI to sDriverID
89835>>>            Get DriverIndex of hoCLI sDriverID to iDriver
89836>>>            
89836>>>            // If driver not loaded; load it.
89836>>>            If (iDriver = 0) Begin
89838>>>                Load_Driver sDriverID
89839>>>                Get DriverIndex sDriverID to iDriver
89840>>>            End                      
89840>>>>
89840>>>            If (iDriver <> 0) Begin
89842>>>                Get_Attribute DF_DRIVER_NUMBER_CONNECTION_IDS of iDriver to iNumConn
89845>>>                Decrement iNumConn
89846>>>                For iCount from 0 to iNumConn
89852>>>>
89852>>>                    Get_Attribute DF_DRIVER_CONNECTION_ID of iDriver iCount to sID
89855>>>                    If (sID = sConnectionID) Move True to bOK
89858>>>                Loop
89859>>>>
89859>>>            End
89859>>>>
89859>>>        End
89859>>>>
89859>>>        
89859>>>        Function_Return bOK
89860>>>    End_Function                   
89861>>>    
89861>>>    Function IsDAWSQLDriver String sDriverID Returns Boolean
89863>>>        Boolean bOK
89863>>>        Move (sDriverID = MSSQLDRV_ID or sDriverID = DB2_DRV_ID or sDriverID = ODBC_DRV_ID) to bOK
89864>>>        Function_Return bOK
89865>>>    End_Function
89866>>>
89866>>>    Function IsMertechDriver String sDriverID Returns Boolean
89868>>>        Boolean bOK
89868>>>        Move False to bOK
89869>>>        Move (sDriverID = SQLFLEX or sDriverID = ORAFLEX or sDriverID = MDSPgSQL or sDriverID = MDSMySQL) to bOK
89870>>>        Function_Return bOK
89871>>>    End_Function
89872>>>            
