87658>>>    // To delete an index
87658>>>    Function ApiIndexRemove Handle hTable Integer iIndex Returns Boolean
87660>>>        Integer iTableNo iNumSegments
87660>>>        String sDriverID
87660>>>        Boolean bOK
87660>>>        
87660>>>        Get AutoConnectionIDLogin to bOK
87661>>>        Move False to Err
87662>>>        Move hTable to iTableNo
87663>>>        Open hTable Mode DF_EXCLUSIVE
87665>>>        Get_Attribute DF_FILE_DRIVER of hTable to sDriverID
87668>>>        
87668>>>        // Check to see if the index exists or not...
87668>>>        Get_Attribute DF_INDEX_NUMBER_SEGMENTS of hTable iIndex to iNumSegments
87671>>>        If (iNumSegments = 0) Begin
87673>>>            Function_Return False
87674>>>        End
87674>>>>
87674>>>        
87674>>>        Structure_Start hTable sDriverID
87675>>>            Send Ignore_Error of Error_Object_Id DFERR_BAD_PARAMETER
87676>>>            Delete_Index iTableNo iIndex
87677>>>            Send Trap_Error of Error_Object_Id DFERR_BAD_PARAMETER
87678>>>        Structure_End hTable DF_STRUCTEND_OPT_NONE
87680>>>
87680>>>        Function_Return (Err = False)
87681>>>    End_Function
